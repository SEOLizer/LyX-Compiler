// Test StrCharAt
fn main(): int64 {
  var s: pchar := "Hello World";
  
  // Test einzelne Zeichen
  var c0: int64 := StrCharAt(s, 0);  // 'H'
  var c1: int64 := StrCharAt(s, 1);  // 'e'
  var c5: int64 := StrCharAt(s, 5);  // ' '
  var c10: int64 := StrCharAt(s, 10); // 'd'
  
  PrintStr("c0 = ");
  PrintInt(c0);
  PrintStr(" (expected 72)\n");
  
  PrintStr("c1 = ");
  PrintInt(c1);
  PrintStr(" (expected 101)\n");
  
  PrintStr("c5 = ");
  PrintInt(c5);
  PrintStr(" (expected 32)\n");
  
  PrintStr("c10 = ");
  PrintInt(c10);
  PrintStr(" (expected 100)\n");
  
  return 0;
}