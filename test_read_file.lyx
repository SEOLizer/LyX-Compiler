// Minimal test - just read a file and print it
fn main(): int64 {
  var content: int64 := FileReadAll("compiler/lyxc.lpr" as pchar);
  if content == 0 {
    PrintStr("FileReadAll failed\n");
    return 1;
  }
  
  var len: int64 := StrLen(content);
  PrintStr("File length: ");
  PrintInt(len);
  PrintStr("\n");
  
  // Print first 50 chars
  PrintStr("First 50 chars: ");
  var i: int64 := 0;
  while i < 50 {
    if i >= len { break; }
    var c: int64 := peek8(content + i);
    if c == 0 { break; }
    PrintInt(c);
    PrintStr(" ");
    i := i + 1;
  }
  PrintStr("\n");
  
  return 0;
}