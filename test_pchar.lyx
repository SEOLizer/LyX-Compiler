// Test pchar handling
fn main(): int64 {
  // Create a buffer on heap
  var buf: int64 := mmap(0, 32, 3, 34, -1, 0);
  
  // Put "Hello" in it
  poke8(buf + 0, 72);
  poke8(buf + 1, 101);
  poke8(buf + 2, 108);
  poke8(buf + 3, 108);
  poke8(buf + 4, 111);
  poke8(buf + 5, 0);
  
  // Cast to pchar
  var s: pchar := buf as pchar;
  
  // Try to print as string - this calls PrintStr which might use pchar
  PrintStr("As string: ");
  PrintStr(s);
  PrintStr("\n");
  
  // Try direct print of each char
  PrintStr("As bytes: ");
  var i: int64 := 0;
  while i < 5 {
    var c: int64 := peek8(buf + i);
    PrintInt(c);
    PrintStr(" ");
    i := i + 1;
  }
  PrintStr("\n");
  
  munmap(buf, 32);
  return 0;
}