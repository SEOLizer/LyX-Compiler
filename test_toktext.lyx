// Simulate lexer TokText functionality
pub fn testTokText(src: int64, start: int64, len: int64): int64 {
  // This mimics what TokText does: StrSub(self.src, self.tokStart, self.tokLen)
  return StrSub(src, start, len);
}

fn main(): int64 {
  // Create source string
  var src: int64 := mmap(0, 64, 3, 34, -1, 0);
  
  // Put "Hello World" in it
  var msg: int64 := 72; // H
  poke8(src + 0, msg);
  poke8(src + 1, 101); // e
  poke8(src + 2, 108); // l
  poke8(src + 3, 108); // l
  poke8(src + 4, 111); // o
  poke8(src + 5, 32);  // space
  poke8(src + 6, 87);  // W
  poke8(src + 7, 111); // o
  poke8(src + 8, 114); // r
  poke8(src + 9, 108); // l
  poke8(src + 10, 100); // d
  poke8(src + 11, 0);
  
  PrintStr("Source: ");
  var i: int64 := 0;
  while i < 11 {
    PrintInt(peek8(src + i));
    PrintStr(" ");
    i := i + 1;
  }
  PrintStr("\n");
  
  // Test TokText - get token at position 0, length 5 -> "Hello"
  var token: int64 := testTokText(src, 0, 5);
  PrintStr("Token (Hello): ");
  var j: int64 := 0;
  while j < 5 {
    PrintInt(peek8(token + j));
    PrintStr(" ");
    j := j + 1;
  }
  PrintStr("\n");
  
  // Test TokText - get token at position 6, length 5 -> "World"
  var token2: int64 := testTokText(src, 6, 5);
  PrintStr("Token (World): ");
  var k: int64 := 0;
  while k < 5 {
    PrintInt(peek8(token2 + k));
    PrintStr(" ");
    k := k + 1;
  }
  PrintStr("\n");
  
  munmap(src, 64);
  return 0;
}