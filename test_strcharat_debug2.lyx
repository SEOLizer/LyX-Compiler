// Test to verify StrCharAt works in isolation
fn main(): int64 {
  // Create string on heap
  var buf: int64 := mmap(0, 32, 3, 34, -1, 0);
  poke8(buf + 0, 72);  // 'H'
  poke8(buf + 1, 101); // 'e'
  poke8(buf + 2, 108); // 'l'
  poke8(buf + 3, 108); // 'l'
  poke8(buf + 4, 111); // 'o'
  poke8(buf + 5, 0);
  
  // Test 1: Direct character access via peek8
  PrintStr("peek8 test: ");
  PrintInt(peek8(buf + 0));
  PrintStr(" ");
  PrintInt(peek8(buf + 1));
  PrintStr(" ");
  PrintInt(peek8(buf + 2));
  PrintStr("\n");
  
  // Test 2: Using StrCharAt 
  // Note: This might fail if StrCharAt is broken in S1
  PrintStr("StrCharAt test: ");
  
  // Try to call StrCharAt via a wrapper to see if it works
  var c1: int64 := 0;
  //c1 := StrCharAt(buf, 0);  // Commented out to avoid crash
  
  PrintStr("before StrCharAt\n");
  c1 := StrCharAt(buf, 0);
  PrintStr("after StrCharAt, result: ");
  PrintInt(c1);
  PrintStr("\n");
  
  munmap(buf, 32);
  return 0;
}