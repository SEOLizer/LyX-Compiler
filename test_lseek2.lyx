// Test with absolute path
fn main(): int64 {
  var path: int64 := StrConcat("/home/andreas/PhpstormProjects/aurum/" as pchar, "test_selfhost_minimal.lyx" as pchar);
  
  var fd: int64 := open(path, 0, 0);
  PrintStr("open returned: ");
  PrintInt(fd);
  PrintStr("\n");
  
  if fd < 0 {
    PrintStr("open failed\n");
    return 1;
  }
  
  var size: int64 := lseek(fd, 0, 2);
  PrintStr("lseek to end: ");
  PrintInt(size);
  PrintStr("\n");
  
  close(fd);
  
  return 0;
}