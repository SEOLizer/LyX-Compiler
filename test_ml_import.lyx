// Test ML Import
import std.io;
import std.ml;

pub fn main(): int64 {
  // Linear Regression Test: y = 2x + 1
  LinearRegressionInit();
  LinearRegressionFit2(1.0, 2.0, 3.0, 5.0, 0.1, 100);
  
  PrintStr("Linear Regression Test\n");
  PrintStr("Weight: ");
  PrintFloat(LinearRegressionWeight());
  PrintStr("\nBias: ");
  PrintFloat(LinearRegressionBias());
  PrintStr("\nLoss: ");
  PrintFloat(LinearRegressionLoss());
  PrintStr("\nEpochs: ");
  PrintInt(LinearRegressionEpochs());
  PrintStr("\nPredict(5): ");
  PrintFloat(LinearRegressionPredict(5.0));
  PrintStr("\n");
  
  // Logistic Regression Test
  LogisticRegressionInit();
  LogisticRegressionFit2(1.0, 2.0, 0.0, 1.0, 0.1, 100);
  
  PrintStr("\nLogistic Regression Test\n");
  PrintStr("Weight: ");
  PrintFloat(LogisticRegressionWeight());
  PrintStr("\nAccuracy: ");
  PrintFloat(LogisticRegressionAccuracy());
  PrintStr("\nPredictProb(2.5): ");
  PrintFloat(LogisticRegressionPredictProb(2.5));
  PrintStr("\nPredict(2.5): ");
  PrintInt(LogisticRegressionPredict(2.5));
  PrintStr("\n");
  
  return 0;
}