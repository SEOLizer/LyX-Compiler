// std/os.lyx
// Operating system utilities

// ============================================================================
// External libc functions
// ============================================================================

extern fn getenv(name: pchar): pchar;
extern fn setenv(name: pchar, val: pchar, overwrite: int64): int64;
extern fn unsetenv(name: pchar): int64;
extern fn getcwd(buf: pchar, size: int64): pchar;
extern fn chdir(path: pchar): int64;
extern fn getpid(): int64;
extern fn getuid(): int64;
extern fn sysconf(name: int64): int64;
extern fn time(tloc: int64): int64;
extern fn getppid(): int64;
