con SC_CLK_TCK: int64 := 2;
con SC_PAGESIZE: int64 := 47;

// ============================================================================
// Sleep Functions
// ============================================================================

pub fn sleep(milliseconds: int64): void {
  if (milliseconds <= 0) {
    return;
  }
  var i: int64 := 0;
  var spinCount: int64 := milliseconds * 10000;
  while (i < spinCount) {
    i := i + 1;
  }
}

pub fn sleep_seconds(seconds: int64): void {
  sleep(seconds * 1000);
}

pub fn sleep_microseconds(microseconds: int64): void {
  if (microseconds <= 0) {
    return;
  }
  var us999: int64 := microseconds + 999;
  var millis: int64 := us999 / 1000;
  sleep(millis);
}

