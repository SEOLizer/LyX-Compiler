// ============================================================================
// User Information
// ============================================================================

pub fn get_home_dir(): pchar {
  var home: pchar := env_get("HOME");
  if (home != "") {
    return home;
  }
  return "";
}

pub fn get_temp_dir(): pchar {
  var tmp: pchar := env_get("TMPDIR");
  if (tmp != "") {
    return tmp;
  }
  return "/tmp";
}

pub fn get_user_name(): pchar {
  var user: pchar := env_get("USER");
  if (user != "") {
    return user;
  }
  return "";
}

// ============================================================================
// Path Utilities
// ============================================================================

pub fn path_filename(path: pchar): pchar {
  if (path == 0) {
    return "";
  }
  var i: int64 := 0;
  var last_slash: int64 := -1;
  while (path[i] != 0) {
    if (path[i] == 47) {
      last_slash := i;
    }
    i := i + 1;
  }
  if (last_slash < 0) {
    return path;
  }
  return path + last_slash + 1;
}

pub fn path_dirname(path: pchar): pchar {
  return "";
}

pub fn path_is_absolute(path: pchar): bool {
  if (path == 0) {
    return false;
  }
  return path[0] == 47;
}

