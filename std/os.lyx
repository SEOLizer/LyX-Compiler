// exec(path, a0..a4): fork + execve + wait4
// Returns exit status of child, or -1 on error.
// Pass "" for unused args (a1..a4).
pub fn exec(path: pchar, a0: pchar, a1: pchar, a2: pchar, a3: pchar): int64 {
  PrintStr("exec:A\n");
  // Build argv[] array in anonymous mmap: 6 pointers x 8 bytes = 48 bytes
  var argv: int64 := mmap(0, 48, 3, 34, -1, 0);
  PrintStr("exec:B argv=");
  PrintInt(argv);
  PrintStr("\n");
  if (argv == 0) {
    return -1;
  }
  poke64(argv + 0,  path as int64);
  PrintStr("exec:C poke0 done\n");
  poke64(argv + 8,  a0   as int64);
  PrintStr("exec:D poke1 done\n");
  poke64(argv + 16, a1   as int64);
  poke64(argv + 24, a2   as int64);
  poke64(argv + 32, a3   as int64);
  poke64(argv + 40, 0);
  PrintStr("exec:E all pokes done\n");

  var pid: int64 := sys_fork();
  PrintStr("exec:F pid=");
  PrintInt(pid);
  PrintStr("\n");
  if (pid < 0) {
    munmap(argv, 48);
    return -1;
  }
  if (pid == 0) {
    sys_execve(path, argv, 0);
    os_exit(127);
  }
  PrintStr("exec:G parent waiting\n");
  var status: int64 := mmap(0, 8, 3, 34, -1, 0);
  PrintStr("exec:H status=");
  PrintInt(status);
  PrintStr("\n");
  var ret: int64 := sys_wait4(pid, status, 0);
  PrintStr("exec:I wait done ret=");
  PrintInt(ret);
  PrintStr("\n");
  var exitCode: int64 := (peek64(status) >> 8) & 255;
  munmap(status, 8);
  munmap(argv, 48);
  PrintStr("exec:J done\n");
  return exitCode;
}

