}

// ============================================================================
// System Information
// ============================================================================

pub fn get_num_cores(): int64 {
  var cores: int64 := sysconf(SC_CLK_TCK);
  if (cores <= 0) {
    return 1;
  }
  return cores;
}

pub fn get_page_size(): int64 {
  var pagesize: int64 := sysconf(SC_PAGESIZE);
  if (pagesize <= 0) {
    return 4096;
  }
  return pagesize;
}

