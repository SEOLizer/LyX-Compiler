// Lyx QUIC Module - RFC 9000 (QUIC v1) Protocol Framework
// QUIC transport protocol with integrated TLS 1.3 encryption
//
// QUIC runs over UDP (typically port 443) and provides:
// - Reliable, multiplexed streams
// - Built-in TLS 1.3 encryption
// - Connection migration
// - 0-RTT connection establishment
// - Congestion control
//
// Note: Full QUIC requires TLS 1.3 integration.
// This module provides the packet structure and framing.
// For production use, OpenSSL 3.2+ or a dedicated QUIC library
// (quiche, ngtcp2, msquic) is recommended.
//
// Usage:
//   import std.net.quic;
//   var conn: QUICConn := QUICConnect("server.example.com", 443);
//   var stream: QUICStream := QUICOpenStream(conn);
//   QUICStreamWrite(stream, data, len);
//   var n: int64 := QUICStreamRead(stream, buf, bufsize);
//   QUICCloseStream(stream);
//   QUICDisconnect(conn);

