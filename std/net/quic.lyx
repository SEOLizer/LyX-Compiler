// QUIC connection
pub type QUICConn = struct {
  sock: UDPSocket;         // UDP socket
  connected: int64;        // 1 if connection established
  localConnId: int64;      // Pointer to local connection ID (8 bytes)
  remoteConnId: int64;     // Pointer to remote connection ID (8 bytes)
  nextStreamId: int64;     // Next stream ID to allocate
  packetNumber: int64;     // Current packet number
};

// QUIC stream
pub type QUICStream = struct {
  conn: int64;             // Pointer to connection
  streamId: int64;         // Stream identifier
  state: int64;            // Stream state
  offset: int64;           // Current send offset
};

// QUIC packet header
pub type QUICPacketHeader = struct {
  headerForm: int64;       // 0 = short, 1 = long
  fixedBit: int64;         // Always 1
  packetType: int64;       // Packet type (long header)
  typeSpecific: int64;     // Type-specific bits
  version: int64;          // QUIC version (long header)
  destConnIdLen: int64;    // Destination connection ID length
  destConnId: int64;       // Pointer to destination connection ID
  srcConnIdLen: int64;     // Source connection ID length
  srcConnId: int64;        // Pointer to source connection ID
  packetNumber: int64;     // Packet number
  payloadLen: int64;       // Payload length
};

// Generate pseudo-random bytes using LCG
pub fn QUICRandomBytes(buf: int64, len: int64) {
  var i: int64 := 0;
  var rng: int64 := 0x12345678;
  while (i < len) {
    rng := rng * 1664525 + 1013904223;
    var rbyte: int64 := rng & 255;
    poke8(buf + i, rbyte);
    i := i + 1;
  }
}

// Encode variable-length integer (QUIC varint encoding)
// Returns number of bytes written
pub fn QUICWriteVarint(buf: int64, pos: int64, value: int64): int64 {
  if (value < 64) {
    // 1-byte: 00xxxxxx
    poke8(buf + pos, value);
    return 1;
  }
  else if (value < 16384) {
    // 2-byte: 01xxxxxxxxxxxxxx
    poke8(buf + pos, (value / 256) + 64);
    poke8(buf + pos + 1, value - (value / 256) * 256);
    return 2;
  }
  else if (value < 1073741824) {
    // 4-byte: 10xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
    poke8(buf + pos, (value / 16777216) + 128);
    var rem: int64 := value - (value / 16777216) * 16777216;
    poke8(buf + pos + 1, rem / 65536);
    rem := rem - (rem / 65536) * 65536;
    poke8(buf + pos + 2, rem / 256);
    poke8(buf + pos + 3, rem - (rem / 256) * 256);
    return 4;
  }
  else {
    // 8-byte: 11xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
    poke8(buf + pos, (value / 72057594037927936) + 192);
    var rem: int64 := value - (value / 72057594037927936) * 72057594037927936;
    poke8(buf + pos + 1, rem / 281474976710656);
    rem := rem - (rem / 281474976710656) * 281474976710656;
    poke8(buf + pos + 2, rem / 1099511627776);
    rem := rem - (rem / 1099511627776) * 1099511627776;
    poke8(buf + pos + 3, rem / 4294967296);
    rem := rem - (rem / 4294967296) * 4294967296;
    poke8(buf + pos + 4, rem / 16777216);
    rem := rem - (rem / 16777216) * 16777216;
    poke8(buf + pos + 5, rem / 65536);
    rem := rem - (rem / 65536) * 65536;
    poke8(buf + pos + 6, rem / 256);
    poke8(buf + pos + 7, rem - (rem / 256) * 256);
    return 8;
  }
}

// Decode variable-length integer
// Returns decoded value
pub fn QUICReadVarint(buf: int64, pos: int64): int64 {
  var first: int64 := peek8(buf + pos);
  var prefix: int64 := first / 64;  // Top 2 bits
  
  if (prefix == 0) {
    // 1-byte
    return first - (first / 64) * 64;
  }
  else if (prefix == 1) {
    // 2-byte
    return ((first - 64) * 256) + peek8(buf + pos + 1);
  }
  else if (prefix == 2) {
    // 4-byte
    var val: int64 := (first - 128) * 16777216;
    val := val + (peek8(buf + pos + 1) * 65536);
    val := val + (peek8(buf + pos + 2) * 256);
    val := val + peek8(buf + pos + 3);
    return val;
  }
  else {
    // 8-byte
    var val: int64 := (first - 192) * 72057594037927936;
    val := val + (peek8(buf + pos + 1) * 281474976710656);
    val := val + (peek8(buf + pos + 2) * 1099511627776);
    val := val + (peek8(buf + pos + 3) * 4294967296);
    val := val + (peek8(buf + pos + 4) * 16777216);
    val := val + (peek8(buf + pos + 5) * 65536);
    val := val + (peek8(buf + pos + 6) * 256);
    val := val + peek8(buf + pos + 7);
    return val;
  }
}

// Get bytes consumed by varint at position
pub fn QUICVarintSize(buf: int64, pos: int64): int64 {
  var first: int64 := peek8(buf + pos);
  var prefix: int64 := first / 64;
  
  if (prefix == 0) {
    return 1;
  }
  else if (prefix == 1) {
    return 2;
  }
  else if (prefix == 2) {
    return 4;
  }
  else {
    return 8;
  }
}

// Build QUIC Initial packet
// destConnId: pointer to destination connection ID
// srcConnId: pointer to source connection ID
// token: token (0 for initial)
// Returns pointer to packet (caller must free)
pub fn QUICBuildInitialPacket(destConnId: int64, destLen: int64, srcConnId: int64, srcLen: int64): int64 {
  var buf: int64;
  var pos: int64;
  var headerByte: int64;
  var i: int64;
  
  buf := mmap(0, QUIC_MAX_PACKET_SIZE, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    return 0;
  }
  
  pos := 0;
  
  // Long header: 1 (header form) + 1 (fixed bit) + 2 (packet type) + 4 (type-specific)
  // = 1100 0000 = 0xC0 for Initial
  headerByte := $C0 + QUIC_PKT_INITIAL;
  poke8(buf + pos, headerByte);
  pos := pos + 1;
  
  // Version (4 bytes, big-endian)
  var ver: int64 := QUIC_VERSION_1;
  poke8(buf + pos, (ver / 16777216) - ((ver / 4294967296) * 256));
  poke8(buf + pos + 1, (ver / 65536) - ((ver / 16777216) * 256));
  poke8(buf + pos + 2, (ver / 256) - ((ver / 65536) * 256));
  poke8(buf + pos + 3, ver - ((ver / 256) * 256));
  pos := pos + 4;
  
  // Destination connection ID length + ID
  poke8(buf + pos, destLen);
  pos := pos + 1;
  if (destConnId != 0) {
    i := 0;
    while (i < destLen) {
      poke8(buf + pos + i, peek8(destConnId + i));
      i := i + 1;
    }
  }
  pos := pos + destLen;
  
  // Source connection ID length + ID
  poke8(buf + pos, srcLen);
  pos := pos + 1;
  if (srcConnId != 0) {
    i := 0;
    while (i < srcLen) {
      poke8(buf + pos + i, peek8(srcConnId + i));
      i := i + 1;
    }
  }
  pos := pos + srcLen;
  
  // Token length (0 for initial)
  pos := pos + QUICWriteVarint(buf, pos, 0);
  
  // Length (placeholder - will be filled with encryption)
  var lengthPos: int64 := pos;
  pos := pos + QUICWriteVarint(buf, pos, 0);
  
  // Packet number (1 byte for simplicity)
  poke8(buf + pos, 0);
  pos := pos + 1;
  
  // CRYPTO frame (empty for now - would contain TLS ClientHello)
  // In production, this would contain the TLS 1.3 ClientHello
  // wrapped in a CRYPTO frame
  pos := pos + QUICWriteVarint(buf, pos, QUIC_FRAME_CRYPTO);
  pos := pos + QUICWriteVarint(buf, pos, 0);  // offset
  pos := pos + QUICWriteVarint(buf, pos, 0);  // length
  
  return buf;
}

// Build QUIC STREAM frame
// streamId: stream identifier
// data: pointer to data
// dataLen: data length
// fin: 1 if this is the final segment
// Returns pointer to frame (caller must free)
pub fn QUICBuildStreamFrame(streamId: int64, data: int64, dataLen: int64, fin: int64): int64 {
  var buf: int64;
  var pos: int64;
  var i: int64;
  var frameType: int64;
  
  var streamSz: int64 := dataLen + 32;
  buf := mmap(0, streamSz, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    return 0;
  }
  
  pos := 0;
  
  // Frame type: STREAM with offset and length
  // Base = $08, bits: OFF=1, LEN=1, FIN=0/1
  frameType := QUIC_FRAME_STREAM_BASE + 2 + 4;  // offset + length
  if (fin == 1) {
    frameType := frameType + 1;  // + FIN bit
  }
  poke8(buf + pos, frameType);
  pos := pos + 1;
  
  // Stream ID
  pos := pos + QUICWriteVarint(buf, pos, streamId);
  
  // Offset (0 for now)
  pos := pos + QUICWriteVarint(buf, pos, 0);
  
  // Length
  pos := pos + QUICWriteVarint(buf, pos, dataLen);
  
  // Data
  if (data != 0) {
    i := 0;
    while (i < dataLen) {
      poke8(buf + pos + i, peek8(data + i));
      i := i + 1;
    }
  }
  pos := pos + dataLen;
  
  return buf;
}

// Build QUIC PADDING frame
pub fn QUICBuildPaddingFrame(len: int64): int64 {
  var buf: int64;
  var i: int64;
  
  buf := mmap(0, len, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    return 0;
  }
  
  i := 0;
  while (i < len) {
    poke8(buf + i, QUIC_FRAME_PADDING);
    i := i + 1;
  }
  
  return buf;
}

// Build QUIC ACK frame
// largestAcked: largest acknowledged packet number
// ackDelay: acknowledgment delay
// Returns pointer to frame (caller must free)
pub fn QUICBuildAckFrame(largestAcked: int64, ackDelay: int64): int64 {
  var buf: int64;
  var pos: int64;
  
  buf := mmap(0, 32, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    return 0;
  }
  
  pos := 0;
  
  // Frame type (ACK = $02)
  poke8(buf + pos, QUIC_FRAME_ACK);
  pos := pos + 1;
  
  // Largest acknowledged
  pos := pos + QUICWriteVarint(buf, pos, largestAcked);
  
  // ACK delay
  pos := pos + QUICWriteVarint(buf, pos, ackDelay);
  
  // ACK range count (0 - single range)
  pos := pos + QUICWriteVarint(buf, pos, 0);
  
  // First ACK range (0 - just largest)
  pos := pos + QUICWriteVarint(buf, pos, 0);
  
  return buf;
}

// Build QUIC CONNECTION_CLOSE frame
// errorCode: error code
// reason: reason phrase (null-terminated)
// Returns pointer to frame (caller must free)
pub fn QUICBuildConnectionClose(errorCode: int64, reason: int64): int64 {
  var buf: int64;
  var pos: int64;
  var reasonLen: int64;
  var i: int64;
  
  reasonLen := 0;
  if (reason != 0) {
    while (peek8(reason + reasonLen) != 0) {
      reasonLen := reasonLen + 1;
    }
  }
  
  var closeSz: int64 := 64 + reasonLen;
  buf := mmap(0, closeSz, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    return 0;
  }
  
  pos := 0;
  
  // Frame type (CONNECTION_CLOSE with transport error = $1C)
  poke8(buf + pos, QUIC_FRAME_CONNECTION_CLOSE);
  pos := pos + 1;
  
  // Error code
  pos := pos + QUICWriteVarint(buf, pos, errorCode);
  
  // Frame type that triggered close (0 = unknown)
  pos := pos + QUICWriteVarint(buf, pos, 0);
  
  // Reason phrase length
  pos := pos + QUICWriteVarint(buf, pos, reasonLen);
  
  // Reason phrase
  i := 0;
  while (i < reasonLen) {
    poke8(buf + pos + i, peek8(reason + i));
    i := i + 1;
  }
  pos := pos + reasonLen;
  
  return buf;
}

// Connect to QUIC server
// Creates UDP socket and prepares for handshake
// Note: Full handshake requires TLS 1.3 integration
pub fn QUICConnect(host: int64, port: int64): QUICConn {
  var conn: QUICConn;
  var sock: UDPSocket;
  var ip: int64;
  
  conn.sock.fd := -1;
  conn.connected := 0;
  conn.localConnId := 0;
  conn.remoteConnId := 0;
  conn.nextStreamId := 0;
  conn.packetNumber := 0;
  
  // Resolve hostname
  ip := GetHostByName(host);
  if (ip == 0) {
    return conn;
  }
  
  // Create UDP socket
  sock := UDPSocketNew();
  if (sock.fd < 0) {
    return conn;
  }
  
  conn.sock := sock;
  
  // Generate local connection ID
  conn.localConnId := mmap(0, QUIC_CONN_ID_LEN, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (conn.localConnId != 0) {
    QUICRandomBytes(conn.localConnId, QUIC_CONN_ID_LEN);
  }
  
  // Generate remote connection ID (initially unknown, set during handshake)
  conn.remoteConnId := mmap(0, QUIC_CONN_ID_LEN, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (conn.remoteConnId != 0) {
    QUICRandomBytes(conn.remoteConnId, QUIC_CONN_ID_LEN);
  }
  
  // Note: Full connection establishment requires:
  // 1. Build TLS 1.3 ClientHello
  // 2. Wrap in CRYPTO frame
  // 3. Pack in Initial packet
  // 4. Send to server
  // 5. Parse server response
  // 6. Complete TLS handshake
  // 7. Transition to 1-RTT encryption
  
  return conn;
}

// Open a new bidirectional stream
pub fn QUICOpenStream(conn: QUICConn): QUICStream {
  var stream: QUICStream;
  
  stream.conn := 0;
  stream.streamId := 0;
  stream.state := 0;
  stream.offset := 0;
  
  if (conn.connected == 0) {
    return stream;
  }
  
  stream.streamId := conn.nextStreamId;
  conn.nextStreamId := conn.nextStreamId + 4;  // Bidi streams are 0, 4, 8, ...
  
  return stream;
}

// Write data to stream (unencrypted - for protocol demonstration)
pub fn QUICStreamWrite(stream: QUICStream, data: int64, len: int64): int64 {
  if (stream.state == 0) {
    return -1;
  }
  
  // In production, this would:
  // 1. Build STREAM frame
  // 2. Encrypt with connection keys
  // 3. Send over UDP
  
  return len;
}

// Read data from stream
pub fn QUICStreamRead(stream: QUICStream, buf: int64, bufsize: int64): int64 {
  if (stream.state == 0) {
    return -1;
  }
  
  // In production, this would:
  // 1. Receive UDP datagram
  // 2. Decrypt with connection keys
  // 3. Parse frames
  // 4. Extract STREAM frame data
  
  return 0;
}

