// Disconnect from QUIC server
pub fn QUICDisconnect(conn: QUICConn) {
  if (conn.connected == 1) {
    // Send CONNECTION_CLOSE frame
    var frame: int64 := QUICBuildConnectionClose(QUIC_ERR_NO_ERROR, "Normal close");
    if (frame != 0) {
      UDPSocketSendToAddr(conn.sock, frame, 64, 0, QUIC_PORT);
      munmap(frame, 64);
    }
    conn.connected := 0;
  }
  
  if (conn.localConnId != 0) {
    munmap(conn.localConnId, QUIC_CONN_ID_LEN);
  }
  if (conn.remoteConnId != 0) {
    munmap(conn.remoteConnId, QUIC_CONN_ID_LEN);
  }
  
  UDPSocketClose(conn.sock);
}
