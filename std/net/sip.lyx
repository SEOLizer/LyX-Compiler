// Disconnect from SIP server
pub fn SIPDisconnect(conn: SIPConn) {
  if (conn.callId != 0) {
    munmap(conn.callId, 33);
  }
  if (conn.sock.fd >= 0) {
    UDPSocketClose(conn.sock);
  }
  conn.connected := 0;
}
