// Lyx SIP Client - RFC 3261 compliant
// Session Initiation Protocol for VoIP, video, and instant messaging
//
// SIP uses UDP or TCP port 5060 (or TLS on 5061)
// The protocol is text-based, similar to HTTP
//
// Message structure:
// - Request line: METHOD sip:user@domain SIP/2.0
// - Status line: SIP/2.0 CODE REASON
// - Headers: Key: Value
// - Empty line (\r\n)
// - Body (usually SDP)
//
// Usage:
//   import std.net.sip;
//   var sip: SIPConn := SIPConnect("sip.example.com", 5060);
//   SIPRegister(sip, "user", "pass", "sip.example.com");
//   SIPSendMessage(sip, "user@domain", "Hello!");
//   SIPDisconnect(sip);

unit std.net.sip;

import std.net.socket;
import std.net.dns;
import std.net.types;

// SIP port
pub con SIP_PORT: int64 := 5060;
pub con SIPS_PORT: int64 := 5061;

