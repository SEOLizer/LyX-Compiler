// Convert LDAP result code to error message
pub fn LDAPErrorToStr(code: int64): int64 {
  if (code == 0) { return "Success"; }
  else if (code == 1) { return "Operations Error"; }
  else if (code == 2) { return "Protocol Error"; }
  else if (code == 3) { return "Time Limit Exceeded"; }
  else if (code == 4) { return "Size Limit Exceeded"; }
  else if (code == 5) { return "Compare False"; }
  else if (code == 6) { return "Compare True"; }
  else if (code == 7) { return "Auth Method Not Supported"; }
  else if (code == 8) { return "Strong Auth Required"; }
  else if (code == 10) { return "Referral"; }
  else if (code == 11) { return "Admin Limit Exceeded"; }
  else if (code == 12) { return "Unavailable Critical Extension"; }
  else if (code == 13) { return "Confidentiality Required"; }
  else if (code == 14) { return "SASL Bind In Progress"; }
  else if (code == 16) { return "No Such Attribute"; }
  else if (code == 17) { return "Undefined Attribute Type"; }
  else if (code == 18) { return "Inappropriate Matching"; }
  else if (code == 19) { return "Constraint Violation"; }
  else if (code == 20) { return "Attribute Or Value Exists"; }
  else if (code == 21) { return "Invalid Attribute Syntax"; }
  else if (code == 32) { return "No Such Object"; }
  else if (code == 33) { return "Alias Problem"; }
  else if (code == 34) { return "Invalid DN Syntax"; }
  else if (code == 36) { return "Alias Dereferencing Problem"; }
  else if (code == 48) { return "Inappropriate Authentication"; }
  else if (code == 49) { return "Invalid Credentials"; }
  else if (code == 50) { return "Insufficient Access Rights"; }
  else if (code == 51) { return "Busy"; }
  else if (code == 52) { return "Unavailable"; }
  else if (code == 53) { return "Unwilling To Perform"; }
  else if (code == 54) { return "Loop Detect"; }
  else if (code == 64) { return "Naming Violation"; }
  else if (code == 65) { return "Object Class Violation"; }
  else if (code == 66) { return "Not Allowed On Non-Leaf"; }
  else if (code == 67) { return "Not Allowed On RDN"; }
  else if (code == 68) { return "Entry Already Exists"; }
  else if (code == 69) { return "Object Class Mods Prohibited"; }
  else if (code == 71) { return "Affects Multiple DSAs"; }
  else if (code == 80) { return "Other"; }
  else if (code == -1) { return "Parse Error"; }
  else if (code == -2) { return "Connection Error"; }
  else if (code == -3) { return "Timeout"; }
  return "Unknown Error";
}

// ============================================================================
// WP2: DN-Parsing (einfach)
// ============================================================================

// Count RDN components in a DN
// Example: "cn=admin,dc=example,dc=com" has 3 RDNs
pub fn LDAPCountRDNs(dn: int64): int64 {
  var count: int64 := 1;
  var i: int64;
  var c: int64;
  var len: int64;
  
  if (dn == 0) {
    return 0;
  }
  
  len := LDAPStrLen(dn);
  i := 0;
  while (i < len) {
    c := peek8(dn + i);
    if (c == 44) {  // comma
      count := count + 1;
    }
    i := i + 1;
  }
  
  return count;
}

// Get RDN at index (0-based)
// Returns pointer to copy of RDN (caller must free)
pub fn LDAPGetRDNAt(dn: int64, index: int64): int64 {
  var len: int64;
  var i: int64;
  var j: int64;
  var start: int64;
  var commaCount: int64;
  var rdnStart: int64;
  var rdnEnd: int64;
  var rdnLen: int64;
  var rdnBuf: int64;
  
  if (dn == 0) {
    return 0;
  }
  
  len := LDAPStrLen(dn);
  commaCount := 0;
  start := 0;
  
  // Find start of requested RDN
  i := 0;
  while (i < len) {
    if (peek8(dn + i) == 44) {  // comma
      if (commaCount == index) {
        start := i + 1;
        break;
      }
      commaCount := commaCount + 1;
    }
    i := i + 1;
  }
  
  if (index > commaCount) {
    return 0;
  }
  
  // Find end of RDN
  rdnStart := start;
  i := start;
  while (i < len) {
    if (peek8(dn + i) == 44 || i == len - 1) {
      rdnEnd := i;
      break;
    }
    i := i + 1;
  }
  
  rdnLen := rdnEnd - rdnStart;
  if (i == len - 1) {
    rdnLen := rdnLen + 1;
  }
  
  // Copy RDN
  rdnBuf := mmap(0, rdnLen + 1, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (rdnBuf == 0) {
    return 0;
  }
  
  i := 0;
  while (i < rdnLen) {
    poke8(rdnBuf + i, peek8(dn + rdnStart + i));
    i := i + 1;
  }
  poke8(rdnBuf + rdnLen, 0);
  
  return rdnBuf;
}

// Get result code from any LDAP response
pub fn LDAPGetResultCode(buf: int64, bufSize: int64): int64 {
  var pos: int64;
  var tag: int64;
  var b: int64;
  
  if (buf == 0 || bufSize < 10) {
    return -2;
  }
  
  pos := 0;
  
  // Skip outer SEQUENCE
  tag := peek8(buf + pos);
  if (tag == ASN1_SEQUENCE) {
    pos := ASN1SkipValue(buf, pos) - 1;
  }
  
  // Skip Message ID
  tag := peek8(buf + pos);
  if (tag == ASN1_INTEGER) {
    pos := ASN1SkipValue(buf, pos);
  }
  
  // Skip to result code (ENUMERATED in various response types)
  pos := pos + 1;  // Skip response tag
  
  // Skip length
  b := peek8(buf + pos);
  if (b < 128) {
    pos := pos + 1;
  }
  else {
    pos := pos + 1 + (b - 128);
  }
  
  // Now at result code
  tag := peek8(buf + pos);
  if (tag == $0A) {  // ENUMERATED
    pos := pos + 1;
    b := peek8(buf + pos);
    if (b < 128) {
      pos := pos + 1;
    }
    else {
      pos := pos + 1 + (b - 128);
    }
    return peek8(buf + pos);
  }
  
  return -1;
}
