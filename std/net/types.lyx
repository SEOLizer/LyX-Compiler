pub con AF_INET: int64 := 2;
pub con AF_INET6: int64 := 10;
pub con SOCK_STREAM: int64 := 1;
pub con SOCK_DGRAM: int64 := 2;
pub con SOCK_RAW: int64 := 3;
pub con IPPROTO_TCP: int64 := 6;
pub con IPPROTO_UDP: int64 := 17;
pub con IPPROTO_ICMP: int64 := 1;
pub con IPPROTO_RAW: int64 := 255;
pub con SOL_SOCKET: int64 := 1;
pub con SO_REUSEADDR: int64 := 2;

// TCP Socket options
pub con TCP_NODELAY: int64 := 1;
pub con TCP_KEEPALIVE: int64 := $10;

// Socket options
pub con SO_KEEPALIVE: int64 := 9;
pub con SO_RCVBUF: int64 := 8;
pub con SO_SNDBUF: int64 := 7;
pub con SO_ERROR: int64 := 4;
pub con SO_TYPE: int64 := 3;
pub con SO_REUSEPORT: int64 := 15;
pub con SO_LINGER: int64 := 13;

// Socket flags
pub con MSG_PEEK: int64 := 2;
pub con MSG_DONTWAIT: int64 := 64;

// mmap constants
pub con PROT_READ: int64 := 1;
pub con PROT_WRITE: int64 := 2;
pub con PROT_RW: int64 := 3;
pub con MAP_ANONYMOUS: int64 := 32;
pub con MAP_PRIVATE: int64 := 2;
pub con MAP_ANON: int64 := 34;
pub con FD_NONE: int64 := -1;

// ICMP constants
pub con ICMP_ECHO: int64 := 8;
pub con ICMP_ECHOREPLY: int64 := 0;

// Ethernet constants (Linux definitions)
pub con ETH_P_IP: int64 := $0800;      // IPv4
pub con ETH_P_ARP: int64 := $0806;    // ARP
pub con ETH_P_IPV6: int64 := $86DD;   // IPv6
