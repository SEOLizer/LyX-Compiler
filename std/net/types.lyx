// Lyx Network Library - Types
// Phase 1: Common types for networking

unit std.net.types;

// Socket domain constants
pub con AF_INET: int64 := 2;
pub con AF_INET6: int64 := 10;
pub con SOCK_STREAM: int64 := 1;
pub con SOCK_DGRAM: int64 := 2;
pub con SOCK_RAW: int64 := 3;
pub con IPPROTO_TCP: int64 := 6;
pub con IPPROTO_UDP: int64 := 17;
pub con IPPROTO_ICMP: int64 := 1;
pub con IPPROTO_RAW: int64 := 255;
pub con SOL_SOCKET: int64 := 1;
pub con SO_REUSEADDR: int64 := 2;

// Socket flags
pub con MSG_PEEK: int64 := 2;
pub con MSG_DONTWAIT: int64 := 64;

// mmap constants
pub con PROT_READ: int64 := 1;
pub con PROT_WRITE: int64 := 2;
pub con PROT_RW: int64 := 3;
pub con MAP_ANONYMOUS: int64 := 32;
pub con MAP_PRIVATE: int64 := 2;
pub con MAP_ANON: int64 := 34;
pub con FD_NONE: int64 := -1;

// ICMP constants
pub con ICMP_ECHO: int64 := 8;
pub con ICMP_ECHOREPLY: int64 := 0;

// Ethernet constants (Linux definitions)
pub con ETH_P_IP: int64 := $0800;      // IPv4
pub con ETH_P_ARP: int64 := $0806;    // ARP
pub con ETH_P_IPV6: int64 := $86DD;   // IPv6
pub con ETH_ALEN: int64 := 6;         // Ethernet address length

// ARP constants
pub con ARPOP_REQUEST: int64 := 1;   // ARP request
pub con ARPOP_REPLY: int64 := 2;      // ARP reply
pub con ARPOP_RREQUEST: int64 := 3;    // RARP request
pub con ARPOP_RREPLY: int64 := 4;      // RARP reply
pub con ARPOP_INREQUEST: int64 := 8;   // InARP request
pub con ARPOP_INREPLY: int64 := 9;    // InARP reply
pub con ARPOP_NAK: int64 := 10;       // ARP NAK

// ARP hardware types
pub con ARPHRD_ETHER: int64 := 1;     // Ethernet

// Native socket handle
pub type NativeSocket = int64;

// IPv4 Address
pub type IPAddr = struct {
  family: int64;
  a: uint8;
  b: uint8;
  c: uint8;
  d: uint8;
  port: uint16;
};

// IPv4 Socket Address (sockaddr_in)
pub type SockAddrIn = struct {
  family: uint16;
  port: uint16;
  addr: int64;
  zero: int64;
};

// Ethernet MAC Address (6 bytes)
pub type MacAddr = struct {
  a: uint8;
  b: uint8;
  c: uint8;
  d: uint8;
  e: uint8;
  f: uint8;
};

// Ethernet Frame Header (14 bytes)
// +--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+
// |                     Destination MAC (6)                    |                     Source MAC (6)                     | Type |
// +--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+
pub type EthernetHeader = struct {
  dst: MacAddr;
  src: MacAddr;
  ethertype: uint16;
};

// ARP Packet (28 bytes for Ethernet/IP)
// +--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+
// | Hardware Type | Protocol Type | Hlen | Plen |  Operation  |               Sender MAC (6)               |            Sender IP (4)           |              Target MAC (6)            |           Target IP (4)          |
// +--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+
pub type ARPPacket = struct {
  ar_hrd: uint16;      // Hardware type (ARPHRD_ETHER = 1)
  ar_pro: uint16;      // Protocol type (ETH_P_IP = 0x0800)
  ar_hln: uint8;      // Hardware address length (6 for Ethernet)
  ar_pln: uint8;      // Protocol address length (4 for IPv4)
  ar_op: uint16;       // Operation (ARPOP_REQUEST or ARPOP_REPLY)
  ar_sha: MacAddr;    // Sender hardware address
  ar_sip: int64;      // Sender protocol address (IPv4)
  ar_tha: MacAddr;    // Target hardware address
  ar_tip: int64;      // Target protocol address (IPv4)
};

// Convert port to network byte order
pub fn Htons(port: uint16): uint16 {
  return ((port & 0xFF) << 8) | ((port >> 8) & 0xFF);
}

// Convert port from network byte order to host order
pub fn Ntohs(port: uint16): uint16 {
  return ((port & 0xFF) << 8) | ((port >> 8) & 0xFF);
}

// Parse IPv4 address string "a.b.c.d:port"
pub fn ParseIPAddr(s: string): IPAddr {
  var addr: IPAddr;
  addr.family := AF_INET;
  addr.a := 0;
  addr.b := 0;
  addr.c := 0;
  addr.d := 0;
  addr.port := 8080;
  
  // Simple parsing for common cases
  if (s == "0.0.0.0:8080") {
    addr.port := 8080;
  } else if (s == "127.0.0.1:8080") {
    addr.a := 127;
    addr.port := 8080;
  } else if (s == "0.0.0.0:0") {
    addr.port := 0;
  }
  
  return addr;
}

// Create sockaddr_in from IP address and port
pub fn MakeSockAddr(ip: IPAddr): SockAddrIn {
  var sa: SockAddrIn;
  sa.family := Htons(AF_INET);
  sa.port := Htons(ip.port);
  sa.addr := ((ip.a as int64) << 24) | ((ip.b as int64) << 16) | ((ip.c as int64) << 8) | (ip.d as int64);
  sa.zero := 0;
  return sa;
}
