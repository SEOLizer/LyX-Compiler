// Native socket handle
pub type NativeSocket = int64;

// IPv4 Address
pub type IPAddr = struct {
  family: int64;
  a: uint8;
  b: uint8;
  c: uint8;
  d: uint8;
  port: uint16;
};

// IPv4 Socket Address (sockaddr_in)
pub type SockAddrIn = struct {
  family: uint16;
  port: uint16;
  addr: int64;
  zero: int64;
};

// Ethernet MAC Address (6 bytes)
pub type MacAddr = struct {
  a: uint8;
  b: uint8;
  c: uint8;
  d: uint8;
  e: uint8;
  f: uint8;
};

// Ethernet Frame Header (14 bytes)
// +--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+
// |                     Destination MAC (6)                    |                     Source MAC (6)                     | Type |
// +--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+
pub type EthernetHeader = struct {
  dst: MacAddr;
  src: MacAddr;
  ethertype: uint16;
};

// ARP Packet (28 bytes for Ethernet/IP)
// +--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+
// | Hardware Type | Protocol Type | Hlen | Plen |  Operation  |               Sender MAC (6)               |            Sender IP (4)           |              Target MAC (6)            |           Target IP (4)          |
// +--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+--------+
pub type ARPPacket = struct {
  ar_hrd: uint16;      // Hardware type (ARPHRD_ETHER = 1)
  ar_pro: uint16;      // Protocol type (ETH_P_IP = 0x0800)
  ar_hln: uint8;      // Hardware address length (6 for Ethernet)
  ar_pln: uint8;      // Protocol address length (4 for IPv4)
  ar_op: uint16;       // Operation (ARPOP_REQUEST or ARPOP_REPLY)
  ar_sha: MacAddr;    // Sender hardware address
  ar_sip: int64;      // Sender protocol address (IPv4)
  ar_tha: MacAddr;    // Target hardware address
  ar_tip: int64;      // Target protocol address (IPv4)
};

// Convert port to network byte order
pub fn Htons(port: uint16): uint16 {
  return ((port & 0xFF) << 8) | ((port >> 8) & 0xFF);
}

// Convert port from network byte order to host order
pub fn Ntohs(port: uint16): uint16 {
  return ((port & 0xFF) << 8) | ((port >> 8) & 0xFF);
}

// Parse ASCII digit to integer value (0-9)
fn asciiToDigit(c: int64): int64 {
  if (c >= 48 && c <= 57) {  // '0' to '9'
    return c - 48;
  }
  return -1;
}

// Internal: Parse a single octet from string
// Returns parsed value and new position, or -1 on error
fn parseOctet(s: int64, pos: int64, len: int64, outVal: int64): int64 {
  var val: int64 := 0;
  var digitCount: int64 := 0;
  var c: int64;
  var done: bool := false;
  
  while (pos < len && !done) {
    c := peek8(s + pos);
    
    // Check for delimiter characters
    if (c == 46 || c == 58 || c == 0) {  // '.' or ':' or null
      done := true;
    } else {
      var d: int64 := asciiToDigit(c);
      if (d < 0) {
        return -1;  // invalid character
      }
      
      val := val * 10 + d;
      digitCount := digitCount + 1;
      pos := pos + 1;
      
      // Maximum 3 digits per octet
      if (digitCount > 3) {
        return -1;
      }
    }
  }
  
  // Must have at least one digit
  if (digitCount == 0) {
    return -1;
  }
  
  // Value must be 0-255
  if (val > 255) {
    return -1;
  }
  
  // Write output through pointer
  poke8(outVal, val);
  return pos;
}

// Internal: Parse port number
// Returns parsed port and new position, or -1 on error
fn parsePort(s: int64, pos: int64, len: int64, outPort: int64): int64 {
  var val: int64 := 0;
  var digitCount: int64 := 0;
  var c: int64;
  var done: bool := false;
  
  while (pos < len && !done) {
    c := peek8(s + pos);
    
    if (c == 0) {  // null terminator
      done := true;
    } else {
      var d: int64 := asciiToDigit(c);
      if (d < 0) {
        return -1;  // invalid character
      }
      
      val := val * 10 + d;
      digitCount := digitCount + 1;
      pos := pos + 1;
      
      // Maximum 5 digits for port (0-65535)
      if (digitCount > 5) {
        return -1;
      }
    }
  }
  
  // Port is optional - if no digits, default to 0
  if (digitCount == 0) {
    val := 0;
  } else {
    // Value must be 0-65535
    if (val > 65535) {
      return -1;
    }
  }
  
  // Write port as little-endian 16-bit value
  poke8(outPort, val & 0xFF);
  poke8(outPort + 1, (val >> 8) & 0xFF);
  return pos;
}

// Parse IPv4 address string to IPAddr
// Supported formats:
//   - "a.b.c.d" (e.g., "192.168.1.1")
//   - "a.b.c.d:port" (e.g., "192.168.1.1:8080")
//   - ":port" (any IP, specific port)
// Returns IPAddr with port=0 on parse error
pub fn ParseIPAddr(s: int64, len: int64): IPAddr {
  var addr: IPAddr;
  var pos: int64 := 0;
  var tmp: int64;
  var portPtr: int64;
  
  // Default values
  addr.family := AF_INET;
  addr.a := 0;
  addr.b := 0;
  addr.c := 0;
  addr.d := 0;
  addr.port := 0;
  
  // Handle empty string
  if (len <= 0) {
    return addr;
  }
  
  // Check for leading ':' (any IP, just port)
  if (peek8(s) == 58) {  // ':'
    pos := 1;
    portPtr := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
    if (portPtr <= 0) {
      return addr;
    }
    pos := parsePort(s, pos, len, portPtr);
    if (pos < 0) {
      munmap(portPtr, 16);
      return addr;
    }
    // Read port as little-endian 16-bit value
    addr.port := (peek8(portPtr) | (peek8(portPtr + 1) << 8)) as uint16;
    munmap(portPtr, 16);
    return addr;
  }
  
  // Allocate temporary storage for parsed values
  tmp := mmap(0, 32, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (tmp <= 0) {
    return addr;
  }
  
  // Parse first octet (a)
  pos := parseOctet(s, pos, len, tmp);
  if (pos < 0) {
    munmap(tmp, 32);
    return addr;
  }
  addr.a := peek8(tmp) as uint8;
  
  // Expect '.'
  if (pos < len && peek8(s + pos) == 46) {
    pos := pos + 1;
  } else {
    munmap(tmp, 32);
    return addr;
  }
  
  // Parse second octet (b)
  pos := parseOctet(s, pos, len, tmp);
  if (pos < 0) {
    munmap(tmp, 32);
    return addr;
  }
  addr.b := peek8(tmp) as uint8;
  
  // Expect '.'
  if (pos < len && peek8(s + pos) == 46) {
    pos := pos + 1;
  } else {
    munmap(tmp, 32);
    return addr;
  }
  
  // Parse third octet (c)
  pos := parseOctet(s, pos, len, tmp);
  if (pos < 0) {
    munmap(tmp, 32);
    return addr;
  }
  addr.c := peek8(tmp) as uint8;
  
  // Expect '.'
  if (pos < len && peek8(s + pos) == 46) {
    pos := pos + 1;
  } else {
    munmap(tmp, 32);
    return addr;
  }
  
  // Parse fourth octet (d)
  pos := parseOctet(s, pos, len, tmp);
  if (pos < 0) {
    munmap(tmp, 32);
    return addr;
  }
  addr.d := peek8(tmp) as uint8;
  
  // Check for port (':')
  if (pos < len && peek8(s + pos) == 58) {
    pos := pos + 1;
    portPtr := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
    if (portPtr <= 0) {
      munmap(tmp, 32);
      return addr;
    }
    pos := parsePort(s, pos, len, portPtr);
    if (pos < 0) {
      munmap(portPtr, 16);
      munmap(tmp, 32);
      return addr;
    }
    // Read port as little-endian 16-bit value
    addr.port := (peek8(portPtr) | (peek8(portPtr + 1) << 8)) as uint16;
    munmap(portPtr, 16);
  }

  munmap(tmp, 32);
  return addr;
}

// Create sockaddr_in from IP address and port
pub fn MakeSockAddr(ip: IPAddr): SockAddrIn {
  var sa: SockAddrIn;
  sa.family := Htons(AF_INET);
  sa.port := Htons(ip.port);
  sa.addr := ((ip.a as int64) << 24) | ((ip.b as int64) << 16) | ((ip.c as int64) << 8) | (ip.d as int64);
  sa.zero := 0;
  return sa;
}

// Create sockaddr_in at a given memory address (for syscalls)
// addr: memory address (allocated with mmap)
// ip: packed IPv4 address in network byte order
// port: port number in host byte order
pub fn SockAddrInCreate(addr: int64, ip: int64, port: int64) {
  // sin_family = AF_INET (2) - little endian at offset 0
  poke8(addr, 2);
  poke8(addr + 1, 0);
  
  // sin_port - BIG ENDIAN (network byte order) at offset 2
  poke8(addr + 2, (port >> 8) & 0xFF);
  poke8(addr + 3, port & 0xFF);
  
  // sin_addr - network byte order at offset 4
  poke8(addr + 4, (ip >> 24) & 0xFF);
  poke8(addr + 5, (ip >> 16) & 0xFF);
  poke8(addr + 6, (ip >> 8) & 0xFF);
  poke8(addr + 7, ip & 0xFF);
  
  // Zero padding (8 bytes) at offsets 8-15
  poke8(addr + 8, 0);
  poke8(addr + 9, 0);
  poke8(addr + 10, 0);
  poke8(addr + 11, 0);
  poke8(addr + 12, 0);
  poke8(addr + 13, 0);
  poke8(addr + 14, 0);
  poke8(addr + 15, 0);
}

// Create timeval structure at a given memory address (for select)
// addr: memory address (allocated with mmap)
// timeoutMs: timeout in milliseconds (-1 = infinite, 0 = immediate)
pub fn TimeValCreate(addr: int64, timeoutMs: int64) {
  // tv_sec at offset 0 (int64, little-endian)
  var sec: int64 := timeoutMs / 1000;
  poke8(addr + 0, sec & 0xFF);
  poke8(addr + 1, (sec >> 8) & 0xFF);
  poke8(addr + 2, (sec >> 16) & 0xFF);
  poke8(addr + 3, (sec >> 24) & 0xFF);
  poke8(addr + 4, (sec >> 32) & 0xFF);
  poke8(addr + 5, (sec >> 40) & 0xFF);
  poke8(addr + 6, (sec >> 48) & 0xFF);
  poke8(addr + 7, (sec >> 56) & 0xFF);
  
  // tv_usec at offset 8 (int64, little-endian)
  var usec: int64 := (timeoutMs % 1000) * 1000;
  poke8(addr + 8, usec & 0xFF);
  poke8(addr + 9, (usec >> 8) & 0xFF);
  poke8(addr + 10, (usec >> 16) & 0xFF);
  poke8(addr + 11, (usec >> 24) & 0xFF);
  poke8(addr + 12, (usec >> 32) & 0xFF);
  poke8(addr + 13, (usec >> 40) & 0xFF);
  poke8(addr + 14, (usec >> 48) & 0xFF);
  poke8(addr + 15, (usec >> 56) & 0xFF);
}

// Create sockaddr_un (Unix socket address) at a given memory address
// addr: memory address (allocated with mmap) - must be at least 110 bytes
// path: socket path as pointer to null-terminated string
// Returns: address length needed for bind/connect
pub fn SockAddrUnCreate(addr: int64, path: int64): int64 {
  var i: int64 := 0;
  var pathLen: int64 := 0;
  
  // Offset 0: sun_family = AF_UNIX (1) - little endian
  poke8(addr, 1);
  poke8(addr + 1, 0);
  
  // Offset 2: sun_path (108 bytes max, plus null terminator)
  // Copy path characters
  if (path != 0) {
    while (i < 107) {
      var c: int64 := peek8(path + i);
      if (c == 0) {
        break;
      }
      poke8(addr + 2 + i, c);
      i := i + 1;
      pathLen := pathLen + 1;
    }
  }
  
  // Null terminator
  poke8(addr + 2 + i, 0);
  
  // Return total address length = 2 (family) + pathLen + 1 (null)
  return 2 + pathLen + 1;
}

// ============================================================================
// IPv6 Support
// ============================================================================
//
// IPv6 addresses are represented as two int64 values (network byte order):
//   ip6Hi = upper 64 bits  (groups a,b,c,d — most significant first)
//   ip6Lo = lower 64 bits  (groups e,f,g,h)
//
// Example: 2001:0db8::1
//   ip6Hi = (0x2001 << 48) | (0x0db8 << 32) = 0x20010db800000000
//   ip6Lo = 1
//
// Use IPv6MakeHi/IPv6MakeLo to construct addresses from individual groups.
// Use IPv6LoopbackHi/Lo and IPv6AnyHi/Lo for common addresses.
// Use SockAddrIn6Create(addr, ip6Hi, ip6Lo, port) to build sockaddr_in6.

// Pack 4 uint16 groups into the high 64 bits of an IPv6 address
// a is the most significant group (leftmost in "xxxx:xxxx:xxxx:xxxx:...")
pub fn IPv6MakeHi(a: int64, b: int64, c: int64, d: int64): int64 {
  return ((a & 0xFFFF) << 48) |
         ((b & 0xFFFF) << 32) |
         ((c & 0xFFFF) << 16) |
         (d & 0xFFFF);
}

// Pack 4 uint16 groups into the low 64 bits of an IPv6 address
pub fn IPv6MakeLo(e: int64, f: int64, g: int64, h: int64): int64 {
  return ((e & 0xFFFF) << 48) |
         ((f & 0xFFFF) << 32) |
         ((g & 0xFFFF) << 16) |
         (h & 0xFFFF);
}

// Extract group index i (0=most significant) from hi/lo pair
pub fn IPv6GetGroup(ip6Hi: int64, ip6Lo: int64, i: int64): int64 {
  if (i < 4) {
    return (ip6Hi >> ((3 - i) * 16)) & 0xFFFF;
  }
  return (ip6Lo >> ((7 - i) * 16)) & 0xFFFF;
}

// Loopback address ::1
pub fn IPv6LoopbackHi(): int64 { return 0; }
pub fn IPv6LoopbackLo(): int64 { return 1; }

// Unspecified address ::
pub fn IPv6AnyHi(): int64 { return 0; }
pub fn IPv6AnyLo(): int64 { return 0; }


// Write sockaddr_in6 structure to a 28-byte mmap'd buffer
// Layout:
//   offset  0: sin6_family   (uint16, LE) = AF_INET6 = 10
//   offset  2: sin6_port     (uint16, BE = network byte order)
//   offset  4: sin6_flowinfo (uint32) = 0
//   offset  8: sin6_addr     (16 bytes, network byte order) = hi then lo
//   offset 24: sin6_scope_id (uint32) = 0
pub fn SockAddrIn6Create(addr: int64, ip6Hi: int64, ip6Lo: int64, port: int64) {
  // sin6_family = AF_INET6 (10), little-endian
  poke8(addr + 0, 10);
  poke8(addr + 1, 0);

  // sin6_port — big-endian (network byte order)
  poke8(addr + 2, (port >> 8) & 0xFF);
  poke8(addr + 3, port & 0xFF);

  // sin6_flowinfo = 0
  poke8(addr + 4, 0);
  poke8(addr + 5, 0);
  poke8(addr + 6, 0);
  poke8(addr + 7, 0);

  // sin6_addr: 16 bytes, high 64 bits first (network byte order = big-endian)
  poke8(addr +  8, (ip6Hi >> 56) & 0xFF);
  poke8(addr +  9, (ip6Hi >> 48) & 0xFF);
  poke8(addr + 10, (ip6Hi >> 40) & 0xFF);
  poke8(addr + 11, (ip6Hi >> 32) & 0xFF);
  poke8(addr + 12, (ip6Hi >> 24) & 0xFF);
  poke8(addr + 13, (ip6Hi >> 16) & 0xFF);
  poke8(addr + 14, (ip6Hi >>  8) & 0xFF);
  poke8(addr + 15,  ip6Hi        & 0xFF);
  poke8(addr + 16, (ip6Lo >> 56) & 0xFF);
  poke8(addr + 17, (ip6Lo >> 48) & 0xFF);
  poke8(addr + 18, (ip6Lo >> 40) & 0xFF);
  poke8(addr + 19, (ip6Lo >> 32) & 0xFF);
  poke8(addr + 20, (ip6Lo >> 24) & 0xFF);
  poke8(addr + 21, (ip6Lo >> 16) & 0xFF);
  poke8(addr + 22, (ip6Lo >>  8) & 0xFF);
  poke8(addr + 23,  ip6Lo        & 0xFF);

  // sin6_scope_id = 0
  poke8(addr + 24, 0);
  poke8(addr + 25, 0);
  poke8(addr + 26, 0);
  poke8(addr + 27, 0);
}

// Internal: parse a single hex digit (0-9, a-f, A-F)
// Returns 0-15 or -1 on error
fn hexDigit(c: int64): int64 {
  if (c >= 48 && c <= 57) {        // '0'-'9'
    return c - 48;
  }
  if (c >= 65 && c <= 70) {        // 'A'-'F'
    return c - 55;
  }
  if (c >= 97 && c <= 102) {       // 'a'-'f'
    return c - 87;
  }
  return -1;
}

// Internal: parse one IPv6 hex group (1-4 hex digits) starting at pos
// Writes result to groups[idx] (via base ptr + idx*2)
// Returns new pos, or -1 on parse error
fn parseIPv6Group(s: int64, pos: int64, len: int64, outVal: int64): int64 {
  var val: int64 := 0;
  var count: int64 := 0;
  var c: int64;
  var d: int64;
  var done: bool := false;

  while (pos < len && !done) {
    c := peek8(s + pos);
    d := hexDigit(c);
    if (d < 0) {
      done := true;
    } else {
      val := val * 16 + d;
      count := count + 1;
      pos := pos + 1;
      if (count > 4) {
        return -1;
      }
    }
  }

  if (count == 0) {
    return -1;
  }

  poke16(outVal, val as uint16);
  return pos;
}

// Parse an IPv6 address string and write the result as two int64 hi/lo values.
// Supports:
//   Full form:     "2001:0db8:0000:0000:0000:0000:0000:0001"
//   Compressed:    "2001:db8::1"
//   Loopback:      "::1"
//   Any:           "::"
// outHi and outLo must be mmap'd int64 pointers (8 bytes each).
// Writes 0/0 on parse error.
pub fn ParseIPv6(s: int64, len: int64, outHi: int64, outLo: int64) {
  var buf: int64;          // 8 uint16 groups (16 bytes)
  var afterBuf: int64;     // 8 uint16 groups for part after ::
  var i: int64;
  var pos: int64 := 0;
  var groupsBefore: int64 := 0;
  var groupsAfter: int64 := 0;
  var hasDouble: bool := false;
  var newPos: int64;
  var c: int64;

  poke64(outHi, 0);
  poke64(outLo, 0);

  if (len <= 0) {
    return;
  }

  // Allocate temporary storage for up to 8 groups before and after ::
  buf := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf <= 0) {
    return;
  }
  afterBuf := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (afterBuf <= 0) {
    munmap(buf, 16);
    return;
  }

  // Zero both buffers
  i := 0;
  while (i < 16) {
    poke8(buf + i, 0);
    poke8(afterBuf + i, 0);
    i := i + 1;
  }

  // Check for leading "::"
  if (pos + 1 < len && peek8(s + pos) == 58 && peek8(s + pos + 1) == 58) {
    hasDouble := true;
    pos := pos + 2;
  }

  // Parse groups (before :: or all 8 if no ::)
  var done: bool := false;
  while (!done && pos < len && groupsBefore < 8) {
    // Try to parse a hex group
    newPos := parseIPv6Group(s, pos, len, buf + groupsBefore * 2);
    if (newPos < 0) {
      // parse error
      munmap(buf, 16);
      munmap(afterBuf, 16);
      return;
    }
    groupsBefore := groupsBefore + 1;
    pos := newPos;

    // Check what comes next
    if (pos >= len) {
      done := true;
    } else {
      c := peek8(s + pos);
      if (c == 58) {  // ':'
        // Check for '::'
        if (pos + 1 < len && peek8(s + pos + 1) == 58) {
          if (hasDouble) {
            // Second '::' is invalid
            munmap(buf, 16);
            munmap(afterBuf, 16);
            return;
          }
          hasDouble := true;
          pos := pos + 2;
          done := true;  // switch to parsing afterBuf
        } else {
          pos := pos + 1;  // skip single ':'
        }
      } else {
        done := true;
      }
    }
  }

  // If we had '::', parse groups after it
  if (hasDouble) {
    done := false;
    while (!done && pos < len && groupsAfter < 8) {
      newPos := parseIPv6Group(s, pos, len, afterBuf + groupsAfter * 2);
      if (newPos < 0) {
        done := true;  // end of string, no more groups
      } else {
        groupsAfter := groupsAfter + 1;
        pos := newPos;
        if (pos < len && peek8(s + pos) == 58) {
          pos := pos + 1;
        } else {
          done := true;
        }
      }
    }
  }

  // Reconstruct the 8 groups:
  //   [0..groupsBefore-1]  = groups before ::
  //   zeros fill the gap
  //   [8-groupsAfter..7]   = groups after ::
  // If no ::, just use buf[0..7] directly
  var groups: int64 := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (groups <= 0) {
    munmap(buf, 16);
    munmap(afterBuf, 16);
    return;
  }
  i := 0;
  while (i < 16) {
    poke8(groups + i, 0);
    i := i + 1;
  }

  // Copy before-groups
  i := 0;
  while (i < groupsBefore) {
    poke16(groups + i * 2, peek16(buf + i * 2));
    i := i + 1;
  }

  // Copy after-groups (at end of the 8-group array)
  if (hasDouble) {
    var startIdx: int64 := 8 - groupsAfter;
    i := 0;
    while (i < groupsAfter) {
      poke16(groups + (startIdx + i) * 2, peek16(afterBuf + i * 2));
      i := i + 1;
    }
  }

  // Pack 8 groups into hi/lo int64 values (big-endian: group 0 in highest bits)
  var hi: int64 := ((peek16(groups +  0) & 0xFFFF) << 48) |
                   ((peek16(groups +  2) & 0xFFFF) << 32) |
                   ((peek16(groups +  4) & 0xFFFF) << 16) |
                    (peek16(groups +  6) & 0xFFFF);
  var lo: int64 := ((peek16(groups +  8) & 0xFFFF) << 48) |
                   ((peek16(groups + 10) & 0xFFFF) << 32) |
                   ((peek16(groups + 12) & 0xFFFF) << 16) |
                    (peek16(groups + 14) & 0xFFFF);

  poke64(outHi, hi);
  poke64(outLo, lo);

  munmap(buf, 16);
  munmap(afterBuf, 16);
  munmap(groups, 16);
}

// Internal: map nibble (0-15) to lowercase hex character code
fn nibbleToHex(d: int64): int64 {
  if (d < 10) {
    return 48 + d;   // '0'-'9'
  }
  return 87 + d;     // 'a'-'f'  (97 + d - 10)
}

// Internal: write a uint16 as up to 4 lowercase hex chars (no leading zeros)
// Returns number of chars written
fn writeHex16(buf: int64, pos: int64, val: int64): int64 {
  var tmp: int64 := mmap(0, 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  var n: int64 := 0;
  var v: int64 := val & 0xFFFF;
  var written: int64 := 0;

  if (tmp <= 0) {
    return 0;
  }

  // Build digits in reverse
  if (v == 0) {
    poke8(tmp, 48);  // '0'
    n := 1;
  } else {
    while (v > 0) {
      poke8(tmp + n, nibbleToHex(v & 0xF));
      v := v >> 4;
      n := n + 1;
    }
  }

  // Write in correct order (reverse tmp)
  var j: int64 := n - 1;
  while (j >= 0) {
    poke8(buf + pos + written, peek8(tmp + j));
    written := written + 1;
    j := j - 1;
  }

  munmap(tmp, 8);
  return written;
}

// Format an IPv6 address (given as hi/lo int64 pair) to a null-terminated string
// in buf (must be >= 40 bytes). Uses :: compression for the longest run of zero groups.
pub fn IPv6Format(ip6Hi: int64, ip6Lo: int64, buf: int64) {
  var groups: int64 := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
  var pos: int64 := 0;
  var i: int64;
  var g: int64;
  var bestStart: int64 := -1;
  var bestLen: int64 := 0;
  var cur: int64 := -1;
  var curLen: int64 := 0;

  if (groups <= 0) {
    poke8(buf, 0);
    return;
  }

  // Unpack hi/lo into 8 uint16 groups
  poke16(groups +  0, (ip6Hi >> 48) & 0xFFFF);
  poke16(groups +  2, (ip6Hi >> 32) & 0xFFFF);
  poke16(groups +  4, (ip6Hi >> 16) & 0xFFFF);
  poke16(groups +  6,  ip6Hi        & 0xFFFF);
  poke16(groups +  8, (ip6Lo >> 48) & 0xFFFF);
  poke16(groups + 10, (ip6Lo >> 32) & 0xFFFF);
  poke16(groups + 12, (ip6Lo >> 16) & 0xFFFF);
  poke16(groups + 14,  ip6Lo        & 0xFFFF);

  // Find longest run of consecutive zero groups
  i := 0;
  while (i < 8) {
    if (peek16(groups + i * 2) == 0) {
      if (cur < 0) {
        cur := i;
        curLen := 1;
      } else {
        curLen := curLen + 1;
      }
      if (curLen > bestLen) {
        bestStart := cur;
        bestLen := curLen;
      }
    } else {
      cur := -1;
      curLen := 0;
    }
    i := i + 1;
  }

  // Write groups with :: compression
  i := 0;
  while (i < 8) {
    if (bestLen >= 2 && i == bestStart) {
      // Write "::" (or leading ":" at start, trailing ":" at end)
      if (i == 0) {
        poke8(buf + pos, 58); pos := pos + 1;
      }
      poke8(buf + pos, 58); pos := pos + 1;
      i := i + bestLen;
      if (i == 8) {
        poke8(buf + pos, 58); pos := pos + 1;
      }
    } else {
      if (i > 0) {
        poke8(buf + pos, 58); pos := pos + 1;
      }
      g := peek16(groups + i * 2);
      pos := pos + writeHex16(buf, pos, g);
      i := i + 1;
    }
  }

  poke8(buf + pos, 0);  // null terminator
  munmap(groups, 16);
}
