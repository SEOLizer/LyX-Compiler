// Lyx Network Library - DNS Resolver
// DNS client for A, AAAA, MX, CNAME record lookups

unit std.net.dns;

import std.net.socket;
import std.net.types;

// ============================================================================
// DNS Constants
// ============================================================================

// DNS header flags
pub con DNS_QR_QUERY: int64 := 0;       // Query
pub con DNS_QR_RESPONSE: int64 := 1;    // Response
pub con DNS_OPCODE_QUERY: int64 := 0;   // Standard query
pub con DNS_RD: int64 := 1;             // Recursion Desired
pub con DNS_RA: int64 := 1;             // Recursion Available

// DNS record types
pub con DNS_TYPE_A: int64 := 1;         // IPv4 address
pub con DNS_TYPE_AAAA: int64 := 28;     // IPv6 address
pub con DNS_TYPE_CNAME: int64 := 5;     // Canonical name
pub con DNS_TYPE_MX: int64 := 15;       // Mail exchange
pub con DNS_TYPE_TXT: int64 := 16;      // Text record
pub con DNS_TYPE_NS: int64 := 2;        // Name server
pub con DNS_TYPE_SOA: int64 := 6;       // Start of authority

// DNS classes
pub con DNS_CLASS_IN: int64 := 1;       // Internet

// DNS response codes
pub con DNS_RCODE_OK: int64 := 0;       // No error
pub con DNS_RCODE_FORMERR: int64 := 1;  // Format error
pub con DNS_RCODE_SERVFAIL: int64 := 2; // Server failure
pub con DNS_RCODE_NXDOMAIN: int64 := 3; // Non-existent domain
pub con DNS_RCODE_NOTIMP: int64 := 4;   // Not implemented
pub con DNS_RCODE_REFUSED: int64 := 5;  // Query refused

// Default DNS servers
pub con DNS_PORT: int64 := 53;

// ============================================================================
// DNS Result Structures
// ============================================================================

// Generic DNS Result (64 bytes)
// Used for A, AAAA, MX, CNAME records
// Offset 0: success (bool, 1 byte)
// Offset 1-7: padding
// Offset 8: recordType (int64)
// Offset 16: ttl (int64)
// Offset 24: rcode (int64)
// Offset 32: data length (int64)
// Offset 40: data (24 bytes for AAAA/MX/CNAME)
pub type DNSResult = struct {
  success: bool;
  recordType: int64;
  ttl: int64;
  rcode: int64;
  dataLen: int64;
  data: array[uint8, 24];
};

// ============================================================================
// Internal: Random ID generator (simple LCG)
// ============================================================================

var g_dns_seed: int64 := 12345;

fn dns_random_id(): uint16 {
  g_dns_seed := (g_dns_seed * 1103515245 + 12345) & 0x7FFFFFFF;
  return (g_dns_seed & 0xFFFF) as uint16;
}

// ============================================================================
// Internal: Encode domain name in DNS format
// ============================================================================

fn dns_encode_name(buf: int64, offset: int64, name: int64, nameLen: int64): int64 {
  var i: int64 := 0;
  var labelStart: int64 := offset;
  var pos: int64 := offset + 1;
  var c: int64;
  var labelLen: int64 := 0;
  
  while (i < nameLen) {
    c := peek8(name + i);
    
    if (c == 46) {  // '.' character
      poke8(buf + labelStart, labelLen);
      labelStart := pos;
      pos := pos + 1;
      labelLen := 0;
    } else {
      poke8(buf + pos, c);
      pos := pos + 1;
      labelLen := labelLen + 1;
    }
    i := i + 1;
  }
  
  poke8(buf + labelStart, labelLen);
  poke8(buf + pos, 0);
  pos := pos + 1;
  
  return pos - offset;
}

// ============================================================================
// Internal: Build DNS query packet
// ============================================================================

fn dns_build_query(buf: int64, name: int64, nameLen: int64, queryType: int64): int64 {
  var offset: int64 := 0;
  var id: uint16 := dns_random_id();
  
  // DNS Header (12 bytes)
  poke8(buf + 0, (id >> 8) & 0xFF);
  poke8(buf + 1, id & 0xFF);
  poke8(buf + 2, 0x01);  // Flags: RD=1
  poke8(buf + 3, 0x00);
  poke8(buf + 4, 0x00);  // QDCOUNT = 1
  poke8(buf + 5, 0x01);
  poke8(buf + 6, 0x00);  // ANCOUNT = 0
  poke8(buf + 7, 0x00);
  poke8(buf + 8, 0x00);  // NSCOUNT = 0
  poke8(buf + 9, 0x00);
  poke8(buf + 10, 0x00); // ARCOUNT = 0
  poke8(buf + 11, 0x00);
  
  offset := 12;
  
  // Question section
  var nameBytes: int64 := dns_encode_name(buf, offset, name, nameLen);
  offset := offset + nameBytes;
  
  poke8(buf + offset, (queryType >> 8) & 0xFF);
  poke8(buf + offset + 1, queryType & 0xFF);
  offset := offset + 2;
  
  poke8(buf + offset, 0x00);
  poke8(buf + offset + 1, 0x01);
  offset := offset + 2;
  
  return offset;
}

// ============================================================================
// Internal: Skip DNS name (handles compression)
// ============================================================================

fn dns_skip_name(buf: int64, offset: int64, maxLen: int64): int64 {
  var pos: int64 := offset;
  var len: int64;
  
  while (pos < maxLen) {
    len := peek8(buf + pos);
    
    if (len == 0) {
      return pos + 1;
    }
    
    if ((len & 0xC0) == 0xC0) {
      return pos + 2;
    }
    
    pos := pos + 1 + len;
  }
  
  return pos;
}

// ============================================================================
// Internal: Parse DNS response (extended)
// Supports A, AAAA, MX, CNAME records
// resultPtr: pointer to 64-byte result buffer
// queryType: the type of record we asked for
// Returns: true on success, false on error
// ============================================================================

fn dns_parse_response_ex(buf: int64, bufLen: int64, resultPtr: int64, queryType: int64): bool {
  var flags: int64;
  var qdcount: int64;
  var ancount: int64;
  var offset: int64;
  var i: int64;
  var rtype: int64;
  var rclass: int64;
  var ttl: int64;
  var rdlength: int64;
  
  // Initialize result (64 bytes)
  poke8(resultPtr + 0, 0);     // success = false
  poke8(resultPtr + 8, 0);     // recordType = 0
  poke8(resultPtr + 16, 0);    // ttl = 0
  poke8(resultPtr + 24, -1);   // rcode = -1 (error)
  poke8(resultPtr + 32, 0);     // dataLen = 0
  
  if (bufLen < 12) {
    return false;
  }
  
  // Parse header
  flags := (peek8(buf + 2) << 8) | peek8(buf + 3);
  
  // Check QR bit (must be response)
  if ((flags & 0x8000) == 0) {
    poke8(resultPtr + 24, -2);  // rcode = -2
    return false;
  }
  
  // Extract RCODE
  var rcode: int64 := flags & 0x000F;
  poke8(resultPtr + 24, rcode);
  
  if (rcode != DNS_RCODE_OK) {
    return false;
  }
  
  // Get counts
  qdcount := (peek8(buf + 4) << 8) | peek8(buf + 5);
  ancount := (peek8(buf + 6) << 8) | peek8(buf + 7);
  
  if (ancount == 0) {
    poke8(resultPtr + 24, DNS_RCODE_NXDOMAIN);
    return false;
  }
  
  // Skip header
  offset := 12;
  
  // Skip question section
  i := 0;
  while (i < qdcount) {
    offset := dns_skip_name(buf, offset, bufLen);
    offset := offset + 4;
    i := i + 1;
  }
  
  // Parse answer section
  i := 0;
  while (i < ancount) {
    offset := dns_skip_name(buf, offset, bufLen);
    
    if (offset + 10 > bufLen) {
      return false;
    }
    
    rtype := (peek8(buf + offset) << 8) | peek8(buf + offset + 1);
    offset := offset + 2;
    
    rclass := (peek8(buf + offset) << 8) | peek8(buf + offset + 1);
    offset := offset + 2;
    
    ttl := (peek8(buf + offset) << 24) | (peek8(buf + offset + 1) << 16) |
           (peek8(buf + offset + 2) << 8) | peek8(buf + offset + 3);
    offset := offset + 4;
    
    rdlength := (peek8(buf + offset) << 8) | peek8(buf + offset + 1);
    offset := offset + 2;
    
    // Check if this is the record type we're looking for
    if (rclass != DNS_CLASS_IN) {
      offset := offset + rdlength;
      i := i + 1;
      continue;
    }
    
    // A record (IPv4)
    if ((rtype == DNS_TYPE_A) && (queryType == DNS_TYPE_A) && (rdlength == 4)) {
      // Store as IPv4 in first 4 bytes of data
      poke8(resultPtr + 40, peek8(buf + offset));
      poke8(resultPtr + 41, peek8(buf + offset + 1));
      poke8(resultPtr + 42, peek8(buf + offset + 2));
      poke8(resultPtr + 43, peek8(buf + offset + 3));
      
      // Store TTL
      poke8(resultPtr + 16, ttl & 0xFF);
      poke8(resultPtr + 17, (ttl >> 8) & 0xFF);
      poke8(resultPtr + 18, (ttl >> 16) & 0xFF);
      poke8(resultPtr + 19, (ttl >> 24) & 0xFF);
      
      // Store record type and data length
      poke8(resultPtr + 8, DNS_TYPE_A);
      poke8(resultPtr + 32, 4);
      
      poke8(resultPtr + 0, 1);  // success = true
      return true;
    }
    
    // AAAA record (IPv6)
    if ((rtype == DNS_TYPE_AAAA) && (queryType == DNS_TYPE_AAAA) && (rdlength == 16)) {
      var j: int64 := 0;
      while (j < 16) {
        poke8(resultPtr + 40 + j, peek8(buf + offset + j));
        j := j + 1;
      }
      
      // Store TTL
      poke8(resultPtr + 16, ttl & 0xFF);
      poke8(resultPtr + 17, (ttl >> 8) & 0xFF);
      poke8(resultPtr + 18, (ttl >> 16) & 0xFF);
      poke8(resultPtr + 19, (ttl >> 24) & 0xFF);
      
      // Store record type and data length
      poke8(resultPtr + 8, DNS_TYPE_AAAA);
      poke8(resultPtr + 32, 16);
      
      poke8(resultPtr + 0, 1);  // success = true
      return true;
    }
    
    // CNAME record (canonical name)
    if ((rtype == DNS_TYPE_CNAME) && (queryType == DNS_TYPE_CNAME)) {
      // Skip the name and read the canonical name
      var nameOffset: int64 := dns_skip_name(buf, offset, bufLen);
      
      // Copy the canonical name (up to 24 bytes)
      var copyLen: int64 := rdlength;
      if (copyLen > 24) {
        copyLen := 24;
      }
      
      var j: int64 := 0;
      while (j < copyLen) {
        poke8(resultPtr + 40 + j, peek8(buf + offset + j));
        j := j + 1;
      }
      
      // Store TTL
      poke8(resultPtr + 16, ttl & 0xFF);
      poke8(resultPtr + 17, (ttl >> 8) & 0xFF);
      poke8(resultPtr + 18, (ttl >> 16) & 0xFF);
      poke8(resultPtr + 19, (ttl >> 24) & 0xFF);
      
      // Store record type and data length
      poke8(resultPtr + 8, DNS_TYPE_CNAME);
      poke8(resultPtr + 32, copyLen);
      
      poke8(resultPtr + 0, 1);  // success = true
      return true;
    }
    
    // MX record (mail exchange)
    if ((rtype == DNS_TYPE_MX) && (queryType == DNS_TYPE_MX)) {
      // MX format: 2-byte priority, then domain name
      // Read priority (2 bytes, big-endian)
      var priority: int64 := (peek8(buf + offset) << 8) | peek8(buf + offset + 1);
      
      // Store priority in first 2 bytes of data
      poke8(resultPtr + 40, (priority >> 8) & 0xFF);
      poke8(resultPtr + 41, priority & 0xFF);
      
      // Skip past the priority to the domain name
      var nameOffset: int64 := dns_skip_name(buf, offset + 2, bufLen);
      
      // Copy domain name (up to 22 bytes to fit in 24)
      var copyLen: int64 := rdlength - 2;
      if (copyLen > 22) {
        copyLen := 22;
      }
      
      var j: int64 := 0;
      while (j < copyLen) {
        poke8(resultPtr + 42 + j, peek8(buf + offset + 2 + j));
        j := j + 1;
      }
      
      // Store TTL
      poke8(resultPtr + 16, ttl & 0xFF);
      poke8(resultPtr + 17, (ttl >> 8) & 0xFF);
      poke8(resultPtr + 18, (ttl >> 16) & 0xFF);
      poke8(resultPtr + 19, (ttl >> 24) & 0xFF);
      
      // Store record type and data length
      poke8(resultPtr + 8, DNS_TYPE_MX);
      poke8(resultPtr + 32, 2 + copyLen);  // priority + domain
      
      poke8(resultPtr + 0, 1);  // success = true
      return true;
    }
    
    offset := offset + rdlength;
    i := i + 1;
  }
  
  return false;
}

// ============================================================================
// Public API: DNS Resolve
// ============================================================================

// Resolve hostname to IPv4 address using specified DNS server
// resultPtr: pointer to 32-byte result buffer
// Returns: true on success, false on error
pub fn DNSResolve(hostname: int64, hostnameLen: int64, dnsServerIP: int64, resultPtr: int64): bool {
  var sock: UDPSocket;
  var buf: int64;
  var queryLen: int64;
  var nread: int64;
  var ret: int64;
  
  // Initialize result
  poke8(resultPtr + 0, 0);
  poke8(resultPtr + 8, 0);
  poke8(resultPtr + 16, 0);
  poke8(resultPtr + 24, -1);
  
  // Create UDP socket
  sock := UDPSocketNew();
  if (sock.fd < 0) {
    return false;
  }
  
  buf := BufferAlloc(512);
  if (buf == 0) {
    UDPSocketClose(sock);
    return false;
  }
  
  queryLen := dns_build_query(buf, hostname, hostnameLen, DNS_TYPE_A);
  
  ret := UDPSocketSendToAddr(sock, buf, queryLen, dnsServerIP, DNS_PORT);
  if (ret < 0) {
    BufferFree(buf, 512);
    UDPSocketClose(sock);
    return false;
  }
  
  nread := UDPSocketRecv(sock, buf, 512, 0, 0);
  if (nread < 12) {
    BufferFree(buf, 512);
    UDPSocketClose(sock);
    return false;
  }
  
  ret := dns_parse_response_ex(buf, nread, resultPtr, DNS_TYPE_A);
  
  BufferFree(buf, 512);
  UDPSocketClose(sock);
  
  return ret;
}

// ============================================================================
// Generic DNS Resolve (supports any record type)
// ============================================================================

// Resolve hostname using specified DNS server and record type
// queryType: DNS_TYPE_A, DNS_TYPE_AAAA, DNS_TYPE_MX, DNS_TYPE_CNAME
// resultPtr: pointer to 64-byte result buffer
// Returns: true on success, false on error
pub fn DNSResolveEx(hostname: int64, hostnameLen: int64, dnsServerIP: int64, queryType: int64, resultPtr: int64): bool {
  var sock: UDPSocket;
  var buf: int64;
  var queryLen: int64;
  var nread: int64;
  var ret: int64;
  
  // Initialize result
  poke8(resultPtr + 0, 0);
  poke8(resultPtr + 8, 0);
  poke8(resultPtr + 16, 0);
  poke8(resultPtr + 24, -1);
  poke8(resultPtr + 32, 0);
  
  // Create UDP socket
  sock := UDPSocketNew();
  if (sock.fd < 0) {
    return false;
  }
  
  buf := BufferAlloc(512);
  if (buf == 0) {
    UDPSocketClose(sock);
    return false;
  }
  
  queryLen := dns_build_query(buf, hostname, hostnameLen, queryType);
  
  ret := UDPSocketSendToAddr(sock, buf, queryLen, dnsServerIP, DNS_PORT);
  if (ret < 0) {
    BufferFree(buf, 512);
    UDPSocketClose(sock);
    return false;
  }
  
  nread := UDPSocketRecv(sock, buf, 512, 0, 0);
  if (nread < 12) {
    BufferFree(buf, 512);
    UDPSocketClose(sock);
    return false;
  }
  
  ret := dns_parse_response_ex(buf, nread, resultPtr, queryType);
  
  BufferFree(buf, 512);
  UDPSocketClose(sock);
  
  return ret;
}

// ============================================================================
// Specific Record Type Resolvers
// ============================================================================

// Resolve hostname to IPv6 address (AAAA record)
pub fn DNSResolveAAAA(hostname: int64, hostnameLen: int64, dnsServerIP: int64, resultPtr: int64): bool {
  return DNSResolveEx(hostname, hostnameLen, dnsServerIP, DNS_TYPE_AAAA, resultPtr);
}

// Resolve hostname to IPv6 address using Google DNS
pub fn DNSResolveAAAAGoogle(hostname: int64, hostnameLen: int64, resultPtr: int64): bool {
  var googleDNS: int64 := IPPack(8, 8, 8, 8);
  return DNSResolveAAAA(hostname, hostnameLen, googleDNS, resultPtr);
}

// Resolve hostname to IPv6 address using Cloudflare DNS
pub fn DNSResolveAAAACoudflare(hostname: int64, hostnameLen: int64, resultPtr: int64): bool {
  var cfDNS: int64 := IPPack(1, 1, 1, 1);
  return DNSResolveAAAA(hostname, hostnameLen, cfDNS, resultPtr);
}

// Resolve hostname to canonical name (CNAME record)
pub fn DNSResolveCNAME(hostname: int64, hostnameLen: int64, dnsServerIP: int64, resultPtr: int64): bool {
  return DNSResolveEx(hostname, hostnameLen, dnsServerIP, DNS_TYPE_CNAME, resultPtr);
}

// Resolve hostname to canonical name using Google DNS
pub fn DNSResolveCNAMEGoogle(hostname: int64, hostnameLen: int64, resultPtr: int64): bool {
  var googleDNS: int64 := IPPack(8, 8, 8, 8);
  return DNSResolveCNAME(hostname, hostnameLen, googleDNS, resultPtr);
}

// Resolve hostname to canonical name using Cloudflare DNS
pub fn DNSResolveCNAMECloudflare(hostname: int64, hostnameLen: int64, resultPtr: int64): bool {
  var cfDNS: int64 := IPPack(1, 1, 1, 1);
  return DNSResolveCNAME(hostname, hostnameLen, cfDNS, resultPtr);
}

// Resolve hostname to mail exchange (MX record)
pub fn DNSResolveMX(hostname: int64, hostnameLen: int64, dnsServerIP: int64, resultPtr: int64): bool {
