}

// ============================================================================
// Helper Functions
// ============================================================================

// Helper: Print IPv4 address
pub fn DNSPrintIP(ip: int64) {
  PrintInt((ip >> 24) & 0xFF);
  PrintStr(".");
  PrintInt((ip >> 16) & 0xFF);
  PrintStr(".");
  PrintInt((ip >> 8) & 0xFF);
  PrintStr(".");
  PrintInt(ip & 0xFF);
}

// Helper: Print IPv6 address
pub fn DNSPrintIPV6(data: int64) {
  var i: int64 := 0;
  var first: bool := true;
  
  while (i < 16) {
    var word: int64 := (peek8(data + i) << 8) | peek8(data + i + 1);
    
    if (word == 0 && first) {
      // Skip leading zeros
      i := i + 2;
      continue;
    }
    
    if (!first) {
      PrintStr(":");
    }
    first := false;
    
    // Print in hex
    var hex: string := "";
    if ((word >> 12) > 0) {
      // Simplified hex output
    }
    PrintInt(word);
    
    i := i + 2;
  }
}

// Helper: Get IPv4 from result (for A records)
pub fn DNSResultGetIPv4(resultPtr: int64): int64 {
  return (peek8(resultPtr + 40) << 24) | (peek8(resultPtr + 41) << 16) |
         (peek8(resultPtr + 42) << 8) | peek8(resultPtr + 43);
}

// Helper: Get TTL from result
pub fn DNSResultGetTTL(resultPtr: int64): int64 {
  return (peek8(resultPtr + 16) << 24) | (peek8(resultPtr + 17) << 16) |
         (peek8(resultPtr + 18) << 8) | peek8(resultPtr + 19);
}

// Helper: Get record type from result
pub fn DNSResultGetType(resultPtr: int64): int64 {
  return peek8(resultPtr + 8);
}

// Helper: Check if result is success
pub fn DNSResultIsSuccess(resultPtr: int64): bool {
  return peek8(resultPtr + 0) != 0;
}
