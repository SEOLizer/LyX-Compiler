}

// ============================================================================
// ICMP (Ping)
// ============================================================================

// ICMP Echo Request/Reply Header (8 bytes)
// +--------+--------+--------+--------+--------+--------+--------+--------+
// |  Type  |  Code  |          Checksum           |       ID        |  Seq  |
// +--------+--------+--------+--------+--------+--------+--------+--------+
pub type ICMPHeader = struct {
  icmp_type: uint8;
  icmp_code: uint8;
  icmp_cksum: uint16;
  icmp_id: uint16;
  icmp_seq: uint16;
};

// Create an ICMP echo request packet
pub fn ICMPMakeEchoRequest(id: uint16, seq: uint16): ICMPHeader {
  var hdr: ICMPHeader;
  hdr.icmp_type := ICMP_ECHO as uint8;
  hdr.icmp_code := 0;
  hdr.icmp_cksum := 0;
  hdr.icmp_id := id;
  hdr.icmp_seq := seq;
  return hdr;
}

// Calculate ICMP checksum (simple 16-bit sum)
pub fn ICMPChecksum(data: int64, len: int64): uint16 {
  var sum: int64 := 0;
  var i: int64 := 0;
  
  // Sum all 16-bit words
  while (i < len) {
    if ((i + 1) < len) {
      sum := sum + (peek8(data + i + 1) << 8) + peek8(data + i);
    } else {
      sum := sum + peek8(data + i);
    }
    i := i + 2;
  }
  
  // Add carries
  while ((sum >> 16) > 0) {
    sum := (sum & 0xFFFF) + (sum >> 16);
  }
  
  return ((~sum) & 0xFFFF) as uint16;
}

// Send ICMP echo request (ping)
pub fn ICMPPing(destIP: int64, id: uint16, seq: uint16, timeoutSecs: int64): int64 {
  var sock: RawSocket;
  var buf: int64;
  var replyBuf: int64;
  var destAddr: int64;
  var hdr: ICMPHeader;
  var n: int64;
  
  // Create raw socket for ICMP
  sock := RawSocketNew(IPPROTO_ICMP);
  if (sock.fd < 0) {
    return -1;
  }
  
  // Allocate buffer for packet
  buf := BufferAlloc(1024);
  if (buf == 0) {
    RawSocketClose(sock);
    return -1;
  }
  
  replyBuf := BufferAlloc(1024);
  if (replyBuf == 0) {
    BufferFree(buf, 1024);
    RawSocketClose(sock);
    return -1;
  }
  
  // Build ICMP header
  hdr := ICMPMakeEchoRequest(id, seq);
  
  // Write header to buffer using poke8 (little-endian)
  poke8(buf + 0, hdr.icmp_type as int64);
  poke8(buf + 1, hdr.icmp_code as int64);
  // checksum placeholder (bytes 2-3) - set to 0 for now
  poke8(buf + 2, 0);
  poke8(buf + 3, 0);
  // ID and sequence (little-endian)
  poke8(buf + 4, (id & 0xFF) as int64);
  poke8(buf + 5, ((id >> 8) & 0xFF) as int64);
  poke8(buf + 6, (seq & 0xFF) as int64);
  poke8(buf + 7, ((seq >> 8) & 0xFF) as int64);
  
  // Calculate and write checksum
  var cksum: uint16 := ICMPChecksum(buf, 8);
  poke8(buf + 2, (cksum & 0xFF) as int64);
  poke8(buf + 3, ((cksum >> 8) & 0xFF) as int64);
  
  // Set destination address (as int64 - packed sockaddr_in)
  destAddr := 0;
  // family = AF_INET (2) in little-endian at offset 0
  poke8(destAddr + 0, 2);
  poke8(destAddr + 1, 0);
  // port = 0 at offset 2
  poke8(destAddr + 2, 0);
  poke8(destAddr + 3, 0);
  // IP address at offset 4 (already in network order in destIP)
  // zero padding at offset 8
  
  // Send ICMP packet
  n := RawSocketSendTo(sock, buf, 8, destAddr);
  
  // Wait for reply (simplified - just check once)
  // In a real implementation, you'd loop with timeout
  
  // Cleanup
  BufferFree(buf, 1024);
  BufferFree(replyBuf, 1024);
  RawSocketClose(sock);
  
  return n;
}

// ============================================================================
// ARP (Address Resolution Protocol)
// ============================================================================

// Create an Ethernet header for ARP
pub fn EthernetHeaderCreate(dstMac: MacAddr, srcMac: MacAddr, ethertype: int64): EthernetHeader {
  var hdr: EthernetHeader;
  hdr.dst := dstMac;
  hdr.src := srcMac;
  hdr.ethertype := ethertype as uint16;
  return hdr;
}

// Create an ARP request packet
pub fn ARPMakeRequest(senderMac: MacAddr, senderIP: int64, targetIP: int64): ARPPacket {
  var pkt: ARPPacket;
  
  // Hardware type: Ethernet
  pkt.ar_hrd := ARPHRD_ETHER as uint16;
  
  // Protocol: IPv4
  pkt.ar_pro := ETH_P_IP as uint16;
  
  // Address lengths
  pkt.ar_hln := 6;
  pkt.ar_pln := 4;
  
  // Operation: Request
  pkt.ar_op := ARPOP_REQUEST as uint16;
  
  // Sender addresses
  pkt.ar_sha := senderMac;
  pkt.ar_sip := senderIP;
  
  // Target addresses (unknown for request - broadcast)
  pkt.ar_tha.a := 0;
  pkt.ar_tha.b := 0;
  pkt.ar_tha.c := 0;
  pkt.ar_tha.d := 0;
  pkt.ar_tha.e := 0;
  pkt.ar_tha.f := 0;
  pkt.ar_tip := targetIP;
  
  return pkt;
}

// Create an ARP reply packet
pub fn ARPMakeReply(senderMac: MacAddr, senderIP: int64, targetMac: MacAddr, targetIP: int64): ARPPacket {
  var pkt: ARPPacket;
  
  pkt.ar_hrd := ARPHRD_ETHER as uint16;
  pkt.ar_pro := ETH_P_IP as uint16;
  pkt.ar_hln := 6;
  pkt.ar_pln := 4;
  pkt.ar_op := ARPOP_REPLY as uint16;
  
  pkt.ar_sha := senderMac;
  pkt.ar_sip := senderIP;
  pkt.ar_tha := targetMac;
  pkt.ar_tip := targetIP;
  
  return pkt;
}

// Serialize Ethernet + ARP packet to buffer
// Returns total packet length
pub fn ARPSerializePacket(eth: EthernetHeader, arp: ARPPacket, buf: int64): int64 {
  var offset: int64 := 0;
  
  // Ethernet header (14 bytes)
  poke8(buf + offset, eth.dst.a as int64); offset := offset + 1;
  poke8(buf + offset, eth.dst.b as int64); offset := offset + 1;
  poke8(buf + offset, eth.dst.c as int64); offset := offset + 1;
  poke8(buf + offset, eth.dst.d as int64); offset := offset + 1;
  poke8(buf + offset, eth.dst.e as int64); offset := offset + 1;
  poke8(buf + offset, eth.dst.f as int64); offset := offset + 1;
  
  poke8(buf + offset, eth.src.a as int64); offset := offset + 1;
  poke8(buf + offset, eth.src.b as int64); offset := offset + 1;
  poke8(buf + offset, eth.src.c as int64); offset := offset + 1;
  poke8(buf + offset, eth.src.d as int64); offset := offset + 1;
  poke8(buf + offset, eth.src.e as int64); offset := offset + 1;
  poke8(buf + offset, eth.src.f as int64); offset := offset + 1;
  
  // EtherType (big-endian)
  poke8(buf + offset, ((eth.ethertype >> 8) & 0xFF) as int64); offset := offset + 1;
  poke8(buf + offset, (eth.ethertype & 0xFF) as int64); offset := offset + 1;
  
  // ARP packet (28 bytes)
  // Hardware type (little-endian)
  poke8(buf + offset, (arp.ar_hrd & 0xFF) as int64); offset := offset + 1;
  poke8(buf + offset, ((arp.ar_hrd >> 8) & 0xFF) as int64); offset := offset + 1;
  
  // Protocol type (big-endian)
  poke8(buf + offset, ((arp.ar_pro >> 8) & 0xFF) as int64); offset := offset + 1;
  poke8(buf + offset, (arp.ar_pro & 0xFF) as int64); offset := offset + 1;
  
  // Hlen and Pln
  poke8(buf + offset, arp.ar_hln as int64); offset := offset + 1;
  poke8(buf + offset, arp.ar_pln as int64); offset := offset + 1;
  
  // Operation (little-endian)
  poke8(buf + offset, (arp.ar_op & 0xFF) as int64); offset := offset + 1;
  poke8(buf + offset, ((arp.ar_op >> 8) & 0xFF) as int64); offset := offset + 1;
  
  // Sender MAC
  poke8(buf + offset, arp.ar_sha.a as int64); offset := offset + 1;
  poke8(buf + offset, arp.ar_sha.b as int64); offset := offset + 1;
  poke8(buf + offset, arp.ar_sha.c as int64); offset := offset + 1;
  poke8(buf + offset, arp.ar_sha.d as int64); offset := offset + 1;
  poke8(buf + offset, arp.ar_sha.e as int64); offset := offset + 1;
  poke8(buf + offset, arp.ar_sha.f as int64); offset := offset + 1;
  
  // Sender IP (4 bytes, network byte order)
  poke8(buf + offset, ((arp.ar_sip >> 24) & 0xFF) as int64); offset := offset + 1;
  poke8(buf + offset, ((arp.ar_sip >> 16) & 0xFF) as int64); offset := offset + 1;
  poke8(buf + offset, ((arp.ar_sip >> 8) & 0xFF) as int64); offset := offset + 1;
  poke8(buf + offset, (arp.ar_sip & 0xFF) as int64); offset := offset + 1;
  
  // Target MAC
  poke8(buf + offset, arp.ar_tha.a as int64); offset := offset + 1;
  poke8(buf + offset, arp.ar_tha.b as int64); offset := offset + 1;
  poke8(buf + offset, arp.ar_tha.c as int64); offset := offset + 1;
  poke8(buf + offset, arp.ar_tha.d as int64); offset := offset + 1;
  poke8(buf + offset, arp.ar_tha.e as int64); offset := offset + 1;
  poke8(buf + offset, arp.ar_tha.f as int64); offset := offset + 1;
  
  // Target IP (4 bytes, network byte order)
  poke8(buf + offset, ((arp.ar_tip >> 24) & 0xFF) as int64); offset := offset + 1;
  poke8(buf + offset, ((arp.ar_tip >> 16) & 0xFF) as int64); offset := offset + 1;
  poke8(buf + offset, ((arp.ar_tip >> 8) & 0xFF) as int64); offset := offset + 1;
  poke8(buf + offset, (arp.ar_tip & 0xFF) as int64); offset := offset + 1;
  
  // Total: 14 + 28 = 42 bytes
  return offset;
}

// Create a broadcast MAC address (ff:ff:ff:ff:ff:ff)
pub fn MacBroadcast(): MacAddr {
  var mac: MacAddr;
  mac.a := 0xFF;
  mac.b := 0xFF;
  mac.c := 0xFF;
  mac.d := 0xFF;
  mac.e := 0xFF;
  mac.f := 0xFF;
  return mac;
}

// Convert IP address to packed format (network byte order)
pub fn IPPack(a: uint8, b: uint8, c: uint8, d: uint8): int64 {
  return ((a as int64) << 24) | ((b as int64) << 16) | ((c as int64) << 8) | (d as int64);
}

// Convert packed IP to string representation (simple)
pub fn IPUnpack(ip: int64): IPAddr {
  var addr: IPAddr;
  addr.a := ((ip >> 24) & 0xFF) as uint8;
  addr.b := ((ip >> 16) & 0xFF) as uint8;
  addr.c := ((ip >> 8) & 0xFF) as uint8;
  addr.d := (ip & 0xFF) as uint8;
  addr.family := AF_INET;
  return addr;
}

// ============================================================================
// Non-blocking I/O Support
// ============================================================================

// Fcntl constants for non-blocking
con F_GETFL: int64 := 3;
con F_SETFL: int64 := 4;
con O_NONBLOCK: int64 := 2048;

// Error codes
con EAGAIN: int64 := 11;
con EINPROGRESS: int64 := 115;
con EWOULDBLOCK: int64 := 11;

// Set socket to non-blocking mode
// Returns 0 on success, -1 on error
pub fn SocketSetNonBlocking(fd: int64): int64 {
  var flags: int64;
  
  // Get current flags
  flags := sys_fcntl(fd, F_GETFL, 0);
  if (flags < 0) {
    return -1;
  }
  
  // Set O_NONBLOCK flag
  flags := flags | O_NONBLOCK;
  
  // Set new flags
  return sys_fcntl(fd, F_SETFL, flags);
}

// Set socket to blocking mode
// Returns 0 on success, -1 on error
pub fn SocketSetBlocking(fd: int64): int64 {
  var flags: int64;
  
  // Get current flags
  flags := sys_fcntl(fd, F_GETFL, 0);
  if (flags < 0) {
    return -1;
  }
  
  // Clear O_NONBLOCK flag
  flags := flags & (~O_NONBLOCK);
  
  // Set new flags
  return sys_fcntl(fd, F_SETFL, flags);
}

// Check if socket is non-blocking
// Returns true if non-blocking, false if blocking
pub fn SocketIsNonBlocking(fd: int64): bool {
  var flags: int64;
  
  flags := sys_fcntl(fd, F_GETFL, 0);
  if (flags < 0) {
    return false;
  }
  
  return (flags & O_NONBLOCK) != 0;
}

// ============================================================================
// poll() support
// ============================================================================

// pollfd structure (16 bytes)
// Offset 0: fd (int64)
// Offset 8: events (int16)
// Offset 10: revents (int16)
pub type PollFD = struct {
  fd: int64;
  events: int16;
  revents: int16;
};

// Poll events
con POLLIN: int16 := 1;     // Data available to read
con POLLOUT: int16 := 4;    // Can write without blocking
con POLLERR: int16 := 8;    // Error condition
con POLLHUP: int16 := 16;   // Hangup
con POLLNVAL: int32 := 32;  // Invalid file descriptor

// Wait for events on file descriptors
// fds: pointer to array of PollFD
// nfds: number of entries
// timeout: milliseconds (-1 = infinite, 0 = immediate)
// Returns: number of ready fds, 0 = timeout, -1 = error
pub fn SocketPoll(fds: int64, nfds: int64, timeout: int64): int64 {
  return sys_poll(fds, nfds, timeout);
}

// Check if POLLIN is set in revents
pub fn PollFDReadable(fds: int64, index: int64): bool {
  var offset: int64 := index * 16 + 10;  // revents at offset 10
  var revents: int16 := peek8(fds + offset) as int16;
  return (revents & POLLIN) != 0;
}

// Check if POLLOUT is set in revents
pub fn PollFDWritable(fds: int64, index: int64): bool {
  var offset: int64 := index * 16 + 10;  // revents at offset 10
  var revents: int16 := peek8(fds + offset) as int16;
  return (revents & POLLOUT) != 0;
}

// Check if POLLERR is set in revents
pub fn PollFDError(fds: int64, index: int64): bool {
  var offset: int64 := index * 16 + 10;  // revents at offset 10
  var revents: int16 := peek8(fds + offset) as int16;
  return (revents & POLLERR) != 0;
}

// ============================================================================
// select() support
// ============================================================================

// fd_set management for select()
// Each fd_set holds up to 1024 file descriptors (Linux limit)

// Initialize fd_set (clear all bits)
pub fn FDSetZero(fdSet: int64) {
  var i: int64 := 0;
  while (i < 128) {  // 1024 bits = 128 bytes
    poke8(fdSet + i, 0);
    i := i + 1;
  }
}

// Set a file descriptor in fd_set
pub fn FDSet(fd: int64, fdSet: int64) {
  var byteIndex: int64 := fd >> 3;      // fd / 8
  var bitIndex: int64 := fd & 7;        // fd % 8
  var mask: int64 := 1 << bitIndex;
  
  var current: int64 := peek8(fdSet + byteIndex);
  current := current | mask;
  poke8(fdSet + byteIndex, current);
}

// Clear a file descriptor in fd_set
pub fn FDClr(fd: int64, fdSet: int64) {
  var byteIndex: int64 := fd >> 3;
  var bitIndex: int64 := fd & 7;
  var mask: int64 := 1 << bitIndex;
  
  var current: int64 := peek8(fdSet + byteIndex);
  current := current & (~mask);
  poke8(fdSet + byteIndex, current);
}

// Check if a file descriptor is set in fd_set
pub fn FDIsSet(fd: int64, fdSet: int64): bool {
  var byteIndex: int64 := fd >> 3;
  var bitIndex: int64 := fd & 7;
  var mask: int64 := 1 << bitIndex;
  
  var current: int64 := peek8(fdSet + byteIndex);
  return (current & mask) != 0;
}

// ============================================================================
// Non-blocking Connect
// ============================================================================

// Non-blocking connect result
pub type ConnectResult = struct {
  success: bool;
  error: int64;  // 0 = no error, positive = errno
};

// Connect with timeout using poll()
// Returns ConnectResult with success=true if connected, or error code
pub fn TCPConnectNonBlocking(ip: int64, port: int64, timeoutMs: int64): ConnectResult {
  var result: ConnectResult;
  var conn: TCPConn;
  var fd: int64;
  var addr: int64;
  var ret: int64;
  var pollFd: int64;
  var pollResult: int64;
  
  result.success := false;
  result.error := 0;
  
  // Create socket
  fd := sys_socket(AF_INET, SOCK_STREAM, IPPROTO_TCP);
  if (fd < 0) {
    result.error := -1;
    return result;
  }
  
  // Set non-blocking
  ret := SocketSetNonBlocking(fd);
  if (ret < 0) {
    sys_close(fd);
    result.error := -2;
    return result;
  }
  
  // Allocate sockaddr_in
  addr := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (addr <= 0) {
    sys_close(fd);
    result.error := -3;
    return result;
  }
  
  // Fill sockaddr_in
  poke8(addr, 2);
  poke8(addr + 1, 0);
  poke8(addr + 2, (port >> 8) & 0xFF);
  poke8(addr + 3, port & 0xFF);
  poke8(addr + 4, (ip >> 24) & 0xFF);
  poke8(addr + 5, (ip >> 16) & 0xFF);
  poke8(addr + 6, (ip >> 8) & 0xFF);
  poke8(addr + 7, ip & 0xFF);
  poke8(addr + 8, 0);
  poke8(addr + 9, 0);
  poke8(addr + 10, 0);
  poke8(addr + 11, 0);
  poke8(addr + 12, 0);
  poke8(addr + 13, 0);
  poke8(addr + 14, 0);
  poke8(addr + 15, 0);
  
  // Attempt non-blocking connect
  ret := sys_connect(fd, addr, 16);
  munmap(addr, 16);
  
  if (ret == 0) {
    // Immediate success
    result.success := true;
    result.error := 0;
    return result;
  }
  
  if (ret != EINPROGRESS) {
    // Immediate error (not EINPROGRESS)
    sys_close(fd);
    result.error := ret;
    return result;
  }
  
  // Connection is in progress - wait for it with poll()
  pollFd := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (pollFd <= 0) {
    sys_close(fd);
    result.error := -4;
    return result;
  }
  
  // Set up pollfd
  // fd at offset 0
  poke8(pollFd + 0, fd & 0xFF);
  poke8(pollFd + 1, (fd >> 8) & 0xFF);
  poke8(pollFd + 2, (fd >> 16) & 0xFF);
  poke8(pollFd + 3, (fd >> 24) & 0xFF);
  poke8(pollFd + 4, (fd >> 32) & 0xFF);
  poke8(pollFd + 5, (fd >> 40) & 0xFF);
  poke8(pollFd + 6, (fd >> 48) & 0xFF);
  poke8(pollFd + 7, (fd >> 56) & 0xFF);
  
  // events = POLLOUT at offset 8 (int16)
  poke8(pollFd + 8, POLLOUT & 0xFF);
  poke8(pollFd + 9, (POLLOUT >> 8) & 0xFF);
  
  // revents at offset 10 (int16) - initialize to 0
  poke8(pollFd + 10, 0);
  poke8(pollFd + 11, 0);
  
  // Wait for connection
  pollResult := sys_poll(pollFd, 1, timeoutMs);
  
  if (pollResult < 0) {
    // Poll error
    munmap(pollFd, 16);
    sys_close(fd);
    result.error := pollResult;
    return result;
  }
  
  if (pollResult == 0) {
    // Timeout
    munmap(pollFd, 16);
    sys_close(fd);
    result.error := EAGAIN;  // Timeout
    return result;
  }
  
  // Check revents for POLLOUT (connected) or POLLERR (error)
  var revents: int16 := peek8(pollFd + 10) as int16;
  munmap(pollFd, 16);
  
  if ((revents & POLLOUT) != 0) {
    // Connection succeeded - check for socket error
    var sockErr: int64 := 0;
    var sockErrResult: int64 := sys_getsockopt(fd, SOL_SOCKET, SO_ERROR, sockErr, 4);
    
    if (sockErrResult < 0) {
      sys_close(fd);
      result.error := sockErrResult;
      return result;
    }
    
    if (sockErr != 0) {
      sys_close(fd);
      result.error := sockErr;
      return result;
    }
    
    result.success := true;
    result.error := 0;
    return result;
  }
  
  if ((revents & POLLERR) != 0) {
    // Error - get socket error
    var sockErr: int64 := 0;
    sys_getsockopt(fd, SOL_SOCKET, SO_ERROR, sockErr, 4);
    sys_close(fd);
    result.error := sockErr;
    return result;
  }
  
  // Unexpected state
  sys_close(fd);
  result.error := -5;
  return result;
}

// ============================================================================
// Socket Ready Check (using select for single socket)
// ============================================================================

// Check if socket is ready for reading
// Returns: 1 = ready, 0 = not ready (timeout), -1 = error
pub fn SocketCanRead(fd: int64, timeoutMs: int64): int64 {
  var fdSet: int64;
  var result: int64;
  
  fdSet := mmap(0, 128, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (fdSet <= 0) {
    return -1;
  }
  
  FDSetZero(fdSet);
  FDSet(fd, fdSet);
  
  // Use select with timeout
  // timeval structure: tv_sec (int64) at offset 0, tv_usec (int64) at offset 8
  var timeval: int64 := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (timeval <= 0) {
    munmap(fdSet, 128);
    return -1;
  }
  
  // Set timeout
  poke8(timeval + 0, (timeoutMs / 1000) & 0xFF);
  poke8(timeval + 1, ((timeoutMs / 1000) >> 8) & 0xFF);
  poke8(timeval + 2, ((timeoutMs / 1000) >> 16) & 0xFF);
  poke8(timeval + 3, ((timeoutMs / 1000) >> 24) & 0xFF);
  poke8(timeval + 4, ((timeoutMs / 1000) >> 32) & 0xFF);
  poke8(timeval + 5, ((timeoutMs / 1000) >> 40) & 0xFF);
  poke8(timeval + 6, ((timeoutMs / 1000) >> 48) & 0xFF);
  poke8(timeval + 7, ((timeoutMs / 1000) >> 56) & 0xFF;
  
  // tv_usec = (timeoutMs % 1000) * 1000
  var usec: int64 := (timeoutMs % 1000) * 1000;
  poke8(timeval + 8, usec & 0xFF);
  poke8(timeval + 9, (usec >> 8) & 0xFF);
  poke8(timeval + 10, (usec >> 16) & 0xFF);
  poke8(timeval + 11, (usec >> 24) & 0xFF);
  poke8(timeval + 12, (usec >> 32) & 0xFF);
  poke8(timeval + 13, (usec >> 40) & 0xFF);
  poke8(timeval + 14, (usec >> 48) & 0xFF);
  poke8(timeval + 15, (usec >> 56) & 0xFF);
  
  result := sys_select(fd + 1, fdSet, 0, 0, timeval);
  
  munmap(timeval, 16);
  munmap(fdSet, 128);
  
  if (result < 0) {
    return -1;
  }
  
  if (result == 0) {
    return 0;
  }
  
  if (FDIsSet(fd, fdSet)) {
    return 1;
  }
  
  return 0;
}

// Check if socket is ready for writing
// Returns: 1 = ready, 0 = not ready (timeout), -1 = error
pub fn SocketCanWrite(fd: int64, timeoutMs: int64): int64 {
  var fdSet: int64;
  var result: int64;
  
  fdSet := mmap(0, 128, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (fdSet <= 0) {
    return -1;
  }
  
  FDSetZero(fdSet);
  FDSet(fd, fdSet);
  
  // Use select with timeout
  var timeval: int64 := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (timeval <= 0) {
    munmap(fdSet, 128);
    return -1;
  }
  
  // Set timeout
  poke8(timeval + 0, (timeoutMs / 1000) & 0xFF);
  poke8(timeval + 1, ((timeoutMs / 1000) >> 8) & 0xFF);
  poke8(timeval + 2, ((timeoutMs / 1000) >> 16) & 0xFF);
  poke8(timeval + 3, ((timeoutMs / 1000) >> 24) & 0xFF);
  poke8(timeval + 4, ((timeoutMs / 1000) >> 32) & 0xFF);
  poke8(timeval + 5, ((timeoutMs / 1000) >> 40) & 0xFF);
  poke8(timeval + 6, ((timeoutMs / 1000) >> 48) & 0xFF);
  poke8(timeval + 7, ((timeoutMs / 1000) >> 56) & 0xFF);
  
  var usec: int64 := (timeoutMs % 1000) * 1000;
  poke8(timeval + 8, usec & 0xFF);
  poke8(timeval + 9, (usec >> 8) & 0xFF);
  poke8(timeval + 10, (usec >> 16) & 0xFF);
  poke8(timeval + 11, (usec >> 24) & 0xFF);
  poke8(timeval + 12, (usec >> 32) & 0xFF);
  poke8(timeval + 13, (usec >> 40) & 0xFF);
  poke8(timeval + 14, (usec >> 48) & 0xFF);
  poke8(timeval + 15, (usec >> 56) & 0xFF);
  
  result := sys_select(fd + 1, 0, fdSet, 0, timeval);
  
  munmap(timeval, 16);
  munmap(fdSet, 128);
  
  if (result < 0) {
    return -1;
  }
  
  if (result == 0) {
    return 0;
  }
  
  if (FDIsSet(fd, fdSet)) {
    return 1;
  }
  
  return 0;
}
