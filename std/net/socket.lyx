// Lyx Network Library - Socket API
// Blocking and non-blocking socket operations

unit std.net.socket;

import std.net.types;
import std.net.syscalls;

// ============================================================================
// Memory Buffer Allocation
// ============================================================================

// Allocate a memory buffer using mmap
// Returns pointer to buffer, or 0 on failure
pub fn BufferAlloc(size: int64): int64 {
  // mmap(addr=0, length=size, prot=RW, flags=MAP_ANONYMOUS|MAP_PRIVATE, fd=-1, offset=0)
  return mmap(0, size, PROT_RW, MAP_ANON, FD_NONE, 0);
}

// Free a memory buffer allocated with BufferAlloc
pub fn BufferFree(buf: int64, size: int64): int64 {
  return munmap(buf, size);
}

// ============================================================================
// TCP Listener
// ============================================================================

pub type TCPListener = struct {
  fd: int64;
};

// Create a new TCP listener
pub fn TCPListenerNew(): TCPListener {
  var listener: TCPListener;
  var fd: int64;

  // Create socket
  fd := sys_socket(AF_INET, SOCK_STREAM, IPPROTO_TCP);
  if (fd < 0) {
    listener.fd := -1;
    return listener;
  }

  listener.fd := fd;
  return listener;
}

// Set SO_REUSEADDR option (call before bind)
pub fn TCPListenerSetReuseAddr(listener: TCPListener): int64 {
  var optval: int64 := 1;
  // setsockopt(fd, SOL_SOCKET, SO_REUSEADDR, &optval, sizeof(optval))
  return sys_setsockopt(listener.fd, SOL_SOCKET, SO_REUSEADDR, optval, 4);
}

// Set SO_REUSEPORT option (call before bind)
// Allows multiple sockets to bind to the same port
pub fn TCPListenerSetReusePort(listener: TCPListener): int64 {
  var optval: int64 := 1;
  return sys_setsockopt(listener.fd, SOL_SOCKET, SO_REUSEPORT, optval, 4);
}

// Set listen backlog queue size
pub fn TCPListenerSetBacklog(listener: TCPListener, backlog: int64): int64 {
  return sys_listen(listener.fd, backlog);
}

// Bind to address and port
// addr: pointer to sockaddr_in structure (16 bytes)
pub fn TCPListenerBind(listener: TCPListener, addr: int64): int64 {
  return sys_bind(listener.fd, addr, 16);
}

// Bind to IP and port (convenience function)
// ip: packed IP address (use IPPack)
// port: port number in host byte order
pub fn TCPListenerBindTo(listener: TCPListener, ip: int64, port: int64): int64 {
  var addr: int64;
  var ret: int64;
  
  // Allocate sockaddr_in on stack (use mmap for now)
  addr := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (addr <= 0) {
    return -1;
  }
  
  // Fill sockaddr_in structure
  // sin_family = AF_INET (2) - little endian
  poke8(addr, 2);
  poke8(addr + 1, 0);
  
  // sin_port - BIG ENDIAN (network byte order)
  poke8(addr + 2, (port >> 8) & 0xFF);
  poke8(addr + 3, port & 0xFF);
  
  // sin_addr - network byte order (already packed correctly)
  poke8(addr + 4, (ip >> 24) & 0xFF);
  poke8(addr + 5, (ip >> 16) & 0xFF);
  poke8(addr + 6, (ip >> 8) & 0xFF);
  poke8(addr + 7, ip & 0xFF);
  
  // Zero padding
  poke8(addr + 8, 0);
  poke8(addr + 9, 0);
  poke8(addr + 10, 0);
  poke8(addr + 11, 0);
  poke8(addr + 12, 0);
  poke8(addr + 13, 0);
  poke8(addr + 14, 0);
  poke8(addr + 15, 0);
  
  ret := sys_bind(listener.fd, addr, 16);
  munmap(addr, 16);
  return ret;
}

// Start listening
pub fn TCPListenerListen(listener: TCPListener, backlog: int64): int64 {
  return sys_listen(listener.fd, backlog);
}

// Accept a connection (simplified - no client address)
pub fn TCPListenerAccept(listener: TCPListener): TCPConn {
  var conn: TCPConn;
  var clientFd: int64;
  
  // Accept with null pointers (0) for address
  clientFd := sys_accept(listener.fd, 0, 0);
  if (clientFd < 0) {
    conn.fd := -1;
    return conn;
  }

  conn.fd := clientFd;
  return conn;
}

// Close listener
pub fn TCPListenerClose(listener: TCPListener) {
  if (listener.fd >= 0) {
    sys_close(listener.fd);
  }
}

// ============================================================================
// TCP Connection
// ============================================================================

pub type TCPConn = struct {
  fd: int64;
};

// Read from connection
pub fn TCPConnRead(conn: TCPConn, buf: int64, n: int64): int64 {
  return sys_read(conn.fd, buf, n);
}

// Write to connection
pub fn TCPConnWrite(conn: TCPConn, buf: int64, n: int64): int64 {
  return sys_write(conn.fd, buf, n);
}

// Close connection
pub fn TCPConnClose(conn: TCPConn) {
  if (conn.fd >= 0) {
    sys_close(conn.fd);
  }
}

// ============================================================================
// TCP Options
// ============================================================================

// Set TCP_NODELAY (disable Nagle's algorithm)
// Returns 0 on success, -1 on error
pub fn TCPConnSetNodelay(conn: TCPConn, enable: bool): int64 {
  var optval: int64;
  if (enable) {
    optval := 1;
  } else {
    optval := 0;
  }
  return sys_setsockopt(conn.fd, IPPROTO_TCP, TCP_NODELAY, optval, 4);
}

// Set SO_KEEPALIVE (enable TCP keep-alive probes)
// Returns 0 on success, -1 on error
pub fn TCPConnSetKeepAlive(conn: TCPConn, enable: bool): int64 {
  var optval: int64;
  if (enable) {
    optval := 1;
  } else {
    optval := 0;
  }
  return sys_setsockopt(conn.fd, SOL_SOCKET, SO_KEEPALIVE, optval, 4);
}

// Get socket error status (SO_ERROR)
// Returns 0 if no error, or errno value
pub fn TCPConnGetError(conn: TCPConn): int64 {
  var optval: int64 := 0;
  var result: int64;
  // getsockopt returns 0 on success, -1 on error
  result := sys_getsockopt(conn.fd, SOL_SOCKET, SO_ERROR, optval, 4);
  if (result < 0) {
    return result;
  }
  return optval;
}

// Set socket receive buffer size (SO_RCVBUF)
// Returns 0 on success, -1 on error
pub fn TCPConnSetRecvBuf(conn: TCPConn, size: int64): int64 {
  return sys_setsockopt(conn.fd, SOL_SOCKET, SO_RCVBUF, size, 4);
}

// Set socket send buffer size (SO_SNDBUF)
// Returns 0 on success, -1 on error
pub fn TCPConnSetSendBuf(conn: TCPConn, size: int64): int64 {
  return sys_setsockopt(conn.fd, SOL_SOCKET, SO_SNDBUF, size, 4);
}

// Set SO_REUSEADDR on connection socket
// Returns 0 on success, -1 on error
pub fn TCPConnSetReuseAddr(conn: TCPConn, enable: bool): int64 {
  var optval: int64;
  if (enable) {
    optval := 1;
  } else {
    optval := 0;
  }
  return sys_setsockopt(conn.fd, SOL_SOCKET, SO_REUSEADDR, optval, 4);
}

// Connect to a remote server
// Returns TCPConn with fd >= 0 on success, fd < 0 on error
pub fn TCPConnect(ip: int64, port: int64): TCPConn {
  var conn: TCPConn;
  var fd: int64;
  var addr: int64;
  var ret: int64;
  
  // Create socket
  fd := sys_socket(AF_INET, SOCK_STREAM, IPPROTO_TCP);
  if (fd < 0) {
    conn.fd := fd;
    return conn;
  }
  
  // Allocate sockaddr_in
  addr := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (addr <= 0) {
    sys_close(fd);
    conn.fd := -1;
    return conn;
  }
  
  // Fill sockaddr_in structure
  poke8(addr, 2);      // AF_INET
  poke8(addr + 1, 0);
  
  // sin_port - BIG ENDIAN
  poke8(addr + 2, (port >> 8) & 0xFF);
  poke8(addr + 3, port & 0xFF);
  
  // sin_addr - network byte order
  poke8(addr + 4, (ip >> 24) & 0xFF);
  poke8(addr + 5, (ip >> 16) & 0xFF);
  poke8(addr + 6, (ip >> 8) & 0xFF);
  poke8(addr + 7, ip & 0xFF);
  
  // Zero padding
  poke8(addr + 8, 0);
  poke8(addr + 9, 0);
  poke8(addr + 10, 0);
  poke8(addr + 11, 0);
  poke8(addr + 12, 0);
  poke8(addr + 13, 0);
  poke8(addr + 14, 0);
  poke8(addr + 15, 0);
  
  // Connect
  ret := sys_connect(fd, addr, 16);
  munmap(addr, 16);
  
  if (ret < 0) {
    sys_close(fd);
    conn.fd := ret;
    return conn;
  }
  
  conn.fd := fd;
  return conn;
}

// Connect using IPAddr struct (convenience)
pub fn TCPConnectAddr(ipAddr: IPAddr): TCPConn {
  var ip: int64;
  ip := IPPack(ipAddr.a, ipAddr.b, ipAddr.c, ipAddr.d);
  return TCPConnect(ip, ipAddr.port as int64);
}

