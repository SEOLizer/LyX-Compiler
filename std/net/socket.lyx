pub type UDPSocket = struct {
  fd: int64;
};

// Create a new UDP socket
pub fn UDPSocketNew(): UDPSocket {
  var sock: UDPSocket;
  var fd: int64;

  // Create UDP socket
  fd := sys_socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
  if (fd < 0) {
    sock.fd := -1;
    return sock;
  }

  sock.fd := fd;
  return sock;
}

// Bind UDP socket to address (raw sockaddr_in pointer)
pub fn UDPSocketBind(sock: UDPSocket, addr: int64): int64 {
  return sys_bind(sock.fd, addr, 16);
}

// Bind UDP socket to IP and port (convenience)
pub fn UDPSocketBindTo(sock: UDPSocket, ip: int64, port: int64): int64 {
  var addr: int64;
  var ret: int64;
  
  addr := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (addr <= 0) {
    return -1;
  }
  
  // Fill sockaddr_in
  poke8(addr, 2);      // AF_INET
  poke8(addr + 1, 0);
  poke8(addr + 2, (port >> 8) & 0xFF);  // port big-endian
  poke8(addr + 3, port & 0xFF);
  poke8(addr + 4, (ip >> 24) & 0xFF);   // IP network order
  poke8(addr + 5, (ip >> 16) & 0xFF);
  poke8(addr + 6, (ip >> 8) & 0xFF);
  poke8(addr + 7, ip & 0xFF);
  poke8(addr + 8, 0);
  poke8(addr + 9, 0);
  poke8(addr + 10, 0);
  poke8(addr + 11, 0);
  poke8(addr + 12, 0);
  poke8(addr + 13, 0);
  poke8(addr + 14, 0);
  poke8(addr + 15, 0);
  
  ret := sys_bind(sock.fd, addr, 16);
  munmap(addr, 16);
  return ret;
}

// Send data to address (raw sockaddr_in pointer)
pub fn UDPSocketSendTo(sock: UDPSocket, buf: int64, n: int64, dest: int64): int64 {
  return sys_sendto(sock.fd, buf, n, 0, dest, 16);
}

// Send data to IP and port (convenience)
pub fn UDPSocketSendToAddr(sock: UDPSocket, buf: int64, n: int64, ip: int64, port: int64): int64 {
  var addr: int64;
  var ret: int64;
  
  addr := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (addr <= 0) {
    return -1;
  }
  
  // Fill sockaddr_in
  poke8(addr, 2);      // AF_INET
  poke8(addr + 1, 0);
  poke8(addr + 2, (port >> 8) & 0xFF);
  poke8(addr + 3, port & 0xFF);
  poke8(addr + 4, (ip >> 24) & 0xFF);
  poke8(addr + 5, (ip >> 16) & 0xFF);
  poke8(addr + 6, (ip >> 8) & 0xFF);
  poke8(addr + 7, ip & 0xFF);
  poke8(addr + 8, 0);
  poke8(addr + 9, 0);
  poke8(addr + 10, 0);
  poke8(addr + 11, 0);
  poke8(addr + 12, 0);
  poke8(addr + 13, 0);
  poke8(addr + 14, 0);
  poke8(addr + 15, 0);
  
  ret := sys_sendto(sock.fd, buf, n, 0, addr, 16);
  munmap(addr, 16);
  return ret;
}

// Receive data and sender address (raw)
pub fn UDPSocketRecvFrom(sock: UDPSocket, buf: int64, n: int64, src: int64, addrlen: int64): int64 {
  return sys_recvfrom(sock.fd, buf, n, 0, src, addrlen);
}

// Receive data with sender info (convenience)
// Returns bytes read, fills senderIP and senderPort
pub fn UDPSocketRecv(sock: UDPSocket, buf: int64, n: int64, senderIP: int64, senderPort: int64): int64 {
  var addr: int64;
  var addrlen: int64;
  var ret: int64;
  
  addr := mmap(0, 32, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (addr <= 0) {
    return -1;
  }
  
  // addrlen at offset 16 (store as int64)
  addrlen := addr + 16;
  poke8(addrlen, 16);  // sizeof(sockaddr_in)
  poke8(addrlen + 1, 0);
  poke8(addrlen + 2, 0);
  poke8(addrlen + 3, 0);
  poke8(addrlen + 4, 0);
  poke8(addrlen + 5, 0);
  poke8(addrlen + 6, 0);
  poke8(addrlen + 7, 0);
  
  ret := sys_recvfrom(sock.fd, buf, n, 0, addr, addrlen);
  
  if (ret >= 0) {
    // Extract sender IP (bytes 4-7, network order)
    var ip: int64 := (peek8(addr + 4) << 24) | (peek8(addr + 5) << 16) | 
                     (peek8(addr + 6) << 8) | peek8(addr + 7);
    // Extract sender port (bytes 2-3, big-endian)
    var port: int64 := (peek8(addr + 2) << 8) | peek8(addr + 3);
    
    // Store results (if pointers provided)
    if (senderIP != 0) {
      poke8(senderIP, ip & 0xFF);
      poke8(senderIP + 1, (ip >> 8) & 0xFF);
      poke8(senderIP + 2, (ip >> 16) & 0xFF);
      poke8(senderIP + 3, (ip >> 24) & 0xFF);
      poke8(senderIP + 4, 0);
      poke8(senderIP + 5, 0);
      poke8(senderIP + 6, 0);
      poke8(senderIP + 7, 0);
    }
    if (senderPort != 0) {
      poke8(senderPort, port & 0xFF);
      poke8(senderPort + 1, (port >> 8) & 0xFF);
      poke8(senderPort + 2, 0);
      poke8(senderPort + 3, 0);
      poke8(senderPort + 4, 0);
      poke8(senderPort + 5, 0);
      poke8(senderPort + 6, 0);
      poke8(senderPort + 7, 0);
    }
  }
  
  munmap(addr, 32);
  return ret;
}

// Close UDP socket
pub fn UDPSocketClose(sock: UDPSocket) {
  if (sock.fd >= 0) {
    sys_close(sock.fd);
  }
}

