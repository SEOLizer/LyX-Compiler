// WP2: BSON document buffer
pub type MongoDoc = struct {
  data: int64;     // pointer to buffer
  size: int64;     // buffer size
  len: int64;     // used length
};

// WP2: Create new document
pub fn MongoDocNew(): MongoDoc {
  var doc: MongoDoc;
  doc.data := mmap(0, 4096, PROT_RW, MAP_ANON, FD_NONE, 0);
  doc.size := 4096;
  doc.len := 0;
  return doc;
}

