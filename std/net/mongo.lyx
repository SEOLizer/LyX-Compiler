// WP4: Send request to MongoDB
pub fn MongoSend(conn: MongoConn, data: int64, len: int64): int64 {
  if (conn.fd < 0 || conn.connected == 0) {
    return -1;
  }
  return sys_write(conn.fd, data, len);
}

// WP4: Read response from MongoDB
pub fn MongoRead(conn: MongoConn, data: int64, len: int64): int64 {
  if (conn.fd < 0 || conn.connected == 0) {
    return -1;
  }
  return sys_read(conn.fd, data, len);
}

// WP5: Build full collection name (db.collection)
pub fn MongoCollectionName(db: int64, coll: int64): int64 {
  var buf: int64;
  var pos: int64;
  var dbLen: int64;
  var collLen: int64;
  
  dbLen := 0;
  while (peek8(db + dbLen) != 0) { dbLen := dbLen + 1; }
  collLen := 0;
  while (peek8(coll + collLen) != 0) { collLen := collLen + 1; }
  
  buf := mmap(0, dbLen + 1 + collLen + 1, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    return 0;
  }
  
  pos := 0;
  var i: int64 := 0;
  while (i < dbLen) {
    poke8(buf + pos, peek8(db + i));
    pos := pos + 1;
    i := i + 1;
  }
  poke8(buf + pos, 46);  // dot
  pos := pos + 1;
  i := 0;
  while (i < collLen) {
    poke8(buf + pos, peek8(coll + i));
    pos := pos + 1;
    i := i + 1;
  }
  poke8(buf + pos, 0);
  
  return buf;
}

