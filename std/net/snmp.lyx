// Helper: Parse SNMP octet string response as printable text
// Returns pointer to null-terminated string (caller must free)
pub fn SNMPResponseAsString(resp: SNMPResponse): int64 {
  var str: int64;
  var i: int64;
  
  if (resp.valueType != ASN1_OCTET_STRING || resp.valueLen == 0) {
    return 0;
  }
  
  var snmpStrSz: int64 := resp.valueLen + 1;
  str := mmap(0, snmpStrSz, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (str == 0) {
    return 0;
  }
  
  i := 0;
  while (i < resp.valueLen) {
    poke8(str + i, peek8(resp.value + i));
    i := i + 1;
  }
  poke8(str + resp.valueLen, 0);
  
  return str;
}

// Helper: Parse SNMP integer response
pub fn SNMPResponseAsInteger(resp: SNMPResponse): int64 {
  if (resp.valueType != ASN1_INTEGER || resp.valueLen == 0) {
    return -1;
  }
  
  var value: int64 := 0;
  var i: int64 := 0;
  
  while (i < resp.valueLen) {
    value := value * 256 + peek8(resp.value + i);
    i := i + 1;
  }
  
  return value;
}
