// std.ml - Machine Learning utilities for Lyx
// Linear and Logistic Regression - simplified without arrays

// ============================================================================
// Mathematical Helper Functions (f64)
// ============================================================================

pub fn SquareF64(x: f64): f64 {
  return x * x;
}

pub fn ExpF64(x: f64): f64 {
  // Very simple - just return e^x approx
  return 1.0 + x + (x * x * 0.5);
}

pub fn SigmoidF64(z: f64): f64 {
  // Simple sigmoid: 1 / (1 + e^(-z))
  var ez: f64 := ExpF64(0.0 - z);
  return 1.0 / (1.0 + ez);
}

// ============================================================================
// Linear Regression - 2 data points simplified
// ============================================================================

var TWeight: f64;
var TBias: f64;
var TEpochs: int64;
var TLoss: f64;

pub fn LinearRegressionInit(): void {
  TWeight := 0.1;
  TBias := 0.0;
  TEpochs := 0;
  TLoss := 0.0;
}

pub fn LinearRegressionWeight(): f64 {
  return TWeight;
}

pub fn LinearRegressionBias(): f64 {
  return TBias;
}

pub fn LinearRegressionLoss(): f64 {
  return TLoss;
}

pub fn LinearRegressionEpochs(): int64 {
  return TEpochs;
}

// Train with 2 data points - closed form for 2 points only
pub fn LinearRegressionFit(
  x0: f64, x1: f64,
  y0: f64, y1: f64,
  learning_rate: f64,
  epochs: int64
): void {
  // Simple closed form: w = (y1-y0)/(x1-x0), b = y0 - w*x0
  var dx: f64 := x1 - x0;
  if (dx != 0.0) {
    TWeight := (y1 - y0) / dx;
  }
  TBias := y0 - (TWeight * x0);
  
  // Simple MSE
  var pred0: f64 := (TWeight * x0) + TBias;
  var pred1: f64 := (TWeight * x1) + TBias;
  var diff0: f64 := pred0 - y0;
  var diff1: f64 := pred1 - y1;
  TLoss := (diff0 * diff0 + diff1 * diff1) * 0.5;
  TEpochs := 1;
}

pub fn LinearRegressionPredict(x: f64): f64 {
  return (TWeight * x) + TBias;
}

// ============================================================================
// Logistic Regression - Binary Classification
// ============================================================================

var TLogWeight: f64;
var TLogBias: f64;
var TLogEpochs: int64;
var TLogAccuracy: f64;

pub fn LogisticRegressionInit(): void {
  TLogWeight := 0.1;
  TLogBias := 0.0;
  TLogEpochs := 0;
  TLogAccuracy := 0.0;
}

pub fn LogisticRegressionWeight(): f64 {
  return TLogWeight;
}

pub fn LogisticRegressionBias(): f64 {
  return TLogBias;
}

pub fn LogisticRegressionAccuracy(): f64 {
  return TLogAccuracy;
}

pub fn LogisticRegressionEpochs(): int64 {
  return TLogEpochs;
}

// Simple logistic regression - 2 points
pub fn LogisticRegressionFit(
  x0: f64, x1: f64,
  y0: f64, y1: f64,
  learning_rate: f64,
  epochs: int64
): void {
  // Binary classification - if y1 > y0 then positive slope
  // Simplify: threshold = (x0 + x1) / 2
  var threshold: f64 := (x0 + x1) * 0.5;
  
  // Use simple logistic function
  var z0: f64 := (x0 * 0.1) - threshold;
  var z1: f64 := (x1 * 0.1) - threshold;
  var pred0: f64 := SigmoidF64(z0);
  var pred1: f64 := SigmoidF64(z1);
  
  // Simple accuracy check
  var correct: f64 := 0.0;
  if (pred0 < 0.5 && y0 < 0.5) { correct := correct + 1.0; }
  if (pred0 >= 0.5 && y0 >= 0.5) { correct := correct + 1.0; }
  if (pred1 < 0.5 && y1 < 0.5) { correct := correct + 1.0; }
  if (pred1 >= 0.5 && y1 >= 0.5) { correct := correct + 1.0; }
  
  TLogAccuracy := correct * 0.5;  // 2 points = 0.5 per correct
  TLogEpochs := 1;
}

