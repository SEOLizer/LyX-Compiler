// ============================================================================
// Main API
// ============================================================================

pub fn parseAndRender(lfdSource: pchar): int64 {
    // Parse LFD source and render to Qt widgets
    // Returns the top-level QWidget*
    
    var parser: LFDParser := newLFDParser(lfdSource);
    
    if (!validateLFD(parser)) {
        PrintStr("LFD Parse Error: ");
        PrintStr(getLastError(parser));
        return 0;
    }
    
    // Render the AST
    return renderForm(parser);
}