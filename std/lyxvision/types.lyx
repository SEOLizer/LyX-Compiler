// std/lyxvision/types.lyx
// LyxVision - Basis-Typen (TPoint, TRect, TEvent)
// Inspiriert von Borland Turbo Vision

unit std.lyxvision.types;

// ============================================================================
// TPoint - 2D-Koordinatenpunkt
// ============================================================================

pub type TPoint = struct {
  x: int64;
  y: int64;
};

// Konstruktor: Erstellt einen neuen Punkt
pub fn PointNew(x: int64, y: int64): TPoint {
  var p: TPoint := TPoint { x: 0, y: 0 };
  p.x := x;
  p.y := y;
  return p;
}

// Null-Punkt (0, 0)
pub fn PointZero(): TPoint {
  var p: TPoint := TPoint { x: 0, y: 0 };
  p.x := 0;
  p.y := 0;
  return p;
}

// Punkt-Addition
pub fn PointAdd(a: TPoint, b: TPoint): TPoint {
  var p: TPoint := TPoint { x: 0, y: 0 };
  p.x := a.x + b.x;
  p.y := a.y + b.y;
  return p;
}

// Punkt-Subtraktion
pub fn PointSub(a: TPoint, b: TPoint): TPoint {
  var p: TPoint := TPoint { x: 0, y: 0 };
  p.x := a.x - b.x;
  p.y := a.y - b.y;
  return p;
}

// Punkt-Vergleich
pub fn PointEqual(a: TPoint, b: TPoint): bool {
  return (a.x == b.x) && (a.y == b.y);
}

// ============================================================================
// TRect - Rechteck (Bounding Box)
// ============================================================================

pub type TRect = struct {
  ax: int64;
  ay: int64;
  bx: int64;
  by: int64;
};

// Konstruktor: Erstellt ein Rechteck aus Koordinaten
pub fn RectFromCoords(ax: int64, ay: int64, bx: int64, by: int64): TRect {
  var r: TRect := TRect { ax: 0, ay: 0, bx: 0, by: 0 };
  r.ax := ax;
  r.ay := ay;
  r.bx := bx;
  r.by := by;
  return r;
}

// Leeres Rechteck
pub fn RectEmpty(): TRect {
  return RectFromCoords(0, 0, 0, 0);
}

// Breite des Rechtecks
pub fn RectWidth(r: TRect): int64 {
  return r.bx - r.ax;
}

// Höhe des Rechtecks
pub fn RectHeight(r: TRect): int64 {
  return r.by - r.ay;
}

// Größe als TPoint
pub fn RectSize(r: TRect): TPoint {
  var p: TPoint := TPoint { x: 0, y: 0 };
  p.x := RectWidth(r);
  p.y := RectHeight(r);
  return p;
}

// Prüft, ob Rechteck leer ist
pub fn RectIsEmpty(r: TRect): bool {
  return (r.bx <= r.ax) || (r.by <= r.ay);
}

// Prüft, ob ein Punkt im Rechteck liegt
pub fn RectContainsPoint(r: TRect, px: int64, py: int64): bool {
  return (px >= r.ax) && (px < r.bx) && (py >= r.ay) && (py < r.by);
}

// Verschiebt das Rechteck
pub fn RectMove(r: TRect, dx: int64, dy: int64): TRect {
  var result: TRect := TRect { ax: 0, ay: 0, bx: 0, by: 0 };
  result.ax := r.ax + dx;
  result.ay := r.ay + dy;
  result.bx := r.bx + dx;
  result.by := r.by + dy;
  return result;
}

// Vergrößert das Rechteck
pub fn RectGrow(r: TRect, dx: int64, dy: int64): TRect {
  var result: TRect := TRect { ax: 0, ay: 0, bx: 0, by: 0 };
  result.ax := r.ax - dx;
  result.ay := r.ay - dy;
  result.bx := r.bx + dx;
  result.by := r.by + dy;
  return result;
}

