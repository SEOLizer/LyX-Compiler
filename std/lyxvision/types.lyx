// ============================================================================
// TEvent - Event-Struktur
// ============================================================================

pub type TEvent = struct {
  what:        int64;
  buttons:     int64;
  doubleClick: int64;
  whereX:      int64;
  whereY:      int64;
  keyCode:     int64;
  charCode:    int64;
  scanCode:    int64;
  command:     int64;
  infoInt:     int64;
};

// Erstellt ein leeres Event
pub fn EventEmpty(): TEvent {
  var e: TEvent := TEvent { 
    what: evNothing, 
    buttons: 0, 
    doubleClick: 0, 
    whereX: 0, 
    whereY: 0, 
    keyCode: 0, 
    charCode: 0, 
    scanCode: 0, 
    command: cmValid, 
    infoInt: 0 
  };
  return e;
}

// Erstellt ein Tastatur-Event
pub fn EventKey(kc: int64, cc: int64): TEvent {
  var e: TEvent := EventEmpty();
  e.what := evKeyDown;
  e.keyCode := kc;
  e.charCode := cc;
  return e;
}

// Erstellt ein Kommando-Event
pub fn EventCommand(cmd: int64, info: int64): TEvent {
  var e: TEvent := EventEmpty();
  e.what := evCommand;
  e.command := cmd;
  e.infoInt := info;
  return e;
}

// Prüft, ob Event leer ist
pub fn EventIsNothing(e: TEvent): bool {
  return e.what == evNothing;
}

// Prüft, ob Event ein Tastatur-Event ist
pub fn EventIsKeyboard(e: TEvent): bool {
  return (e.what & evKeyboard) != 0;
}

// Prüft, ob Event ein Kommando ist
pub fn EventIsCommand(e: TEvent): bool {
  return e.what == evCommand;
}

// Markiert Event als behandelt
pub fn EventClear(e: TEvent): TEvent {
  e.what := evNothing;
  return e;
}

