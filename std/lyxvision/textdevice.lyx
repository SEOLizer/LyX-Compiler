pub con tdOverlay:  int64 := 0;  // Überlagerungsmodus
pub con tdReplace: int64 := 1;  // Ersetzungsmodus
pub con tdUpdate:   int64 := 2;  // Update-Modus

// ============================================================================
// TTextDevice - Textausgabe-Gerät
// ============================================================================

pub type TTextDevice = class extends TView {
  // TextDevice-spezifische Felder
  cursorX: int64;          // Logische Cursor-Position X
  cursorY: int64;          // Logische Cursor-Position Y
  screenX: int64;          // Tatsächliche Screen-Position X
  screenY: int64;          // Tatsächliche Screen-Position Y
  deviceMode: int64;       // tdOverlay, tdReplace, tdUpdate
  bufferX: int64;          // Pufferbreite
  bufferY: int64;          // Pufferhöhe
  bufferDirty: int64;      // 1 = Puffer muss neu gezeichnet werden
  
  // Puffer für Textzeilen (statisch, max 80x25)
  lineData0: pchar;
  lineData1: pchar;
  lineData2: pchar;
  lineData3: pchar;
  lineData4: pchar;
  lineData5: pchar;
  lineData6: pchar;
  lineData7: pchar;
  lineData8: pchar;
  lineData9: pchar;
  lineData10: pchar;
  lineData11: pchar;
  lineData12: pchar;
  lineData13: pchar;
  lineData14: pchar;
  lineData15: pchar;
  lineData16: pchar;
  lineData17: pchar;
  lineData18: pchar;
  lineData19: pchar;
  lineData20: pchar;
  lineData21: pchar;
  lineData22: pchar;
  lineData23: pchar;
  lineData24: pchar;
  
  // Konstruktor
  fn Init(tx: int64, ty: int64, tw: int64, th: int64, bx: int64, by: int64, mode: int64) {
    // TView Initialisierung
    self.originX := tx;
    self.originY := ty;
    self.sizeX := tw;
    self.sizeY := th;
    self.cursorX := 0;
    self.cursorY := 0;
    self.growMode := gfFixed;
    self.dragMode := dmLimitAll;
    self.helpCtx := hcNoContext;
    self.state := sfVisible;
    self.options := 0;
    self.ownerPtr := 0;
    self.nextPtr := 0;
    self.viewType := vtView;
    self.dirtyLevel := dfClean;
    self.parentDirty := dfClean;
    
    // TTextDevice spezifisch
    self.cursorX := 0;
    self.cursorY := 0;
    self.screenX := 0;
    self.screenY := 0;
    self.deviceMode := mode;
    self.bufferX := bx;
    self.bufferY := by;
    self.bufferDirty := 1;
    
    // Initialize lines as empty strings
    self.lineData0 := "";
    self.lineData1 := "";
    self.lineData2 := "";
    self.lineData3 := "";
    self.lineData4 := "";
    self.lineData5 := "";
    self.lineData6 := "";
    self.lineData7 := "";
    self.lineData8 := "";
    self.lineData9 := "";
    self.lineData10 := "";
    self.lineData11 := "";
    self.lineData12 := "";
    self.lineData13 := "";
    self.lineData14 := "";
    self.lineData15 := "";
    self.lineData16 := "";
    self.lineData17 := "";
    self.lineData18 := "";
    self.lineData19 := "";
    self.lineData20 := "";
    self.lineData21 := "";
    self.lineData22 := "";
    self.lineData23 := "";
    self.lineData24 := "";
  }
};

