// ============================================================================
// TextDevice-Funktionen
// ============================================================================

pub fn TextDeviceNew(x: int64, y: int64, w: int64, h: int64, bx: int64, by: int64, mode: int64): TTextDevice {
  var td: TTextDevice := new TTextDevice();
  td.Init(x, y, w, h, bx, by, mode);
  return td;
}

// Setzt den Modus
pub fn TextDeviceSetMode(td: TTextDevice, mode: int64): TTextDevice {
  td.deviceMode := mode;
  td.bufferDirty := 1;
  return td;
}

// Gibt den aktuellen Modus zurück
pub fn TextDeviceGetMode(td: TTextDevice): int64 {
  return td.deviceMode;
}

// Setzt die Cursor-Position
pub fn TextDeviceSetCursor(td: TTextDevice, x: int64, y: int64): TTextDevice {
  if (x >= 0 && x < td.bufferX && y >= 0 && y < td.bufferY) {
    td.cursorX := x;
    td.cursorY := y;
    td.bufferDirty := 1;
  }
  return td;
}

// Gibt die Cursor-Position zurück
pub fn TextDeviceGetCursorX(td: TTextDevice): int64 {
  return td.cursorX;
}

pub fn TextDeviceGetCursorY(td: TTextDevice): int64 {
  return td.cursorY;
}

// Schreibt einen String an der aktuellen Position
pub fn TextDeviceWriteStr(td: TTextDevice, s: pchar): TTextDevice {
  var i: int64 := 0;
  
  // Einfache Implementierung: Zeichen für Zeichen verarbeiten
  // (Eine echte Implementierung würde den String parsen)
  
  while (i < 256) {  // Max 256 Zeichen
    // Prüfen ob wir am Ende des Bildschirms sind
    if (td.cursorX >= td.bufferX) {
      td.cursorX := 0;
      td.cursorY := td.cursorY + 1;
    }
    
    // Scrollen wenn nötig
    if (td.cursorY >= td.bufferY) {
      TextDeviceScrollUp(td);
      td.cursorY := td.bufferY - 1;
    }
    
    // Zeichen an aktueller Position speichern (vereinfacht)
    // In einer echten Implementierung würde hier der Puffer aktualisiert
    
    td.cursorX := td.cursorX + 1;
    i := i + 1;
    
    // Abbruchbedingung (vereinfacht)
    if (i >= 64) { break; }
  }
  
  td.bufferDirty := 1;
  return td;
}

// Schreibt einen Zeilenumbruch
pub fn TextDeviceWriteLn(td: TTextDevice): TTextDevice {
  td.cursorX := 0;
  td.cursorY := td.cursorY + 1;
  
  // Scrollen wenn nötig
  if (td.cursorY >= td.bufferY) {
    TextDeviceScrollUp(td);
    td.cursorY := td.bufferY - 1;
  }
  
  td.bufferDirty := 1;
  return td;
}

// Scrollt den Text eine Zeile nach oben
pub fn TextDeviceScrollUp(td: TTextDevice): TTextDevice {
  var i: int64 := 0;
  
  // Zeilen nach oben schieben
  i := 0;
  while (i < td.bufferY - 1) {
    var nextLine: pchar := TextDeviceGetLine(td, i + 1);
    TextDeviceSetLine(td, i, nextLine);
    i := i + 1;
  }
  
  // Letzte Zeile leeren
  TextDeviceSetLine(td, td.bufferY - 1, "");
  
  td.bufferDirty := 1;
  return td;
}

// Löscht den gesamten Puffer
pub fn TextDeviceClear(td: TTextDevice): TTextDevice {
  var i: int64 := 0;
  
  i := 0;
  while (i < td.bufferY) {
    TextDeviceSetLine(td, i, "");
    i := i + 1;
  }
  
  td.cursorX := 0;
  td.cursorY := 0;
  td.bufferDirty := 1;
  return td;
}

// Löscht eine Zeile
pub fn TextDeviceClearLine(td: TTextDevice, y: int64): TTextDevice {
  if (y >= 0 && y < td.bufferY) {
    TextDeviceSetLine(td, y, "");
    td.bufferDirty := 1;
  }
  return td;
}

// Setzt ein Zeichen an einer bestimmten Position
pub fn TextDevicePutChar(td: TTextDevice, x: int64, y: int64, ch: pchar): TTextDevice {
  if (x >= 0 && x < td.bufferX && y >= 0 && y < td.bufferY) {
    // In einer echten Implementierung würde hier der Puffer aktualisiert
    td.bufferDirty := 1;
  }
  return td;
}

// Zeichnet das TextDevice auf den Bildschirm
pub fn TextDeviceDraw(td: TTextDevice): TTextDevice {
  if (!FlagSet(td.state, sfVisible)) {
    return td;
  }
  
  var y: int64 := 0;
  
  // Hintergrund zeichnen
  SetColors(colorLightGray, colorBlack);
  FillRect(td.originX, td.originY, 
           td.originX + td.sizeX - 1, td.originY + td.sizeY - 1);
  
  // Rahmen zeichnen
  SetColors(colorWhite, colorBlack);
  DrawBox(td.originX, td.originY, 
          td.originX + td.sizeX - 1, td.originY + td.sizeY - 1);
  
  // Textzeilen zeichnen (nur sichtbare Zeilen)
  y := 0;
  while (y < td.sizeY - 2 && y < td.bufferY) {
    var line: pchar := TextDeviceGetLine(td, y);
    
    SetColors(colorLightGray, colorBlack);
    MoveCursor(td.originX + 1, td.originY + 1 + y);
    PrintStr(line);
    ClearToEol();
    
    y := y + 1;
  }
  
  // Cursor zeichnen (wenn sichtbar)
  if (td.cursorX < td.sizeX - 2 && td.cursorY < td.sizeY - 2) {
    SetColors(colorBlack, colorCyan);
    MoveCursor(td.originX + 1 + td.cursorX, td.originY + 1 + td.cursorY);
  }
  
  td.bufferDirty := 0;
  td.dirtyLevel := dfClean;
  return td;
}

// Markiert das Device als "dirty" (neu zu zeichnen)
pub fn TextDeviceTouch(td: TTextDevice): TTextDevice {
  td.bufferDirty := 1;
  td.dirtyLevel := dfVisual;
  return td;
}

// Gibt die Breite des Puffers zurück
pub fn TextDeviceGetWidth(td: TTextDevice): int64 {
  return td.bufferX;
}

// Gibt die Höhe des Puffers zurück
pub fn TextDeviceGetHeight(td: TTextDevice): int64 {
  return td.bufferY;
}

