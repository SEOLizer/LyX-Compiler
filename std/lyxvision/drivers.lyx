pub fn EnableMouse() {
  PrintStr("\e[?1000h");
  PrintStr("\e[?1002h");
  PrintStr("\e[?1006h");
}

pub fn DisableMouse() {
  PrintStr("\e[?1006l");
  PrintStr("\e[?1002l");
  PrintStr("\e[?1000l");
}

