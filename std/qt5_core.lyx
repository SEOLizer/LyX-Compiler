extern fn qunsetenv(varName: int64): int64 link "libQt5Core.so.5";

// Check if environment variable is set
pub fn QEnvironmentVariableIsSet(name: pchar): int64 {
  var val: int64 := std.os.getenv(name);
  if (val == 0) {
    return 0;
  }
  return 1;
}

// Check if environment variable is empty
pub fn QEnvironmentVariableIsEmpty(name: pchar): int64 {
  var val: int64 := std.os.getenv(name);
  if (val == 0) {
    return 1;  // Not set = empty
  }
  var len: int64 := StrLen(val);
  if (len == 0) {
    return 1;
  }
  return 0;
}

