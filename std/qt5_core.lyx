// ============================================================================
// Qt Timer via Linux timerfd (pure C-FFI, no Qt dependency)
// ============================================================================

// timerfd_create flags
pub con TFD_CLOEXEC: int64 := 02000000;
pub con TFD_NONBLOCK: int64 := 0400;

// timerfd_create - Linux-specific, creates timer file descriptor
extern fn timerfd_create(clockid: int64, flags: int64): int64 link "libc.so.6";

// timerfd_settime - arm timer
extern fn timerfd_settime(fd: int64, flags: int64, newValue: int64, oldValue: int64): int64 link "libc.so.6";

// timerfd_gettime - get current timer value
extern fn timerfd_gettime(fd: int64, currValue: int64): int64 link "libc.so.6";

// Linux clock IDs
pub con CLOCK_REALTIME: int64 := 0;
pub con CLOCK_MONOTONIC: int64 := 1;
pub con CLOCK_PROCESS_CPUTIME_ID: int64 := 2;
pub con CLOCK_THREAD_CPUTIME_ID: int64 := 3;

// Timer structure (struct itimerspec)
pub type ITimerSpec = struct {
  tv_sec: int64;      // seconds
  tv_nsec: int64;     // nanoseconds
};

// Qt-style Timer wrapper using Linux timerfd
pub type QTimer = struct {
  fd: int64;          // timer file descriptor
  intervalMs: int64; // interval in milliseconds
  active: int64;     // 1 if timer is running
  callback: int64;    // callback function pointer (not implemented in pure Lyx)
};

// Create and start a periodic timer
// intervalMs: time in milliseconds between triggers
// Returns: QTimer handle
pub fn QTimerStart(intervalMs: int64): QTimer {
  var timer: QTimer;
  var fd: int64;
  var spec: ITimerSpec;
  
  timer.fd := -1;
  timer.intervalMs := intervalMs;
  timer.active := 0;
  timer.callback := 0;
  
  // Create timer with CLOCK_MONOTONIC (immune to system time changes)
  fd := timerfd_create(CLOCK_MONOTONIC, TFD_CLOEXEC | TFD_NONBLOCK);
  if (fd == -1) {
    return timer;
  }
  
  timer.fd := fd;
  
  // Set timer to fire every intervalMs milliseconds
  spec.tv_sec := intervalMs / 1000;
  spec.tv_nsec := (intervalMs % 1000) * 1000000;
  
  // Set periodic timer: allocate 32-byte itimerspec buffer and fill manually
  var specPtr: int64 := mmap(0, 32, 3, 32, -1, 0);
  if (specPtr != 0) {
    var tvSec: int64 := spec.tv_sec;
    var tvNsec: int64 := spec.tv_nsec;
    poke8(specPtr + 0, tvSec & 255);
    poke8(specPtr + 1, (tvSec >> 8) & 255);
    poke8(specPtr + 2, (tvSec >> 16) & 255);
    poke8(specPtr + 3, (tvSec >> 24) & 255);
    poke8(specPtr + 4, (tvSec >> 32) & 255);
    poke8(specPtr + 5, (tvSec >> 40) & 255);
    poke8(specPtr + 6, (tvSec >> 48) & 255);
    poke8(specPtr + 7, (tvSec >> 56) & 255);
    poke8(specPtr + 8, tvNsec & 255);
    poke8(specPtr + 9, (tvNsec >> 8) & 255);
    poke8(specPtr + 10, (tvNsec >> 16) & 255);
    poke8(specPtr + 11, (tvNsec >> 24) & 255);
    poke8(specPtr + 12, (tvNsec >> 32) & 255);
    poke8(specPtr + 13, (tvNsec >> 40) & 255);
    poke8(specPtr + 14, (tvNsec >> 48) & 255);
    poke8(specPtr + 15, (tvNsec >> 56) & 255);
    timerfd_settime(fd, 0, specPtr, 0);
    munmap(specPtr, 32);
  }
  
  timer.active := 1;
  return timer;
}

// Check if timer has expired (non-blocking read)
// Returns: number of expirations, or 0 if no expiration pending
pub fn QTimerExpired(timer: QTimer): int64 {
  if (timer.fd == -1) {
    return 0;
  }
  
  // Read from fd (non-blocking) - returns number of expirations
  // Use 8-byte buffer for uint64 expiration count
  var readBuf: int64 := mmap(0, 8, 3, 32, -1, 0);
  var n: int64 := read(timer.fd, readBuf, 8);
  var buf: int64 := 0;
  if (n == 8) {
    buf := peek8(readBuf) & 255;
    buf := buf | ((peek8(readBuf + 1) & 255) << 8);
    buf := buf | ((peek8(readBuf + 2) & 255) << 16);
    buf := buf | ((peek8(readBuf + 3) & 255) << 24);
    buf := buf | ((peek8(readBuf + 4) & 255) << 32);
    buf := buf | ((peek8(readBuf + 5) & 255) << 40);
    buf := buf | ((peek8(readBuf + 6) & 255) << 48);
    buf := buf | ((peek8(readBuf + 7) & 255) << 56);
  }
  munmap(readBuf, 8);
  if (n == 8) {
    return buf;  // Number of timer expirations
  }
  return 0;  // No expiration or error
}

// Stop and close timer
pub fn QTimerStop(timer: QTimer) {
  if (timer.fd != -1) {
    // Close the file descriptor
    close(timer.fd);
    timer.fd := -1;
  }
  timer.active := 0;
}

// Check if timer is active
pub fn QTimerIsActive(timer: QTimer): int64 {
  return timer.active;
}

// Get timer interval
pub fn QTimerInterval(timer: QTimer): int64 {
  return timer.intervalMs;
}

