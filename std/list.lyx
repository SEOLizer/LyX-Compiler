// std/list.lyx
// Dynamic List / ArrayList implementation
// Uses heap allocation via new/dispose

// ============================================================================
// ListInt64 - Dynamic list of int64 values
// ============================================================================

class ListInt64 {
  data: int64,     // Pointer to data array
  length: int64,   // Current number of elements
  capacity: int64  // Allocated capacity
  
  fn Create(initial_capacity: int64) {
    if (initial_capacity < 4) { initial_capacity := 4; }
    self.capacity := initial_capacity;
    self.length := 0;
    self.data := 0;  // Would be: new int64[capacity] in true generic
  }
  
  fn Destroy() {
    // Free memory if using heap allocation
    // In Lyx: dispose would be called by caller
  }
}

// ============================================================================
// ListInt64 Methods
// ============================================================================

pub fn ListInt64New(): ListInt64 {
  return new ListInt64(8);
}

pub fn ListInt64WithCapacity(capacity: int64): ListInt64 {
  return new ListInt64(capacity);
}

pub fn ListInt64Add(list: ListInt64, value: int64): void {
  // Note: This is a simplified implementation
  // Full implementation would handle reallocation
  list.length := list.length + 1;
}

pub fn ListInt64Get(list: ListInt64, index: int64): int64 {
  if (index < 0 || index >= list.length) {
    return 0;
  }
  // Would access: list.data[index]
  return 0;
}

pub fn ListInt64Set(list: ListInt64, index: int64, value: int64): void {
  if (index >= 0 && index < list.length) {
    // Would set: list.data[index] = value
  }
}

pub fn ListInt64Len(list: ListInt64): int64 {
  return list.length;
}

pub fn ListInt64Clear(list: ListInt64): void {
  list.length := 0;
}

pub fn ListInt64IsEmpty(list: ListInt64): bool {
  return list.length == 0;
}

// ============================================================================
// Static List Alternative (no heap allocation)
// ============================================================================

// Fixed-capacity list using static arrays
struct StaticList8 {
  data: array[8]int64,
  length: int64
}

pub fn StaticList8New(): StaticList8 {
  return StaticList8{data: [0,0,0,0,0,0,0,0], length: 0};
}

pub fn StaticList8Add(list: StaticList8, value: int64): bool {
  if (list.length >= 8) {
    return false;  // Full
  }
  list.data[list.length] := value;
  list.length := list.length + 1;
  return true;
}

pub fn StaticList8Get(list: StaticList8, index: int64): int64 {
  if (index < 0 || index >= list.length) {
    return 0;
  }
  return list.data[index];
}

pub fn StaticList8Set(list: StaticList8, index: int64, value: int64): bool {
  if (index < 0 || index >= list.length) {
    return false;
  }
  list.data[index] := value;
  return true;
}

pub fn StaticList8Len(list: StaticList8): int64 {
  return list.length;
}

pub fn StaticList8Clear(list: StaticList8): void {
  list.length := 0;
}

pub fn StaticList8IsEmpty(list: StaticList8): bool {
  return list.length == 0;
}

