// ============================================================================
// StackInt64
// ============================================================================

pub type StackInt64 = struct {
  data: array[32]int64;
  top: int64;
}

pub fn StackInt64New(): StackInt64 {
  var s: StackInt64;
  s.top := 0;
  return s;
}

pub fn StackInt64Push(s: StackInt64, value: int64): bool {
  if (s.top >= 32) { return False; }
  s.data[s.top] := value;
  s.top := s.top + 1;
  return True;
}

pub fn StackInt64Pop(s: StackInt64): int64 {
  if (s.top == 0) { return 0; }
  s.top := s.top - 1;
  return s.data[s.top];
}

pub fn StackInt64Peek(s: StackInt64): int64 {
  if (s.top == 0) { return 0; }
  var ti: int64 := s.top - 1;
  return s.data[ti];
}

pub fn StackInt64IsEmpty(s: StackInt64): bool {
  return s.top == 0;
}

pub fn StackInt64IsFull(s: StackInt64): bool {
  return s.top >= 32;
}

// ============================================================================
// QueueInt64
// ============================================================================

pub type QueueInt64 = struct {
  data: array[32]int64;
  front: int64;
  rear: int64;
  count: int64;
}

pub fn QueueInt64New(): QueueInt64 {
  var q: QueueInt64;
  q.front := 0;
  q.rear := 0;
  q.count := 0;
  return q;
}

pub fn QueueInt64Enqueue(q: QueueInt64, value: int64): bool {
  if (q.count >= 32) { return False; }
  q.data[q.rear] := value;
  q.rear := q.rear + 1;
  if (q.rear >= 32) { q.rear := 0; }
  q.count := q.count + 1;
  return True;
}

pub fn QueueInt64Dequeue(q: QueueInt64): int64 {
  if (q.count == 0) { return 0; }
  var value: int64 := q.data[q.front];
  q.front := q.front + 1;
  if (q.front >= 32) { q.front := 0; }
  q.count := q.count - 1;
  return value;
}

pub fn QueueInt64Peek(q: QueueInt64): int64 {
  if (q.count == 0) { return 0; }
  return q.data[q.front];
}

pub fn QueueInt64IsEmpty(q: QueueInt64): bool {
  return q.count == 0;
}

pub fn QueueInt64IsFull(q: QueueInt64): bool {
  return q.count >= 32;
}

