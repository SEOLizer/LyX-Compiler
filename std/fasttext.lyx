// ============================================================================
// Cleanup
// ============================================================================

// Free all model memory
pub fn FastTextFree(): void {
  if (ft_vocab != 0) {
    munmap(ft_vocab, ft_vocab_size * 256);
  }
  if (ft_embeddings != 0) {
    munmap(ft_embeddings, ft_vocab_size * ft_dimension * 8);
  }
  if (ft_output != 0) {
    munmap(ft_output, ft_vocab_size * ft_dimension * 8);
  }
  
  ft_vocab := 0;
  ft_embeddings := 0;
  ft_output := 0;
  ft_vocab_size := 0;
  ft_loaded := 0;
}

