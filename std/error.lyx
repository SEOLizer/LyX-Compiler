// ============================================================================
// Fehlerbehandlungsfunktionen
// ============================================================================

// Extrahiert den Fehlercode aus einem negativen Syscall-Ergebnis
// Returns: positiver Fehlercode (1-133) oder 0 wenn kein Fehler
pub fn GetErrorCode(result: int64): int64 {
    if (result >= 0) {
        return 0;  // Kein Fehler
    }
    
    // Negativer Wert = Fehler, Betrag ist der Fehlercode
    return -result;
}

// Prüft ob ein Ergebnis ein Fehler ist
// Returns: true wenn Fehler, false wenn Erfolg
pub fn IsError(result: int64): bool {
    return result < 0;
}

