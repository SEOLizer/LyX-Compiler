// ============================================================================
// Fehlerbehandlungshilfen
// ============================================================================

// Gibt true zurück wenn der Syscall einen Fehler anzeigt
pub fn CheckSyscallError(result: int64): bool {
    return IsError(result);
}

// Gibt den Fehlercode zurück oder 0 wenn kein Fehler
pub fn GetSyscallErrorCode(result: int64): int64 {
    return GetErrorCode(result);
}

// Gibt die Fehlermeldung zurück oder "Success" wenn kein Fehler
pub fn GetSyscallErrorMessage(result: int64): pchar {
    if (!IsError(result)) {
        return "Success";
    }
    return GetErrorMessage(GetErrorCode(result));
}

