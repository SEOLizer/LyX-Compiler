pub fn AESEncryptOutputSize(input_len: int64): int64 {
    if ((input_len mod 16) == 0) { return input_len + 16; }
    var blocks_out: int64 := input_len / 16;
    var blocks_out1: int64 := blocks_out + 1;
    return blocks_out1 * 16;
}

pub fn AESDecryptOutputSize(input_len: int64): int64 {
    return input_len;
}

