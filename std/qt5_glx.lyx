// Lyx Qt5 GLX Library - GLX FFI Bindings
// Provides GLX 1.4+ function bindings for X11 OpenGL context
//
// Usage:
//   import std.qt5_glx;
//   var disp := XOpenDisplay(nil);
//   var vi := GLXChooseVisual(disp, screen, attribs);
//   var ctx := GLXCreateContext(disp, vi, nil, GLX_RGBA);
//   GLXMakeCurrent(disp, window, ctx);
//   // OpenGL calls here

