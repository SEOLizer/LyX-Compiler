// ============================================================================
// GLX Types (simplified wrappers)
// ============================================================================

// GLX Context (opaque)
pub type GLXContext = struct {
  ctx: int64;           // native GLX context
  valid: int64;
};

// GLX Drawable (window/pbuffer)
pub type GLXDrawable = struct {
  drawable: int64;      // native drawable
  valid: int64;
};

// GLX Visual (simplified)
pub type GLXVisual = struct {
  visual: int64;        // XVisualInfo pointer
  valid: int64;
};

// ============================================================================
// High-level API
// ============================================================================

// Query GLX version
pub fn GLXQueryVersion(dpy: int64): int64 {
  var major: int64;
  var minor: int64;
  
  return glXQueryVersion(dpy, cast<int64>(cast<int64>(0)), cast<int64>(cast<int64>(0)));
}

// Get GLX extensions
pub fn GLXGetExtensions(dpy: int64, screen: int64): int64 {
  return glXQueryExtensionsString(dpy, screen);
}

// Get GLX vendor
pub fn GLXGetVendor(dpy: int64, screen: int64): int64 {
  return glXQueryServerString(dpy, screen, 0);  // GLX_VENDOR
}

// Get GLX version string
pub fn GLXGetVersion(dpy: int64, screen: int64): int64 {
  return glXQueryServerString(dpy, screen, 1);  // GLX_VERSION
}

// Create OpenGL 2.1 context (legacy)
pub fn GLXCreateContextLegacy(dpy: int64, visual: int64, share: int64, direct: int64): GLXContext {
  var ctx: GLXContext;
  
  ctx.ctx := 0;
  ctx.valid := 0;
  
  ctx.ctx := glXCreateContext(dpy, visual, share, direct);
  if (ctx.ctx == 0) {
    return ctx;
  }
  
  ctx.valid := 1;
  return ctx;
}

// Create OpenGL 3.x+ context (modern, requires GLX_ARB_create_context)
pub fn GLXCreateContextModern(dpy: int64, config: int64, share: int64, direct: int64, majorVer: int64, minorVer: int64, flags: int64): GLXContext {
  var ctx: GLXContext;
  var attribs: int64;
  
  ctx.ctx := 0;
  ctx.valid := 0;
  
  // Build attrib list: [attribute, value, ..., None]
  // We'll need to pass a properly formatted attrib array
  
  // Use legacy version for now (GLXCreateContext is universally available)
  // Modern version via glXCreateContextAttribsARB would need attribute array
  
  return ctx;
}

// Make context current
pub fn GLXMakeCurrent(dpy: int64, drawable: int64, ctx: GLXContext): int64 {
  if (ctx.valid == 0) {
    return GLX_FALSE;
  }
  
  return glXMakeCurrent(dpy, drawable, ctx.ctx);
}

// Get current context
pub fn GLXGetCurrentContext(): GLXContext {
  var ctx: GLXContext;
  
  ctx.ctx := glXGetCurrentContext();
  ctx.valid := 1;
  return ctx;
}

// Swap buffers (present frame)
pub fn GLXSwapBuffers(dpy: int64, drawable: int64) {
  glXSwapBuffers(dpy, drawable);
}

// Set vsync (extension - may not be available)
pub fn GLXSetSwapInterval(dpy: int64, drawable: int64, interval: int64): int64 {
  // Try glXSwapIntervalEXT first (most common)
  var ret: int64 := glXSwapIntervalEXT(dpy, drawable, interval);
  if (ret == 0) {
    return 0;  // Success
  }
  
  // Fall back to glXSwapIntervalMESA
  ret := glXSwapIntervalMESA(interval);
  return ret;
}

// Get current drawable
pub fn GLXGetCurrentDrawable(): GLXDrawable {
  var draw: GLXDrawable;
  
  draw.drawable := glXGetCurrentDrawable();
  draw.valid := 1;
  return draw;
}

// Get current display
pub fn GLXGetCurrentDisplay(): int64 {
  return glXGetCurrentDisplay();
}

// Destroy context
pub fn GLXDestroyContext(dpy: int64, ctx: GLXContext) {
  if (ctx.ctx != 0) {
    glXDestroyContext(dpy, ctx.ctx);
  }
  
  ctx.ctx := 0;
  ctx.valid := 0;
}

// Wait for GL to finish
pub fn GLXWaitGL() {
  glXWaitGL();
}

// Wait for X to finish
pub fn GLXWaitX() {
  glXWaitX();
}

// ============================================================================
// Simple Window Creation (requires X11)
// ============================================================================

// Note: Full X11 window creation requires X11 FFI (std.x11)
//
// Simple usage with X11:
// 1. Import std.x11
// 2. Open display: XOpenDisplay(0)
// 3. Get visual: GLXChooseVisual(dpy, screen, attribs)
// 4. Create context: GLXCreateContextLegacy(dpy, visual, 0, 1)
// 5. Create window: XCreateWindow(...)
// 6. Make current: GLXMakeCurrent(dpy, window, ctx)
// 7. Draw with OpenGL
// 8. Swap: GLXSwapBuffers(dpy, window)

// ============================================================================
// Note
// ============================================================================
//
// GLX provides OpenGL rendering on X11.
//
// Usage pattern:
// 1. Open X display (via X11 FFI)
// 2. Get visual with GLX attributes (RGBA, doublebuffer, depth)
// 3. Create GL context with glXCreateContext
// 4. Create X window
// 5. glXMakeCurrent to bind context
// 6. OpenGL rendering
// 7. glXSwapBuffers to present
//
// For modern OpenGL 3.x+, use glXCreateContextAttribsARB.
// For vsync, use GLX_EXT_swap_control extension.
//
// For Wayland, use EGL instead of GLX (see std/qt5_egl.lyx)