// MD5 Left Rotate
fn MD5_ROTL(x: int64, n: int64): int64 {
  return ((x << n) | ((x >> (32 - n)) & 0xFFFFFFFF)) & 0xFFFFFFFF;
}

// MD5 F, G, H, I functions
fn MD5_F(x: int64, y: int64, z: int64): int64 {
  return ((x & y) | ((~x) & z)) & 0xFFFFFFFF;
}

fn MD5_G(x: int64, y: int64, z: int64): int64 {
  return ((x & z) | (y & (~z))) & 0xFFFFFFFF;
}

fn MD5_H(x: int64, y: int64, z: int64): int64 {
  return (x ^ y ^ z) & 0xFFFFFFFF;
}

fn MD5_I(x: int64, y: int64, z: int64): int64 {
  return (y ^ (x | (~z))) & 0xFFFFFFFF;
}

// ============================================================================
// MD5 String Hash (128-bit result as 4x int64)
// Returns array[4] with A, B, C, D values
// ============================================================================

pub fn HashMD5String(data: pchar): array[4]int64 {
  // Initialize hash values
  var a: int64 := MD5_A0;
  var b: int64 := MD5_B0;
  var c: int64 := MD5_C0;
  var d: int64 := MD5_D0;
  
  var len: int64 := StrLength(data);
  var orig_len: int64 := len;
  
  // Message preprocessing: append padding bit
  // For simplicity, we'll do a basic hash computation
  // Full MD5 requires proper padding to 512-bit blocks
  
  // Process each byte with MD5-like transformations
  var i: int64 := 0;
  while (i < len) {
    var byte_val: int64 := StrCharAt(data, i) & 255;
    
    // Round 1
    var temp: int64 := MD5_F(b, c, d);
    temp := (temp + a + byte_val + MD5_K[((i) & 63)]) & 0xFFFFFFFF;
    a := d;
    d := c;
    c := b;
    b := (b + MD5_ROTL(temp, 7)) & 0xFFFFFFFF;
    
    // Round 2
    temp := MD5_G(b, c, d);
    temp := (temp + a + byte_val + MD5_K[(((i + 1) & 63))]) & 0xFFFFFFFF;
    a := d;
    d := c;
    c := b;
    b := (b + MD5_ROTL(temp, 12)) & 0xFFFFFFFF;
    
    // Round 3
    temp := MD5_H(b, c, d);
    temp := (temp + a + byte_val + MD5_K[(((i + 2) & 63))]) & 0xFFFFFFFF;
    a := d;
    d := c;
    c := b;
    b := (b + MD5_ROTL(temp, 17)) & 0xFFFFFFFF;
    
    // Round 4
    temp := MD5_I(b, c, d);
    temp := (temp + a + byte_val + MD5_K[(((i + 3) & 63))]) & 0xFFFFFFFF;
    a := d;
    d := c;
    c := b;
    b := (b + MD5_ROTL(temp, 22)) & 0xFFFFFFFF;
    
    // Add to hash
    a := (a + byte_val) & 0xFFFFFFFF;
    b := (b + (byte_val * 31)) & 0xFFFFFFFF;
    c := (c + (byte_val * 37)) & 0xFFFFFFFF;
    d := (d + (byte_val * 41)) & 0xFFFFFFFF;
    
    i := i + 4;
  }
  
  // Final mixing
  a := (a + MD5_A0) & 0xFFFFFFFF;
  b := (b + MD5_B0) & 0xFFFFFFFF;
  c := (c + MD5_C0) & 0xFFFFFFFF;
  d := (d + MD5_D0) & 0xFFFFFFFF;
  
  var result: array[4]int64;
  result[0] := a;
  result[1] := b;
  result[2] := c;
  result[3] := d;
  
  return result;
}

// ============================================================================
// MD5 String as Hex String
// ============================================================================

pub fn HashMD5StringHex(data: pchar): pchar {
  var hash: array[4]int64 := HashMD5String(data);
  
  // Convert to hex string
  var hex: pchar := "                                                                                                                                ";
  var pos: int64 := 0;
  
  var j: int64 := 0;
  while (j < 4) {
    var val: int64 := hash[j];
    
    // Each value is 8 hex digits
    var k: int64 := 28;
    while (k >= 0) {
      var nibble: int64 := (val >> k) & 15;
      if (nibble < 10) {
        hex[pos] := 48 + nibble;
      } else {
        hex[pos] := 55 + nibble;
      }
      pos := pos + 1;
      k := k - 4;
    }
    j := j + 1;
  }
  
  hex[pos] := 0;
  return hex;
}

