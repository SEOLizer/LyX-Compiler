// ============================================================================
// MD5 Quick Hash (simplified single-pass for short strings)
// ============================================================================

pub fn HashMD5Quick(data: pchar): int64 {
  // Quick MD5-like hash (not full MD5, but produces 128-bit equivalent)
  var h0: int64 := 0x67452301;
  var h1: int64 := 0xefcdab89;
  var h2: int64 := 0x98badcfe;
  var h3: int64 := 0x10325476;
  
  var i: int64 := 0;
  var len: int64 := StrLength(data);
  
  while (i < len) {
    var c: int64 := StrCharAt(data, i) & 255;
    
    h0 := (h0 + c) & 0xFFFFFFFF;
    h1 := (h1 + (c * 31)) & 0xFFFFFFFF;
    h2 := (h2 + (c * 37)) & 0xFFFFFFFF;
    h3 := (h3 + (c * 41)) & 0xFFFFFFFF;
    
    // Mix
    var t: int64 := h0;
    h0 := (h0 + MD5_ROTL(h1, 5) + h2) & 0xFFFFFFFF;
    h2 := (h2 + MD5_ROTL(h3, 7) + t) & 0xFFFFFFFF;
    
    i := i + 1;
  }
  
  // Combine into single 128-bit value
  var result: int64 := h0;
  result := (result << 32) | h1;
  result := (result << 32) | h2;
  result := (result << 32) | h3;
  
  return result;
}

// ============================================================================
// Verify MD5 (compare hash of data with expected)
// ============================================================================

pub fn MD5Verify(data: pchar, expected_hex: pchar): bool {
  var hash_hex: pchar := HashMD5StringHex(data);
  
  var i: int64 := 0;
  while (i < 32) {
    if (hash_hex[i] != expected_hex[i]) {
      return false;
    }
    i := i + 1;
  }
  
  return true;
}

