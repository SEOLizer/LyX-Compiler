pub fn HashSHAKE128(data: pchar, output_bits: int64): int64 {
  // SHAKE128 with variable output length
  var state: array[25]int64;
  var i: int64 := 0;
  while (i < 25) {
    state[i] := 0;
    i := i + 1;
  }
  
  // Absorb
  var len: int64 := StrLength(data);
  var rate_bytes: int64 := 168; // SHAKE128 rate
  
  i := 0;
  while (i < len) {
    var j: int64 := 0;
    while (j < rate_bytes && (i + j) < len) {
      var byte_val: int64 := StrCharAt(data, i + j) & 255;
      state[j / 8] := state[j / 8] ^ (byte_val << ((j & 7) * 8));
      j := j + 1;
    }
    SHA3Permute(state);
    i := i + rate_bytes;
  }
  
  // Return truncated output
  return state[0] & ((1 << (output_bits & 63)) - 1);
}

