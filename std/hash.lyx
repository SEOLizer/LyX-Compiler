fn Ch(x: int64, y: int64, z: int64): int64 {
  return (x & y) ^ ((~x) & z);
}

fn Maj(x: int64, y: int64, z: int64): int64 {
  return (x & y) ^ (x & z) ^ (y & z);
}

fn Rotr(x: int64, n: int64): int64 {
  var sh: int64 := 32 - n;
  var left: int64 := x >> n;
  var right: int64 := x << sh;
  var rmasked: int64 := right & 0xFFFFFFFF;
  return left | rmasked;
}

fn Sigma0(x: int64): int64 {
  return Rotr(x, 2) ^ Rotr(x, 13) ^ Rotr(x, 22);
}

fn Sigma1(x: int64): int64 {
  return Rotr(x, 6) ^ Rotr(x, 11) ^ Rotr(x, 25);
}

fn Gamma0(x: int64): int64 {
  return Rotr(x, 7) ^ Rotr(x, 18) ^ (x >> 3);
}

fn Gamma1(x: int64): int64 {
  return Rotr(x, 17) ^ Rotr(x, 19) ^ (x >> 10);
}

fn SHA256Add(a: int64, b: int64): int64 {
  var s: int64 := a + b;
  return s & 0xFFFFFFFF;
}

fn SHA256RightShift(a: int64, n: int64): int64 {
  return a >> n;
}

// ============================================================================
// SHA-256 Hash (simplified single-block)
// ============================================================================

pub fn HashSHA256(data: pchar): int64 {
  var h0: int64 := 0x6a09e667;
  var h1: int64 := 0xbb67ae85;
  var h2: int64 := 0x3c6ef372;
  var h3: int64 := 0xa54ff53a;
  var h4: int64 := 0x510e527f;
  var h5: int64 := 0x9b05688c;
  var h6: int64 := 0x1f83d9ab;
  var h7: int64 := 0x5be0cd19;

  var i: int64 := 0;
  var len: int64 := StrLen(data);

  while (i < len) {
    var byte_val: int64 := StrCharAt(data, i) & 255;

    var t1tmp: int64 := h4 + Ch(h4, h5, h6) + byte_val;
    var t1: int64 := t1tmp & 0xFFFFFFFF;
    var t2tmp: int64 := Sigma0(h0) + Maj(h0, h1, h2);
    var t2: int64 := t2tmp & 0xFFFFFFFF;

    var h7t: int64 := h7 + t1; h7 := h7t & 0xFFFFFFFF;
    var h6t: int64 := h6 + t1; h6 := h6t & 0xFFFFFFFF;
    var h5g: int64 := h5 + Gamma1(t1); h5 := h5g & 0xFFFFFFFF;
    var h4t: int64 := h4 + t1; h4 := h4t & 0xFFFFFFFF;
    var h3t: int64 := h3 + t2; h3 := h3t & 0xFFFFFFFF;
    var h2g: int64 := h2 + Gamma0(t2); h2 := h2g & 0xFFFFFFFF;
    var h1s: int64 := h1 + Sigma1(t2); h1 := h1s & 0xFFFFFFFF;
    var h0s: int64 := h0 + t1 + t2; h0 := h0s & 0xFFFFFFFF;

    i := i + 1;
  }

  var result: int64 := h0;
  result := (result << 32) | h1;
  result := (result << 32) | h2;
  result := (result << 32) | h3;

  return result;
}

// ============================================================================
// Password Hashing with Salt
// ============================================================================

pub fn HashPassword(password: pchar, salt: pchar): int64 {
  var phash: int64 := HashSHA256(password);
  var shash: int64 := HashFNV1a64(salt);
  var hash: int64 := phash ^ shash;

  var i: int64 := 0;
  while (i < 1000) {
    hash := hash ^ phash;
    hash := hash ^ shash;
    var htmp: int64 := hash * FNV_PRIME_64; hash := htmp & 0xFFFFFFFFFFFFFFFF;
    i := i + 1;
  }

  return hash;
}

pub fn HashPasswordSimple(password: pchar, salt: int64): int64 {
  var hash: int64 := HashFNV1a64(password);
  hash := hash ^ salt;
  hash := hash * FNV_PRIME_64;

  var i: int64 := 0;
  while (i < 100) {
    hash := hash ^ salt;
    hash := hash * FNV_PRIME_64;
    i := i + 1;
  }

  return hash;
}

// ============================================================================
// Hash Table Helper
// ============================================================================

pub fn HashTableIndex(key: pchar, table_size: int64): int64 {
  var hash: int64 := HashDJB2(key);
  if (hash < 0) { hash := -hash; }
  return hash % table_size;
}

// ============================================================================
// Byte Array Hash
// ============================================================================

pub fn HashBytes(data: pchar, len: int64): int64 {
  var hash: int64 := FNV_OFFSET_BASIS_64;
  var i: int64 := 0;
  while (i < len) {
    hash := hash ^ StrCharAt(data, i);
    hash := hash * FNV_PRIME_64;
    i := i + 1;
  }
  return hash;
}

// ============================================================================
// Integer Hash
// ============================================================================

pub fn HashInt64(key: int64): int64 {
  key := key ^ (key >> 33);
  key := key * 0xff51afd7ed558ccd;
  key := key ^ (key >> 33);
  key := key * 0xc4ceb9fe1a85ec53;
  key := key ^ (key >> 33);
  return key;
}

pub fn HashInt32(key: int64): int64 {
  key := key ^ (key >> 16);
  key := key * 0x85ebca6b;
  key := key ^ (key >> 13);
  key := key * 0xc2b2ae35;
  key := key ^ (key >> 16);
  return key & 0xFFFFFFFF;
}

