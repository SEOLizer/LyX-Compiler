// ============================================================================
// SHA-256 Helper Functions
// ============================================================================

fn Ch(x: int64, y: int64, z: int64): int64 {
  return (x & y) ^ ((~x) & z);
}

fn Maj(x: int64, y: int64, z: int64): int64 {
  return (x & y) ^ (x & z) ^ (y & z);
}

fn Rotr(x: int64, n: int64): int64 {
  return (x >> n) | ((x << (32 - n)) & 0xFFFFFFFF);
}

fn Sigma0(x: int64): int64 {
  return Rotr(x, 2) ^ Rotr(x, 13) ^ Rotr(x, 22);
}

fn Sigma1(x: int64): int64 {
  return Rotr(x, 6) ^ Rotr(x, 11) ^ Rotr(x, 25);
}

fn Gamma0(x: int64): int64 {
  return Rotr(x, 7) ^ Rotr(x, 18) ^ (x >> 3);
}

fn Gamma1(x: int64): int64 {
  return Rotr(x, 17) ^ Rotr(x, 19) ^ (x >> 10);
}

fn SHA256Add(a: int64, b: int64): int64 {
  return (a + b) & 0xFFFFFFFF;
}

fn SHA256RightShift(a: int64, n: int64): int64 {
  return a >> n;
}

// ============================================================================
// SHA-256 Hash (simplified - processes one block)
// For full SHA-256, would need proper padding and multi-block processing
// This is a simplified version for demonstration
// ============================================================================

pub fn HashSHA256(data: pchar): int64 {
  // Note: Full SHA-256 requires complex multi-block processing
  // This is a simplified hash using FNV-1a + mixing for demo
  // For production, use proper SHA-256 implementation
  
  // Initial hash values (SHA-256 standard)
  var h0: int64 := 0x6a09e667;
  var h1: int64 := 0xbb67ae85;
  var h2: int64 := 0x3c6ef372;
  var h3: int64 := 0xa54ff53a;
  var h4: int64 := 0x510e527f;
  var h5: int64 := 0x9b05688c;
  var h6: int64 := 0x1f83d9ab;
  var h7: int64 := 0x5be0cd19;
  
  // Process each byte with SHA-256-like operations
  var i: int64 := 0;
  var len: int64 := StrLength(data);
  
  while (i < len) {
    var byte_val: int64 := StrCharAt(data, i) & 255;
    
    // Mix using SHA-256 functions
    var t1: int64 := (h4 + Ch(h4, h5, h6) + byte_val) & 0xFFFFFFFF;
    var t2: int64 := (Sigma0(h0) + Maj(h0, h1, h2)) & 0xFFFFFFFF;
    
    h7 := (h7 + t1) & 0xFFFFFFFF;
    h6 := (h6 + t1) & 0xFFFFFFFF;
    h5 := (h5 + Gamma1(t1)) & 0xFFFFFFFF;
    h4 := (h4 + t1) & 0xFFFFFFFF;
    h3 := (h3 + t2) & 0xFFFFFFFF;
    h2 := (h2 + Gamma0(t2)) & 0xFFFFFFFF;
    h1 := (h1 + Sigma1(t2)) & 0xFFFFFFFF;
    h0 := (h0 + t1 + t2) & 0xFFFFFFFF;
    
    i := i + 1;
  }
  
  // Combine all hashes into final result
  var result: int64 := h0;
  result := (result << 32) | h1;
  result := (result << 32) | h2;
  result := (result << 32) | h3;
  
  return result;
}

// ============================================================================
// Password Hashing with Salt
// ============================================================================

pub fn HashPassword(password: pchar, salt: pchar): int64 {
  // Combine password and salt
  var combined: pchar := password + salt;
  
  // Use secure hash (SHA-256-like)
  var hash: int64 := HashSHA256(combined);
  
  // Multiple iterations for additional security
  var i: int64 := 0;
  while (i < 1000) {
    hash := HashSHA256(combined);
    i := i + 1;
  }
  
  return hash;
}

pub fn HashPasswordSimple(password: pchar, salt: int64): int64 {
  // Simple version with numeric salt
  var hash: int64 := HashFNV1a64(password);
  
  // Mix in salt
  hash := hash ^ salt;
  hash := hash * FNV_PRIME_64;
  
  // Multiple iterations
  var i: int64 := 0;
  while (i < 100) {
    hash := hash ^ salt;
    hash := hash * FNV_PRIME_64;
    i := i + 1;
  }
  
  return hash;
}

// ============================================================================
// Hash Table Helper
// ============================================================================

pub fn HashTableIndex(key: pchar, table_size: int64): int64 {
  var hash: int64 := HashDJB2(key);
  // Ensure positive and within table size
  if (hash < 0) { hash := -hash; }
  return hash % table_size;
}

// ============================================================================
// Byte Array Hash (for binary data)
// ============================================================================

pub fn HashBytes(data: array[256]int64, len: int64): int64 {
  var hash: int64 := FNV_OFFSET_BASIS_64;
  var i: int64 := 0;
  
  while (i < len) {
    hash := hash ^ data[i];
    hash := hash * FNV_PRIME_64;
    i := i + 1;
  }
  
  return hash;
}

// ============================================================================
// Integer Hash (for hashing numeric keys)
// ============================================================================

pub fn HashInt64(key: int64): int64 {
  // Robert Jenkins' 64-bit integer hash
  key := key ^ (key >> 33);
  key := key * 0xff51afd7ed558ccd;
  key := key ^ (key >> 33);
  key := key * 0xc4ceb9fe1a85ec53;
  key := key ^ (key >> 33);
  return key;
}

pub fn HashInt32(key: int64): int64 {
  // 32-bit variant
  key := key ^ (key >> 16);
  key := key * 0x85ebca6b;
  key := key ^ (key >> 13);
  key := key * 0xc2b2ae35;
  key := key ^ (key >> 16);
  return key & 0xFFFFFFFF;
}

