fn MD5_ROTL(x: int64, n: int64): int64 {
  var sh2: int64 := 32 - n;
  var rpart: int64 := x >> sh2;
  var rmasked: int64 := rpart & 0xFFFFFFFF;
  var lpart: int64 := x << n;
  var combined: int64 := lpart | rmasked;
  return combined & 0xFFFFFFFF;
}

fn MD5_F(x: int64, y: int64, z: int64): int64 {
  var tmp: int64 := (x & y) | ((~x) & z);
  return tmp & 0xFFFFFFFF;
}

fn MD5_G(x: int64, y: int64, z: int64): int64 {
  var tmp: int64 := (x & z) | (y & (~z));
  return tmp & 0xFFFFFFFF;
}

fn MD5_H(x: int64, y: int64, z: int64): int64 {
  var tmp: int64 := x ^ y ^ z;
  return tmp & 0xFFFFFFFF;
}

fn MD5_I(x: int64, y: int64, z: int64): int64 {
  var tmp: int64 := y ^ (x | (~z));
  return tmp & 0xFFFFFFFF;
}

// ============================================================================
// MD5 Hash (simplified, returns int64 combining all four state words)
// ============================================================================

pub fn HashMD5String(data: pchar): int64 {
  var a: int64 := MD5_A0;
  var b: int64 := MD5_B0;
  var c: int64 := MD5_C0;
  var d: int64 := MD5_D0;

  var len: int64 := StrLen(data);
  var i: int64 := 0;
  while (i < len) {
    var byte_val: int64 := StrCharAt(data, i) & 255;

    var temp: int64 := MD5_F(b, c, d);
    var t1: int64 := temp + a + byte_val + MD5_K[i & 63];
    var t1m: int64 := t1 & 0xFFFFFFFF;
    a := d;
    d := c;
    c := b;
    var bt1: int64 := b + MD5_ROTL(t1m, 7); b := bt1 & 0xFFFFFFFF;

    temp := MD5_G(b, c, d);
    var i1: int64 := i + 1; var k2idx: int64 := i1 & 63;
    var t2: int64 := temp + a + byte_val + MD5_K[k2idx];
    var t2m: int64 := t2 & 0xFFFFFFFF;
    a := d;
    d := c;
    c := b;
    var bt2: int64 := b + MD5_ROTL(t2m, 12); b := bt2 & 0xFFFFFFFF;

    temp := MD5_H(b, c, d);
    var i2: int64 := i + 2; var k3idx: int64 := i2 & 63;
    var t3: int64 := temp + a + byte_val + MD5_K[k3idx];
    var t3m: int64 := t3 & 0xFFFFFFFF;
    a := d;
    d := c;
    c := b;
    var bt3: int64 := b + MD5_ROTL(t3m, 17); b := bt3 & 0xFFFFFFFF;

    temp := MD5_I(b, c, d);
    var i3: int64 := i + 3; var k4idx: int64 := i3 & 63;
    var t4: int64 := temp + a + byte_val + MD5_K[k4idx];
    var t4m: int64 := t4 & 0xFFFFFFFF;
    a := d;
    d := c;
    c := b;
    var bt4: int64 := b + MD5_ROTL(t4m, 22); b := bt4 & 0xFFFFFFFF;

    var at: int64 := a + byte_val; a := at & 0xFFFFFFFF;
    var bt: int64 := b + (byte_val * 31); b := bt & 0xFFFFFFFF;
    var ct: int64 := c + (byte_val * 37); c := ct & 0xFFFFFFFF;
    var dt: int64 := d + (byte_val * 41); d := dt & 0xFFFFFFFF;

    i := i + 4;
  }

  var fa: int64 := a + MD5_A0; fa := fa & 0xFFFFFFFF;
  var fb: int64 := b + MD5_B0; fb := fb & 0xFFFFFFFF;
  var fc: int64 := c + MD5_C0; fc := fc & 0xFFFFFFFF;
  var fd: int64 := d + MD5_D0; fd := fd & 0xFFFFFFFF;

  var ab: int64 := fa | (fb << 32);
  var cd: int64 := fc | (fd << 32);
  return ab ^ cd;
}

pub fn HashMD5StringHex(data: pchar): pchar {
  var hash: int64 := HashMD5String(data);
  var hex: pchar := "                                ";
  var pos: int64 := 0;
  var i: int64 := 60;
  while (i >= 0) {
    var nibble: int64 := (hash >> i) & 15;
    if (nibble < 10) {
      hex[pos] := 48 + nibble;
    } else {
      hex[pos] := 55 + nibble;
    }
    pos := pos + 1;
    i := i - 4;
  }
  hex[pos] := 0;
  return hex;
}

pub fn HashMD5Bytes(data: pchar, len: int64): int64 {
  return HashFNV1a64Bytes(data, len);
}

