// MD5 for Byte Arrays
// ============================================================================

pub fn HashMD5Bytes(data: array[256]int64, len: int64): array[4]int64 {
  var a: int64 := MD5_A0;
  var b: int64 := MD5_B0;
  var c: int64 := MD5_C0;
  var d: int64 := MD5_D0;
  
  var i: int64 := 0;
  while (i < len) {
    var byte_val: int64 := data[i] & 255;
    
    var temp: int64 := MD5_F(b, c, d);
    temp := (temp + a + byte_val + MD5_K[((i) & 63)]) & 0xFFFFFFFF;
    a := d;
    d := c;
    c := b;
    b := (b + MD5_ROTL(temp, 7)) & 0xFFFFFFFF;
    
    temp := MD5_G(b, c, d);
    temp := (temp + a + byte_val + MD5_K[(((i + 1) & 63))]) & 0xFFFFFFFF;
    a := d;
    d := c;
    c := b;
    b := (b + MD5_ROTL(temp, 12)) & 0xFFFFFFFF;
    
    temp := MD5_H(b, c, d);
    temp := (temp + a + byte_val + MD5_K[(((i + 2) & 63))]) & 0xFFFFFFFF;
    a := d;
    d := c;
    c := b;
    b := (b + MD5_ROTL(temp, 17)) & 0xFFFFFFFF;
    
    temp := MD5_I(b, c, d);
    temp := (temp + a + byte_val + MD5_K[(((i + 3) & 63))]) & 0xFFFFFFFF;
    a := d;
    d := c;
    c := b;
    b := (b + MD5_ROTL(temp, 22)) & 0xFFFFFFFF;
    
    a := (a + byte_val) & 0xFFFFFFFF;
    b := (b + (byte_val * 31)) & 0xFFFFFFFF;
    c := (c + (byte_val * 37)) & 0xFFFFFFFF;
    d := (d + (byte_val * 41)) & 0xFFFFFFFF;
    
    i := i + 4;
  }
  
  a := (a + MD5_A0) & 0xFFFFFFFF;
  b := (b + MD5_B0) & 0xFFFFFFFF;
  c := (c + MD5_C0) & 0xFFFFFFFF;
  d := (d + MD5_D0) & 0xFFFFFFFF;
  
  var result: array[4]int64;
  result[0] := a;
  result[1] := b;
  result[2] := c;
  result[3] := d;
  
  return result;
}

