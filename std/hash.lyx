// ============================================================================
// FNV-1a Constants
// ============================================================================

con FNV_OFFSET_BASIS_32: int64 := 2166136261;
con FNV_PRIME_32: int64 := 16777619;
con FNV_OFFSET_BASIS_64: int64 := 14695981039346656037;
con FNV_PRIME_64: int64 := 1099511628211;

// ============================================================================
// FNV-1a 32-bit
// ============================================================================

pub fn HashFNV1a32(data: pchar): int64 {
  var hash: int64 := FNV_OFFSET_BASIS_32;
  var i: int64 := 0;
  var len: int64 := StrLen(data);
  while (i < len) {
    var byte_val: int64 := StrCharAt(data, i);
    hash := hash ^ byte_val;
    hash := hash * FNV_PRIME_32;
    i := i + 1;
  }
  return hash & 4294967295;
}

pub fn HashFNV1a32Bytes(data: pchar, len: int64): int64 {
  var hash: int64 := FNV_OFFSET_BASIS_32;
  var i: int64 := 0;
  while (i < len) {
    var byte_val: int64 := StrCharAt(data, i);
    hash := hash ^ byte_val;
    hash := hash * FNV_PRIME_32;
    i := i + 1;
  }
  return hash & 4294967295;
}

// ============================================================================
// FNV-1a 64-bit
// ============================================================================

pub fn HashFNV1a64(data: pchar): int64 {
  var hash: int64 := FNV_OFFSET_BASIS_64;
