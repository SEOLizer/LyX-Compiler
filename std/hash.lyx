// SHA-3 Round Constants (simplified set)
con KECCAK_RHO: array[24]int64 := [
  1, 3, 6, 10, 15, 21, 28, 36, 45, 55, 66, 78,
  91, 105, 120, 136, 153, 171, 190, 210, 231, 253, 276, 300
];

con KECCAK_ROUND_C: array[24]int64 := [
  0x0000000000000001, 0x0000000000008082, 0x800000000000808a, 0x8000000080008000,
  0x000000000000808b, 0x0000000080000001, 0x8000000080008081, 0x8000000000008009,
  0x000000000000008a, 0x0000000000000088, 0x0000000080008009, 0x000000008000000a,
  0x000000008000808b, 0x800000000000008b, 0x8000000000008089, 0x8000000000008003,
  0x8000000000008002, 0x8000000000000080, 0x000000000000800a, 0x800000008000000a,
  0x8000000080008081, 0x8000000000008080, 0x0000000080000001, 0x8000000080008008
];

// SHA-3 state (25 64-bit words for 1600-bit state)
type SHA3State = {
  data: array[25]int64
};

fn SHA3Theta(state: array[25]int64): void {
  // Theta step
  var c: array[5]int64;
  var x: int64 := 0;
  while (x < 5) {
    c[x] := state[x] ^ state[x + 5] ^ state[x + 10] ^ state[x + 15] ^ state[x + 20];
    x := x + 1;
  }
  
  var d: array[5]int64;
  x := 0;
  while (x < 5) {
    d[x] := c[(x + 4) & 5] ^ (((c[(x + 1) & 5] << 1) | (c[(x + 1) & 5] >> 63)) & 0xFFFFFFFFFFFFFFFF);
    x := x + 1;
  }
  
  x := 0;
  while (x < 25) {
    state[x] := state[x] ^ d[x & 5];
    x := x + 1;
  }
}

fn SHA3RhoPi(state: array[25]int64): void {
  // Rho and Pi steps
  var x: int64 := 1;
  var y: int64 := 0;
  var current: int64 := state[1];
  var i: int64 := 0;
  
  while (i < 24) {
    var (new_x, new_y): (int64, int64) := ((y * 2 + x * 3) & 7, x);
    var t: int64 := state[new_x * 5 + new_y];
    state[new_x * 5 + new_y] := (((current << KECCAK_RHO[i]) | (current >> (64 - KECCAK_RHO[i]))) & 0xFFFFFFFFFFFFFFFF);
    current := t;
    x := new_x;
    y := new_y;
    i := i + 1;
  }
}

fn SHA3Chi(state: array[25]int64): void {
  // Chi step
  var x: int64 := 0;
  while (x < 5) {
    var y: int64 := 0;
    while (y < 5) {
      var idx: int64 := x * 5 + y;
      state[idx] := state[idx] ^ ((~(state[(x + 1) & 5 * 5 + y])) & state[(x + 2) & 5 * 5 + y]);
      y := y + 1;
    }
    x := x + 1;
  }
}

fn SHA3Iota(state: array[25]int64, round_idx: int64): void {
  // Iota step
  state[0] := state[0] ^ KECCAK_ROUND_C[round_idx];
}

fn SHA3Permute(state: array[25]int64): void {
  var i: int64 := 0;
  while (i < 24) {
    SHA3Theta(state);
    SHA3RhoPi(state);
    SHA3Chi(state);
    SHA3Iota(state, i);
    i := i + 1;
  }
}

