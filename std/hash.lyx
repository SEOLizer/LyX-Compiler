pub fn HashMD5FileChunk(chunk: array[512]int64, chunk_len: int64, state: array[4]int64): array[4]int64 {
  // Update MD5 state with a new chunk of data
  // Used for streaming hash of large files
  
  var a: int64 := state[0];
  var b: int64 := state[1];
  var c: int64 := state[2];
  var d: int64 := state[3];
  
  var i: int64 := 0;
  while (i < chunk_len) {
    var byte_val: int64 := chunk[i] & 255;
    
    var temp: int64 := MD5_F(b, c, d);
    temp := (temp + a + byte_val + MD5_K[((i) & 63)]) & 0xFFFFFFFF;
    a := d;
    d := c;
    c := b;
    b := (b + MD5_ROTL(temp, 7)) & 0xFFFFFFFF;
    
    i := i + 1;
  }
  
  var result: array[4]int64;
  result[0] := a;
  result[1] := b;
  result[2] := c;
  result[3] := d;
  
  return result;
}

