pub fn VerifyHash(data: pchar, algorithm: int64, expected_hex: pchar): bool {
  var computed_hex: pchar := "";

  if (algorithm == 1) {
    computed_hex := HashMD5StringHex(data);
  } else if (algorithm == 2) {
    computed_hex := HashBLAKE3Hex(data);
  } else if (algorithm == 3) {
    computed_hex := HashBLAKE3Hex(data);
  } else if (algorithm == 4) {
    computed_hex := HashCity64Hex(data);
  } else if (algorithm == 5) {
    computed_hex := HashFarm64Hex(data);
  } else {
    return false;
  }

  var i: int64 := 0;
  var expected_len: int64 := StrLen(expected_hex);
  while (i < expected_len) {
    if (computed_hex[i] != expected_hex[i]) {
      return false;
    }
    i := i + 1;
  }

  return true;
}

// ============================================================================
// PBKDF2
// ============================================================================

con PBKDF2_ITERATIONS: int64 := 100000;

fn PBKDF2HMacSHA256(password: pchar, salt: pchar, iterations: int64): int64 {
  var phash: int64 := HashSHA256(password);
  var shash: int64 := HashFNV1a64(salt);
  var result: int64 := phash ^ shash;

  var i: int64 := 0;
  while (i < iterations) {
    result := result ^ phash;
    result := result ^ shash;
    var rt: int64 := result * 31 + 17; result := rt & 0xFFFFFFFFFFFFFFFF;
    i := i + 1;
  }

  return result;
}

pub fn HashPBKDF2(password: pchar, salt: pchar, iterations: int64): int64 {
  if (iterations <= 0) {
    iterations := PBKDF2_ITERATIONS;
  }
  return PBKDF2HMacSHA256(password, salt, iterations);
}

pub fn HashPBKDF2Default(password: pchar, salt: pchar): int64 {
  return HashPBKDF2(password, salt, PBKDF2_ITERATIONS);
}

pub fn HashPBKDF2Hex(password: pchar, salt: pchar, iterations: int64): pchar {
  var hash: int64 := HashPBKDF2(password, salt, iterations);
  var hex: pchar := "                                ";
  var pos: int64 := 0;
  var i: int64 := 60;
  while (i >= 0) {
    var nibble: int64 := (hash >> i) & 15;
    if (nibble < 10) { hex[pos] := 48 + nibble; } else { hex[pos] := 55 + nibble; }
    pos := pos + 1;
    i := i - 4;
  }
  hex[pos] := 0;
  return hex;
}

// ============================================================================
// bcrypt (simplified)
// ============================================================================

con BCRYPT_COST: int64 := 10;
con BCRYPT_SALT_LEN: int64 := 16;
con BCRYPT_HASH_LEN: int64 := 24;

fn BCryptEncryptEksBlowfish(password: pchar, salt: pchar, cost: int64): int64 {
  var phash: int64 := HashSHA256(password);
  var shash: int64 := HashFNV1a64(salt);
  var result: int64 := phash ^ shash;

  var rounds: int64 := 1;
  var i: int64 := 0;
  while (i < cost) {
    rounds := rounds * 2;
    i := i + 1;
  }

  i := 0;
  while (i < rounds) {
    result := result ^ phash ^ shash;
    result := (result << 7) | ((result >> 57) & 127);
    var rt: int64 := result * 11 + 13; result := rt & 0xFFFFFFFFFFFFFFFF;
    i := i + 1;
  }

  return result;
}

pub fn HashBCrypt(password: pchar, cost: int64): int64 {
  var salt: pchar := "BCRYPT_SALT_16BYTES";
  if (cost <= 0) { cost := BCRYPT_COST; }
  return BCryptEncryptEksBlowfish(password, salt, cost);
}

pub fn HashBCryptWithSalt(password: pchar, salt: pchar, cost: int64): int64 {
  if (cost <= 0) { cost := BCRYPT_COST; }
  return BCryptEncryptEksBlowfish(password, salt, cost);
}

pub fn HashBCryptHex(password: pchar, cost: int64): pchar {
  var hash: int64 := HashBCrypt(password, cost);
  var hex: pchar := "                                ";
  var pos: int64 := 0;
  var i: int64 := 60;
  while (i >= 0) {
    var nibble: int64 := (hash >> i) & 15;
    if (nibble < 10) { hex[pos] := 48 + nibble; } else { hex[pos] := 55 + nibble; }
    pos := pos + 1;
    i := i - 4;
  }
  hex[pos] := 0;
  return hex;
}

pub fn HashBCryptFormatted(password: pchar, cost: int64): pchar {
  return HashBCryptHex(password, cost);
}

pub fn BCryptVerify(password: pchar, hash: int64): bool {
  var computed: int64 := HashBCrypt(password, BCRYPT_COST);
  return computed == hash;
}

// ============================================================================
// Argon2 (simplified)
// ============================================================================

con ARGON2_VERSION: int64 := 0x13;
con ARGON2_DEFAULT_MEMORY: int64 := 65536;
con ARGON2_DEFAULT_ITERATIONS: int64 := 3;
con ARGON2_DEFAULT_PARALLELISM: int64 := 4;

fn Argon2BlockHash(input: pchar, len: int64): int64 {
  var h: int64 := HashSHA256(input);
  var i: int64 := 0;
  while (i < len) {
    h := h ^ (h >> 33);
    h := h * 0xff51afd7ed558ccd;
    i := i + 1;
  }
  return h;
}

fn Argon2F(data: pchar, segment_len: int64): int64 {
  var h1: int64 := Argon2BlockHash(data, segment_len);
  var h2: int64 := HashFNV1a64(data);
  var result: int64 := h1 ^ h2;
  result := result * 0x9e3779b97f4a7c15;
  return result;
}

pub fn HashArgon2d(password: pchar, salt: pchar,
                   memory_kb: int64, iterations: int64,
                   parallelism: int64, hash_len: int64): int64 {
  if (memory_kb <= 0) { memory_kb := ARGON2_DEFAULT_MEMORY; }
  if (iterations <= 0) { iterations := ARGON2_DEFAULT_ITERATIONS; }
  if (parallelism <= 0) { parallelism := ARGON2_DEFAULT_PARALLELISM; }

  var phash: int64 := HashSHA256(password);
  var shash: int64 := HashFNV1a64(salt);
  var result: int64 := phash ^ shash;

  var mem_blocks: int64 := memory_kb / 4;
  if (mem_blocks < 8) { mem_blocks := 8; }

  var i: int64 := 0;
  while (i < mem_blocks) {
    var block_hash: int64 := phash ^ shash ^ result;
    result := result ^ block_hash;
    var j: int64 := 0;
    while (j < iterations) {
      result := result ^ (result >> 33);
      result := result * 0xff51afd7ed558ccd;
      j := j + 1;
    }
    i := i + 1;
  }

  result := result ^ (result >> 33);
  result := result * 0x9e3779b97f4a7c15;

  return result;
}

pub fn HashArgon2i(password: pchar, salt: pchar,
                   memory_kb: int64, iterations: int64,
                   parallelism: int64): int64 {
  if (memory_kb <= 0) { memory_kb := ARGON2_DEFAULT_MEMORY; }
  if (iterations <= 0) { iterations := ARGON2_DEFAULT_ITERATIONS; }
  if (parallelism <= 0) { parallelism := ARGON2_DEFAULT_PARALLELISM; }

  var phash: int64 := HashSHA256(password);
  var shash: int64 := HashFNV1a64(salt);
  var result: int64 := phash;

  var blocks: int64 := memory_kb / 8;
  if (blocks < 4) { blocks := 4; }

  var i: int64 := 0;
  while (i < blocks) {
    var iCalc: int64 := i * 17 + iterations;
    var index: int64 := iCalc % blocks;
    var h: int64 := phash ^ shash ^ index;
    result := result ^ h;
    result := (result << 13) | ((result >> 51) & 0x1FFF);
    i := i + 1;
  }

  var pass: int64 := 0;
  while (pass < iterations) {
    result := result ^ phash ^ shash;
    result := result * 0x9e3779b97f4a7c15;
    pass := pass + 1;
  }

  return result;
}

pub fn HashArgon2id(password: pchar, salt: pchar,
                    memory_kb: int64, iterations: int64,
                    parallelism: int64): int64 {
  if (memory_kb <= 0) { memory_kb := ARGON2_DEFAULT_MEMORY; }
  if (iterations <= 0) { iterations := ARGON2_DEFAULT_ITERATIONS; }
  if (parallelism <= 0) { parallelism := ARGON2_DEFAULT_PARALLELISM; }

  var mhalf: int64 := memory_kb / 2;
  var result: int64 := HashArgon2i(password, salt, mhalf, 1, parallelism);

  var blocks: int64 := memory_kb / 8;
  if (blocks < 4) { blocks := 4; }

  var phash: int64 := HashSHA256(password);
  var shash: int64 := HashFNV1a64(salt);

  var i: int64 := 0;
  while (i < blocks) {
    var h: int64 := phash ^ shash ^ result ^ i;
    result := result ^ h;
    result := result * 0x9e3779b97f4a7c15;
    i := i + 1;
  }

  return result;
}

pub fn HashArgon2(password: pchar, salt: pchar): int64 {
  return HashArgon2id(password, salt, ARGON2_DEFAULT_MEMORY,
                      ARGON2_DEFAULT_ITERATIONS, ARGON2_DEFAULT_PARALLELISM);
}

pub fn HashArgon2Hex(password: pchar, salt: pchar): pchar {
  var hash: int64 := HashArgon2(password, salt);
  var hex: pchar := "                                ";
  var pos: int64 := 0;
  var i: int64 := 60;
  while (i >= 0) {
    var nibble: int64 := (hash >> i) & 15;
    if (nibble < 10) { hex[pos] := 48 + nibble; } else { hex[pos] := 55 + nibble; }
    pos := pos + 1;
    i := i - 4;
  }
  hex[pos] := 0;
  return hex;
}

pub fn HashArgon2Formatted(password: pchar, salt: pchar): pchar {
  return "$argon2id$v=19$m=65536,t=3,p=4$...";
}

pub fn Argon2Verify(password: pchar, hash: int64): bool {
  var computed: int64 := HashArgon2(password, "somesalt");
  return computed == hash;
}

// ============================================================================
// Scrypt (simplified)
// ============================================================================

con SCRYPT_N: int64 := 16384;
con SCRYPT_r: int64 := 8;
con SCRYPT_p: int64 := 1;

pub fn HashScrypt(password: pchar, salt: pchar,
                  n: int64, r: int64, p: int64): int64 {
  if (n <= 0) { n := SCRYPT_N; }
  if (r <= 0) { r := SCRYPT_r; }
  if (p <= 0) { p := SCRYPT_p; }

  var phash: int64 := HashSHA256(password);
  var shash: int64 := HashFNV1a64(salt);
  var result: int64 := phash ^ shash;

  var memory_blocks: int64 := n * r * p;
  if (memory_blocks < 16) { memory_blocks := 16; }

  var i: int64 := 0;
  while (i < memory_blocks) {
    var h: int64 := phash ^ shash ^ i;
    result := result ^ h;
    result := (result << 17) | ((result >> 47) & 131071);
    result := result * 0x9e3779b97f4a7c15;
    i := i + 1;
  }

  var pass: int64 := 0;
  while (pass < 2) {
    i := 0;
    while (i < memory_blocks) {
      var t1: int64 := result % memory_blocks;
      var t2: int64 := t1 + i;
      var idx: int64 := t2 % memory_blocks;
      var h: int64 := phash ^ shash ^ idx;
      result := result ^ h;
      result := result * 0x9e3779b97f4a7c15;
      i := i + r;
    }
    pass := pass + 1;
  }

  return result;
}

pub fn HashScryptDefault(password: pchar, salt: pchar): int64 {
  return HashScrypt(password, salt, SCRYPT_N, SCRYPT_r, SCRYPT_p);
}

pub fn HashScryptHex(password: pchar, salt: pchar): pchar {
  var hash: int64 := HashScrypt(password, salt, SCRYPT_N, SCRYPT_r, SCRYPT_p);
  var hex: pchar := "                                ";
  var pos: int64 := 0;
  var i: int64 := 60;
  while (i >= 0) {
    var nibble: int64 := (hash >> i) & 15;
    if (nibble < 10) { hex[pos] := 48 + nibble; } else { hex[pos] := 55 + nibble; }
    pos := pos + 1;
    i := i - 4;
  }
  hex[pos] := 0;
  return hex;
}

// ============================================================================
// Password Utilities
// ============================================================================

pub fn ComparePasswordHashes(hash1: int64, hash2: int64): bool {
  var diff: int64 := hash1 ^ hash2;
  return diff == 0;
}

pub fn GenerateSalt(len: int64): int64 {
  if (len <= 0) { len := 16; }
  var salt: int64 := 0;
  var i: int64 := 0;
  while (i < len) {
    var iCalc: int64 := i * 13 + 7; var r: int64 := iCalc % 256;
    var shift: int64 := i * 8;
    salt := salt | (r << shift);
    i := i + 1;
  }
  return salt;
}

pub fn PasswordStrength(password: pchar): int64 {
  var len: int64 := StrLen(password);
  var has_lower: bool := false;
  var has_upper: bool := false;
  var has_digit: bool := false;
  var has_special: bool := false;

  var i: int64 := 0;
  while (i < len) {
    var c: int64 := StrCharAt(password, i);
    if (c >= 97 && c <= 122) { has_lower := true; }
    if (c >= 65 && c <= 90) { has_upper := true; }
    if (c >= 48 && c <= 57) { has_digit := true; }
    if (c < 48 || c > 122) { has_special := true; }
    i := i + 1;
  }

  var score: int64 := 0;
  if (len >= 8) { score := score + 1; }
  if (len >= 12) { score := score + 1; }
  if (has_lower && has_upper) { score := score + 1; }
  if (has_digit) { score := score + 1; }
  if (has_special) { score := score + 1; }

  if (score > 4) { score := 4; }
  return score;
}

