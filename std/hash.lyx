// BLAKE3 Constants
con BLAKE3_IV: array[8]int64 := [
  0x6a09e667f3bcc908, 0xbb67ae8584caa73b,
  0x3c6ef372fe94f82b, 0xa54ff53a5f1d36f1,
  0x510e527fade682d1, 0x9b05688c2b3e6c1f,
  0x1f83d9abfb41bd6b, 0x5be0cd19137e2179
];

// BLAKE3 rotation constants
con BLAKE3_R1: int64 := 16;
con BLAKE3_R2: int64 := 12;
con BLAKE3_R3: int64 := 8;
con BLAKE3_R4: int64 := 7;

// BLAKE3 G function
fn BLAKE3_G(a: int64, b: int64, c: int64, d: int64, x: int64, y: int64): array[2]int64 {
  var result: array[2]int64;
  
  a := (a + b + x) & 0xFFFFFFFFFFFFFFFF;
  d := (d ^ a) >> BLAKE3_R1 | ((d ^ a) << (64 - BLAKE3_R1));
  c := (c + d) & 0xFFFFFFFFFFFFFFFF;
  b := (b ^ c) >> BLAKE3_R2 | ((b ^ c) << (64 - BLAKE3_R2));
  a := (a + b + y) & 0xFFFFFFFFFFFFFFFF;
  d := (d ^ a) >> BLAKE3_R3 | ((d ^ a) << (64 - BLAKE3_R3));
  c := (c + d) & 0xFFFFFFFFFFFFFFFF;
  b := (b ^ c) >> BLAKE3_R4 | ((b ^ c) << (64 - BLAKE3_R4));
  
  result[0] := a;
  result[1] := b;
  return result;
}

// BLAKE3 compression (simplified single block)
fn BLAKE3Compress(h: array[8]int64, block: array[16]int64, counter: int64, flag: int64): array[8]int64 {
  var v: array[16]int64;
  var i: int64 := 0;
  
  // Initialize working vector
  while (i < 8) {
    v[i] := h[i];
    i := i + 1;
  }
  
  // IV for BLAKE3
  v[8] := 0x6a09e667f3bcc908;
  v[9] := 0xbb67ae8584caa73b;
  v[10] := 0x3c6ef372fe94f82b;
  v[11] := 0xa54ff53a5f1d36f1;
  v[12] := counter & 0xFFFFFFFFFFFFFFFF;
  v[13] := flag & 0xFFFFFFFFFFFFFFFF;
  v[14] := 0x6a09e667f3bcc908;
  v[15] := 0xbb67ae8584caa73b;
  
  // Simplified rounds (fewer than full BLAKE3 for performance)
  i := 0;
  while (i < 4) {
    // Column mixing
    var g: array[2]int64 := BLAKE3_G(v[0], v[4], v[8], v[12], block[0], block[1]);
    v[0] := g[0]; v[4] := g[1];
    
    g := BLAKE3_G(v[1], v[5], v[9], v[13], block[2], block[3]);
    v[1] := g[0]; v[5] := g[1];
    
    g := BLAKE3_G(v[2], v[6], v[10], v[14], block[4], block[5]);
    v[2] := g[0]; v[6] := g[1];
    
    g := BLAKE3_G(v[3], v[7], v[11], v[15], block[6], block[7]);
    v[3] := g[0]; v[7] := g[1];
    
    // Diagonal mixing
    g := BLAKE3_G(v[0], v[5], v[10], v[15], block[8], block[9]);
    v[0] := g[0]; v[5] := g[1];
    
    g := BLAKE3_G(v[1], v[6], v[11], v[12], block[10], block[11]);
    v[1] := g[0]; v[6] := g[1];
    
    g := BLAKE3_G(v[2], v[7], v[8], v[13], block[12], block[13]);
    v[2] := g[0]; v[7] := g[1];
    
    g := BLAKE3_G(v[3], v[4], v[9], v[14], block[14], block[15]);
    v[3] := g[0]; v[4] := g[1];
    
    i := i + 1;
  }
  
  // Finalize
  i := 0;
  while (i < 8) {
    h[i] := h[i] ^ v[i] ^ v[i + 8];
    i := i + 1;
  }
  
  return h;
}

// Convert string to block
fn StringToBlock(s: pchar, block: array[16]int64): void {
  var i: int64 := 0;
  while (i < 16) {
    block[i] := 0;
    i := i + 1;
  }
  
  var len: int64 := StrLength(s);
  i := 0;
  while (i < len) {
    var byte_val: int64 := StrCharAt(s, i) & 255;
    var word_idx: int64 := (i / 8) & 15;
    block[word_idx] := block[word_idx] | (byte_val << ((i & 7) * 8));
    i := i + 1;
  }
}

// ============================================================================
// BLAKE3 Hash Functions
// ============================================================================

pub fn HashBLAKE3(data: pchar): int64 {
  // Initialize hash state
  var h: array[8]int64;
  h[0] := 0x6a09e667f3bcc908;
  h[1] := 0xbb67ae8584caa73b;
  h[2] := 0x3c6ef372fe94f82b;
  h[3] := 0xa54ff53a5f1d36f1;
  h[4] := 0x510e527fade682d1;
  h[5] := 0x9b05688c2b3e6c1f;
  h[6] := 0x1f83d9abfb41bd6b;
  h[7] := 0x5be0cd19137e2179;
  
  // Prepare block
  var block: array[16]int64;
  StringToBlock(data, block);
  
  // Compress
  h := BLAKE3Compress(h, block, 0, 0);
  
  // Combine to single 64-bit value
  var result: int64 := h[0];
  result := result ^ (h[2] >> 32);
  result := result ^ (h[4] >> 32);
  result := result ^ (h[6] >> 32);
  
  return result;
}

pub fn HashBLAKE3Bytes(data: array[256]int64, len: int64): int64 {
  var h: array[8]int64;
  h[0] := 0x6a09e667f3bcc908;
  h[1] := 0xbb67ae8584caa73b;
  h[2] := 0x3c6ef372fe94f82b;
  h[3] := 0xa54ff53a5f1d36f1;
  h[4] := 0x510e527fade682d1;
  h[5] := 0x9b05688c2b3e6c1f;
  h[6] := 0x1f83d9abfb41bd6b;
  h[7] := 0x5be0cd19137e2179;
  
  var block: array[16]int64;
  var i: int64 := 0;
  
  // Process in 64-byte blocks
  while ((i + 64) <= len) {
    var j: int64 := 0;
    while (j < 16) {
      block[j] := data[i + j * 4];
      j := j + 1;
    }
    h := BLAKE3Compress(h, block, i / 64, 0);
    i := i + 64;
  }
  
  // Handle remaining bytes
  j := 0;
  while (j < 16) {
    block[j] := 0;
    j := j + 1;
  }
  while (i < len) {
    var word_idx: int64 := ((i - (len / 64) * 64) / 4) & 15;
    block[word_idx] := block[word_idx] | ((data[i] & 255) << ((i & 3) * 8));
    i := i + 1;
  }
  
  h := BLAKE3Compress(h, block, len / 64, 1);
  
  var result: int64 := h[0];
  result := result ^ (h[2] >> 32);
  result := result ^ (h[4] >> 32);
  result := result ^ (h[6] >> 32);
  
  return result;
}

pub fn HashBLAKE3Hex(data: pchar): pchar {
  var hash: int64 := HashBLAKE3(data);
  
  var hex: pchar := "                                                                                                                                ";
  var pos: int64 := 0;
  var i: int64 := 60;
  
  while (i >= 0) {
    var nibble: int64 := (hash >> i) & 15;
    if (nibble < 10) {
      hex[pos] := 48 + nibble;
    } else {
      hex[pos] := 55 + nibble;
    }
    pos := pos + 1;
    i := i - 4;
  }
  
  hex[pos] := 0;
  return hex;
}

