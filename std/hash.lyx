pub fn HashSHA3_224(data: pchar): int64 {
  // SHA3-224 (simplified output of 224 bits = 28 bytes)
  var state: array[25]int64;
  var i: int64 := 0;
  while (i < 25) {
    state[i] := 0;
    i := i + 1;
  }
  
  // Absorb
  var len: int64 := StrLength(data);
  var rate_bytes: int64 := 144; // 224 - 2*224 = 144 for SHA3-224
  
  i := 0;
  while (i < len) {
    var j: int64 := 0;
    while (j < rate_bytes && (i + j) < len) {
      var byte_val: int64 := StrCharAt(data, i + j) & 255;
      state[j / 8] := state[j / 8] ^ (byte_val << ((j & 7) * 8));
      j := j + 1;
    }
    SHA3Permute(state);
    i := i + rate_bytes;
  }
  
  // Squeeze - return first 224 bits
  var result: int64 := state[0] & 0xFFFFFFFFFFFFFFFF;
  result := result ^ (state[1] & 0xFFFFFFFF) << 32;
  result := result ^ (state[2] & 0xFFFF) << 64;
  
  return result;
}

pub fn HashSHA3_256(data: pchar): int64 {
  // SHA3-256
  var state: array[25]int64;
  var i: int64 := 0;
  while (i < 25) {
    state[i] := 0;
    i := i + 1;
  }
  
  var len: int64 := StrLength(data);
  var rate_bytes: int64 := 136; // 256 - 2*256 = 136
  
  i := 0;
  while (i < len) {
    var j: int64 := 0;
    while (j < rate_bytes && (i + j) < len) {
      var byte_val: int64 := StrCharAt(data, i + j) & 255;
      state[j / 8] := state[j / 8] ^ (byte_val << ((j & 7) * 8));
      j := j + 1;
    }
    SHA3Permute(state);
    i := i + rate_bytes;
  }
  
  var result: int64 := state[0] ^ state[2];
  
  return result;
}

pub fn HashSHA3_512(data: pchar): int64 {
  // SHA3-512
  var state: array[25]int64;
  var i: int64 := 0;
  while (i < 25) {
    state[i] := 0;
    i := i + 1;
  }
  
  var len: int64 := StrLength(data);
  var rate_bytes: int64 := 72; // 512 - 2*512 = 72
  
  i := 0;
  while (i < len) {
    var j: int64 := 0;
    while (j < rate_bytes && (i + j) < len) {
      var byte_val: int64 := StrCharAt(data, i + j) & 255;
      state[j / 8] := state[j / 8] ^ (byte_val << ((j & 7) * 8));
      j := j + 1;
    }
    SHA3Permute(state);
    i := i + rate_bytes;
  }
  
  // Mix all 8 words for more entropy
  var result: int64 := state[0] ^ state[1] ^ state[2] ^ state[3] ^ 
                       state[4] ^ state[5] ^ state[6] ^ state[7];
  
  return result;
}

pub fn HashSHA3_256Hex(data: pchar): pchar {
  var hash: int64 := HashSHA3_256(data);
  
  var hex: pchar := "                                                                                                                                ";
  var pos: int64 := 0;
  var i: int64 := 60;
  
  while (i >= 0) {
    var nibble: int64 := (hash >> i) & 15;
    if (nibble < 10) {
      hex[pos] := 48 + nibble;
    } else {
      hex[pos] := 55 + nibble;
    }
    pos := pos + 1;
    i := i - 4;
  }
  
  hex[pos] := 0;
  return hex;
}

