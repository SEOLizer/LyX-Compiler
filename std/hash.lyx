// ============================================================================
// DJB2 - Simple but effective hash
// ============================================================================

pub fn HashDJB2(data: pchar): int64 {
  var hash: int64 := 5381;
  var i: int64 := 0;
  var len: int64 := StrLength(data);
  
  while (i < len) {
    var c: int64 := StrCharAt(data, i);
    // hash * 33 + c
    hash := (hash * 33) + c;
    i := i + 1;
  }
  
  return hash;
}

// ============================================================================
// MurmurHash2 (simplified 32-bit)
// ============================================================================

con MURMUR_M: int64 := 0x5bd1e995;
con MURMUR_R: int64 := 24;

pub fn HashMurmur2(data: pchar, seed: int64): int64 {
  var len: int64 := StrLength(data);
  var h: int64 := seed ^ len;
  var i: int64 := 0;
  
  while (i < len) {
    var k: int64 := StrCharAt(data, i);
    k := k * MURMUR_M;
    k := k ^ (k >> MURMUR_R);
    k := k * MURMUR_M;
    
    h := h * MURMUR_M;
    h := h ^ k;
    
    i := i + 1;
  }
  
  // Finalization
  h := h ^ (h >> 13);
  h := h * MURMUR_M;
  h := h ^ (h >> 15);
  
  return h;
}

pub fn HashMurmur2Default(data: pchar): int64 {
  return HashMurmur2(data, 0);
}

