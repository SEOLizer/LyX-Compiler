pub fn HashCRC32(data: pchar): int64 {
  var crc: int64 := 0xFFFFFFFF;
  var i: int64 := 0;
  var len: int64 := StrLen(data);
  while (i < len) {
    var xv: int64 := crc ^ StrCharAt(data, i);
    var index: int64 := xv & 255;
    var shifted: int64 := crc >> 8;
    crc := shifted ^ CRC32_TABLE[index];
    i := i + 1;
  }
  return crc ^ 0xFFFFFFFF;
}

