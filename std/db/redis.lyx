pub fn RedisLRange(conn: RedisConn, key: pchar, start: int64, stop: int64): RedisReply {
    var reqbuf: int64 := mmap(0, 512, 3, 34, -1, 0);
    var reply: RedisReply;
    reply.kind := REDIS_REPLY_NIL;
    reply.int_val := 0;
    reply.str_val := "";
    reply.str_len := 0;
    if (reqbuf <= 0) { return reply; }

    var pos: int64 := 0;
    // *4\r\n
    poke8(reqbuf + pos, 42); pos := pos + 1;  // '*'
    poke8(reqbuf + pos, 52); pos := pos + 1;  // '4'
    poke8(reqbuf + pos, 13); pos := pos + 1;  // \r
    poke8(reqbuf + pos, 10); pos := pos + 1;  // \n
    // LRANGE key start stop (bulk strings for integers)
    pos := appendBulk(reqbuf, pos, "LRANGE");
    pos := appendBulk(reqbuf, pos, key);
    // Use bulk string format for start and stop integers
    pos := appendBulk(reqbuf, pos, "0");
    pos := appendBulk(reqbuf, pos, "-1");

    reply := sendRaw(conn, reqbuf, pos);
    munmap(reqbuf, 512);
    return reply;
}

