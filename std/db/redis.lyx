pub fn RedisZRange(conn: RedisConn, key: pchar, start: int64, stop: int64): RedisReply {
    // Send: ZRANGE key start stop
    var req_buf: pchar := "                                                                                                                                ";
    var pos: int64 := 0;
    var key_len: int64 := StrLen(key);
    
    StrSetChar(req_buf, pos, 42); pos := pos + 1;
    StrSetChar(req_buf, pos, 52); pos := pos + 1;  // 4
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    // ZRANGE
    StrSetChar(req_buf, pos, 36); pos := pos + 1;
    StrSetChar(req_buf, pos, 54); pos := pos + 1;
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    StrSetChar(req_buf, pos, 90); pos := pos + 1;
    StrSetChar(req_buf, pos, 82); pos := pos + 1;
    StrSetChar(req_buf, pos, 65); pos := pos + 1;
    StrSetChar(req_buf, pos, 78); pos := pos + 1;
    StrSetChar(req_buf, pos, 71); pos := pos + 1;
    StrSetChar(req_buf, pos, 69); pos := pos + 1;
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    // Key
    StrSetChar(req_buf, pos, 36); pos := pos + 1;
    pos := appendInt(req_buf, pos, key_len);
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    var i: int64 := 0;
    while (i < key_len) { StrSetChar(req_buf, pos, StrCharAt(key, i)); pos := pos + 1; i := i + 1; }
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    // Start
    StrSetChar(req_buf, pos, 36); pos := pos + 1;
    pos := appendInt(req_buf, pos, start);
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    // Stop
    StrSetChar(req_buf, pos, 36); pos := pos + 1;
    pos := appendInt(req_buf, pos, stop);
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    sys_write(conn.fd, req_buf, pos);
    return parseReplyFD(conn.fd);
}

