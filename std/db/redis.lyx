// ============================================================================
// List Operations (LPUSH, RPUSH, LPOP, RPOP, LRANGE, LLEN)
// ============================================================================

pub fn RedisLPush(conn: RedisConn, key: pchar, value: pchar): RedisReply {
    var reqbuf: int64 := mmap(0, 512, 3, 34, -1, 0);
    var reply: RedisReply;
    reply.kind := REDIS_REPLY_NIL;
    reply.int_val := 0;
    reply.str_val := "";
    reply.str_len := 0;
    if (reqbuf <= 0) { return reply; }

    var pos: int64 := 0;
    // Build *3\r\n directly
    poke8(reqbuf + pos, 42); pos := pos + 1;  // *
    poke8(reqbuf + pos, 51); pos := pos + 1;  // 3
    poke8(reqbuf + pos, 13); pos := pos + 1;  // \r
    poke8(reqbuf + pos, 10); pos := pos + 1;  // \n
    
    pos := appendBulk(reqbuf, pos, "LPUSH");
    pos := appendBulk(reqbuf, pos, key);
    pos := appendBulk(reqbuf, pos, value);

    reply := sendRaw(conn, reqbuf, pos);
    munmap(reqbuf, 512);
    return reply;
}

