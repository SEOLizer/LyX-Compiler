pub fn RedisDel(conn: RedisConn, key: pchar): int64 {
    var reqbuf: int64 := mmap(0, 256, 3, 34, -1, 0);
    if (reqbuf <= 0) { return -1; }

    var pos: int64 := 0;
    poke8(reqbuf + pos, 42); pos := pos + 1;
    poke8(reqbuf + pos, 50); pos := pos + 1;  // '2'
    pos := appendCRLF(reqbuf, pos);
    var delcmd: pchar := "DEL";
    pos := appendBulk(reqbuf, pos, delcmd);
    pos := appendBulk(reqbuf, pos, key);

    // Write to socket
    if (conn.fd < 0 || conn.buf <= 0) {
        munmap(reqbuf, 256);
        return -1;
    }
    var sent: int64 := sys_write(conn.fd, reqbuf, pos);
    if (sent <= 0) {
        munmap(reqbuf, 256);
        return -1;
    }
    
    var n: int64 := sys_read(conn.fd, conn.buf, conn.buf_len - 1);
    munmap(reqbuf, 256);
    
    if (n <= 0) { return -1; }
    poke8(conn.buf + n, 0);  // null-terminate
    
    // Parse integer response: :<number>\r\n
    // Note: peek8 is broken, use peek16 workaround
    var first16: int64 := peek16(conn.buf);
    var first: int64 := first16 & 0xFF;
    if (first == 58) {  // ':' 
        return redisParseInt(conn.buf + 1);
    }
    return -1;
}

