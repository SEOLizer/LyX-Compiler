// std/db/redis.lyx - Redis Client using RESP protocol
// Native implementation using std.net.socket

unit std.db.redis;

// Use TCPConnect from std.net.socket for connection
import std.net.types;
import std.net.syscalls;
import std.string;

// ============================================================================
// Redis Connection
// ============================================================================

pub type RedisConn = struct {
    fd: int64;
    host: pchar;
    port: int64;
    timeout_ms: int64;
};

// Redis reply kinds (as constants)
pub con REDIS_REPLY_NIL: int64 := 0;
pub con REDIS_REPLY_ERROR: int64 := 1;
pub con REDIS_REPLY_STATUS: int64 := 2;
pub con REDIS_REPLY_INTEGER: int64 := 3;
pub con REDIS_REPLY_BULK: int64 := 4;
pub con REDIS_REPLY_ARRAY: int64 := 5;

pub type RedisReply = struct {
    kind: int64;
    int_val: int64;
    str_val: pchar;
    str_len: int64;
};

// ============================================================================
// RESP Protocol Helpers
// ============================================================================

// Parse integer from string
fn parseInt(s: pchar): int64 {
    var result: int64 := 0;
    var neg: bool := false;
    var i: int64 := 0;
    
    if (StrCharAt(s, 0) == 45) {  // -
        neg := true;
        i := 1;
    }
    
    while (i < StrLen(s)) {
        var c: int64 := StrCharAt(s, i);
        if (c < 48 || c > 57) { break; }
        result := result * 10 + (c - 48);
        i := i + 1;
    }
    
    if (neg) { result := -result; }
    return result;
}

// Read one line from socket using syscalls
fn readLineFD(fd: int64, buffer: pchar, max_len: int64): int64 {
    var pos: int64 := 0;
    var tmp: pchar := " ";
    
    while (pos < max_len - 1) {
        var n: int64 := sys_read(fd, tmp, 1);
        if (n <= 0) { break; }
        
        var ch: int64 := StrCharAt(tmp, 0);
        
        if (ch == 13) {  // \r - could be \r\n
            // Try to read the next byte
            var n2: int64 := sys_read(fd, tmp, 1);
            if (n2 > 0) {
                var ch2: int64 := StrCharAt(tmp, 0);
                if (ch2 == 10) {  // \n
                    break;
                }
            }
        }
        
        StrSetChar(buffer, pos, ch);
        pos := pos + 1;
    }
    
    StrSetChar(buffer, pos, 0);
    return pos;
}

// Parse RESP reply
fn parseReplyFD(fd: int64): RedisReply {
    var reply: RedisReply;
    reply.kind := REDIS_REPLY_NIL;
    reply.int_val := 0;
    reply.str_val := "";
    reply.str_len := 0;
    
    // Peek first byte
    var tmp: pchar := " ";
    var n: int64 := sys_read(fd, tmp, 1);
    if (n <= 0) { return reply; }
    
    var first: int64 := StrCharAt(tmp, 0);
    
    if (first == 43) {  // + (status reply)
        reply.kind := REDIS_REPLY_STATUS;
        var line: pchar := "                                        ";
        readLineFD(fd, line, 40);
        reply.str_val := line;
    } else if (first == 45) {  // - (error reply)
        reply.kind := REDIS_REPLY_ERROR;
        var line: pchar := "                                        ";
        readLineFD(fd, line, 40);
        reply.str_val := line;
    } else if (first == 58) {  // : (integer reply)
        reply.kind := REDIS_REPLY_INTEGER;
        var line: pchar := "                                        ";
        readLineFD(fd, line, 40);
        reply.int_val := parseInt(line);
    } else if (first == 36) {  // $ (bulk string)
        reply.kind := REDIS_REPLY_BULK;
    } else if (first == 42) {  // * (array)
        reply.kind := REDIS_REPLY_ARRAY;
    }
    
    return reply;
}

// ============================================================================
// Connection Management
// ============================================================================

// Create a new Redis connection - simplified without std.net.socket
pub fn RedisConnect(host: pchar, port: int64): RedisConn {
    var conn: RedisConn;
    conn.host := host;
    conn.port := port;
    conn.timeout_ms := 5000;
    conn.fd := -1;
    
    // Direct syscalls (same as working test)
    var fd: int64 := sys_socket(2, 1, 0);  // AF_INET, SOCK_STREAM
    if (fd < 0) { return conn; }
    
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);  // PROT_RW, MAP_ANON
    if (addr <= 0) {
        sys_close(fd);
        conn.fd := -1;
        return conn;
    }
    
    // Fill sockaddr_in
    poke8(addr, 2);  // sin_family
    // port 6379 = 0x18EB in big endian
    poke8(addr + 2, 0x18);
    poke8(addr + 3, 0xEB);
    // IP 127.0.0.1 = 0x7F000001 in network byte order
    poke8(addr + 4, 0x7F);
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    
    var result: int64 := sys_connect(fd, addr, 16);
    munmap(addr, 16);
    
    if (result < 0) {
        sys_close(fd);
        conn.fd := -1;
        return conn;
    }
    
    conn.fd := fd;
    return conn;
}
pub fn RedisClose(conn: RedisConn): void {
    if (conn.fd >= 0) {
        sys_close(conn.fd);
    }
}

// ============================================================================
// Command Sending
// ============================================================================

// Helper: append integer to buffer as string
fn appendInt(buf: pchar, pos: int64, n: int64): int64 {
    // Handle negative
    if (n < 0) {
        StrSetChar(buf, pos, 45); pos := pos + 1;  // -
        n := -n;
    }
    
    // Convert to digits (reversed)
    var digits: array[32]int64;
    var count: int64 := 0;
    
    if (n == 0) {
        digits[0] := 48;  // 0
        count := 1;
    } else {
        while (n > 0) {
            digits[count] := 48 + (n % 10);
            count := count + 1;
            n := n / 10;
        }
    }
    
    // Write in reverse order
    var i: int64 := count - 1;
    while (i >= 0) {
        StrSetChar(buf, pos, digits[i]); pos := pos + 1;
        i := i - 1;
    }
    
    return pos;
}

// Send generic command with variable args
// Returns reply from server
fn sendCommand(conn: RedisConn, cmd: pchar, argc: int64, args: pchar): RedisReply {
    // RESP format: *argc\r\n$len1\r\narg1\r\n$len2\r\narg2\r\n...
    // Buffer: * (1) + digits + \r\n + $ + digits + \r\n + arg + ...
    // Max buffer: * (1) + 10 + 2 + 1 + 10 + 2 + arglen ~= 200 bytes
    var req_buf: pchar := "                                                                                                                                ";
    var pos: int64 := 0;
    
    // Array header: *argc
    StrSetChar(req_buf, pos, 42); pos := pos + 1;  // *
    pos := appendInt(req_buf, pos, argc);
    StrSetChar(req_buf, pos, 13); pos := pos + 1;  // \r
    StrSetChar(req_buf, pos, 10); pos := pos + 1;  // \n
    
    // Command name as first argument
    var cmd_len: int64 := StrLen(cmd);
    StrSetChar(req_buf, pos, 36); pos := pos + 1;  // $
    pos := appendInt(req_buf, pos, cmd_len);
    StrSetChar(req_buf, pos, 13); pos := pos + 1;  // \r
    StrSetChar(req_buf, pos, 10); pos := pos + 1;  // \n
    
    // Copy command
    var i: int64 := 0;
    while (i < cmd_len) {
        StrSetChar(req_buf, pos, StrCharAt(cmd, i)); pos := pos + 1;
        i := i + 1;
    }
    StrSetChar(req_buf, pos, 13); pos := pos + 1;  // \r
    StrSetChar(req_buf, pos, 10); pos := pos + 1;  // \n
    
    // Additional arguments (key, value, etc.)
    var arg_idx: int64 := 0;
    while (arg_idx < argc) {
        // Get arg pointer from args array - simplified: just use args directly
        // In real impl, we'd have an array of strings
        var arg_len: int64 := StrLen(args);
        
        StrSetChar(req_buf, pos, 36); pos := pos + 1;  // $
        pos := appendInt(req_buf, pos, arg_len);
        StrSetChar(req_buf, pos, 13); pos := pos + 1;  // \r
        StrSetChar(req_buf, pos, 10); pos := pos + 1;  // \n
        
        i := 0;
        while (i < arg_len) {
            StrSetChar(req_buf, pos, StrCharAt(args, i)); pos := pos + 1;
            i := i + 1;
        }
        StrSetChar(req_buf, pos, 13); pos := pos + 1;
        StrSetChar(req_buf, pos, 10); pos := pos + 1;
        
        arg_idx := arg_idx + 1;
    }
    
    // Send command
    sys_write(conn.fd, req_buf, pos);
    
    // Parse reply
    return parseReplyFD(conn.fd);
}

// Send simple 1-arg command (like PING)
fn sendSimpleCommand(conn: RedisConn, cmd: pchar): RedisReply {
    // Simplified for PING: *1\r\n$4\r\nPING\r\n
    var req_buf: pchar := "                        ";
    var pos: int64 := 0;
    
    StrSetChar(req_buf, pos, 42); pos := pos + 1;  // *
    StrSetChar(req_buf, pos, 49); pos := pos + 1;  // 1
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    StrSetChar(req_buf, pos, 36); pos := pos + 1;  // $
    StrSetChar(req_buf, pos, 52); pos := pos + 1;  // 4
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    StrSetChar(req_buf, pos, 80); pos := pos + 1;  // P
    StrSetChar(req_buf, pos, 73); pos := pos + 1;  // I
    StrSetChar(req_buf, pos, 78); pos := pos + 1;  // N
    StrSetChar(req_buf, pos, 71); pos := pos + 1;  // G
    
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    sys_write(conn.fd, req_buf, pos);
    return parseReplyFD(conn.fd);
}

// ============================================================================
// Public API
// ============================================================================

// Ping Redis server
pub fn RedisPing(conn: RedisConn): bool {
    var reply: RedisReply := sendSimpleCommand(conn, "PING");
    return (reply.kind == REDIS_REPLY_STATUS);
}

// Get value by key
pub fn RedisGet(conn: RedisConn, key: pchar): RedisReply {
    // Send: GET key
    // RESP: *2\r\n$3\r\nGET\r\n$keylen\r\nkey\r\n
    var req_buf: pchar := "                                                                                                                                ";
    var pos: int64 := 0;
    var key_len: int64 := StrLen(key);
    
    // Array: *2
    StrSetChar(req_buf, pos, 42); pos := pos + 1;  // *
    StrSetChar(req_buf, pos, 50); pos := pos + 1;  // 2
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    // GET
    StrSetChar(req_buf, pos, 36); pos := pos + 1;  // $
    StrSetChar(req_buf, pos, 51); pos := pos + 1;  // 3
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    StrSetChar(req_buf, pos, 71); pos := pos + 1;  // G
    StrSetChar(req_buf, pos, 69); pos := pos + 1;  // E
    StrSetChar(req_buf, pos, 84); pos := pos + 1;  // T
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    // Key
    StrSetChar(req_buf, pos, 36); pos := pos + 1;  // $
    pos := appendInt(req_buf, pos, key_len);
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    var i: int64 := 0;
    while (i < key_len) {
        StrSetChar(req_buf, pos, StrCharAt(key, i)); pos := pos + 1;
        i := i + 1;
    }
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    // Send
    sys_write(conn.fd, req_buf, pos);
    
    // Parse reply - simple version for now
    return parseReplyFD(conn.fd);
}

// Set key-value pair
pub fn RedisSet(conn: RedisConn, key: pchar, value: pchar): RedisReply {
    // Send: SET key value
    var req_buf: pchar := "                                                                                                                                ";
    var pos: int64 := 0;
    var key_len: int64 := StrLen(key);
    var val_len: int64 := StrLen(value);
    
    // Array: *3
    StrSetChar(req_buf, pos, 42); pos := pos + 1;  // *
    StrSetChar(req_buf, pos, 51); pos := pos + 1;  // 3
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    // SET
    StrSetChar(req_buf, pos, 36); pos := pos + 1;  // $
    StrSetChar(req_buf, pos, 51); pos := pos + 1;  // 3
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    StrSetChar(req_buf, pos, 83); pos := pos + 1;  // S
    StrSetChar(req_buf, pos, 69); pos := pos + 1;  // E
    StrSetChar(req_buf, pos, 84); pos := pos + 1;  // T
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    // Key
    StrSetChar(req_buf, pos, 36); pos := pos + 1;  // $
    pos := appendInt(req_buf, pos, key_len);
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    var i: int64 := 0;
    while (i < key_len) {
        StrSetChar(req_buf, pos, StrCharAt(key, i)); pos := pos + 1;
        i := i + 1;
    }
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    // Value
    StrSetChar(req_buf, pos, 36); pos := pos + 1;  // $
    pos := appendInt(req_buf, pos, val_len);
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    i := 0;
    while (i < val_len) {
        StrSetChar(req_buf, pos, StrCharAt(value, i)); pos := pos + 1;
        i := i + 1;
    }
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    // Send
    sys_write(conn.fd, req_buf, pos);
    
    // Parse reply
    return parseReplyFD(conn.fd);
}

// Set with expiration (SETEX)
pub fn RedisSetEX(conn: RedisConn, key: pchar, value: pchar, ttl_sec: int64): RedisReply {
    // Send: SETEX key ttl value
    var req_buf: pchar := "                                                                                                                                ";
    var pos: int64 := 0;
    var key_len: int64 := StrLen(key);
    var val_len: int64 := StrLen(value);
    
    // Array: *4
    StrSetChar(req_buf, pos, 42); pos := pos + 1;  // *
    StrSetChar(req_buf, pos, 52); pos := pos + 1;  // 4
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    // SETEX
    StrSetChar(req_buf, pos, 36); pos := pos + 1;
    StrSetChar(req_buf, pos, 53); pos := pos + 1;  // 5
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    StrSetChar(req_buf, pos, 83); pos := pos + 1;  // S
    StrSetChar(req_buf, pos, 69); pos := pos + 1;  // E
    StrSetChar(req_buf, pos, 84); pos := pos + 1;  // T
    StrSetChar(req_buf, pos, 69); pos := pos + 1;  // E
    StrSetChar(req_buf, pos, 88); pos := pos + 1;  // X
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    // Key
    StrSetChar(req_buf, pos, 36); pos := pos + 1;
    pos := appendInt(req_buf, pos, key_len);
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    var i: int64 := 0;
    while (i < key_len) { StrSetChar(req_buf, pos, StrCharAt(key, i)); pos := pos + 1; i := i + 1; }
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    // TTL
    StrSetChar(req_buf, pos, 36); pos := pos + 1;
    pos := appendInt(req_buf, pos, ttl_sec);
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    // Value
    StrSetChar(req_buf, pos, 36); pos := pos + 1;
    pos := appendInt(req_buf, pos, val_len);
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    i := 0;
    while (i < val_len) { StrSetChar(req_buf, pos, StrCharAt(value, i)); pos := pos + 1; i := i + 1; }
    StrSetChar(req_buf, pos, 13); pos := pos + 1;
    StrSetChar(req_buf, pos, 10); pos := pos + 1;
    
    sys_write(conn.fd, req_buf, pos);
    return parseReplyFD(conn.fd);
}

