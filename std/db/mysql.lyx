// Result-Set Traversal
// ============================================================================

pub fn MySQLFetchRow(res: MySQLResult): int64 {
    if (res.rows <= 0) { return 0; }
    if (res.current_row >= res.row_count) { return 0; }

    var rowPtr: int64 := peek64(res.rows + res.current_row * 8);
    res.current_row := res.current_row + 1;
    return rowPtr;
}

pub fn MySQLDataSeek(res: MySQLResult, rowNum: int64): void {
    if (rowNum < 0 || rowNum >= res.row_count) { return; }
    res.current_row := rowNum;
}

pub fn MySQLGetFieldName(res: MySQLResult, idx: int64): pchar {
    if (idx < 0 || idx >= res.field_count) { return ""; }
    if (res.fields <= 0) { return ""; }
    return "";
}

pub fn MySQLGetFieldType(res: MySQLResult, idx: int64): int64 {
    if (idx < 0 || idx >= res.field_count) { return 0; }
    return 0;
}

pub fn MySQLGetFieldLength(res: MySQLResult, idx: int64): int64 {
    if (idx < 0 || idx >= res.field_count) { return 0; }
    return 0;
}

// Skip one length-encoded string in a row packet; returns updated position
fn skipLenEncStr(row: int64, pos: int64): int64 {
    var b: int64 := peek8(row + pos);
    pos := pos + 1;
    if (b == 0xFB) {
        return pos;
    } else if (b < 251) {
        return pos + b;
    } else if (b == 0xFC) {
        var len: int64 := peek8(row + pos) | (peek8(row + pos + 1) << 8);
        return pos + 2 + len;
    } else if (b == 0xFD) {
        var len: int64 := peek8(row + pos) | (peek8(row + pos + 1) << 8) | (peek8(row + pos + 2) << 16);
        return pos + 3 + len;
    }
    return pos;
}

// Returns column value as null-terminated pchar (valid until next GetRowStr call)
pub fn MySQLGetRowStr(res: MySQLResult, row: int64, idx: int64): pchar {
    if (row <= 0) { return ""; }
    if (idx < 0 || idx >= res.field_count) { return ""; }
    if (res.field_buf <= 0) { return ""; }

    var pos: int64 := 0;
    var col: int64 := 0;
    while (col < idx) {
        pos := skipLenEncStr(row, pos);
        col := col + 1;
    }

    var b: int64 := peek8(row + pos);
    pos := pos + 1;

    if (b == 0xFB) {
        poke8(res.field_buf, 0);
        return res.field_buf as pchar;
    }

    var vlen: int64 := 0;
    var vstart: int64 := 0;

    if (b < 251) {
        vlen := b;
        vstart := pos;
    } else if (b == 0xFC) {
        vlen := peek8(row + pos) | (peek8(row + pos + 1) << 8);
        vstart := pos + 2;
    } else if (b == 0xFD) {
        vlen := peek8(row + pos) | (peek8(row + pos + 1) << 8) | (peek8(row + pos + 2) << 16);
        vstart := pos + 3;
    } else {
        poke8(res.field_buf, 0);
        return res.field_buf as pchar;
    }

    var i: int64 := 0;
    while (i < vlen && i < 4095) {
        poke8(res.field_buf + i, peek8(row + vstart + i));
        i := i + 1;
    }
    poke8(res.field_buf + i, 0);

    return res.field_buf as pchar;
}

pub fn MySQLGetRowInt(res: MySQLResult, row: int64, idx: int64): int64 {
    var s: pchar := MySQLGetRowStr(res, row, idx);
    var val: int64 := 0;
    var i: int64 := 0;
    while (true) {
        var c: int64 := peek8(s + i);
        if (c == 0) { break; }
        val := val * 10 + (c - 48);
        i := i + 1;
    }
    return val;
}

pub fn MySQLIsNull(res: MySQLResult, row: int64, idx: int64): bool {
    if (row <= 0) { return true; }
    if (idx < 0 || idx >= res.field_count) { return true; }

    var pos: int64 := 0;
    var col: int64 := 0;
    while (col < idx) {
        pos := skipLenEncStr(row, pos);
        col := col + 1;
    }

    return peek8(row + pos) == 0xFB;
}

// ============================================================================
// Transactions
// ============================================================================

pub fn MySQLBegin(conn: MySQLConn): bool {
    var res: MySQLResult := MySQLQuery(conn, "BEGIN");
    MySQLFreeResult(res);
    if (conn.error_num != 0) { return false; }
    return true;
}

pub fn MySQLCommit(conn: MySQLConn): bool {
    var res: MySQLResult := MySQLQuery(conn, "COMMIT");
    MySQLFreeResult(res);
    if (conn.error_num != 0) { return false; }
    return true;
}

pub fn MySQLRollback(conn: MySQLConn): bool {
    var res: MySQLResult := MySQLQuery(conn, "ROLLBACK");
    MySQLFreeResult(res);
    if (conn.error_num != 0) { return false; }
    return true;
}

pub fn MySQLSetAutoCommit(conn: MySQLConn, enable: bool): bool {
    if (enable) {
        var res: MySQLResult := MySQLQuery(conn, "SET autocommit=1");
        MySQLFreeResult(res);
        if (conn.error_num != 0) { return false; }
    } else {
        var res: MySQLResult := MySQLQuery(conn, "SET autocommit=0");
        MySQLFreeResult(res);
        if (conn.error_num != 0) { return false; }
    }
    return true;
}

pub fn MySQLInTransaction(conn: MySQLConn): bool {
    return (conn.status & SERVER_STATUS_IN_TRANSACTION) != 0;
}

// ============================================================================
// Prepared Statements - Helper Functions
// ============================================================================

fn newMySQLStmt(): MySQLStmt {
    var stmt: MySQLStmt;
    stmt.conn := 0;
    stmt.stmt_id := 0;
    stmt.sql := "";
    stmt.param_count := 0;
    stmt.column_count := 0;
    stmt.params := 0;
    stmt.param_types := 0;
    stmt.param_bufs := 0;
    stmt.params_alloc := 0;
    stmt.cursor_type := 0;
    stmt.flags := 0;
    return stmt;
}

fn freeMySQLStmt(stmt: MySQLStmt): void {
    if (stmt.params > 0) { munmap(stmt.params, stmt.params_alloc * 48); }
    if (stmt.param_types > 0) { munmap(stmt.param_types, stmt.params_alloc * 8); }
    if (stmt.param_bufs > 0) { 
        var i: int64 := 0;
        while (i < stmt.param_count) {
            var bufPtr: int64 := peek64(stmt.param_bufs + i * 8);
            if (bufPtr > 0) { 
                var bufLen: int64 := peek64(stmt.params + i * 48 + 8);
                if (bufLen > 0) { munmap(bufPtr, bufLen); }
            }
            i := i + 1;
        }
        munmap(stmt.param_bufs, stmt.params_alloc * 8);
    }
    stmt.params := 0;
    stmt.param_types := 0;
    stmt.param_bufs := 0;
}

// ============================================================================
// COM_STMT_PREPARE
// ============================================================================

pub fn MySQLStmtPrepare(conn: MySQLConn, sql: pchar): MySQLStmt {
    var stmt: MySQLStmt := newMySQLStmt();
    stmt.conn := conn as int64;
    stmt.sql := sql;

    var sqlLen: int64 := StrLen(sql);
    if (sqlLen == 0) {
        conn.error_num := 2020;
        return stmt;
    }

    // Send COM_STMT_PREPARE command
    // Packet format: [0x16][stmt_data_len:3][sql]
    var cmdPacketLen: int64 := sqlLen + 4;
    var cmdPacket: int64 := mmap(0, cmdPacketLen, 3, 34, -1, 0);
    if (cmdPacket <= 0) {
        conn.error_num := 2021;
        return stmt;
    }

    poke8(cmdPacket, COM_STMT_PREPARE);
    writeInt3(cmdPacket + 1, sqlLen);

    var i: int64 := 0;
    while (i < sqlLen) {
        poke8(cmdPacket + 4 + i, peek8(sql + i));
        i := i + 1;
    }

    conn.packet_num := 0;
    var sent: bool := MySQLSendPacket(conn, cmdPacket + 1, sqlLen + 3);
    munmap(cmdPacket, cmdPacketLen);

    if (!sent) {
        conn.error_num := 2022;
        return stmt;
    }

    // Read prepared statement response
    var resp: int64 := MySQLReadPacket(conn);
    var respLen: int64 := conn.last_payload_len;

    if (resp <= 0) {
        conn.error_num := 2023;
        return stmt;
    }

    var firstByte: int64 := peek8(resp);

    // Check for error packet
    if (firstByte == 0xFF) {
        parseErrorPacket(conn, resp, respLen);
        munmap(resp, respLen + 1);
        return stmt;
    }

    // COM_STMT_PREPARE_OK packet format:
    // [0x00][stmt_id:4][columns:2][params:2][warning_count:2][status:1]

    var pos: int64 := 1;
    stmt.stmt_id := peek8(resp + pos) | (peek8(resp + pos + 1) << 8) | 
                     (peek8(resp + pos + 2) << 16) | (peek8(resp + pos + 3) << 24);
    pos := pos + 4;

    var colCnt: int64 := peek8(resp + pos) | (peek8(resp + pos + 1) << 8);
    stmt.column_count := colCnt;
    pos := pos + 2;

    var paramCnt: int64 := peek8(resp + pos) | (peek8(resp + pos + 1) << 8);
    stmt.param_count := paramCnt;
    pos := pos + 2;

    // pos + 2: warning_count, pos + 3: status (00 = OK, FE = more results)

    if (paramCnt > 0) {
        stmt.params_alloc := paramCnt;
        if (paramCnt > 0) {
            stmt.params := mmap(0, 48 * paramCnt, 3, 34, -1, 0);
            stmt.param_types := mmap(0, 8 * paramCnt, 3, 34, -1, 0);
            stmt.param_bufs := mmap(0, 8 * paramCnt, 3, 34, -1, 0);
        }

        // Read parameter definition packets
        var p: int64 := 0;
        while (p < paramCnt) {
            var paramDef: int64 := MySQLReadPacket(conn);
            var paramDefLen: int64 := conn.last_payload_len;
            if (paramDef > 0) {
                munmap(paramDef, paramDefLen + 1);
            }
            p := p + 1;
        }

        // Read EOF after parameters
        var eof1: int64 := MySQLReadPacket(conn);
        if (eof1 > 0) { munmap(eof1, conn.last_payload_len + 1); }
    }

    if (colCnt > 0) {
        // Read column definition packets
        var c: int64 := 0;
        while (c < colCnt) {
            var colDef: int64 := MySQLReadPacket(conn);
            var colDefLen: int64 := conn.last_payload_len;
            if (colDef > 0) {
                munmap(colDef, colDefLen + 1);
            }
            c := c + 1;
        }

        // Read EOF after columns
        var eof2: int64 := MySQLReadPacket(conn);
        if (eof2 > 0) { munmap(eof2, conn.last_payload_len + 1); }
    }

    munmap(resp, respLen + 1);
    return stmt;
}

// ============================================================================
// COM_STMT_EXECUTE
// ============================================================================

// Reusable packet buffer
var stmtExecBuf: int64 := 0;
var stmtExecBufSize: int64 := 0;

fn ensureStmtExecBuf(minSize: int64): int64 {
    if (stmtExecBufSize >= minSize) {
        return stmtExecBuf;
    }
    if (stmtExecBuf > 0) {
        munmap(stmtExecBuf, stmtExecBufSize);
    }
    stmtExecBufSize := minSize + 256;
    stmtExecBuf := mmap(0, stmtExecBufSize, 3, 34, -1, 0);
    return stmtExecBuf;
}

// Encode a bound parameter in binary protocol format
fn encodeStmtParamBinary(paramIdx: int64, stmt: MySQLStmt, outBuf: int64): int64 {
    if (paramIdx >= stmt.param_count) { return 0; }

    var pos: int64 := 0;
    var nullBitmap: int64 := peek64(stmt.params + paramIdx * 48 + 32);
    var isNull: bool := false;
    if (nullBitmap != 0) {
        isNull := peek8(nullBitmap + (paramIdx >> 3)) != 0;
    }

    if (isNull) {
        poke8(outBuf, 0xFB);
        return 1;
    }

    var typeCode: int64 := peek64(stmt.param_types + paramIdx * 8);
    var buffer: int64 := peek64(stmt.param_bufs + paramIdx * 8);
    var length: int64 := peek64(stmt.params + paramIdx * 48 + 16);

    // Type codes: MYSQL_TYPE_TINY=1, MYSQL_TYPE_SHORT=2, MYSQL_TYPE_LONG=3,
    // MYSQL_TYPE_LONGLONG=8, MYSQL_TYPE_FLOAT=4, MYSQL_TYPE_DOUBLE=5, MYSQL_TYPE_STRING=254, etc.

    if (typeCode == MYSQL_TYPE_TINY) {
        poke8(outBuf, peek8(buffer));
        return 1;
    } else if (typeCode == MYSQL_TYPE_SHORT) {
        var val: int64 := peek8(buffer) | (peek8(buffer + 1) << 8);
        poke8(outBuf, val & 0xFF);
        poke8(outBuf + 1, (val >> 8) & 0xFF);
        return 2;
    } else if (typeCode == MYSQL_TYPE_LONG) {
        var val: int64 := peek8(buffer) | (peek8(buffer + 1) << 8) | 
                          (peek8(buffer + 2) << 16) | (peek8(buffer + 3) << 24);
        poke8(outBuf, val & 0xFF);
        poke8(outBuf + 1, (val >> 8) & 0xFF);
        poke8(outBuf + 2, (val >> 16) & 0xFF);
        poke8(outBuf + 3, (val >> 24) & 0xFF);
        return 4;
    } else if (typeCode == MYSQL_TYPE_LONGLONG) {
        var val: int64 := peek8(buffer) | (peek8(buffer + 1) << 8) | 
                          (peek8(buffer + 2) << 16) | (peek8(buffer + 3) << 24) |
                          (peek8(buffer + 4) << 32) | (peek8(buffer + 5) << 40) |
                          (peek8(buffer + 6) << 48) | (peek8(buffer + 7) << 56);
        var j: int64 := 0;
        while (j < 8) {
            poke8(outBuf + j, (val >> (j * 8)) & 0xFF);
            j := j + 1;
        }
        return 8;
    } else if (typeCode == MYSQL_TYPE_FLOAT) {
        // Float: IEEE 754 binary32 (4 bytes)
        var fbits: int64 := peek32(buffer);
        var k: int64 := 0;
        while (k < 4) {
            poke8(outBuf + k, (fbits >> (k * 8)) & 0xFF);
            k := k + 1;
        }
        return 4;
    } else if (typeCode == MYSQL_TYPE_DOUBLE) {
        // Double: IEEE 754 binary64 (8 bytes)
        var dbitsLo: int64 := peek32(buffer);
        var dbitsHi: int64 := peek32(buffer + 4);
        var k: int64 := 0;
        while (k < 4) {
            poke8(outBuf + k, (dbitsLo >> (k * 8)) & 0xFF);
            k := k + 1;
        }
        k := 0;
        while (k < 4) {
            poke8(outBuf + 4 + k, (dbitsHi >> (k * 8)) & 0xFF);
            k := k + 1;
        }
        return 8;
    } else {
        // String/binary: length-encoded string
        // Write first byte as length
        if (length < 251) {
            poke8(outBuf, length);
            pos := 1;
        } else if (length < 0x10000) {
            poke8(outBuf, 0xFC);
            poke8(outBuf + 1, length & 0xFF);
            poke8(outBuf + 2, (length >> 8) & 0xFF);
            pos := 3;
        } else {
            poke8(outBuf, 0xFD);
            poke8(outBuf + 1, length & 0xFF);
            poke8(outBuf + 2, (length >> 8) & 0xFF);
            poke8(outBuf + 3, (length >> 16) & 0xFF);
            pos := 4;
        }

        // Copy string data
        var j: int64 := 0;
        while (j < length) {
            poke8(outBuf + pos + j, peek8(buffer + j));
            j := j + 1;
        }
        return pos + length;
    }
}

// Send COM_STMT_EXECUTE packet
pub fn MySQLStmtExecute(conn: MySQLConn, stmt: MySQLStmt): MySQLResult {
    var res: MySQLResult := newMySQLResult();

    if (stmt.stmt_id == 0 || conn.fd < 0) {
        conn.error_num := 2030;
        return res;
    }

    // Build COM_STMT_EXECUTE packet:
    // [COM_STMT_EXECUTE=0x23][stmt_id:4][flags:1][iteration_count:4][null_bitmap][param_values]
    var execBuf: int64 := ensureStmtExecBuf(32768);
    if (execBuf <= 0) {
        conn.error_num := 2031;
        return res;
    }

    var bufPos: int64 := 0;
    poke8(execBuf, COM_STMT_EXECUTE);
    bufPos := 1;

    // stmt_id (4 bytes, little-endian)
    var sid: int64 := stmt.stmt_id;
    poke8(execBuf + bufPos, sid & 0xFF);
    poke8(execBuf + bufPos + 1, (sid >> 8) & 0xFF);
    poke8(execBuf + bufPos + 2, (sid >> 16) & 0xFF);
    poke8(execBuf + bufPos + 3, (sid >> 24) & 0xFF);
    bufPos := bufPos + 4;

    // flags: 0x00 = CURSOR_TYPE_NO_CURSOR, 0x01 = CURSOR_TYPE_READ_ONLY
    poke8(execBuf + bufPos, stmt.cursor_type);
    bufPos := bufPos + 1;

    // iteration_count (4 bytes, always 1)
    poke8(execBuf + bufPos, 1);
    poke8(execBuf + bufPos + 1, 0);
    poke8(execBuf + bufPos + 2, 0);
    poke8(execBuf + bufPos + 3, 0);
    bufPos := bufPos + 4;

    // null bitmap if we have parameters
    if (stmt.param_count > 0) {
        var pcount7: int64 := stmt.param_count + 7;
        var nullBitmapSize: int64 := pcount7 / 8;
        var n: int64 := 0;
        while (n < nullBitmapSize) {
            var nullBit: int64 := 0;
            // Build null bitmap from bound parameters
            var p: int64 := 0;
            while (p < stmt.param_count) {
                var isNullFlag: bool := false;
                var nullFlagPtr: int64 := peek64(stmt.params + p * 48 + 40);
                if (nullFlagPtr != 0) {
                    isNullFlag := peek8(nullFlagPtr) != 0;
                }
                if (isNullFlag && ((p & 7) == n)) {
                    nullBit := nullBit | (1 << (p & 7));
                }
                p := p + 1;
            }
            poke8(execBuf + bufPos + n, nullBit);
            n := n + 1;
        }
        bufPos := bufPos + nullBitmapSize;
    }

    // new_params_bound_flag: 0x00 (no new parameters)
    poke8(execBuf + bufPos, 0);
    bufPos := bufPos + 1;

    // Encode each bound parameter
    var p: int64 := 0;
    while (p < stmt.param_count) {
        var encodedLen: int64 := encodeStmtParamBinary(p, stmt, execBuf + bufPos);
        bufPos := bufPos + encodedLen;
        p := p + 1;
    }

    conn.packet_num := 0;
    if (!MySQLSendPacket(conn, execBuf + 1, bufPos - 1)) {
        conn.error_num := 2032;
        return res;
    }

    // Read response
    var resp: int64 := MySQLReadPacket(conn);
    var respLen: int64 := conn.last_payload_len;

    if (resp <= 0) {
        conn.error_num := 2033;
        return res;
    }

    var firstByte: int64 := peek8(resp);

    // OK packet: query executed, maybe result set
    if (firstByte == 0x00) {
        parseOKPacket(conn, resp, respLen);
        munmap(resp, respLen + 1);
        return res;
    }

    // Error packet
    if (firstByte == 0xFF) {
        parseErrorPacket(conn, resp, respLen);
        munmap(resp, respLen + 1);
        return res;
    }

    // Result set follows (column count byte)
    var fieldCnt: int64 := peek8(resp);
    res.field_count := fieldCnt;
    conn.field_count := fieldCnt;
    munmap(resp, respLen + 1);

    if (fieldCnt == 0) {
        return res;
    }

    // Allocate field array
    res.field_alloc := fieldCnt;
    if (fieldCnt > 0) {
        res.fields := mmap(0, 112 * fieldCnt, 3, 34, -1, 0);
    }

    // Read column definitions
    var f: int64 := 0;
    while (f < fieldCnt) {
        var colDef: int64 := MySQLReadPacket(conn);
        var colDefLen: int64 := conn.last_payload_len;
        if (colDef > 0) {
            munmap(colDef, colDefLen + 1);
        }
        f := f + 1;
    }

    // Read EOF
    var eof1: int64 := MySQLReadPacket(conn);
    if (eof1 > 0) { munmap(eof1, conn.last_payload_len + 1); }

    // Read rows
    res.row_alloc := 256;
    res.rows := mmap(0, 8 * 256, 3, 34, -1, 0);
    res.row_lengths := mmap(0, 8 * 256, 3, 34, -1, 0);

    var rowCount: int64 := 0;
    var done: bool := false;
    while (!done) {
        var rowPkt: int64 := MySQLReadPacket(conn);
        var rowPktLen: int64 := conn.last_payload_len;

        if (rowPkt <= 0) {
            done := true;
            break;
        }

        var rowFirst: int64 := peek8(rowPkt);

        // EOF packet
        if (rowFirst == 0xFE && rowPktLen < 9) {
            munmap(rowPkt, rowPktLen + 1);
            done := true;
            break;
        }

        // Error packet
        if (rowFirst == 0xFF) {
            parseErrorPacket(conn, rowPkt, rowPktLen);
            munmap(rowPkt, rowPktLen + 1);
            done := true;
            break;
        }

        if (rowCount < res.row_alloc) {
            poke64(res.rows + rowCount * 8, rowPkt);
            poke64(res.row_lengths + rowCount * 8, rowPktLen);
        } else {
            munmap(rowPkt, rowPktLen + 1);
        }
        rowCount := rowCount + 1;
    }

    res.row_count := rowCount;
    return res;
}

// ============================================================================
// Parameter Binding
// ============================================================================

pub fn MySQLStmtBindParam(stmt: MySQLStmt, paramIdx: int64, typeCode: int64, buffer: int64, bufferLen: int64): bool {
    if (paramIdx < 0 || paramIdx >= stmt.param_count) {
        return false;
    }

    // Ensure parameter storage is allocated
    if (stmt.params <= 0) {
        return false;
    }

    // Store buffer pointer
    poke64(stmt.param_bufs + paramIdx * 8, buffer);
    
    // Store buffer length
    poke64(stmt.params + paramIdx * 48 + 8, bufferLen);

    // Store actual length (initially same as buffer length)
    poke64(stmt.params + paramIdx * 48 + 16, bufferLen);

    // Store type code
    poke64(stmt.param_types + paramIdx * 8, typeCode);

    return true;
}

pub fn MySQLStmtBindNull(stmt: MySQLStmt, paramIdx: int64, isNull: bool): bool {
    if (paramIdx < 0 || paramIdx >= stmt.param_count) {
        return false;
    }

    // Allocate null bitmap if not exists
    var nullBitmap: int64 := peek64(stmt.params + paramIdx * 48 + 32);
    if (nullBitmap == 0) {
        var nbmapSz: int64 := stmt.param_count + 7;
        var nbmapSz2: int64 := nbmapSz / 8;
        nullBitmap := mmap(0, nbmapSz2, 3, 34, -1, 0);
        if (nullBitmap <= 0) { return false; }
        poke64(stmt.params + paramIdx * 48 + 32, nullBitmap);
    }

    // Set null bit for this parameter
    if (isNull) {
        var current: int64 := peek8(nullBitmap + (paramIdx / 8));
        current := current | (1 << (paramIdx & 7));
        poke8(nullBitmap + (paramIdx / 8), current);
    } else {
        var current: int64 := peek8(nullBitmap + (paramIdx / 8));
        current := current & ~(1 << (paramIdx & 7));
        poke8(nullBitmap + (paramIdx / 8), current);
    }

    return true;
}

pub fn MySQLStmtBindInt(stmt: MySQLStmt, paramIdx: int64, value: int64): bool {
    if (paramIdx < 0 || paramIdx >= stmt.param_count) {
        return false;
    }

    // Allocate local buffer for integer
    var intBuf: int64 := mmap(0, 8, 3, 34, -1, 0);
    if (intBuf <= 0) { return false; }

    poke64(intBuf, value);
    poke64(stmt.param_bufs + paramIdx * 8, intBuf);
    poke64(stmt.params + paramIdx * 48 + 8, 8);
    poke64(stmt.params + paramIdx * 48 + 16, 4);
    poke64(stmt.param_types + paramIdx * 8, MYSQL_TYPE_LONGLONG);

    return true;
}

pub fn MySQLStmtBindStr(stmt: MySQLStmt, paramIdx: int64, str: pchar): bool {
    if (paramIdx < 0 || paramIdx >= stmt.param_count) {
        return false;
    }

    var strAddr: int64 := str as int64;
    var strLen: int64 := 0;
    if (strAddr != 0) {
        while (peek8(strAddr + strLen) != 0) { strLen := strLen + 1; }
    }

    var strBufLen: int64 := strLen + 1;
    var strBuf: int64 := mmap(0, strBufLen, 3, 34, -1, 0);
    if (strBuf <= 0) { return false; }

    var i: int64 := 0;
    while (i < strLen) {
        poke8(strBuf + i, peek8(strAddr + i));
        i := i + 1;
    }
    poke8(strBuf + strLen, 0);

    poke64(stmt.param_bufs + paramIdx * 8, strBuf);
    poke64(stmt.params + paramIdx * 48 + 8, strLen + 1);
    poke64(stmt.params + paramIdx * 48 + 16, strLen);
    poke64(stmt.param_types + paramIdx * 8, MYSQL_TYPE_STRING);

    return true;
}

