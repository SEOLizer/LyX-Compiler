// std/db/mysql.lyx - MySQL/MariaDB Client using MySQL Wire Protocol
//
// Supports: MySQL 5.7+, MariaDB 10.x

unit std.db.mysql;

import std.net.types;
import std.net.syscalls;
import std.string;
import std.crypto.sha1;

// ============================================================================
// Constants - Capability Flags
// ============================================================================

pub con CLIENT_LONG_PASSWORD: int64 := 1;
pub con CLIENT_FOUND_ROWS: int64 := 2;
pub con CLIENT_LONG_FLAG: int64 := 4;
pub con CLIENT_CONNECT_WITH_DB: int64 := 8;
pub con CLIENT_PROTOCOL_41: int64 := 512;
pub con CLIENT_TRANSACTIONS: int64 := 8192;
pub con CLIENT_SECURE_CONNECTION: int64 := 32768;
pub con CLIENT_MULTI_STATEMENTS: int64 := 65536;
pub con CLIENT_MULTI_RESULTS: int64 := 131072;
pub con CLIENT_PLUGIN_AUTH: int64 := 524288;

// Only flags we actually implement — CLIENT_COMPRESS (32) excluded to avoid zlib negotiation
pub con DEFAULT_CAP_FLAGS: int64 := 762383;

// ============================================================================
// Constants - Server Status
// ============================================================================

pub con SERVER_STATUS_IN_TRANSACTION: int64 := 1;
pub con SERVER_STATUS_AUTOCOMMIT: int64 := 2;

