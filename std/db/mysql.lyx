// ============================================================================
// COM_STMT_CLOSE & COM_STMT_RESET
// ============================================================================

pub fn MySQLStmtClose(stmt: MySQLStmt): void {
    if (stmt.stmt_id == 0) {
        return;
    }

    var conn: MySQLConn := stmt.conn as MySQLConn;
    if (conn.fd < 0) {
        freeMySQLStmt(stmt);
        return;
    }

    // Send COM_STMT_CLOSE command
    var closeBuf: int64 := mmap(0, 5, 3, 34, -1, 0);
    if (closeBuf <= 0) {
        freeMySQLStmt(stmt);
        return;
    }

    poke8(closeBuf, COM_STMT_CLOSE);

    // stmt_id (4 bytes)
    var sid: int64 := stmt.stmt_id;
    poke8(closeBuf + 1, sid & 0xFF);
    poke8(closeBuf + 2, (sid >> 8) & 0xFF);
    poke8(closeBuf + 3, (sid >> 16) & 0xFF);
    poke8(closeBuf + 4, (sid >> 24) & 0xFF);

    conn.packet_num := 0;
    MySQLSendPacket(conn, closeBuf + 1, 4);
    munmap(closeBuf, 5);

    freeMySQLStmt(stmt);
}

pub fn MySQLStmtReset(stmt: MySQLStmt): void {
    if (stmt.stmt_id == 0) {
        return;
    }

    var conn: MySQLConn := stmt.conn as MySQLConn;
    if (conn.fd < 0) {
        return;
    }

    // Send COM_STMT_RESET command
    var resetBuf: int64 := mmap(0, 5, 3, 34, -1, 0);
    if (resetBuf <= 0) {
        return;
    }

    poke8(resetBuf, 0x1A); // COM_STMT_RESET

    // stmt_id (4 bytes)
    var sid: int64 := stmt.stmt_id;
    poke8(resetBuf + 1, sid & 0xFF);
    poke8(resetBuf + 2, (sid >> 8) & 0xFF);
    poke8(resetBuf + 3, (sid >> 16) & 0xFF);
    poke8(resetBuf + 4, (sid >> 24) & 0xFF);

    // Send it without resetting packet_num (COM_STMT_RESET is special)
    var cmdBuf: int64 := mmap(0, 5, 3, 34, -1, 0);
    if (cmdBuf > 0) {
        var j: int64 := 0;
        while (j < 5) {
            poke8(cmdBuf + j, peek8(resetBuf + j));
            j := j + 1;
        }
        conn.packet_num := 0;
        MySQLSendPacket(conn, cmdBuf, 5);
        munmap(cmdBuf, 5);
    }
    munmap(resetBuf, 5);

    // Read response (OK or error)
    var resp: int64 := MySQLReadPacket(conn);
    if (resp > 0) {
        munmap(resp, conn.last_payload_len + 1);
    }

    // Reset parameter bindings
    if (stmt.param_count > 0 && stmt.param_bufs > 0) {
        var p: int64 := 0;
        while (p < stmt.param_count) {
            var bufPtr: int64 := peek64(stmt.param_bufs + p * 8);
            if (bufPtr > 0) {
                var bufLen: int64 := peek64(stmt.params + p * 48 + 8);
                if (bufLen > 0) { munmap(bufPtr, bufLen); }
            }
            poke64(stmt.param_bufs + p * 8, 0);
            p := p + 1;
        }
    }
}

