// ============================================================================
// Utility-Funktionen
// ============================================================================

// Größe eines Types (für API)
pub fn size_of_int64(): int64 { return 8; }
pub fn size_of_ptr(): int64 { return 8; }

// Alignment prüfen
pub fn is_aligned(ptr: Ptr): bool {
  return ptr mod ALIGNMENT == 0;
}

// ============================================================================
// Sichere Allokation mit Error-Handling
// ============================================================================

// malloc mit Prüfung (wirft bei Fehler nicht, gibt 0 zurück)
pub fn malloc_safe(size: int64): Ptr {
  var ptr: Ptr := malloc(size);
  
  if (ptr == 0) {
    return 0;
  }
  
  return ptr;
}

// Allozieren oder Panic (für kritische Pfade)
pub fn malloc_orpanic(size: int64): Ptr {
  var ptr: Ptr := malloc(size);
  
  // Bei OOM: Endlosschleife (panic)
  // In echter Implementierung: Exception werfen
  while (ptr == 0) {
    // Panic-Loop
    ptr := malloc(size);
  }
  
  return ptr;
}

