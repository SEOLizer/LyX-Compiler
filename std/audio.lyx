pub con SAMPLE_RATE_48000: int64 := 48000;
pub con SAMPLE_RATE_96000: int64 := 96000;

// ============================================================================
// Audio Types
// ============================================================================

// Audio Info structure - holds parsed audio file metadata
pub type AudioInfo = struct {
  format: int64;        // AF_PCM8, AF_PCM16, AF_MP3, etc.
  sampleRate: int64;    // samples per second (e.g., 44100)
  channels: int64;      // 1 = mono, 2 = stereo
  bitsPerSample: int64;  // 8, 16, 24, 32
  dataOffset: int64;    // byte offset to audio data
  dataSize: int64;      // size of audio data in bytes
  durationMs: int64;   // total duration in milliseconds
};

// Audio State - internal state for playback
pub type AudioState = struct {
  info: AudioInfo;      // audio file metadata
  fd: int64;           // file descriptor for audio device
  isPlaying: bool;     // true if currently playing
  isPaused: bool;    // true if paused
  position: int64;    // current position in bytes
  buffer: int64;      // decoded PCM buffer (mmap)
  bufferSize: int64;   // size of decoded buffer
};

// Audio Device configuration
pub type AudioConfig = struct {
  device: int64;        // device name (pchar, "default" or "hw:0")
  sampleRate: int64;    // desired sample rate
  channels: int64;    // desired channels
  bitsPerSample: int64; // desired bits per sample
  bufferSize: int64;   // buffer size in frames
};

// ============================================================================
// Audio File Functions
// ============================================================================

// Open and parse audio file
// Returns AudioState with filled info, or nil on error
pub fn AudioOpen(path: pchar): AudioState? {
  var state: AudioState?;
  var header: int64;
  var magic: int64;
  var i: int64;
  
  state := new AudioState;
  if (state == 0 as AudioState?) {
    return 0 as AudioState?;
  }
  
  // Initialize state
  state.fd := 0;
  state.isPlaying := false;
  state.isPaused := false;
  state.position := 0;
  state.buffer := 0;
  state.bufferSize := 0;
  
  // Open file
  // TODO: Implement file open and parse
  // - Check magic bytes (RIFF for WAV, ID3 for MP3)
  // - Parse format chunk
  // - Get data chunk offset and size
  
  return state;
}

// Close audio file and free resources
// Returns AUDIO_OK on success, or error code
pub fn AudioClose(state: AudioState?): int64 {
  if (state == 0 as AudioState?) {
    return AUDIO_ERROR;
  }
  
  // Free buffer if allocated
  if (state.buffer != 0) {
    munmap(state.buffer, state.bufferSize);
    state.buffer := 0;
  }
  
  // Free state
  dispose state;
  
  return AUDIO_OK;
}

// Get audio info from state
// Returns pointer to AudioInfo, or nil if state is invalid
pub fn AudioGetInfo(state: AudioState?): AudioInfo? {
  if (state == 0 as AudioState?) {
    return 0 as AudioInfo?;
  }
  return state.info;
}

// ============================================================================
// Playback Functions
// ============================================================================

// Start playback
// Decodes audio and sends to audio device
// Returns AUDIO_OK on success, or error code
pub fn AudioPlay(state: AudioState?): int64 {
  if (state == 0 as AudioState?) {
    return AUDIO_ERROR;
  }
  
  // TODO: Implement
  // - Decode audio data (WAV: copy, MP3: libmpg123)
  // - Open audio device (ALSA or PipeWire)
  // - Write PCM data to device
  // - Set isPlaying := true
  
  state.isPlaying := true;
  return AUDIO_OK;
}

// Pause playback
// Returns AUDIO_OK on success, or error code
pub fn AudioPause(state: AudioState?): int64 {
  if (state == 0 as AudioState?) {
    return AUDIO_ERROR;
  }
  
  if (!state.isPlaying) {
    return AUDIO_ERROR;
  }
  
  // TODO: Implement pause (suspend stream)
  state.isPaused := true;
  return AUDIO_OK;
}

// Resume playback after pause
// Returns AUDIO_OK on success, or error code
pub fn AudioResume(state: AudioState?): int64 {
  if (state == 0 as AudioState?) {
    return AUDIO_ERROR;
  }
  
  if (!state.isPaused) {
    return AUDIO_ERROR;
  }
  
  // TODO: Implement resume
  state.isPaused := false;
  return AUDIO_OK;
}

// Stop playback
// Returns AUDIO_OK on success, or error code
pub fn AudioStop(state: AudioState?): int64 {
  if (state == 0 as AudioState?) {
    return AUDIO_ERROR;
  }
  
  // TODO: Implement stop (close device, reset position)
  state.isPlaying := false;
  state.isPaused := false;
  state.position := 0;
  
  return AUDIO_OK;
}

// Get current position in milliseconds
// Returns position in ms, or -1 on error
pub fn AudioPosition(state: AudioState?): int64 {
  if (state == 0 as AudioState?) {
    return -1;
  }
  
  // Calculate position from bytes
  var bytesPerMs: int64;
  bytesPerMs := state.info.sampleRate * state.info.channels * (state.info.bitsPerSample / 8);
  bytesPerMs := bytesPerMs / 1000;
  
  if (bytesPerMs == 0) {
    return -1;
  }
  
  return state.position / bytesPerMs;
}

// Get total duration in milliseconds
// Returns duration in ms, or -1 on error
pub fn AudioDuration(state: AudioState?): int64 {
  if (state == 0 as AudioState?) {
    return -1;
  }
  
  return state.info.durationMs;
}

