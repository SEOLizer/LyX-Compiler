// ============================================================================
// Audio Constants
// ============================================================================

// Error codes
pub con AUDIO_OK: int64 := 0;
pub con AUDIO_ERROR: int64 := -1;
pub con AUDIO_EOF: int64 := -2;
pub con AUDIO_NOT_SUPPORTED: int64 := -3;
pub con AUDIO_DEVICE_OPEN: int64 := -4;
pub con AUDIO_DEVICE_WRITE: int64 := -5;

// Audio formats
pub con AF_PCM8: int64 := 1;
pub con AF_PCM16: int64 := 2;
pub con AF_PCM24: int64 := 3;
pub con AF_PCM32: int64 := 4;
pub con AF_MP3: int64 := 10;

// Audio channels
pub con CHANNEL_MONO: int64 := 1;
pub con CHANNEL_STEREO: int64 := 2;

// Sample rates (common)
pub con SAMPLE_RATE_8000: int64 := 8000;
pub con SAMPLE_RATE_11025: int64 := 11025;
pub con SAMPLE_RATE_22050: int64 := 22050;
