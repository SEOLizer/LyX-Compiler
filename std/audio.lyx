// ============================================================================
// Utility Functions
// ============================================================================

// Get human-readable error message
// Returns pointer to error string
pub fn AudioErrorString(code: int64): pchar {
  if (code == AUDIO_OK) {
    return "OK";
  } else if (code == AUDIO_ERROR) {
    return "General error";
  } else if (code == AUDIO_EOF) {
    return "End of file";
  } else if (code == AUDIO_NOT_SUPPORTED) {
    return "Format not supported";
  } else if (code == AUDIO_DEVICE_OPEN) {
    return "Cannot open device";
  } else if (code == AUDIO_DEVICE_WRITE) {
    return "Cannot write to device";
  }
  return "Unknown error";
}

// Detect audio format from file
// Returns AF_PCM8, AF_PCM16, AF_MP3, or -1 on error
pub fn AudioDetectFormat(path: pchar): int64 {
  var fd: int64;
  var buf: int64;
  var isWAV: bool;
  var isMP3: bool;
  
  fd := open(path, O_RDONLY, 0);
  if (fd < 0) {
    return -1;
  }
  
  // Read first 12 bytes for detection
  buf := mmap(0, 12, PROT_R, MAP_ANON, fd, 0);
  if (buf == 0) {
    close(fd);
    return -1;
  }
  
  // Check for "RIFF" + "WAVE" (WAV)
  // Check for "ID3" (MP3 with ID3v2)
  // Check for 0xFFE/0xFFF (MP3 without ID3)
  
  // TODO: Implement properly
  isWAV := true;  // TODO
  isMP3 := true;  // TODO
  
  munmap(buf, 12);
  close(fd);
  
  if (isWAV) {
    return AF_PCM16;  // Assume 16-bit PCM for WAV
  }
  if (isMP3) {
    return AF_MP3;
  }
  
  return -1;
}