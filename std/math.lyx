// Integer Square Root (alias for Sqrt64)
public fn IntSqrt(n: int64): int64 {
  return Sqrt64(n);
}

// Atan2 in microdegrees: returns angle in microdegrees (-180000000 to 180000000)
public fn Atan2Microdegrees(y: int64, x: int64): int64 {
  if (x == 0) {
    if (y > 0) { return 90000000; }
    if (y < 0) { return -90000000; }
    return 0;
  }
  
  var angle: int64 := 0;
  var ay: int64 := Abs64(y);
  var ax: int64 := Abs64(x);
  
  // atan(y/x) approximation
  if (ax > ay) {
    var ratio: int64 := (ay * 1000000) / ax;
    angle := (ratio * 45) / 100000;
  } else {
    var ratio: int64 := (ax * 1000000) / ay;
    angle := 90000000 - (ratio * 45) / 100000;
  }
  
  // Determine quadrant
  if (x < 0) {
    if (y >= 0) { angle := 180000000 - angle; }
    else { angle := -180000000 + angle; }
  } else {
    if (y < 0) { angle := -angle; }
  }
  
  return angle;
}

// Inverse Cosine (returns angle in microdegrees)
// Input: value in fixed-point (-1000000 to 1000000)
public fn Cos64Inverse(cos_value: int64): int64 {
  if (cos_value > 1000000) { cos_value := 1000000; }
  if (cos_value < -1000000) { cos_value := -1000000; }
  
  // Simplified: use lookup approximation
  // For small angles, acos(x) ≈ π/2 - x
  // This is a simplified implementation
  var abs_cos: int64 := Abs64(cos_value);
  
  if (abs_cos >= 999990) {
    if (cos_value >= 0) { return 0; }
    return 180000000;
  }
  
  // Binary search approximation
  var lo: int64 := 0;
  var hi: int64 := 180000000;
  
  var i: int64 := 0;
  while (i < 30) {
    var lohi: int64 := lo + hi;
    var mid: int64 := lohi / 2;
    var cos_mid: int64 := Cos64(mid);
    if (cos_mid < cos_value) {
      hi := mid;
    } else {
      lo := mid;
    }
    i := i + 1;
  }

  var lohif: int64 := lo + hi;
  return lohif / 2;
}

