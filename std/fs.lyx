// ============================================================================
// Path-Funktionen (Pfad-Manipulation)
// ============================================================================

// Interner Puffer für Path-Operationen (max 4096 Zeichen)
con PATH_BUF_SIZE: int64 := 4096;

// Normalisiert einen Pfad: ./ und ../ und // auflösen
// "/home/user/./foo/../bar//baz" -> "/home/user/bar/baz"
// Nutzt Stack-basierten Algorithmus
pub fn PathNormalize(dest: pchar, src: pchar): pchar {
  // Da Lyx keine dynamischen Arrays hat, implementieren wir eine 
  // vereinfachte Version ohne vollständigen Stack
  var result: pchar := "                                                                                ";
  var src_len: int64 := StrLen(src);
  
  // Prüfe ob absolut oder relativ
  var is_absolute: bool := false;
  if (src_len > 0 && StrCharAt(src, 0) == 47) {  // '/'
    is_absolute := true;
  }
  
  // Einfacherer Algorithmus: ein Durchgang
  var i: int64 := 0;
  var j: int64 := 0;
  var last_slash: int64 := 0;
  var comp_start: int64 := 0;
  
  if (is_absolute) {
    StrSetChar(result, 0, 47);  // '/'
    j := 1;
    last_slash := 0;
  }
  
  while (i < src_len) {
    var c: int64 := StrCharAt(src, i);
    
    if (c == 47) {  // '/'
      // Segment beenden
      var seg_len: int64 := i - comp_start;
      
      if (seg_len == 1 && StrCharAt(src, comp_start) == 46) {  // "."
        // Überspringen
        comp_start := i + 1;
        last_slash := j;
      }
      else if (seg_len == 2 && StrCharAt(src, comp_start) == 46 && StrCharAt(src, comp_start + 1) == 46) {  // ".."
        // Zurückgehen: entferne letztes Segment
        if (last_slash < j) {
          j := last_slash;
          if (j > 0 && is_absolute) {
            // Finde vorigen Slash
            var k: int64 := j - 1;
            while (k > 0) {
              if (StrCharAt(result, k) == 47) { last_slash := k; break; }
              k := k - 1;
            }
            if (k == 0) { last_slash := 0; }
          }
        }
        comp_start := i + 1;
        last_slash := j;
      }
      else if (seg_len > 0) {
        // Normales Segment: kopieren
        var k: int64 := 0;
        while (k < seg_len) {
          StrSetChar(result, j + k, StrCharAt(src, comp_start + k));
          k := k + 1;
        }
        j := j + seg_len;
        last_slash := j;
        StrSetChar(result, j, 47);  // '/'
        j := j + 1;
        comp_start := i + 1;
      }
      else {
        // Mehrere / : überspringen
        comp_start := i + 1;
      }
    }
    i := i + 1;
  }
  
  // Letztes Segment prüfen
  var seg_len: int64 := i - comp_start;
  if (seg_len == 1 && StrCharAt(src, comp_start) == 46) {
    // "." am Ende - entfernen
  }
  else if (seg_len == 2 && StrCharAt(src, comp_start) == 46 && StrCharAt(src, comp_start + 1) == 46) {
    // ".." am Ende - entferne letztes Segment
    if (last_slash < j) {
      j := last_slash;
    }
  }
  else if (seg_len > 0) {
    // Normales Segment kopieren
    var k: int64 := 0;
    while (k < seg_len) {
      StrSetChar(result, j + k, StrCharAt(src, comp_start + k));
      k := k + 1;
    }
    j := j + seg_len;
  }
  
  // Entferne trailing slash (außer bei "/")
  if (j > 1 && StrCharAt(result, j - 1) == 47) {
    j := j - 1;
  }
  
  // Null-terminator
  StrSetChar(result, j, 0);
  
  // Kopiere nach dest (bis zur Puffergröße)
  var copy_len: int64 := j;
  if (copy_len >= PATH_BUF_SIZE) { copy_len := PATH_BUF_SIZE - 1; }
  var k: int64 := 0;
  while (k < copy_len) {
    StrSetChar(dest, k, StrCharAt(result, k));
    k := k + 1;
  }
  StrSetChar(dest, copy_len, 0);
  
  return dest;
}

// Gibt den Verzeichnis-Teil eines Pfades zurück
// "/home/user/doc.lyx" -> "/home/user"
// Gibt "." zurück wenn kein Verzeichnis
pub fn PathDir(dest: pchar, path: pchar): pchar {
  var path_len: int64 := StrLen(path);
  if (path_len == 0) {
    StrSetChar(dest, 0, 46); StrSetChar(dest, 1, 0);  // "."
    return dest;
  }
  
  // Finde letzten Slash
  var last_slash: int64 := -1;
  var i: int64 := path_len - 1;
  while (i >= 0) {
    if (StrCharAt(path, i) == 47) {  // '/'
      last_slash := i;
      break;
    }
    i := i - 1;
  }
  
  if (last_slash <= 0) {
    // Kein Slash oder nur root
    StrSetChar(dest, 0, 46); StrSetChar(dest, 1, 0);  // "."
    return dest;
  }
  
  // Kopiere Verzeichnis-Teil
  var j: int64 := 0;
  while (j < last_slash) {
    StrSetChar(dest, j, StrCharAt(path, j));
    j := j + 1;
  }
  StrSetChar(dest, last_slash, 0);
  return dest;
}

// Gibt die Datei-Extension zurück (mit Punkt)
// "archive.tar.gz" -> ".gz"
// "" wenn keine Extension
pub fn PathExt(dest: pchar, path: pchar): pchar {
  var path_len: int64 := StrLen(path);
  if (path_len == 0) {
    StrSetChar(dest, 0, 0);
    return dest;
  }
  
  // Finde letzten Slash (um nur im Dateinamen zu suchen)
  var last_slash: int64 := -1;
  var i: int64 := path_len - 1;
  while (i >= 0) {
    if (StrCharAt(path, i) == 47) {  // '/'
      last_slash := i;
      break;
    }
    i := i - 1;
  }
  
  // Finde letzten Punkt nach dem letzten Slash
  var last_dot: int64 := -1;
  i := last_slash + 1;
  while (i < path_len) {
    if (StrCharAt(path, i) == 46) {  // '.'
      last_dot := i;
    }
    i := i + 1;
  }
  
  if (last_dot < 0 || last_dot == path_len - 1) {
    // Kein Punkt oder punkt am Ende
    StrSetChar(dest, 0, 0);
    return dest;
  }
  
  // Kopiere Extension (mit Punkt)
  i := last_dot;
  var j: int64 := 0;
  while (i < path_len) {
    StrSetChar(dest, j, StrCharAt(path, i));
    i := i + 1;
    j := j + 1;
  }
  StrSetChar(dest, j, 0);
  return dest;
}

// Gibt den Basis-Dateinamen ohne Extension zurück
// "/tmp/data.csv" -> "data"
// "/tmp/archive.tar.gz" -> "archive.tar"
pub fn PathBase(dest: pchar, path: pchar): pchar {
  var path_len: int64 := StrLen(path);
  if (path_len == 0) {
    StrSetChar(dest, 0, 0);
    return dest;
  }
  
  // Finde letzten Slash
  var last_slash: int64 := -1;
  var i: int64 := path_len - 1;
  while (i >= 0) {
    if (StrCharAt(path, i) == 47) {  // '/'
      last_slash := i;
      break;
    }
    i := i - 1;
  }
  
  var file_start: int64 := last_slash + 1;
  
  // Finde letzten Punkt nach dem Slash
  var last_dot: int64 := -1;
  i := file_start;
  while (i < path_len) {
    if (StrCharAt(path, i) == 46) {  // '.'
      last_dot := i;
    }
    i := i + 1;
  }
  
  var file_end: int64 := path_len;
  if (last_dot > file_start) {
    file_end := last_dot;
  }
  
  // Kopiere Basis-Name
  var j: int64 := 0;
  i := file_start;
  while (i < file_end) {
    StrSetChar(dest, j, StrCharAt(path, i));
    i := i + 1;
    j := j + 1;
  }
  StrSetChar(dest, j, 0);
  return dest;
}

// JoinHoch / Resolve: kombiniert Basis-Pfad mit relativem Pfad
// resolve("/home/user/", "../other/file.txt") -> "/home/other/file.txt"
// resolve(".", "../foo.txt") -> basierend auf current dir (nicht implementiert - gibt nur normalize zurück)
pub fn PathResolve(dest: pchar, base: pchar, relative: pchar): pchar {
  // Prüfe ob relative Pfad absolut ist
  var rel_len: int64 := StrLen(relative);
  if (rel_len > 0 && StrCharAt(relative, 0) == 47) {
    // Absolute Pfad: nur normalisieren
    return PathNormalize(dest, relative);
  }
  
  // Kombiniere base + "/" + relative
  var combined: pchar := "                                                                                ";
  var base_len: int64 := StrLen(base);
  
  var i: int64 := 0;
  var j: int64 := 0;
  
  // Base kopieren
  while (i < base_len) {
    StrSetChar(combined, j, StrCharAt(base, i));
    i := i + 1;
    j := j + 1;
  }
  
  // Slash hinzufügen wenn nötig
  if (j > 0 && StrCharAt(combined, j - 1) != 47) {
    StrSetChar(combined, j, 47);  // '/'
    j := j + 1;
  }
  
  // Relative Pfad kopieren
  i := 0;
  while (i < rel_len) {
    StrSetChar(combined, j, StrCharAt(relative, i));
    i := i + 1;
    j := j + 1;
  }
  StrSetChar(combined, j, 0);
  
  // Normalisieren
  return PathNormalize(dest, combined);
}
