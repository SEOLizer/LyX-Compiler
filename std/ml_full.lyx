// ============================================================================
// DataFrame-based Linear Regression (arbitrary data points)
// ============================================================================

// Train Linear Regression from DataFrame
// df: DataFrame pointer
// xCol: column name for feature (int64 pointer)
// yCol: column name for target (int64 pointer)
pub fn LinearRegressionFitDataFrame(df: int64, xCol: int64, yCol: int64): void {
  // Get data.core functions via extern
  // Since we can't import directly, we use the global model state
  // This function reads from DataFrame at runtime
  
  // For now, use a simplified approach: read from DataFrame via data.core
  // The DataFrame structure is:
  //   columns: int64 (pointer to Column arrays)
  //   colCount: int64
  //   rowCount: int64
  
  var rowCount: int64 := 0;
  var colCount: int64 := 0;
  
  // Read rowCount and colCount from DataFrame
  // rowCount is at offset 16 (after columns pointer)
  rowCount := peek8(df + 24);  // rowCount offset
  colCount := peek8(df + 16); // colCount offset
  
  if (rowCount < 2) {
    lr_loss := 1.0;
    lr_epochs := 0;
    return;
  }
  
  // Find column indices
  var xIdx: int64 := -1;
  var yIdx: int64 := -1;
  
  var i: int64 := 0;
  while (i < colCount) {
    var colName: int64 := peek8(peek8(df) + i * 16);
    // Simple string comparison would go here
    // For now, assume xCol is first column, yCol is second
    if (i == 0) { xIdx := i; }
    if (i == 1) { yIdx := i; }
    i := i + 1;
  }
  
  if (xIdx < 0 || yIdx < 0) {
    lr_loss := 1.0;
    return;
  }
  
  // Calculate sums for closed-form solution
  var sum_x: f64 := 0.0;
  var sum_y: f64 := 0.0;
  var sum_xy: f64 := 0.0;
  var sum_xx: f64 := 0.0;
  
  i := 0;
  while (i < rowCount) {
    // Get x and y values from DataFrame columns
    var xSeries: int64 := peek8(peek8(df) + xIdx * 16 + 8);
    var ySeries: int64 := peek8(peek8(df) + yIdx * 16 + 8);
    
    // Get f64 values from series (stored as bits at data + idx * 8)
    var xVal: f64 := peekf64(peek8(xSeries) + i * 8);
    var yVal: f64 := peekf64(peek8(ySeries) + i * 8);
    
    sum_x := sum_x + xVal;
    sum_y := sum_y + yVal;
    sum_xy := sum_xy + (xVal * yVal);
    sum_xx := sum_xx + (xVal * xVal);
    
    i := i + 1;
  }
  
  // Closed-form solution
  var n: f64 := rowCount as f64;
  var denom: f64 := (n * sum_xx) - (sum_x * sum_x);
  
  var neg0001: f64 := 0.0 - 0.0001;
  if (denom > 0.0001 || denom < neg0001) {
    var numerator: f64 := n * sum_xy - sum_x * sum_y;
    lr_weight := numerator / denom;
  } else {
    lr_weight := 0.1;
  }
  
  // Bias
  lr_bias := (sum_y - lr_weight * sum_x) / n;
  
  // Calculate MSE loss
  var loss_sum: f64 := 0.0;
  i := 0;
  while (i < rowCount) {
    var xSeries: int64 := peek8(peek8(df) + xIdx * 16 + 8);
    var ySeries: int64 := peek8(peek8(df) + yIdx * 16 + 8);
    var xVal: f64 := peekf64(peek8(xSeries) + i * 8);
    var yVal: f64 := peekf64(peek8(ySeries) + i * 8);
    
    var pred: f64 := lr_weight * xVal + lr_bias;
    var diff: f64 := pred - yVal;
    loss_sum := loss_sum + (diff * diff);
    
    i := i + 1;
  }
  
  lr_loss := loss_sum / n;
  lr_epochs := 1;
}

