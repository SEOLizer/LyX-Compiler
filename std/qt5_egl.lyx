// ============================================================================
// EGL Types
// ============================================================================

// EGL Display (opaque)
pub type EGLDisplay = struct {
  display: int64;       // native display handle
  initialized: int64;   // 1 if eglInitialize succeeded
  versionMajor: int64;
  versionMinor: int64;
};

// EGL Context (opaque)
pub type EGLContext = struct {
  ctx: int64;           // EGL context handle
  valid: int64;
};

// EGL Surface (opaque)
pub type EGLSurface = struct {
  surface: int64;       // EGL surface handle
  valid: int64;
};

// EGL Config (opaque)
pub type EGLConfig = struct {
  config: int64;
};

// ============================================================================
// High-level API
// ============================================================================

// Get default EGL display for Wayland/X11
pub fn EGLGetDisplay(): EGLDisplay {
  var disp: EGLDisplay;
  var major: int64;
  var minor: int64;
  
  disp.display := eglGetDisplay(EGL_DEFAULT_DISPLAY);
  disp.initialized := 0;
  disp.versionMajor := 0;
  disp.versionMinor := 0;
  
  if (disp.display == 0) {
    return disp;
  }
  
  // Initialize EGL
  if (eglInitialize(disp.display, cast<int64>(cast<int64>(0)), cast<int64>(cast<int64>(0))) == EGL_FALSE) {
    return disp;
  }
  
  disp.initialized := 1;
  return disp;
}

// Get EGL version
pub fn EGLGetVersion(disp: EGLDisplay): int64 {
  if (disp.initialized == 0) {
    return 0;
  }
  return eglQueryString(disp.display, 12352);  // EGL_VERSION
}

// Get EGL vendor
pub fn EGLGetVendor(disp: EGLDisplay): int64 {
  if (disp.initialized == 0) {
    return 0;
  }
  return eglQueryString(disp.display, 12353);  // EGL_VENDOR
}

// Get EGL extensions
pub fn EGLGetExtensions(disp: EGLDisplay): int64 {
  if (disp.initialized == 0) {
    return 0;
  }
  return eglQueryString(disp.display, 12354);  // EGL_EXTENSIONS
}

// Bind OpenGL API
pub fn EGLBindOpenGL(disp: EGLDisplay): int64 {
  if (disp.initialized == 0) {
    return EGL_FALSE;
  }
  return eglBindAPI(EGL_OPENGL_API);
}

// Bind OpenGL ES API
pub fn EGLBindOpenGLES(disp: EGLDisplay): int64 {
  if (disp.initialized == 0) {
    return EGL_FALSE;
  }
  return eglBindAPI(EGL_OPENGL_ES_API);
}

// Create OpenGL context
pub fn EGLCreateContext(disp: EGLDisplay, config: EGLConfig, shareCtx: EGLContext): EGLContext {
  var ctx: EGLContext;
  
  ctx.ctx := 0;
  ctx.valid := 0;
  
  if (disp.initialized == 0) {
    return ctx;
  }
  
  // Create context with OpenGL API
  ctx.ctx := eglCreateContext(disp.display, config.config, shareCtx.ctx, 0);
  if (ctx.ctx == 0) {
    return ctx;
  }
  
  ctx.valid := 1;
  return ctx;
}

// Create window surface (requires native window handle)
pub fn EGLCreateWindowSurface(disp: EGLDisplay, config: EGLConfig, window: int64): EGLSurface {
  var surf: EGLSurface;
  
  surf.surface := 0;
  surf.valid := 0;
  
  if (disp.initialized == 0) {
    return surf;
  }
  
  surf.surface := eglCreateWindowSurface(disp.display, config.config, window, 0);
  if (surf.surface == 0) {
    return surf;
  }
  
  surf.valid := 1;
  return surf;
}

// Make context current
pub fn EGLMakeCurrent(disp: EGLDisplay, surf: EGLSurface, ctx: EGLContext): int64 {
  if (disp.initialized == 0) {
    return EGL_FALSE;
  }
  
  return eglMakeCurrent(disp.display, surf.surface, surf.surface, ctx.ctx);
}

// Swap buffers (present frame)
pub fn EGLSwapBuffers(disp: EGLDisplay, surf: EGLSurface): int64 {
  if (disp.initialized == 0) {
    return EGL_FALSE;
  }
  
  return eglSwapBuffers(disp.display, surf.surface);
}

// Set swap interval (vsync)
pub fn EGLSetSwapInterval(disp: EGLDisplay, interval: int64): int64 {
  if (disp.initialized == 0) {
    return EGL_FALSE;
  }
  
  return eglSwapInterval(disp.display, interval);
}

// Destroy context
pub fn EGLDestroyContext(disp: EGLDisplay, ctx: EGLContext) {
  if (disp.initialized == 0) {
    return;
  }
  
  if (ctx.ctx != 0) {
    eglDestroyContext(disp.display, ctx.ctx);
  }
  
  ctx.valid := 0;
}

// Destroy surface
pub fn EGLDestroySurface(disp: EGLDisplay, surf: EGLSurface) {
  if (disp.initialized == 0) {
    return;
  }
  
  if (surf.surface != 0) {
    eglDestroySurface(disp.display, surf.surface);
  }
  
  surf.valid := 0;
}

// Terminate EGL
pub fn EGLTerminate(disp: EGLDisplay) {
  if (disp.initialized == 0) {
    return;
  }
  
  eglTerminate(disp.display);
  disp.initialized := 0;
}

// ============================================================================
// Note
// ============================================================================
//
// EGL provides platform-abstracted graphics context creation for:
// - Wayland (wl_display)
// - X11 (X11 native display)
// - DRM/GBM
//
// Usage pattern:
// 1. EGLGetDisplay() - get default display
// 2. EGLBindOpenGL() or EGLBindOpenGLES() - choose API
// 3. eglChooseConfig() - select framebuffer config
// 4. EGLCreateContext() - create GL context
// 5. EGLCreateWindowSurface() - create window surface (needs native window)
// 6. EGLMakeCurrent() - bind context to thread
// 7. gl* functions - OpenGL rendering
// 8. EGLSwapBuffers() - present
//
// For Wayland integration, you'll need Wayland FFI bindings (std/qt5_wayland.lyx)