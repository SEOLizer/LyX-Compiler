// Lyx Qt5 EGL Library - EGL FFI Bindings
// Provides EGL 1.4+ function bindings for Wayland/OpenGL ES context
//
// Usage:
//   import std.qt5_egl;
//   var disp := EGLGetDisplay(EGL_DEFAULT_DISPLAY);
//   EGLInitialize(disp, major, minor);
//   // Create OpenGL ES context and surface

