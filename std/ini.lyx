// ============================================================================
// Helper Functions
// ============================================================================

// Skip whitespace
fn skipWhitespace(s: pchar, pos: int64): int64 {
    while (StrCharAt(s, pos) == 32 || StrCharAt(s, pos) == 9) {
        pos := pos + 1;
    }
    return pos;
}

// Check if line is a comment
fn isComment(s: pchar, pos: int64): bool {
    var c: int64 := StrCharAt(s, pos);
    return c == 35 || c == 59;
}

// Check if line starts a section
fn isSectionStart(s: pchar, pos: int64): bool {
    return StrCharAt(s, pos) == 91;
}

// Find end of line
fn findLineEnd(s: pchar, pos: int64): int64 {
    while (StrCharAt(s, pos) != 0 &&
           StrCharAt(s, pos) != 10 &&
           StrCharAt(s, pos) != 13) {
        pos := pos + 1;
    }
    return pos;
}

// Find key-value separator
fn findSeparator(s: pchar): int64 {
    var i: int64 := 0;
    while (StrCharAt(s, i) != 0) {
        if (StrCharAt(s, i) == 61) {
            return i;
        }
        i := i + 1;
    }
    return -1;
}

// ============================================================================
// Parsing
// ============================================================================

// Parse INI from string
// Returns non-zero handle on success, 0 on error
pub fn ParseString(input: pchar): int64 {
    if (input == 0) {
        return 0;
    }
    
    // Basic validation - check for balanced brackets
    var pos: int64 := 0;
    var bracket_count: int64 := 0;
    while (StrCharAt(input, pos) != 0) {
        if (StrCharAt(input, pos) == 91) { bracket_count := bracket_count + 1; }
        if (StrCharAt(input, pos) == 93) { bracket_count := bracket_count - 1; }
        pos := pos + 1;
    }
    
    if (bracket_count != 0) {
        return 0;
    }
    
    return 1;
}

