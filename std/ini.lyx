// Skip whitespace (spaces and tabs)
fn skipWhitespace(s: pchar, pos: int64): int64 {
    while (StrCharAt(s, pos) == 32 || StrCharAt(s, pos) == 9) {
        pos := pos + 1;
    }
    return pos;
}

// Check if character is a comment marker
fn isCommentChar(c: int64): bool {
    return c == 35 || c == 59;  // '#' or ';'
}

// Find end of line (handle \n, \r, \r\n)
fn findLineEnd(s: pchar, pos: int64): int64 {
    while (StrCharAt(s, pos) != 0 &&
           StrCharAt(s, pos) != 10 &&
           StrCharAt(s, pos) != 13) {
        pos := pos + 1;
    }
    return pos;
}

// Skip to next line
fn skipToNextLine(s: pchar, pos: int64): int64 {
    pos := findLineEnd(s, pos);
    while (StrCharAt(s, pos) == 10 || StrCharAt(s, pos) == 13) {
        pos := pos + 1;
    }
    return pos;
}

// Trim whitespace from both ends of string
fn trimString(s: pchar, s_len: int64, output: pchar): int64 {
    var start: int64 := 0;
    while (start < s_len && (StrCharAt(s, start) == 32 || StrCharAt(s, start) == 9)) {
        start := start + 1;
    }
    
    var end: int64 := s_len;
    while (end > start && (StrCharAt(s, end - 1) == 32 || StrCharAt(s, end - 1) == 9)) {
        end := end - 1;
    }
    
    var i: int64 := 0;
    while (start + i < end) {
        StrSetChar(output, i, StrCharAt(s, start + i));
        i := i + 1;
    }
    StrSetChar(output, i, 0);
    
    return i;
}

// Find key-value separator '='
fn findKeyValueSeparator(s: pchar, start: int64, end: int64): int64 {
    var i: int64 := start;
    while (i < end) {
        if (StrCharAt(s, i) == 61) {  // '='
            return i;
        }
        // Stop at comment
        if (StrCharAt(s, i) == 35 || StrCharAt(s, i) == 59) {
            return -1;
        }
        i := i + 1;
    }
    return -1;
}

