// Escape special characters in value
pub fn EscapeValue(input: pchar, output: pchar): int64 {
    if (input == 0 || output == 0) { return 0; }
    
    var in_pos: int64 := 0;
    var out_pos: int64 := 0;
    
    while (StrCharAt(input, in_pos) != 0) {
        var c: int64 := StrCharAt(input, in_pos);
        
        if (c == 10) {  // newline -> \n
            StrSetChar(output, out_pos, 92); out_pos := out_pos + 1;
            StrSetChar(output, out_pos, 110); out_pos := out_pos + 1;
        } else if (c == 13) {  // carriage return -> \r
            StrSetChar(output, out_pos, 92); out_pos := out_pos + 1;
            StrSetChar(output, out_pos, 114); out_pos := out_pos + 1;
        } else if (c == 92) {  // backslash -> \\
            StrSetChar(output, out_pos, 92); out_pos := out_pos + 1;
            StrSetChar(output, out_pos, 92); out_pos := out_pos + 1;
        } else {
            StrSetChar(output, out_pos, c); out_pos := out_pos + 1;
        }
        
        in_pos := in_pos + 1;
    }
    
    StrSetChar(output, out_pos, 0);
    return out_pos;
}

// Unescape special characters in value
pub fn UnescapeValue(input: pchar, output: pchar): int64 {
    if (input == 0 || output == 0) { return 0; }
    
    var in_pos: int64 := 0;
    var out_pos: int64 := 0;
    
    while (StrCharAt(input, in_pos) != 0) {
        var c: int64 := StrCharAt(input, in_pos);
        
        if (c == 92 && StrCharAt(input, in_pos + 1) == 110) {  // \n
            StrSetChar(output, out_pos, 10); out_pos := out_pos + 1;
            in_pos := in_pos + 2;
        } else if (c == 92 && StrCharAt(input, in_pos + 1) == 114) {  // \r
            StrSetChar(output, out_pos, 13); out_pos := out_pos + 1;
            in_pos := in_pos + 2;
        } else if (c == 92 && StrCharAt(input, in_pos + 1) == 92) {  // \\
            StrSetChar(output, out_pos, 92); out_pos := out_pos + 1;
            in_pos := in_pos + 2;
        } else {
            StrSetChar(output, out_pos, c); out_pos := out_pos + 1;
            in_pos := in_pos + 1;
        }
    }
    
    StrSetChar(output, out_pos, 0);
    return out_pos;
}

// ============================================================================
// Validation Functions
// ============================================================================

// Validate section name (alphanumeric, underscore, hyphen)
pub fn IsValidSectionName(name: pchar): bool {
    if (name == 0) { return false; }
    
    var i: int64 := 0;
    while (StrCharAt(name, i) != 0) {
        var c: int64 := StrCharAt(name, i);
        var valid: bool := false;
        
        if (c >= 65 && c <= 90) { valid := true; }      // A-Z
        if (c >= 97 && c <= 122) { valid := true; }     // a-z
        if (c >= 48 && c <= 57) { valid := true; }      // 0-9
        if (c == 95 || c == 45) { valid := true; }      // _ -
        
        if not valid { return false; }
        i := i + 1;
    }
    
    return i > 0;
}

// Validate key name (no whitespace, no '=')
pub fn IsValidKeyName(key: pchar): bool {
    if (key == 0) { return false; }
    
    var i: int64 := 0;
    while (StrCharAt(key, i) != 0) {
        var c: int64 := StrCharAt(key, i);
        if (c == 32 || c == 9 || c == 61) { return false; }  // space, tab, =
        i := i + 1;
    }
    
    return i > 0;
}

// ============================================================================
// INI String Building Helpers
// ============================================================================

// Build key=value line
pub fn BuildKeyValueLine(key: pchar, value: pchar, output: pchar): int64 {
    if (key == 0 || output == 0) { return 0; }
    
    var pos: int64 := 0;
    var i: int64 := 0;
    
    // Write key
    while (StrCharAt(key, i) != 0) {
        StrSetChar(output, pos, StrCharAt(key, i));
        pos := pos + 1;
        i := i + 1;
    }
    
    // Write '='
    StrSetChar(output, pos, 61); pos := pos + 1;
    
    // Write value
    i := 0;
    if (value != 0) {
        while (StrCharAt(value, i) != 0) {
            StrSetChar(output, pos, StrCharAt(value, i));
            pos := pos + 1;
            i := i + 1;
        }
    }
    
    StrSetChar(output, pos, 0);
    return pos;
}

// Build section header
pub fn BuildSectionHeader(section: pchar, output: pchar): int64 {
    if (section == 0 || output == 0) { return 0; }
    
    var pos: int64 := 0;
    var i: int64 := 0;
    
    StrSetChar(output, pos, 91); pos := pos + 1;  // '['
    
    while (StrCharAt(section, i) != 0) {
        StrSetChar(output, pos, StrCharAt(section, i));
        pos := pos + 1;
        i := i + 1;
    }
    
    StrSetChar(output, pos, 93); pos := pos + 1;  // ']'
    StrSetChar(output, pos, 0);
    
    return pos;
}

// ============================================================================
// Parse Helpers
// ============================================================================

// Parse a line and extract key and value
// Returns 1 if successful, 0 if not a valid key-value line
pub fn ParseLine(line: pchar, line_len: int64, key_out: pchar, value_out: pchar): bool {
    if (line == 0 || line_len == 0) { return false; }
    
    // Find separator
    var sep_pos: int64 := -1;
    var i: int64 := 0;
    while (i < line_len) {
        if (StrCharAt(line, i) == 61) {  // '='
            sep_pos := i;
            break;
        }
        // Stop at comment
        if (StrCharAt(line, i) == 35 || StrCharAt(line, i) == 59) {
            break;
        }
        i := i + 1;
    }
    
    if (sep_pos < 0) { return false; }
    
    // Extract key (trim)
    var key_len: int64 := trimString(line, sep_pos, key_out);
    if (key_len == 0) { return false; }
    
    // Extract value (trim)
    var value_start: int64 := sep_pos + 1;
    var value_len: int64 := trimString(line + value_start, line_len - value_start, value_out);
    
    return true;
}

// Check if line is a section header
pub fn IsSectionLine(line: pchar, line_len: int64): bool {
    if (line == 0 || line_len < 3) { return false; }
    
    // Must start with '['
    if (StrCharAt(line, 0) != 91) { return false; }
    
    // Must end with ']'
    if (StrCharAt(line, line_len - 1) != 93) { return false; }
    
    return true;
}

// Extract section name from section line
pub fn ParseSectionLine(line: pchar, line_len: int64, output: pchar): int64 {
    if (line == 0 || line_len < 3) { return 0; }
    
    var start: int64 := 1;
    var end: int64 := line_len - 1;
    
    // Trim whitespace
    while (start < end && (StrCharAt(line, start) == 32 || StrCharAt(line, start) == 9)) {
        start := start + 1;
    }
    while (end > start && (StrCharAt(line, end - 1) == 32 || StrCharAt(line, end - 1) == 9)) {
        end := end - 1;
    }
    
    // Copy section name
    var i: int64 := 0;
    while (start + i < end) {
        StrSetChar(output, i, StrCharAt(line, start + i));
        i := i + 1;
    }
    StrSetChar(output, i, 0);
    
    return i;
}