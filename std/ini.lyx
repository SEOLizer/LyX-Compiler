// Get integer value
pub fn GetInt(doc: int64, section: pchar, key: pchar, default_val: int64): int64 {
    if (doc == 0 || section == 0 || key == 0) {
        return default_val;
    }
    
    var val: pchar := GetString(doc, section, key, "");
    if (val == 0 || StrCharAt(val, 0) == 0) {
        return default_val;
    }
    
    // Parse integer from string
    var result: int64 := 0;
    var neg: bool := false;
    var pos: int64 := 0;
    
    if (StrCharAt(val, 0) == 45) {  // '-'
        neg := true;
        pos := pos + 1;
    }
    
    while (pos < MAX_VALUE_LENGTH && StrCharAt(val, pos) != 0) {
        var c: int64 := StrCharAt(val, pos);
        if (c >= 48 && c <= 57) {
            result := result * 10 + (c - 48);
        }
        pos := pos + 1;
    }
    
    if (neg) { result := -result; }
    return result;
}

// Get boolean value
pub fn GetBool(doc: int64, section: pchar, key: pchar, default_val: bool): bool {
    if (doc == 0 || section == 0 || key == 0) {
        return default_val;
    }
    
    var val: pchar := GetString(doc, section, key, "");
    if (val == 0 || StrCharAt(val, 0) == 0) {
        return default_val;
    }
    
    // Check for true values (case insensitive would be better)
    var first: int64 := StrCharAt(val, 0);
    if (first == 116 || first == 84 || first == 121 || first == 89 || first == 111 || first == 49) {
        return true;
    }
    
    return false;
}

