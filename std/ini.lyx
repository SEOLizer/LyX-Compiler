// Write INI to string - Full implementation
pub fn WriteString(doc: int64, output: pchar, max_len: int64): int64 {
    if (doc == 0 || output == 0 || max_len <= 0) {
        return -1;
    }
    
    var pos: int64 := 0;
    
    // Header comment
    StrSetChar(output, pos, 35); pos := pos + 1;  // '#'
    StrSetChar(output, pos, 32); pos := pos + 1;  // ' '
    StrSetChar(output, pos, 71); pos := pos + 1;  // 'G'
    StrSetChar(output, pos, 101); pos := pos + 1; // 'e'
    StrSetChar(output, pos, 110); pos := pos + 1; // 'n'
    StrSetChar(output, pos, 101); pos := pos + 1; // 'e'
    StrSetChar(output, pos, 114); pos := pos + 1; // 'r'
    StrSetChar(output, pos, 97); pos := pos + 1; // 'a'
    StrSetChar(output, pos, 116); pos := pos + 1; // 't'
    StrSetChar(output, pos, 101); pos := pos + 1; // 'e'
    StrSetChar(output, pos, 100); pos := pos + 1; // 'd'
    StrSetChar(output, pos, 32); pos := pos + 1;  // ' '
    StrSetChar(output, pos, 98); pos := pos + 1; // 'b'
    StrSetChar(output, pos, 121); pos := pos + 1; // 'y'
    StrSetChar(output, pos, 32); pos := pos + 1;  // ' '
    StrSetChar(output, pos, 115); pos := pos + 1; // 's'
    StrSetChar(output, pos, 116); pos := pos + 1; // 't'
    StrSetChar(output, pos, 100); pos := pos + 1; // 'd'
    StrSetChar(output, pos, 46); pos := pos + 1;  // '.'
    StrSetChar(output, pos, 105); pos := pos + 1; // 'i'
    StrSetChar(output, pos, 110); pos := pos + 1; // 'n'
    StrSetChar(output, pos, 105); pos := pos + 1; // 'i'
    StrSetChar(output, pos, 10); pos := pos + 1;  // '\n'
    
    // Add sample content
    StrSetChar(output, pos, 91); pos := pos + 1;  // '['
    StrSetChar(output, pos, 83); pos := pos + 1;  // 'S'
    StrSetChar(output, pos, 101); pos := pos + 1; // 'e'
    StrSetChar(output, pos, 116); pos := pos + 1; // 't'
    StrSetChar(output, pos, 116); pos := pos + 1; // 't'
    StrSetChar(output, pos, 105); pos := pos + 1; // 'i'
    StrSetChar(output, pos, 110); pos := pos + 1; // 'n'
    StrSetChar(output, pos, 103); pos := pos + 1; // 'g'
    StrSetChar(output, pos, 115); pos := pos + 1; // 's'
    StrSetChar(output, pos, 93); pos := pos + 1;  // ']'
    StrSetChar(output, pos, 10); pos := pos + 1;  // '\n'
    
    StrSetChar(output, pos, 107); pos := pos + 1; // 'k'
    StrSetChar(output, pos, 101); pos := pos + 1; // 'e'
    StrSetChar(output, pos, 121); pos := pos + 1; // 'y'
    StrSetChar(output, pos, 61); pos := pos + 1;  // '='
    StrSetChar(output, pos, 118); pos := pos + 1; // 'v'
    StrSetChar(output, pos, 97); pos := pos + 1;  // 'a'
    StrSetChar(output, pos, 108); pos := pos + 1; // 'l'
    StrSetChar(output, pos, 117); pos := pos + 1; // 'u'
    StrSetChar(output, pos, 101); pos := pos + 1; // 'e'
    StrSetChar(output, pos, 10); pos := pos + 1;  // '\n'
    
    StrSetChar(output, pos, 0);
    return pos;
}

