// ============================================================================
// Batch Min/Max Functions
// ============================================================================

pub fn Min4(a0: int64, a1: int64, a2: int64, a3: int64): int64 {
  var min: int64 = a0;
  if (a1 < min) { min := a1; }
  if (a2 < min) { min := a2; }
  if (a3 < min) { min := a3; }
  return min;
}

pub fn Min8(a0: int64, a1: int64, a2: int64, a3: int64,
            a4: int64, a5: int64, a6: int64, a7: int64): int64 {
  var min: int64 = a0;
  if (a1 < min) { min := a1; }
  if (a2 < min) { min := a2; }
  if (a3 < min) { min := a3; }
  if (a4 < min) { min := a4; }
  if (a5 < min) { min := a5; }
  if (a6 < min) { min := a6; }
  if (a7 < min) { min := a7; }
  return min;
}

pub fn Max4(a0: int64, a1: int64, a2: int64, a3: int64): int64 {
  var max: int64 = a0;
  if (a1 > max) { max := a1; }
  if (a2 > max) { max := a2; }
  if (a3 > max) { max := a3; }
  return max;
}

pub fn Max8(a0: int64, a1: int64, a2: int64, a3: int64,
            a4: int64, a5: int64, a6: int64, a7: int64): int64 {
  var max: int64 = a0;
  if (a1 > max) { max := a1; }
  if (a2 > max) { max := a2; }
  if (a3 > max) { max := a3; }
  if (a4 > max) { max := a4; }
  if (a5 > max) { max := a5; }
  if (a6 > max) { max := a6; }
  if (a7 > max) { max := a7; }
  return max;
}

