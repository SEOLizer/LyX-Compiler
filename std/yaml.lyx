// ============================================================================
// Validation
// ============================================================================

// Check if string is valid YAML identifier
pub fn IsValidKey(s: pchar): bool {
    if (s == 0) { return false; }
    
    var i: int64 := 0;
    while (StrCharAt(s, i) != 0) {
        var c: int64 := StrCharAt(s, i);
        
        // Allow: alphanumeric, underscore, hyphen
        var valid: bool := false;
        if (c >= 65 && c <= 90) { valid := true; }      // A-Z
        if (c >= 97 && c <= 122) { valid := true; }     // a-z
        if (c >= 48 && c <= 57) { valid := true; }      // 0-9
        if (c == 95 || c == 45) { valid := true; }      // _ -
        
        if not valid { return false; }
        i := i + 1;
    }
    
    return true;
}

// Check if string needs quoting in YAML
pub fn NeedsQuoting(s: pchar): bool {
    if (s == 0) { return true; }
    
    var i: int64 := 0;
    while (StrCharAt(s, i) != 0) {
        var c: int64 := StrCharAt(s, i);
        
        // Needs quoting if contains: colon, hash, special chars
        if (c == 58 || c == 35 || c == 91 || c == 93 || c == 123 || c == 125 ||
            c == 44 || c == 38 || c == 42 || c == 33 || c == 124) {
            return true;
        }
        
        // Needs quoting if starts with special characters
        if (i == 0 && (c == 45 || c == 46 || c == 39 || c == 34 || c == 64 || c == 33)) {
            return true;
        }
        
        i := i + 1;
    }
    
    return false;
}