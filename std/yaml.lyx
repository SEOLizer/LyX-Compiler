// ============================================================================
// YAML String Helpers
// ============================================================================

// Escape string for YAML
pub fn EscapeString(input: pchar, output: pchar): int64 {
    if (input == 0 || output == 0) { return 0; }
    
    var in_pos: int64 := 0;
    var out_pos: int64 := 0;
    
    while (StrCharAt(input, in_pos) != 0) {
        var c: int64 := StrCharAt(input, in_pos);
        
        // Handle special characters that need escaping in YAML
        if (c == 92) {  // backslash
            StrSetChar(output, out_pos, 92); out_pos := out_pos + 1;
            StrSetChar(output, out_pos, 92); out_pos := out_pos + 1;
        } else if (c == 34) {  // double quote
            StrSetChar(output, out_pos, 92); out_pos := out_pos + 1;
            StrSetChar(output, out_pos, 34); out_pos := out_pos + 1;
        } else if (c == 10) {  // newline
            StrSetChar(output, out_pos, 92); out_pos := out_pos + 1;
            StrSetChar(output, out_pos, 110); out_pos := out_pos + 1;
        } else if (c == 13) {  // carriage return
            StrSetChar(output, out_pos, 92); out_pos := out_pos + 1;
            StrSetChar(output, out_pos, 114); out_pos := out_pos + 1;
        } else if (c == 9) {  // tab
            StrSetChar(output, out_pos, 92); out_pos := out_pos + 1;
            StrSetChar(output, out_pos, 116); out_pos := out_pos + 1;
        } else {
            StrSetChar(output, out_pos, c); out_pos := out_pos + 1;
        }
        
        in_pos := in_pos + 1;
    }
    
    StrSetChar(output, out_pos, 0);
    return out_pos;
}

// Unescape YAML string
pub fn UnescapeString(input: pchar, output: pchar): int64 {
    if (input == 0 || output == 0) { return 0; }
    
    var in_pos: int64 := 0;
    var out_pos: int64 := 0;
    
    while (StrCharAt(input, in_pos) != 0) {
        var c: int64 := StrCharAt(input, in_pos);
        
        if (c == 92) {  // escape sequence
            var next: int64 := StrCharAt(input, in_pos + 1);
            if (next == 92) {
                StrSetChar(output, out_pos, 92); out_pos := out_pos + 1;
            } else if (next == 34) {
                StrSetChar(output, out_pos, 34); out_pos := out_pos + 1;
            } else if (next == 110) {
                StrSetChar(output, out_pos, 10); out_pos := out_pos + 1;
            } else if (next == 114) {
                StrSetChar(output, out_pos, 13); out_pos := out_pos + 1;
            } else if (next == 116) {
                StrSetChar(output, out_pos, 9); out_pos := out_pos + 1;
            }
            in_pos := in_pos + 2;
        } else {
            StrSetChar(output, out_pos, c); out_pos := out_pos + 1;
            in_pos := in_pos + 1;
        }
    }
    
    StrSetChar(output, out_pos, 0);
    return out_pos;
}

// ============================================================================
// Type Conversion
// ============================================================================

// Parse YAML string to int64
pub fn ParseYamlInt(s: pchar): int64 {
    if (s == 0) { return 0; }
    
    var i: int64 := 0;
    var negative: bool := false;
    var value: int64 := 0;
    
    // Handle sign
    if (StrCharAt(s, 0) == 45) {  // '-'
        negative := true;
        i := i + 1;
    }
    
    // Parse digits
    while (isDigit(StrCharAt(s, i))) {
        value := value * 10 + (StrCharAt(s, i) - 48);
        i := i + 1;
    }
    
    if (negative) { value := -value; }
    return value;
}

// Parse YAML string to bool
pub fn ParseYamlBool(s: pchar): bool {
    if (s == 0) { return false; }
    
    var first: int64 := StrCharAt(s, 0);
    
    // true values: true, yes, on, 1
    if (first == 116 || first == 84 || first == 121 || first == 89 || first == 111 || first == 49) {
        return true;
    }
    
    // false values: false, no, off, 0
    return false;
}

