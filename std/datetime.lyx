// Format date only
pub fn FormatDate(year: int64, month: int64, day: int64, output: pchar): int64 {
    // Output: YYYY-MM-DD
    StrSetChar(output, 0, (year / 1000) + 48);  // Thousands
    StrSetChar(output, 1, ((year / 100) % 10) + 48);
    StrSetChar(output, 2, ((year / 10) % 10) + 48);
    StrSetChar(output, 3, (year % 10) + 48);
    StrSetChar(output, 4, 45);  // '-'
    StrSetChar(output, 5, (month / 10) + 48);
    StrSetChar(output, 6, (month % 10) + 48);
    StrSetChar(output, 7, 45);  // '-'
    StrSetChar(output, 8, (day / 10) + 48);
    StrSetChar(output, 9, (day % 10) + 48);
    StrSetChar(output, 10, 0);
    return 10;
}

// Format time only
pub fn FormatTime(hour: int64, minute: int64, second: int64, output: pchar): int64 {
    // Output: HH:MM:SS
    StrSetChar(output, 0, (hour / 10) + 48);
    StrSetChar(output, 1, (hour % 10) + 48);
    StrSetChar(output, 2, 58);  // ':'
    StrSetChar(output, 3, (minute / 10) + 48);
    StrSetChar(output, 4, (minute % 10) + 48);
    StrSetChar(output, 5, 58);  // ':'
    StrSetChar(output, 6, (second / 10) + 48);
    StrSetChar(output, 7, (second % 10) + 48);
    StrSetChar(output, 8, 0);
    return 8;
}

