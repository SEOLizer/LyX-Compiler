// ============================================================================
// Validation
// ============================================================================

// Check if date is valid
pub fn IsValidDate(year: int64, month: int64, day: int64): bool {
    // Check month range
    if (month < 1 || month > 12) { return false; }
    // Check day range
    if (day < 1) { return false; }
    // Check days in month
    var max_day: int64 := DaysInMonth(year, month);
    if (day > max_day) { return false; }
    return true;
}

// Check if time is valid
pub fn IsValidTime(hour: int64, minute: int64, second: int64): bool {
    if (hour < 0 || hour > 23) { return false; }
    if (minute < 0 || minute > 59) { return false; }
    if (second < 0 || second > 59) { return false; }
    return true;
}

// Check if datetime is valid
pub fn IsValidDateTime(year: int64, month: int64, day: int64, hour: int64, minute: int64, second: int64): bool {
    return IsValidDate(year, month, day) && IsValidTime(hour, minute, second);
}

