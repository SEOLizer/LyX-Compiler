// Format duration (e.g., "1h 30m 45s")
pub fn FormatDuration(seconds: int64, output: pchar): int64 {
    var hours: int64 := seconds / 3600;
    var mins: int64 := (seconds % 3600) / 60;
    var secs: int64 := seconds % 60;
    
    var out_pos: int64 := 0;
    var i: int64 := 0;
    
    // Hours
    if (hours > 0) {
        // Convert to string
        if (hours >= 100) {
            StrSetChar(output, out_pos, (hours / 100) + 48); out_pos := out_pos + 1;
            StrSetChar(output, out_pos, ((hours / 10) % 10) + 48); out_pos := out_pos + 1;
            StrSetChar(output, out_pos, (hours % 10) + 48); out_pos := out_pos + 1;
        } else if (hours >= 10) {
            StrSetChar(output, out_pos, (hours / 10) + 48); out_pos := out_pos + 1;
            StrSetChar(output, out_pos, (hours % 10) + 48); out_pos := out_pos + 1;
        } else {
            StrSetChar(output, out_pos, hours + 48); out_pos := out_pos + 1;
        }
        StrSetChar(output, out_pos, 104); out_pos := out_pos + 1;  // 'h'
        StrSetChar(output, out_pos, 32); out_pos := out_pos + 1;   // ' '
    }
    
    // Minutes
    if (mins > 0 || (hours > 0 && secs > 0)) {
        StrSetChar(output, out_pos, (mins / 10) + 48); out_pos := out_pos + 1;
        StrSetChar(output, out_pos, (mins % 10) + 48); out_pos := out_pos + 1;
        StrSetChar(output, out_pos, 109); out_pos := out_pos + 1;  // 'm'
        if (secs > 0) {
            StrSetChar(output, out_pos, 32); out_pos := out_pos + 1;  // ' '
        }
    }
    
    // Seconds
    if (secs > 0 || (hours == 0 && mins == 0)) {
        StrSetChar(output, out_pos, (secs / 10) + 48); out_pos := out_pos + 1;
        StrSetChar(output, out_pos, (secs % 10) + 48); out_pos := out_pos + 1;
        StrSetChar(output, out_pos, 115); out_pos := out_pos + 1;  // 's'
    }
    
    StrSetChar(output, out_pos, 0);
    return out_pos;
}

// Format short duration (e.g., "1:30:45" or "30:45")
pub fn FormatDurationShort(seconds: int64, output: pchar): int64 {
    var hours: int64 := seconds / 3600;
    var mins: int64 := (seconds % 3600) / 60;
    var secs: int64 := seconds % 60;
    
    var out_pos: int64 := 0;
    
    // Hours (only if >= 1 hour)
    if (hours > 0) {
        if (hours >= 100) {
            StrSetChar(output, out_pos, (hours / 100) + 48); out_pos := out_pos + 1;
            StrSetChar(output, out_pos, ((hours / 10) % 10) + 48); out_pos := out_pos + 1;
            StrSetChar(output, out_pos, (hours % 10) + 48); out_pos := out_pos + 1;
        } else if (hours >= 10) {
            StrSetChar(output, out_pos, (hours / 10) + 48); out_pos := out_pos + 1;
            StrSetChar(output, out_pos, (hours % 10) + 48); out_pos := out_pos + 1;
        } else {
            StrSetChar(output, out_pos, hours + 48); out_pos := out_pos + 1;
        }
        StrSetChar(output, out_pos, 58); out_pos := out_pos + 1;  // ':'
    }
    
    // Minutes
    StrSetChar(output, out_pos, (mins / 10) + 48); out_pos := out_pos + 1;
    StrSetChar(output, out_pos, (mins % 10) + 48); out_pos := out_pos + 1;
    StrSetChar(output, out_pos, 58); out_pos := out_pos + 1;  // ':'
    
    // Seconds
    StrSetChar(output, out_pos, (secs / 10) + 48); out_pos := out_pos + 1;
    StrSetChar(output, out_pos, (secs % 10) + 48); out_pos := out_pos + 1;
    
    StrSetChar(output, out_pos, 0);
    return out_pos;
}

