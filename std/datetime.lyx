// Format timezone offset (e.g., "+02:00" or "-05:00")
pub fn FormatTimezoneOffset(offset_seconds: int64, output: pchar): int64 {
    var out_pos: int64 := 0;
    var offset_hours: int64 := offset_seconds / 3600;
    var offset_mins: int64 := (offset_seconds % 3600) / 60;
    
    // Sign
    if (offset_seconds >= 0) {
        StrSetChar(output, out_pos, 43); out_pos := out_pos + 1;  // '+'
    } else {
        StrSetChar(output, out_pos, 45); out_pos := out_pos + 1;  // '-'
        offset_hours := -offset_hours;
    }
    
    // Hours
    StrSetChar(output, out_pos, (offset_hours / 10) + 48); out_pos := out_pos + 1;
    StrSetChar(output, out_pos, (offset_hours % 10) + 48); out_pos := out_pos + 1;
    
    StrSetChar(output, out_pos, 58); out_pos := out_pos + 1;  // ':'
    
    // Minutes
    StrSetChar(output, out_pos, (offset_mins / 10) + 48); out_pos := out_pos + 1;
    StrSetChar(output, out_pos, (offset_mins % 10) + 48); out_pos := out_pos + 1;
    
    StrSetChar(output, out_pos, 0);
    return out_pos;
}

// ============================================================================
// Calendar Calculations
// ============================================================================

// Get number of days in a month
pub fn DaysInMonth(year: int64, month: int64): int64 {
    // 31 days: Jan, Mar, May, Jul, Aug, Oct, Dec
    // 30 days: Apr, Jun, Sep, Nov
    // 28/29 days: Feb (leap year)
    if (month == 2) {
        // February
        if ((year % 4 == 0 && year % 100 != 0) || (year % 400 == 0)) {
            return 29;
        }
        return 28;
    }
    if (month == 4 || month == 6 || month == 9 || month == 11) {
        return 30;
    }
    return 31;
}

// Get week number of year (ISO week date)
// Returns 1-53
pub fn WeekNumber(year: int64, month: int64, day: int64): int64 {
    return 0;  // TODO: Implement
}

// Get day of year (1-366)
pub fn DayOfYear(year: int64, month: int64, day: int64): int64 {
    // Sum days in previous months + current day
    var days: int64 := 0;
    var m: int64 := 1;
    while (m < month) {
        days := days + DaysInMonth(year, m);
        m := m + 1;
    }
    days := days + day;
    return days;
}

