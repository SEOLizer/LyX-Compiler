// Lyx Statistics & Aggregation Module
// Aggregate functions for arrays and higher-order operations
//
// This module provides:
// - Array aggregate functions: Min, Max, Sum, Avg, Median, Count
// - Higher-order functions: Filter, Map, Reduce
// - Statistical functions: Variance, StdDev
//
// Usage:
//   import std.stats;
//   var arr: array := [10, 20, 30, 40, 50];
//   var s: int64 := ArraySum(arr);      // 150
//   var a: int64 := ArrayAvg(arr);      // 30
//   var mn: int64 := ArrayMin(arr);     // 10
//   var mx: int64 := ArrayMax(arr);     // 50
//   var m: int64 := ArrayMedian(arr);   // 30
//   var c: int64 := ArrayCount(arr);    // 5

unit std.stats;

// ============================================================================
// Array Aggregate Functions
// ============================================================================

// Sum of all elements in array
// Returns sum of all elements
pub fn ArraySum(arr: array): int64 {
  var sum: int64 := 0;
  var i: int64 := 0;
  var n: int64 := len(arr);
  
  while (i < n) {
    sum := sum + arr[i];
    i := i + 1;
  }
  
  return sum;
}

// Minimum element in array
// Returns smallest element, or 0 if array is empty
pub fn ArrayMin(arr: array): int64 {
  var n: int64 := len(arr);
  var i: int64 := 1;
  var mn: int64;
  
  if (n == 0) {
    return 0;
  }
  
  mn := arr[0];
  
  while (i < n) {
    if (arr[i] < mn) {
      mn := arr[i];
    }
    i := i + 1;
  }
  
  return mn;
}

// Maximum element in array
// Returns largest element, or 0 if array is empty
pub fn ArrayMax(arr: array): int64 {
  var n: int64 := len(arr);
  var i: int64 := 1;
  var mx: int64;
  
  if (n == 0) {
    return 0;
  }
  
  mx := arr[0];
  
  while (i < n) {
    if (arr[i] > mx) {
      mx := arr[i];
    }
    i := i + 1;
  }
  
  return mx;
}

// Average of all elements
// Returns average (sum / count), or 0 if array is empty
pub fn ArrayAvg(arr: array): int64 {
  var n: int64 := len(arr);
  
  if (n == 0) {
    return 0;
  }
  
  return ArraySum(arr) / n;
}

// Median of sorted array (middle element)
// For even-length arrays, returns lower middle element
// Returns median, or 0 if array is empty
pub fn ArrayMedian(arr: array): int64 {
  var n: int64 := len(arr);
  
  if (n == 0) {
    return 0;
  }
  
  // Sort a copy and return middle element
  var sorted: array := ArraySort(arr);
  var mid: int64 := n / 2;
  var result: int64 := sorted[mid];
  free(sorted);
  
  return result;
}

// Count elements in array (alias for len, but with consistent naming)
pub fn ArrayCount(arr: array): int64 {
  return len(arr);
}

// Product of all elements
pub fn ArrayProduct(arr: array): int64 {
  var n: int64 := len(arr);
  var i: int64 := 0;
  var product: int64 := 1;
  
  if (n == 0) {
    return 0;
  }
  
  while (i < n) {
    product := product * arr[i];
    i := i + 1;
  }
  
  return product;
}

// First element, or default if empty
pub fn ArrayFirst(arr: array, default: int64): int64 {
  if (len(arr) == 0) {
    return default;
  }
  return arr[0];
}

// Last element, or default if empty
pub fn ArrayLast(arr: array, default: int64): int64 {
  var n: int64 := len(arr);
  if (n == 0) {
    return default;
  }
  return arr[n - 1];
}

// Index of first occurrence of value, or -1 if not found
pub fn ArrayIndexOf(arr: array, value: int64): int64 {
  var i: int64 := 0;
  var n: int64 := len(arr);
  
  while (i < n) {
    if (arr[i] == value) {
      return i;
    }
    i := i + 1;
  }
  
  return -1;
}

// Index of last occurrence of value, or -1 if not found
pub fn ArrayLastIndexOf(arr: array, value: int64): int64 {
  var n: int64 := len(arr);
  var i: int64 := n - 1;
  
  while (i >= 0) {
    if (arr[i] == value) {
      return i;
    }
    i := i - 1;
  }
  
  return -1;
}

// Check if array contains value
pub fn ArrayContains(arr: array, value: int64): bool {
  return ArrayIndexOf(arr, value) >= 0;
}

// Count occurrences of value in array
pub fn ArrayCountValue(arr: array, value: int64): int64 {
  var count: int64 := 0;
  var i: int64 := 0;
  var n: int64 := len(arr);
  
  while (i < n) {
    if (arr[i] == value) {
      count := count + 1;
    }
    i := i + 1;
  }
  
  return count;
}

// ============================================================================
// Sorting
// ============================================================================

// Sort array (ascending, returns new array)
// Uses insertion sort (O(n²), suitable for small arrays)
pub fn ArraySort(arr: array): array {
  var n: int64 := len(arr);
  var sorted: array := [0, 0, 0];  // Will be resized
  var i: int64 := 0;
  
  // Copy array
  while (i < n) {
    push(sorted, arr[i]);
    i := i + 1;
  }
  
  // Remove initial 3 zeros
  if (n > 0) {
    pop(sorted); pop(sorted); pop(sorted);
  } else {
    pop(sorted); pop(sorted); pop(sorted);
  }
  
  // Insertion sort
  i := 1;
  while (i < n) {
    var key: int64 := sorted[i];
    var j: int64 := i - 1;
    
    while (j >= 0 && sorted[j] > key) {
      sorted[j + 1] := sorted[j];
      j := j - 1;
    }
    
    sorted[j + 1] := key;
    i := i + 1;
  }
  
  return sorted;
}

// Reverse array (returns new array)
pub fn ArrayReverse(arr: array): array {
  var n: int64 := len(arr);
  var reversed: array := [0, 0, 0];
  var i: int64 := n - 1;
  
  while (i >= 0) {
    push(reversed, arr[i]);
    i := i - 1;
  }
  
  // Remove initial 3 zeros
  if (n > 0) {
    pop(reversed); pop(reversed); pop(reversed);
  } else {
    pop(reversed); pop(reversed); pop(reversed);
  }
  
  return reversed;
}

