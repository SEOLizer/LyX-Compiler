// Filter: Keep only elements where predicate(element) returns 1
// Returns new filtered array
pub fn ArrayFilter(arr: array, callback: int64): array {
  // callback is a function pointer: fn(element: int64): int64
  // Returns new array with elements where callback returns 1
  var n: int64 := len(arr);
  var result: array := [0, 0, 0];
  var i: int64 := 0;
  var count: int64 := 0;
  
  // Note: callback invocation requires IR support for indirect calls
  // For now, provide predicate as inline filter
  // This is a limitation of the current implementation
  
  while (i < n) {
    // Call callback(arr[i]) - requires indirect call support
    // For now, just copy all elements
    push(result, arr[i]);
    i := i + 1;
  }
  
  // Remove initial 3 zeros
  if (n > 0) {
    pop(result); pop(result); pop(result);
  } else {
    pop(result); pop(result); pop(result);
  }
  
  return result;
}

