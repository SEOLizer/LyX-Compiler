// Filter elements greater than threshold
pub fn ArrayFilterGt(arr: array, threshold: int64): array {
  var n: int64 := len(arr);
  var result: array := [];
  var i: int64 := 0;
  
  while (i < n) {
    if (arr[i] > threshold) {
      push(result, arr[i]);
    }
    i := i + 1;
  }
  
  return result;
}

// Filter elements less than threshold
pub fn ArrayFilterLt(arr: array, threshold: int64): array {
  var n: int64 := len(arr);
  var result: array := [];
  var i: int64 := 0;
  
  while (i < n) {
    if (arr[i] < threshold) {
      push(result, arr[i]);
    }
    i := i + 1;
  }
  
  return result;
}

// Filter elements in range [min, max]
pub fn ArrayFilterRange(arr: array, min: int64, max: int64): array {
  var n: int64 := len(arr);
  var result: array := [];
  var i: int64 := 0;
  
  while (i < n) {
    if (arr[i] >= min && arr[i] <= max) {
      push(result, arr[i]);
    }
    i := i + 1;
  }
  
  return result;
}

