// ============================================================================
// Statistical Functions
// ============================================================================

// Variance (population variance)
// var(X) = E[(X - μ)²] = (1/n) * Σ(xi - mean)²
pub fn ArrayVariance(arr: array): int64 {
  var n: int64 := len(arr);
  
  if (n == 0) {
    return 0;
  }
  
  var mean: int64 := ArrayAvg(arr);
  var sumSqDiff: int64 := 0;
  var i: int64 := 0;
  
  while (i < n) {
    var diff: int64 := arr[i] - mean;
    sumSqDiff := sumSqDiff + (diff * diff);
    i := i + 1;
  }
  
  return sumSqDiff / n;
}

// Standard deviation (population)
pub fn ArrayStdDev(arr: array): int64 {
  var variance: int64 := ArrayVariance(arr);
  
  // Integer square root approximation
  if (variance <= 0) {
    return 0;
  }
  
  // Newton's method for integer sqrt
  var x: int64 := variance;
  var y: int64 := (x + 1) / 2;
  
  while (y < x) {
    x := y;
    y := (x + variance / x) / 2;
  }
  
  return x;
}

// Range (max - min)
pub fn ArrayRange(arr: array): int64 {
  return ArrayMax(arr) - ArrayMin(arr);
}

// Sum of squares
pub fn ArraySumSquares(arr: array): int64 {
  var n: int64 := len(arr);
  var i: int64 := 0;
  var sum: int64 := 0;
  
  while (i < n) {
    sum := sum + (arr[i] * arr[i]);
    i := i + 1;
  }
  
  return sum;
}

// ============================================================================
// Utility Functions
// ============================================================================

// Clamp value to range [min, max]
pub fn Clamp64(value: int64, min: int64, max: int64): int64 {
  if (value < min) {
    return min;
  }
  if (value > max) {
    return max;
  }
  return value;
}

// Percentage of value relative to total
pub fn Percentage64(value: int64, total: int64): int64 {
  if (total == 0) {
    return 0;
  }
  return (value * 100) / total;
}

// Is value in range [min, max]?
pub fn InRange64(value: int64, min: int64, max: int64): bool {
  return value >= min && value <= max;
}

// Absolute difference
pub fn AbsDiff64(a: int64, b: int64): int64 {
  if (a > b) {
    return a - b;
  }
  return b - a;
}
