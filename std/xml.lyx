// Node types
con XML_NODE_ELEMENT: int64 := 1;
con XML_NODE_TEXT: int64 := 2;
con XML_NODE_CDATA: int64 := 3;
con XML_NODE_COMMENT: int64 := 4;
con XML_NODE_DECLARATION: int64 := 5;

