pub con ERR_XML_ATTR_ERROR: int64 := 4;

// Document handle (int64 pointer)

// ============================================================================
// Helper Functions
// ============================================================================

// Check if character is whitespace
fn isXmlSpace(c: int64): bool {
    return c == 32 || c == 9 || c == 10 || c == 13;
}

// Skip whitespace
fn skipXmlSpace(s: pchar, pos: int64): int64 {
    while (isXmlSpace(StrCharAt(s, pos))) {
        pos := pos + 1;
    }
    return pos;
}

// Find end of line
fn findXmlLineEnd(s: pchar, pos: int64): int64 {
    while (StrCharAt(s, pos) != 0 && StrCharAt(s, pos) != 10 && StrCharAt(s, pos) != 13) {
        pos := pos + 1;
    }
    return pos;
}

// String length helper
fn xmlStrLen(s: pchar): int64 {
    var i: int64 := 0;
    while (s[i] != 0) { i := i + 1; }
    return i;
}

// ============================================================================
// XML Escaping (for attribute values and text content)
// ============================================================================

// Escape XML special characters
pub fn EscapeText(input: pchar, output: pchar): int64 {
    if (input == 0 || output == 0) { return 0; }
    
    var inPos: int64 := 0;
    var outPos: int64 := 0;
    
    while (true) {
        var c: int64 := StrCharAt(input, inPos);
        
        if (c == 0) {
            StrSetChar(output, outPos, 0);
            break;
        }
        
        if (c == 38) {  // '&'
            StrSetChar(output, outPos, 38); outPos := outPos + 1;
            StrSetChar(output, outPos, 97); outPos := outPos + 1;
            StrSetChar(output, outPos, 109); outPos := outPos + 1;
            StrSetChar(output, outPos, 112); outPos := outPos + 1;
            StrSetChar(output, outPos, 59); outPos := outPos + 1;
        } else if (c == 60) {  // '<'
            StrSetChar(output, outPos, 38); outPos := outPos + 1;
            StrSetChar(output, outPos, 108); outPos := outPos + 1;
            StrSetChar(output, outPos, 116); outPos := outPos + 1;
            StrSetChar(output, outPos, 59); outPos := outPos + 1;
        } else if (c == 62) {  // '>'
            StrSetChar(output, outPos, 38); outPos := outPos + 1;
            StrSetChar(output, outPos, 103); outPos := outPos + 1;
            StrSetChar(output, outPos, 116); outPos := outPos + 1;
            StrSetChar(output, outPos, 59); outPos := outPos + 1;
        } else {
            StrSetChar(output, outPos, c);
            outPos := outPos + 1;
        }
        
        inPos := inPos + 1;
    }
    
    return outPos;
}

// Escape for attribute values (adds quotes and handles ")
pub fn EscapeAttribute(input: pchar, output: pchar): int64 {
    if (input == 0 || output == 0) { return 0; }
    
    StrSetChar(output, 0, 34);  // Opening "
    var outPos: int64 := 1;
    
    var inPos: int64 := 0;
    while (true) {
        var c: int64 := StrCharAt(input, inPos);
        
        if (c == 0) {
            StrSetChar(output, outPos, 34); outPos := outPos + 1;  // Closing "
            StrSetChar(output, outPos, 0);
            break;
        }
        
        if (c == 34) {  // '"'
            StrSetChar(output, outPos, 38); outPos := outPos + 1;
            StrSetChar(output, outPos, 113); outPos := outPos + 1;
            StrSetChar(output, outPos, 117); outPos := outPos + 1;
            StrSetChar(output, outPos, 111); outPos := outPos + 1;
            StrSetChar(output, outPos, 116); outPos := outPos + 1;
            StrSetChar(output, outPos, 59); outPos := outPos + 1;
        } else if (c == 38) {  // '&'
            StrSetChar(output, outPos, 38); outPos := outPos + 1;
            StrSetChar(output, outPos, 97); outPos := outPos + 1;
            StrSetChar(output, outPos, 109); outPos := outPos + 1;
            StrSetChar(output, outPos, 112); outPos := outPos + 1;
            StrSetChar(output, outPos, 59); outPos := outPos + 1;
        } else if (c == 60) {  // '<'
            StrSetChar(output, outPos, 38); outPos := outPos + 1;
            StrSetChar(output, outPos, 108); outPos := outPos + 1;
            StrSetChar(output, outPos, 116); outPos := outPos + 1;
            StrSetChar(output, outPos, 59); outPos := outPos + 1;
        } else {
            StrSetChar(output, outPos, c);
            outPos := outPos + 1;
        }
        
        inPos := inPos + 1;
    }
    
    return outPos;
}

// ============================================================================
// XML Parsing
// ============================================================================

// Find tag name end
fn findTagNameEnd(s: pchar, pos: int64): int64 {
    var i: int64 := pos;
    while (true) {
        var c: int64 := StrCharAt(s, i);
        if (c == 32 || c == 9 || c == 10 || c == 13 || c == 47 || c == 62 || c == 0) {
            break;
        }
        i := i + 1;
    }
    return i;
}

// Find attribute name end
fn findAttrNameEnd(s: pchar, pos: int64): int64 {
    var i: int64 := pos;
    while (true) {
        var c: int64 := StrCharAt(s, i);
        if (c == 32 || c == 9 || c == 10 || c == 13 || c == 61 || c == 62 || c == 47 || c == 0) {
            break;
        }
        i := i + 1;
    }
    return i;
}

// Find attribute value end (handles quoted values)
fn findAttrValueEnd(s: pchar, pos: int64): int64 {
    var quote: int64 := StrCharAt(s, pos);
    if (quote != 34 && quote != 39) { return pos; }  // Not quoted
    
    var i: int64 := pos + 1;
    while (true) {
        var c: int64 := StrCharAt(s, i);
        if (c == 0) { return i; }
        if (c == quote) { return i + 1; }
        i := i + 1;
    }
}

// Parse XML declaration (<?xml version="1.0" encoding="UTF-8"?>)
fn parseXmlDecl(s: pchar, pos: int64, outVersion: pchar, outEncoding: pchar): int64 {
    // Skip '<?xml'
    pos := pos + 5;
    pos := skipXmlSpace(s, pos);
    
    // Parse attributes
    while (StrCharAt(s, pos) != 63 && StrCharAt(s, pos) != 0) {  // '?'
        // Find attribute name
        var nameStart: int64 := pos;
        var nameEnd: int64 := findAttrNameEnd(s, pos);
        var nameLen: int64 := nameEnd - nameStart;
        
        pos := nameEnd;
        pos := skipXmlSpace(s, pos);
        
        if (StrCharAt(s, pos) != 61) { return pos; }  // '='
        pos := pos + 1;
        pos := skipXmlSpace(s, pos);
        
        var valueStart: int64 := pos;
        var valueEnd: int64 := findAttrValueEnd(s, pos);
        
        // Copy attribute name
        var i: int64 := 0;
        while (i < nameLen && nameStart + i < valueEnd - 1) {
            var c: int64 := StrCharAt(s, nameStart + i);
            
            // Check for version
            if (i == 0 && nameLen == 7) {
                if (StrCharAt(s, nameStart) == 118 &&
                    StrCharAt(s, nameStart + 1) == 101 &&
                    StrCharAt(s, nameStart + 2) == 114 &&
                    StrCharAt(s, nameStart + 3) == 115 &&
                    StrCharAt(s, nameStart + 4) == 105 &&
                    StrCharAt(s, nameStart + 5) == 111 &&
                    StrCharAt(s, nameStart + 6) == 110) {
                    // Copy version value
                    var j: int64 := 0;
                    var vStart: int64 := valueStart + 1;
                    var vEnd: int64 := valueEnd - 1;
                    while (vStart + j < vEnd) {
                        StrSetChar(outVersion, j, StrCharAt(s, vStart + j));
                        j := j + 1;
                    }
                    StrSetChar(outVersion, j, 0);
                }
            }
            
            // Check for encoding
            if (nameLen == 8) {
                if (StrCharAt(s, nameStart) == 101 &&
                    StrCharAt(s, nameStart + 1) == 110 &&
                    StrCharAt(s, nameStart + 2) == 99 &&
                    StrCharAt(s, nameStart + 3) == 111 &&
                    StrCharAt(s, nameStart + 4) == 100 &&
                    StrCharAt(s, nameStart + 5) == 105 &&
                    StrCharAt(s, nameStart + 6) == 110 &&
                    StrCharAt(s, nameStart + 7) == 103) {
                    // Copy encoding value
                    var j: int64 := 0;
                    var vStart: int64 := valueStart + 1;
                    var vEnd: int64 := valueEnd - 1;
                    while (vStart + j < vEnd) {
                        StrSetChar(outEncoding, j, StrCharAt(s, vStart + j));
                        j := j + 1;
                    }
                    StrSetChar(outEncoding, j, 0);
                }
            }
            
            i := i + 1;
        }
        
        pos := valueEnd;
        pos := skipXmlSpace(s, pos);
    }
    
    return pos;
}

// Parse a single tag and its content
fn parseTag(s: pchar, pos: int64, outTagName: pchar, outText: pchar, indent: int64, output: pchar): int64 {
    // Skip '<'
    if (StrCharAt(s, pos) != 60) { return pos; }  // '<'
    pos := pos + 1;
    
    // Check for closing tag
    var isClosing: bool := false;
    if (StrCharAt(s, pos) == 47) {
        isClosing := true;
        pos := pos + 1;
    }
    
    // Skip whitespace
    pos := skipXmlSpace(s, pos);
    
    // Get tag name
    var nameEnd: int64 := findTagNameEnd(s, pos);
    var nameLen: int64 := nameEnd - pos;
    
    var i: int64 := 0;
    while (i < nameLen) {
        StrSetChar(outTagName, i, StrCharAt(s, pos + i));
        i := i + 1;
    }
    StrSetChar(outTagName, i, 0);
    
    pos := nameEnd;
    
    // If closing tag, find '>'
    if (isClosing) {
        while (StrCharAt(s, pos) != 62 && StrCharAt(s, pos) != 0) { pos := pos + 1; }
        if (StrCharAt(s, pos) == 62) { pos := pos + 1; }
        return pos;
    }
    
    // Parse attributes (simplified - just skip them for now)
    var textStart: int64 := 0;
    var textLen: int64 := 0;
    
    while (StrCharAt(s, pos) != 62 && StrCharAt(s, pos) != 47 && StrCharAt(s, pos) != 0) {
        pos := skipXmlSpace(s, pos);
        
        // Check for /> (self-closing)
        if (StrCharAt(s, pos) == 47) {
            pos := pos + 1;
            if (StrCharAt(s, pos) == 62) {  // '>'
                pos := pos + 1;
                return pos;
            }
        }
        
        // Skip attribute name
        var attrNameEnd: int64 := findAttrNameEnd(s, pos);
        pos := attrNameEnd;
        pos := skipXmlSpace(s, pos);
        
        // Skip = and value
        if (StrCharAt(s, pos) == 61) {
            pos := pos + 1;
            pos := skipXmlSpace(s, pos);
            var attrValueEnd: int64 := findAttrValueEnd(s, pos);
            pos := attrValueEnd;
        }
    }
    
    if (StrCharAt(s, pos) == 62) { pos := pos + 1; }  // '>'
    
    // Find closing tag
    var closeStart: int64 := pos;
    
    // Look for </tag>
    while (StrCharAt(s, closeStart) != 0) {
        if (StrCharAt(s, closeStart) == 60 && StrCharAt(s, closeStart + 1) == 47) {
            break;
        }
        closeStart := closeStart + 1;
    }
    
    // Extract text content
    textLen := closeStart - pos;
    i := 0;
    while (i < textLen && i < 255) {
        StrSetChar(outText, i, StrCharAt(s, pos + i));
        i := i + 1;
    }
    StrSetChar(outText, i, 0);
    
    return closeStart;
}

// ============================================================================
// Main Parse Function
// ============================================================================

// Simple XML parser - returns document handle
// Output buffer structure: [version:32][encoding:32][rootName:256][rootText:256]
pub fn ParseString(input: pchar, output: pchar): int64 {
    if (input == 0 || output == 0) { return 0; }
    
    var pos: int64 := 0;
    
    // Skip BOM if present
    if (StrCharAt(input, 0) == 239 && StrCharAt(input, 1) == 187 && StrCharAt(input, 2) == 191) {
        pos := pos + 3;
    }
    
    // Skip whitespace
    pos := skipXmlSpace(input, pos);
    
    // Check for XML declaration
    if (StrCharAt(input, pos) == 60 && StrCharAt(input, pos + 1) == 63 &&
        StrCharAt(input, pos + 2) == 120 && StrCharAt(input, pos + 3) == 109 &&  // '<?xml'
        StrCharAt(input, pos + 4) == 108) {
        
        var version: int64 := alloc(32);
        var encoding: int64 := alloc(32);
        
        pos := parseXmlDecl(input, pos, version, encoding);
        
        // Skip ?>
        while (StrCharAt(input, pos) != 63 && StrCharAt(input, pos) != 0) { pos := pos + 1; }
        if (StrCharAt(input, pos) == 63) { pos := pos + 2; }
        
        pos := skipXmlSpace(input, pos);
    }
    
    // Parse root element
    var tagName: int64 := alloc(256);
    var textContent: int64 := alloc(256);
    
    pos := parseTag(input, pos, tagName, textContent, 0, output);
    
    // Return simple success indicator (1)
    return 1;
}

// ============================================================================
// XML Generation
// ============================================================================

// Generate XML declaration
pub fn WriteDeclaration(output: pchar, version: pchar, encoding: pchar): int64 {
    if (output == 0) { return 0; }
    
    var pos: int64 := 0;
    
    StrSetChar(output, pos, 60); pos := pos + 1;  // '<'
    StrSetChar(output, pos, 63); pos := pos + 1;  // '?'
    StrSetChar(output, pos, 120); pos := pos + 1; // 'x'
    StrSetChar(output, pos, 109); pos := pos + 1; // 'm'
    StrSetChar(output, pos, 108); pos := pos + 1; // 'l'
    StrSetChar(output, pos, 32); pos := pos + 1;  // ' '
    
    // Version
    var i: int64 := 0;
    StrSetChar(output, pos, 118); pos := pos + 1; // 'v'
    StrSetChar(output, pos, 101); pos := pos + 1; // 'e'
    StrSetChar(output, pos, 114); pos := pos + 1; // 'r'
    StrSetChar(output, pos, 115); pos := pos + 1; // 's'
    StrSetChar(output, pos, 105); pos := pos + 1; // 'i'
    StrSetChar(output, pos, 111); pos := pos + 1; // 'o'
    StrSetChar(output, pos, 110); pos := pos + 1; // 'n'
    StrSetChar(output, pos, 61); pos := pos + 1;  // '='
    StrSetChar(output, pos, 34); pos := pos + 1;  // '"'
    
    if (version != 0) {
        while (StrCharAt(version, i) != 0) {
            StrSetChar(output, pos, StrCharAt(version, i));
            pos := pos + 1;
            i := i + 1;
        }
    } else {
        StrSetChar(output, pos, 49); pos := pos + 1;
        StrSetChar(output, pos, 46); pos := pos + 1;
        StrSetChar(output, pos, 48); pos := pos + 1;
    }
    
    StrSetChar(output, pos, 34); pos := pos + 1;  // '"'
    StrSetChar(output, pos, 32); pos := pos + 1;  // ' '
    
    // Encoding
    if (encoding != 0) {
        StrSetChar(output, pos, 101); pos := pos + 1; // 'e'
        StrSetChar(output, pos, 110); pos := pos + 1; // 'n'
        StrSetChar(output, pos, 99); pos := pos + 1;  // 'c'
        StrSetChar(output, pos, 111); pos := pos + 1; // 'o'
        StrSetChar(output, pos, 100); pos := pos + 1; // 'd'
        StrSetChar(output, pos, 105); pos := pos + 1; // 'i'
        StrSetChar(output, pos, 110); pos := pos + 1; // 'n'
        StrSetChar(output, pos, 103); pos := pos + 1; // 'g'
        StrSetChar(output, pos, 61); pos := pos + 1;  // '='
        StrSetChar(output, pos, 34); pos := pos + 1;  // '"'
        
        i := 0;
        while (StrCharAt(encoding, i) != 0) {
            StrSetChar(output, pos, StrCharAt(encoding, i));
            pos := pos + 1;
            i := i + 1;
        }
        
        StrSetChar(output, pos, 34); pos := pos + 1;  // '"'
    }
    
    StrSetChar(output, pos, 63); pos := pos + 1;  // '?'
    StrSetChar(output, pos, 62); pos := pos + 1;  // '>'
    StrSetChar(output, pos, 10); pos := pos + 1;  // newline
    
    return pos;
}

// Generate XML element with attributes and text content
pub fn WriteElement(output: pchar, tagName: pchar, attrs: pchar, attrCount: int64, text: pchar, indent: int64): int64 {
    if (output == 0 || tagName == 0) { return 0; }
    
    var pos: int64 := 0;
    var i: int64 := 0;
    
    // Indent
    while (i < indent) {
        StrSetChar(output, pos, 32); pos := pos + 1;  // ' '
        i := i + 1;
    }
    
    // Opening tag
    StrSetChar(output, pos, 60); pos := pos + 1;  // '<'
    
    i := 0;
    while (StrCharAt(tagName, i) != 0) {
        StrSetChar(output, pos, StrCharAt(tagName, i));
        pos := pos + 1;
        i := i + 1;
    }
    
    // Attributes (if provided)
    if (attrs != 0 && attrCount > 0) {
        var j: int64 := 0;
        while (j < attrCount) {
            StrSetChar(output, pos, 32); pos := pos + 1;  // ' '
            
            // Get attribute name (simplified - assumes contiguous memory)
            var attrOff: int64 := j * 128;
            
            i := 0;
            while (i < 64) {
                var c: int64 := StrCharAt(attrs, attrOff + i);
                if (c == 0) { break; }
                StrSetChar(output, pos, c); pos := pos + 1;
                i := i + 1;
            }
            
            StrSetChar(output, pos, 61); pos := pos + 1;  // '='
            StrSetChar(output, pos, 34); pos := pos + 1;  // '"'
            
            // Get attribute value
            var valOff: int64 := attrOff + 64;
            i := 0;
            while (i < 64) {
                var c: int64 := StrCharAt(attrs, valOff + i);
                if (c == 0) { break; }
                StrSetChar(output, pos, c); pos := pos + 1;
                i := i + 1;
            }
            
            StrSetChar(output, pos, 34); pos := pos + 1;  // '"'
            
            j := j + 1;
        }
    }
    
    // Check for empty element (no text)
    if (text == 0 || StrCharAt(text, 0) == 0) {
        StrSetChar(output, pos, 47); pos := pos + 1;  // '/'
        StrSetChar(output, pos, 62); pos := pos + 1;  // '>'
        StrSetChar(output, pos, 10); pos := pos + 1;  // newline
        return pos;
    }
    
    StrSetChar(output, pos, 62); pos := pos + 1;  // '>'
    
    // Text content
    i := 0;
    while (StrCharAt(text, i) != 0) {
        StrSetChar(output, pos, StrCharAt(text, i));
        pos := pos + 1;
        i := i + 1;
    }
    
    // Closing tag
    StrSetChar(output, pos, 60); pos := pos + 1;  // '<'
    StrSetChar(output, pos, 47); pos := pos + 1;  // '/'
    
    i := 0;
    while (StrCharAt(tagName, i) != 0) {
        StrSetChar(output, pos, StrCharAt(tagName, i));
        pos := pos + 1;
        i := i + 1;
    }
    
    StrSetChar(output, pos, 62); pos := pos + 1;  // '>'
    StrSetChar(output, pos, 10); pos := pos + 1;  // newline
    
    return pos;
}

// Generate complete XML document
pub fn WriteDocument(output: pchar, rootName: pchar, rootText: pchar, version: pchar, encoding: pchar): int64 {
    if (output == 0 || rootName == 0) { return 0; }
    
    var pos: int64 := 0;
    
    // Write declaration
    pos := pos + WriteDeclaration(output, version, encoding);
    
    // Write root element
    pos := pos + WriteElement(output + pos, rootName, 0, 0, rootText, 0);
    
    // Null terminate
    StrSetChar(output, pos, 0);
    
    return pos;
}

// ============================================================================
// Array <-> XML Conversion
// ============================================================================

// XML to Array conversion
// Parses XML and creates a simple array structure
// Output format: [type][nameLen][name][valueLen][value][childCount][childOffset...]
// This is a simplified representation

pub fn XMLToArray(xml: pchar, output: pchar): int64 {
    if (xml == 0 || output == 0) { return 0; }
    
    var pos: int64 := 0;
    
    // Skip whitespace
    pos := skipXmlSpace(xml, pos);
    
    // Check for XML declaration
    if (StrCharAt(xml, pos) == 60 && StrCharAt(xml, pos + 1) == 63) {
        while (StrCharAt(xml, pos) != 62 && StrCharAt(xml, pos) != 0) { pos := pos + 1; }
        if (StrCharAt(xml, pos) == 62) { pos := pos + 1; }
    }
    
    pos := skipXmlSpace(xml, pos);
    
    // Parse root element
    if (StrCharAt(xml, pos) != 60) { return 0; }
    pos := pos + 1;
    
    // Skip '/' for closing tag
    if (StrCharAt(xml, pos) == 47) { pos := pos + 1; }
    
    // Get root tag name
    var nameEnd: int64 := findTagNameEnd(xml, pos);
    var nameLen: int64 := nameEnd - pos;
    
    // Store root name length at position 0
    var outPos: int64 := 0;
    StrSetChar(output, outPos, nameLen & 255); outPos := outPos + 1;
    StrSetChar(output, outPos, (nameLen >> 8) & 255); outPos := outPos + 1;
    
    // Copy root name
    var i: int64 := 0;
    while (i < nameLen) {
        StrSetChar(output, outPos, StrCharAt(xml, pos + i));
        outPos := outPos + 1;
        i := i + 1;
    }
    
    pos := nameEnd;
    pos := skipXmlSpace(xml, pos);
    
    // Skip attributes
    while (StrCharAt(xml, pos) != 62 && StrCharAt(xml, pos) != 47) {
        pos := skipXmlSpace(xml, pos);
        var attrEnd: int64 := findAttrNameEnd(xml, pos);
        pos := attrEnd;
        pos := skipXmlSpace(xml, pos);
        if (StrCharAt(xml, pos) == 61) {
            pos := pos + 1;
            var valEnd: int64 := findAttrValueEnd(xml, pos);
            pos := valEnd;
        }
    }
    
    if (StrCharAt(xml, pos) == 47) {  // Self-closing
        StrSetChar(output, outPos, 0);  // No text content
        return 1;
    }
    
    pos := pos + 1;  // Skip '>'
    
    // Find closing tag
    var textStart: int64 := pos;
    var closePos: int64 := pos;
    
    while (StrCharAt(xml, closePos) != 0) {
        if (StrCharAt(xml, closePos) == 60 && StrCharAt(xml, closePos + 1) == 47) {
            break;
        }
        closePos := closePos + 1;
    }
    
    // Copy text content
    var textLen: int64 := closePos - textStart;
    StrSetChar(output, outPos, textLen & 255); outPos := outPos + 1;
    StrSetChar(output, outPos, (textLen >> 8) & 255); outPos := outPos + 1;
    
    i := 0;
    while (i < textLen && outPos < 1024) {
        StrSetChar(output, outPos, StrCharAt(xml, textStart + i));
        outPos := outPos + 1;
        i := i + 1;
    }
    
    return 1;
}

// Array to XML conversion
// Takes a simple array representation and generates XML
// Input format: [nameLen][name][textLen][text][childCount][children...]

pub fn ArrayToXML(arr: pchar, output: pchar): int64 {
    if (arr == 0 || output == 0) { return 0; }
    
    var pos: int64 := 0;
    var outPos: int64 := 0;
    
    // Get name length
    var nameLen: int64 := StrCharAt(arr, 0) | (StrCharAt(arr, 1) << 8);
    
    // Write opening tag
    StrSetChar(output, outPos, 60); outPos := outPos + 1;  // '<'
    
    var i: int64 := 0;
    while (i < nameLen) {
        StrSetChar(output, outPos, StrCharAt(arr, 2 + i));
        outPos := outPos + 1;
        i := i + 1;
    }
    
    StrSetChar(output, outPos, 62); outPos := outPos + 1;  // '>'
    
    // Get text length
    var textOff: int64 := 2 + nameLen;
    var textLen: int64 := StrCharAt(arr, textOff) | (StrCharAt(arr, textOff + 1) << 8);
    
    // Write text content
    i := 0;
    while (i < textLen) {
        StrSetChar(output, outPos, StrCharAt(arr, textOff + 2 + i));
        outPos := outPos + 1;
        i := i + 1;
    }
    
    // Write closing tag
    StrSetChar(output, outPos, 60); outPos := outPos + 1;  // '<'
    StrSetChar(output, outPos, 47); outPos := outPos + 1;  // '/'
    
    i := 0;
    while (i < nameLen) {
        StrSetChar(output, outPos, StrCharAt(arr, 2 + i));
        outPos := outPos + 1;
        i := i + 1;
    }
    
    StrSetChar(output, outPos, 62); outPos := outPos + 1;  // '>'
    StrSetChar(output, outPos, 0);  // Null terminate
    
    return outPos;
}

// ============================================================================
// XML Array Helper Functions
// ============================================================================

// Create XML array entry
pub fn CreateArrayEntry(name: pchar, text: pchar, output: pchar): int64 {
    if (output == 0) { return 0; }
    
    var outPos: int64 := 0;
    var i: int64 := 0;
    
    // Name length (2 bytes)
    var nameLen: int64 := 0;
    while (StrCharAt(name, nameLen) != 0) { nameLen := nameLen + 1; }
    
    StrSetChar(output, outPos, nameLen & 255); outPos := outPos + 1;
    StrSetChar(output, outPos, (nameLen >> 8) & 255); outPos := outPos + 1;
    
    // Name
    i := 0;
    while (i < nameLen && i < 64) {
        StrSetChar(output, outPos, StrCharAt(name, i));
        outPos := outPos + 1;
        i := i + 1;
    }
    
    // Text length (2 bytes)
    var textLen: int64 := 0;
    if (text != 0) {
        while (StrCharAt(text, textLen) != 0) { textLen := textLen + 1; }
    }
    
    StrSetChar(output, outPos, textLen & 255); outPos := outPos + 1;
    StrSetChar(output, outPos, (textLen >> 8) & 255); outPos := outPos + 1;
    
    // Text
    i := 0;
    while (i < textLen && i < 256) {
        StrSetChar(output, outPos, StrCharAt(text, i));
        outPos := outPos + 1;
        i := i + 1;
    }
    
    return outPos;
}

// Get name from array entry
pub fn GetArrayEntryName(arr: pchar, output: pchar): int64 {
    if (arr == 0 || output == 0) { return 0; }
    
    var nameLen: int64 := StrCharAt(arr, 0) | (StrCharAt(arr, 1) << 8);
    
    var i: int64 := 0;
    while (i < nameLen && i < 64) {
        StrSetChar(output, i, StrCharAt(arr, 2 + i));
        i := i + 1;
    }
    StrSetChar(output, i, 0);
    
    return nameLen;
}

// Get text from array entry
pub fn GetArrayEntryText(arr: pchar, output: pchar): int64 {
    if (arr == 0 || output == 0) { return 0; }
    
    var nameLen: int64 := StrCharAt(arr, 0) | (StrCharAt(arr, 1) << 8);
    var textOff: int64 := 2 + nameLen;
    
    var textLen: int64 := StrCharAt(arr, textOff) | (StrCharAt(arr, textOff + 1) << 8);
    
    var i: int64 := 0;
    while (i < textLen && i < 256) {
        StrSetChar(output, i, StrCharAt(arr, textOff + 2 + i));
        i := i + 1;
    }
    StrSetChar(output, i, 0);
    
    return textLen;
}

// ============================================================================
// Validation
// ============================================================================

// Validate basic XML structure
pub fn IsValid(xml: pchar): bool {
    if (xml == 0) { return false; }
    
    var pos: int64 := 0;
    
    // Skip BOM
    if (StrCharAt(xml, 0) == 239 && StrCharAt(xml, 1) == 187 && StrCharAt(xml, 2) == 191) {
        pos := pos + 3;
    }
    
    pos := skipXmlSpace(xml, pos);
    
    // Must start with '<'
    if (StrCharAt(xml, pos) != 60) { return false; }  // '<'
    
    // Check for XML declaration
    if (StrCharAt(xml, pos + 1) == 63) {  // '?'
        // Find closing ?>
        pos := pos + 2;
        while (StrCharAt(xml, pos) != 0) {
            if (StrCharAt(xml, pos) == 63 && StrCharAt(xml, pos + 1) == 62) {
                pos := pos + 2;
                break;
            }
            pos := pos + 1;
        }
    }
    
    pos := skipXmlSpace(xml, pos);
    
    // Must have root element
    if (StrCharAt(xml, pos) != 60) { return false; }
    
    return true;
}

// Count elements in XML
pub fn CountElements(xml: pchar): int64 {
    if (xml == 0) { return 0; }
    
    var count: int64 := 0;
    var i: int64 := 0;
    var inTag: bool := false;
    
    while (StrCharAt(xml, i) != 0) {
        var c: int64 := StrCharAt(xml, i);
        
        if (c == 60) {  // '<'
            inTag := true;
            
            // Count opening tags (not closing, not comments, not declarations)
            if (StrCharAt(xml, i + 1) != 47 &&  // not '</'
                StrCharAt(xml, i + 1) != 33 &&  // not '<!--'
                StrCharAt(xml, i + 1) != 63) {  // not '<?'
                count := count + 1;
            }
        } else if (c == 62) {  // '>'
            inTag := false;
        }
        
        i := i + 1;
    }
    
    return count;
}

// ============================================================================
// Pretty Print
// ============================================================================

// Format XML with indentation
pub fn PrettyPrint(input: pchar, output: pchar, indentSize: int64): int64 {
    if (input == 0 || output == 0) { return 0; }
    
    var inPos: int64 := 0;
    var outPos: int64 := 0;
    var indent: int64 := 0;
    var inText: bool := false;
    
    // Skip BOM
    if (StrCharAt(input, 0) == 239 && StrCharAt(input, 1) == 187 && StrCharAt(input, 2) == 191) {
        inPos := inPos + 3;
    }
    
    while (StrCharAt(input, inPos) != 0) {
        var c: int64 := StrCharAt(input, inPos);
        
        if (c == 60) {  // '<'
            // Check for closing tag
            if (StrCharAt(input, inPos + 1) == 47) {
                indent := indent - indentSize;
                if (indent < 0) { indent := 0; }
            }
            
            // Newline before tag
            if (outPos > 0 && StrCharAt(output, outPos - 1) != 10) {
                StrSetChar(output, outPos, 10); outPos := outPos + 1;
            }
            
            // Add indentation
            var i: int64 := 0;
            while (i < indent) {
                StrSetChar(output, outPos, 32); outPos := outPos + 1;
                i := i + 1;
            }
            
            inText := false;
        } else if (c == 62) {  // '>'
            // Check if next char starts closing tag or new tag
            if (StrCharAt(input, inPos + 1) == 60) {
                indent := indent + indentSize;
            }
            inText := true;
        }
        
        // Don't copy whitespace outside tags (except within text)
        if (not inText || (c != 10 && c != 13)) {
            StrSetChar(output, outPos, c);
            outPos := outPos + 1;
        }
        
        inPos := inPos + 1;
    }
    
    StrSetChar(output, outPos, 0);
    return outPos;
}