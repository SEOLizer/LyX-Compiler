// Lyx IBAN Validation - ISO 13616
// International Bank Account Number validation with country-specific checks
//
// IBAN format: CCkk BBBB CCCC CCCC CCCC
// - CC: Country code (2 letters)
// - kk: Check digits (2 digits)
// - BBBB...: Bank identifier + account number (up to 30 alphanumeric)
//
// Validation algorithm (ISO 13616):
// 1. Move first 4 characters to the end
// 2. Convert letters: A=10, B=11, ..., Z=35
// 3. Compute mod 97
// 4. Valid if result == 1
//
// Usage:
//   import std.validate.iban;
//   var valid: bool := IBANValidate("DE89370400440532013000");
//   var country: int64 := IBANGetCountry("DE89370400440532013000");
//   var formatted: int64 := IBANFormat("DE89370400440532013000");

unit std.validate.iban;

// IBAN validation status
pub con IBAN_OK: int64 := 0;
pub con IBAN_ERR_INVALID_LENGTH: int64 := 1;
pub con IBAN_ERR_INVALID_CHAR: int64 := 2;
pub con IBAN_ERR_INVALID_CHECK: int64 := 3;
pub con IBAN_ERR_UNKNOWN_COUNTRY: int64 := 4;
pub con IBAN_ERR_INVALID_COUNTRY_LENGTH: int64 := 5;

// String length helper
pub fn IBANStrLen(s: int64): int64 {
  var len: int64 := 0;
  if (s == 0) {
    return 0;
  }
  while (peek8(s + len) != 0) {
    len := len + 1;
  }
  return len;
}

// Convert letter to IBAN number (A=10, B=11, ..., Z=35)
pub fn IBANLetterToNum(c: int64): int64 {
  if (c >= 65 && c <= 90) {
    return c - 55;  // A=10, B=11, ..., Z=35
  }
  if (c >= 97 && c <= 122) {
    return c - 87;  // a=10, b=11, ..., z=35
  }
  return -1;
}

// Check if character is alphanumeric
pub fn IBANIsAlphaNum(c: int64): int64 {
  if (c >= 48 && c <= 57) {  // 0-9
    return 1;
  }
  if (c >= 65 && c <= 90) {  // A-Z
    return 1;
  }
  if (c >= 97 && c <= 122) {  // a-z
    return 1;
  }
  return 0;
}

// Normalize IBAN string (remove spaces, convert to uppercase)
// Returns allocated string (caller must free)
pub fn IBANNormalize(iban: int64): int64 {
  var len: int64;
  var buf: int64;
  var pos: int64;
  var i: int64;
  var c: int64;
  
  if (iban == 0) {
    return 0;
  }
  
  len := IBANStrLen(iban);
  var bufSz1: int64 := len + 1;
  buf := mmap(0, bufSz1, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    return 0;
  }
  
  pos := 0;
  i := 0;
  
  while (i < len) {
    c := peek8(iban + i);
    
    // Skip spaces and hyphens
    if (c == 32 || c == 45) {
      i := i + 1;
      continue;
    }
    
    // Convert to uppercase
    if (c >= 97 && c <= 122) {
      c := c - 32;
    }
    
    poke8(buf + pos, c);
    pos := pos + 1;
    i := i + 1;
  }
  
  poke8(buf + pos, 0);
  return buf;
}

// Get expected IBAN length for a country code
// country: 2-letter country code
// Returns expected length (including country code + checkD digits), or 0 if unknown
pub fn IBANCountryLength(country: int64): int64 {
  var c1: int64;
  var c2: int64;
  
  if (country == 0) {
    return 0;
  }
  
  c1 := peek8(country);
  c2 := peek8(country + 1);
  
  // Convert to uppercase
  if (c1 >= 97 && c1 <= 122) { c1 := c1 - 32; }
  if (c2 >= 97 && c2 <= 122) { c2 := c2 - 32; }
  
  // European countries
  if (c1 == 68 && c2 == 69) { return 22; }  // DE - Germany
  if (c1 == 65 && c2 == 84) { return 20; }  // AT - Austria
  if (c1 == 67 && c2 == 72) { return 21; }  // CH - Switzerland
