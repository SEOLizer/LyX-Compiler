// Compute mod 97 of a large number represented as string
// Used for IBAN validation
// Returns number mod 97
pub fn IBANMod97(numStr: int64): int64 {
  var i: int64;
  var c: int64;
  var d: int64;
  var remainder: int64;
  
  remainder := 0;
  i := 0;
  
  while (i < 50) {  // Max IBAN length is 34 digits
    c := peek8(numStr + i);
    if (c == 0) {
      break;
    }
    
    // Convert char to digit
    if (c >= 48 && c <= 57) {
      d := c - 48;
    }
    else if (c >= 65 && c <= 90) {
      d := c - 55;  // A=10, B=11, ...
    }
    else {
      break;
    }
    
    remainder := remainder * 10 + d;
    remainder := remainder - (remainder / 97) * 97;
    
    i := i + 1;
  }
  
  return remainder;
}

// Validate IBAN
// iban: IBAN string (may contain spaces)
// Returns IBAN_OK if valid, or error code
pub fn IBANValidate(iban: int64): int64 {
  var normalized: int64;
  var len: int64;
  var i: int64;
  var c: int64;
  var rearranged: int64;
  var numericStr: int64;
  var modResult: int64;
  var expectedLen: int64;
  var country: int64;
  
  if (iban == 0) {
    return IBAN_ERR_INVALID_LENGTH;
  }
  
  // Normalize
  normalized := IBANNormalize(iban);
  if (normalized == 0) {
    return IBAN_ERR_INVALID_LENGTH;
  }
  
  len := IBANStrLen(normalized);
  
  // Minimum length: 5 (2 country + 2 checkD + 1 BBAN)
  if (len < 5) {
    munmap(normalized, len + 1);
    return IBAN_ERR_INVALID_LENGTH;
  }
  
  // Maximum length: 34
  if (len > 34) {
    munmap(normalized, len + 1);
    return IBAN_ERR_INVALID_LENGTH;
  }
  
  // Check first 2 characters are letters (country code)
  c := peek8(normalized);
  if ((c < 65 || c > 90) && (c < 97 || c > 122)) {
    munmap(normalized, len + 1);
    return IBAN_ERR_INVALID_CHAR;
  }
  c := peek8(normalized + 1);
  if ((c < 65 || c > 90) && (c < 97 || c > 122)) {
    munmap(normalized, len + 1);
    return IBAN_ERR_INVALID_CHAR;
  }
  
  // Check characters 3-4 are digits (checkD digits)
  c := peek8(normalized + 2);
  if (c < 48 || c > 57) {
    munmap(normalized, len + 1);
    return IBAN_ERR_INVALID_CHAR;
  }
  c := peek8(normalized + 3);
  if (c < 48 || c > 57) {
    munmap(normalized, len + 1);
    return IBAN_ERR_INVALID_CHAR;
  }
  
  // Check all characters are alphanumeric
  i := 0;
  while (i < len) {
    if (IBANIsAlphaNum(peek8(normalized + i)) == 0) {
      munmap(normalized, len + 1);
      return IBAN_ERR_INVALID_CHAR;
    }
    i := i + 1;
  }
  
  // Check country-specific length
  country := normalized;
  expectedLen := IBANCountryLength(country);
  if (expectedLen > 0 && len != expectedLen) {
    munmap(normalized, len + 1);
    return IBAN_ERR_INVALID_COUNTRY_LENGTH;
  }
  
  // Rearrange: move first 4 characters to end
  var rearSz: int64 := len + 1;
  rearranged := mmap(0, rearSz, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (rearranged == 0) {
    munmap(normalized, len + 1);
    return IBAN_ERR_INVALID_LENGTH;
  }
  
  // Copy characters 4..end
  i := 4;
  while (i < len) {
    var ri: int64 := i - 4;
    var rAddr: int64 := rearranged + ri;
    var nAddr: int64 := normalized + i;
    poke8(rAddr, peek8(nAddr));
    i := i + 1;
  }

  // Copy first 4 characters to end
  i := 0;
  while (i < 4) {
    var ch: int64 := peek8(normalized + i);
    var baseOff: int64 := len - 4;
    var off: int64 := baseOff + i;
    var wAddr: int64 := rearranged + off;
    if ((ch >= 65) && (ch <= 90)) {
      var val: int64 := ch - 55;
      var vd10: int64 := val / 10;
      var d1: int64 := 48 + vd10;
      poke8(wAddr, d1);
    } else {
      poke8(wAddr, ch);
    }
    i := i + 1;
  }
  
  // Build numeric string (letters converted to 2 digits)
  // Max: 34 chars * 2 = 68 digits
  numericStr := mmap(0, 80, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (numericStr == 0) {
    munmap(normalized, len + 1);
    munmap(rearranged, len + 1);
    return IBAN_ERR_INVALID_LENGTH;
  }
  
  var numPos: int64 := 0;
  
  // First: characters 4..end
  i := 4;
  while (i < len) {
    c := peek8(normalized + i);
    if (c >= 48 && c <= 57) {
      poke8(numericStr + numPos, c);
      numPos := numPos + 1;
    }
    else if (c >= 65 && c <= 90) {
      var val: int64 := c - 55;
      poke8(numericStr + numPos, 48 + (val / 10));
      numPos := numPos + 1;
      poke8(numericStr + numPos, 48 + (val - (val / 10) * 10));
      numPos := numPos + 1;
    }
    i := i + 1;
  }
  
  // Then: first 4 characters
  i := 0;
  while (i < 4) {
    c := peek8(normalized + i);
    if (c >= 65 && c <= 90) {
      var val: int64 := c - 55;
      poke8(numericStr + numPos, 48 + (val / 10));
      numPos := numPos + 1;
      poke8(numericStr + numPos, 48 + (val - (val / 10) * 10));
      numPos := numPos + 1;
    }
    else {
      poke8(numericStr + numPos, c);
      numPos := numPos + 1;
    }
    i := i + 1;
  }
  
  poke8(numericStr + numPos, 0);
  
  // Compute mod 97
  modResult := IBANMod97(numericStr);
  
  munmap(normalized, len + 1);
  munmap(rearranged, len + 1);
  munmap(numericStr, 80);
  
  if (modResult == 1) {
    return IBAN_OK;
  }
  
  return IBAN_ERR_INVALID_CHECK;
}

// Calculate IBAN checkD digits
// iban: IBAN string with checkD digits set to "00"
// Returns 2-digit checkD code as string, or 0 on error
pub fn IBANCalculateCheck(iban: int64): int64 {
  var normalized: int64;
  var len: int64;
  var numericStr: int64;
  var numPos: int64;
  var i: int64;
  var c: int64;
  var modResult: int64;
  var checkCode: int64;
  
  if (iban == 0) {
    return 0;
  }
  
  normalized := IBANNormalize(iban);
  if (normalized == 0) {
    return 0;
  }
  
  len := IBANStrLen(normalized);
  if (len < 5) {
    munmap(normalized, len + 1);
    return 0;
  }
  
  // Build numeric string with rearrangement
  numericStr := mmap(0, 80, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (numericStr == 0) {
    munmap(normalized, len + 1);
    return 0;
  }
  
  numPos := 0;
  
  // Characters 4..end first
  i := 4;
  while (i < len) {
    c := peek8(normalized + i);
    if (c >= 48 && c <= 57) {
      poke8(numericStr + numPos, c);
      numPos := numPos + 1;
    }
    else if (c >= 65 && c <= 90) {
      var val: int64 := c - 55;
      poke8(numericStr + numPos, 48 + (val / 10));
      numPos := numPos + 1;
      poke8(numericStr + numPos, 48 + (val - (val / 10) * 10));
      numPos := numPos + 1;
    }
    i := i + 1;
  }
  
  // First 2 characters (country code) as letters
  i := 0;
  while (i < 2) {
    c := peek8(normalized + i);
    if (c >= 65 && c <= 90) {
      var val: int64 := c - 55;
      poke8(numericStr + numPos, 48 + (val / 10));
      numPos := numPos + 1;
      poke8(numericStr + numPos, 48 + (val - (val / 10) * 10));
      numPos := numPos + 1;
    }
    i := i + 1;
  }
  
  // Add "00" for checkD digits
  poke8(numericStr + numPos, 48);
  numPos := numPos + 1;
  poke8(numericStr + numPos, 48);
  numPos := numPos + 1;
  
  poke8(numericStr + numPos, 0);
  
  // Compute mod 97
  modResult := IBANMod97(numericStr);
  
  munmap(numericStr, 80);
  
  // Check code = 98 - modResult
  var checkD: int64 := 98 - modResult;
  
  checkCode := mmap(0, 3, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (checkCode == 0) {
    munmap(normalized, len + 1);
    return 0;
  }
  
  poke8(checkCode, 48 + (checkD / 10));
  poke8(checkCode + 1, 48 + (checkD - (checkD / 10) * 10));
  poke8(checkCode + 2, 0);
  
  munmap(normalized, len + 1);
  return checkCode;
}

// Get country code from IBAN
// Returns pointer to 2-char country code string (allocated, caller must free)
pub fn IBANGetCountry(iban: int64): int64 {
  var normalized: int64;
  var country: int64;
  
  if (iban == 0) {
    return 0;
  }
  
  normalized := IBANNormalize(iban);
  if (normalized == 0) {
    return 0;
  }
  
  country := mmap(0, 3, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (country == 0) {
    munmap(normalized, IBANStrLen(iban) + 1);
    return 0;
  }
  
  poke8(country, peek8(normalized));
  poke8(country + 1, peek8(normalized + 1));
  poke8(country + 2, 0);
  
  munmap(normalized, IBANStrLen(iban) + 1);
  return country;
}

// Format IBAN with spaces (groups of 4)
// iban: IBAN string (normalized)
// Returns formatted string (e.g., "DE89 3704 0044 0532 0130 00"), caller must free
pub fn IBANFormat(iban: int64): int64 {
  var normalized: int64;
  var len: int64;
  var bufLen: int64;
  var buf: int64;
  var pos: int64;
  var i: int64;
  
  if (iban == 0) {
    return 0;
  }
  
  normalized := IBANNormalize(iban);
  if (normalized == 0) {
    return 0;
  }
  
  len := IBANStrLen(normalized);
  bufLen := len + (len / 4) + 2;
  buf := mmap(0, bufLen, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    munmap(normalized, len + 1);
    return 0;
  }
  
  pos := 0;
  i := 0;
  
  while (i < len) {
    if (i > 0 && (i - (i / 4) * 4) == 0) {
      poke8(buf + pos, 32);  // space
      pos := pos + 1;
    }
    poke8(buf + pos, peek8(normalized + i));
    pos := pos + 1;
    i := i + 1;
  }
  
  poke8(buf + pos, 0);
  
  munmap(normalized, len + 1);
  return buf;
}

// Extract bank identifier from IBAN
// Returns pointer to bank identifier string (allocated, caller must free)
pub fn IBANGetBankId(iban: int64): int64 {
  var normalized: int64;
  var len: int64;
  var bankLen: int64;
  var bankId: int64;
  var i: int64;
  var country: int64;
  var c1: int64;
  var c2: int64;
  
  if (iban == 0) {
    return 0;
  }
  
  normalized := IBANNormalize(iban);
  if (normalized == 0) {
    return 0;
  }
  
  len := IBANStrLen(normalized);
  
  // Get country to determine bank ID length
  c1 := peek8(normalized);
  c2 := peek8(normalized + 1);
  if (c1 >= 97) { c1 := c1 - 32; }
  if (c2 >= 97) { c2 := c2 - 32; }
  
  // Most countries: bank ID is at position 4-7 (4 chars)
  // Some countries have different layouts
  bankLen := 4;  // Default
  
  if (c1 == 68 && c2 == 69) { bankLen := 8; }  // DE: BLZ (8 digits)
  if (c1 == 71 && c2 == 66) { bankLen := 4; }  // GB: sort code (6, but 4 here)
  if (c1 == 70 && c2 == 82) { bankLen := 5; }  // FR: code banque (5)
  
  if (len < 4 + bankLen) {
    munmap(normalized, len + 1);
    return 0;
  }
  
  var bankSz: int64 := bankLen + 1;
  bankId := mmap(0, bankSz, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (bankId == 0) {
    munmap(normalized, len + 1);
    return 0;
  }
  
  i := 0;
  while (i < bankLen) {
    poke8(bankId + i, peek8(normalized + 4 + i));
    i := i + 1;
  }
  poke8(bankId + bankLen, 0);
  
  munmap(normalized, len + 1);
  return bankId;
}
