// Lyx ISBN/ISSN Module - Book Trade Identifiers
// Comprehensive ISBN-10, ISBN-13, and ISSN validation and conversion
//
// ISBN (International Standard Book Number):
// - ISBN-10: 10 digits (legacy, used until 2007)
// - ISBN-13: 13 digits (current standard, uses EAN-13 with 978/979 prefix)
//
// ISSN (International Standard Serial Number):
// - ISSN: 8 characters (XXXX-XXXX, last digit can be X)
//
// Usage:
//   import std.validate.isbn;
//   var valid: bool := ISBN13Validate("978-3-16-148410-0");
//   var isbn13: int64 := ISBN10To13("0-306-40615-2");
//   var formatted: int64 := ISBN13Format("9783161484100");
//   var issnValid: bool := ISSNValidate("0020-0255");

unit std.validate.isbn;

import std.validate.ean;

// Validation status
pub con ISBN_OK: int64 := 0;
pub con ISBN_ERR_INVALID_LENGTH: int64 := 1;
pub con ISBN_ERR_INVALID_CHAR: int64 := 2;
pub con ISBN_ERR_INVALID_CHECK: int64 := 3;
pub con ISBN_ERR_INVALID_PREFIX: int64 := 4;
pub con ISBN_ERR_CANNOT_CONVERT: int64 := 5;

// String length helper
pub fn ISBNStrLen(s: int64): int64 {
  var len: int64 := 0;
  if (s == 0) {
    return 0;
  }
  while (peek8(s + len) != 0) {
    len := len + 1;
  }
  return len;
}

// Check if character is a digit
pub fn ISBNIsDigit(c: int64): int64 {
  if (c >= 48 && c <= 57) {
    return 1;
  }
  return 0;
}

// Convert digit char to int
pub fn ISBNDigitToInt(c: int64): int64 {
  if (c >= 48 && c <= 57) {
    return c - 48;
  }
  return -1;
}

// Normalize ISBN string (remove hyphens, spaces, convert to uppercase)
// Returns pointer to allocated normalized string (caller must free)
pub fn ISBNNormalize(isbn: int64): int64 {
  var buf: int64;
  var pos: int64;
  var i: int64;
  var c: int64;
  var len: int64;
  
  if (isbn == 0) {
    return 0;
  }
  
  len := ISBNStrLen(isbn);
  var isbnBufSz: int64 := len + 1;
  buf := mmap(0, isbnBufSz, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    return 0;
  }
  
  pos := 0;
  i := 0;
  
  while (i < len) {
    c := peek8(isbn + i);
    
    // Skip hyphens and spaces
    if (c == 45 || c == 32) {  // '-' or ' '
      i := i + 1;
      continue;
    }
    
    // Convert lowercase to uppercase
    if (c >= 97 && c <= 122) {
      c := c - 32;
    }
    
    poke8(buf + pos, c);
    pos := pos + 1;
    i := i + 1;
  }
  
  poke8(buf + pos, 0);
  return buf;
}

// Count digits in string (ignoring hyphens/spaces)
pub fn ISBNCountDigits(isbn: int64): int64 {
  var count: int64 := 0;
  var i: int64 := 0;
  var c: int64;
  
  if (isbn == 0) {
    return 0;
  }
  
  while (i < 20) {
    c := peek8(isbn + i);
    if (c == 0) {
      break;
    }
    if (ISBNIsDigit(c) == 1 || c == 88 || c == 120) {  // digit or X/x
      count := count + 1;
    }
    i := i + 1;
  }
  
  return count;
}

// Validate ISBN-13 (with optional hyphens)
// isbn: ISBN-13 string (may contain hyphens)
// Returns ISBN_OK if valid
pub fn ISBN13ValidateFull(isbn: int64): int64 {
  var normalized: int64;
  var result: int64;
  
  if (isbn == 0) {
    return ISBN_ERR_INVALID_LENGTH;
  }
  
  // Check digit count
  if (ISBNCountDigits(isbn) != 13) {
    return ISBN_ERR_INVALID_LENGTH;
  }
  
  // Normalize
  normalized := ISBNNormalize(isbn);
  if (normalized == 0) {
    return ISBN_ERR_INVALID_LENGTH;
  }
  
  // Validate using EAN module
  result := EAN13Validate(normalized);
  munmap(normalized, ISBNStrLen(isbn) + 1);
  
  if (result != 0) {
    return ISBN_ERR_INVALID_CHECK;
  }
  
  return ISBN_OK;
}

// Validate ISBN-10 (with optional hyphens)
// isbn: ISBN-10 string (may contain hyphens, last char can be X)
// Returns ISBN_OK if valid
pub fn ISBN10ValidateFull(isbn: int64): int64 {
  var normalized: int64;
  var len: int64;
  var i: int64;
  var sum: int64;
  var d: int64;
  var c: int64;
  var checkD: int64;
  
  if (isbn == 0) {
    return ISBN_ERR_INVALID_LENGTH;
  }
  
  if (ISBNCountDigits(isbn) != 10) {
    return ISBN_ERR_INVALID_LENGTH;
  }
  
  normalized := ISBNNormalize(isbn);
  if (normalized == 0) {
    return ISBN_ERR_INVALID_LENGTH;
  }
  
  len := ISBNStrLen(normalized);
  
  // Calculate weighted sum
  sum := 0;
  i := 0;
  while (i < 9) {
    c := peek8(normalized + i);
    if (ISBNIsDigit(c) == 0) {
      munmap(normalized, len + 1);
      return ISBN_ERR_INVALID_CHAR;
    }
    d := ISBNDigitToInt(c);
    sum := sum + (d * (10 - i));
    i := i + 1;
  }
  
  // Check digit (can be X for 10)
  c := peek8(normalized + 9);
  if (c == 88) {  // 'X'
    d := 10;
  }
  else if (ISBNIsDigit(c) == 1) {
    d := ISBNDigitToInt(c);
  }
  else {
    munmap(normalized, len + 1);
    return ISBN_ERR_INVALID_CHAR;
  }
  
  sum := sum + d;
  
  munmap(normalized, len + 1);
  
  if ((sum - (sum / 11) * 11) != 0) {
    return ISBN_ERR_INVALID_CHECK;
  }
  
  return ISBN_OK;
}

// Calculate ISBN-13 checkD digit
// isbn: 12-digit string (without checkD digit)
// Returns checkD digit (0-9), or -1 on error
pub fn ISBN13CheckDigit(isbn: int64): int64 {
  var normalized: int64;
  var result: int64;
  
  normalized := ISBNNormalize(isbn);
  if (normalized == 0) {
    return -1;
  }
  
  result := EAN13CheckDigit(normalized);
  munmap(normalized, ISBNStrLen(isbn) + 1);
  
  return result;
}

// Calculate ISBN-10 checkD digit
// isbn: 9-digit string (without checkD digit)
// Returns checkD digit as char ('0'-'9' or 'X'), or 0 on error
pub fn ISBN10CheckDigitFull(isbn: int64): int64 {
  var normalized: int64;
  var sum: int64 := 0;
  var i: int64;
  var d: int64;
  var result: int64;
  
  normalized := ISBNNormalize(isbn);
  if (normalized == 0) {
    return 0;
  }
  
  i := 0;
  while (i < 9) {
    d := ISBNDigitToInt(peek8(normalized + i));
    if (d < 0) {
      munmap(normalized, ISBNStrLen(isbn) + 1);
      return 0;
    }
    sum := sum + (d * (10 - i));
    i := i + 1;
  }
  
  munmap(normalized, ISBNStrLen(isbn) + 1);
  
  var remainder: int64 := sum - (sum / 11) * 11;
  result := 11 - remainder;
  result := result - (result / 11) * 11;
  
  if (result == 10) {
    return 88;  // 'X'
  }
  
  return 48 + result;  // '0'-'9'
}

// Convert ISBN-10 to ISBN-13
// isbn10: 10-digit ISBN string (may contain hyphens)
// Returns allocated ISBN-13 string (13 digits, no hyphens), or 0 on error
pub fn ISBN10To13(isbn10: int64): int64 {
  var normalized: int64;
  var isbn13: int64;
  var i: int64;
  var checkD: int64;
  
  if (isbn10 == 0) {
    return 0;
  }
  
  if (ISBNCountDigits(isbn10) != 10) {
    return 0;
  }
  
  normalized := ISBNNormalize(isbn10);
  if (normalized == 0) {
    return 0;
  }
  
  isbn13 := mmap(0, 14, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (isbn13 == 0) {
    munmap(normalized, 11);
    return 0;
  }
  
  // Add 978 prefix
  poke8(isbn13, 57);      // '9'
  poke8(isbn13 + 1, 55);  // '7'
  poke8(isbn13 + 2, 56);  // '8'
  
  // Copy first 9 digits
  i := 0;
  while (i < 9) {
    poke8(isbn13 + 3 + i, peek8(normalized + i));
    i := i + 1;
  }
  
  munmap(normalized, 11);
  
  // Calculate new checkD digit
  checkD := EAN13CheckDigit(isbn13);
  if (checkD < 0) {
    munmap(isbn13, 14);
    return 0;
  }
  
  poke8(isbn13 + 12, 48 + checkD);
  poke8(isbn13 + 13, 0);
  
  return isbn13;
}

// Convert ISBN-13 to ISBN-10 (only possible for 978 prefix)
// isbn13: 13-digit ISBN string (may contain hyphens)
// Returns allocated ISBN-10 string (10 digits, no hyphens), or 0 on error
pub fn ISBN13To10(isbn13: int64): int64 {
  var normalized: int64;
  var isbn10: int64;
  var i: int64;
  var checkD: int64;
  var sum: int64;
  
  if (isbn13 == 0) {
    return 0;
  }
  
  if (ISBNCountDigits(isbn13) != 13) {
    return 0;
  }
  
  normalized := ISBNNormalize(isbn13);
  if (normalized == 0) {
    return 0;
  }
  
  // Check if prefix is 978 (only 978 can be converted to ISBN-10)
  if (peek8(normalized) != 57 || peek8(normalized + 1) != 55 || peek8(normalized + 2) != 56) {
    munmap(normalized, 14);
    return 0;  // 979 prefix cannot be converted
  }
  
  isbn10 := mmap(0, 11, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (isbn10 == 0) {
    munmap(normalized, 14);
    return 0;
  }
  
  // Copy digits 3-11 (skip 978 prefix)
  i := 0;
  while (i < 9) {
    poke8(isbn10 + i, peek8(normalized + 3 + i));
    i := i + 1;
  }
  
  munmap(normalized, 14);
  
  // Calculate ISBN-10 checkD digit
  sum := 0;
  i := 0;
  while (i < 9) {
    sum := sum + (ISBNDigitToInt(peek8(isbn10 + i)) * (10 - i));
    i := i + 1;
  }
  
  var remainder: int64 := sum - (sum / 11) * 11;
  checkD := 11 - remainder;
  checkD := checkD - (checkD / 11) * 11;
  
  if (checkD == 10) {
    poke8(isbn10 + 9, 88);  // 'X'
  } else {
    poke8(isbn10 + 9, 48 + checkD);
  }
  
  poke8(isbn10 + 10, 0);
  return isbn10;
}

// Format ISBN-13 with standard hyphens
// isbn: 13-digit ISBN string (normalized)
// Returns formatted string (e.g., "978-3-16-148410-0"), caller must free
pub fn ISBN13Format(isbn: int64): int64 {
  var normalized: int64;
  var buf: int64;
  var pos: int64;
  var i: int64;
  var len: int64;
  
  if (isbn == 0) {
    return 0;
  }
  
  normalized := ISBNNormalize(isbn);
  if (normalized == 0) {
    return 0;
  }
  
  len := ISBNStrLen(normalized);
  if (len < 13) {
    munmap(normalized, len + 1);
    return 0;
  }
  
  // Allocate buffer (13 digits + 4 hyphens + null = 18)
  buf := mmap(0, 18, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    munmap(normalized, len + 1);
    return 0;
  }
  
  pos := 0;
  
  // ISBN prefix (3 digits): 978 or 979
  i := 0;
  while (i < 3) {
    poke8(buf + pos, peek8(normalized + i));
    pos := pos + 1;
    i := i + 1;
  }
  poke8(buf + pos, 45);  // '-'
  pos := pos + 1;
  
  // Registration group (1 digit)
  poke8(buf + pos, peek8(normalized + 3));
  pos := pos + 1;
  poke8(buf + pos, 45);  // '-'
  pos := pos + 1;
  
  // Registrant + title (6 digits)
  i := 4;
  while (i < 10) {
    poke8(buf + pos, peek8(normalized + i));
    pos := pos + 1;
    i := i + 1;
  }
  poke8(buf + pos, 45);  // '-'
  pos := pos + 1;
  
  // Publication + checkD (3 digits)
  i := 10;
  while (i < 13) {
    poke8(buf + pos, peek8(normalized + i));
    pos := pos + 1;
    i := i + 1;
  }
  
  poke8(buf + pos, 0);
  
  munmap(normalized, len + 1);
  return buf;
}

// Format ISBN-10 with standard hyphens
// isbn: 10-digit ISBN string (normalized)
// Returns formatted string (e.g., "0-306-40615-2"), caller must free
pub fn ISBN10Format(isbn: int64): int64 {
  var normalized: int64;
  var buf: int64;
  var pos: int64;
  var i: int64;
  var len: int64;
  var groupLen: int64;
  
  if (isbn == 0) {
    return 0;
  }
  
  normalized := ISBNNormalize(isbn);
  if (normalized == 0) {
    return 0;
  }
  
  len := ISBNStrLen(normalized);
  if (len < 10) {
    munmap(normalized, len + 1);
    return 0;
  }
  
  // Determine group length based on first digit(s)
  // 0-1: English (1 digit)
  // 2: French (1 digit)
  // 3: German (1 digit)
  // 4: Japan (1 digit)
  // 5: Russian (1 digit, but 50- is USSR)
  // 7: China (1 digit)
  // 80-84: Czech/Slovak (2 digits)
  // 85-89: Brazil (2 digits)
  // 90-94: Netherlands (2 digits)
  // 950-989: Argentina (3 digits)
  // 99-999: Various (2-3 digits)
  
  var firstDigit: int64 := ISBNDigitToInt(peek8(normalized));
  
  groupLen := 1;  // Default: 1 digit
  if (firstDigit >= 8 && firstDigit <= 9) {
    // Check if second digit suggests 2-digit group
    var secondDigit: int64 := ISBNDigitToInt(peek8(normalized + 1));
    if (secondDigit >= 0 && secondDigit <= 9) {
      groupLen := 2;
    }
  }
  
  // Allocate buffer (10 digits + 3 hyphens + null = 14)
  buf := mmap(0, 14, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    munmap(normalized, len + 1);
    return 0;
  }
  
  pos := 0;
  
  // Group
  i := 0;
  while (i < groupLen) {
    poke8(buf + pos, peek8(normalized + i));
    pos := pos + 1;
    i := i + 1;
  }
  poke8(buf + pos, 45);  // '-'
  pos := pos + 1;
  
  // Registrant
  var regLen: int64 := 10 - groupLen - 2;  // remaining digits minus checkD
  i := groupLen;
  while (i < groupLen + regLen) {
    poke8(buf + pos, peek8(normalized + i));
    pos := pos + 1;
    i := i + 1;
  }
  poke8(buf + pos, 45);  // '-'
  pos := pos + 1;
  
  // Publication + checkD
  i := groupLen + regLen;
  while (i < 10) {
    poke8(buf + pos, peek8(normalized + i));
    pos := pos + 1;
    i := i + 1;
  }
  
  poke8(buf + pos, 0);
  
  munmap(normalized, len + 1);
  return buf;
}

// Validate ISSN (International Standard Serial Number)
// issn: 8-character string (XXXX-XXXX, last can be X)
// Returns ISBN_OK if valid
pub fn ISSNValidate(issn: int64): int64 {
  var normalized: int64;
  var len: int64;
  var i: int64;
  var sum: int64;
  var d: int64;
  var c: int64;
  var checkD: int64;
  
  if (issn == 0) {
    return ISBN_ERR_INVALID_LENGTH;
  }
  
  normalized := ISBNNormalize(issn);
  if (normalized == 0) {
    return ISBN_ERR_INVALID_LENGTH;
  }
  
  len := ISBNStrLen(normalized);
  if (len != 8) {
    munmap(normalized, len + 1);
    return ISBN_ERR_INVALID_LENGTH;
  }
  
  // First 4 must be digits
  i := 0;
  while (i < 4) {
    if (ISBNIsDigit(peek8(normalized + i)) == 0) {
      munmap(normalized, len + 1);
      return ISBN_ERR_INVALID_CHAR;
    }
    i := i + 1;
  }
  
  // Position 4 should be hyphen (or digit if normalized without hyphen)
  // We normalized without hyphens, so all 8 are digits/X
  
  // Last char can be X or digit
  c := peek8(normalized + 7);
  if (c != 88 && ISBNIsDigit(c) == 0) {
    munmap(normalized, len + 1);
    return ISBN_ERR_INVALID_CHAR;
  }
  
  // Calculate checkD digit (same as ISBN-10)
  sum := 0;
  i := 0;
  while (i < 7) {
    d := ISBNDigitToInt(peek8(normalized + i));
    sum := sum + (d * (8 - i));
    i := i + 1;
  }
  
  // Check digit
  c := peek8(normalized + 7);
  if (c == 88) {
    d := 10;
  } else {
    d := ISBNDigitToInt(c);
  }
  
  sum := sum + d;
  
  munmap(normalized, len + 1);
  
  if ((sum - (sum / 11) * 11) != 0) {
    return ISBN_ERR_INVALID_CHECK;
  }
  
  return ISBN_OK;
}

// Calculate ISSN checkD digit
// issn: 7-digit string (without checkD digit)
// Returns checkD digit as char ('0'-'9' or 'X'), or 0 on error
pub fn ISSNCheckDigit(issn: int64): int64 {
  var sum: int64 := 0;
  var i: int64;
  var d: int64;
  var result: int64;
  
  if (issn == 0) {
    return 0;
  }
  
  i := 0;
  while (i < 7) {
    d := ISBNDigitToInt(peek8(issn + i));
    if (d < 0) {
      return 0;
    }
    sum := sum + (d * (8 - i));
    i := i + 1;
  }
  
  var remainder: int64 := sum - (sum / 11) * 11;
  result := 11 - remainder;
  result := result - (result / 11) * 11;
  
  if (result == 10) {
    return 88;  // 'X'
  }
  
  return 48 + result;
}

// Format ISSN with hyphen
// issn: 8-character string (normalized)
// Returns formatted string "XXXX-XXXX", caller must free
pub fn ISSNFormat(issn: int64): int64 {
  var normalized: int64;
  var buf: int64;
  var i: int64;
  var len: int64;
  
  if (issn == 0) {
    return 0;
  }
  
  normalized := ISBNNormalize(issn);
  if (normalized == 0) {
    return 0;
  }
  
  len := ISBNStrLen(normalized);
  if (len < 8) {
    munmap(normalized, len + 1);
    return 0;
  }
  
  buf := mmap(0, 10, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    munmap(normalized, len + 1);
    return 0;
  }
  
  // XXXX-XXXX
  i := 0;
  while (i < 4) {
    poke8(buf + i, peek8(normalized + i));
    i := i + 1;
  }
  poke8(buf + 4, 45);  // '-'
  i := 4;
  while (i < 8) {
    poke8(buf + i + 1, peek8(normalized + i));
    i := i + 1;
  }
  poke8(buf + 9, 0);
  
  munmap(normalized, len + 1);
  return buf;
}

// Detect ISBN/ISSN type from string
// Returns: 10 = ISBN-10, 13 = ISBN-13, 8 = ISSN, 0 = unknown
pub fn ISBNDetectType(isbn: int64): int64 {
  var digitCount: int64;
  var normalized: int64;
  var result: int64;
  
  if (isbn == 0) {
    return 0;
  }
  
  digitCount := ISBNCountDigits(isbn);
  
  if (digitCount == 13) {
    return 13;
  }
  
  if (digitCount == 10) {
    return 10;
  }
  
  if (digitCount == 8) {
    normalized := ISBNNormalize(isbn);
    if (normalized != 0) {
      // Check if it looks like ISSN (8 digits, last can be X)
      if (ISSNValidate(normalized) == ISBN_OK) {
        munmap(normalized, 9);
        return 8;
      }
      munmap(normalized, 9);
    }
  }
  
  return 0;
}
