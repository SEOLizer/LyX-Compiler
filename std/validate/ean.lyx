// Lyx Business Validations Module
// Validations for business identifiers (EAN, ISBN, UPC, etc.)
//
// Usage:
//   import std.validate.ean;
//   var valid: bool := EAN13Validate("4006381333931");
//   var check: int64 := EAN13CheckDigit("400638133393");
//   var formatted: pchar := EAN13Format("4006381333931");

unit std.validate.ean;

// EAN validation status
pub con EAN_OK: int64 := 0;
pub con EAN_ERR_INVALID_LENGTH: int64 := 1;
pub con EAN_ERR_INVALID_CHAR: int64 := 2;
pub con EAN_ERR_INVALID_CHECK: int64 := 3;

// String length helper
pub fn EANStrLen(s: int64): int64 {
  var len: int64 := 0;
  if (s == 0) {
    return 0;
  }
  while (peek8(s + len) != 0) {
    len := len + 1;
  }
  return len;
}

// Check if character is a digit (0-9)
pub fn EANIsDigit(c: int64): int64 {
  if (c >= 48 && c <= 57) {
    return 1;
  }
  return 0;
}

// Convert digit character to integer
pub fn EANDigitToInt(c: int64): int64 {
  if (c >= 48 && c <= 57) {
    return c - 48;
  }
  return -1;
}

// Calculate EAN-13 check digit
// code: 12-digit string (without check digit)
// Returns check digit (0-9), or -1 on error
pub fn EAN13CheckDigit(code: int64): int64 {
  var sum: int64 := 0;
  var i: int64;
  var d: int64;
  var weight: int64;
  
  if (code == 0) {
    return -1;
  }
  
  // Must be exactly 12 digits
  i := 0;
  while (i < 12) {
    d := EANDigitToInt(peek8(code + i));
    if (d < 0) {
      return -1;
    }
    
    // Weight: 1 for positions 0,2,4,... (odd positions from right)
    //         3 for positions 1,3,5,... (even positions from right)
    // Since we read left to right: position 0 (leftmost) has weight 1
    //                               position 1 has weight 3
    //                               position 2 has weight 1, etc.
    if ((i - (i / 2) * 2) == 0) {
      weight := 1;
    } else {
      weight := 3;
    }
    
    sum := sum + (d * weight);
    i := i + 1;
  }
  
  // Check digit = (10 - (sum mod 10)) mod 10
  var remainder: int64 := sum - (sum / 10) * 10;
  var check: int64 := 10 - remainder;
  check := check - (check / 10) * 10;
  
  return check;
}

// Calculate EAN-8 check digit
// code: 7-digit string (without check digit)
// Returns check digit (0-9), or -1 on error
pub fn EAN8CheckDigit(code: int64): int64 {
  var sum: int64 := 0;
  var i: int64;
  var d: int64;
  var weight: int64;
  
  if (code == 0) {
    return -1;
  }
  
  // Must be exactly 7 digits
  i := 0;
  while (i < 7) {
    d := EANDigitToInt(peek8(code + i));
    if (d < 0) {
      return -1;
    }
    
    if ((i - (i / 2) * 2) == 0) {
      weight := 3;
    } else {
      weight := 1;
    }
    
    sum := sum + (d * weight);
    i := i + 1;
  }
  
  var remainder: int64 := sum - (sum / 10) * 10;
  var check: int64 := 10 - remainder;
  check := check - (check / 10) * 10;
  
  return check;
}

// Validate EAN-13 code
// code: 13-digit string
// Returns EAN_OK if valid, or error code
pub fn EAN13Validate(code: int64): int64 {
  var len: int64;
  var i: int64;
  var d: int64;
  var expectedCheck: int64;
  var actualCheck: int64;
  
  if (code == 0) {
    return EAN_ERR_INVALID_LENGTH;
  }
  
  len := EANStrLen(code);
  if (len != 13) {
    return EAN_ERR_INVALID_LENGTH;
  }
  
  // Check all characters are digits
  i := 0;
  while (i < 13) {
    if (EANIsDigit(peek8(code + i)) == 0) {
      return EAN_ERR_INVALID_CHAR;
    }
    i := i + 1;
  }
  
  // Calculate expected check digit from first 12 digits
  expectedCheck := EAN13CheckDigit(code);
  if (expectedCheck < 0) {
    return EAN_ERR_INVALID_CHAR;
  }
  
  // Get actual check digit (last digit)
  actualCheck := EANDigitToInt(peek8(code + 12));
  
  if (expectedCheck != actualCheck) {
    return EAN_ERR_INVALID_CHECK;
  }
  
  return EAN_OK;
}

// Validate EAN-8 code
// code: 8-digit string
// Returns EAN_OK if valid, or error code
pub fn EAN8Validate(code: int64): int64 {
  var len: int64;
  var i: int64;
  var expectedCheck: int64;
  var actualCheck: int64;
  
  if (code == 0) {
    return EAN_ERR_INVALID_LENGTH;
  }
  
  len := EANStrLen(code);
  if (len != 8) {
    return EAN_ERR_INVALID_LENGTH;
  }
  
  // Check all characters are digits
  i := 0;
  while (i < 8) {
    if (EANIsDigit(peek8(code + i)) == 0) {
      return EAN_ERR_INVALID_CHAR;
    }
    i := i + 1;
  }
  
  // Calculate expected check digit
  expectedCheck := EAN8CheckDigit(code);
  if (expectedCheck < 0) {
    return EAN_ERR_INVALID_CHAR;
  }
  
  // Get actual check digit
  actualCheck := EANDigitToInt(peek8(code + 7));
  
  if (expectedCheck != actualCheck) {
    return EAN_ERR_INVALID_CHECK;
  }
  
  return EAN_OK;
}

// Validate EAN-14 code (GTIN-14)
// code: 14-digit string
// Returns EAN_OK if valid, or error code
pub fn EAN14Validate(code: int64): int64 {
  var len: int64;
  var i: int64;
  var sum: int64;
  var d: int64;
  var weight: int64;
  var expectedCheck: int64;
  var actualCheck: int64;
  
  if (code == 0) {
    return EAN_ERR_INVALID_LENGTH;
  }
  
  len := EANStrLen(code);
  if (len != 14) {
    return EAN_ERR_INVALID_LENGTH;
  }
  
  // Check all characters are digits
  i := 0;
  while (i < 14) {
    if (EANIsDigit(peek8(code + i)) == 0) {
      return EAN_ERR_INVALID_CHAR;
    }
    i := i + 1;
  }
  
  // Calculate check digit (same algorithm as EAN-13 but with 13 digits)
  sum := 0;
  i := 0;
  while (i < 13) {
    d := EANDigitToInt(peek8(code + i));
    if ((i - (i / 2) * 2) == 0) {
      weight := 3;
    } else {
      weight := 1;
    }
    sum := sum + (d * weight);
    i := i + 1;
  }
  
  var remainder: int64 := sum - (sum / 10) * 10;
  expectedCheck := 10 - remainder;
  expectedCheck := expectedCheck - (expectedCheck / 10) * 10;
  
  actualCheck := EANDigitToInt(peek8(code + 13));
  
  if (expectedCheck != actualCheck) {
    return EAN_ERR_INVALID_CHECK;
  }
  
  return EAN_OK;
}

// Validate ISBN-13 code
// ISBN-13 uses EAN-13 format, must start with 978 or 979
// code: 13-digit string
// Returns EAN_OK if valid, or error code
pub fn ISBN13Validate(code: int64): int64 {
  var len: int64;
  var eanResult: int64;
  var prefix: int64;
  
  // First validate as EAN-13
  eanResult := EAN13Validate(code);
  if (eanResult != EAN_OK) {
    return eanResult;
  }
  
  // Check prefix (978 or 979)
  prefix := (EANDigitToInt(peek8(code)) * 100) + 
            (EANDigitToInt(peek8(code + 1)) * 10) + 
            EANDigitToInt(peek8(code + 2));
  
  if (prefix != 978 && prefix != 979) {
    return EAN_ERR_INVALID_CHAR;
  }
  
  return EAN_OK;
}

// Validate ISBN-10 code (legacy format)
// code: 10-digit string (last digit can be 'X' for 10)
// Returns EAN_OK if valid, or error code
pub fn ISBN10Validate(code: int64): int64 {
  var len: int64;
  var i: int64;
  var d: int64;
  var sum: int64;
  var c: int64;
  
  if (code == 0) {
    return EAN_ERR_INVALID_LENGTH;
  }
  
  len := EANStrLen(code);
  if (len != 10) {
    return EAN_ERR_INVALID_LENGTH;
  }
  
  // Calculate weighted sum
  sum := 0;
  i := 0;
  while (i < 9) {
    c := peek8(code + i);
    if (EANIsDigit(c) == 0) {
      return EAN_ERR_INVALID_CHAR;
    }
    d := EANDigitToInt(c);
    sum := sum + (d * (10 - i));
    i := i + 1;
  }
  
  // Last digit can be 0-9 or 'X' (10)
  c := peek8(code + 9);
  if (c == 88 || c == 120) {  // 'X' or 'x'
    d := 10;
  }
  else if (EANIsDigit(c) == 1) {
    d := EANDigitToInt(c);
  }
  else {
    return EAN_ERR_INVALID_CHAR;
  }
  
  sum := sum + d;
  
  // Sum must be divisible by 11
  if ((sum - (sum / 11) * 11) != 0) {
    return EAN_ERR_INVALID_CHECK;
  }
  
  return EAN_OK;
}

// Calculate ISBN-10 check digit
// code: 9-digit string (without check digit)
// Returns check digit as character ('0'-'9' or 'X'), or 0 on error
pub fn ISBN10CheckDigit(code: int64): int64 {
  var sum: int64 := 0;
  var i: int64;
  var d: int64;
  
  if (code == 0) {
    return 0;
  }
  
  i := 0;
  while (i < 9) {
    d := EANDigitToInt(peek8(code + i));
    if (d < 0) {
      return 0;
    }
    sum := sum + (d * (10 - i));
    i := i + 1;
  }
  
  var remainder: int64 := sum - (sum / 11) * 11;
  var check: int64 := 11 - remainder;
  check := check - (check / 11) * 11;
  
  if (check == 10) {
    return 88;  // 'X'
  }
  
  return 48 + check;  // '0'-'9'
}

// Validate UPC-A code (12 digits, used in North America)
// UPC-A is essentially EAN-13 with leading zero
// code: 12-digit string
// Returns EAN_OK if valid, or error code
pub fn UPCAValidate(code: int64): int64 {
  var len: int64;
  var i: int64;
  var sum: int64;
  var d: int64;
  var weight: int64;
  var expectedCheck: int64;
  var actualCheck: int64;
  
  if (code == 0) {
    return EAN_ERR_INVALID_LENGTH;
  }
  
  len := EANStrLen(code);
  if (len != 12) {
    return EAN_ERR_INVALID_LENGTH;
  }
  
  i := 0;
  while (i < 12) {
    if (EANIsDigit(peek8(code + i)) == 0) {
      return EAN_ERR_INVALID_CHAR;
    }
    i := i + 1;
  }
  
  // UPC-A check digit algorithm (same as EAN-13 with 11 data digits)
  sum := 0;
  i := 0;
  while (i < 11) {
    d := EANDigitToInt(peek8(code + i));
    if ((i - (i / 2) * 2) == 0) {
      weight := 3;
    } else {
      weight := 1;
    }
    sum := sum + (d * weight);
    i := i + 1;
  }
  
  var remainder: int64 := sum - (sum / 10) * 10;
  expectedCheck := 10 - remainder;
  expectedCheck := expectedCheck - (expectedCheck / 10) * 10;
  
  actualCheck := EANDigitToInt(peek8(code + 11));
  
  if (expectedCheck != actualCheck) {
    return EAN_ERR_INVALID_CHECK;
  }
  
  return EAN_OK;
}

// Format EAN-13 with spaces for readability
// code: 13-digit string
// Returns formatted string: "XXX XXXXXXX XXX" (caller must free)
pub fn EAN13Format(code: int64): int64 {
  var buf: int64;
  var pos: int64;
  var i: int64;
  var len: int64;
  
  if (code == 0) {
    return 0;
  }
  
  len := EANStrLen(code);
  if (len < 13) {
    return 0;
  }
  
  buf := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    return 0;
  }
  
  pos := 0;
  
  // Group 1: 3 digits
  i := 0;
  while (i < 3) {
    poke8(buf + pos, peek8(code + i));
    pos := pos + 1;
    i := i + 1;
  }
  poke8(buf + pos, 32);  // space
  pos := pos + 1;
  
  // Group 2: 7 digits
  i := 3;
  while (i < 10) {
    poke8(buf + pos, peek8(code + i));
    pos := pos + 1;
    i := i + 1;
  }
  poke8(buf + pos, 32);  // space
  pos := pos + 1;
  
  // Group 3: 3 digits (including check digit)
  i := 10;
  while (i < 13) {
    poke8(buf + pos, peek8(code + i));
    pos := pos + 1;
    i := i + 1;
  }
  
  poke8(buf + pos, 0);
  return buf;
}

// Format EAN-8 with spaces
// code: 8-digit string
// Returns formatted string: "XXXX XXXX" (caller must free)
pub fn EAN8Format(code: int64): int64 {
  var buf: int64;
  var pos: int64;
  var i: int64;
  var len: int64;
  
  if (code == 0) {
    return 0;
  }
  
  len := EANStrLen(code);
  if (len < 8) {
    return 0;
  }
  
  buf := mmap(0, 10, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    return 0;
  }
  
  pos := 0;
  
  // Group 1: 4 digits
  i := 0;
  while (i < 4) {
    poke8(buf + pos, peek8(code + i));
    pos := pos + 1;
    i := i + 1;
  }
  poke8(buf + pos, 32);  // space
  pos := pos + 1;
  
  // Group 2: 4 digits
  i := 4;
  while (i < 8) {
    poke8(buf + pos, peek8(code + i));
    pos := pos + 1;
    i := i + 1;
  }
  
  poke8(buf + pos, 0);
  return buf;
}

