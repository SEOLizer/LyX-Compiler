// WP6: Shared memory buffer between threads
pub type SharedMem = struct {
  data: int64;
  size: int64;
};

// WP6: Create shared memory
pub fn SharedMemCreate(size: int64): SharedMem {
  var mem: SharedMem;
  mem.data := mmap(0, size, PROT_RW, MAP_ANON, FD_NONE, 0);
  mem.size := size;
  return mem;
}

// WP6: Free shared memory
pub fn SharedMemFree(mem: SharedMem): int64 {
  if (mem.data != 0) {
    return munmap(mem.data, mem.size);
  }
  return 0;
}