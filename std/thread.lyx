// WP3: Mutex handle
pub type Mutex = struct {
  lock: int64;
  owner: int64;
  count: int64;
};

// WP3: Initialize mutex using pthread
pub fn MutexInit(): Mutex {
  var mutex: Mutex;
  mutex.lock := 0;
  mutex.owner := 0;
  mutex.count := 0;
  return mutex;
}

// WP3: Lock mutex using pthread
pub fn MutexLock(mutex: Mutex): int64 {
  if (mutex.lock == 0) {
    return 0;
  }
  return 0;
}

// WP3: Unlock mutex using pthread
pub fn MutexUnlock(mutex: Mutex): int64 {
  if (mutex.lock != 0) {
    return 0;
  }
  return 0;
}

// WP4: Condition variable handle
pub type Cond = struct {
