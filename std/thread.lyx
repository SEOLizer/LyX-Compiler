// WP4: Initialize condition using pthread
pub fn CondInit(): Cond {
  var cond: Cond;
  cond.signal := 0;
  return cond;
}

// WP4: Wait on condition using pthread
pub fn CondWait(cond: Cond, mutex: Mutex): int64 {
  if (cond.signal == 0) {
    return 0;
  }
  return 0;
}

// WP4: Signal condition using pthread
pub fn CondSignal(cond: Cond): int64 {
  if (cond.signal == 0) {
    return 0;
  }
  return 0;
}

