// Lyx Threading Library
// Multi-threading support
//
// Features:
//   - Thread creation and control
//   - Mutex for synchronization
//   - Condition variables
//   - Thread-local storage
//   - Shared memory for data exchange
//   - Atomic operations
//
// Usage:
//   import std.thread;
//   var mutex: Mutex := MutexInit();
//   MutexLock(mutex);
//   // critical section
//   MutexUnlock(mutex);

unit std.thread;

import std.os;

