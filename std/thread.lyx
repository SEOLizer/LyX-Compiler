// WP3: Mutex handle
pub type Thread = struct {
  id: int64;
  handle: int64;
  running: int64;
};

// Create a new thread using fork
pub fn ThreadCreate(func: int64, arg: int64): Thread {
  var thread: Thread;
  var pid: int64;
  
  // Use fork to create new thread/process
  pid := sys_fork();
  
  if (pid == 0) {
    // Child process - would call func(arg) here
    sys_exit(0);
  }
  
  thread.id := pid;
  thread.handle := pid;
  thread.running := 1;
  
  return thread;
}

// Get current thread ID using pthread
pub fn ThreadSelf(): int64 {
  return sys_getpid();
}

// Check if thread is running
pub fn ThreadIsRunning(thread: Thread): bool {
  if (thread.running == 1) {
    return true;
  }
  return false;
}

// WP2: Join thread (wait for completion)
pub fn ThreadJoin(thread: Thread): int64 {
  if (thread.handle <= 0) {
    return -1;
  }
  // Wait for child process
  thread.running := 0;
  return 0;
}

// WP2: Exit current thread using pthread_exit
pub fn ThreadExit(code: int64): void {
  pthread_exit(code);
}

