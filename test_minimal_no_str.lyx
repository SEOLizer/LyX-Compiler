// Very minimal test - no string functions
fn main(): int64 {
  var buf: int64 := mmap(0, 32, 3, 34, -1, 0);
  
  // Just use peek8 - no StrSub, no StrCharAt
  poke8(buf + 0, 65);
  poke8(buf + 1, 66);
  poke8(buf + 2, 67);
  
  PrintStr("peek8: ");
  PrintInt(peek8(buf + 0));
  PrintStr(" ");
  PrintInt(peek8(buf + 1));
  PrintStr(" ");
  PrintInt(peek8(buf + 2));
  PrintStr("\n");
  
  munmap(buf, 32);
  return 0;
}