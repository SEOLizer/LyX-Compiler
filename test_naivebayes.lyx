// Test: Naive Bayes Classifier
// Demonstrates text classification with word counts

import std.io;
import std.ml;

extern fn mmap(addr: int64, len: int64, prot: int64, flags: int64, fd: int64, offset: int64): int64;
extern fn munmap(addr: int64, len: int64): int64;

con PROT_RW: int64 := 3;
con MAP_ANON: int64 := 32;
con FD_NONE: int64 := -1;

pub fn main(): int64 {
  PrintStr("=== Test: Naive Bayes Classifier ===\n\n");
  
  // Simple vocabulary
  // 0:free, 1:win, 2:money, 3:prize, 4:click
  // 5:meeting, 6:project, 7:deadline, 8:report, 9:team
  var vocabSize: int64 := 10;
  var nClasses: int64 := 2;
  var nDocs: int64 := 6;
  
  NaiveBayesInit(nClasses, vocabSize);
  
  // Training data
  // Doc 0: Class 0 (spam) - "free money prize click"
  // Doc 1: Class 0 (spam) - "free prize win click"
  // Doc 2: Class 0 (spam) - "free money win"
  
  // Doc 3: Class 1 (ham) - "meeting project deadline report team"
  // Doc 4: Class 1 (ham) - "meeting team project"
  // Doc 5: Class 1 (ham) - "project deadline team report"
  
  var documents: int64 := mmap(0, 6 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  var docLengths: int64 := mmap(0, 6 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  var labels: int64 := mmap(0, 6 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  
  // Doc 0: free money prize click
  var doc0: int64 := mmap(0, 4 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  poke8(doc0 + 0, 0);  // free
  poke8(doc0 + 8, 2); // money
  poke8(doc0 + 16, 3); // prize
  poke8(doc0 + 24, 4); // click
  poke8(documents + 0 * 8, doc0);
  poke8(docLengths + 0 * 8, 4);
  poke8(labels + 0 * 8, 0);  // spam
  
  // Doc 1: free prize win click
  var doc1: int64 := mmap(0, 4 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  poke8(doc1 + 0, 0);  // free
  poke8(doc1 + 8, 3); // prize
  poke8(doc1 + 16, 1); // win
  poke8(doc1 + 24, 4); // click
  poke8(documents + 1 * 8, doc1);
  poke8(docLengths + 1 * 8, 4);
  poke8(labels + 1 * 8, 0);  // spam
  
  // Doc 2: free money win
  var doc2: int64 := mmap(0, 3 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  poke8(doc2 + 0, 0);  // free
  poke8(doc2 + 8, 2); // money
  poke8(doc2 + 16, 1); // win
  poke8(documents + 2 * 8, doc2);
  poke8(docLengths + 2 * 8, 3);
  poke8(labels + 2 * 8, 0);  // spam
  
  // Doc 3: meeting project deadline report team
  var doc3: int64 := mmap(0, 5 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  poke8(doc3 + 0, 5);  // meeting
  poke8(doc3 + 8, 6); // project
  poke8(doc3 + 16, 7); // deadline
  poke8(doc3 + 24, 8); // report
  poke8(doc3 + 32, 9); // team
  poke8(documents + 3 * 8, doc3);
  poke8(docLengths + 3 * 8, 5);
  poke8(labels + 3 * 8, 1);  // ham
  
  // Doc 4: meeting team project
  var doc4: int64 := mmap(0, 3 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  poke8(doc4 + 0, 5);  // meeting
  poke8(doc4 + 8, 9); // team
  poke8(doc4 + 16, 6); // project
  poke8(documents + 4 * 8, doc4);
  poke8(docLengths + 4 * 8, 3);
  poke8(labels + 4 * 8, 1);  // ham
  
  // Doc 5: project deadline team report
  var doc5: int64 := mmap(0, 4 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  poke8(doc5 + 0, 6);  // project
  poke8(doc5 + 8, 7); // deadline
  poke8(doc5 + 16, 9); // team
  poke8(doc5 + 24, 8); // report
  poke8(documents + 5 * 8, doc5);
  poke8(docLengths + 5 * 8, 4);
  poke8(labels + 5 * 8, 1);  // ham
  
  PrintStr("Train on 6 documents\n");
  PrintStr("Classes: 0=spam, 1=ham\n\n");
  
  // Train
  NaiveBayesFit(documents, docLengths, labels, nDocs);
  
  PrintStr("Class counts:\n");
  PrintStr("  Spam: ");
  PrintInt(NaiveBayesGetClassCount(0));
  PrintStr("\n");
  PrintStr("  Ham: ");
  PrintInt(NaiveBayesGetClassCount(1));
  PrintStr("\n\n");
  
  // Test predictions
  PrintStr("--- Predictions ---\n");
  
  // Test: "free win prize"
  var test1: int64 := mmap(0, 3 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  poke8(test1 + 0, 0);  // free
  poke8(test1 + 8, 1); // win
  poke8(test1 + 16, 3); // prize
  var pred1: int64 := NaiveBayesPredict(test1, 3);
  PrintStr("Predict 'free win prize': ");
  if (pred1 == 0) { PrintStr("SPAM"); }
  else { PrintStr("HAM"); }
  PrintStr("\n");
  
  // Test: "meeting deadline"
  var test2: int64 := mmap(0, 2 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  poke8(test2 + 0, 5);  // meeting
  poke8(test2 + 8, 7); // deadline
  var pred2: int64 := NaiveBayesPredict(test2, 2);
  PrintStr("Predict 'meeting deadline': ");
  if (pred2 == 0) { PrintStr("SPAM"); }
  else { PrintStr("HAM"); }
  PrintStr("\n");
  
  // Test: "team project meeting"
  var test3: int64 := mmap(0, 3 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  poke8(test3 + 0, 9);  // team
  poke8(test3 + 8, 6); // project
  poke8(test3 + 16, 5); // meeting
  var pred3: int64 := NaiveBayesPredict(test3, 3);
  PrintStr("Predict 'team project meeting': ");
  if (pred3 == 0) { PrintStr("SPAM"); }
  else { PrintStr("HAM"); }
  PrintStr("\n");
  
  // Test: "free click money prize win"
  var test4: int64 := mmap(0, 5 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  poke8(test4 + 0, 0);  // free
  poke8(test4 + 8, 4); // click
  poke8(test4 + 16, 2); // money
  poke8(test4 + 24, 3); // prize
  poke8(test4 + 32, 1); // win
  var pred4: int64 := NaiveBayesPredict(test4, 5);
  PrintStr("Predict 'free click money prize win': ");
  if (pred4 == 0) { PrintStr("SPAM"); }
  else { PrintStr("HAM"); }
  PrintStr("\n\n");
  
  // Score
  var score: f64 := NaiveBayesScore(documents, docLengths, labels, nDocs);
  PrintStr("Training accuracy: ");
  PrintFloat(score * 100.0);
  PrintStr("%\n\n");
  
  // Test Bernoulli Naive Bayes
  PrintStr("--- Bernoulli Naive Bayes ---\n");
  NaiveBayesBernoulliInit(nClasses, vocabSize);
  NaiveBayesBernoulliFit(documents, docLengths, labels, nDocs);
  
  var predB: int64 := NaiveBayesBernoulliPredict(test1, 3);
  PrintStr("Bernoulli 'free win prize': ");
  if (predB == 0) { PrintStr("SPAM"); }
  else { PrintStr("HAM"); }
  PrintStr("\n");
  
  predB := NaiveBayesBernoulliPredict(test2, 2);
  PrintStr("Bernoulli 'meeting deadline': ");
  if (predB == 0) { PrintStr("SPAM"); }
  else { PrintStr("HAM"); }
  PrintStr("\n");
  
  // Cleanup
  munmap(doc0, 4 * 8);
  munmap(doc1, 4 * 8);
  munmap(doc2, 3 * 8);
  munmap(doc3, 5 * 8);
  munmap(doc4, 3 * 8);
  munmap(doc5, 4 * 8);
  munmap(documents, 6 * 8);
  munmap(docLengths, 6 * 8);
  munmap(labels, 6 * 8);
  munmap(test1, 3 * 8);
  munmap(test2, 2 * 8);
  munmap(test3, 3 * 8);
  munmap(test4, 5 * 8);
  
  PrintStr("\n=== Naive Bayes Test Complete ===\n");
  return 0;
}