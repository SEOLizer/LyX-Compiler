// test_ml_arrays.lyx - ML Test (Basic Version)
// This test uses the basic std.ml which supports 1-2 data points

import std.io;
import std.ml;

pub fn main(): int64 {
  PrintStr("=== ML Test (Basic Version) ===\n");
  
  // Test 1: Statistics with 2 values
  PrintStr("\n[Test 1] Statistics\n");
  var mean: f64 := Mean2(4.0, 6.0);
  var varianz: f64 := Variance2(4.0, 6.0);
  var stddev: f64 := StdDev2(4.0, 6.0);
  
  PrintStr("Mean2(4,6) = ");
  PrintFloat(mean);
  PrintStr("\n");
  PrintStr("Variance2(4,6) = ");
  PrintFloat(varianz);
  PrintStr("\n");
  PrintStr("StdDev2(4,6) = ");
  PrintFloat(stddev);
  PrintStr("\n");
  
  // Test 2: Loss Metrics
  PrintStr("\n[Test 2] Loss Metrics\n");
  var mse: f64 := MSE2(3.0, 5.0, 3.1, 4.9);
  var mae: f64 := MAE2(3.0, 5.0, 3.1, 4.9);
  var r2: f64 := R2Score2(3.0, 5.0, 3.0, 5.0);
  
  PrintStr("MSE2 = ");
  PrintFloat(mse);
  PrintStr("\nMAE2 = ");
  PrintFloat(mae);
  PrintStr("\nR2Score2 = ");
  PrintFloat(r2);
  PrintStr("\n");
  
  // Test 3: Normalization
  PrintStr("\n[Test 3] Normalization\n");
  var norm: f64 := MinMaxNorm(5.0, 0.0, 10.0);
  var zscore: f64 := ZScoreNorm(5.0, 2.0, 2.0);
  
  PrintStr("MinMaxNorm(5,0,10) = ");
  PrintFloat(norm);
  PrintStr("\nZScoreNorm(5,2,2) = ");
  PrintFloat(zscore);
  PrintStr("\n");
  
  // Test 4: Train/Test Split
  PrintStr("\n[Test 4] Train/Test Split\n");
  var i: int64 := 0;
  while (i < 4) {
    var split: int64 := TrainTestSplit(i);
    PrintStr("Split(");
    PrintInt(i);
    PrintStr(") = ");
    if (split == 0) { PrintStr("train"); }
    else { PrintStr("test"); }
    PrintStr("\n");
    i := i + 1;
  }
  
  PrintStr("\n=== Done ===\n");
  
  return 0;
}