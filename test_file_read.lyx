// Test: use mmap directly like FileReadAll does
fn main(): int64 {
  var fd: int64 := open("/etc/hostname", 0, 0);
  if fd < 0 {
    PrintStr("open failed\n");
    return 1;
  }
  
  var size: int64 := lseek(fd, 0, 2);
  lseek(fd, 0, 0);
  
  var buf: int64 := mmap(0, size + 1, 3, 34, -1, 0);
  var n: int64 := read(fd, buf, size);
  close(fd);
  
  PrintStr("Read ");
  PrintInt(n);
  PrintStr(" bytes, first bytes: ");
  
  var i: int64 := 0;
  while i < 10 {
    PrintInt(peek8(buf + i));
    PrintStr(" ");
    i := i + 1;
  }
  PrintStr("\n");
  
  munmap(buf, size + 1);
  return 0;
}