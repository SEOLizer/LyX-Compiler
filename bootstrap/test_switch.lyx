// bootstrap/test_switch.lyx -- WP-10c switch/case smoke test

fn describe(n: int64): int64 {
  switch (n) {
    case 1: {
      PrintStr("one\n");
    }
    case 2: {
      PrintStr("two\n");
    }
    case 3: {
      PrintStr("three\n");
    }
    default: {
      PrintStr("other\n");
    }
  }
  return 0;
}

fn main(argc: int64, argv: pchar): int64 {
  describe(1);
  describe(2);
  describe(3);
  describe(99);

  // Switch with break
  var x: int64 := 2;
  switch (x) {
    case 1: { PrintStr("x=1\n"); }
    case 2: { PrintStr("x=2\n"); break; }
    case 3: { PrintStr("x=3\n"); }
  }

  // Switch with expression
  var a: int64 := 10;
  var b: int64 := 5;
  switch (a + b) {
    case 15: { PrintStr("sum=15\n"); }
    default: { PrintStr("wrong\n"); }
  }

  return 0;
}
