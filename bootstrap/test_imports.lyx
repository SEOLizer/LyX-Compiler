import bootstrap.mathlib;

fn main(argc: int64, argv: pchar): int64 {
  // pub fn calls from imported module
  PrintStr("add(3,4)=");   PrintInt(add(3, 4));   PrintStr("\n");
  PrintStr("mul(6,7)=");   PrintInt(mul(6, 7));   PrintStr("\n");
  PrintStr("max2(9,5)=");  PrintInt(max2(9, 5));  PrintStr("\n");
  PrintStr("fact(6)=");    PrintInt(factorial(6)); PrintStr("\n");

  // pub con from imported module
  PrintStr("PI=");  PrintInt(MATH_PI); PrintStr("\n");
  PrintStr("E=");   PrintInt(MATH_E);  PrintStr("\n");

  // pub struct + function using imported struct
  var a: Vec2;
  a.x := 3;
  a.y := 4;
  var b: Vec2;
  b.x := 1;
  b.y := 2;
  PrintStr("dot="); PrintInt(vec2_dot(a, b)); PrintStr("\n");

  return 0;
}
