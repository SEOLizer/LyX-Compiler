// bootstrap/test_enums.lyx -- WP-10f enum smoke test

// Basic auto-increment enum (0, 1, 2, ...)
enum Direction {
  North,
  East,
  South,
  West
}

// Enum with explicit values
enum HttpStatus {
  OK        = 200,
  NotFound  = 404,
  Error     = 500
}

// Mixed: explicit value resets counter, then auto-increments
enum Token {
  TK_EOF,
  TK_IDENT,
  TK_INT = 10,
  TK_PLUS,
  TK_MINUS
}

fn describeDir(d: int64): int64 {
  switch (d) {
    case 0: { PrintStr("North\n"); }
    case 1: { PrintStr("East\n");  }
    case 2: { PrintStr("South\n"); }
    case 3: { PrintStr("West\n");  }
    default: { PrintStr("?\n"); }
  }
  return 0;
}

fn main(argc: int64, argv: pchar): int64 {
  // Basic auto-increment
  PrintStr("North="); PrintInt(North); PrintStr("\n");
  PrintStr("East=");  PrintInt(East);  PrintStr("\n");
  PrintStr("South="); PrintInt(South); PrintStr("\n");
  PrintStr("West=");  PrintInt(West);  PrintStr("\n");

  // Explicit values
  PrintStr("OK=");       PrintInt(OK);       PrintStr("\n");
  PrintStr("NotFound="); PrintInt(NotFound); PrintStr("\n");
  PrintStr("Error=");    PrintInt(Error);    PrintStr("\n");

  // Mixed
  PrintStr("TK_EOF=");   PrintInt(TK_EOF);   PrintStr("\n");
  PrintStr("TK_IDENT="); PrintInt(TK_IDENT); PrintStr("\n");
  PrintStr("TK_INT=");   PrintInt(TK_INT);   PrintStr("\n");
  PrintStr("TK_PLUS=");  PrintInt(TK_PLUS);  PrintStr("\n");
  PrintStr("TK_MINUS="); PrintInt(TK_MINUS); PrintStr("\n");

  // Use in switch/case via variable
  var dir: int64 := South;
  describeDir(dir);

  // Use in comparison
  if (dir == South) {
    PrintStr("going South\n");
  }

  // Use as function arg directly
  describeDir(West);

  return 0;
}
