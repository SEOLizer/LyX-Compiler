    // Emit: dest = enumValue
    return dest;
  }
  
  // ============================================================================
  // Extended Expression Lowering (handles all expression types)
  // ============================================================================
  
  fn lowerExprExtended(expr: int64): int64 {
    if (expr < 0) { 
      return self.allocTemp();
    }
    
    var k: int64 := self.nodeKind(expr);
    
    // Extended expression types
    if (k == NK_LOAD_FIELD) {
      return self.lowerLoadField(expr);
    }
    if (k == NK_STORE_FIELD) {
      return self.lowerStoreField(expr);
    }
    if (k == NK_LOAD_ELEM) {
      return self.lowerLoadElem(expr);
    }
    if (k == NK_STORE_ELEM) {
      return self.lowerStoreElem(expr);
    }
    if (k == NK_LOAD_FIELD_HEAP) {
      return self.lowerLoadFieldHeap(expr);
    }
    if (k == NK_STORE_FIELD_HEAP) {
      return self.lowerStoreFieldHeap(expr);
    }
    if (k == NK_SUPER_CALL) {
      return self.lowerSuperCall(expr);
    }
    if (k == NK_IS_EXPR) {
      return self.lowerIsType(expr);
    }
    if (k == NK_CLOSURE) {
      return self.lowerClosure(expr);
    }
    if (k == NK_FN_PTR) {
      return self.lowerFnPtr(expr);
    }
    if (k == NK_TYPE_NAME) {
      return self.lowerTypeName(expr);
    }
    if (k == NK_TYPE_PARAM) {
      return self.lowerTypeParam(expr);
    }
    if (k == NK_TYPE_ARRAY) {
      return self.lowerTypeArray(expr);
    }
    if (k == NK_MATCH) {
      return self.lowerMatch(expr);
    }
    if (k == NK_SWITCH) {
      // Switch as expression or statement
      return self.lowerSwitch(expr);
    }
    if (k == NK_TRY) {
      return self.lowerTry(expr);
    }
    if (k == NK_THROW) {
      return self.lowerThrowExpr(expr);
    }
    
    // Delegate to base expression lowering
    return self.lowerExpr(expr);
  }
