// ============================================================================
// IRLower Class
// ============================================================================

pub type IRLower = class {
  // Global function count workaround (since IRModule access is broken across S1/S2)
  // Initialized in init() method
  globalFuncCount: int64;
  
  // IR Module reference (stored as int64, accessed via helper functions)
  ir: int64;
  
  // Reference to IRModule object (for method calls)
  irModule: IRModule;
  
  // AST data
  nodes: int64;
  nodeCount: int64;
  src: pchar;
  
  // Current function context
  curFunc: int64;
  
  // Local variable tracking
  localCount: int64;
  paramCount: int64;
  
  // Label and temp counters
  labelCount: int64;
  tempCount: int64;
  
  // Loop control (for break/continue)
  loopExitLabel: int64;
  loopContLabel: int64;
  
  // Return value temp (for functions with non-void return)
  retValTemp: int64;
  
  // Function exit label (for return statements to jump to)
  funcExitLabel: int64;
  
  // Class/Struct metadata (for field lookups)
  structFieldOffsets: int64;  // buffer: structName -> fieldOffset
  classVmtOffsets: int64;    // buffer: className -> methodOffset
  currentClass: int64;        // current class being lowered
  
  // Generic type arguments
  typeArgs: int64;           // current type arguments for generic instantiation
  typeArgCount: int64;
  
  // ------------------------------------------------------------------
  // Initialization
  // ------------------------------------------------------------------
  
  fn init(irModPtr: int64, astNodes: int64, astNodeCount: int64, astSrc: pchar, irMod: IRModule) {
    self.ir := irModPtr;
    self.irModule := irMod;
    self.nodes := astNodes;
    self.nodeCount := astNodeCount;
    self.src := astSrc;
    // Initialize global function count
    self.globalFuncCount := 0;
    self.localCount := 0;
    self.paramCount := 0;
    self.labelCount := 0;
    self.tempCount := 0;
    self.loopExitLabel := -1;
    self.loopContLabel := -1;
    self.curFunc := -1;
    self.retValTemp := -1;
    self.structFieldOffsets := 0;
    self.classVmtOffsets := 0;
    self.currentClass := -1;
    self.typeArgs := 0;
    self.typeArgCount := 0;
  }
  
  // Helper function to call IRModule methods via vtable
  // Since we're storing the pointer directly, we need to find the vtable and methods
  fn initIRHelper(ptr: int64) {
    // The IRModule has a vtable at offset 0, methods at vtable[0], vtable[1], etc.
    // addFunc is method #X, getFuncCount is method #Y
    // We can't easily call them directly without knowing the vtable layout
    // For now, we'll just use raw memory access
  }
  
  // Helper: add function directly to IRModule via raw memory
  // Bypasses method calls that don't work in S1→S2 context
  fn irAddFunc(nameOff: int64, nameLen: int64, localCount: int64, paramCount: int64): int64 {
    // IRModule layout:
    //   funcBuffer at +80 (field 10)
    //   funcCap at +88 (field 11)  
    //   funcLen at +96 (field 12)
    // IR_FUNC_SIZE = 80 bytes per function
    
    PrintStr("irAddFunc: starting with direct memory access...\n");
    
    // Read funcLen and funcCap from IRModule
    var funcLen: int64 := peek64(self.ir + 96);
    var funcCap: int64 := peek64(self.ir + 88);
    PrintStr("irAddFunc: funcLen = "); PrintInt(funcLen); PrintStr(", funcCap = "); PrintInt(funcCap); PrintStr("\n");
    
    // Compute idx
    var idx: int64 := funcLen;
    
    // Grow if needed
    if (((funcLen + 1) * 80) > funcCap) {
      var newCap: int64 := funcCap * 2;
      var oldBuf: int64 := peek64(self.ir + 80);
      var newBuf: int64 := mmap(0, newCap, 3, 34, -1, 0);
      // Copy existing functions
      var i: int64 := 0;
      while (i < funcLen) {
        var j: int64 := 0;
        while (j < 80) {
          poke8(newBuf + i * 80 + j, peek8(oldBuf + i * 80 + j));
          j := j + 1;
        }
        i := i + 1;
      }
      // Update funcBuffer and funcCap
      poke64(self.ir + 80, newBuf);
      poke64(self.ir + 88, newCap);
      funcCap := newCap;
      PrintStr("irAddFunc: grew buffer to "); PrintInt(newCap); PrintStr("\n");
    }
    
    // Get funcBuffer
    var funcBuf: int64 := peek64(self.ir + 80);
    var off: int64 := idx * 80;
    
    // Store function data
    poke64(funcBuf + off + 0, nameOff);   // nameOff
    poke64(funcBuf + off + 8, nameLen);   // nameLen
    poke64(funcBuf + off + 16, 0);        // instrsOff (will be set later)
    poke64(funcBuf + off + 24, 0);        // instrCount
    poke64(funcBuf + off + 32, localCount);  // localCount
    poke64(funcBuf + off + 40, paramCount);  // paramCount
    poke64(funcBuf + off + 48, 0);        // retStructSize
    poke64(funcBuf + off + 56, 0);        // capturedVarsOff
    poke64(funcBuf + off + 64, 0);        // capturedCount
    poke64(funcBuf + off + 72, 0);        // needsStaticLink
    
    // Increment funcLen
    funcLen := funcLen + 1;
    poke64(self.ir + 96, funcLen);
    PrintStr("irAddFunc: new funcLen = "); PrintInt(funcLen); PrintStr("\n");
    
    return idx;
  }
  
  fn irGetFuncCount(): int64 {
    return peek64(self.ir + 96);
  }
  
  // Remove duplicate global
  // ------------------------------------------------------------------
  // AST Node Access Helpers
  // ------------------------------------------------------------------
  
  fn nodeOff(i: int64): int64 { return self.nodes + i * 88; }
  fn nodeKind(i: int64): int64 { return peek64(self.nodeOff(i)); }
  fn nodeC0(i: int64): int64 { return peek64(self.nodeOff(i) + 8); }
  fn nodeC1(i: int64): int64 { return peek64(self.nodeOff(i) + 16); }
  fn nodeC2(i: int64): int64 { return peek64(self.nodeOff(i) + 24); }
  fn nodeC3(i: int64): int64 { return peek64(self.nodeOff(i) + 32); }
  fn nodeIVal(i: int64): int64 { return peek64(self.nodeOff(i) + 56); }
  fn nodeSVal(i: int64): pchar { return self.src + peek64(self.nodeOff(i) + 64); }
  fn nodeSLen(i: int64): int64 { return peek64(self.nodeOff(i) + 72); }
  fn nodeNext(i: int64): int64 { return peek64(self.nodeOff(i) + 40); }
  
  // ------------------------------------------------------------------
  // IR Module Helpers (call through function pointers)
  // ------------------------------------------------------------------
  
  // Helper: add IR instruction directly to IRModule
  // When IRModule is passed as int64 (from "as int64" cast), it's the VTable pointer
  // The actual object fields are accessed via VTable pointer
  fn irAddInstrDirect(op: int64, dest: int64, src1: int64, src2: int64, src3: int64, imm: int64): int64 {
    PrintStr("irAddInstrDirect: op="); PrintInt(op); PrintStr(" dest="); PrintInt(dest); PrintStr(" src1="); PrintInt(src1); PrintStr(" imm="); PrintInt(imm); PrintStr("\n");
    
    // Check what's at the first offset
    var firstField: int64 := peek64(self.ir);
    PrintStr("irAddInstrDirect: firstField="); PrintInt(firstField); PrintStr("\n");
    
    // VTable pointer is typically < 100MB (small pointer to code section)
    // mmap address is typically > 100MB (large pointer in user space)
    // Use 100 million as threshold
    if (firstField > 100000000) {
      PrintStr("irAddInstrDirect: looks like direct object, fields at +0\n");
      // Direct object - fields at +0
      var instrBuf: int64 := peek64(self.ir + 0);
      var instrCap: int64 := peek64(self.ir + 8);
      var instrLen: int64 := peek64(self.ir + 16);
      PrintStr("irAddInstrDirect: buf="); PrintInt(instrBuf); PrintStr(" cap="); PrintInt(instrCap); PrintStr(" len="); PrintInt(instrLen); PrintStr("\n");
    } else {
      PrintStr("irAddInstrDirect: looks like vtable pointer, fields at +8\n");
      // VTable pointer - fields at +8
      var instrBuf: int64 := peek64(self.ir + 8);
      var instrCap: int64 := peek64(self.ir + 16);
      var instrLen: int64 := peek64(self.ir + 24);
      PrintStr("irAddInstrDirect: buf="); PrintInt(instrBuf); PrintStr(" cap="); PrintInt(instrCap); PrintStr(" len="); PrintInt(instrLen); PrintStr("\n");
    }
    var instrCap: int64 := peek64(self.ir + 16); // instrCap at +16
    var instrLen: int64 := peek64(self.ir + 24); // instrLen at +24
    
    // Grow if needed (IR_INSTR_SIZE = 80 bytes)
    if (((instrLen + 1) * 80) > instrCap) {
      var newCap: int64 := instrCap * 2;
      var nb: int64 := mmap(0, newCap, 3, 34, -1, 0);
      var i: int64 := 0;
      while (i < instrLen) {
        var j: int64 := 0;
        while (j < 80) {
          poke8(nb + i * 80 + j, peek8(instrBuf + i * 80 + j));
          j := j + 1;
        }
        i := i + 1;
      }
      poke64(self.ir + 8, nb);
      poke64(self.ir + 16, newCap);
      instrCap := newCap;
      instrBuf := nb;
    }
    
    // Store instruction
    var off: int64 := instrLen * 80;
    poke64(instrBuf + off + 0, op);
    poke64(instrBuf + off + 8, dest);
    poke64(instrBuf + off + 16, src1);
    poke64(instrBuf + off + 24, src2);
    poke64(instrBuf + off + 32, src3);
    poke64(instrBuf + off + 40, imm);
    
    // Increment instrLen
    instrLen := instrLen + 1;
    poke64(self.ir + 24, instrLen);
    
    return instrLen - 1;
  }

  // Control-flow emit helpers
  fn irEmitLabel(labelId: int64) {
    self.irAddInstrDirect(IRO_LABEL, -1, -1, -1, -1, labelId);
  }

  fn irEmitJmp(labelId: int64) {
    self.irAddInstrDirect(IRO_JMP, -1, -1, -1, -1, labelId);
  }

  fn irEmitBrFalse(cond: int64, labelId: int64) {
    self.irAddInstrDirect(IRO_BR_FALSE, -1, cond, -1, -1, labelId);
  }
  
  // ------------------------------------------------------------------
  // Label Generation
  // ------------------------------------------------------------------
  
  fn genLabel(): int64 {
    var lbl: int64 := self.labelCount;
    self.labelCount := self.labelCount + 1;
    return lbl;
  }
  
  // ------------------------------------------------------------------
  // Temporary Register Allocation
  // ------------------------------------------------------------------
  
  fn allocTemp(): int64 {
    var t: int64 := self.tempCount;
    self.tempCount := self.tempCount + 1;
    if (t >= self.localCount) { self.localCount := t + 1; }
    return t;
  }
  
  fn allocParam(): int64 {
    var p: int64 := self.paramCount;
    self.paramCount := self.paramCount + 1;
    return p;
  }
  
  // ------------------------------------------------------------------
  // Expression Lowering
  // ------------------------------------------------------------------
  
  fn lowerExpr(expr: int64): int64 {
    // Invalid node
    if (expr < 0) { 
      return self.allocTemp();  // Allocate temp anyway for safety
    }
    
    var k: int64 := self.nodeKind(expr);
    PrintStr("lowerExpr: expr="); PrintInt(expr); PrintStr(" kind="); PrintInt(k); PrintStr("\n");
    
    // Literal: integer constant
    if (k == NK_LIT_INT) {
      PrintStr("lowerExpr: found NK_LIT_INT\n");
      var dest: int64 := self.allocTemp();
      var val: int64 := self.nodeIVal(expr);
      PrintStr("lowerExpr: dest="); PrintInt(dest); PrintStr(" val="); PrintInt(val); PrintStr("\n");
      // Emit: dest = const val
      self.irAddInstrDirect(IRO_CONST_INT, dest, -1, -1, -1, val);
      return dest;
    }
    
    // Literal: float constant
    if (k == NK_LIT_FLOAT) {
      var dest: int64 := self.allocTemp();
      var bits: int64 := self.nodeIVal(expr);
      // Emit: dest = const float bits
      return dest;
    }
    
    // Literal: string constant
    if (k == NK_LIT_STR) {
      var dest: int64 := self.allocTemp();
      var strOff: int64 := self.nodeIVal(expr);
      PrintStr("lowerExpr: NK_LIT_STR strOff="); PrintInt(strOff); PrintStr("\n");
      // Emit: dest = const str strOff (IRO_CONST_STR = 1)
      self.irAddInstrDirect(IRO_CONST_STR, dest, -1, -1, -1, strOff);
      return dest;
    }
    
    // Literal: boolean
    if (k == NK_LIT_BOOL) {
      var dest: int64 := self.allocTemp();
      var val: int64 := self.nodeIVal(expr);
      // Emit: dest = const val
      return dest;
    }
    
    // Literal: character
    if (k == NK_LIT_CHAR) {
      var dest: int64 := self.allocTemp();
      var val: int64 := self.nodeIVal(expr);
      // Emit: dest = const val
      return dest;
    }
    
    // Literal: null
    if (k == NK_LIT_NULL) {
      var dest: int64 := self.allocTemp();
      // Emit: dest = const 0
      return dest;
    }
    
    // Identifier (variable reference)
    if (k == NK_IDENT) {
      var dest: int64 := self.allocTemp();
      // Load from local or global based on context
      return dest;
    }
    
    // Binary operation
    if (k == NK_BINOP) {
      return self.lowerBinOp(expr);
    }
    
    // Unary operation
    if (k == NK_UNOP) {
      return self.lowerUnOp(expr);
    }
    
    // Function call
    if (k == NK_CALL) {
      return self.lowerCall(expr);
    }
    
    // Array index access
    if (k == NK_INDEX) {
      return self.lowerIndex(expr);
    }
    
    // Field access
    if (k == NK_FIELD) {
      return self.lowerField(expr);
    }
    
    // Cast expression
    if (k == NK_CAST) {
      return self.lowerCast(expr);
    }
    
    // New (heap allocation)
    if (k == NK_NEW) {
      return self.lowerNew(expr);
    }
    
    // Range expression
    if (k == NK_RANGE) {
      return self.lowerRange(expr);
    }
    
    // Unknown expression type - allocate temp
    var t: int64 := self.allocTemp();
    return t;
  }
  
  // ------------------------------------------------------------------
  // Binary Operation Lowering
  // ------------------------------------------------------------------
  
  fn lowerBinOp(expr: int64): int64 {
    var op: int64 := self.nodeIVal(expr);
    var t1: int64 := self.lowerExpr(self.nodeC0(expr));
    var t2: int64 := self.lowerExpr(self.nodeC1(expr));
    var dest: int64 := self.allocTemp();
    
    // Arithmetic ops: +, -, *, /, %
    // Comparison ops: ==, !=, <, <=, >, >=
    // Bitwise ops: &, |, ^, <<, >>
    // Logical ops: &&, ||
    
    // Emit appropriate IR instruction based on op
    return dest;
  }
  
  // ------------------------------------------------------------------
  // Unary Operation Lowering
  // ------------------------------------------------------------------
  
  fn lowerUnOp(expr: int64): int64 {
    var op: int64 := self.nodeIVal(expr);
    var t1: int64 := self.lowerExpr(self.nodeC0(expr));
    var dest: int64 := self.allocTemp();
    
    // Unary ops: -, !, ~, &
    return dest;
  }
  
  // ------------------------------------------------------------------
  // Function Call Lowering
  // ------------------------------------------------------------------
  
  fn lowerCall(expr: int64): int64 {
    // In the parser, NK_CALL stores:
    // - sVal: function name string offset
    // - iVal: method call flag (0 = bare function call, 1 = method call)
    // - C0: first argument (for bare function calls from ParsePrimary)
    // - C1: first argument (for method calls from ParsePostfix)
    // PrintStr is the only builtin we handle for now
    
    PrintStr("lowerCall: processing call\n");
    var dest: int64 := self.allocTemp();
    
    // Function name string is in sVal (directly on the call node)
    var fname: pchar := self.nodeSVal(expr);
    PrintStr("lowerCall: fname ptr="); PrintInt(fname as int64); PrintStr("\n");
    
    // Check which field has the first argument
    var curArg: int64 := self.nodeC0(expr);
    var methodFlag: int64 := self.nodeIVal(expr);
    PrintStr("lowerCall: methodFlag="); PrintInt(methodFlag); PrintStr(" C0="); PrintInt(curArg); PrintStr("\n");
    
    // Try to lower the first argument
    if (curArg >= 0) {
      PrintStr("lowerCall: lowering argument from C0\n");
      var argTemp: int64 := self.lowerExpr(curArg);
      PrintStr("lowerCall: argTemp="); PrintInt(argTemp); PrintStr("\n");
      
      // Emit builtin call for PrintStr (builtinId = 1)
      var builtinId: int64 := 1;
      PrintStr("lowerCall: emitting IRO_CALL_BUILTIN with builtinId="); PrintInt(builtinId); PrintStr("\n");
      self.irAddInstrDirect(IRO_CALL_BUILTIN, dest, argTemp, -1, -1, builtinId);
      PrintStr("lowerCall: emitted\n");
    }
    
    PrintStr("lowerCall: done\n");
    return dest;
  }
  
  // ------------------------------------------------------------------
  // Index/Array Access Lowering
  // ------------------------------------------------------------------
  
  fn lowerIndex(expr: int64): int64 {
    var base: int64 := self.lowerExpr(self.nodeC0(expr));
    var idx: int64 := self.lowerExpr(self.nodeC1(expr));
    var dest: int64 := self.allocTemp();
    
    // Emit load from base[idx]
    return dest;
  }
  
  // ------------------------------------------------------------------
  // Field Access Lowering
  // ------------------------------------------------------------------
  
  fn lowerField(expr: int64): int64 {
    var base: int64 := self.lowerExpr(self.nodeC0(expr));
    // Field name is in string value
    var dest: int64 := self.allocTemp();
    
    // Emit field load: dest = base.field
    return dest;
  }
  
  // ------------------------------------------------------------------
  // Cast Lowering
  // ------------------------------------------------------------------
  
  fn lowerCast(expr: int64): int64 {
    var src: int64 := self.lowerExpr(self.nodeC0(expr));
    // Target type is in C1
    var dest: int64 := self.allocTemp();
    
    // Emit cast based on source/target type
    return dest;
  }
  
  // ------------------------------------------------------------------
  // New Expression Lowering
  // ------------------------------------------------------------------
  
  fn lowerNew(expr: int64): int64 {
    // Type to allocate is in C0
    var dest: int64 := self.allocTemp();
    
    // Emit allocation
    return dest;
  }
  
  // ------------------------------------------------------------------
  // Range Expression Lowering
  // ------------------------------------------------------------------
  
  fn lowerRange(expr: int64): int64 {
    var lo: int64 := self.lowerExpr(self.nodeC0(expr));
    var hi: int64 := self.lowerExpr(self.nodeC1(expr));
    var dest: int64 := self.allocTemp();
    
    // Emit range construction
    return dest;
  }
  
  // ------------------------------------------------------------------
  // Statement Lowering
  // ------------------------------------------------------------------
  
  fn lowerStmt(stmt: int64) {
    if (stmt < 0) { return; }
    
    var k: int64 := self.nodeKind(stmt);
    PrintStr("lowerStmt: stmt="); PrintInt(stmt); PrintStr(" kind="); PrintInt(k); PrintStr("\n");
    
    if (k == NK_BLOCK) { 
      self.lowerBlock(stmt); 
    }
    else if (k == NK_IF) { 
      self.lowerIf(stmt); 
    }
    else if (k == NK_WHILE) { 
      self.lowerWhile(stmt); 
    }
    else if (k == NK_FOR) { 
      self.lowerFor(stmt); 
    }
    else if (k == NK_RETURN) { 
      self.lowerReturn(stmt); 
    }
    else if (k == NK_EXPR_STMT) { 
      var expr: int64 := self.nodeC0(stmt); 
      if (expr >= 0) { self.lowerExpr(expr); } 
    }
    else if (k == NK_ASSIGN) { 
      self.lowerAssign(stmt); 
    }
    else if (k == NK_BREAK) { 
      self.lowerBreak(stmt); 
    }
    else if (k == NK_CONTINUE) { 
      self.lowerContinue(stmt); 
    }
    else if (k == NK_DISPOSE) { 
      self.lowerDispose(stmt); 
    }
    else if (k == NK_THROW) { 
      self.lowerThrow(stmt); 
    }
    else if (k == NK_TRY) { 
      self.lowerTryStmt(stmt); 
    }
    else if (k == NK_SWITCH) { 
      self.lowerSwitch(stmt); 
    }
    else if (k == NK_DISPOSE) { 
      self.lowerDispose(stmt); 
    }
    // Try/Catch/Finally handled in lowering blocks
  }
  
  // ------------------------------------------------------------------
  // Block Lowering
  // ------------------------------------------------------------------
  
  fn lowerBlock(block: int64) {
    PrintStr("===== lowerBlock START =====\n");
    var stmt: int64 := self.nodeC0(block);
    PrintStr("lowerBlock: first stmt="); PrintInt(stmt); PrintStr("\n");
    if (stmt < 0) {
      PrintStr("lowerBlock: no statements\n");
      PrintStr("===== lowerBlock END =====\n");
      return;
    }
    while (stmt >= 0) { 
      self.lowerStmt(stmt); 
      stmt := self.nodeNext(stmt); 
    }
    PrintStr("===== lowerBlock END =====\n");
  }
  
  // ------------------------------------------------------------------
  // If Statement Lowering
  // ------------------------------------------------------------------
  
  fn lowerIf(stmt: int64) {
    var cond: int64 := self.nodeC0(stmt);
    var condTemp: int64 := self.lowerExpr(cond);

    var elseLbl: int64 := self.genLabel();
    var endLbl: int64 := self.genLabel();

    // if not condTemp goto elseLbl
    self.irEmitBrFalse(condTemp, elseLbl);

    // Then block
    if (self.nodeC1(stmt) >= 0) {
      self.lowerBlock(self.nodeC1(stmt));
    }

    // goto endLbl (skip else)
    self.irEmitJmp(endLbl);

    // elseLbl:
    self.irEmitLabel(elseLbl);

    // Else block
    if (self.nodeC2(stmt) >= 0) {
      self.lowerBlock(self.nodeC2(stmt));
    }

    // endLbl:
    self.irEmitLabel(endLbl);
  }
  
  // ------------------------------------------------------------------
  // While Statement Lowering
  // ------------------------------------------------------------------
  
  fn lowerWhile(stmt: int64) {
    var loopLbl: int64 := self.genLabel();
    var exitLbl: int64 := self.genLabel();

    // Save outer loop labels
    var savedExit: int64 := self.loopExitLabel;
    var savedCont: int64 := self.loopContLabel;

    self.loopExitLabel := exitLbl;
    self.loopContLabel := loopLbl;

    // loopLbl:
    self.irEmitLabel(loopLbl);

    // Condition
    var cond: int64 := self.nodeC0(stmt);
    var condTemp: int64 := self.lowerExpr(cond);

    // if not condTemp goto exitLbl
    self.irEmitBrFalse(condTemp, exitLbl);

    // Loop body
    if (self.nodeC1(stmt) >= 0) {
      self.lowerBlock(self.nodeC1(stmt));
    }

    // goto loopLbl
    self.irEmitJmp(loopLbl);

    // exitLbl:
    self.irEmitLabel(exitLbl);

    // Restore outer loop labels
    self.loopExitLabel := savedExit;
    self.loopContLabel := savedCont;
  }
  
  // ------------------------------------------------------------------
  // For Statement Lowering
  // ------------------------------------------------------------------
  
  fn lowerFor(stmt: int64) {
    // For loop structure:
    // C0: init (assign or var decl)
    // C1: condition
    // C2: step
    // C3: body

    var loopLbl: int64 := self.genLabel();
    var contLbl: int64 := self.genLabel();  // continue target: before step
    var exitLbl: int64 := self.genLabel();

    var savedExit: int64 := self.loopExitLabel;
    var savedCont: int64 := self.loopContLabel;

    self.loopExitLabel := exitLbl;
    self.loopContLabel := contLbl;

    // Init (C0)
    var init: int64 := self.nodeC0(stmt);
    if (init >= 0) { self.lowerStmt(init); }

    // loopLbl:
    self.irEmitLabel(loopLbl);

    // Condition (C1)
    var cond: int64 := self.nodeC1(stmt);
    if (cond >= 0) {
      var condTemp: int64 := self.lowerExpr(cond);
      self.irEmitBrFalse(condTemp, exitLbl);
    }

    // Body (C3)
    var body: int64 := self.nodeC3(stmt);
    if (body >= 0) { self.lowerBlock(body); }

    // contLbl: (continue lands here, then executes step)
    self.irEmitLabel(contLbl);

    // Step (C2)
    var step: int64 := self.nodeC2(stmt);
    if (step >= 0) { self.lowerStmt(step); }

    // goto loopLbl
    self.irEmitJmp(loopLbl);

    // exitLbl:
    self.irEmitLabel(exitLbl);

    self.loopExitLabel := savedExit;
    self.loopContLabel := savedCont;
  }
  
  // ------------------------------------------------------------------
  // Return Statement Lowering
  // ------------------------------------------------------------------
  
  fn lowerReturn(stmt: int64) {
    var retVal: int64 := self.nodeC0(stmt);
    if (retVal >= 0) { 
      var retTemp: int64 := self.lowerExpr(retVal);
      // Emit: store retTemp to retValTemp (local variable)
      self.irAddInstrDirect(IRO_STORE_LOCAL, self.retValTemp, retTemp, -1, -1, 0);
    }
    
    // Emit: goto funcExit
    self.irEmitJmp(self.funcExitLabel);
  }
  
