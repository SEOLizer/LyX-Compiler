  // Create parallel array (SIMD vector)
  fn lowerParallelArray(expr: int64): int64 {
    // C0: element type
    // C1: element count (must be power of 2, e.g., 4, 8)
    var elemCount: int64 := self.nodeIVal(self.nodeC1(expr));
    var dest: int64 := self.allocTemp();
    
    // Allocate aligned: 16-byte alignment for SSE2
    // Emit: dest = alloc_aligned(elemCount * elemSize, 16)
    return dest;
  }
  
  // SIMD element load
  fn lowerSIMDLoadElem(expr: int64): int64 {
    var arrTemp: int64 := self.lowerExpr(self.nodeC0(expr));
