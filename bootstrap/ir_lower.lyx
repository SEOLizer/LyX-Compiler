  // ============================================================================
  // WP-20: Struct Lowering
  // ============================================================================
  
  // Load field from struct (stack-allocated)
  fn lowerLoadField(expr: int64): int64 {
    // C0: base struct (already lowered to temp)
    // C1: field index (or name string offset)
    var baseTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    var fieldIdx: int64 := self.nodeIVal(self.nodeC1(expr));
    var dest: int64 := self.allocTemp();
    
    // Emit: dest = load baseTemp.fieldOffset
    // Field offset = fieldIdx * 8 (assuming 8-byte alignment)
    return dest;
  }
  
  // Store field to struct (stack-allocated)
  fn lowerStoreField(expr: int64): int64 {
    var baseTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    var fieldIdx: int64 := self.nodeIVal(self.nodeC1(expr));
    var srcTemp: int64 := self.lowerExpr(self.nodeC2(expr));
    
    // Emit: store srcTemp to baseTemp.fieldOffset
    return srcTemp;
  }
  
  // Load element from struct array (static array)
  fn lowerLoadElem(expr: int64): int64 {
    var baseTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    var idxTemp: int64 := self.lowerExpr(self.nodeC1(expr));
    var dest: int64 := self.allocTemp();
    
    // Emit: dest = load baseTemp[idxTemp * elemSize]
    return dest;
  }
  
  // Store element to struct array (static array)
  fn lowerStoreElem(expr: int64): int64 {
    var baseTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    var idxTemp: int64 := self.lowerExpr(self.nodeC1(expr));
    var srcTemp: int64 := self.lowerExpr(self.nodeC2(expr));
    
    // Emit: store srcTemp to baseTemp[idxTemp * elemSize]
    return srcTemp;
  }
  
  // Struct-by-value copy (for assignment/return)
  fn lowerStructCopy(structTemp: int64, fieldCount: int64): int64 {
    // Copy all fields: for i in 0..fieldCount-1: dest[i] = src[i]
    var i: int64 := 0;
    while (i < fieldCount) {
      // Emit load field i to temp
      // Emit store to dest field i
      i := i + 1;
    }
    return structTemp;
  }
  
  // ============================================================================
  // WP-20: Class/Object Lowering
  // ============================================================================
  
  // new T() - heap allocation
  fn lowerNewClass(expr: int64): int64 {
    // C0: class type node (or size)
    var size: int64 := self.nodeIVal(expr);
    var dest: int64 := self.allocTemp();
    
    // Emit: dest = alloc(size)
    // Then: store VMT pointer at dest[0]
    return dest;
  }
  
  // dispose obj - heap deallocation
  fn lowerDisposeClass(objTemp: int64): int64 {
    // Emit: free objTemp
    return objTemp;
  }
  
  // Load field from heap object
  fn lowerLoadFieldHeap(expr: int64): int64 {
    var objTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    var fieldOffset: int64 := self.nodeIVal(self.nodeC1(expr));
    var dest: int64 := self.allocTemp();
    
    // Emit: dest = load objTemp[fieldOffset]
    return dest;
  }
  
  // Store field to heap object
  fn lowerStoreFieldHeap(expr: int64): int64 {
    var objTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    var fieldOffset: int64 := self.nodeIVal(self.nodeC1(expr));
    var srcTemp: int64 := self.lowerExpr(self.nodeC2(expr));
    
    // Emit: store srcTemp to objTemp[fieldOffset]
    return srcTemp;
  }
  
  // Virtual method call
  fn lowerVirtualCall(expr: int64): int64 {
    var objTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    var methodOffset: int64 := self.nodeIVal(self.nodeC1(expr));
    
    // Arguments in C2 (linked list)
    var curArg: int64 := self.nodeC2(expr);
    while (curArg >= 0) {
      self.lowerExpr(curArg);
      curArg := self.nodeNext(curArg);
    }
    
    var dest: int64 := self.allocTemp();
    
    // Emit: tmp = load objTemp[0]  (VMT pointer)
    // Emit: methodPtr = load tmp[methodOffset * 8]
    // Emit: call methodPtr(objTemp, args...)
    return dest;
  }
  
  // Static method call (no VMT lookup)
  fn lowerStaticCall(expr: int64): int64 {
    // Function name is in C0
    var funcNameOff: int64 := self.nodeIVal(self.nodeC0(expr));
    
    // Arguments in C1
    var curArg: int64 := self.nodeC1(expr);
    while (curArg >= 0) {
      self.lowerExpr(curArg);
      curArg := self.nodeNext(curArg);
    }
    
    var dest: int64 := self.allocTemp();
    
    // Emit: call funcName(objTemp, args...)
    return dest;
  }
  
  // super.method() call
  fn lowerSuperCall(expr: int64): int64 {
    // Similar to static call but uses parent class VMT
    var methodOffset: int64 := self.nodeIVal(self.nodeC0(expr));
    
    var curArg: int64 := self.nodeC1(expr);
    while (curArg >= 0) {
      self.lowerExpr(curArg);
      curArg := self.nodeNext(curArg);
    }
    
    var dest: int64 := self.allocTemp();
    
    // Emit: call parentVMT[methodOffset](self, args...)
    return dest;
  }
  
  // isType expression (runtime type check)
  fn lowerIsType(expr: int64): int64 {
    var objTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    var typeId: int64 := self.nodeIVal(self.nodeC1(expr));
    var dest: int64 := self.allocTemp();
    
    // Emit: dest = (objTemp != 0 && objTemp.vmt.typeId == typeId) ? 1 : 0
    return dest;
  }
  
  // ============================================================================
  // WP-20: Interface Lowering
  // ============================================================================
  
  // Interface VMT lookup (for interface calls)
  fn lowerInterfaceCall(expr: int64): int64 {
    var objTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    var ifaceId: int64 := self.nodeIVal(self.nodeC1(expr));
    var methodOffset: int64 := self.nodeIVal(self.nodeC2(expr));
    
    var curArg: int64 := self.nodeC3(expr);
    while (curArg >= 0) {
      self.lowerExpr(curArg);
      curArg := self.nodeNext(curArg);
    }
    
    var dest: int64 := self.allocTemp();
    
    // Emit: itable = objTemp[0] - offset_to_interface
    // Emit: methodPtr = load itable[methodOffset]
    // Emit: call methodPtr(objTemp, args...)
    return dest;
  }
  
  // Interface cast (with runtime check)
  fn lowerInterfaceCast(expr: int64): int64 {
    var objTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    var ifaceId: int64 := self.nodeIVal(self.nodeC1(expr));
    var dest: int64 := self.allocTemp();
    
    // Emit: dest = {objTemp, itable} if cast succeeds
    // Or: dest = 0 if cast fails (and potentially throw)
    return dest;
  }
  
  // ============================================================================
  // WP-20: Dynamic Array Lowering
  // ============================================================================
  
  // Dynamic array literal
  fn lowerDynArrayLit(expr: int64): int64 {
    // C0: element type
    // C1: element count
    // C2: elements (linked list)
    var elemCount: int64 := self.nodeIVal(self.nodeC1(expr));
    var dest: int64 := self.allocTemp();
    
    // Allocate: dest = alloc(elemCount * elemSize + 24)  (24 for header: ptr, len, cap)
    // Initialize header: len = elemCount, cap = elemCount
    // Copy elements
    
    // Emit: dest = dyn_array_alloc(elemCount)
    var curElem: int64 := self.nodeC2(expr);
    var idx: int64 := 0;
    while (curElem >= 0) {
      var elemTemp: int64 := self.lowerExpr(curElem);
      // Emit: store elemTemp to dest[24 + idx * elemSize]
      curElem := self.nodeNext(curElem);
      idx := idx + 1;
    }
    
    return dest;
  }
  
  // Array index access (dynamic array)
  fn lowerDynArrayIndex(expr: int64): int64 {
    var arrTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    var idxTemp: int64 := self.lowerExpr(self.nodeC1(expr));
    var dest: int64 := self.allocTemp();
    
    // Bounds check: if idxTemp < 0 || idxTemp >= arrTemp.len, throw
    // Emit: dest = load arrTemp.ptr[idxTemp * elemSize]
    return dest;
  }
  
  // Store to dynamic array element
  fn lowerDynArrayStore(expr: int64): int64 {
    var arrTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    var idxTemp: int64 := self.lowerExpr(self.nodeC1(expr));
    var srcTemp: int64 := self.lowerExpr(self.nodeC2(expr));
    
    // Bounds check
    // Emit: store srcTemp to arrTemp.ptr[idxTemp * elemSize]
    return srcTemp;
  }
  
  // Array push (dynamic array expansion)
  fn lowerDynArrayPush(expr: int64): int64 {
    var arrTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    var elemTemp: int64 := self.lowerExpr(self.nodeC1(expr));
    
    // Check: if arrTemp.len == arrTemp.cap, realloc(arrTemp, arrTemp.cap * 2)
    // Emit: arrTemp.ptr[arrTemp.len] = elemTemp
    // Emit: arrTemp.len = arrTemp.len + 1
    return arrTemp;
  }
  
  // Array pop
  fn lowerDynArrayPop(expr: int64): int64 {
    var arrTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    var dest: int64 := self.allocTemp();
    
    // Emit: dest = arrTemp.ptr[arrTemp.len - 1]
    // Emit: arrTemp.len = arrTemp.len - 1
    return dest;
  }
  
  // Array length
  fn lowerDynArrayLen(expr: int64): int64 {
    var arrTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    var dest: int64 := self.allocTemp();
    
    // Emit: dest = arrTemp.len
    return dest;
  }
  
  // Array free
  fn lowerDynArrayFree(expr: int64): int64 {
    var arrTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    
    // Emit: free(arrTemp.ptr)
    // Emit: arrTemp = {0, 0, 0}
    return arrTemp;
  }
  
  // ============================================================================
  // WP-20: Exception Handling Lowering
  // ============================================================================
  
  // try block entry
  fn lowerTry(stmt: int64): int64 {
    var tryBody: int64 := self.nodeC0(stmt);
    var catchVar: int64 := self.nodeC1(stmt);
    var catchBody: int64 := self.nodeC2(stmt);
    var finallyBody: int64 := self.nodeC3(stmt);
    
    var catchLbl: int64 := self.genLabel();
    var finallyLbl: int64 := self.genLabel();
    var endLbl: int64 := self.genLabel();
    
    // Save handler info
    var savedHandler: int64 := self.loopExitLabel;  // reuse for handler stack
    self.loopExitLabel := catchLbl;  // for throw to find catch
    
    // Emit: push_handler(catchLbl, finallyLbl)
    // Try body
    if (tryBody >= 0) { self.lowerBlock(tryBody); }
    
    // Emit: pop_handler
    // Jump to end
    // goto endLbl
    
    // Catch label
    // catchLbl:
    // Load exception value
    if (catchBody >= 0) { self.lowerBlock(catchBody); }
    
    // Finally (always executed)
    // finallyLbl:
    if (finallyBody >= 0) { self.lowerBlock(finallyBody); }
    
    // End label
    // endLbl:
    
    // Restore handler
    self.loopExitLabel := savedHandler;
    
    return 0;
  }
  
  // throw expression
  fn lowerThrowExpr(expr: int64): int64 {
    var exnTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    
    // Emit: store exnTemp to _lyx_exn_val
    // Emit: longjmp to handler
    return exnTemp;
  }
  
  // panic(msg) builtin
  fn lowerPanic(expr: int64): int64 {
    var msgTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    
    // Emit: write msg to stderr
    // Emit: exit(1)
    return msgTemp;
  }
  
  // ============================================================================
  // WP-20: Closure / Nested Function Lowering
  // ============================================================================
  
  // Create closure object
  fn lowerClosure(expr: int64): int64 {
    // C0: function to close over
    // C1: captured variables (linked list)
    var funcNode: int64 := self.nodeC0(expr);
    var captures: int64 := self.nodeC1(expr);
    var dest: int64 := self.allocTemp();
    
    // Allocate closure object: {funcPtr, envPtr}
    // envPtr points to captured variables on heap
    
    // Process captures
    var capOffset: int64 := 16;  // after funcPtr (8 bytes)
    var curCap: int64 := captures;
    while (curCap >= 0) {
      var capTemp: int64 := self.lowerExpr(curCap);
      // Store captured value to env buffer
      curCap := self.nodeNext(curCap);
      capOffset := capOffset + 8;
    }
    
    return dest;
  }
  
  // Call closure (through function pointer)
  fn lowerClosureCall(expr: int64): int64 {
    var clTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    
    // Arguments in C1
    var curArg: int64 := self.nodeC1(expr);
    while (curArg >= 0) {
      self.lowerExpr(curArg);
      curArg := self.nodeNext(curArg);
    }
    
    var dest: int64 := self.allocTemp();
    
    // Emit: funcPtr = load clTemp[0]
    // Emit: envPtr = load clTemp[8]
    // Emit: call funcPtr(envPtr, args...)
    return dest;
  }
  
  // Static link parameter (for nested functions)
  fn lowerStaticLink(): int64 {
    // Allocate temp for static link (passed as hidden first arg)
    var slTemp: int64 := self.allocTemp();
    return slTemp;
  }
  
  // Load captured variable from static link
  fn lowerLoadCaptured(varOffset: int64): int64 {
    var slTemp: int64 := self.lowerStaticLink();
    var dest: int64 := self.allocTemp();
    
    // Emit: dest = load slTemp[varOffset]
    return dest;
  }
  
  // Store to captured variable
  fn lowerStoreCaptured(varOffset: int64, srcTemp: int64): int64 {
    var slTemp: int64 := self.lowerStaticLink();
    
    // Emit: store srcTemp to slTemp[varOffset]
    return srcTemp;
  }
  
  // ============================================================================
  // WP-20: Generics Lowering
  // ============================================================================
  
  // Generic function instantiation call
  fn lowerGenericCall(expr: int64): int64 {
    // C0: generic function name
    // C1: type arguments (linked list)
    // C2: regular arguments
    var genFuncName: int64 := self.nodeC0(expr);
    var typeArgs: int64 := self.nodeC1(expr);
    var args: int64 := self.nodeC2(expr);
    
    // Process type arguments to get type hash
    var typeHash: int64 := 0;
    var curType: int64 := typeArgs;
    while (curType >= 0) {
      // Hash each type
      curType := self.nodeNext(curType);
    }
    
    // Look up in instantiation cache
    // If found: use monomorphized function name
    // If not found: generate new instance
    
    // Process regular arguments
    var curArg: int64 := args;
    while (curArg >= 0) {
      self.lowerExpr(curArg);
      curArg := self.nodeNext(curArg);
    }
    
    var dest: int64 := self.allocTemp();
    
    // Emit: call <mangled_name>(typeArgs..., args...)
    return dest;
  }
  
  // Type argument as runtime typeid
  fn lowerTypeId(typeNode: int64): int64 {
    var dest: int64 := self.allocTemp();
    
    // Resolve type to typeId at compile time
    // Emit: dest = typeId
    return dest;
  }
  
