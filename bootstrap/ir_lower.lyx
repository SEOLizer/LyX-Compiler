  // Assignment Lowering
  // ------------------------------------------------------------------
  
  fn lowerAssign(stmt: int64) {
    var target: int64 := self.nodeC0(stmt);
    var val: int64 := self.nodeC1(stmt);
    
    if (target >= 0 && val >= 0) { 
      var valTemp: int64 := self.lowerExpr(val);
      
      // Target is IDENT
      if (self.nodeKind(target) == NK_IDENT) {
        // Emit: store to local variable
      }
      // Target is FIELD
      else if (self.nodeKind(target) == NK_FIELD) {
        // Emit: store to field
      }
      // Target is INDEX
      else if (self.nodeKind(target) == NK_INDEX) {
        // Emit: store to array element
      }
    }
  }
  
  // ------------------------------------------------------------------
  // Break Statement Lowering
  // ------------------------------------------------------------------
  
  fn lowerBreak(stmt: int64) {
    if (self.loopExitLabel >= 0) {
      self.irEmitJmp(self.loopExitLabel);
    }
  }
  
  // ------------------------------------------------------------------
  // Continue Statement Lowering
  // ------------------------------------------------------------------
  
  fn lowerContinue(stmt: int64) {
    if (self.loopContLabel >= 0) {
      self.irEmitJmp(self.loopContLabel);
    }
  }
  
  // ------------------------------------------------------------------
  // Dispose Statement Lowering
  // ------------------------------------------------------------------
  
  fn lowerDispose(stmt: int64) {
    var ptr: int64 := self.nodeC0(stmt);
    if (ptr >= 0) {
      var ptrTemp: int64 := self.lowerExpr(ptr);
      // Emit: free ptrTemp
    }
  }
  
  // ------------------------------------------------------------------
  // Throw Statement Lowering
  // ------------------------------------------------------------------
  
  fn lowerThrow(stmt: int64) {
    var exn: int64 := self.nodeC0(stmt);
    if (exn >= 0) {
      var exnTemp: int64 := self.lowerExpr(exn);
      // Emit: throw exnTemp
    }
  }
  
  // ------------------------------------------------------------------
  // Try Statement Lowering
  // ------------------------------------------------------------------
  
  fn lowerTryStmt(stmt: int64) {
    // Try statement: C0=tryBody, C1=catchVar, C2=catchBody, C3=finallyBody
    var tryBody: int64 := self.nodeC0(stmt);
    var catchVar: int64 := self.nodeC1(stmt);
    var catchBody: int64 := self.nodeC2(stmt);
    var finallyBody: int64 := self.nodeC3(stmt);
    
    var catchLbl: int64 := self.genLabel();
    var finallyLbl: int64 := self.genLabel();
    var endLbl: int64 := self.genLabel();
    
    // Save handler info
    var savedHandler: int64 := self.loopExitLabel;
    self.loopExitLabel := catchLbl;
    
    // Emit: push_handler(catchLbl, finallyLbl)
    
    // Try body
    if (tryBody >= 0) { 
      self.lowerBlock(tryBody); 
    }
    
    // Emit: pop_handler
    // Jump to end (skip catch)
    // goto endLbl
    
    // Catch label
    // catchLbl:
    // Load exception value to catch variable
    if (catchBody >= 0) { 
      self.lowerBlock(catchBody); 
    }
    
    // Finally (always executed on both paths)
    // finallyLbl:
    if (finallyBody >= 0) { 
      self.lowerBlock(finallyBody); 
    }
    
    // End label
    // endLbl:
    
    // Restore handler
    self.loopExitLabel := savedHandler;
  }
  
  // ------------------------------------------------------------------
  // Function Lowering
  // ------------------------------------------------------------------
  
  fn lowerFunc(funcNode: int64) {
    PrintStr("=== lowerFunc START ===\n");
    PrintStr("funcNode = "); PrintInt(funcNode); PrintStr("\n");
    PrintStr("self.ir = "); PrintInt(self.ir); PrintStr("\n");
    
    // Save current context
    var savedLocal: int64 := self.localCount;
    var savedParam: int64 := self.paramCount;
    var savedTemp: int64 := self.tempCount;
    var savedRetVal: int64 := self.retValTemp;
    
    // Reset for this function
    self.localCount := 0;
    self.paramCount := 0;
    self.tempCount := 0;
    self.curFunc := funcNode;
    
    // Allocate return value temp
    self.retValTemp := self.allocTemp();
    PrintStr("retValTemp allocated\n");
    
    // Generate function exit label for return statements
    self.funcExitLabel := self.genLabel();
    
    // Count and allocate params
    var param: int64 := self.nodeC0(funcNode);
    PrintStr("param = "); PrintInt(param); PrintStr("\n");
    while (param >= 0) { 
      self.allocParam(); 
      param := self.nodeNext(param); 
    }
    PrintStr("params done, paramCount = "); PrintInt(self.paramCount); PrintStr("\n");
    
    // Lower function body
    var body: int64 := self.nodeC2(funcNode);
    PrintStr("body = "); PrintInt(body); PrintStr("\n");
    if (body >= 0) { 
      PrintStr("Calling lowerBlock...\n");
      self.lowerBlock(body); 
    } else {
      PrintStr("No body\n");
    }
    
    PrintStr("Adding function to IR module...\n");
    // Add the function to the IR module
    self._addFunc();
    PrintStr("_addFunc done\n");
    
    // Emit function exit label
    self.irEmitLabel(self.funcExitLabel);
    PrintStr("funcExitLabel emitted\n");
    
    // Debug IR state after function
    // Access through ir field which was set in init
    // Can't directly access, but we can check later
    
    PrintStr("=== lowerFunc END ===\n");
  }
   
  // ------------------------------------------------------------------
  // Module Lowering
  // ------------------------------------------------------------------
  
  fn lowerModule(decls: int64) {
    PrintStr("=== lowerModule START ===\n");
    PrintStr("decls = "); PrintInt(decls); PrintStr("\n");
    PrintStr("self.nodes = "); PrintInt(self.nodes); PrintStr("\n");
    PrintStr("self.nodeCount = "); PrintInt(self.nodeCount); PrintStr("\n");
    
    var cur: int64 := decls;
    var iterCount: int64 := 0;
    while (cur >= 0 && iterCount < 10) {
      iterCount := iterCount + 1;
      PrintStr("Loop iteration "); PrintInt(iterCount); PrintStr("\n");
      PrintStr("cur = "); PrintInt(cur); PrintStr("\n");
      
      var kind: int64 := self.nodeKind(cur);
      PrintStr("nodeKind(cur) = "); PrintInt(kind); PrintStr("\n");
      
      // Function declaration
      if (kind == NK_FUNC_DECL) { 
        PrintStr("Found FUNC_DECL, calling lowerFunc...\n");
        self.lowerFunc(cur); 
        PrintStr("lowerFunc done\n");
      } else {
        PrintStr("Not FUNC_DECL, skipping\n");
      }
      // Other declarations handled separately
      cur := self.nodeNext(cur);
      PrintStr("next = "); PrintInt(cur); PrintStr("\n");
    }
    PrintStr("=== lowerModule END ===\n");
  }
  
