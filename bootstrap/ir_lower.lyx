  // ============================================================================
  // WP-20: Match / Pattern Lowering
  // ============================================================================
  
  // Match expression
  fn lowerMatch(expr: int64): int64 {
    // C0: subject expression
    // C1: cases (linked list of NK_MATCH_CASE)
    var subjectTemp: int64 := self.lowerExpr(self.nodeC0(expr));
    var cases: int64 := self.nodeC1(expr);
    var dest: int64 := self.allocTemp();
    
    var endLbl: int64 := self.genLabel();
    
    // Process each case
    var curCase: int64 := cases;
    while (curCase >= 0) {
      var pattern: int64 := self.nodeC0(curCase);
      var patternBody: int64 := self.nodeC1(curCase);
      var nextCaseLbl: int64 := self.genLabel();
      
      // Check pattern match
      var matched: int64 := self.lowerPatternMatch(subjectTemp, pattern);
      
      // Emit: if matched goto nextCaseLbl
      // Emit: body
      // Emit: dest = result
      // Emit: goto endLbl
      
      // nextCaseLbl:
      curCase := self.nodeNext(curCase);
    }
    
    // If no match found - handle default/wildcard
    
    // endLbl:
    return dest;
  }
  
  // Pattern match helper
  fn lowerPatternMatch(subjectTemp: int64, pattern: int64): int64 {
    var patKind: int64 := self.nodeKind(pattern);
    var dest: int64 := self.allocTemp();
    
    if (patKind == NK_PATTERN_LIT) {
      // Literal pattern: subjectTemp == pattern.value
      var patVal: int64 := self.nodeIVal(pattern);
      // Emit: dest = (subjectTemp == patVal)
    }
    else if (patKind == NK_PATTERN_WILD) {
      // Wildcard pattern: always matches
      // Emit: dest = 1
    }
    else if (patKind == NK_PATTERN_BIND) {
      // Binding pattern: bind subject to new variable
      // Emit: store subjectTemp to newVar
      // Emit: dest = 1
    }
    else if (patKind == NK_PATTERN_ENUM) {
      // Enum pattern: check tag and extract payload
      var enumName: pchar := self.nodeSVal(pattern);
      var payloadNode: int64 := self.nodeC0(pattern);
      // Emit: tag = subjectTemp.tag
      // Emit: if tag == enumTag then match payload
    }
    else if (patKind == NK_PATTERN_STRUCT) {
      // Struct pattern: destructure and match fields
      var structName: pchar := self.nodeSVal(pattern);
      var fields: int64 := self.nodeC0(pattern);
      // Emit: for each field, check field value
    }
    
    return dest;
  }
  
  // ============================================================================
  // WP-20: Switch Statement Lowering
  // ============================================================================
  
  // Switch statement (lowered to match or series of comparisons)
  fn lowerSwitch(stmt: int64): int64 {
    // C0: subject expression
    // C1: cases (linked list of NK_CASE)
    var subjectTemp: int64 := self.lowerExpr(self.nodeC0(stmt));
    var cases: int64 := self.nodeC1(stmt);
    var defaultCase: int64 := self.nodeC2(stmt);  // may be -1
    
    var endLbl: int64 := self.genLabel();
    
    // Generate jump table or series of comparisons
    // For small number of cases: if/else chain
    // For many cases: jump table (switch on index)
    
    var curCase: int64 := cases;
    while (curCase >= 0) {
      var caseVal: int64 := self.nodeIVal(self.nodeC0(curCase));
      var caseBody: int64 := self.nodeC1(curCase);
      var nextCaseLbl: int64 := self.genLabel();
      
      // Emit: if subjectTemp != caseVal goto nextCaseLbl
      if (caseBody >= 0) {
        self.lowerBlock(caseBody);
      }
      // Emit: goto endLbl
      
      // nextCaseLbl:
      curCase := self.nodeNext(curCase);
    }
    
    // Default case
    if (defaultCase >= 0) {
      self.lowerBlock(defaultCase);
    }
    
    // endLbl:
    return 0;
  }
  
