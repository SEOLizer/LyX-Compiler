  // Add function to IR module - using globalFuncCount field as workaround
  fn _addFunc() {
    var nameOff: int64 := self.nodeIVal(self.curFunc);
    var nameLen: int64 := 3;
    var funcIdx: int64 := self.irAddFunc(nameOff, nameLen, self.localCount, self.paramCount);
    self.globalFuncCount := self.globalFuncCount + 1;
  }
  
  // Helper: get string length
  fn getStringLen(off: int64): int64 {
    PrintStr("getStringLen: self.ir = "); PrintInt(self.ir); PrintStr("\n");
    PrintStr("getStringLen: off = "); PrintInt(off); PrintStr("\n");
    
    // Read strBuffer from IRModule at offset +24 (after vtable)
    var strBuf: int64 := peek64(self.ir + 24);
    PrintStr("getStringLen: strBuf = "); PrintInt(strBuf); PrintStr("\n");
    
    var ptr: int64 := strBuf + off;
    PrintStr("getStringLen: ptr = "); PrintInt(ptr); PrintStr("\n");
    
    var len: int64 := 0;
    // Try just one iteration to see if it crashes
    var b: int64 := peek8(ptr);
    PrintStr("getStringLen: first byte = "); PrintInt(b); PrintStr("\n");
    
    return len;
