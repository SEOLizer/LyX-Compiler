// ============================================================================
// Compiler Constants
// ============================================================================

con COMPILER_NAME: pchar := "lyxc";
con COMPILER_VERSION: pchar := "0.3.0";
con COMPILER_BUILD: pchar := "bootstrap";

// Target architectures
con TARGET_X86_64: int64 := 1;
con TARGET_ARM64: int64 := 2;
con TARGET_RISCV64: int64 := 3;
con TARGET_ARM_CM: int64 := 4;

// Optimization levels
con OPT_NONE: int64 := 0;
con OPT_O1: int64 := 1;
con OPT_O2: int64 := 2;
con OPT_O3: int64 := 3;
con OPT_SAFE: int64 := 4;

// Output formats
con FORMAT_ELF: int64 := 1;
con FORMAT_PE: int64 := 2;
con FORMAT_MACHO: int64 := 3;

// ============================================================================
// Command Line Options
// ============================================================================

pub type CLIOptions = record {
  // Input/Output
  inputFile: int64;
  outputFile: int64;
  
  // Target
  target: int64;
  format: int64;
  
  // Optimization
  optLevel: int64;
  
  // Features
  enableLint: bool;
  lintOnly: bool;
  enableDebug: bool;
  enableVerbose: bool;
  
  // Dump options
  dumpLexer: bool;
  dumpParser: bool;
  dumpSema: bool;
  dumpIR: bool;
  dumpASM: bool;
  emitASM: bool;
  dumpList: bool;
  
  // Warnings
  warningsAsErrors: bool;
  warnAll: bool;
  
  // Misc
  includePath: int64;
  stdPath: int64;
  arch: int64;
  defineMacros: int64;
  emitRelocs: bool;
  stripDebug: bool;
};

// ============================================================================
// Compiler Configuration
// ============================================================================

pub type CompilerConfig = class {
  // Options
  opts: CLIOptions;
  
  // Compilation state
  exitCode: int64;
  errorCount: int64;
  warningCount: int64;
  codeSize: int64;
  
  // Module cache
  unitCache: int64;
  
  // Build info
  buildTime: int64;
  
  // Constructor
  pub fn Create(): int64 {
    var self: int64 := alloc(sizeof(CompilerConfig));
    
    self.opts := 0 as CLIOptions;
    self.exitCode := 0;
    self.errorCount := 0;
    self.warningCount := 0;
    
    self.unitCache := map_new(32);
    self.buildTime := Time();
    
    return self;
  }
  
  // ---------------------------------------------------------------------------
  // CLI Parsing
  // ---------------------------------------------------------------------------
  
  fn parseCLI(argc: int64, argv: pchar): bool {
    self.opts := alloc(sizeof(CLIOptions));
    
    var i: int64 := 1;
    
    while i < argc {
      var arg: pchar := ArgvGet(argv, i);
      var argLen: int64 := StrLen(arg);
      
      if argLen == 0 {
        i := i + 1;
        continue;
      }
      
      var firstChar: int64 := peek8(arg);
      
      // Check for flag (starts with -)
      if firstChar == 45 {  // '-'
        if argLen == 1 {
          i := i + 1;
          continue;
        }
        
        var secondChar: int64 := peek8(arg + 1);
        
        // Long flags (--)
        if secondChar == 45 {  // '--'
          self.parseLongFlag(arg, argLen);
        } else {
          // Short flags (-)
          self.parseShortFlags(arg, argLen);
        }
      } else {
        // Positional argument
        if self.opts.inputFile == 0 {
          self.opts.inputFile := arg;
        } else if self.opts.outputFile == 0 {
          self.opts.outputFile := arg;
        }
      }
      
      i := i + 1;
    }
    
    // Validate required options
    if self.opts.inputFile == 0 {
      EPrintStr("Error: No input file specified\n"c);
      self.exitCode := 1;
      return false;
    }
    
    // Set defaults
    if self.opts.target == 0 {
      self.opts.target := TARGET_X86_64;
    }
    if self.opts.format == 0 {
      self.opts.format := FORMAT_ELF;
    }
    if self.opts.optLevel == 0 {
      self.opts.optLevel := OPT_O2;
    }
    
    return true;
  }
  
  fn parseLongFlag(arg: int64, argLen: int64): void {
    // --target=x86_64|arm64|riscv64|arm_cm
    if StrStartsWith(arg, "--target=") {
      var val: int64 := arg + 8;
      if StrCmp(val, "x86_64"c) == 0 {
        self.opts.target := TARGET_X86_64;
      } else if StrCmp(val, "arm64"c) == 0 {
        self.opts.target := TARGET_ARM64;
      } else if StrCmp(val, "riscv64"c) == 0 {
        self.opts.target := TARGET_RISCV64;
      } else if StrCmp(val, "arm_cm"c) == 0 {
        self.opts.target := TARGET_ARM_CM;
      }
      return;
    }
    
    // --std-path=PATH
    if StrStartsWith(arg, "--std-path=") {
      self.opts.stdPath := arg + 10;
      return;
    }
    
    // --arch=x86_64|arm64|xtensa|riscv
    if StrStartsWith(arg, "--arch=") {
      var val: int64 := arg + 7;
      if StrCmp(val, "x86_64"c) == 0 {
        self.opts.arch := TARGET_X86_64;
      } else if StrCmp(val, "arm64"c) == 0 {
        self.opts.arch := TARGET_ARM64;
      } else if StrCmp(val, "riscv"c) == 0 {
        self.opts.arch := TARGET_RISCV64;
      }
      return;
    }
    
    // --output= or -o
    if StrStartsWith(arg, "--output=") {
      self.opts.outputFile := arg + 9;
      return;
    }
    
    // --opt=O0|O1|O2|O3|Osafe
    if StrStartsWith(arg, "--opt=") {
      var val: int64 := arg + 6;
      if StrCmp(val, "O0"c) == 0 {
        self.opts.optLevel := OPT_NONE;
      } else if StrCmp(val, "O1"c) == 0 {
        self.opts.optLevel := OPT_O1;
      } else if StrCmp(val, "O2"c) == 0 {
        self.opts.optLevel := OPT_O2;
      } else if StrCmp(val, "O3"c) == 0 {
        self.opts.optLevel := OPT_O3;
      } else if StrCmp(val, "Osafe"c) == 0 {
        self.opts.optLevel := OPT_SAFE;
      }
      return;
    }
    
    // --format=elf|pe|macho
    if StrStartsWith(arg, "--format=") {
      var val: int64 := arg + 9;
      if StrCmp(val, "elf"c) == 0 {
        self.opts.format := FORMAT_ELF;
      } else if StrCmp(val, "pe"c) == 0 {
        self.opts.format := FORMAT_PE;
      } else if StrCmp(val, "macho"c) == 0 {
        self.opts.format := FORMAT_MACHO;
      }
      return;
    }
    
    // Boolean flags
    if StrCmp(arg, "--lint"c) == 0 {
      self.opts.enableLint := true;
      return;
    }
    if StrCmp(arg, "--lint-only"c) == 0 {
      self.opts.lintOnly := true;
      self.opts.enableLint := true;
      return;
    }
    if StrCmp(arg, "--debug"c) == 0 {
      self.opts.enableDebug := true;
      return;
    }
    if StrCmp(arg, "--verbose"c) == 0 {
      self.opts.enableVerbose := true;
      return;
    }
    if StrCmp(arg, "--warnings-as-errors"c) == 0 {
      self.opts.warningsAsErrors := true;
      return;
    }
    if StrCmp(arg, "--warn-all"c) == 0 {
      self.opts.warnAll := true;
      return;
    }
    if StrCmp(arg, "--dump-lexer"c) == 0 {
      self.opts.dumpLexer := true;
      return;
    }
    if StrCmp(arg, "--dump-parser"c) == 0 {
      self.opts.dumpParser := true;
      return;
    }
    if StrCmp(arg, "--dump-sema"c) == 0 {
      self.opts.dumpSema := true;
      return;
    }
    if StrCmp(arg, "--dump-ir"c) == 0 {
      self.opts.dumpIR := true;
      return;
    }
    if StrCmp(arg, "--dump-asm"c) == 0 {
      self.opts.dumpASM := true;
      return;
    }
    if StrCmp(arg, "--emit-asm"c) == 0 {
      self.opts.emitASM := true;
      return;
    }
    if StrCmp(arg, "--list"c) == 0 {
      self.opts.dumpList := true;
      return;
    }
    
    // --version
    if StrCmp(arg, "--version"c) == 0 {
      PrintStr(COMPILER_NAME);
      PrintStr(" "c);
      PrintStrLn(COMPILER_VERSION);
      PrintStr("Build: "c);
      PrintStrLn(COMPILER_BUILD);
      self.exitCode := 0;
      return;
    }
    
    // --help
    if StrCmp(arg, "--help"c) == 0 {
      self.printHelp();
      self.exitCode := 0;
      return;
    }
    
    // --build-info
    if StrCmp(arg, "--build-info"c) == 0 {
      PrintStrLn("Compiler Build Information:");
      PrintStr("  Name: "c);
      PrintStrLn(COMPILER_NAME);
      PrintStr("  Version: "c);
      PrintStrLn(COMPILER_VERSION);
      PrintStr("  Build: "c);
      PrintStrLn(COMPILER_BUILD);
      PrintStr("  Target: "c);
      PrintStrLn("x86_64-linux-elf");
      self.exitCode := 0;
      return;
    }
    
    // --config
    if StrCmp(arg, "--config"c) == 0 {
      PrintStrLn("Compiler Configuration:");
      PrintStr("  Targets: x86_64, arm64, riscv64, arm_cm"c);
      PrintStrLn("");
      PrintStr("  Formats: elf, pe, macho"c);
      PrintStrLn("");
      PrintStr("  Optimization: O0, O1, O2, O3, Osafe"c);
      self.exitCode := 0;
      return;
    }
    
    // --no-opt (disable optimizations)
    if StrCmp(arg, "--no-opt"c) == 0 {
      self.opts.optLevel := OPT_NONE;
      return;
    }
    
    // --no-lint (disable linter)
    if StrCmp(arg, "--no-lint"c) == 0 {
      self.opts.enableLint := false;
      return;
    }
  }
  
  fn parseShortFlags(arg: int64, argLen: int64): void {
    var i: int64 := 1;
    while i < argLen {
      var c: int64 := peek8(arg + i);
      
      if c == 111 {  // 'o'
        // -o next arg is output
        if i + 1 < argLen {
          self.opts.outputFile := arg + i + 1;
        }
      } else if c == 79 {  // 'O'
        // -Olevel
        var level: int64 := peek8(arg + i + 1);
        if level == 48 {  // '0'
          self.opts.optLevel := OPT_NONE;
        } else if level == 49 {  // '1'
          self.opts.optLevel := OPT_O1;
        } else if level == 50 {  // '2'
          self.opts.optLevel := OPT_O2;
        } else if level == 51 {  // '3'
          self.opts.optLevel := OPT_O3;
        }
      } else if c == 118 {  // 'v'
        self.opts.enableVerbose := true;
      } else if c == 100 {  // 'd'
        self.opts.enableDebug := true;
      } else if c == 108 {  // 'l'
        self.opts.enableLint := true;
      } else if c == 71 {  // 'g'
        self.opts.enableDebug := true;
      } else if c == 119 {  // 'W'
        if i + 1 < argLen {
          var next: int64 := peek8(arg + i + 1);
          if next == 101 {  // 'e'
            self.opts.warningsAsErrors := true;
          } else if next == 97 {  // 'a'
            self.opts.warnAll := true;
          }
        }
      }
      
      i := i + 1;
    }
  }
  
