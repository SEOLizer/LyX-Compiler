    PrintStrLn("Usage: lyxc [options] <input> [-o <output>]");
    PrintStrLn("");
    PrintStrLn("Options:");
    PrintStrLn("  --std-path=PATH    Stdlib path override");
    PrintStrLn("  --arch=ARCH        Architecture: x86_64, arm64, riscv");
    PrintStrLn("  --target=<arch>     Target architecture: x86_64, arm64, riscv64, arm_cm");
    PrintStrLn("  --format=<fmt>     Output format: elf, pe, macho");
    PrintStrLn("  --opt=<level>      Optimization: O0, O1, O2, O3, Osafe");
    PrintStrLn("  --no-opt           Disable IR optimizations");
    PrintStrLn("  --no-lint          Disable linter");
    PrintStrLn("  -o <file>          Output file");
    PrintStrLn("  --lint             Enable linter");
    PrintStrLn("  --lint-only        Lint only, skip compilation");
    PrintStrLn("  --debug            Include debug info");
    PrintStrLn("  --verbose          Verbose output");
    PrintStrLn("  --dump-lexer       Dump lexer tokens");
    PrintStrLn("  --dump-parser      Dump AST");
    PrintStrLn("  --dump-sema        Dump semantic info");
    PrintStrLn("  --dump-ir          Dump IR");
    PrintStrLn("  --dump-asm        Dump assembly");
    PrintStrLn("  --emit-asm        Emit IR as pseudo-assembler (no binary)");
    PrintStrLn("  --list             Generate listing");
    PrintStrLn("  --version         Show version");
    PrintStrLn("  --help             Show this help");
  }
  
  // ---------------------------------------------------------------------------
  // Pipeline Orchestration
  // ---------------------------------------------------------------------------
  
  pub fn Compile(inputFile: pchar): int64 {
    if self.opts.enableVerbose {
      PrintStr("Compiling: "c);
      PrintStrLn(inputFile);
    }
    
    // Stage 1: Lexer
    if self.opts.enableVerbose {
      PrintStrLn("Stage 1: Lexing...");
    }
    
    var source: pchar := FileReadAll(inputFile);
    if source == 0 as pchar {
      EPrintStr("Error: Cannot read input file: "c);
      EPrintStrLn(inputFile);
      self.exitCode := 1;
      return self.exitCode;
    }
    
    var lexer: int64 := TLexer.Create(source, StrLen(source));
    lexer.Init();
    
    if self.opts.dumpLexer {
      self.dumpTokens(lexer);
    }
    
    // Stage 2: Parser
    if self.opts.enableVerbose {
      PrintStrLn("Stage 2: Parsing...");
    }
    
    var parser: int64 := TParser.Create();
    parser.Init(lexer);
    var astRoot: int64 := parser.Parse();
    
    if parser.HasErrors() {
      self.exitCode := 1;
      return self.exitCode;
    }
    
    if self.opts.dumpParser {
      self.dumpAST(astRoot);
    }
    
    // Stage 3: Semantic Analysis
    if self.opts.enableVerbose {
      PrintStrLn("Stage 3: Semantic Analysis...");
    }
    
    var sema: int64 := TSema.Create();
    sema.Init();
    var semaResult: int64 := sema.Analyze(astRoot);
    
    if semaResult != 0 {
      self.exitCode := 1;
      return self.exitCode;
    }
    
    if self.opts.dumpSema {
      self.dumpSemaInfo(sema);
    }
    
    // Stage 4: Linter (optional)
    if self.opts.enableLint {
      if self.opts.enableVerbose {
        PrintStrLn("Stage 4: Linting...");
      }
      
      var linter: int64 := TLinter.Create();
      var lintResult: int64 := linter.Lint(astRoot);
      
      if lintResult != 0 {
        self.warningCount := self.warningCount + lintResult;
        
        if self.opts.warningsAsErrors {
          self.exitCode := 1;
          return self.exitCode;
        }
      }
    }
    
    // Stage 5: Early exit for lint-only mode
    if self.opts.lintOnly {
      if self.opts.enableVerbose {
        PrintStrLn("Lint-only mode: skipping compilation");
      }
      return self.exitCode;
    }
    
    // Stage 5: IR Generation
    if self.opts.enableVerbose {
      PrintStrLn("Stage 5: IR Generation...");
    }

    // Create IR module and lower AST → IR
    var irMod: IRModule := new IRModule();
    irMod.init();

    var lower: IRLower := new IRLower();
    lower.init(irMod as int64, astRoot, 0, 0 as pchar);
    lower.lowerModule(astRoot);

    if self.opts.dumpIR {
      self.dumpIR(irMod as int64);
    }

    // Stage 6: Optimization
    if self.opts.optLevel > OPT_NONE {
      if self.opts.enableVerbose {
        PrintStrLn("Stage 6: Optimizing...");
      }

      var optimizer: IROptimize := new IROptimize();
      optimizer.init(irMod);
      optimizer.optimize();

      if self.opts.enableVerbose {
        PrintStr("Optimization passes: "c);
        PrintInt(optimizer.passCount);
        PrintStrLn(" iterations"c);
      }
    }

    // Stage 7: Inlining (if enabled)
    // TODO: Wire up ir_inline when ready

    // Stage 7: Code Generation
    if self.opts.enableVerbose {
      PrintStrLn("Stage 7: Code Generation...");
    }

    var codeBuffer: int64 := 0;

    if self.opts.target == TARGET_X86_64 {
      codeBuffer := self.emitX86_64(irMod as int64);
    } else if self.opts.target == TARGET_ARM64 {
      codeBuffer := self.emitARM64(irMod as int64);
    } else if self.opts.target == TARGET_RISCV64 {
      codeBuffer := self.emitRISCV(irMod as int64);
    } else if self.opts.target == TARGET_ARM_CM {
      codeBuffer := self.emitARMCm(irMod as int64);
    }

    if codeBuffer == 0 {
      self.exitCode := 1;
      return self.exitCode;
    }

    if self.opts.dumpASM {
      self.dumpASM(codeBuffer, self.codeSize);
    }
    
    // Stage 8: Binary Writing
    if self.opts.enableVerbose {
      PrintStrLn("Stage 8: Writing Binary...");
    }
    
    // Emit ASM mode: skip binary writing
    if self.opts.emitASM {
      if self.opts.enableVerbose {
        PrintStrLn("Emit-ASM mode: skipping binary write");
      }
      // Output assembly instead
      self.emitASMFile(outputFile, codeBuffer, self.codeSize);
      return self.exitCode;
    }
    
    var outputFile: pchar := self.opts.outputFile;
    if outputFile == 0 as pchar {
      // Default output name
      outputFile := "a.out"c;
    }
    
    var writeResult: bool := self.writeBinary(outputFile, codeBuffer, self.codeSize);
    
    if not writeResult {
      EPrintStrLn("Error: Cannot write output file");
      self.exitCode := 1;
      return self.exitCode;
    }
    
    if self.opts.enableVerbose {
      PrintStr("Wrote: "c);
      PrintStrLn(outputFile);
    }
    
    return self.exitCode;
  }
  
  // ---------------------------------------------------------------------------
  // Code Emission
  // ---------------------------------------------------------------------------

  fn emitX86_64(irMod: int64): int64 {
    var emitter: Emitx86 := new Emitx86();
    emitter.init(irMod);
    self.codeSize := emitter.emit();
    return emitter.getCodeBuf();
  }

  fn emitARM64(irMod: int64): int64 {
    var emitter: EmitARM64 := new EmitARM64();
    emitter.init(irMod);
    self.codeSize := emitter.emit();
    return emitter.getCodeBuf();
  }

  fn emitRISCV(irMod: int64): int64 {
    var emitter: RISCVEmitter := new RISCVEmitter();
    emitter.init(irMod);
    self.codeSize := emitter.emit();
    return emitter.getCodeBuf();
  }

  fn emitARMCm(irMod: int64): int64 {
    var emitter: ARMCMEmitter := new ARMCMEmitter();
    emitter.init(irMod);
    self.codeSize := emitter.emit();
    return emitter.getCodeBuf();
  }
  
  // ---------------------------------------------------------------------------
  // Binary Writing
  // ---------------------------------------------------------------------------
  
  fn writeBinary(path: pchar, code: int64, size: int64): bool {
    if self.opts.format == FORMAT_ELF {
      return self.writeELF(path, code, size);
    } else if self.opts.format == FORMAT_PE {
      return self.writePE(path, code, size);
    } else if self.opts.format == FORMAT_MACHO {
      return self.writeMachO(path, code, size);
    }
    return false;
  }
  
  fn writeELF(path: pchar, code: int64, size: int64): bool {
    var writer: int64 := ELF64Writer.Create();
    writer.SetEntry(0x401000);
    writer.SetTextSection(code, size, 0x401000);
    
    var output: int64 := writer.Write();
    var outputSize: int64 := writer.GetSize();
    
    var result: bool := FileWriteAll(path, output as pchar, outputSize);
    
    writer.Free();
    
    return result;
  }
  
  fn writePE(path: pchar, code: int64, size: int64): bool {
    var writer: int64 := PE64Writer.Create();
    writer.SetEntry(0x401000);
    writer.SetTextSection(code, size, 0x401000);
    
    var output: int64 := writer.Write();
    var outputSize: int64 := writer.GetSize();
    
    var result: bool := FileWriteAll(path, output as pchar, outputSize);
    
    writer.Free();
    
    return result;
  }
  
  fn writeMachO(path: pchar, code: int64, size: int64): bool {
    var writer: int64 := MachO64Writer.Create();
    writer.SetEntry(0x1000);
    writer.SetTextSection(code, size, 0x1000);
    
    var output: int64 := writer.Write();
    var outputSize: int64 := writer.GetSize();
    
    var result: bool := FileWriteAll(path, output as pchar, outputSize);
    
    writer.Free();
    
    return result;
  }
  
  // ---------------------------------------------------------------------------
  // Dump Functions
  // ---------------------------------------------------------------------------
  
  fn dumpTokens(lexer: int64): void {
    var l: int64 := lexer as TLexer;
    PrintStrLn("=== LEXER TOKENS ===");
    
    var tok: int64 := l.Next();
    while tok != 0 {
      var kind: int64 := l.TokKind(tok);
      PrintStr("Token "c);
      PrintInt(kind);
      PrintStr(": "c);
      var text: pchar := l.TokText(tok);
      if text != 0 as pchar {
        PrintStrLn(text);
      } else {
        PrintStrLn("(null)");
      }
      tok := l.Next();
    }
  }
  
  fn dumpAST(astRoot: int64): void {
    PrintStrLn("=== PARSER AST ===");
    // Would dump AST nodes
  }
  
  fn dumpSemaInfo(sema: int64): void {
    PrintStrLn("=== SEMANTIC INFO ===");
    // Would dump symbol table
  }
  
  fn dumpIR(irMod: int64): void {
    PrintStrLn("=== IR DUMP ===");
    // Would dump IR
  }
  
  fn dumpASM(code: int64, size: int64): void {
    PrintStrLn("=== ASSEMBLY ===");
    // Would dump disassembly
  }
  
  fn emitASMFile(path: pchar, code: int64, size: int64): void {
    // Write assembly to file instead of binary
    // For now, dump to stdout
    PrintStrLn("=== EMITTED ASSEMBLY ===");
    PrintStr("Output written to: "c);
    PrintStrLn(path);
  }
  
  // ---------------------------------------------------------------------------
  // Multi-Target Dispatch
  // ---------------------------------------------------------------------------
  
  pub fn GetTargetName(): pchar {
    if self.opts.target == TARGET_X86_64 {
      return "x86_64"c;
    }
    if self.opts.target == TARGET_ARM64 {
      return "arm64"c;
    }
    if self.opts.target == TARGET_RISCV64 {
      return "riscv64"c;
    }
    if self.opts.target == TARGET_ARM_CM {
      return "arm_cm"c;
    }
    return "unknown"c;
  }
  
  // ---------------------------------------------------------------------------
  // Unit Cache
  // ---------------------------------------------------------------------------
  
  pub fn GetCachedUnit(path: pchar): int64 {
    return map_get(self.unitCache, path, StrLen(path));
  }
  
  pub fn CacheUnit(path: pchar, unitData: int64): void {
    map_set(self.unitCache, path, StrLen(path), unitData);
  }
  
  // ---------------------------------------------------------------------------
  // Incremental Compilation
  // ---------------------------------------------------------------------------
  
  fn shouldRebuild(inputFile: pchar, outputFile: pchar): bool {
    if not FileExists(outputFile) {
      return true;
    }
    
    var inputTime: int64 := FileModTime(inputFile);
    var outputTime: int64 := FileModTime(outputFile);
    
    return inputTime > outputTime;
  }
  
  // ---------------------------------------------------------------------------
  // Error Handling
  // ---------------------------------------------------------------------------
  
  pub fn ReportError(msg: pchar, line: int64, column: int64): void {
    EPrintStr("Error");
    if line > 0 {
      EPrintStr(": "c);
      EPrintInt(line);
      if column > 0 {
        EPrintStr(":"c);
        EPrintInt(column);
      }
    }
    EPrintStr(": "c);
    EPrintStrLn(msg);
    
    self.errorCount := self.errorCount + 1;
  }
  
  pub fn ReportWarning(msg: pchar, line: int64, column: int64): void {
    EPrintStr("Warning");
    if line > 0 {
      EPrintStr(": "c);
      EPrintInt(line);
      if column > 0 {
        EPrintStr(":"c);
        EPrintInt(column);
      }
    }
    EPrintStr(": "c);
    EPrintStrLn(msg);
    
    self.warningCount := self.warningCount + 1;
  }
  
  // ---------------------------------------------------------------------------
  // Statistics
  // ---------------------------------------------------------------------------
  
  pub fn PrintStats(): void {
    if self.opts.enableVerbose {
      PrintStrLn("=== COMPILATION STATS ===");
      PrintStr("Errors: "c);
      PrintIntLn(self.errorCount);
      PrintStr("Warnings: "c);
      PrintIntLn(self.warningCount);
      PrintStr("Time: "c);
      PrintInt(Time() - self.buildTime);
      PrintStrLn("ms");
    }
  }
  
  // ---------------------------------------------------------------------------
  // Memory Management
  // ---------------------------------------------------------------------------
  
  pub fn Free(): void {
    if self.unitCache != 0 {
      map_free(self.unitCache);
    }
    if self.opts != 0 {
      free(self.opts as int64);
    }
    free(self);
  }
};

// ============================================================================
// Global Compiler Instance
// ============================================================================

var globalCompiler: int64 := 0;

// ============================================================================
// Main Entry Point
// ============================================================================

pub fn main(argc: int64, argv: pchar): int64 {
  // Initialize compiler
  globalCompiler := CompilerConfig.Create();
  var cfg: int64 := globalCompiler as CompilerConfig;
  
  // Parse CLI
  var cliOk: bool := cfg.parseCLI(argc, argv);
  if not cliOk {
    return cfg.exitCode;
  }
  
  // Get input file
  var inputFile: pchar := cfg.opts.inputFile;
  if inputFile == 0 as pchar {
    EPrintStrLn("Error: No input file specified");
    EPrintStrLn("Run with --help for usage");
    cfg.exitCode := 1;
    return cfg.exitCode;
  }
  
  // Check if we need to rebuild
  var outputFile: pchar := cfg.opts.outputFile;
  if outputFile == 0 as pchar {
    outputFile := "a.out"c;
  }
  
  if cfg.shouldRebuild(inputFile, outputFile) {
    // Compile
    cfg.Compile(inputFile);
  } else {
    if cfg.opts.enableVerbose {
      PrintStr("Skipping "c);
      PrintStr(inputFile);
      PrintStrLn(" (already up to date)");
    }
  }
  
  // Print statistics
  cfg.PrintStats();
  
  // Cleanup
  var exitCode: int64 := cfg.exitCode;
  cfg.Free();
  
  return exitCode;
}
