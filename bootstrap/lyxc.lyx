  pub fn ReportError(msg: pchar, line: int64, column: int64): void {
    EPrintStr("Error");
    if line > 0 {
      EPrintStr(": "c);
      EPrintInt(line);
      if column > 0 {
        EPrintStr(":"c);
        EPrintInt(column);
      }
    }
    EPrintStr(": "c);
    EPrintStrLn(msg);
    
    self.errorCount := self.errorCount + 1;
  }
  
