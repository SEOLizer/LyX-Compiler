  fn dumpTokens(source: pchar, srcLen: int64): void {
    var lx: Lexer := new Lexer();
    lx.Init(source, srcLen);
    PrintStrLn("=== LEXER TOKENS ===");
    var kind: int64 := lx.Next();
    while kind != TK_EOF {
      PrintStr("Token "c);
      PrintInt(kind);
      PrintStr(": "c);
      var text: pchar := lx.TokText();
      if text != 0 {
        PrintStrLn(text);
      } else {
        PrintStrLn("(null)");
      }
      kind := lx.Next();
    }
    dispose lx;
  }
  
