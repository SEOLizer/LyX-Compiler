// ============================================================================
// Compiler Constants
// ============================================================================

con COMPILER_NAME: pchar := "lyxc";
con COMPILER_VERSION: pchar := "0.3.0";
con COMPILER_BUILD: pchar := "bootstrap";

// Target architectures
con TARGET_X86_64: int64 := 1;
con TARGET_ARM64: int64 := 2;
con TARGET_RISCV64: int64 := 3;
con TARGET_ARM_CM: int64 := 4;

// Optimization levels
con OPT_NONE: int64 := 0;
con OPT_O1: int64 := 1;
con OPT_O2: int64 := 2;
con OPT_O3: int64 := 3;
con OPT_SAFE: int64 := 4;

// Output formats
con FORMAT_ELF: int64 := 1;
con FORMAT_PE: int64 := 2;
con FORMAT_MACHO: int64 := 3;

// ============================================================================
// Command Line Options
// ============================================================================

pub type CLIOptions = struct {
  // Input/Output (using int64 for pointer storage)
  inputFile: int64;
  outputFile: int64;
  
  // Target
  target: int64;
  format: int64;
  
  // Optimization
  optLevel: int64;
  
  // Features
  enableLint: bool;
  lintOnly: bool;
  enableDebug: bool;
  enableVerbose: bool;
  
  // Dump options
  dumpLexer: bool;
  dumpParser: bool;
  dumpSema: bool;
  dumpIR: bool;
  dumpASM: bool;
  emitASM: bool;
  dumpList: bool;

  // CLI P2: Advanced options
  targetEnergy: int64;
  dumpRelocs: bool;
  traceImports: bool;

  // CLI P3: Analysis and instrumentation
  asmListing: bool;
  mcdc: bool;
  mcdcReport: bool;
  staticAnalysis: bool;
  callGraph: bool;
  mapFile: bool;
  
  // Warnings
  warningsAsErrors: bool;
  warnAll: bool;
  
  // Misc
  includePath: int64;
  stdPath: int64;
  arch: int64;
  defineMacros: int64;
  emitRelocs: bool;
  stripDebug: bool;
};

