    if self.target == TARGET_ARM64 {
      return "arm64"c;
    }
    if self.target == TARGET_RISCV64 {
      return "riscv64"c;
    }
    if self.target == TARGET_ARM_CM {
      return "arm_cm"c;
    }
    return "unknown"c;
  }
  
