  pub fn PrintStats(): void {
    if self.enableVerbose {
      PrintStrLn("=== COMPILATION STATS ===");
      PrintStr("Errors: "c);
      PrintIntLn(self.errorCount);
      PrintStr("Warnings: "c);
      PrintIntLn(self.warningCount);
      PrintStr("Time: "c);
      PrintInt(Time() - self.buildTime);
      PrintStrLn("ms");
    }
  }
  
  // ---------------------------------------------------------------------------
  // Memory Management
  // ---------------------------------------------------------------------------
  
  pub fn Free(): void {
    PrintStrLn("=== Free START ===");
    PrintStr("self = "); PrintInt(self); PrintStr("\n");
    PrintStr("unitCache = "); PrintInt(self.unitCache); PrintStr("\n");
    
    if self.unitCache != 0 {
      PrintStrLn("Free: calling map_free...");
      map_free(self.unitCache);
      PrintStrLn("Free: map_free done");
    } else {
      PrintStrLn("Free: unitCache is 0, skipping");
    }
    
    PrintStrLn("Free: about to call free(self)...");
    free(self);
    PrintStrLn("Free: done");
  }
};

// ============================================================================
// Global Compiler Instance
// ============================================================================

var globalCompiler: int64 := 0;

// ============================================================================
// Main Entry Point
// ============================================================================

pub fn main(argc: int64, argv: pchar): int64 {
  // Initialize compiler
  globalCompiler := CompilerConfig.Create();
  var cfg: int64 := globalCompiler as CompilerConfig;
  
  // Parse CLI
  var cliOk: bool := cfg.parseCLI(argc, argv);
  if not cliOk {
    return cfg.exitCode;
  }
  
  // Get input file
  var inputFile: pchar := cfg.inputFile;
  if inputFile == 0 {
    EPrintStrLn("Error: No input file specified");
    EPrintStrLn("Run with --help for usage");
    cfg.exitCode := 1;
    return cfg.exitCode;
  }
  
  // Check if we need to rebuild
  var outputFile: pchar := cfg.outputFile;
  if outputFile == 0 {
    outputFile := "a.out"c;
  }
  
  if cfg.shouldRebuild(inputFile, outputFile) {
    PrintStrLn("shouldRebuild returned true - calling Compile...");
    // Compile
    cfg.Compile(inputFile, outputFile);
    PrintStrLn("Compile done");
  } else {
    if cfg.enableVerbose {
      PrintStr("Skipping "c);
      PrintStr(inputFile);
      PrintStrLn(" (already up to date)");
    }
  }
  
  // Print statistics
  cfg.PrintStats();
  
  // Cleanup
  var exitCode: int64 := cfg.exitCode;
  
  // Inline the free logic to avoid method call issues
  if cfg.unitCache != 0 {
    map_free(cfg.unitCache);
  }
  free(cfg);
  
  return exitCode;
}
 
