      PrintIntLn(self.errorCount);
      PrintStr("Warnings: "c);
      PrintIntLn(self.warningCount);
      PrintStr("Time: "c);
      PrintInt(Time() - self.buildTime);
      PrintStrLn("ms");
    }
  }
  
  // ---------------------------------------------------------------------------
  // Memory Management
  // ---------------------------------------------------------------------------
  
  pub fn Free(): void {
    PrintStrLn("=== Free START ===");
    PrintStr("self = "); PrintInt(self); PrintStr("\n");
    PrintStr("unitCache = "); PrintInt(self.unitCache); PrintStr("\n");
    
    if self.unitCache != 0 {
      PrintStrLn("Free: calling map_free...");
      map_free(self.unitCache);
      PrintStrLn("Free: map_free done");
    } else {
      PrintStrLn("Free: unitCache is 0, skipping");
    }
    
    PrintStrLn("Free: about to call free(self)...");
    free(self);
    PrintStrLn("Free: done");
  }
