  // ---------------------------------------------------------------------------
  // Binary Writing
  // ---------------------------------------------------------------------------
  
  fn writeBinary(path: pchar, code: int64, size: int64): bool {
    PrintStrLn("=== writeBinary START ===");
    PrintStr("path = "); PrintInt(path as int64); PrintStr("\n");
    PrintStr("code = "); PrintInt(code); PrintStr("\n");
    PrintStr("size = "); PrintInt(size); PrintStr("\n");
    PrintStr("format = "); PrintInt(self.format); PrintStr("\n");
    PrintStr("FORMAT_ELF = "); PrintInt(FORMAT_ELF); PrintStr("\n");
    
    if self.format == FORMAT_ELF {
      PrintStrLn("writeBinary: calling writeELF...");
      return self.writeELF(path, code, size);
    } else if self.format == FORMAT_PE {
      return self.writePE(path, code, size);
    } else if self.format == FORMAT_MACHO {
      return self.writeMachO(path, code, size);
    }
    PrintStrLn("writeBinary: unknown format, returning false");
    return false;
  }
  
  fn writeELF(path: pchar, code: int64, size: int64): bool {
    // Create a minimal valid ELF64 file
    var codeOffset: int64 := 4096;  // Put code at offset 4096
    var elfSize: int64 := codeOffset + size;
    var elfBuf: int64 := mmap(0, elfSize, 3, 34, -1, 0);
    
    // Build the ELF header manually using poke32 where possible
    // e_ident[0-3] = 0x7f + "ELF" (0x464c457f in big endian, but we write bytes individually)
    
    // Set each byte of ELF magic individually
    var ptr: int64 := elfBuf;
    // magic: 0x7f 0x45 0x4c 0x46
    var magic: int64 := 0x464c457f;
    // In memory: 7f 45 4c 46 - let's write as 32-bit little endian value
    poke32(elfBuf + 0, magic);
    // But we need 0x7f at offset 0... the value 0x464c457f has 0x7f at highest byte
    // That's wrong. 0x464c457f = 1179403647 decimal
    // In little endian: 7f 45 4c 46 - but that's actually 0x464c457f reversed
    
    // Let's use a simpler approach - write the exact hex bytes we need
    // e_ident[0] = 0x7f = 127
    // e_ident[1] = 'E' = 69
    // e_ident[2] = 'L' = 76
    // e_ident[3] = 'F' = 70
    
    // Try writing 8 bytes at a time
    var ident: int64 := 0x464c45;  // Would be "ELE" reversed - no that's not right either
    
    // Try directly writing specific byte values we know work from xxd output
    // At offset 0: 7f
    poke8(elfBuf + 0, 127);  // 0x7f
    poke8(elfBuf + 1, 69);   // 'E'
    poke8(elfBuf + 2, 76);   // 'L'
    poke8(elfBuf + 3, 70);   // 'F'
    poke8(elfBuf + 4, 2);    // 64-bit
    poke8(elfBuf + 5, 1);    // little endian
    poke8(elfBuf + 6, 1);    // ELF version
    poke8(elfBuf + 7, 0);    // OS/ABI
    
    // e_type = 2 (ET_EXEC) at offset 16
    poke16(elfBuf + 16, 2);
    // e_machine = 62 (x86-64) at offset 18
    poke16(elfBuf + 18, 62);
    // e_entry = 0x1000 at offset 24
    // 0x1000 = 4096 = 0x00 0x10 0x00 0x00 in little endian
    poke8(elfBuf + 24, 0);    // low byte = 0
    poke8(elfBuf + 25, 16);   // next = 16 (0x10)
    poke8(elfBuf + 26, 0);    // 0x00
    poke8(elfBuf + 27, 0);    // 0x00
    
    // e_phoff = 64 at offset 32
    poke64(elfBuf + 32, 64);
    // e_shoff = 0 at offset 40
    poke64(elfBuf + 40, 0);
    // e_flags = 0 at offset 48
    poke32(elfBuf + 48, 0);
    // e_ehsize = 64 at offset 52
    poke16(elfBuf + 52, 64);
    // e_phentsize = 56 at offset 54
    poke16(elfBuf + 54, 56);
    // e_phnum = 1 at offset 56
    poke16(elfBuf + 56, 1);
    // e_shentsize = 0 at offset 58
    poke16(elfBuf + 58, 0);
    // e_shnum = 0 at offset 60
    poke16(elfBuf + 60, 0);
    // e_shstrndx = 0 at offset 62
    poke16(elfBuf + 62, 0);
    
    // Program Header at offset 64
    // p_type = 1 (PT_LOAD) at offset 64
    poke32(elfBuf + 64, 1);
    // p_flags = 5 (rwx) at offset 68
    poke32(elfBuf + 68, 5);
    // p_offset = 0 at offset 72
    poke64(elfBuf + 72, 0);
    // p_vaddr = 0 at offset 80
    poke64(elfBuf + 80, 0);
    // p_paddr = 0 at offset 88
    poke64(elfBuf + 88, 0);
    // p_filesz = elfSize at offset 96
    poke64(elfBuf + 96, elfSize);
    // p_memsz = elfSize at offset 104
    poke64(elfBuf + 104, elfSize);
    // p_align = 4096 at offset 112
    poke64(elfBuf + 112, 4096);
    
    // Copy code to codeOffset
    var i: int64 := 0;
    while (i < size) {
      poke8(elfBuf + codeOffset + i, peek8(code + i));
      i := i + 1;
    }
    
    var result: bool := FileWriteAll(path, elfBuf as pchar, elfSize);
    PrintStr("writeELF: wrote "); PrintInt(elfSize); PrintStr(" bytes, result="); PrintInt(result as int64); PrintStr("\n");
    
    return result;
  }

  fn writePE(path: pchar, code: int64, size: int64): bool {
    var writer: int64 := PE64Writer.Create();
    writer.SetEntry(0x401000);
    writer.SetTextSection(code, size, 0x401000);
    
    var output: int64 := writer.Write();
    var outputSize: int64 := writer.GetSize();
    
    var result: bool := FileWriteAll(path, output as pchar, outputSize);
    
    writer.Free();
    
    return result;
  }
  
  fn writeMachO(path: pchar, code: int64, size: int64): bool {
    var writer: int64 := MachO64Writer.Create();
    writer.SetEntry(0x1000);
    writer.SetTextSection(code, size, 0x1000);
    
    var output: int64 := writer.Write();
    var outputSize: int64 := writer.GetSize();
    
    var result: bool := FileWriteAll(path, output as pchar, outputSize);
    
    writer.Free();
    
    return result;
  }
  
