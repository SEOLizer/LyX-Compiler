  dumpLexer: bool;
  dumpParser: bool;
  dumpSema: bool;
  dumpIR: bool;
  dumpASM: bool;
  emitASM: bool;
  dumpList: bool;
  targetEnergy: int64;
  dumpRelocs: bool;
  traceImports: bool;
  asmListing: bool;
  mcdc: bool;
  mcdcReport: bool;
  staticAnalysis: bool;
  callGraph: bool;
  mapFile: bool;
  warningsAsErrors: bool;
  warnAll: bool;
  includePath: int64;
