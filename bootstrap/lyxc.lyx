  // ---------------------------------------------------------------------------
  // CLI Parsing
  // ---------------------------------------------------------------------------
  
  fn parseCLI(argc: int64, argv: pchar): bool {
    // Initialize ALL fields to known values (opts is embedded, not a pointer)
    // Memory from alloc may contain garbage
    self.inputFile := 0;
    self.outputFile := 0;
    self.target := 0;
    self.format := 0;
    self.optLevel := 0;
    self.enableLint := false;
    self.lintOnly := false;
    self.enableDebug := false;
    self.enableVerbose := false;
    self.dumpLexer := false;
    self.dumpParser := false;
    self.dumpSema := false;
    self.dumpIR := false;
    self.dumpASM := false;
    self.dumpRelocs := false;
    self.callGraph := false;
    self.mapFile := false;
    self.staticAnalysis := false;
    self.mcdc := false;
    self.mcdcReport := false;
    self.emitASM := false;
    self.emitRelocs := false;
    self.warningsAsErrors := false;
    self.warnAll := false;
    self.asmListing := false;
    self.lintOnly := false;
    
    // Force verbose off for now
    self.enableVerbose := false;
    
    var i: int64 := 1;
    
    while i < argc {
      var arg: pchar := ArgvGet(argv, i);
      var argLen: int64 := StrLen(arg);
      
      if argLen == 0 {
        i := i + 1;
        continue;
      }
      
      var firstChar: int64 := peek8(arg);
      
      // Check for flag (starts with -)
      if firstChar == 45 {  // '-'
        if argLen == 1 {
          i := i + 1;
          continue;
        }
        
        var secondChar: int64 := peek8(arg + 1);
        
        // Long flags (--)
        if secondChar == 45 {  // '--'
          self.parseLongFlag(arg, argLen);
        } else {
          // Short flags (-)
          self.parseShortFlags(arg, argLen);
        }
      } else {
        // Positional argument
        if self.inputFile == 0 {
          self.inputFile := arg as int64;
        } else if self.outputFile == 0 {
          self.outputFile := arg as int64;
        }
      }
      
      i := i + 1;
    }
    
    // Validate required options
    if self.inputFile == 0 {
      EPrintStr("Error: No input file specified\n"c);
      self.exitCode := 1;
      return false;
    }
    
    // Set defaults
    if self.target == 0 {
      self.target := TARGET_X86_64;
    }
    if self.format == 0 {
      self.format := FORMAT_ELF;
    }
    if self.optLevel == 0 {
      self.optLevel := OPT_O2;
    }
    
    return true;
  }
  
  fn parseLongFlag(arg: int64, argLen: int64): void {
    // --target=x86_64|arm64|riscv64|arm_cm
    if StrStartsWith(arg, "--target=") {
      var val: int64 := arg + 8;
      if StrCmp(val, "x86_64"c) == 0 {
        self.target := TARGET_X86_64;
      } else if StrCmp(val, "arm64"c) == 0 {
        self.target := TARGET_ARM64;
      } else if StrCmp(val, "riscv64"c) == 0 {
        self.target := TARGET_RISCV64;
      } else if StrCmp(val, "arm_cm"c) == 0 {
        self.target := TARGET_ARM_CM;
      }
      return;
    }
    
    // --std-path=PATH
    if StrStartsWith(arg, "--std-path=") {
      self.stdPath := arg + 10;
      return;
    }
    
    // --arch=x86_64|arm64|riscv64|arm_cm (alias für --target)
    if StrStartsWith(arg, "--arch=") {
      var val: int64 := arg + 7;
      if StrCmp(val, "x86_64"c) == 0 {
        self.target := TARGET_X86_64;
        self.arch := TARGET_X86_64;
      } else if StrCmp(val, "arm64"c) == 0 {
        self.target := TARGET_ARM64;
        self.arch := TARGET_ARM64;
      } else if StrCmp(val, "riscv"c) == 0 || StrCmp(val, "riscv64"c) == 0 {
        self.target := TARGET_RISCV64;
        self.arch := TARGET_RISCV64;
      } else if StrCmp(val, "arm_cm"c) == 0 {
        self.target := TARGET_ARM_CM;
        self.arch := TARGET_ARM_CM;
      }
      return;
    }
    
    // --output= or -o
    if StrStartsWith(arg, "--output=") {
      self.outputFile := arg + 9;
      return;
    }
    
    // --opt=O0|O1|O2|O3|Osafe
    if StrStartsWith(arg, "--opt=") {
      var val: int64 := arg + 6;
      if StrCmp(val, "O0"c) == 0 {
        self.optLevel := OPT_NONE;
      } else if StrCmp(val, "O1"c) == 0 {
        self.optLevel := OPT_O1;
      } else if StrCmp(val, "O2"c) == 0 {
        self.optLevel := OPT_O2;
      } else if StrCmp(val, "O3"c) == 0 {
        self.optLevel := OPT_O3;
      } else if StrCmp(val, "Osafe"c) == 0 {
        self.optLevel := OPT_SAFE;
      }
      return;
    }
    
    // --format=elf|pe|macho
    if StrStartsWith(arg, "--format=") {
      var val: int64 := arg + 9;
      if StrCmp(val, "elf"c) == 0 {
        self.format := FORMAT_ELF;
      } else if StrCmp(val, "pe"c) == 0 {
        self.format := FORMAT_PE;
      } else if StrCmp(val, "macho"c) == 0 {
        self.format := FORMAT_MACHO;
      }
      return;
    }
    
    // Boolean flags
    if StrCmp(arg, "--lint"c) == 0 {
      self.enableLint := true;
      return;
    }
    if StrCmp(arg, "--lint-only"c) == 0 {
      self.lintOnly := true;
      self.enableLint := true;
      return;
    }
    if StrCmp(arg, "--debug"c) == 0 {
      self.enableDebug := true;
      return;
    }
    if StrCmp(arg, "--verbose"c) == 0 {
      self.enableVerbose := true;
      return;
    }
    if StrCmp(arg, "--warnings-as-errors"c) == 0 {
      self.warningsAsErrors := true;
      return;
    }
    if StrCmp(arg, "--warn-all"c) == 0 {
      self.warnAll := true;
      return;
    }
    if StrCmp(arg, "--dump-lexer"c) == 0 {
      self.dumpLexer := true;
      return;
    }
    if StrCmp(arg, "--dump-parser"c) == 0 {
      self.dumpParser := true;
      return;
    }
    if StrCmp(arg, "--dump-sema"c) == 0 {
      self.dumpSema := true;
      return;
    }
    if StrCmp(arg, "--dump-ir"c) == 0 {
      self.dumpIR := true;
      return;
    }
    if StrCmp(arg, "--dump-asm"c) == 0 {
      self.dumpASM := true;
      return;
    }
    if StrCmp(arg, "--emit-asm"c) == 0 {
      self.emitASM := true;
      return;
    }
    if StrCmp(arg, "--list"c) == 0 {
      self.dumpList := true;
      return;
    }

    // CLI P2: --target-energy=N
    if StrStartsWith(arg, "--target-energy=") {
      var val: int64 := arg + 16;
      self.targetEnergy := ParseInt(val);
      return;
    }

    // CLI P2: --dump-relocs
    if StrCmp(arg, "--dump-relocs"c) == 0 {
      self.dumpRelocs := true;
      return;
    }

    // CLI P2: --trace-imports
    if StrCmp(arg, "--trace-imports"c) == 0 {
      self.traceImports := true;
      return;
    }

    // CLI P3: --asm-listing
    if StrCmp(arg, "--asm-listing"c) == 0 {
      self.asmListing := true;
      return;
    }

    // CLI P3: --mcdc
    if StrCmp(arg, "--mcdc"c) == 0 {
      self.mcdc := true;
      return;
    }

    // CLI P3: --mcdc-report
    if StrCmp(arg, "--mcdc-report"c) == 0 {
      self.mcdcReport := true;
      return;
    }

    // CLI P3: --static-analysis
    if StrCmp(arg, "--static-analysis"c) == 0 {
      self.staticAnalysis := true;
      return;
    }

    // CLI P3: --call-graph
    if StrCmp(arg, "--call-graph"c) == 0 {
      self.callGraph := true;
      return;
    }

    // CLI P3: --map-file
    if StrCmp(arg, "--map-file"c) == 0 {
      self.mapFile := true;
      return;
    }
    
    // --version
    if StrCmp(arg, "--version"c) == 0 {
      PrintStr(COMPILER_NAME);
      PrintStr(" "c);
      PrintStrLn(COMPILER_VERSION);
      PrintStr("Build: "c);
      PrintStrLn(COMPILER_BUILD);
      self.exitCode := 0;
      return;
    }
    
    // --help
    if StrCmp(arg, "--help"c) == 0 {
      self.printHelp();
      self.exitCode := 0;
      return;
    }
    
    // --build-info
    if StrCmp(arg, "--build-info"c) == 0 {
      PrintStrLn("Compiler Build Information:");
      PrintStr("  Name: "c);
      PrintStrLn(COMPILER_NAME);
      PrintStr("  Version: "c);
      PrintStrLn(COMPILER_VERSION);
      PrintStr("  Build: "c);
      PrintStrLn(COMPILER_BUILD);
      PrintStr("  Target: "c);
      PrintStrLn("x86_64-linux-elf");
      self.exitCode := 0;
      return;
    }
    
    // --config
    if StrCmp(arg, "--config"c) == 0 {
      PrintStrLn("Compiler Configuration:");
      PrintStr("  Targets: x86_64, arm64, riscv64, arm_cm"c);
      PrintStrLn("");
      PrintStr("  Formats: elf, pe, macho"c);
      PrintStrLn("");
      PrintStr("  Optimization: O0, O1, O2, O3, Osafe"c);
      self.exitCode := 0;
      return;
    }
    
    // --no-opt (disable optimizations)
    if StrCmp(arg, "--no-opt"c) == 0 {
      self.optLevel := OPT_NONE;
      return;
    }
    
    // --no-lint (disable linter)
    if StrCmp(arg, "--no-lint"c) == 0 {
      self.enableLint := false;
      return;
    }
  }
  
  fn parseShortFlags(arg: int64, argLen: int64): void {
    var i: int64 := 1;
    while i < argLen {
      var c: int64 := peek8(arg + i);
      
      if c == 79 {  // 'O'
        // -Olevel
        var level: int64 := peek8(arg + i + 1);
        if level == 48 {  // '0'
          self.optLevel := OPT_NONE;
        } else if level == 49 {  // '1'
          self.optLevel := OPT_O1;
        } else if level == 50 {  // '2'
          self.optLevel := OPT_O2;
        } else if level == 51 {  // '3'
          self.optLevel := OPT_O3;
        }
      } else if c == 118 {  // 'v'
        self.enableVerbose := true;
      } else if c == 100 {  // 'd'
        self.enableDebug := true;
      } else if c == 108 {  // 'l'
        self.enableLint := true;
      } else if c == 71 {  // 'g'
        self.enableDebug := true;
      } else if c == 119 {  // 'W'
        if i + 1 < argLen {
          var next: int64 := peek8(arg + i + 1);
          if next == 101 {  // 'e'
            self.warningsAsErrors := true;
          } else if next == 97 {  // 'a'
            self.warnAll := true;
          }
        }
      }
      
      i := i + 1;
    }
  }
  
