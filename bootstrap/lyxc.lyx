    return emitter.getCodeBuf();
  }
  
  // ---------------------------------------------------------------------------
  // Binary Writing
  // ---------------------------------------------------------------------------
  
  fn writeBinary(path: pchar, code: int64, size: int64): bool {
    PrintStrLn("=== writeBinary START ===");
    PrintStr("path = "); PrintInt(path as int64); PrintStr("\n");
    PrintStr("code = "); PrintInt(code); PrintStr("\n");
    PrintStr("size = "); PrintInt(size); PrintStr("\n");
    PrintStr("format = "); PrintInt(self.format); PrintStr("\n");
    PrintStr("FORMAT_ELF = "); PrintInt(FORMAT_ELF); PrintStr("\n");
    
    if self.format == FORMAT_ELF {
      PrintStrLn("writeBinary: calling writeELF...");
      return self.writeELF(path, code, size);
    } else if self.format == FORMAT_PE {
      return self.writePE(path, code, size);
    } else if self.format == FORMAT_MACHO {
      return self.writeMachO(path, code, size);
    }
    PrintStrLn("writeBinary: unknown format, returning false");
    return false;
  }
  
  fn writeELF(path: pchar, code: int64, size: int64): bool {
    // Create minimal ELF matching S1 layout:
    // - Single PT_LOAD at offset 0x1000 (vaddr 0x401000)
    // - Entry point at 0x401000
    // - Headers at offset 64 (must be covered by LOAD)
    
    var codeFileOffset: int64 := 4096;  // 0x1000
    var elfSize: int64 := codeFileOffset + size;
    
    var fd: int64 := open(path, 577, 493);
    if fd == -1 { return false; }
    close(fd);
    
    var elfBuf: int64 := mmap(0, elfSize, 3, 34, -1, 0);
    if elfBuf == -1 { return false; }
    
    // Zero buffer
    var z: int64 := 0;
    while (z < elfSize) {
      poke8(elfBuf + z, 0);
      z := z + 1;
    }
    
    // Copy code to offset 4096
    var i: int64 := 0;
    while (i < size) {
      poke8(elfBuf + codeFileOffset + i, peek8(code + i));
      i := i + 1;
    }
    
    // ELF header (64 bytes)
    var off: int64 := 0;
    poke8(elfBuf + off, 127); off := off + 1;  // 0x7F
    poke8(elfBuf + off, 69); off := off + 1;  // 'E'
    poke8(elfBuf + off, 76); off := off + 1;  // 'L'
    poke8(elfBuf + off, 70); off := off + 1;  // 'F'
    poke8(elfBuf + off, 2); off := off + 1;   // 64-bit
    poke8(elfBuf + off, 1); off := off + 1;   // little endian
    poke8(elfBuf + off, 1); off := off + 1;   // ELF version
    poke8(elfBuf + off, 0); off := off + 1;   // OS ABI
    poke8(elfBuf + off, 0); off := off + 1;
    poke8(elfBuf + off, 0); off := off + 1;
    poke8(elfBuf + off, 0); off := off + 1;
    poke8(elfBuf + off, 0); off := off + 1;
    poke8(elfBuf + off, 0); off := off + 1;
    poke8(elfBuf + off, 0); off := off + 1;
    poke8(elfBuf + off, 0); off := off + 1;
    poke8(elfBuf + off, 0); off := off + 1;
    
    // e_type (offset 16): ET_EXEC = 2
    poke16(elfBuf + 16, 2);
    // e_machine (offset 18): x86-64 = 62
    poke16(elfBuf + 18, 62);
    // e_entry (offset 24): entry point = 0x401000
    poke64(elfBuf + 24, 0x401000);
    // e_phoff (offset 32): program header offset = 64
    poke64(elfBuf + 32, 64);
    // e_shoff (offset 40): no section headers = 0
    poke64(elfBuf + 40, 0);
    // e_flags (offset 48): 0
    poke32(elfBuf + 48, 0);
    // e_ehsize (offset 52): 64
    poke16(elfBuf + 52, 64);
    // e_phentsize (offset 54): 56
    poke16(elfBuf + 54, 56);
    // e_phnum (offset 56): 1 program header
    poke16(elfBuf + 56, 1);
    // e_shentsize (offset 58): 0
    poke16(elfBuf + 58, 0);
    // e_shnum (offset 60): 0
    poke16(elfBuf + 60, 0);
    // e_shstrndx (offset 62): 0
    poke16(elfBuf + 62, 0);
    
    // Single PT_LOAD segment (at offset 64)
    var ph: int64 := 64;
    // p_type: PT_LOAD = 1
    poke32(elfBuf + ph, 1); ph := ph + 4;
    // p_flags: rwx = 7
    poke32(elfBuf + ph, 7); ph := ph + 4;
    // p_offset: file offset = 0x1000
    poke64(elfBuf + ph, codeFileOffset); ph := ph + 8;
    // p_vaddr: virtual address = 0x401000
    poke64(elfBuf + ph, 0x401000); ph := ph + 8;
    // p_paddr: physical address = 0x401000
    poke64(elfBuf + ph, 0x401000); ph := ph + 8;
    // p_filesz: file size = code size
    poke64(elfBuf + ph, size); ph := ph + 8;
    // p_memsz: memory size = code size
    poke64(elfBuf + ph, size); ph := ph + 8;
    // p_align: alignment = 0x1000
    poke64(elfBuf + ph, 4096);
    
    var result: int64 := FileWriteAll(path, elfBuf as pchar, elfSize) as int64;
    munmap(elfBuf, elfSize);
    chmod(path, 493);
    
    return result != 0;
  }

  fn writePE(path: pchar, code: int64, size: int64): bool {
    var writer: int64 := PE64Writer.Create();
    writer.SetEntry(0x401000);
    writer.SetTextSection(code, size, 0x401000);
    
    var output: int64 := writer.Write();
    var outputSize: int64 := writer.GetSize();
    
    var result: bool := FileWriteAll(path, output as pchar, outputSize);
    
    writer.Free();
    
    return result;
  }
  
  fn writeMachO(path: pchar, code: int64, size: int64): bool {
    var writer: int64 := MachO64Writer.Create();
    writer.SetEntry(0x1000);
    writer.SetTextSection(code, size, 0x1000);
    
    var output: int64 := writer.Write();
    var outputSize: int64 := writer.GetSize();
    
    var result: bool := FileWriteAll(path, output as pchar, outputSize);
    
    writer.Free();
    
    return result;
  }
  
