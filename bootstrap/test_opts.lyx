// bootstrap/test_opts.lyx -- WP-10g optimisation smoke test

con A: int64 := 10;
con B: int64 := 3;
con C: int64 := 100;

fn main(argc: int64, argv: pchar): int64 {
  // --- Constant Folding: arithmetic ---
  var x: int64 := 2 + 3 * 4;          // folds to 14
  PrintStr("2+3*4=");   PrintInt(x); PrintStr("\n");

  var y: int64 := A * B + 1;           // A=10, B=3 → 31
  PrintStr("A*B+1=");   PrintInt(y); PrintStr("\n");

  var z: int64 := C - A * B;           // 100 - 30 = 70
  PrintStr("C-A*B=");   PrintInt(z); PrintStr("\n");

  // --- Constant Folding: comparisons ---
  var eq: int64 := A == 10;            // → 1
  PrintStr("A==10=");   PrintInt(eq); PrintStr("\n");

  var ne: int64 := B != 3;             // → 0
  PrintStr("B!=3=");    PrintInt(ne); PrintStr("\n");

  var lt: int64 := B < A;              // → 1
  PrintStr("B<A=");     PrintInt(lt); PrintStr("\n");

  // --- Constant Folding: unary ---
  var neg: int64 := -A;                // → -10
  PrintStr("-A=");      PrintInt(neg); PrintStr("\n");

  var not0: int64 := !0;               // → 1
  PrintStr("!0=");      PrintInt(not0); PrintStr("\n");

  var not1: int64 := !1;               // → 0
  PrintStr("!1=");      PrintInt(not1); PrintStr("\n");

  // --- Dead-branch elimination ---
  if (1) {
    PrintStr("always\n");
  } else {
    PrintStr("never\n");   // must not appear
  }

  if (0) {
    PrintStr("dead\n");    // must not appear
  } else {
    PrintStr("else\n");
  }

  // --- CSE: const LHS (no push/pop) ---
  var v: int64 := 5;
  var r1: int64 := A + v;              // 10 + 5 = 15
  PrintStr("A+v=");     PrintInt(r1); PrintStr("\n");

  // --- CSE: const RHS (no push/pop) ---
  var r2: int64 := v * B;              // 5 * 3 = 15
  PrintStr("v*B=");     PrintInt(r2); PrintStr("\n");

  // --- Bitwise fold ---
  var band: int64 := 0xFF & 0x0F;     // → 15
  PrintStr("0xFF&0x0F="); PrintInt(band); PrintStr("\n");

  var bor: int64 := 0xF0 | 0x0F;      // → 255
  PrintStr("0xF0|0x0F="); PrintInt(bor); PrintStr("\n");

  var shl: int64 := 1 << 4;           // → 16
  PrintStr("1<<4=");    PrintInt(shl); PrintStr("\n");

  var shr: int64 := 64 >> 2;          // → 16
  PrintStr("64>>2=");   PrintInt(shr); PrintStr("\n");

  return 0;
}
