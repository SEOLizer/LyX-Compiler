// bootstrap/lexer.lyx
// Lyx Self-Hosted Lexer (WP-05)
// Tokenizes Lyx source code in Lyx itself.

// ============================================================================
// Token Kind Constants
// ============================================================================

pub con TK_EOF: int64 := 0;
pub con TK_ERROR: int64 := 1;
pub con TK_IDENT: int64 := 2;
pub con TK_INT: int64 := 3;
pub con TK_FLOAT: int64 := 4;  // Float literal token
pub con TK_STRING: int64 := 5;
pub con TK_CHAR: int64 := 6;

// Keywords (10+)
pub con TK_FN: int64 := 10;
pub con TK_VAR: int64 := 11;
pub con TK_LET: int64 := 12;
pub con TK_CO: int64 := 13;
pub con TK_CON: int64 := 14;
pub con TK_IF: int64 := 15;
pub con TK_ELSE: int64 := 16;
pub con TK_WHILE: int64 := 17;
pub con TK_RETURN: int64 := 18;
pub con TK_TRUE: int64 := 19;
pub con TK_FALSE: int64 := 20;
pub con TK_NULL: int64 := 21;
pub con TK_EXTERN: int64 := 22;
pub con TK_CASE: int64 := 23;
pub con TK_SWITCH: int64 := 24;
pub con TK_BREAK: int64 := 25;
pub con TK_DEFAULT: int64 := 26;
pub con TK_MATCH: int64 := 27;
pub con TK_UNIT: int64 := 28;
pub con TK_IMPORT: int64 := 29;
pub con TK_PUB: int64 := 30;
pub con TK_AS: int64 := 31;
pub con TK_TYPE: int64 := 32;
pub con TK_ENUM: int64 := 33;
pub con TK_STRUCT: int64 := 34;
pub con TK_ARRAY: int64 := 35;
pub con TK_CONTINUE: int64 := 69;  // was 36 - collision with TK_STATIC fixed
pub con TK_STATIC: int64 := 36;
pub con TK_FOR: int64 := 37;
pub con TK_TO: int64 := 38;
pub con TK_DOWNTO: int64 := 39;
pub con TK_DO: int64 := 40;
pub con TK_REPEAT: int64 := 41;
pub con TK_UNTIL: int64 := 42;
pub con TK_POOL: int64 := 43;
pub con TK_TRY: int64 := 44;
pub con TK_CATCH: int64 := 45;
pub con TK_THROW: int64 := 46;
pub con TK_FINALLY: int64 := 47;
pub con TK_CLASS: int64 := 48;
pub con TK_EXTENDS: int64 := 49;
pub con TK_SUPER: int64 := 50;
pub con TK_NEW: int64 := 51;
pub con TK_DISPOSE: int64 := 52;
pub con TK_IFACE: int64 := 53;
pub con TK_IMPLS: int64 := 54;
pub con TK_PRIVATE: int64 := 55;
pub con TK_PROTD: int64 := 56;
pub con TK_PARALLEL: int64 := 57;
pub con TK_PANIC: int64 := 58;
pub con TK_ASSERT: int64 := 59;
pub con TK_WHERE: int64 := 60;
pub con TK_VALUE: int64 := 61;
pub con TK_MAP: int64 := 62;
pub con TK_SET: int64 := 63;
pub con TK_IN: int64 := 64;
pub con TK_VIRTUAL: int64 := 65;
pub con TK_OVERRIDE: int64 := 66;
pub con TK_ABSTRACT: int64 := 67;
pub con TK_IS: int64 := 68;

// WP-11: Extended primitive types keywords
pub con TK_INT8: int64 := 169;
pub con TK_INT16: int64 := 170;
pub con TK_INT32: int64 := 171;
pub con TK_INT64: int64 := 172;
pub con TK_UINT8: int64 := 173;
pub con TK_UINT16: int64 := 174;
pub con TK_UINT32: int64 := 175;
pub con TK_UINT64: int64 := 176;
pub con TK_CHAR_TYPE: int64 := 177;  // char keyword (not char literal = 6)
pub con TK_F32: int64 := 180;        // Changed from 178 to avoid conflict
pub con TK_F64: int64 := 181;        // Changed from 179 to avoid conflict

// Operators (70+)
pub con TK_PLUS: int64 := 70;
pub con TK_MINUS: int64 := 71;
pub con TK_STAR: int64 := 72;
pub con TK_SLASH: int64 := 73;
pub con TK_PERCENT: int64 := 74;
pub con TK_PLUSPLUS: int64 := 75;
pub con TK_MINMIN: int64 := 76;
