  if (kind == TK_LE)       { return "<="; }
  if (kind == TK_GT)       { return ">"; }
  if (kind == TK_GE)       { return ">="; }
  if (kind == TK_AND)      { return "&&"; }
  if (kind == TK_OR)       { return "||"; }
  if (kind == TK_NOT)      { return "!"; }
  if (kind == TK_NOR)      { return "|~"; }
  if (kind == TK_BITXOR)   { return "^"; }
  if (kind == TK_BITAND)   { return "&"; }
  if (kind == TK_BITOR)    { return "|"; }
  if (kind == TK_BITNOT)   { return "~"; }
  if (kind == TK_SHL)      { return "<<"; }
  if (kind == TK_SHR)      { return ">>"; }
  if (kind == TK_PIPE)     { return "|>"; }
  if (kind == TK_ARROW)    { return "=>"; }
  if (kind == TK_LPAREN)   { return "("; }
  if (kind == TK_RPAREN)   { return ")"; }
  if (kind == TK_LBRACE)   { return "{"; }
  if (kind == TK_RBRACE)   { return "}"; }
  if (kind == TK_LBRACK)   { return "["; }
  if (kind == TK_RBRACK)   { return "]"; }
  if (kind == TK_COLON)    { return ":"; }
  if (kind == TK_COMMA)    { return ","; }
  if (kind == TK_SEMI)     { return ";"; }
  if (kind == TK_ELLIPSIS) { return "..."; }
  if (kind == TK_DOT)      { return "."; }
  if (kind == TK_RANGE)    { return ".."; }
  if (kind == TK_AT)       { return "@"; }
  if (kind == TK_QUEST)    { return "?"; }
  if (kind == TK_NULLCL)   { return "??"; }
  if (kind == TK_SAFECL)   { return "?."; }
  return "?";
}
