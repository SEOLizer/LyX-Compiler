// ============================================================================
// TIRInstr Struktur - 80 Bytes pro Instruktion
// ============================================================================
// Layout:
//   +0:  op      (int64)  - Opcode (IRO_xxx)
//   +8:  dest    (int64)  - Destination temp / local index
//   +16: src1    (int64)  - First source operand
//   +24: src2    (int64)  - Second source operand
//   +32: src3    (int64)  - Third source operand
//   +40: immInt  (int64)  - Immediate integer (const value, width bits, etc.)
//   +48: immFloat(double) - Immediate float (for irConstFloat)
//   +56: strOff  (int64)  - Offset into module string table for ImmStr
//   +64: labelOff(int64)  - Offset into label name string table
//   +72: callMode(int64)  - TIRCallMode
//   +76: reserved(int64)  - Padding

pub con IR_INSTR_SIZE: int64 := 80;

// ============================================================================
// TIRFunction Struktur
// ============================================================================
// Layout:
//   +0:  nameOff   (int64)  - Offset into string table for function name
//   +8:  nameLen   (int64)  - Length of function name
//   +16: instrsOff (int64)  - Offset into instructions buffer
//   +24: instrCount(int64)  - Number of instructions
//   +32: localCount(int64)  - Number of local variables
//   +40: paramCount(int64)  - Number of parameters
//   +48: retStructSize(int64) - Size of return struct (0 if returned in RAX)
//   +56: capturedVarsOff(int64) - Offset to captured variables buffer
//   +64: capturedCount(int64)  - Number of captured variables
//   +72: needsStaticLink(int64) - 1 if function needs static link parameter

pub con IR_FUNC_SIZE: int64 := 80;

// ============================================================================
// TIRModule Struktur
// ============================================================================
// Layout (fields are laid out sequentially in memory):
//   +0:   instrBuffer (int64)  - Instruction buffer pointer
//   +8:   instrCap    (int64)  - Instruction buffer capacity
//   +16:  instrLen    (int64)  - Instruction buffer length
//   +24:  strBuffer   (int64)  - String constants buffer pointer
//   +32:  strCap      (int64)  - String buffer capacity
//   +40:  strLen      (int64)  - String buffer length
//   +48:  labelBuffer (int64)  - Label names buffer pointer
//   +56:  labelCap    (int64)  - Label buffer capacity
//   +64:  labelLen    (int64)  - Label buffer length
//   +72:  funcBuffer  (int64)  - Function table buffer pointer
//   +80:  funcCap     (int64)  - Function table capacity
//   +88:  funcLen     (int64)  - Function count (or buffer length)
//   +96:  globalBuffer(int64)  - Global variables buffer pointer
//   +104: globalCap   (int64)  - Global variables capacity
//   +112: globalLen   (int64)  - Global variables count
//   +120: captureBuffer(int64) - Captured vars buffer pointer
//   +128: captureCap  (int64)  - Captured vars capacity
//   +136: captureLen  (int64)  - Captured vars count
// Total: 144 bytes + methods

pub con IR_MODULE_SIZE: int64 := 144;

pub type IRModule = class {
  
  // Instruction buffer (mmap'd, grows on demand)
  instrBuffer: int64;
  instrCap:    int64;
  instrLen:   int64;
  
  // String table for names and constants
  strBuffer:  int64;
  strCap:     int64;
  strLen:     int64;
  
  // Label name table
  labelBuffer: int64;
  labelCap:    int64;
  labelLen:    int64;
  
  // Function table
  funcBuffer:  int64;
  funcCap:     int64;
  funcLen:     int64;
  
  // Global variables table
  globalBuffer: int64;
  globalCap:    int64;
  globalLen:    int64;
  
  // Captured variables table
  captureBuffer: int64;
  captureCap:    int64;
  captureLen:    int64;
  
  // ------------------------------------------------------------------
  // Initialization
  // ------------------------------------------------------------------
  
  fn init() {
    // Allocate initial buffers (8KB each)
    self.instrBuffer := mmap(0, 8192, 3, 34, -1, 0);
    self.instrCap := 8192;
    self.instrLen := 0;
    
    self.strBuffer := mmap(0, 8192, 3, 34, -1, 0);
    self.strCap := 8192;
    self.strLen := 0;
    
    self.labelBuffer := mmap(0, 4096, 3, 34, -1, 0);
    self.labelCap := 4096;
    self.labelLen := 0;
    
    self.funcBuffer := mmap(0, 4096, 3, 34, -1, 0);
    self.funcCap := 4096;
    self.funcLen := 0;
    
    self.globalBuffer := mmap(0, 4096, 3, 34, -1, 0);
    self.globalCap := 4096;
    self.globalLen := 0;
    
    self.captureBuffer := mmap(0, 4096, 3, 34, -1, 0);
    self.captureCap := 4096;
    self.captureLen := 0;
  }
  
  // ------------------------------------------------------------------
  // String table management
  // ------------------------------------------------------------------
  
  // Add string to table, return offset
  fn addString(s: pchar, slen: int64): int64 {
    var off: int64 := self.strLen;
    // Grow if needed
    if (self.strLen + slen + 1 > self.strCap) {
      var newCap: int64 := self.strCap * 2;
      var nb: int64 := mmap(0, newCap, 3, 34, -1, 0);
      var i: int64 := 0;
      while (i < self.strLen) {
        poke8(nb + i, peek8(self.strBuffer + i));
        i := i + 1;
      }
      self.strBuffer := nb;
      self.strCap := newCap;
    }
    // Copy string
    var i: int64 := 0;
    var src: int64 := s as int64;
    var dst: int64 := self.strBuffer + off;
    while (i < slen) {
      poke8(dst + i, peek8(src + i));
      i := i + 1;
    }
    // Null terminator
    poke8(self.strBuffer + off + slen, 0);
    self.strLen := self.strLen + slen + 1;
    return off;
  }
  
  // Get string from offset
  fn getString(off: int64): pchar {
    return (self.strBuffer + off) as pchar;
  }
  
  // ------------------------------------------------------------------
  // Instruction buffer management
  // ------------------------------------------------------------------
  
  // Grow instruction buffer
  fn growInstrBuffer() {
    var newCap: int64 := self.instrCap * 2;
    var nb: int64 := mmap(0, newCap, 3, 34, -1, 0);
    var i: int64 := 0;
    while (i < self.instrLen) {
      poke8(nb + i, peek8(self.instrBuffer + i));
      i := i + 1;
    }
    self.instrBuffer := nb;
    self.instrCap := newCap;
  }
  
  // Add instruction, return instruction index
  fn addInstruction(op: int64, dest: int64, src1: int64, src2: int64, src3: int64, immInt: int64): int64 {
    var idx: int64 := self.instrLen / IR_INSTR_SIZE;
    
    // Grow if needed
    if (self.instrLen + IR_INSTR_SIZE > self.instrCap) {
      self.growInstrBuffer();
    }
    
    var off: int64 := self.instrLen;
    // op
    poke64(self.instrBuffer + off, op);
    // dest
    poke64(self.instrBuffer + off + 8, dest);
    // src1
    poke64(self.instrBuffer + off + 16, src1);
    // src2
    poke64(self.instrBuffer + off + 24, src2);
    // src3
    poke64(self.instrBuffer + off + 32, src3);
    // immInt
    poke64(self.instrBuffer + off + 40, immInt);
    // immFloat (double) - initialize to 0.0
    var floatOff: int64 := self.instrBuffer + off + 48;
    poke8(floatOff, 0); poke8(floatOff + 1, 0);
    poke8(floatOff + 2, 0); poke8(floatOff + 3, 0);
    poke8(floatOff + 4, 0); poke8(floatOff + 5, 0);
    poke8(floatOff + 6, 0); poke8(floatOff + 7, 0);
    // strOff (initialize to -1)
    poke64(self.instrBuffer + off + 56, -1);
    // labelOff (initialize to -1)
    poke64(self.instrBuffer + off + 64, -1);
    // callMode (initialize to 0)
    poke64(self.instrBuffer + off + 72, 0);
    
    self.instrLen := self.instrLen + IR_INSTR_SIZE;
    return idx;
  }
  
  // Get instruction opcode at index
  fn getInstrOp(idx: int64): int64 {
    var off: int64 := idx * IR_INSTR_SIZE;
    return peek64(self.instrBuffer + off);
  }
  
  // Get instruction dest at index
  fn getInstrDest(idx: int64): int64 {
    var off: int64 := idx * IR_INSTR_SIZE + 8;
    return peek64(self.instrBuffer + off);
  }
  
  // Get instruction src1 at index
  fn getInstrSrc1(idx: int64): int64 {
    var off: int64 := idx * IR_INSTR_SIZE + 16;
    return peek64(self.instrBuffer + off);
  }
  
  // Get instruction src2 at index
  fn getInstrSrc2(idx: int64): int64 {
    var off: int64 := idx * IR_INSTR_SIZE + 24;
    return peek64(self.instrBuffer + off);
  }
  
  // Get instruction src3 at index
  fn getInstrSrc3(idx: int64): int64 {
    var off: int64 := idx * IR_INSTR_SIZE + 32;
    return peek64(self.instrBuffer + off);
  }
  
  // Get instruction immInt at index
  fn getInstrImmInt(idx: int64): int64 {
    var off: int64 := idx * IR_INSTR_SIZE + 40;
    return peek64(self.instrBuffer + off);
  }
  
  // Set instruction immInt at index
  fn setInstrImmInt(idx: int64, val: int64) {
    var off: int64 := idx * IR_INSTR_SIZE + 40;
    poke64(self.instrBuffer + off, val);
  }
  
  // Set instruction string offset at index
  fn setInstrStrOff(idx: int64, off: int64) {
    var iOff: int64 := idx * IR_INSTR_SIZE + 56;
    poke64(self.instrBuffer + iOff, off);
  }
  
  // Get instruction string offset at index
  fn getInstrStrOff(idx: int64): int64 {
    var off: int64 := idx * IR_INSTR_SIZE + 56;
    return peek64(self.instrBuffer + off);
  }
  
  // Set label offset at index
  fn setInstrLabelOff(idx: int64, off: int64) {
    var iOff: int64 := idx * IR_INSTR_SIZE + 64;
    poke64(self.instrBuffer + iOff, off);
  }
  
  // Get label offset at index
  fn getInstrLabelOff(idx: int64): int64 {
    var off: int64 := idx * IR_INSTR_SIZE + 64;
    return peek64(self.instrBuffer + off);
  }
  
  // Set call mode at index
  fn setInstrCallMode(idx: int64, mode: int64) {
    var iOff: int64 := idx * IR_INSTR_SIZE + 72;
    poke64(self.instrBuffer + iOff, mode);
  }
  
  // Get call mode at index
  fn getInstrCallMode(idx: int64): int64 {
    var off: int64 := idx * IR_INSTR_SIZE + 72;
    return peek64(self.instrBuffer + off);
  }
  
  // Set immediate float at index (stored as int64 bits)
  fn setInstrImmFloat(idx: int64, val: int64) {
    var off: int64 := idx * IR_INSTR_SIZE + 48;
    poke64(off, val);
  }
  
  // Get immediate float at index (returns int64 bits)
  fn getInstrImmFloat(idx: int64): int64 {
    var off: int64 := idx * IR_INSTR_SIZE + 48;
    return peek64(off);
  }
  
  // ------------------------------------------------------------------
  // Helper functions for creating instructions
  // Note: float64 is stored as int64 IEEE 754 bit pattern
  // ------------------------------------------------------------------
  
  fn irConstInt(dest: int64, val: int64): int64 {
    return self.addInstruction(IRO_CONST_INT, dest, -1, -1, -1, val);
  }
  
  fn irConstFloat(dest: int64, bits: int64): int64 {
    var idx: int64 := self.addInstruction(IRO_CONST_FLOAT, dest, -1, -1, -1, bits);
    return idx;
  }
  
  fn irConstStr(dest: int64, strOff: int64): int64 {
    var idx: int64 := self.addInstruction(IRO_CONST_STR, dest, -1, -1, -1, 0);
    self.setInstrStrOff(idx, strOff);
    return idx;
  }
  
  fn irAdd(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_ADD, dest, src1, src2, -1, 0);
  }
  
  fn irSub(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_SUB, dest, src1, src2, -1, 0);
  }
  
  fn irMul(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_MUL, dest, src1, src2, -1, 0);
  }
  
  fn irDiv(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_DIV, dest, src1, src2, -1, 0);
  }
  
  fn irMod(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_MOD, dest, src1, src2, -1, 0);
  }
  
  fn irNeg(dest: int64, src1: int64): int64 {
    return self.addInstruction(IRO_NEG, dest, src1, -1, -1, 0);
  }
  
  // Float arithmetic
  fn irFAdd(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_FADD, dest, src1, src2, -1, 0);
  }
  
  fn irFSub(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_FSUB, dest, src1, src2, -1, 0);
  }
  
  fn irFMul(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_FMUL, dest, src1, src2, -1, 0);
  }
  
  fn irFDiv(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_FDIV, dest, src1, src2, -1, 0);
  }
  
  fn irFNeg(dest: int64, src1: int64): int64 {
    return self.addInstruction(IRO_FNEG, dest, src1, -1, -1, 0);
  }
  
  // Comparisons
  fn irCmpEq(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_CMP_EQ, dest, src1, src2, -1, 0);
  }
  
  fn irCmpNeq(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_CMP_NEQ, dest, src1, src2, -1, 0);
  }
  
  fn irCmpLt(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_CMP_LT, dest, src1, src2, -1, 0);
  }
  
  fn irCmpLe(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_CMP_LE, dest, src1, src2, -1, 0);
  }
  
  fn irCmpGt(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_CMP_GT, dest, src1, src2, -1, 0);
  }
  
  fn irCmpGe(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_CMP_GE, dest, src1, src2, -1, 0);
  }
  
  // Float comparisons
  fn irFCmpEq(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_FCMP_EQ, dest, src1, src2, -1, 0);
  }
  
  fn irFCmpLt(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_FCMP_LT, dest, src1, src2, -1, 0);
  }
  
  // Bitwise
  fn irNot(dest: int64, src1: int64): int64 {
    return self.addInstruction(IRO_NOT, dest, src1, -1, -1, 0);
  }
  
  fn irAnd(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_AND, dest, src1, src2, -1, 0);
  }
  
  fn irOr(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_OR, dest, src1, src2, -1, 0);
  }
  
  fn irXor(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_XOR, dest, src1, src2, -1, 0);
  }
  
  fn irBitAnd(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_BITAND, dest, src1, src2, -1, 0);
  }
  
  fn irBitOr(dest: int64, src1: int64, src2: int64): int64 {
    return self.addInstruction(IRO_BITOR, dest, src1, src2, -1, 0);
