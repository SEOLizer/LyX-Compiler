  // Dump all instructions to stdout
  fn dump() {
    var i: int64 := 0;
    var count: int64 := self.instrLen / IR_INSTR_SIZE;
    while (i < count) {
      var op: int64 := self.getInstrOp(i);
      var dest: int64 := self.getInstrDest(i);
      var src1: int64 := self.getInstrSrc1(i);
      var src2: int64 := self.getInstrSrc2(i);
      var src3: int64 := self.getInstrSrc3(i);
      var imm: int64 := self.getInstrImmInt(i);
      
      PrintInt(i);
      PrintStr(": ");
      PrintStr(self.dumpOp(op));
      PrintStr("  ");
      
      if (dest >= 0) {
        PrintStr("t");
        PrintInt(dest);
        PrintStr(" = ");
      }
      if (src1 >= 0) {
        PrintStr("t");
        PrintInt(src1);
      }
      if (src2 >= 0) {
        PrintStr(", t");
        PrintInt(src2);
      }
      if (src3 >= 0) {
        PrintStr(", t");
        PrintInt(src3);
      }
      if (imm != 0) {
        PrintStr(", #");
        PrintInt(imm);
      }
      
      // Handle string/label operands
      var strOff: int64 := self.getInstrStrOff(i);
      if (strOff >= 0) {
        PrintStr(", str@");
        PrintInt(strOff);
      }
      var lblOff: int64 := self.getInstrLabelOff(i);
      if (lblOff >= 0) {
        PrintStr(", label@");
        PrintInt(lblOff);
      }
      
      PrintStr("\n");
      i := i + 1;
    }
    PrintStr("--- End IR dump ---\n");
  }
  
  // Get total instruction count
  fn getInstrCount(): int64 {
    return self.instrLen / IR_INSTR_SIZE;
  }
  
  // ------------------------------------------------------------------
  // Function table management
  // ------------------------------------------------------------------
  
  // Add function to table, return function index
  fn addFunc(nameOff: int64, nameLen: int64, localCount: int64, paramCount: int64): int64 {
    var idx: int64 := self.funcLen;
    PrintStr("addFunc: idx="); PrintInt(idx); PrintStr(" funcLen before="); PrintInt(self.funcLen); PrintStr("\n");
    
    // Grow if needed
    if (self.funcLen + IR_FUNC_SIZE > self.funcCap) {
      var newCap: int64 := self.funcCap * 2;
      var nb: int64 := mmap(0, newCap, 3, 34, -1, 0);
      var i: int64 := 0;
      while (i < self.funcLen) {
        var j: int64 := 0;
        while (j < IR_FUNC_SIZE) {
          poke8(nb + i * IR_FUNC_SIZE + j, peek8(self.funcBuffer + i * IR_FUNC_SIZE + j));
          j := j + 1;
        }
        i := i + 1;
      }
      self.funcBuffer := nb;
      self.funcCap := newCap;
    }
    
    // Store function data at current position
    // funcLen is count, so compute byte offset
    var off: int64 := self.funcLen * IR_FUNC_SIZE;
    // nameOff at +0
    poke64(self.funcBuffer + off + 0, nameOff);
    // nameLen at +8
    poke64(self.funcBuffer + off + 8, nameLen);
    // instrsOff (start of instruction buffer) at +16
    poke64(self.funcBuffer + off + 16, 0);  // Will be set when instructions are emitted
    // instrCount at +24
    poke64(self.funcBuffer + off + 24, 0);  // Will be set when function is finalized
    // localCount at +32
    poke64(self.funcBuffer + off + 32, localCount);
    // paramCount at +40
    poke64(self.funcBuffer + off + 40, paramCount);
    // retStructSize at +48
    poke64(self.funcBuffer + off + 48, 0);
    // capturedVarsOff at +56
    poke64(self.funcBuffer + off + 56, 0);
    // capturedCount at +64
    poke64(self.funcBuffer + off + 64, 0);
    // needsStaticLink at +72
    poke64(self.funcBuffer + off + 72, 0);
    
    // Increment funcLen by 1 (function count)
    self.funcLen := self.funcLen + 1;
    PrintStr("addFunc: funcLen after="); PrintInt(self.funcLen); PrintStr("\n");
    
    return idx;
  }
  
  // Set function count - for debugging
  fn setFuncCount(c: int64): void {
    self.funcLen := c;
  }
  
  // Get function count - funcLen is already the count
  fn getFuncCount(): int64 {
    return self.funcLen;
  }
  
  // Get instruction buffer address
  fn getInstrBuffer(): int64 { return self.instrBuffer; }
  
  // Get function buffer address
  fn getFuncBuffer(): int64 { return self.funcBuffer; }
  
  // Get function cap
  fn getFuncCap(): int64 { return self.funcCap; }
  
  // Get string buffer address (for getStringLen helper)
  fn getStrBuffer(): int64 { return self.strBuffer; }
  
  // Get instruction length
  fn getInstrLen(): int64 { return self.instrLen; }
  
  // Get string length
  fn getStrLen(): int64 { return self.strLen; }
  
  // Get label buffer address
  fn getLabelBuffer(): int64 { return self.labelBuffer; }
  
  // Get global buffer address
  fn getGlobalBuffer(): int64 { return self.globalBuffer; }
}
;
