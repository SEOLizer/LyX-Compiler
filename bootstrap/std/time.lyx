// ============================================================================
// Constants
// ============================================================================

con CLOCK_REALTIME: int64 := 0;
con CLOCK_MONOTONIC: int64 := 1;
con CLOCK_PROCESS_CPUTIME_ID: int64 := 2;
con CLOCK_THREAD_CPUTIME_ID: int64 := 3;

// ============================================================================
// Time Structures
// ============================================================================

// timespec: 16 bytes
// +0: tv_sec (int64)
// +8: tv_nsec (int64)

// ============================================================================
// Time Functions
// ============================================================================

// Get current time (seconds since epoch)
pub fn Time(): int64 {
  var ts: int64 := mmap(0, 16, 3, 34, -1, 0);
  var result: int64 := clock_gettime(CLOCK_REALTIME, ts);
  
  if result < 0 {
    munmap(ts, 16);
    return 0;
  }
  
  var sec: int64 := peek64(ts);
  munmap(ts, 16);
  
  return sec;
}

// Get current time with nanoseconds
pub fn TimeNano(): int64 {
  var ts: int64 := mmap(0, 16, 3, 34, -1, 0);
  var result: int64 := clock_gettime(CLOCK_REALTIME, ts);
  
  if result < 0 {
    munmap(ts, 16);
    return 0;
  }
  
  var sec: int64 := peek64(ts);
  var nsec: int64 := peek64(ts + 8);
  munmap(ts, 16);
  
  return sec * 1000000000 + nsec;
}

