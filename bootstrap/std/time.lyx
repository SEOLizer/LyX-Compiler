// ============================================================================
// Sleep Functions
// ============================================================================

// Sleep for seconds
pub fn Sleep(sec: int64): void {
  var ts: int64 := mmap(0, 16, 3, 34, -1, 0);
  poke64(ts, sec);
  poke64(ts + 8, 0);
  nanosleep(ts, 0);
  munmap(ts, 16);
}

// Sleep for milliseconds
pub fn SleepMs(msec: int64): void {
  var ts: int64 := mmap(0, 16, 3, 34, -1, 0);
  poke64(ts, msec / 1000);
  poke64(ts + 8, (msec % 1000) * 1000000);
  nanosleep(ts, 0);
  munmap(ts, 16);
}

// Sleep for microseconds
pub fn USleep(usec: int64): void {
  var ts: int64 := mmap(0, 16, 3, 34, -1, 0);
  poke64(ts, usec / 1000000);
  poke64(ts + 8, (usec % 1000000) * 1000);
  nanosleep(ts, 0);
  munmap(ts, 16);
}

// Sleep for nanoseconds
pub fn NanoSleep(nsec: int64): void {
  var ts: int64 := mmap(0, 16, 3, 34, -1, 0);
  poke64(ts, nsec / 1000000000);
  poke64(ts + 8, nsec % 1000000000);
  nanosleep(ts, 0);
  munmap(ts, 16);
}

// ============================================================================
// Timer Class
// ============================================================================

pub type Timer = class {
  startTime: int64;
  endTime: int64;
  running: bool;
  
  // Constructor
  pub fn Create(): int64 {
    var self: int64 := alloc(sizeof(Timer));
    self.startTime := 0;
    self.endTime := 0;
    self.running := false;
    return self;
  }
  
  // Start timer
  pub fn Start(): void {
    self.startTime := MonotonicTime();
    self.running := true;
  }
  
  // Stop timer
  pub fn Stop(): void {
    if self.running {
      self.endTime := MonotonicTime();
      self.running := false;
    }
  }
  
  // Get elapsed time in seconds
  pub fn Elapsed(): f64 {
    var end: int64 := self.endTime;
    if self.running {
      end := MonotonicTime();
    }
    
    var diff: int64 := end - self.startTime;
    return (diff as f64) / 1000000000.0;
  }
  
  // Get elapsed time in milliseconds
  pub fn ElapsedMs(): f64 {
    var end: int64 := self.endTime;
    if self.running {
      end := MonotonicTime();
    }
    
    var diff: int64 := end - self.startTime;
    return (diff as f64) / 1000000.0;
  }
  
  // Get elapsed time in microseconds
  pub fn ElapsedUs(): f64 {
    var end: int64 := self.endTime;
    if self.running {
      end := MonotonicTime();
    }
    
    var diff: int64 := end - self.startTime;
    return (diff as f64) / 1000.0;
  }
  
  // Reset timer
  pub fn Reset(): void {
    self.startTime := 0;
    self.endTime := 0;
    self.running := false;
  }
  
  // Free
  pub fn Free(): void {
    free(self);
  }
};

