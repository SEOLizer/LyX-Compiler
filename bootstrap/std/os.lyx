// Get number of CPUs
pub fn GetCPUCount(): int64 {
  // Read /proc/cpuinfo
  var fd: int64 := open("/proc/cpuinfo"c, O_RDONLY, 0);
  if fd < 0 {
    return 1;
  }
  
  var count: int64 := 0;
  var buf: int64 := mmap(0, 4096, 3, 34, -1, 0);
  
  while true {
    var bytesRead: int64 := read(fd, buf, 4096);
    if bytesRead <= 0 {
      break;
    }
    
    var i: int64 := 0;
    while i < bytesRead {
      if peek8(buf + i) == 10 {  // newline
        count := count + 1;
      }
      i := i + 1;
    }
  }
  
  close(fd);
  munmap(buf, 4096);
  
  return count;
}

// ============================================================================
// Memory Info
// ============================================================================

// Get total memory (RAM) in bytes
pub fn GetTotalMemory(): int64 {
  // Read /proc/meminfo
  var fd: int64 := open("/proc/meminfo"c, O_RDONLY, 0);
  if fd < 0 {
    return 0;
  }
  
  var buf: int64 := mmap(0, 4096, 3, 34, -1, 0);
  var bytesRead: int64 := read(fd, buf, 4096);
  close(fd);
  
  if bytesRead <= 0 {
    munmap(buf, 4096);
    return 0;
  }
  
  // Parse MemTotal line
  var i: int64 := 0;
  var found: int64 := 0;
  var val: int64 := 0;
  
  while i < bytesRead - 20 {
    // Check for "MemTotal:"
    if peek8(buf + i) == 77 && peek8(buf + i + 1) == 101 && 
       peek8(buf + i + 2) == 109 && peek8(buf + i + 3) == 84 &&
       peek8(buf + i + 4) == 111 && peek8(buf + i + 5) == 116 &&
       peek8(buf + i + 6) == 97 && peek8(buf + i + 7) == 108 &&
       peek8(buf + i + 8) == 58 {
      found := 1;
      i := i + 9;
      break;
    }
    i := i + 1;
  }
  
  if found == 1 {
    // Skip spaces
    while i < bytesRead && peek8(buf + i) == 32 {
      i := i + 1;
    }
    
    // Parse number
    while i < bytesRead {
      var c: int64 := peek8(buf + i);
      if c >= 48 && c <= 57 {
        val := val * 10 + (c - 48);
      } else if c == 107 || c == 75 {  // 'k' or 'K'
        val := val * 1024;  // Convert from kB
        break;
      } else {
        break;
      }
      i := i + 1;
    }
  }
  
  munmap(buf, 4096);
  return val;
}

// Get available memory in bytes
pub fn GetAvailMemory(): int64 {
  // Read /proc/meminfo
  var fd: int64 := open("/proc/meminfo"c, O_RDONLY, 0);
  if fd < 0 {
    return 0;
  }
  
  var buf: int64 := mmap(0, 4096, 3, 34, -1, 0);
  var bytesRead: int64 := read(fd, buf, 4096);
  close(fd);
  
  if bytesRead <= 0 {
    munmap(buf, 4096);
    return 0;
  }
  
  // Parse MemAvailable line
  var i: int64 := 0;
  var found: int64 := 0;
  var val: int64 := 0;
  
  while i < bytesRead - 20 {
    if peek8(buf + i) == 77 && peek8(buf + i + 1) == 101 && 
       peek8(buf + i + 2) == 109 && peek8(buf + i + 3) == 65 &&
       peek8(buf + i + 4) == 118 && peek8(buf + i + 5) == 97 &&
       peek8(buf + i + 6) == 105 && peek8(buf + i + 7) == 108 &&
       peek8(buf + i + 8) == 97 && peek8(buf + i + 9) == 98 &&
       peek8(buf + i + 10) == 108 && peek8(buf + i + 11) == 101 {
      found := 1;
      i := i + 12;
      break;
    }
    i := i + 1;
  }
  
  if found == 1 {
    while i < bytesRead && peek8(buf + i) == 32 {
      i := i + 1;
    }
    
    while i < bytesRead {
      var c: int64 := peek8(buf + i);
      if c >= 48 && c <= 57 {
        val := val * 10 + (c - 48);
      } else if c == 107 || c == 75 {
        val := val * 1024;
        break;
      } else {
        break;
      }
      i := i + 1;
    }
  }
  
  munmap(buf, 4096);
  return val;
}
