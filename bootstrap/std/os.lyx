// ============================================================================
// Process Information
// ============================================================================

// Get current process ID
pub fn GetPID(): int64 {
  return getpid();
}

// Get parent process ID
pub fn GetPPID(): int64 {
  return getppid();
}

// Get real user ID
pub fn GetUID(): int64 {
  return getuid();
}

// Get effective user ID
pub fn GetEUID(): int64 {
  return geteuid();
}

// Get real group ID
pub fn GetGID(): int64 {
  return getgid();
}

// Get effective group ID
pub fn GetEGID(): int64 {
  return getegid();
}

// ============================================================================
// Environment Variables
// ============================================================================

// Get environment variable
pub fn GetEnv(name: pchar): pchar {
  var nameLen: int64 := StrLen(name);
  var i: int64 := 0;
  
  // Iterate through environ
  while true {
    var envPtr: int64 := peek64(env as int64 + i * 8);
    if envPtr == 0 {
      break;
    }
    
    var j: int64 := 0;
    var keysMatch: int64 := 1;
    
    // Check if name matches
    while j < nameLen {
      if peek8(envPtr + j) != peek8(name + j) {
        keysMatch := 0;
        j := nameLen;
      }
      j := j + 1;
    }
    
    if keysMatch == 1 && peek8(envPtr + nameLen) == 61 {  // '='
      // Found, return val part
      var valueOff: int64 := envPtr + nameLen + 1;
      return valueOff as pchar;
    }
    
    i := i + 1;
  }
  
  return 0 as pchar;
}

// Set environment variable
pub fn SetEnv(name: pchar, val: pchar, overwrite: int64): bool {
  return setenv(name, val, overwrite) == 0;
}

// Unset environment variable
pub fn UnsetEnv(name: pchar): bool {
  return unsetenv(name) == 0;
}

// ============================================================================
// Current Working Directory
// ============================================================================

// Get current working directory
pub fn GetCWD(): pchar {
  var buf: int64 := mmap(0, 4096, 3, 34, -1, 0);
  var result: int64 := getcwd(buf, 4096);
  
  if result == 0 {
    munmap(buf, 4096);
    return 0 as pchar;
  }
  
  return buf as pchar;
}

// Change current working directory
pub fn Chdir(path: pchar): bool {
  return chdir(path) == 0;
}

// ============================================================================
// System Information
// ============================================================================

// Get hostname
pub fn GetHostName(): pchar {
  var buf: int64 := mmap(0, 256, 3, 34, -1, 0);
  var result: int64 := gethostname(buf, 256);
  
  if result < 0 {
    munmap(buf, 256);
    return 0 as pchar;
  }
  
  return buf as pchar;
}

// Get login name
pub fn GetLoginName(): pchar {
  // Try getlogin() first
  var buf: int64 := mmap(0, 256, 3, 34, -1, 0);
  var result: int64 := getlogin();
  
  if result != 0 {
    // Copy result
    var i: int64 := 0;
    while i < 256 {
      var c: int64 := peek8(result + i);
      poke8(buf + i, c);
      if c == 0 {
        munmap(buf, 256);
        return buf as pchar;
      }
      i := i + 1;
    }
  }
  
  // Fallback: use HOME env var
  var home: pchar := GetEnv("HOME"c);
  if home != 0 as pchar {
    var i: int64 := 0;
    while i < 256 {
      var c: int64 := peek8(home + i);
      poke8(buf + i, c);
      if c == 0 {
        break;
      }
      i := i + 1;
    }
    return buf as pchar;
  }
  
  munmap(buf, 256);
  return 0 as pchar;
}

// ============================================================================
// Time
// ============================================================================

// Get current time as unix timestamp
pub fn Time(): int64 {
  var tv: int64 := mmap(0, 16, 3, 34, -1, 0);  // struct timeval
  var result: int64 := gettimeofday(tv, 0);
  
  if result < 0 {
    munmap(tv, 16);
    return 0;
  }
  
  var sec: int64 := peek64(tv);
  munmap(tv, 16);
  
  return sec;
}

// Get current time with microseconds
pub fn GetTimeOfDay(): int64 {
  var tv: int64 := mmap(0, 16, 3, 34, -1, 0);
  var result: int64 := gettimeofday(tv, 0);
  
  if result < 0 {
    munmap(tv, 16);
    return 0;
  }
  
  var sec: int64 := peek64(tv);
  var usec: int64 := peek64(tv + 8);
  munmap(tv, 16);
  
  // Return combined as usec
  return sec * 1000000 + usec;
}

// Sleep for seconds
pub fn Sleep(sec: int64): void {
  var tv: int64 := mmap(0, 16, 3, 34, -1, 0);
  poke64(tv, sec);
  poke64(tv + 8, 0);
  select(0, 0, 0, 0, tv);
  munmap(tv, 16);
}

// Sleep for microseconds
pub fn USleep(usec: int64): void {
  var tv: int64 := mmap(0, 16, 3, 34, -1, 0);
  poke64(tv, usec / 1000000);
  poke64(tv + 8, usec % 1000000);
  select(0, 0, 0, 0, tv);
  munmap(tv, 16);
}

// ============================================================================
// Exit
// ============================================================================

// Exit process with status code
pub fn Exit(code: int64): void {
  syscall(60, code);  // sys_exit
}

