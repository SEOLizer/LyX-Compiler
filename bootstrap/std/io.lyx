// ============================================================================
// Input Functions
// ============================================================================

// Read line from stdin
pub fn ReadLine(): pchar {
  // Allocate buffer (start with 256 bytes)
  var cap: int64 := 256;
  var buf: int64 := mmap(cap, 1);
  var len: int64 := 0;
  
  while true {
    var tmp: int64 := mmap(1, 1);
    var bytesRead: int64 := read(STDIN_FILENO, tmp, 1);
    
    if bytesRead <= 0 {
      munmap(tmp, 1);
      break;
    }
    
    var c: int64 := peek8(tmp);
    munmap(tmp, 1);
    
    if c == 10 {  // newline
      break;
    }
    if c == 13 {  // carriage return
      continue;
    }
    
    // Expand buffer if needed
    if len >= cap - 1 {
      var newCap: int64 := cap * 2;
      var newBuf: int64 := mmap(newCap, 1);
      
      // Copy
      var i: int64 := 0;
      while i < len {
        poke8(newBuf + i, peek8(buf + i));
        i := i + 1;
      }
      
      munmap(buf, cap);
      buf := newBuf;
      cap := newCap;
    }
    
    poke8(buf + len, c);
    len := len + 1;
  }
  
  // Null-terminate
  poke8(buf + len, 0);
  
  return buf as pchar;
}

// Read char from stdin
pub fn ReadChar(): int64 {
  var tmp: int64 := mmap(1, 1);
  var bytesRead: int64 := read(STDIN_FILENO, tmp, 1);
  
  if bytesRead <= 0 {
    munmap(tmp, 1);
    return 0;
  }
  
  var c: int64 := peek8(tmp);
  munmap(tmp, 1);
  
  return c;
}

// Read int64 from stdin
pub fn ReadInt(): int64 {
  // Read until we get a digit or minus sign
  var buf: int64 := mmap(1, 1);
  var c: int64 := 0;
  
  // Skip non-numeric
  while true {
    var bytesRead: int64 := read(STDIN_FILENO, buf, 1);
    if bytesRead <= 0 {
      munmap(buf, 1);
      return 0;
    }
    c := peek8(buf);
    if c == 45 || (c >= 48 && c <= 57) {  // '-' or '0'-'9'
      break;
    }
    if c == 10 || c == 32 {  // newline or space
      continue;
    }
  }
  
  // Now parse the number
  var result: int64 := 0;
  var neg: bool := false;
  
  if c == 45 {  // minus
    neg := true;
    read(STDIN_FILENO, buf, 1);
  } else {
    result := c - 48;
  }
  
  while true {
    var bytesRead: int64 := read(STDIN_FILENO, buf, 1);
    if bytesRead <= 0 {
      break;
    }
    c := peek8(buf);
    if c < 48 || c > 57 {
      break;
    }
    result := result * 10 + (c - 48);
  }
  
  munmap(buf, 1);
  
  if neg {
    return 0 - result;
  }
  return result;
}

