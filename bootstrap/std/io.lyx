// Print to stderr
pub fn EPrintStr(s: pchar): void {
  var len: int64 := StrLen(s);
  if len > 0 {
    write(STDERR_FILENO, s, len);
  }
}

// Print to stderr with newline
pub fn EPrintStrLn(s: pchar): void {
  EPrintStr(s);
  write(STDERR_FILENO, "\n"c, 1);
}

// ============================================================================
// File I/O Helpers (using syscalls)
// ============================================================================

// Open file - returns fd or -1 on error
pub fn FileOpen(path: pchar, flags: int64, mode: int64): int64 {
  return open(path, flags, mode);
}

// Close file
pub fn FileClose(fd: int64): int64 {
  return close(fd);
}

// Read from file
pub fn FileRead(fd: int64, buf: int64, count: int64): int64 {
  return read(fd, buf, count);
}

// Write to file
pub fn FileWrite(fd: int64, buf: int64, count: int64): int64 {
  return write(fd, buf, count);
}

// Seek in file
pub fn FileSeek(fd: int64, offset: int64, whence: int64): int64 {
  return lseek(fd, offset, whence);
}

// Get file size
pub fn FileSize(path: pchar): int64 {
  var fd: int64 := open(path, 0, 0);
  if fd < 0 { return -1; }
  
  var size: int64 := lseek(fd, 0, 2);  // SEEK_END
  close(fd);
  
  return size;
}

// Read entire file
pub fn FileReadAll(path: pchar): pchar {
  var fd: int64 := open(path, 0, 0);
  if fd < 0 { return 0 as pchar; }
  
  var size: int64 := lseek(fd, 0, 2);
  if size <= 0 {
    close(fd);
    return 0 as pchar;
  }
  
  lseek(fd, 0, 0);
  
  var buf: int64 := mmap(size + 1, 1);
  var bytesRead: int64 := read(fd, buf, size);
  
  close(fd);
  
  if bytesRead != size {
    munmap(buf, size + 1);
    return 0 as pchar;
  }
  
  poke8(buf + size, 0);
  return buf as pchar;
}

// Write entire file
pub fn FileWriteAll(path: pchar, data: pchar, size: int64): bool {
  var fd: int64 := open(path, 65, 384);  // O_WRONLY | O_CREAT | O_TRUNC, 0600
  if fd < 0 { return false; }
  
  var written: int64 := write(fd, data, size);
  close(fd);
  
  return written == size;
}
