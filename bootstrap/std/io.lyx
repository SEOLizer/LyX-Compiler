con STDIN_FILENO: int64 := 0;
con STDOUT_FILENO: int64 := 1;
con STDERR_FILENO: int64 := 2;

// ============================================================================
// Print Functions
// ============================================================================

// Print string to stdout
pub fn PrintStr(s: pchar): void {
  var len: int64 := StrLen(s);
  if len > 0 {
    write(STDOUT_FILENO, s, len);
  }
}

// Print string with newline
pub fn PrintStrLn(s: pchar): void {
  PrintStr(s);
  write(STDOUT_FILENO, "\n"c, 1);
}

// Print int64
pub fn PrintInt(n: int64): void {
  var buf: int64 := mmap(32, 1);
  var neg: bool := false;
  
  if n < 0 {
    neg := true;
    n := 0 - n;
  }
  
  var len: int64 := 0;
  if n == 0 {
    poke8(buf, 48);
    len := 1;
  } else {
    while n > 0 {
      var digit: int64 := n % 10;
      poke8(buf + len, 48 + digit);
      len := len + 1;
      n := n / 10;
    }
  }
  
  if neg {
    poke8(buf + len, 45);
    len := len + 1;
  }
  
  // Print in reverse
  var i: int64 := len - 1;
  while i >= 0 {
    write(STDOUT_FILENO, buf + i, 1);
    i := i - 1;
  }
  
  munmap(buf, 32);
}

// Print int64 with newline
pub fn PrintIntLn(n: int64): void {
  PrintInt(n);
  write(STDOUT_FILENO, "\n"c, 1);
}

// Print f64 (simple version)
pub fn PrintFloat(f: f64): void {
  var asInt: int64 := f as int64;
  PrintInt(asInt);
  write(STDOUT_FILENO, "."c, 1);
  var frac: int64 := ((f - (f as int64)) * 1000) as int64;
  PrintInt(frac);
}

// Print char
pub fn PrintChar(c: int64): void {
  var buf: int64 := mmap(1, 1);
  poke8(buf, c);
  write(STDOUT_FILENO, buf, 1);
  munmap(buf, 1);
}

// Print bool
pub fn PrintBool(b: bool): void {
  if b {
    PrintStr("true"c);
  } else {
    PrintStr("false"c);
  }
}

// Print newline
pub fn PrintLn(): void {
  write(STDOUT_FILENO, "\n"c, 1);
}

// ============================================================================
// Formatted Print (Printf)
// ============================================================================

// Parse format specifier: %[flags][width][.precision]specifier
// Supported: %s, %d, %f, %c, %%
// flags: - + space # 0
// width: number
// .precision: .number

// Helper: Parse integer from string
fn parseInt(ptr: int64, start: int64, end: int64): int64 {
  var result: int64 := 0;
  var i: int64 := start;
  
  while i < end {
    var c: int64 := peek8(ptr + i);
    if c < 48 || c > 57 {
      return result;
    }
    result := result * 10 + (c - 48);
    i := i + 1;
  }
  
  return result;
}

// Printf - simple version with %s, %d, %f, %c, %%
pub fn Printf(fmt: pchar, args: int64): void {
  var fmtLen: int64 := StrLen(fmt);
  var argIdx: int64 := 0;
  var i: int64 := 0;
  
  while i < fmtLen {
    var c: int64 := peek8(fmt + i);
    
    if c == 37 {  // '%'
      i := i + 1;
      if i >= fmtLen {
        PrintChar(37);
        break;
      }
      
      c := peek8(fmt + i);
      
      if c == 115 {  // 's' - string
        var arg: int64 := map_get(args, 0 as pchar, argIdx);
        PrintStr(arg as pchar);
        argIdx := argIdx + 1;
      } else if c == 100 {  // 'd' - decimal
        var arg: int64 := map_get(args, 0 as pchar, argIdx);
        PrintInt(arg);
        argIdx := argIdx + 1;
      } else if c == 117 {  // 'u' - unsigned
        var arg: int64 := map_get(args, 0 as pchar, argIdx);
        PrintInt(arg);
        argIdx := argIdx + 1;
      } else if c == 102 {  // 'f' - float
        var arg: int64 := map_get(args, 0 as pchar, argIdx);
        PrintFloat(arg as f64);
        argIdx := argIdx + 1;
      } else if c == 99 {  // 'c' - char
        var arg: int64 := map_get(args, 0 as pchar, argIdx);
        PrintChar(arg);
        argIdx := argIdx + 1;
      } else if c == 37 {  // '%%'
        PrintChar(37);
      } else {
        // Unknown specifier, print as-is
        PrintChar(37);
        PrintChar(c);
      }
    } else {
      PrintChar(c);
    }
    
    i := i + 1;
  }
}

// Fprintf - print to file descriptor
pub fn Fprintf(fd: int64, fmt: pchar, args: int64): void {
  var fmtLen: int64 := StrLen(fmt);
  var argIdx: int64 := 0;
  var i: int64 := 0;
  
  while i < fmtLen {
    var c: int64 := peek8(fmt + i);
    
    if c == 37 {  // '%'
      i := i + 1;
      if i >= fmtLen {
        var buf: int64 := mmap(1, 1);
        poke8(buf, 37);
        write(fd, buf, 1);
        munmap(buf, 1);
        break;
      }
      
      c := peek8(fmt + i);
      
      if c == 115 {  // 's' - string
        var arg: int64 := map_get(args, 0 as pchar, argIdx);
        var len: int64 := StrLen(arg);
        if len > 0 {
          write(fd, arg, len);
        }
        argIdx := argIdx + 1;
      } else if c == 100 {  // 'd' - decimal
        var arg: int64 := map_get(args, 0 as pchar, argIdx);
        
        var buf: int64 := mmap(32, 1);
        var neg: bool := false;
        
        if arg < 0 {
          neg := true;
          arg := 0 - arg;
        }
        
        var len: int64 := 0;
        if arg == 0 {
          poke8(buf, 48);
          len := 1;
        } else {
          while arg > 0 {
            var digit: int64 := arg % 10;
            poke8(buf + len, 48 + digit);
            len := len + 1;
            arg := arg / 10;
          }
        }
        
        if neg {
          poke8(buf + len, 45);
          len := len + 1;
        }
        
        // Write in reverse
        var j: int64 := len - 1;
        while j >= 0 {
          write(fd, buf + j, 1);
          j := j - 1;
        }
        
        munmap(buf, 32);
        argIdx := argIdx + 1;
      } else if c == 37 {  // '%%'
        var buf: int64 := mmap(1, 1);
        poke8(buf, 37);
        write(fd, buf, 1);
        munmap(buf, 1);
      } else {
        // Unknown
        var buf: int64 := mmap(1, 1);
        poke8(buf, c);
        write(fd, buf, 1);
        munmap(buf, 1);
      }
    } else {
      var buf: int64 := mmap(1, 1);
      poke8(buf, c);
      write(fd, buf, 1);
      munmap(buf, 1);
    }
    
    i := i + 1;
  }
}

