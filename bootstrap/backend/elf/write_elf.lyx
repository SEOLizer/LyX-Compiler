pub fn main(): int64 {
  // Minimaler Test: nur ein RET-Instruction
  var code: int64 := mmap(16, 7);
  code[0] := 0xC3;  // RET
  
  WriteElf64("/tmp/test_elf64", 14, code, 1, 0x401000);
  
  munmap(code, 16);
  
  PrintStr("ELF64 Writer Test Complete\n");
  return 0;
}
