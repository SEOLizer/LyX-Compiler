// bootstrap/test_structs.lyx -- WP-10d struct field access smoke test

struct Point {
  x: int64;
  y: int64;
}

struct Rect {
  left:   int64;
  top:    int64;
  right:  int64;
  bottom: int64;
}

fn printPoint(p: Point) {
  PrintStr("x="); PrintInt(p.x); PrintStr(" y="); PrintInt(p.y); PrintStr("\n");
}

fn main(argc: int64, argv: pchar): int64 {
  // Auto-allocated struct local
  var p: Point;
  p.x := 10;
  p.y := 20;
  PrintStr("Point: ");
  printPoint(p);

  // Second struct
  var r: Rect;
  r.left   := 1;
  r.top    := 2;
  r.right  := 100;
  r.bottom := 200;
  PrintStr("Rect left=");   PrintInt(r.left);
  PrintStr(" top=");        PrintInt(r.top);
  PrintStr(" right=");      PrintInt(r.right);
  PrintStr(" bottom=");     PrintInt(r.bottom);
  PrintStr("\n");

  // Struct via new
  var q: Point := new Point();
  q.x := 42;
  q.y := 99;
  PrintStr("new Point: ");
  printPoint(q);

  return 0;
}
