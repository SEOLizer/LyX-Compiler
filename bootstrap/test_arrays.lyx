// bootstrap/test_arrays.lyx  -- WP-10b dynamic array smoke test

fn main(argc: int64, argv: pchar): int64 {
  var nums: array<int64>;

  // push some values
  nums.push(10);
  nums.push(20);
  nums.push(30);

  PrintStr("length=");
  PrintInt(nums.length);
  PrintStr("\n");

  PrintStr("nums[0]=");
  PrintInt(nums[0]);
  PrintStr("\n");

  PrintStr("nums[1]=");
  PrintInt(nums[1]);
  PrintStr("\n");

  PrintStr("nums[2]=");
  PrintInt(nums[2]);
  PrintStr("\n");

  // index write
  nums[1] := 99;
  PrintStr("nums[1] after write=");
  PrintInt(nums[1]);
  PrintStr("\n");

  // pop
  var v: int64 := nums.pop();
  PrintStr("popped=");
  PrintInt(v);
  PrintStr("\n");
  PrintStr("length after pop=");
  PrintInt(nums.length);
  PrintStr("\n");

  return 0;
}
