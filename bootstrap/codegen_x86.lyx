// bootstrap/codegen_x86.lyx
// Lyx Self-Hosted x86_64 Code Generator (WP-08)
// Direct AST → ELF64 code emission, stack-based, no register allocator.
//
// WP-09 addition: import resolution (reads/parses/codegens imported .lyx files)

import bootstrap.parser;
//
// Design:
//   - All method names prefixed cg_ (avoid VMT collision with Parser/Sema)
//   - Stack-based expression evaluation (push/pop)
//   - rbp-relative stack slots for locals and parameters
//   - Single PT_LOAD ELF64, statically linked, no PLT/GOT
//   - _start calls main() then sys_exit; helpers emit PrintStr/PrintInt/StrLen

// ============================================================================
// Local constant copies (avoid imported-constant-in-class-method bug)
// ============================================================================

con CG_NODE_SIZE: int64 := 88;
con CG_TOK_SIZE:  int64 := 40;

// Node kinds (mirror NK_xxx from bootstrap.parser)
con CGN_IMPORT:      int64 := 1;
con CGN_FUNC_DECL:   int64 := 2;
con CGN_PARAM:       int64 := 3;
con CGN_VAR_DECL:    int64 := 4;
con CGN_CON_DECL:    int64 := 5;
con CGN_STRUCT_DECL: int64 := 6;
con CGN_ENUM_DECL:   int64 := 8;
con CGN_BLOCK:       int64 := 20;
con CGN_IF:          int64 := 21;
con CGN_WHILE:       int64 := 22;
con CGN_RETURN:      int64 := 23;
con CGN_EXPR_STMT:   int64 := 24;
con CGN_ASSIGN:      int64 := 25;
con CGN_FOR:         int64 := 26;
con CGN_SWITCH:      int64 := 27;
con CGN_CASE:        int64 := 28;
con CGN_BREAK:       int64 := 29;
con CGN_DISPOSE:     int64 := 30;
con CGN_CONTINUE:    int64 := 35;

// WP-12: Exception handling nodes
con CGN_TRY:       int64 := 31;
con CGN_CATCH:     int64 := 32;
con CGN_FINALLY:   int64 := 33;
con CGN_THROW:     int64 := 34;

con CGN_LIT_INT:     int64 := 40;
con CGN_LIT_FLOAT:   int64 := 41;
con CGN_LIT_STR:     int64 := 42;
con CGN_LIT_CHAR:    int64 := 43;
con CGN_LIT_BOOL:    int64 := 44;
con CGN_LIT_NULL:    int64 := 45;
con CGN_IDENT:       int64 := 46;
con CGN_BINOP:       int64 := 47;
con CGN_UNOP:        int64 := 48;
con CGN_CALL:        int64 := 49;
con CGN_INDEX:       int64 := 50;
con CGN_FIELD:       int64 := 51;
con CGN_NEW:         int64 := 52;
con CGN_CAST:        int64 := 53;  // WP-11: x as Type
con CGN_CLOSURE:     int64 := 54;  // WP-13: closure { fn ptr, captured env }
con CGN_MATCH:       int64 := 64;  // WP-15: match expr { cases }
con CGN_MATCH_CASE:  int64 := 65;  // WP-15: case pattern => expr
con CGN_RANGE:        int64 := 73;  // WP-17: range expression: 1..100
con CGN_WHERE:        int64 := 74;  // WP-17: where clause: type X where constraint
con CGN_IS_EXPR:      int64 := 72;  // WP-16: x is Type

// WP-15: Pattern matching node kinds
con CGN_PATTERN_LIT:  int64 := 66;  // literal pattern
con CGN_PATTERN_WILD: int64 := 67; // wildcard pattern
con CGN_PATTERN_BIND: int64 := 68; // binding pattern (x @ pattern)
con CGN_PATTERN_ENUM: int64 := 75; // enum payload pattern: Ok(v)
con CGN_PATTERN_STRUCT:int64 := 76; // struct destructure pattern: Point { x, y }

// Token kinds for binary operators (mirror TK_xxx from bootstrap.lexer)
con CGT_PLUS:    int64 := 70;
con CGT_MINUS:   int64 := 71;
con CGT_STAR:    int64 := 72;
con CGT_SLASH:   int64 := 73;
con CGT_PERCENT: int64 := 74;
con CGT_EQ2:     int64 := 79;
con CGT_NEQ:     int64 := 80;
con CGT_LT:      int64 := 81;
con CGT_LE:      int64 := 82;
con CGT_GT:      int64 := 83;
con CGT_GE:      int64 := 84;
con CGT_AND:     int64 := 85;
con CGT_OR:      int64 := 86;
con CGT_NOT:     int64 := 87;
con CGT_BITAND:  int64 := 90;
con CGT_BITOR:   int64 := 91;
con CGT_BITNOT:  int64 := 92;
con CGT_SHL:     int64 := 93;
con CGT_SHR:     int64 := 94;

// ELF / load address
con CG_ELF_BASE:   int64 := 4194304;  // 0x400000
con CG_PHDR_OFF:   int64 := 64;       // phdr right after ELF header
con CG_CODE_OFF:   int64 := 120;      // code starts after ELF hdr (64) + phdr (56)

// Helper function offsets within code buffer (fixed layout emitted in cg_emitHelpers)
//   _start:        offset 0   (65 bytes)
//   _lyx_strlen:   offset 65  (15 bytes)
//   _lyx_print_str:offset 80  (26 bytes)
//   _lyx_print_int:offset 106 (104 bytes)
//   _lyx_strsub:   offset 210 (40 bytes)
//   _lyx_strcharat:offset 250 (15 bytes)
//   user code:     offset 265
con CG_H_START:     int64 := 0;
con CG_H_STRLEN:    int64 := 65;
con CG_H_PRINTSTR:  int64 := 80;
con CG_H_PRINTINT:  int64 := 106;
con CG_H_STRSUB:    int64 := 210;
con CG_H_STRCHARAT: int64 := 250;
con CG_H_USER:      int64 := 265;

// Patch kinds
con CG_PATCH_CALL:     int64 := 0;
con CG_PATCH_STR:      int64 := 1;
con CG_PATCH_VMT_ADDR: int64 := 2;  // absolute 8-byte VMT address in code buffer

// Table entry sizes (bytes)
con CG_LOCAL_SZ:   int64 := 24;   // name(8) + nameLen(8) + rbpOff(8)
con CG_LABEL_SZ:   int64 := 24;   // name(8) + nameLen(8) + codeOff(8)
con CG_PATCH_SZ:   int64 := 32;   // codeOff(8) + namePtr(8) + nameLen(8) + kind(8)
con CGN_TYPE_DECL: int64 := 10;   // NK_TYPE_DECL from parser
con CGN_FIELD_DECL:int64 := 7;    // NK_FIELD_DECL from parser
con CG_CLASS_SZ:   int64 := 40;   // className(8)+classLen(8)+fieldsPtr(8)+fieldCnt(8)+vmtDataOff(8)
con CG_CFIELD_SZ:  int64 := 24;   // fieldName(8)+fieldLen(8)+fieldOffset(8)
con CG_VMT_PATCH_SZ: int64 := 24; // codeOff(8) + classNamePtr(8) + classNameLen(8)

// WP-12: Exception handling globals pre-reserved at start of data section
con CG_EXN_VAL: int64 := 0;   // data[0..7]:  current exception value (_lyx_exn_val)
con CG_EXN_PTR: int64 := 8;   // data[8..15]: current handler jmp_buf ptr (_lyx_exn_ptr)

// ============================================================================
// Codegen class
// ============================================================================

pub type Codegen = class {

  // Code emission buffer
  code:    int64;
  codeLen: int64;
  codeCap: int64;

  // String literal data buffer
  data:    int64;
  dataLen: int64;
  dataCap: int64;

  // Local variable table
  locals:     int64;
  localCount: int64;
  localCap:   int64;
  frameSize:  int64;   // bytes allocated below rbp (grows with each local)

  // Function label table
  labels:     int64;
  labelCount: int64;
  labelCap:   int64;

  // Backpatch table
  patches:    int64;
  patchCount: int64;
  patchCap:   int64;

  // Parser output (set by Init)
  pSrc:   pchar;
  pNodes: int64;
  pToks:  int64;

  // Unique id for anonymous labels (if/while)
  nextLblId: int64;

  // Import deduplication (WP-09: avoid processing same module twice)
  importNames: int64;  // mmap buffer of {ptr:int64, len:int64} pairs (16 bytes each)
  importCount: int64;
  importCap:   int64;

  // Class layout table (WP-09 OOP support)
  classLayouts: int64;   // {namePtr:8, nameLen:8, fieldsPtr:8, fieldCnt:8} each
  classCount:   int64;
  classCap:     int64;

  // Enum layout table (BUG-08: enum tag analysis for match)
  // Each entry: {namePtr:8, nameLen:8, variantsPtr:8, variantCnt:8} = 32 bytes
  // Each variant: {namePtr:8, nameLen:8, tagValue:8, payloadSize:8} = 32 bytes
  enumLayouts:  int64;
  enumCount:    int64;
  enumCap:      int64;

  // Per-local type tracking (parallel to locals, {typePtr:8, typeLen:8} each)
  localTypes:   int64;

  // Current method class context (set while generating a method body)
  curClassName:    pchar;
  curClassNameLen: int64;

  // Module-level constant table {namePtr:8, nameLen:8, value:8} = 24 bytes per entry
  conTable: int64;
  conCount: int64;
  conCap:   int64;

  // Break support: linked list of pending jmp-rel32 placeholders in code buffer.
  // curBreakHead holds the code offset of the most recent break's 4-byte placeholder,
  // or -1 if no break is pending. Each placeholder stores the previous head as the link.
  curBreakHead: int64;

  // Continue support: linked list of pending jmp-rel32 placeholders for continue
  curContHead: int64;

  // VMT address patch table (WP-10a): {codeOff:8, classNamePtr:8, classNameLen:8}
  // Each entry says: at code offset codeOff there is a mov-rcx-imm64 placeholder
  // that needs the absolute vaddr of the VMT table for the named class.
  vmtPatches:    int64;
  vmtPatchCount: int64;
  vmtPatchCap:   int64;

  // WP-13: Closure support - static link for nested functions
  staticLinkOffset: int64;  // rbp offset of static link param (or -1 if not nested)
  outerFuncName:    pchar;  // name of outer function (for static link)
  outerFuncNameLen: int64;

  // Per-local array flag (WP-10b): byte buffer parallel to locals, 1 = array type
  localIsArray: int64;
  foldBuf:      int64;  // WP-10g: scratch for cg_tryFold constant-folding results

  // Temporary buffer tracking (BUG-02: prevent mmap leaks)
  // Each entry: {bufPtr:8, bufSize:8} = 16 bytes
  tempBufs:      int64;
  tempBufCount:  int64;
  tempBufCap:    int64;

  // WP-13: Captured variable table for nested functions
  // Each entry: {outerFuncPtr:8, outerFuncLen:8, varNamePtr:8, varNameLen:8, offset:8} = 40 bytes
  capturedVars:      int64;
  capturedCount:     int64;
  capturedCap:       int64;

  // ------------------------------------------------------------------
  // Raw byte emitters (code buffer)
  // ------------------------------------------------------------------

  fn cg_trackTempBuf(buf: int64, size: int64) {
    if (self.tempBufCount >= self.tempBufCap) {
      var nc: int64 := self.tempBufCap * 2;
      var nb: int64 := mmap(0, nc * 16, 3, 34, -1, 0);
      var i: int64 := 0;
      while (i < self.tempBufCount * 16) {
        poke8(nb + i, peek8(self.tempBufs + i));
        i := i + 1;
      }
      if (self.tempBufs != 0) { munmap(self.tempBufs, self.tempBufCap * 16); }
      self.tempBufs := nb;
      self.tempBufCap := nc;
    }
    var base: int64 := self.tempBufs + self.tempBufCount * 16;
    poke64(base,     buf);
    poke64(base + 8, size);
    self.tempBufCount := self.tempBufCount + 1;
  }

  fn cg_freeAllTempBufs() {
    var i: int64 := 0;
    while (i < self.tempBufCount) {
      var base: int64 := self.tempBufs + i * 16;
      var buf:  int64 := peek64(base);
      var size: int64 := peek64(base + 8);
      munmap(buf, size);
      i := i + 1;
    }
    self.tempBufCount := 0;
  }

  fn cg_grow() {
    var nc: int64 := self.codeCap * 2;
    var nb: int64 := mmap(0, nc, 3, 34, -1, 0);
    var i: int64 := 0;
    while (i < self.codeLen) { poke8(nb + i, peek8(self.code + i)); i := i + 1; }
    self.code := nb; self.codeCap := nc;
  }

  fn cg_e8(b: int64) {
    if (self.codeLen >= self.codeCap) { self.cg_grow(); }
    poke8(self.code + self.codeLen, b & 255);
    self.codeLen := self.codeLen + 1;
  }

  fn cg_e32(n: int64) {
    self.cg_e8(n); self.cg_e8(n >> 8); self.cg_e8(n >> 16); self.cg_e8(n >> 24);
  }

  fn cg_e64(n: int64) {
    self.cg_e32(n); self.cg_e32(n >> 32);
  }

  // ------------------------------------------------------------------
  // Data buffer emitter
  // ------------------------------------------------------------------

  fn cg_growData() {
    var nc: int64 := self.dataCap * 2;
    var nb: int64 := mmap(0, nc, 3, 34, -1, 0);
    var i: int64 := 0;
    while (i < self.dataLen) { poke8(nb + i, peek8(self.data + i)); i := i + 1; }
    self.data := nb; self.dataCap := nc;
  }

  fn cg_edata(b: int64) {
    if (self.dataLen >= self.dataCap) { self.cg_growData(); }
    poke8(self.data + self.dataLen, b & 255);
    self.dataLen := self.dataLen + 1;
  }

  // ------------------------------------------------------------------
  // Node accessors (prefixed cg_ to avoid VMT collision with Parser)
  // ------------------------------------------------------------------

  fn cg_noff(i: int64): int64   { return self.pNodes + i * CG_NODE_SIZE; }
  fn cg_nkind(i: int64): int64  { return peek64(self.cg_noff(i)); }
  fn cg_nc0(i: int64): int64    { return peek64(self.cg_noff(i) + 8); }
  fn cg_nc1(i: int64): int64    { return peek64(self.cg_noff(i) + 16); }
  fn cg_nc2(i: int64): int64    { return peek64(self.cg_noff(i) + 24); }
  fn cg_nnext(i: int64): int64  { return peek64(self.cg_noff(i) + 40); }
  fn cg_nival(i: int64): int64  { return peek64(self.cg_noff(i) + 56); }
  fn cg_nsoff(i: int64): int64  { return peek64(self.cg_noff(i) + 64); }
  fn cg_nslen(i: int64): int64  { return peek64(self.cg_noff(i) + 72); }
  fn cg_nsval(i: int64): pchar  { return self.pSrc + self.cg_nsoff(i); }

  // ------------------------------------------------------------------
  // String comparison (length-delimited)
  // ------------------------------------------------------------------

  fn cg_seq(a: pchar, an: int64, b: pchar, bn: int64): bool {
    if (an != bn) { return false; }
    var i: int64 := 0;
    while (i < an) {
      if (StrCharAt(a, i) != StrCharAt(b, i)) { return false; }
      i := i + 1;
    }
    return true;
  }

  // ------------------------------------------------------------------
  // Local variable table  (name, nameLen, rbpOff) × CG_LOCAL_SZ bytes
  // ------------------------------------------------------------------

  fn cg_addLocal(name: pchar, nlen: int64): int64 {
    if (self.localCount >= self.localCap) {
      var nc: int64 := self.localCap * 2;
      var nb: int64 := mmap(0, nc * CG_LOCAL_SZ, 3, 34, -1, 0);
      var i: int64 := 0;
      while (i < self.localCount * CG_LOCAL_SZ) { poke8(nb+i, peek8(self.locals+i)); i:=i+1; }
      self.locals := nb;
      var tb: int64 := mmap(0, nc * 16, 3, 34, -1, 0);
      i := 0;
      while (i < self.localCount * 16) { poke8(tb+i, peek8(self.localTypes+i)); i:=i+1; }
      self.localTypes := tb;
      var ab: int64 := mmap(0, nc, 3, 34, -1, 0);
      i := 0;
      while (i < self.localCount) { poke8(ab+i, peek8(self.localIsArray+i)); i:=i+1; }
      self.localIsArray := ab;
      self.localCap := nc;
    }
    self.frameSize := self.frameSize + 8;
    var off: int64 := self.locals + self.localCount * CG_LOCAL_SZ;
    poke64(off,      name as int64);
    poke64(off + 8,  nlen);
    poke64(off + 16, 0 - self.frameSize);
    // Zero the type entry for this new local
    var toff: int64 := self.localTypes + self.localCount * 16;
    poke64(toff,     0);
    poke64(toff + 8, 0);
    poke8(self.localIsArray + self.localCount, 0);
    self.localCount := self.localCount + 1;
    return 0 - self.frameSize;
  }

  fn cg_findLocal(name: pchar, nlen: int64): int64 {
    var i: int64 := self.localCount - 1;
    while (i >= 0) {
      var base: int64 := self.locals + i * CG_LOCAL_SZ;
      var sname: pchar := peek64(base) as pchar;
      var slen:  int64 := peek64(base + 8);
      if (self.cg_seq(sname, slen, name, nlen)) { return peek64(base + 16); }
      i := i - 1;
    }
    return 0;  // 0 = not found (valid offsets are always negative)
  }

  // Returns index (0-based) of local by name, or -1 if not found
  fn cg_findLocalIdx(name: pchar, nlen: int64): int64 {
    var i: int64 := self.localCount - 1;
    while (i >= 0) {
      var base: int64 := self.locals + i * CG_LOCAL_SZ;
      var sname: pchar := peek64(base) as pchar;
      var slen:  int64 := peek64(base + 8);
      if (self.cg_seq(sname, slen, name, nlen)) { return i; }
      i := i - 1;
    }
    return -1;
  }

  // Returns 1 if the CGN_IDENT node ni refers to an array-typed local
  fn cg_identIsArray(ni: int64): int64 {
    if (self.cg_nkind(ni) != CGN_IDENT) { return 0; }
    var idx: int64 := self.cg_findLocalIdx(self.cg_nsval(ni), self.cg_nslen(ni));
    if (idx < 0) { return 0; }
    return peek8(self.localIsArray + idx);
  }

  // WP-13: Find captured variable from outer function's frame via static link
  // Returns the offset in the captured environment, or 0 if not found
  fn cg_findCapturedVar(name: pchar, nlen: int64): int64 {
    // Search the captured vars table for the current outer function
    var i: int64 := 0;
    while (i < self.capturedCount) {
      var base: int64 := self.capturedVars + i * 40;
      var funcPtr:  pchar := peek64(base) as pchar;
      var funcLen:  int64 := peek64(base + 8);
      var varPtr:   pchar := peek64(base + 16) as pchar;
      var varLen:   int64 := peek64(base + 24);
      var varOff:   int64 := peek64(base + 32);
      // Match both outer function name and variable name
      if (funcLen == self.outerFuncNameLen &&
          self.cg_seq(funcPtr, funcLen, self.outerFuncName, self.outerFuncNameLen) &&
          varLen == nlen && self.cg_seq(varPtr, varLen, name, nlen)) {
        return varOff;
      }
      i := i + 1;
    }
    return 0;
  }

  // WP-13: Register a captured variable for the current outer function
  fn cg_addCapturedVar(varName: pchar, varLen: int64, off: int64) {
    // Check if already captured
    var i: int64 := 0;
    while (i < self.capturedCount) {
      var base: int64 := self.capturedVars + i * 40;
      var funcPtr:  pchar := peek64(base) as pchar;
      var funcLen:  int64 := peek64(base + 8);
      var varPtr:   pchar := peek64(base + 16) as pchar;
      var varLen2:  int64 := peek64(base + 24);
      if (funcLen == self.outerFuncNameLen &&
          self.cg_seq(funcPtr, funcLen, self.outerFuncName, self.outerFuncNameLen) &&
          varLen2 == varLen && self.cg_seq(varPtr, varLen2, varName, varLen)) {
        return;  // Already captured
      }
      i := i + 1;
    }
    // Grow table if needed
    if (self.capturedCount >= self.capturedCap) {
      var nc: int64 := self.capturedCap * 2;
      var nb: int64 := mmap(0, nc * 40, 3, 34, -1, 0);
      var j: int64 := 0;
      while (j < self.capturedCount * 40) {
        poke8(nb + j, peek8(self.capturedVars + j));
        j := j + 1;
      }
      munmap(self.capturedVars, self.capturedCap * 40);
      self.capturedVars := nb;
      self.capturedCap := nc;
    }
    var entry: int64 := self.capturedVars + self.capturedCount * 40;
    poke64(entry,      self.outerFuncName as int64);
    poke64(entry + 8,  self.outerFuncNameLen);
    poke64(entry + 16, varName as int64);
    poke64(entry + 24, varLen);
    poke64(entry + 32, off);
    self.capturedCount := self.capturedCount + 1;
  }

  // ------------------------------------------------------------------
  // Label table  (name, nameLen, codeOff) × CG_LABEL_SZ bytes
  // ------------------------------------------------------------------

  fn cg_addLabel(name: pchar, nlen: int64) {
    if (self.labelCount >= self.labelCap) {
      var nc: int64 := self.labelCap * 2;
      var nb: int64 := mmap(0, nc * CG_LABEL_SZ, 3, 34, -1, 0);
      var i: int64 := 0;
      while (i < self.labelCount * CG_LABEL_SZ) { poke8(nb+i, peek8(self.labels+i)); i:=i+1; }
      self.labels := nb; self.labelCap := nc;
    }
    var base: int64 := self.labels + self.labelCount * CG_LABEL_SZ;
    poke64(base,      name as int64);
    poke64(base + 8,  nlen);
    poke64(base + 16, self.codeLen);
    self.labelCount := self.labelCount + 1;
  }

  fn cg_findLabel(name: pchar, nlen: int64): int64 {
    var i: int64 := 0;
    while (i < self.labelCount) {
      var base: int64 := self.labels + i * CG_LABEL_SZ;
      var sname: pchar := peek64(base) as pchar;
      var slen:  int64 := peek64(base + 8);
      if (self.cg_seq(sname, slen, name, nlen)) { return peek64(base + 16); }
      i := i + 1;
    }
    return -1;
  }

  // ------------------------------------------------------------------
  // Module-level constant table  (namePtr, nameLen, value) × 24 bytes
  // Populated from CGN_CON_DECL nodes at module scope; used for identifier
  // resolution inside method bodies where only locals would otherwise work.
  // ------------------------------------------------------------------

  fn cg_addCon(name: pchar, nlen: int64, val: int64) {
    if (self.conCount >= self.conCap) {
      var nc: int64 := self.conCap * 2;
      var nb: int64 := mmap(0, nc * 24, 3, 34, -1, 0);
      var i: int64 := 0;
      while (i < self.conCount * 24) { poke8(nb + i, peek8(self.conTable + i)); i := i + 1; }
      self.conTable := nb; self.conCap := nc;
    }
    var base: int64 := self.conTable + self.conCount * 24;
    poke64(base,      name as int64);
    poke64(base + 8,  nlen);
    poke64(base + 16, val);
    self.conCount := self.conCount + 1;
  }

  fn cg_findConVal(name: pchar, nlen: int64): int64 {
    var i: int64 := 0;
    while (i < self.conCount) {
      var base: int64 := self.conTable + i * 24;
      var ename: pchar := peek64(base) as pchar;
      var elen:  int64 := peek64(base + 8);
      if (self.cg_seq(ename, elen, name, nlen) != 0) { return peek64(base + 16); }
      i := i + 1;
    }
    return -1;
  }

  // ------------------------------------------------------------------
  // WP-10g: Constant Folding + Peephole CSE helpers
  // ------------------------------------------------------------------

  // mov rbx, imm64  (48 BB xx ... xx) — for const-LHS binop optimisation
  fn cg_movRbxImm(val: int64) {
    self.cg_e8(0x48); self.cg_e8(0xBB); self.cg_e64(val);
  }

  // Try to evaluate node ni as a compile-time integer constant.
  // Returns 1 if successful and stores the value in self.foldBuf; 0 otherwise.
  fn cg_tryFold(ni: int64): int64 {
    if (ni < 0) { return 0; }
    var k: int64 := self.cg_nkind(ni);
    // Integer / bool literal
    if (k == CGN_LIT_INT || k == CGN_LIT_BOOL) {
      self.foldBuf := self.cg_nival(ni);
      return 1;
    }
    // Named constant (con FOO = val)
    if (k == CGN_IDENT) {
      var nm: pchar := self.cg_nsval(ni);
      var nl: int64 := self.cg_nslen(ni);
      if (self.cg_findLocal(nm, nl) != 0) { return 0; }  // local var, not foldable
      var cv: int64 := self.cg_findConVal(nm, nl);
      if (cv == -1) { return 0; }  // conservative: treat -1 as "not found"
      self.foldBuf := cv;
      return 1;
    }
    // Unary: -const, !const, ~const
    if (k == CGN_UNOP) {
      if (self.cg_tryFold(self.cg_nc0(ni)) == 0) { return 0; }
      var uop: int64 := self.cg_nival(ni);
      if (uop == CGT_MINUS)  { self.foldBuf := 0 - self.foldBuf; return 1; }
      if (uop == CGT_NOT)    { if (self.foldBuf == 0) { self.foldBuf := 1; } else { self.foldBuf := 0; } return 1; }
      if (uop == CGT_BITNOT) { self.foldBuf := -1 - self.foldBuf; return 1; }
      return 0;
    }
    // Binary: both sides must fold
    if (k == CGN_BINOP) {
      if (self.cg_tryFold(self.cg_nc0(ni)) == 0) { return 0; }
      var lv: int64 := self.foldBuf;
      if (self.cg_tryFold(self.cg_nc1(ni)) == 0) { return 0; }
      var rv: int64 := self.foldBuf;
      var bop: int64 := self.cg_nival(ni);
      if (bop == CGT_PLUS)    { self.foldBuf := lv + rv;  return 1; }
      if (bop == CGT_MINUS)   { self.foldBuf := lv - rv;  return 1; }
      if (bop == CGT_STAR)    { self.foldBuf := lv * rv;  return 1; }
      if (bop == CGT_SLASH)   { if (rv == 0) { return 0; } self.foldBuf := lv / rv; return 1; }
      if (bop == CGT_PERCENT) { if (rv == 0) { return 0; } self.foldBuf := lv % rv; return 1; }
      if (bop == CGT_EQ2)  { if (lv == rv) { self.foldBuf := 1; } else { self.foldBuf := 0; } return 1; }
      if (bop == CGT_NEQ)  { if (lv != rv) { self.foldBuf := 1; } else { self.foldBuf := 0; } return 1; }
      if (bop == CGT_LT)   { if (lv < rv)  { self.foldBuf := 1; } else { self.foldBuf := 0; } return 1; }
      if (bop == CGT_LE)   { if (lv <= rv) { self.foldBuf := 1; } else { self.foldBuf := 0; } return 1; }
      if (bop == CGT_GT)   { if (lv > rv)  { self.foldBuf := 1; } else { self.foldBuf := 0; } return 1; }
      if (bop == CGT_GE)   { if (lv >= rv) { self.foldBuf := 1; } else { self.foldBuf := 0; } return 1; }
      if (bop == CGT_AND)  { if (lv != 0 && rv != 0) { self.foldBuf := 1; } else { self.foldBuf := 0; } return 1; }
      if (bop == CGT_OR)   { if (lv != 0 || rv != 0) { self.foldBuf := 1; } else { self.foldBuf := 0; } return 1; }
      if (bop == CGT_BITAND) { self.foldBuf := lv & rv; return 1; }
      if (bop == CGT_BITOR)  { self.foldBuf := lv | rv; return 1; }
      if (bop == CGT_SHL)    { self.foldBuf := lv << rv; return 1; }
      if (bop == CGT_SHR)    { self.foldBuf := lv >> rv; return 1; }
      return 0;
    }
    return 0;
  }

  // ------------------------------------------------------------------
  // Patch table  (codeOff, namePtr, nameLen, kind) × CG_PATCH_SZ
  // For CG_PATCH_STR: namePtr = dataOff (int64 cast as ptr), nameLen = 0
  // ------------------------------------------------------------------

  fn cg_addPatch(codeOff: int64, namePtr: int64, nlen: int64, kind: int64) {
    if (self.patchCount >= self.patchCap) {
      var nc: int64 := self.patchCap * 2;
      var nb: int64 := mmap(0, nc * CG_PATCH_SZ, 3, 34, -1, 0);
      var i: int64 := 0;
      while (i < self.patchCount * CG_PATCH_SZ) { poke8(nb+i, peek8(self.patches+i)); i:=i+1; }
      self.patches := nb; self.patchCap := nc;
    }
    var base: int64 := self.patches + self.patchCount * CG_PATCH_SZ;
    poke64(base,      codeOff);
    poke64(base + 8,  namePtr);
    poke64(base + 16, nlen);
    poke64(base + 24, kind);
    self.patchCount := self.patchCount + 1;
  }

  fn cg_patchAll() {
    var i: int64 := 0;
    while (i < self.patchCount) {
      var base: int64 := self.patches + i * CG_PATCH_SZ;
      var codeOff: int64 := peek64(base);
      var namePtr: int64 := peek64(base + 8);
      var nlen:    int64 := peek64(base + 16);
      var kind:    int64 := peek64(base + 24);
      if (kind == CG_PATCH_CALL) {
        var targetOff: int64 := self.cg_findLabel(namePtr as pchar, nlen);
        if (targetOff >= 0) {
          var rel32: int64 := targetOff - codeOff - 4;
          poke32(self.code + codeOff, rel32);
        } else {
          PrintStr("codegen: unresolved symbol: ");
          var p: pchar := namePtr as pchar;
          var j: int64 := 0;
          while (j < nlen) { write(1, p + j, 1); j := j + 1; }
          PrintStr("\n");
        }
      } else {
        // CG_PATCH_STR: namePtr encodes data offset
        var dataOff: int64 := namePtr;
        var disp32: int64 := self.codeLen - codeOff - 4 + dataOff;
        poke32(self.code + codeOff, disp32);
      }
      i := i + 1;
    }
    // WP-10a: patch VMT address placeholders
    // vmtVaddr = CG_ELF_BASE + CG_CODE_OFF + codeLen + vmtDataOff
    var vmtBase: int64 := CG_ELF_BASE + CG_CODE_OFF + self.codeLen;
    var j: int64 := 0;
    while (j < self.vmtPatchCount) {
      var vbase: int64 := self.vmtPatches + j * 24;
      var codeOff2:  int64 := peek64(vbase);
      var namePtr2: pchar   := peek64(vbase + 8) as pchar;
      var nameLen2:  int64 := peek64(vbase + 16);
      var classIdx: int64 := self.cg_findClass(namePtr2, nameLen2);
      if (classIdx >= 0) {
        var cb: int64 := self.classLayouts + classIdx * CG_CLASS_SZ;
        var vmtDataOff: int64 := peek64(cb + 32);
        poke64(self.code + codeOff2, vmtBase + vmtDataOff);
      }
      j := j + 1;
    }
  }

  // ------------------------------------------------------------------
  // String data section
  // Copies source string (with escape processing) into data buffer.
  // sOff = offset in source of opening quote char '"'
  // sLen = raw token length including both quotes
  // Returns: offset within data buffer (for use in LEA disp32 patch)
  // ------------------------------------------------------------------

  fn cg_addStr(sOff: int64, sLen: int64): int64 {
    var doff: int64 := self.dataLen;
    var i: int64 := sOff + 1;          // skip opening '"'
    var eend: int64 := sOff + sLen - 1; // stop before closing '"'
    while (i < eend) {
      var c: int64 := StrCharAt(self.pSrc, i);
      if (c == 92 && i + 1 < eend) {   // backslash
        var esc: int64 := StrCharAt(self.pSrc, i + 1);
        if (esc == 110) { self.cg_edata(10); }  // \n
        else if (esc == 114) { self.cg_edata(13); }  // \r
        else if (esc == 116) { self.cg_edata(9);  }  // \t
        else if (esc == 48)  { self.cg_edata(0);  }  // \0
        else { self.cg_edata(esc); }
        i := i + 2;
      } else {
        self.cg_edata(c);
        i := i + 1;
      }
    }
    self.cg_edata(0);  // null terminator
    return doff;
  }

  // ------------------------------------------------------------------
  // x86_64 instruction emitters
  // ------------------------------------------------------------------

  // mov rax, imm64   (10 bytes: 48 B8 + 8 byte LE)
  fn cg_movRaxImm(n: int64) {
    self.cg_e8(0x48); self.cg_e8(0xB8); self.cg_e64(n);
  }

  // mov [rbp+off], rax  (store rax at rbp-relative offset)
  fn cg_storeRax(off: int64) {
    if (off >= -128 && off <= 127) {
      // 48 89 45 off8
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x45); self.cg_e8(off);
    } else {
      // 48 89 85 off32
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x85); self.cg_e32(off);
    }
  }

  // mov rax, [rbp+off]
  fn cg_loadRax(off: int64) {
    if (off >= -128 && off <= 127) {
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x45); self.cg_e8(off);
    } else {
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x85); self.cg_e32(off);
    }
  }

  // mov [rbp+off], rdi  (spill arg0 to stack)
  fn cg_spillRdi(off: int64) {
    if (off >= -128 && off <= 127) {
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x7D); self.cg_e8(off);
    } else {
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xBD); self.cg_e32(off);
    }
  }

  // mov [rbp+off], rsi  (spill arg1)
  fn cg_spillRsi(off: int64) {
    if (off >= -128 && off <= 127) {
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x75); self.cg_e8(off);
    } else {
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xB5); self.cg_e32(off);
    }
  }

  // mov [rbp+off], rdx  (spill arg2)
  fn cg_spillRdx(off: int64) {
    if (off >= -128 && off <= 127) {
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x55); self.cg_e8(off);
    } else {
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x95); self.cg_e32(off);
    }
  }

  // mov [rbp+off], rcx  (spill arg3)
  fn cg_spillRcx(off: int64) {
    if (off >= -128 && off <= 127) {
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x4D); self.cg_e8(off);
    } else {
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x8D); self.cg_e32(off);
    }
  }

  // mov [rbp+off], r8  (spill arg4)
  fn cg_spillR8(off: int64) {
    if (off >= -128 && off <= 127) {
      self.cg_e8(0x4C); self.cg_e8(0x89); self.cg_e8(0x45); self.cg_e8(off);
    } else {
      self.cg_e8(0x4C); self.cg_e8(0x89); self.cg_e8(0x85); self.cg_e32(off);
    }
  }

  // mov [rbp+off], r9  (spill arg5)
  fn cg_spillR9(off: int64) {
    if (off >= -128 && off <= 127) {
      self.cg_e8(0x4C); self.cg_e8(0x89); self.cg_e8(0x4D); self.cg_e8(off);
    } else {
      self.cg_e8(0x4C); self.cg_e8(0x89); self.cg_e8(0x8D); self.cg_e32(off);
    }
  }

  // lea rax, [rip + disp32]  — for string literals; disp32 is placeholder 0
  // Returns: position of disp32 in code buffer (for patching)
  fn cg_emitLeaStr(): int64 {
    self.cg_e8(0x48); self.cg_e8(0x8D); self.cg_e8(0x05);
    var pos: int64 := self.codeLen;
    self.cg_e32(0);
    return pos;
  }

  // WP-12: Emit lea rcx, [rip+disp32] to access a data section global.
  // dataOff = CG_EXN_VAL (0) or CG_EXN_PTR (8). Adds a CG_PATCH_STR patch.
  fn cg_emitLeaRcxData(dataOff: int64) {
    self.cg_e8(0x48); self.cg_e8(0x8D); self.cg_e8(0x0D);  // lea rcx, [rip+disp32]
    var pp: int64 := self.codeLen;
    self.cg_e32(0);
    self.cg_addPatch(pp, dataOff, 0, CG_PATCH_STR);
  }

  // WP-12: Emit longjmp code. rax must hold jmp_buf base pointer.
  // Restores rbx, rbp, r12..r15; sets rsp=rax; then jmp [rsp+56] (catch label).
  fn cg_genLongjmp() {
    self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x18);                     // mov rbx, [rax]
    self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x68); self.cg_e8(0x08);  // mov rbp, [rax+8]
    self.cg_e8(0x4C); self.cg_e8(0x8B); self.cg_e8(0x60); self.cg_e8(0x10);  // mov r12, [rax+16]
    self.cg_e8(0x4C); self.cg_e8(0x8B); self.cg_e8(0x68); self.cg_e8(0x18);  // mov r13, [rax+24]
    self.cg_e8(0x4C); self.cg_e8(0x8B); self.cg_e8(0x70); self.cg_e8(0x20);  // mov r14, [rax+32]
    self.cg_e8(0x4C); self.cg_e8(0x8B); self.cg_e8(0x78); self.cg_e8(0x28);  // mov r15, [rax+40]
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC4);                     // mov rsp, rax
    self.cg_e8(0xFF); self.cg_e8(0x64); self.cg_e8(0x24); self.cg_e8(0x38);  // jmp [rsp+56]
  }

  // WP-11: Parse float literal string src[off..off+len) to IEEE 754 double bits.
  // Handles: N, N.M, N[eE][+-]P format.
  fn cg_parseFloat(src: pchar, off: int64, len: int64): int64 {
    var i: int64 := off;
    var end: int64 := off + len;
    var neg: int64 := 0;
    if (i < end && StrCharAt(src, i) == 45) { neg := 1; i := i + 1; }
    var num: int64 := 0;
    var den: int64 := 1;
    while (i < end && StrCharAt(src, i) >= 48 && StrCharAt(src, i) <= 57) {
      if (num < 900000000000000) { num := num * 10 + StrCharAt(src, i) - 48; }
      i := i + 1;
    }
    if (i < end && StrCharAt(src, i) == 46) {
      i := i + 1;
      while (i < end && StrCharAt(src, i) >= 48 && StrCharAt(src, i) <= 57 && den < 100000000) {
        num := num * 10 + StrCharAt(src, i) - 48;
        den := den * 10;
        i := i + 1;
      }
      while (i < end && StrCharAt(src, i) >= 48 && StrCharAt(src, i) <= 57) { i := i + 1; }
    }
    var expNeg: int64 := 0;
    var expVal: int64 := 0;
    if (i < end && (StrCharAt(src, i) == 101 || StrCharAt(src, i) == 69)) {
      i := i + 1;
      if (i < end && StrCharAt(src, i) == 45) { expNeg := 1; i := i + 1; }
      else if (i < end && StrCharAt(src, i) == 43) { i := i + 1; }
      while (i < end && StrCharAt(src, i) >= 48 && StrCharAt(src, i) <= 57) {
        expVal := expVal * 10 + StrCharAt(src, i) - 48;
        i := i + 1;
      }
    }
    if (num == 0) { return 0; }
    var ej: int64 := 0;
    if (expNeg == 0) {
      while (ej < expVal && num < 100000000000000) { num := num * 10; ej := ej + 1; }
    } else {
      while (ej < expVal && den < 100000000000000) { den := den * 10; ej := ej + 1; }
    }
    // Normalize: find binary exponent so n/d ∈ [1, 2)
    var n: int64 := num;
    var d: int64 := den;
    var binExp: int64 := 0;
    while (n < d && n > 0) {
      if (n > 4611686018427387903) { d := d / 2; if (d == 0) { d := 1; } }
      else { n := n * 2; }
      binExp := binExp - 1;
      if (binExp < -1074) { return 0; }
    }
    while (d < 4611686018427387903 && n >= d * 2) {
      d := d * 2; binExp := binExp + 1;
      if (binExp > 1023) {
        var pInf: int64 := 2047; pInf := pInf << 52;
        if (neg != 0) {
          var smI: int64 := 1; var sI: int64 := 0;
          while (sI < 63) { smI := smI * 2; sI := sI + 1; }
          return pInf | smI;
        }
        return pInf;
      }
    }
    n := n - d;
    var mant: int64 := 0;
    var bit: int64 := 51;
    while (bit >= 0) {
      if (n > 4000000000000000) { n := n / 2; d := d / 2; if (d == 0) { d := 1; } }
      n := n * 2;
      if (n >= d) { mant := mant | (1 << bit); n := n - d; }
      bit := bit - 1;
    }
    var biasedE: int64 := binExp + 1023;
    if (biasedE <= 0) { return 0; }
    if (biasedE >= 2047) {
      var pInf2: int64 := 2047; pInf2 := pInf2 << 52;
      if (neg != 0) {
        var smJ: int64 := 1; var sJ: int64 := 0;
        while (sJ < 63) { smJ := smJ * 2; sJ := sJ + 1; }
        return pInf2 | smJ;
      }
      return pInf2;
    }
    var bits: int64 := (biasedE << 52) | mant;
    if (neg != 0) {
      var sm: int64 := 1; var sk: int64 := 0;
      while (sk < 63) { sm := sm * 2; sk := sk + 1; }
      bits := bits | sm;
    }
    return bits;
  }

  // call rel32  — placeholder; returns position of rel32 for patching
  fn cg_emitCall(): int64 {
    self.cg_e8(0xE8);
    var pos: int64 := self.codeLen;
    self.cg_e32(0);
    return pos;
  }

  // Emit function prologue: push rbp; mov rbp, rsp; sub rsp, imm32 (placeholder)
  // Returns: code position of the imm32 (for later patching with final frame size)
  fn cg_emitPrologue(): int64 {
    self.cg_e8(0x55);                          // push rbp
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xE5);  // mov rbp, rsp
    // sub rsp, imm32 (48 81 EC xx xx xx xx)
    self.cg_e8(0x48); self.cg_e8(0x81); self.cg_e8(0xEC);
    var patchPos: int64 := self.codeLen;
    self.cg_e32(0);
    return patchPos;
  }

  // Emit function epilogue: mov rsp, rbp; pop rbp; ret
  fn cg_emitEpilogue() {
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xEC);  // mov rsp, rbp
    self.cg_e8(0x5D);  // pop rbp
    self.cg_e8(0xC3);  // ret
  }

  // push rax
  fn cg_pushRax() { self.cg_e8(0x50); }
  // pop rax
  fn cg_popRax() { self.cg_e8(0x58); }
  // pop rbx
  fn cg_popRbx() { self.cg_e8(0x5B); }
  // pop rdi
  fn cg_popRdi() { self.cg_e8(0x5F); }
  // pop rsi
  fn cg_popRsi() { self.cg_e8(0x5E); }
  // pop rdx
  fn cg_popRdx() { self.cg_e8(0x5A); }
  // pop rcx
  fn cg_popRcx() { self.cg_e8(0x59); }

  // xor rax, rax  (zero rax)
  fn cg_zeroRax() {
    self.cg_e8(0x48); self.cg_e8(0x31); self.cg_e8(0xC0);
  }

  // neg rax
  fn cg_negRax() {
    self.cg_e8(0x48); self.cg_e8(0xF7); self.cg_e8(0xD8);
  }

  // not rax  (bitwise NOT)
  fn cg_notRax() {
    self.cg_e8(0x48); self.cg_e8(0xF7); self.cg_e8(0xD0);
  }

  // test rax, rax; setnz al; movzx rax, al  (convert any non-zero to 1)
  fn cg_boolRax() {
    self.cg_e8(0x48); self.cg_e8(0x85); self.cg_e8(0xC0);   // test rax, rax
    self.cg_e8(0x0F); self.cg_e8(0x95); self.cg_e8(0xC0);   // setnz al
    self.cg_e8(0x48); self.cg_e8(0x0F); self.cg_e8(0xB6); self.cg_e8(0xC0);  // movzx rax, al
  }

  // Emit binary operation: rax=right operand, rbx=left operand (from stack pop)
  // Result left in rax.
  fn cg_emitBinOp(op: int64) {
    if (op == CGT_PLUS) {
      // add rax, rbx  (48 01 D8)
      self.cg_e8(0x48); self.cg_e8(0x01); self.cg_e8(0xD8);
    } else if (op == CGT_MINUS) {
      // sub rbx, rax; mov rax, rbx  (left - right)
      self.cg_e8(0x48); self.cg_e8(0x29); self.cg_e8(0xC3);  // sub rbx, rax
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xD8);  // mov rax, rbx
    } else if (op == CGT_STAR) {
      // imul rax, rbx  (48 0F AF C3)
      self.cg_e8(0x48); self.cg_e8(0x0F); self.cg_e8(0xAF); self.cg_e8(0xC3);
    } else if (op == CGT_SLASH) {
      // idiv: rdx:rax / rbx → quotient in rax
      // mov rcx, rbx; xor rdx, rdx; mov rax, rbx... wait:
      // we have rax=right, rbx=left; want left/right
      // mov rcx, rax (save divisor); xor rdx,rdx; mov rax, rbx; idiv rcx
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC1);  // mov rcx, rax (divisor)
      self.cg_e8(0x48); self.cg_e8(0x31); self.cg_e8(0xD2);  // xor rdx, rdx
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xD8);  // mov rax, rbx (dividend)
      self.cg_e8(0x48); self.cg_e8(0xF7); self.cg_e8(0xF9);  // idiv rcx
    } else if (op == CGT_PERCENT) {
      // same as div but result = rdx (remainder)
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC1);  // mov rcx, rax
      self.cg_e8(0x48); self.cg_e8(0x31); self.cg_e8(0xD2);  // xor rdx, rdx
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xD8);  // mov rax, rbx
      self.cg_e8(0x48); self.cg_e8(0xF7); self.cg_e8(0xF9);  // idiv rcx
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xD0);  // mov rax, rdx
    } else if (op == CGT_SHL) {
      // shl rbx, cl  (48 D3 E3)  — rax=count → move to cl
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC1);  // mov rcx, rax
      self.cg_e8(0x48); self.cg_e8(0xD3); self.cg_e8(0xE3);  // shl rbx, cl
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xD8);  // mov rax, rbx
    } else if (op == CGT_SHR) {
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC1);  // mov rcx, rax
      self.cg_e8(0x48); self.cg_e8(0xD3); self.cg_e8(0xEB);  // sar rbx, cl (signed)
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xD8);  // mov rax, rbx
    } else if (op == CGT_EQ2) {
      // cmp rbx, rax; sete al; movzx rax, al
      self.cg_e8(0x48); self.cg_e8(0x39); self.cg_e8(0xC3);  // cmp rbx, rax
      self.cg_e8(0x0F); self.cg_e8(0x94); self.cg_e8(0xC0);  // sete al
      self.cg_e8(0x48); self.cg_e8(0x0F); self.cg_e8(0xB6); self.cg_e8(0xC0);
    } else if (op == CGT_NEQ) {
      self.cg_e8(0x48); self.cg_e8(0x39); self.cg_e8(0xC3);  // cmp rbx, rax
      self.cg_e8(0x0F); self.cg_e8(0x95); self.cg_e8(0xC0);  // setne al
      self.cg_e8(0x48); self.cg_e8(0x0F); self.cg_e8(0xB6); self.cg_e8(0xC0);
    } else if (op == CGT_LT) {
      self.cg_e8(0x48); self.cg_e8(0x39); self.cg_e8(0xC3);  // cmp rbx, rax
      self.cg_e8(0x0F); self.cg_e8(0x9C); self.cg_e8(0xC0);  // setl al (rbx < rax)
      self.cg_e8(0x48); self.cg_e8(0x0F); self.cg_e8(0xB6); self.cg_e8(0xC0);
    } else if (op == CGT_LE) {
      self.cg_e8(0x48); self.cg_e8(0x39); self.cg_e8(0xC3);
      self.cg_e8(0x0F); self.cg_e8(0x9E); self.cg_e8(0xC0);  // setle al
      self.cg_e8(0x48); self.cg_e8(0x0F); self.cg_e8(0xB6); self.cg_e8(0xC0);
    } else if (op == CGT_GT) {
      self.cg_e8(0x48); self.cg_e8(0x39); self.cg_e8(0xC3);
      self.cg_e8(0x0F); self.cg_e8(0x9F); self.cg_e8(0xC0);  // setg al
      self.cg_e8(0x48); self.cg_e8(0x0F); self.cg_e8(0xB6); self.cg_e8(0xC0);
    } else if (op == CGT_GE) {
      self.cg_e8(0x48); self.cg_e8(0x39); self.cg_e8(0xC3);
      self.cg_e8(0x0F); self.cg_e8(0x9D); self.cg_e8(0xC0);  // setge al
      self.cg_e8(0x48); self.cg_e8(0x0F); self.cg_e8(0xB6); self.cg_e8(0xC0);
    } else if (op == CGT_AND) {
      // logical and: both non-zero → 1
      // rax=right, rbx=left; test both
      self.cg_e8(0x48); self.cg_e8(0x85); self.cg_e8(0xC0);  // test rax, rax
      self.cg_e8(0x0F); self.cg_e8(0x95); self.cg_e8(0xC0);  // setnz al
      self.cg_e8(0x48); self.cg_e8(0x0F); self.cg_e8(0xB6); self.cg_e8(0xC0); // movzx rax,al
      self.cg_e8(0x48); self.cg_e8(0x85); self.cg_e8(0xDB);  // test rbx, rbx
      self.cg_e8(0x0F); self.cg_e8(0x95); self.cg_e8(0xC3);  // setnz bl
      self.cg_e8(0x48); self.cg_e8(0x0F); self.cg_e8(0xB6); self.cg_e8(0xDB); // movzx rbx,bl
      self.cg_e8(0x48); self.cg_e8(0x21); self.cg_e8(0xD8);  // and rax, rbx
    } else if (op == CGT_OR) {
      // logical or
      self.cg_e8(0x48); self.cg_e8(0x09); self.cg_e8(0xD8);  // or rax, rbx
      self.cg_boolRax();
    } else if (op == CGT_BITAND) {
      // bitwise and rax, rbx
      self.cg_e8(0x48); self.cg_e8(0x21); self.cg_e8(0xD8);
    } else if (op == CGT_BITOR) {
      // bitwise or rax, rbx
      self.cg_e8(0x48); self.cg_e8(0x09); self.cg_e8(0xD8);
    } else {
      // Unknown op: emit 0 (nop effect, rax=0)
      self.cg_zeroRax();
    }
  }

  // ------------------------------------------------------------------
  // ------------------------------------------------------------------
  // OOP support: class layout table and local type tracking
  // ------------------------------------------------------------------

  fn cg_setLocalType(idx: int64, typePtr: pchar, typeLen: int64) {
    var base: int64 := self.localTypes + idx * 16;
    poke64(base,     typePtr as int64);
    poke64(base + 8, typeLen);
  }

  fn cg_findClass(name: pchar, nameLen: int64): int64 {
    var i: int64 := 0;
    while (i < self.classCount) {
      var base: int64 := self.classLayouts + i * CG_CLASS_SZ;
      var p: pchar := peek64(base) as pchar;
      var n: int64 := peek64(base + 8);
      if (n == nameLen && self.cg_seq(p, n, name, nameLen)) { return i; }
      i := i + 1;
    }
    return -1;
  }

  fn cg_getFieldOffset(classIdx: int64, fieldName: pchar, fieldLen: int64): int64 {
    return self.cg_findField(classIdx, fieldName, fieldLen);
  }

  fn cg_findField(classIdx: int64, fieldName: pchar, fieldLen: int64): int64 {
    if (classIdx < 0) { return -1; }
    var base: int64 := self.classLayouts + classIdx * CG_CLASS_SZ;
    var flds: int64 := peek64(base + 16);
    var cnt:  int64 := peek64(base + 24);
    var i: int64 := 0;
    while (i < cnt) {
      var fb: int64 := flds + i * CG_CFIELD_SZ;
      var p: pchar   := peek64(fb) as pchar;
      var n: int64   := peek64(fb + 8);
      if (n == fieldLen && self.cg_seq(p, n, fieldName, fieldLen)) {
        return peek64(fb + 16);
      }
      i := i + 1;
    }
    return -1;
  }

  fn cg_buildClassLayout(ni: int64) {
    var className: pchar := self.cg_nsval(ni);
    var classLen:  int64 := self.cg_nslen(ni);
    // Count fields (child0 chain)
    var fieldNode: int64 := self.cg_nc0(ni);
    var cnt: int64 := 0;
    var tmp: int64 := fieldNode;
    while (tmp != -1) { cnt := cnt + 1; tmp := self.cg_nnext(tmp); }
    // Allocate field array
    var flds: int64 := mmap(0, (cnt + 1) * CG_CFIELD_SZ, 3, 34, -1, 0);
    // WP-10a: fields start at offset 8 (offset 0 reserved for VMT pointer)
    var offset: int64 := 8;
    var i: int64 := 0;
    tmp := fieldNode;
    while (tmp != -1) {
      var fb: int64 := flds + i * CG_CFIELD_SZ;
      poke64(fb,      self.cg_nsval(tmp) as int64);
      poke64(fb + 8,  self.cg_nslen(tmp));
      poke64(fb + 16, offset);
      offset := offset + 8;
      i := i + 1;
      tmp := self.cg_nnext(tmp);
    }
    // WP-10a: emit 8-byte VMT table placeholder in data section
    var vmtDataOff: int64 := self.dataLen;
    var di: int64 := 0;
    while (di < 8) { self.cg_edata(0); di := di + 1; }
    // Grow class table if needed
    if (self.classCount >= self.classCap) {
      var nc: int64 := self.classCap * 2;
      var nb: int64 := mmap(0, nc * CG_CLASS_SZ, 3, 34, -1, 0);
      var ii: int64 := 0;
      while (ii < self.classCount * CG_CLASS_SZ) {
        poke8(nb + ii, peek8(self.classLayouts + ii));
        ii := ii + 1;
      }
      self.classLayouts := nb;
      self.classCap := nc;
    }
    var base: int64 := self.classLayouts + self.classCount * CG_CLASS_SZ;
    poke64(base,      className as int64);
    poke64(base + 8,  classLen);
    poke64(base + 16, flds);
    poke64(base + 24, cnt);
    poke64(base + 32, vmtDataOff);   // WP-10a: offset of VMT table in data section
    self.classCount := self.classCount + 1;
    // Track temporary field array for later cleanup (BUG-02)
    // The flds pointer is stored in classLayouts and used by cg_findField/cg_getFieldOffset
    // until cg_patchAll() completes. cg_freeAllTempBufs() will release it.
    self.cg_trackTempBuf(flds, (cnt + 1) * CG_CFIELD_SZ);
  }

  // Build struct field layout (WP-10d): like cg_buildClassLayout but fields at offset 0
  // and vmtDataOff stored as -1 (marks this entry as a struct, not a class).
  fn cg_buildStructLayout(ni: int64) {
    var sName: pchar := self.cg_nsval(ni);
    var sLen:  int64 := self.cg_nslen(ni);
    var fieldNode: int64 := self.cg_nc0(ni);
    var cnt: int64 := 0;
    var tmp: int64 := fieldNode;
    while (tmp != -1) { cnt := cnt + 1; tmp := self.cg_nnext(tmp); }
    var flds: int64 := mmap(0, (cnt + 1) * CG_CFIELD_SZ, 3, 34, -1, 0);
    // Structs: fields start at offset 0 (no VMT slot)
    var offset: int64 := 0;
    var i: int64 := 0;
    tmp := fieldNode;
    while (tmp != -1) {
      var fb: int64 := flds + i * CG_CFIELD_SZ;
      poke64(fb,      self.cg_nsval(tmp) as int64);
      poke64(fb + 8,  self.cg_nslen(tmp));
      poke64(fb + 16, offset);
      offset := offset + 8;
      i := i + 1;
      tmp := self.cg_nnext(tmp);
    }
    if (self.classCount >= self.classCap) {
      var nc: int64 := self.classCap * 2;
      var nb: int64 := mmap(0, nc * CG_CLASS_SZ, 3, 34, -1, 0);
      var ii: int64 := 0;
      while (ii < self.classCount * CG_CLASS_SZ) {
        poke8(nb + ii, peek8(self.classLayouts + ii));
        ii := ii + 1;
      }
      self.classLayouts := nb;
      self.classCap := nc;
    }
    var base: int64 := self.classLayouts + self.classCount * CG_CLASS_SZ;
    poke64(base,      sName as int64);
    poke64(base + 8,  sLen);
    poke64(base + 16, flds);
    poke64(base + 24, cnt);
    poke64(base + 32, -1);   // vmtDataOff = -1 signals "struct, no VMT"
    self.classCount := self.classCount + 1;
    // Track temporary field array for later cleanup (BUG-02)
    self.cg_trackTempBuf(flds, (cnt + 1) * CG_CFIELD_SZ);
  }

  // BUG-08: Build enum variant layout for match tag analysis
  // Enum layout: {namePtr:8, nameLen:8, variantsPtr:8, variantCnt:8}
  // Each variant: {namePtr:8, nameLen:8, tagValue:8, payloadSize:8} = 32 bytes
  fn cg_buildEnumLayout(ni: int64) {
    var enumName: pchar := self.cg_nsval(ni);
    var enumLen:  int64 := self.cg_nslen(ni);
    // Count variants (child0 chain)
    var variantNode: int64 := self.cg_nc0(ni);
    var cnt: int64 := 0;
    var tmp: int64 := variantNode;
    while (tmp != -1) { cnt := cnt + 1; tmp := self.cg_nnext(tmp); }
    // Allocate variant array: 32 bytes per variant
    var vars: int64 := mmap(0, cnt * 32, 3, 34, -1, 0);
    var i: int64 := 0;
    tmp := variantNode;
    while (tmp != -1) {
      var vb: int64 := vars + i * 32;
      poke64(vb,      self.cg_nsval(tmp) as int64);   // variant name
      poke64(vb + 8,  self.cg_nslen(tmp));             // variant name len
      poke64(vb + 16, i);                              // tag value = index
      // Payload size: count children of variant (NK_PATTERN_BIND etc.)
      var payloadCnt: int64 := 0;
      var pc: int64 := self.cg_nc0(tmp);
      while (pc != -1) { payloadCnt := payloadCnt + 1; pc := self.cg_nnext(pc); }
      poke64(vb + 24, payloadCnt);
      i := i + 1;
      tmp := self.cg_nnext(tmp);
    }
    // Grow enum table if needed
    if (self.enumCount >= self.enumCap) {
      var nc: int64 := self.enumCap * 2;
      var nb: int64 := mmap(0, nc * 32, 3, 34, -1, 0);
      var ii: int64 := 0;
      while (ii < self.enumCount * 32) {
        poke8(nb + ii, peek8(self.enumLayouts + ii));
        ii := ii + 1;
      }
      munmap(self.enumLayouts, self.enumCap * 32);
      self.enumLayouts := nb;
      self.enumCap := nc;
    }
    var base: int64 := self.enumLayouts + self.enumCount * 32;
    poke64(base,      enumName as int64);
    poke64(base + 8,  enumLen);
    poke64(base + 16, vars);
    poke64(base + 24, cnt);
    self.enumCount := self.enumCount + 1;
  }

  // BUG-08: Find enum layout by name, return index or -1
  fn cg_findEnum(name: pchar, nlen: int64): int64 {
    var i: int64 := 0;
    while (i < self.enumCount) {
      var base: int64 := self.enumLayouts + i * 32;
      var p: pchar := peek64(base) as pchar;
      var n: int64 := peek64(base + 8);
      if (n == nlen && self.cg_seq(p, n, name, nlen)) { return i; }
      i := i + 1;
    }
    return -1;
  }

  // BUG-08: Find variant tag value within enum by variant name
  // Returns {tagValue: low 32 bits, payloadSize: high 32 bits} packed in int64
  fn cg_findEnumVariant(enumIdx: int64, varName: pchar, varLen: int64): int64 {
    if (enumIdx < 0) { return -1; }
    var ebase: int64 := self.enumLayouts + enumIdx * 32;
    var vars: int64 := peek64(ebase + 16);
    var vcnt: int64 := peek64(ebase + 24);
    var i: int64 := 0;
    while (i < vcnt) {
      var vb: int64 := vars + i * 32;
      var p: pchar := peek64(vb) as pchar;
      var n: int64 := peek64(vb + 8);
      if (n == varLen && self.cg_seq(p, n, varName, varLen)) {
        var tagVal: int64 := peek64(vb + 16);
        var paySz:  int64 := peek64(vb + 24);
        return tagVal + (paySz << 32);
      }
      i := i + 1;
    }
    return -1;
  }

  fn cg_getLocalClassIdx(varName: pchar, varLen: int64): int64 {
    var i: int64 := self.localCount - 1;
    while (i >= 0) {
      var base: int64 := self.locals + i * CG_LOCAL_SZ;
      var p: pchar  := peek64(base) as pchar;
      var n: int64  := peek64(base + 8);
      if (n == varLen && self.cg_seq(p, n, varName, varLen)) {
        var tb: int64 := self.localTypes + i * 16;
        var tp: pchar := peek64(tb) as pchar;
        var tn: int64 := peek64(tb + 8);
        if (tp == 0 as pchar || tn == 0) { return -1; }
        return self.cg_findClass(tp, tn);
      }
      i := i - 1;
    }
    return -1;
  }

  // WP-10a: record a VMT address patch (mov rcx,imm64 placeholder at codeOff for class)
  fn cg_addVmtPatch(codeOff: int64, className: pchar, classLen: int64) {
    if (self.vmtPatchCount >= self.vmtPatchCap) {
      var nc: int64 := self.vmtPatchCap * 2;
      var nb: int64 := mmap(0, nc * 24, 3, 34, -1, 0);
      var i: int64 := 0;
      while (i < self.vmtPatchCount * 24) { poke8(nb+i, peek8(self.vmtPatches+i)); i:=i+1; }
      self.vmtPatches := nb; self.vmtPatchCap := nc;
    }
    var base: int64 := self.vmtPatches + self.vmtPatchCount * 24;
    poke64(base,      codeOff);
    poke64(base + 8,  className as int64);
    poke64(base + 16, classLen);
    self.vmtPatchCount := self.vmtPatchCount + 1;
  }

  // Helper: get class index for object node (IDENT)
  fn cg_objClassIdx(objNode: int64): int64 {
    if (self.cg_nkind(objNode) != CGN_IDENT) { return -1; }
    var oname: pchar := self.cg_nsval(objNode);
    var olen:  int64 := self.cg_nslen(objNode);
    if (self.cg_seq(oname, olen, "self", 4) != 0) {
      if (self.curClassName == 0 as pchar) { return -1; }
      return self.cg_findClass(self.curClassName, self.curClassNameLen);
    }
    return self.cg_getLocalClassIdx(oname, olen);
  }

  // Inline code for arr.push(val): alloc on first use, then append
  // Layout: [ptr+0]=cap, [ptr+8]=len, [ptr+16+i*8]=data[i]
  fn cg_genArrayPush(objNode: int64, valNode: int64) {
    var aname: pchar := self.cg_nsval(objNode);
    var anlen: int64 := self.cg_nslen(objNode);
    var off: int64 := self.cg_findLocal(aname, anlen);
    // Evaluate value → rax
    self.cg_genExpr(valNode);
    // push rax (save value)
    self.cg_e8(0x50);
    // mov rcx, [rbp+off]  (load array ptr)
    if (off >= -128 && off <= 127) {
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x4D); self.cg_e8(off);
    } else {
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x8D); self.cg_e32(off);
    }
    // test rcx, rcx
    self.cg_e8(0x48); self.cg_e8(0x85); self.cg_e8(0xC9);
    // jnz skip_alloc (rel32 placeholder)
    self.cg_e8(0x0F); self.cg_e8(0x85);
    var jnzPos: int64 := self.codeLen;
    self.cg_e32(0);
    // ---- mmap block: allocate (1026)*8 bytes ----
    // xor edi, edi          (rdi=0, addr=0)
    self.cg_e8(0x31); self.cg_e8(0xFF);
    // mov rsi, 8208         ((1024+2)*8)
    self.cg_e8(0x48); self.cg_e8(0xC7); self.cg_e8(0xC6);
    self.cg_e8(0x10); self.cg_e8(0x20); self.cg_e8(0x00); self.cg_e8(0x00);
    // mov edx, 3            (PROT_RW)
    self.cg_e8(0xBA); self.cg_e8(0x03); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00);
    // mov eax, 34           (MAP_ANON|MAP_PRIVATE)
    self.cg_e8(0xB8); self.cg_e8(0x22); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00);
    // mov r10, rax          (REX.B extends rm to r10: 49 89 C2)
    self.cg_e8(0x49); self.cg_e8(0x89); self.cg_e8(0xC2);
    // mov rax, -1           (fd=-1)
    self.cg_e8(0x48); self.cg_e8(0xC7); self.cg_e8(0xC0);
    self.cg_e8(0xFF); self.cg_e8(0xFF); self.cg_e8(0xFF); self.cg_e8(0xFF);
    // mov r8, rax
    self.cg_e8(0x49); self.cg_e8(0x89); self.cg_e8(0xC0);
    // xor r9d, r9d          (offset=0)
    self.cg_e8(0x45); self.cg_e8(0x31); self.cg_e8(0xC9);
    // mov eax, 9            (SYS_mmap)
    self.cg_e8(0xB8); self.cg_e8(0x09); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00);
    // syscall
    self.cg_e8(0x0F); self.cg_e8(0x05);
    // mov rcx, 1024         (cap)
    self.cg_e8(0x48); self.cg_e8(0xC7); self.cg_e8(0xC1);
    self.cg_e8(0x00); self.cg_e8(0x04); self.cg_e8(0x00); self.cg_e8(0x00);
    // mov [rax], rcx        ([ptr+0] = cap)
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x08);
    // xor rcx, rcx
    self.cg_e8(0x48); self.cg_e8(0x31); self.cg_e8(0xC9);
    // mov [rax+8], rcx      ([ptr+8] = len=0)
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x48); self.cg_e8(0x08);
    // store rax back to local variable
    self.cg_storeRax(off);
    // mov rcx, rax
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC1);
    // ---- end mmap block ----
    // Patch jnz to here (skip_alloc)
    poke32(self.code + jnzPos, self.codeLen - jnzPos - 4);
    // pop rax               (restore value)
    self.cg_e8(0x58);
    // mov rdx, [rcx+8]      (rdx = len)
    self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x51); self.cg_e8(0x08);
    // lea rsi, [rcx+16]     (rsi = data start)
    self.cg_e8(0x48); self.cg_e8(0x8D); self.cg_e8(0x71); self.cg_e8(0x10);
    // mov [rsi+rdx*8], rax  (data[len] = value)
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x04); self.cg_e8(0xD6);
    // inc rdx
    self.cg_e8(0x48); self.cg_e8(0xFF); self.cg_e8(0xC2);
    // mov [rcx+8], rdx      ([ptr+8] = len+1)
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x51); self.cg_e8(0x08);
    // xor rax, rax          (return 0)
    self.cg_e8(0x48); self.cg_e8(0x31); self.cg_e8(0xC0);
  }

  // Inline code for arr.pop(): decrement len, return last element (0 if empty)
  fn cg_genArrayPop(objNode: int64) {
    var aname: pchar := self.cg_nsval(objNode);
    var anlen: int64 := self.cg_nslen(objNode);
    var off: int64 := self.cg_findLocal(aname, anlen);
    // Load array ptr into rcx
    if (off >= -128 && off <= 127) {
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x4D); self.cg_e8(off);
    } else {
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x8D); self.cg_e32(off);
    }
    // test rcx, rcx; jz empty
    self.cg_e8(0x48); self.cg_e8(0x85); self.cg_e8(0xC9);
    self.cg_e8(0x0F); self.cg_e8(0x84);
    var jz1Pos: int64 := self.codeLen;
    self.cg_e32(0);
    // rdx = [rcx+8]  (len)
    self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x51); self.cg_e8(0x08);
    // test rdx, rdx; jz empty
    self.cg_e8(0x48); self.cg_e8(0x85); self.cg_e8(0xD2);
    self.cg_e8(0x0F); self.cg_e8(0x84);
    var jz2Pos: int64 := self.codeLen;
    self.cg_e32(0);
    // dec rdx
    self.cg_e8(0x48); self.cg_e8(0xFF); self.cg_e8(0xCA);
    // [rcx+8] = rdx  (new len)
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x51); self.cg_e8(0x08);
    // lea rsi, [rcx+16]
    self.cg_e8(0x48); self.cg_e8(0x8D); self.cg_e8(0x71); self.cg_e8(0x10);
    // rax = [rsi+rdx*8]
    self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x04); self.cg_e8(0xD6);
    // jmp done
    self.cg_e8(0xE9);
    var jmpPos: int64 := self.codeLen;
    self.cg_e32(0);
    // empty: patch jz targets here
    poke32(self.code + jz1Pos, self.codeLen - jz1Pos - 4);
    poke32(self.code + jz2Pos, self.codeLen - jz2Pos - 4);
    // xor rax, rax
    self.cg_e8(0x48); self.cg_e8(0x31); self.cg_e8(0xC0);
    // done:
    poke32(self.code + jmpPos, self.codeLen - jmpPos - 4);
  }

  // Generate a field load: evaluates object into rax, then loads field
  fn cg_genFieldLoad(ni: int64) {
    var obj: int64 := self.cg_nc0(ni);
    var fieldName: pchar := self.cg_nsval(ni);
    var fieldLen:  int64 := self.cg_nslen(ni);
    self.cg_genExpr(obj);
    // Array .length: rax = ptr, load [rax+8] = len
    if (self.cg_identIsArray(obj) != 0) {
      var lenStr: pchar := "length";
      if (self.cg_seq(fieldName, fieldLen, lenStr, 6)) {
        // mov rax, [rax+8]
        self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x40); self.cg_e8(0x08);
      } else {
        self.cg_zeroRax();
      }
      return;
    }
    var classIdx: int64 := self.cg_objClassIdx(obj);
    var foff: int64 := -1;
    if (classIdx >= 0) { foff := self.cg_getFieldOffset(classIdx, fieldName, fieldLen); }
    if (foff < 0) {
      self.cg_zeroRax();
    } else if (foff == 0) {
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x00);
    } else if (foff <= 127) {
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x40); self.cg_e8(foff);
    } else {
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x80); self.cg_e32(foff);
    }
  }

  // Generate a method declaration (with implicit self as first param)
  fn cg_genMethodDecl(ni: int64, className: pchar, classNameLen: int64) {
    var mname: pchar := self.cg_nsval(ni);
    var mlen:  int64 := self.cg_nslen(ni);
    // Build mangled name: className_methodName
    var mangLen: int64 := classNameLen + 1 + mlen;
    var mangBuf: int64 := mmap(0, mangLen + 1, 3, 34, -1, 0);
    var ii: int64 := 0;
    while (ii < classNameLen) { poke8(mangBuf + ii, StrCharAt(className, ii)); ii := ii + 1; }
    poke8(mangBuf + classNameLen, 95);
    var jj: int64 := 0;
    while (jj < mlen) { poke8(mangBuf + classNameLen + 1 + jj, StrCharAt(mname, jj)); jj := jj + 1; }
    poke8(mangBuf + mangLen, 0);
    // Register label with mangled name
    self.cg_addLabel(mangBuf as pchar, mangLen);
    // Track mangled name buffer for cleanup after patching (BUG-02)
    self.cg_trackTempBuf(mangBuf, mangLen + 1);
    // Reset locals
    self.localCount := 0;
    self.frameSize  := 0;
    // Set class context for self.field access
    self.curClassName    := className;
    self.curClassNameLen := classNameLen;
    // Emit prologue
    var prologuePatch: int64 := self.cg_emitPrologue();
    // Implicit self parameter at register 0 (rdi)
    var selfOff: int64 := self.cg_addLocal("self", 4);
    self.cg_setLocalType(self.localCount - 1, className, classNameLen);
    self.cg_spillRdi(selfOff);
    // Regular params start at register index 1
    var param: int64 := self.cg_nc0(ni);
    var paramIdx: int64 := 1;
    while (param != -1 && paramIdx < 6) {
      var pname: pchar := self.cg_nsval(param);
      var pnlen: int64 := self.cg_nslen(param);
      var poff: int64 := self.cg_addLocal(pname, pnlen);
      // Track param type if it's a user type (NK_TYPE_NAME = 60)
      var ptypeNode: int64 := self.cg_nc0(param);
      if (ptypeNode >= 0 && self.cg_nkind(ptypeNode) == 60) {
        self.cg_setLocalType(self.localCount - 1, self.cg_nsval(ptypeNode), self.cg_nslen(ptypeNode));
      }
      if (paramIdx == 1) { self.cg_spillRsi(poff); }
      else if (paramIdx == 2) { self.cg_spillRdx(poff); }
      else if (paramIdx == 3) { self.cg_spillRcx(poff); }
      else if (paramIdx == 4) { self.cg_spillR8(poff); }
      else if (paramIdx == 5) { self.cg_spillR9(poff); }
      paramIdx := paramIdx + 1;
      param := self.cg_nnext(param);
    }
    // Generate body
    var body: int64 := self.cg_nc2(ni);
    self.cg_genBlock(body);
    // Implicit return
    self.cg_zeroRax();
    self.cg_emitEpilogue();
    // Patch frame size
    var fs: int64 := self.frameSize + 15;
    var aligned: int64 := fs - (fs & 15);
    if (aligned == 0) { aligned := 16; }
    poke32(self.code + prologuePatch, aligned);
    // Clear class context
    self.curClassName    := 0 as pchar;
    self.curClassNameLen := 0;
  }

  // ------------------------------------------------------------------
  // Expression code generation — result always in RAX
  // ------------------------------------------------------------------

  fn cg_genExpr(ni: int64) {
    if (ni < 0) { self.cg_zeroRax(); return; }
    var k: int64 := self.cg_nkind(ni);

    if (k == CGN_LIT_INT) {
      self.cg_movRaxImm(self.cg_nival(ni));

    } else if (k == CGN_LIT_BOOL) {
      self.cg_movRaxImm(self.cg_nival(ni));

    } else if (k == CGN_LIT_CHAR) {
      self.cg_movRaxImm(self.cg_nival(ni));

    } else if (k == CGN_LIT_NULL) {
      self.cg_zeroRax();

    // WP-17: Range expression (1..100) - returns start value in rax
    } else if (k == CGN_RANGE) {
      // c0 = start, c1 = end
      // Generate: push start onto stack, then evaluate end, then pop start back
      // Result: rax = start value (end is stored but needs to be handled by caller)
      self.cg_genExpr(self.cg_nc0(ni));
      self.cg_pushRax();
      self.cg_genExpr(self.cg_nc1(ni));
      // Now rax = end, stack has start
      // For range iteration, we store end in a local for the loop
      // The caller (for loop) will handle iteration
      
    // WP-17: Where clause - just evaluate base type, constraint is compile-time only
    } else if (k == CGN_WHERE) {
      self.cg_genExpr(self.cg_nc0(ni));

    } else if (k == CGN_LIT_STR) {
      var sOff: int64 := self.cg_nsoff(ni);
      var sLen: int64 := self.cg_nslen(ni);
      var dataOff: int64 := self.cg_addStr(sOff, sLen);
      var patchPos: int64 := self.cg_emitLeaStr();
      self.cg_addPatch(patchPos, dataOff, 0, CG_PATCH_STR);

    } else if (k == CGN_IDENT) {
      var name: pchar := self.cg_nsval(ni);
      var nlen: int64 := self.cg_nslen(ni);
      var off: int64 := self.cg_findLocal(name, nlen);
      if (off != 0) {
        self.cg_loadRax(off);
      } else {
        // WP-13: Check if this is a captured variable from outer scope
        // If we have a static link, check if variable is captured via outer frame
        if (self.staticLinkOffset >= 0) {
          var capturedOff: int64 := self.cg_findCapturedVar(name, nlen);
          if (capturedOff != 0) {
            // Load static link into rbx, then access captured var via [rbx+offset]
            self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x5D); self.cg_e8(0x10); // mov rbx, [rbp+16]
            // mov rax, [rbx+capturedOff]
            if (capturedOff >= -128 && capturedOff <= 127) {
              self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x44); self.cg_e8(0x1B); self.cg_e8(capturedOff);
            } else {
              self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x84); self.cg_e8(0x1B);
              self.cg_e32(capturedOff);
            }
          } else {
            // Not local and not captured - check for constant
            var conVal: int64 := self.cg_findConVal(name, nlen);
            if (conVal != -1) {
              self.cg_movRaxImm(conVal);
            } else {
              self.cg_zeroRax();
            }
          }
        } else {
          var conVal: int64 := self.cg_findConVal(name, nlen);
          if (conVal != -1) {
            self.cg_movRaxImm(conVal);
          } else {
            self.cg_zeroRax();
          }
        }
      }

    } else if (k == CGN_BINOP) {
      var op: int64 := self.cg_nival(ni);
      var lhsNi: int64 := self.cg_nc0(ni);
      var rhsNi: int64 := self.cg_nc1(ni);
      // WP-10g: Constant Folding — both sides constant → single immediate
      if (self.cg_tryFold(ni) != 0) {
        self.cg_movRaxImm(self.foldBuf);
      } else if (op != CGT_AND && op != CGT_OR && self.cg_tryFold(lhsNi) != 0) {
        // CSE: LHS is constant → load into rbx directly (no push/pop)
        var lhsVal: int64 := self.foldBuf;
        self.cg_movRbxImm(lhsVal);
        self.cg_genExpr(rhsNi);
        self.cg_emitBinOp(op);
      } else if (op != CGT_AND && op != CGT_OR && self.cg_tryFold(rhsNi) != 0) {
        // CSE: RHS is constant → eval LHS into rax, mov rbx,rax, load const (no push/pop)
        var rhsVal: int64 := self.foldBuf;
        self.cg_genExpr(lhsNi);
        self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC3);  // mov rbx, rax
        self.cg_movRaxImm(rhsVal);
        self.cg_emitBinOp(op);
      } else {
        // General: eval LHS, push; eval RHS; pop rbx
        self.cg_genExpr(lhsNi);
        self.cg_pushRax();
        self.cg_genExpr(rhsNi);
        self.cg_popRbx();
        self.cg_emitBinOp(op);
      }

    } else if (k == CGN_UNOP) {
      var op: int64 := self.cg_nival(ni);
      // WP-10g: fold constant unary expressions
      if (self.cg_tryFold(ni) != 0) {
        self.cg_movRaxImm(self.foldBuf);
      } else {
      self.cg_genExpr(self.cg_nc0(ni));
      if (op == CGT_MINUS) {
        self.cg_negRax();
      } else if (op == CGT_NOT) {
        // logical not: rax = (rax == 0) ? 1 : 0
        self.cg_e8(0x48); self.cg_e8(0x85); self.cg_e8(0xC0);  // test rax, rax
        self.cg_e8(0x0F); self.cg_e8(0x94); self.cg_e8(0xC0);  // sete al
        self.cg_e8(0x48); self.cg_e8(0x0F); self.cg_e8(0xB6); self.cg_e8(0xC0);
      } else if (op == CGT_BITNOT) {
        self.cg_notRax();
      }
      }  // end else (not const-foldable)

    } else if (k == CGN_CALL) {
      self.cg_genCall(ni);

    } else if (k == CGN_NEW) {
      // new T() — allocate class instance via mmap(0, 4096, 3, 34, -1, 0)
      self.cg_movRaxImm(0);    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC7); // mov rdi,rax
      self.cg_movRaxImm(4096); self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC6); // mov rsi,rax
      self.cg_movRaxImm(3);    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC2); // mov rdx,rax
      self.cg_movRaxImm(34);
      self.cg_e8(0x49); self.cg_e8(0x89); self.cg_e8(0xC2);  // mov r10, rax
      self.cg_movRaxImm(-1);
      self.cg_e8(0x4D); self.cg_e8(0x31); self.cg_e8(0xC0);  // xor r8, r8
      self.cg_e8(0x49); self.cg_e8(0xFF); self.cg_e8(0xC8);  // dec r8 → r8=-1
      self.cg_e8(0x4D); self.cg_e8(0x31); self.cg_e8(0xC9);  // xor r9, r9
      self.cg_movRaxImm(9);
      self.cg_e8(0x0F); self.cg_e8(0x05);
      // WP-10d: check if type is a struct (vmtDataOff == -1) → skip VMT setup
      var tname: pchar := self.cg_nsval(ni);
      var tlen:  int64 := self.cg_nslen(ni);
      var ciNew: int64 := self.cg_findClass(tname, tlen);
      var isStructNew: int64 := 0;
      if (ciNew >= 0) {
        var vmtChk: int64 := peek64(self.classLayouts + ciNew * CG_CLASS_SZ + 32);
        if (vmtChk == -1) { isStructNew := 1; }
      }
      if (isStructNew == 0) {
        // WP-10a: rax = object ptr; write VMT pointer at [rax+0]
        // mov rcx, imm64 (placeholder = 0, patched later with VMT vaddr)
        self.cg_e8(0x48); self.cg_e8(0xB9);
        var vmtPatchPos: int64 := self.codeLen;
        self.cg_e64(0);                                         // 8-byte placeholder
        self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x08); // mov [rax], rcx
        // Record patch: fill in VMT address for this class at vmtPatchPos
        self.cg_addVmtPatch(vmtPatchPos, tname, tlen);
      }

    } else if (k == CGN_FIELD) {
      self.cg_genFieldLoad(ni);

    } else if (k == CGN_INDEX) {
      // arr[i]: nc0=arr, nc1=index
      // Eval index first, push; then eval arr; pop index into rbx
      self.cg_genExpr(self.cg_nc1(ni));   // rax = index
      self.cg_pushRax();
      self.cg_genExpr(self.cg_nc0(ni));   // rax = array ptr
      self.cg_popRbx();                    // rbx = index
      // lea rcx, [rax+16]   (data start)
      self.cg_e8(0x48); self.cg_e8(0x8D); self.cg_e8(0x48); self.cg_e8(0x10);
      // mov rax, [rcx+rbx*8]
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x04); self.cg_e8(0xD9);

    } else if (k == CGN_LIT_FLOAT) {
      // WP-11: float literal — parse IEEE 754 bits and load as immediate
      var floatBits: int64 := self.cg_parseFloat(self.pSrc, self.cg_nsoff(ni), self.cg_nslen(ni));
      self.cg_movRaxImm(floatBits);

    } else if (k == CGN_CAST) {
      // WP-11: x as Type — evaluate source, then apply integer truncation/extension
      self.cg_genExpr(self.cg_nc0(ni));
      var typeNode: int64 := self.cg_nc1(ni);
      if (typeNode >= 0) {
        var tname: pchar := self.cg_nsval(typeNode);
        var tlen: int64 := self.cg_nslen(typeNode);
        if (self.cg_seq(tname, tlen, "i8", 2)) {
          // movsx rax, al  — sign-extend byte to qword
          self.cg_e8(0x48); self.cg_e8(0x0F); self.cg_e8(0xBE); self.cg_e8(0xC0);
        } else if (self.cg_seq(tname, tlen, "u8", 2)) {
          // movzx rax, al  — zero-extend byte to qword
          self.cg_e8(0x48); self.cg_e8(0x0F); self.cg_e8(0xB6); self.cg_e8(0xC0);
        } else if (self.cg_seq(tname, tlen, "i16", 3)) {
          // movsx rax, ax  — sign-extend word to qword
          self.cg_e8(0x48); self.cg_e8(0x0F); self.cg_e8(0xBF); self.cg_e8(0xC0);
        } else if (self.cg_seq(tname, tlen, "u16", 3)) {
          // movzx rax, ax  — zero-extend word to qword
          self.cg_e8(0x48); self.cg_e8(0x0F); self.cg_e8(0xB7); self.cg_e8(0xC0);
        } else if (self.cg_seq(tname, tlen, "i32", 3)) {
          // movsxd rax, eax  — sign-extend dword to qword
          self.cg_e8(0x48); self.cg_e8(0x63); self.cg_e8(0xC0);
        } else if (self.cg_seq(tname, tlen, "u32", 3)) {
          // mov eax, eax  — zero-extends to rax automatically on x86-64
          self.cg_e8(0x89); self.cg_e8(0xC0);
        }
        // i64, u64, pchar, bool, char, f32, f64: no-op (already 64-bit in rax)
      }

    } else if (k == CGN_IS_EXPR) {
      // BUG-08 supplement: x is Type — runtime type check via VMT
      // c0 = object expression, c1 = type node
      self.cg_genExpr(self.cg_nc0(ni));
      var typeNode: int64 := self.cg_nc1(ni);
      if (typeNode >= 0) {
        var tname: pchar := self.cg_nsval(typeNode);
        var tlen: int64 := self.cg_nslen(typeNode);
        var classIdx: int64 := self.cg_findClass(tname, tlen);
        if (classIdx >= 0) {
          // Load VMT pointer from object: mov rcx, [rax]
          self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x08);
          // Load expected VMT address
          var vmtOff: int64 := peek64(self.classLayouts + classIdx * CG_CLASS_SZ + 32);
          var expectedVmt: int64 := CG_ELF_BASE + CG_CODE_OFF + self.codeLen + 20 + vmtOff;
          // mov rdx, imm64 (expected VMT)
          self.cg_e8(0x48); self.cg_e8(0xBA);
          self.cg_e64(expectedVmt);
          // cmp rcx, rdx; sete al; movzx rax, al
          self.cg_e8(0x48); self.cg_e8(0x39); self.cg_e8(0xD1);
          self.cg_e8(0x0F); self.cg_e8(0x94); self.cg_e8(0xC0);
          self.cg_e8(0x0F); self.cg_e8(0xB6); self.cg_e8(0xC0);
        } else {
          self.cg_zeroRax();
        }
      } else {
        self.cg_zeroRax();
      }

    } else if (k == CGN_CLOSURE) {
      // WP-13: closure expression — allocate closure struct {fnPtr:8, envPtr:8}
      // c0 = function reference, c1 = captured vars list
      var fnNode: int64 := self.cg_nc0(ni);
      // Allocate closure on stack (16 bytes)
      var closureOff: int64 := self.cg_addLocal("__closure__", 10);
      // Store function pointer
      if (fnNode >= 0 && self.cg_nkind(fnNode) == CGN_IDENT) {
        var fnName: pchar := self.cg_nsval(fnNode);
        var fnLen: int64 := self.cg_nslen(fnNode);
        // lea rax, [rip + fnName] — use label reference
        self.cg_e8(0x48); self.cg_e8(0x8D); self.cg_e8(0x05);
        var fnPatch: int64 := self.codeLen;
        self.cg_e32(0);
        self.cg_addPatch(fnPatch, fnName as int64, fnLen, CG_PATCH_CALL);
        self.cg_storeRax(closureOff);
      } else {
        self.cg_zeroRax();
        self.cg_storeRax(closureOff);
      }
      // Store environment pointer (static link or null)
      if (self.staticLinkOffset >= 0) {
        self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x45); self.cg_e8(0x10);
        self.cg_pushRax();
        self.cg_loadRax(closureOff);
        // mov [rax+8], rbx (env ptr)
        self.cg_popRbx();
        self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x58); self.cg_e8(0x08);
      }
      // Return closure pointer
      self.cg_loadRax(closureOff);

    } else {
      // Unknown expression: emit 0
      self.cg_zeroRax();
    }
  }

  // Generate a function call (NK_CALL node)
  fn cg_genCall(ni: int64) {
    var fname: pchar := self.cg_nsval(ni);
    var fnlen: int64 := self.cg_nslen(ni);
    var isMethod: int64 := self.cg_nival(ni);

    // Count args
    var argNode: int64 := self.cg_nc0(ni);
    if (isMethod == 1) { argNode := self.cg_nc1(ni); }

    // Intercept array built-in methods before arg evaluation (WP-10b)
    if (isMethod == 1) {
      var arrObj: int64 := self.cg_nc0(ni);
      if (self.cg_identIsArray(arrObj) != 0) {
        var pushStr: pchar := "push";
        var popStr:  pchar := "pop";
        if (self.cg_seq(fname, fnlen, pushStr, 4)) {
          self.cg_genArrayPush(arrObj, argNode);
          return;
        } else if (self.cg_seq(fname, fnlen, popStr, 3)) {
          self.cg_genArrayPop(arrObj);
          return;
        }
      }
    }

    var argc: int64 := 0;
    var cur: int64 := argNode;
    while (cur != -1) { argc := argc + 1; cur := self.cg_nnext(cur); }

    // For method calls: push self (object) as first arg
    if (isMethod == 1) {
      self.cg_genExpr(self.cg_nc0(ni));
      self.cg_pushRax();
      argc := argc + 1;
    }

    // Evaluate each arg and push
    cur := argNode;
    while (cur != -1) {
      self.cg_genExpr(cur);
      self.cg_pushRax();
      cur := self.cg_nnext(cur);
    }

    // Pop args into registers
    if (argc >= 6) { self.cg_e8(0x41); self.cg_e8(0x59); }  // pop r9  (arg5)
    if (argc >= 5) { self.cg_e8(0x41); self.cg_e8(0x58); }  // pop r8  (arg4)
    if (argc >= 4) { self.cg_popRcx(); }                      // pop rcx (arg3)
    if (argc >= 3) { self.cg_popRdx(); }                      // pop rdx (arg2)
    if (argc >= 2) { self.cg_popRsi(); }                      // pop rsi (arg1)
    if (argc >= 1) { self.cg_popRdi(); }                      // pop rdi (arg0)
    
    // WP-13: For nested function calls, pass static link (rbp+16 from outer frame)
    // Check if this is a nested function by checking staticLinkOffset >= 0
    if (self.staticLinkOffset >= 0) {
      // Push static link as hidden first argument
      // mov rax, [rbp+16]  (load static link from outer frame)
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x45); self.cg_e8(0x10);
      self.cg_pushRax();
      // Adjust: pop into r10 (8th arg) or push before other args
      // For simplicity, we pass static link in r10 (sysv abi: r10 for special args)
      self.cg_popRax();
      self.cg_e8(0x49); self.cg_e8(0x89); self.cg_e8(0xC2);  // mov r10, rax
    }

    // For method calls: mangle name and emit call
    if (isMethod == 1) {
      var objNode: int64 := self.cg_nc0(ni);
      var classIdx: int64 := self.cg_objClassIdx(objNode);
      if (classIdx >= 0) {
        var clsBase: int64 := self.classLayouts + classIdx * CG_CLASS_SZ;
        var clsName: pchar := peek64(clsBase) as pchar;
        var clsLen:  int64 := peek64(clsBase + 8);
        var mangLen: int64 := clsLen + 1 + fnlen;
        var mangBuf: int64 := mmap(0, mangLen + 1, 3, 34, -1, 0);
        var mi: int64 := 0;
        while (mi < clsLen) { poke8(mangBuf + mi, StrCharAt(clsName, mi)); mi := mi + 1; }
        poke8(mangBuf + clsLen, 95);
        var mj: int64 := 0;
        while (mj < fnlen) { poke8(mangBuf + clsLen + 1 + mj, StrCharAt(fname, mj)); mj := mj + 1; }
        poke8(mangBuf + mangLen, 0);
        var pp: int64 := self.cg_emitCall();
        self.cg_addPatch(pp, mangBuf, mangLen, CG_PATCH_CALL);
        // Track mangled method name buffer for cleanup after patching (BUG-02)
        self.cg_trackTempBuf(mangBuf, mangLen + 1);
      } else {
        var pp: int64 := self.cg_emitCall();
        self.cg_addPatch(pp, fname as int64, fnlen, CG_PATCH_CALL);
      }
      return;
    }

    // Check for builtin functions
    var pstr: pchar := "PrintStr";
    var pint: pchar := "PrintInt";
    var slen: pchar := "StrLen";
    var mmapn: pchar := "mmap";
    var pk8: pchar := "poke8";
    var pk64: pchar := "poke64";
    var gk8: pchar := "peek8";
    var gk64: pchar := "peek64";
    var pk32: pchar := "poke32";
    var gk32: pchar := "peek32";

    if (self.cg_seq(fname, fnlen, pstr, 8)) {
      // call _lyx_print_str  (rdi already has the arg)
      // rel32 = target_offset - call_offset - 4 = CG_H_XXX - pp
      var pp: int64 := self.cg_emitCall();
      var rel32: int64 := CG_H_PRINTSTR - pp;
      poke32(self.code + pp, rel32);

    } else if (self.cg_seq(fname, fnlen, pint, 8)) {
      var pp: int64 := self.cg_emitCall();
      var rel32: int64 := CG_H_PRINTINT - pp;
      poke32(self.code + pp, rel32);

    } else if (self.cg_seq(fname, fnlen, slen, 6)) {
      var pp: int64 := self.cg_emitCall();
      var rel32: int64 := CG_H_STRLEN - pp;
      poke32(self.code + pp, rel32);

    } else if (self.cg_seq(fname, fnlen, "StrSub", 6)) {
      // StrSub(s: pchar, start: int64, len: int64): pchar
      // rdi=s, rsi=start, rdx=len
      // Call _lyx_strsub helper
      var pp: int64 := self.cg_emitCall();
      var rel32: int64 := CG_H_STRSUB - pp;
      poke32(self.code + pp, rel32);

    } else if (self.cg_seq(fname, fnlen, "StrCharAt", 9)) {
      // StrCharAt(s: pchar, i: int64): int64  -- s in rdi, i in rsi
      // Call _lyx_strcharat helper
      var pp: int64 := self.cg_emitCall();
      var rel32: int64 := CG_H_STRCHARAT - pp;
      poke32(self.code + pp, rel32);

    } else if (self.cg_seq(fname, fnlen, mmapn, 4)) {
      // mmap(addr,len,prot,flags,fd,offset): Linux syscall 9
      // After generic pop: rdi=addr, rsi=len, rdx=prot, rcx=flags, r8=fd, r9=offset
      // Linux mmap syscall needs r10=flags (not rcx)
      self.cg_e8(0x49); self.cg_e8(0x89); self.cg_e8(0xCA);  // mov r10, rcx
      self.cg_movRaxImm(9);
      self.cg_e8(0x0F); self.cg_e8(0x05);

    } else if (self.cg_seq(fname, fnlen, pk8, 5)) {
      // poke8(addr, val): mov [rdi], sil
      self.cg_e8(0x40); self.cg_e8(0x88); self.cg_e8(0x37);  // mov [rdi], sil
      self.cg_zeroRax();

    } else if (self.cg_seq(fname, fnlen, gk8, 5)) {
      // peek8(addr): movzx rax, byte [rdi]
      self.cg_e8(0x48); self.cg_e8(0x0F); self.cg_e8(0xB6); self.cg_e8(0x07);

    } else if (self.cg_seq(fname, fnlen, pk64, 6)) {
      // poke64(addr, val): mov [rdi], rsi
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x37);
      self.cg_zeroRax();

    } else if (self.cg_seq(fname, fnlen, gk64, 6)) {
      // peek64(addr): mov rax, [rdi]
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x07);

    } else if (self.cg_seq(fname, fnlen, "poke16", 6)) {
      // poke16(addr, val): mov word [rdi], si  (66 89 37)
      self.cg_e8(0x66); self.cg_e8(0x89); self.cg_e8(0x37);
      self.cg_zeroRax();

    } else if (self.cg_seq(fname, fnlen, pk32, 6)) {
      // poke32(addr, val): mov dword [rdi], esi
      self.cg_e8(0x89); self.cg_e8(0x37);
      self.cg_zeroRax();

    } else if (self.cg_seq(fname, fnlen, gk32, 6)) {
      // peek32(addr): movsxd rax, dword [rdi]
      self.cg_e8(0x48); self.cg_e8(0x63); self.cg_e8(0x07);

    } else if (self.cg_seq(fname, fnlen, "ArgvGet", 7)) {
      // ArgvGet(argv: pchar, i: int64): pchar  -- argv in rdi, i in rsi
      // lea rax, [rdi + rsi*8]  then  mov rax, [rax]
      self.cg_e8(0x48); self.cg_e8(0x8D); self.cg_e8(0x04); self.cg_e8(0xF7);  // lea rax, [rdi+rsi*8]
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x00);                      // mov rax, [rax]

    } else if (self.cg_seq(fname, fnlen, "open", 4)) {
      // open(path, flags, mode): int64 -- sys_open = 2
      // rdi=path, rsi=flags, rdx=mode
      self.cg_movRaxImm(2);
      self.cg_e8(0x0F); self.cg_e8(0x05);

    } else if (self.cg_seq(fname, fnlen, "read", 4)) {
      // read(fd, buf, count): int64 -- sys_read = 0
      // rdi=fd, rsi=buf, rdx=count
      self.cg_movRaxImm(0);
      self.cg_e8(0x0F); self.cg_e8(0x05);

    } else if (self.cg_seq(fname, fnlen, "write", 5)) {
      // write(fd, buf, count): int64 -- sys_write = 1
      // rdi=fd, rsi=buf, rdx=count
      self.cg_movRaxImm(1);
      self.cg_e8(0x0F); self.cg_e8(0x05);

    } else if (self.cg_seq(fname, fnlen, "close", 5)) {
      // close(fd): int64 -- sys_close = 3
      // rdi=fd
      self.cg_movRaxImm(3);
      self.cg_e8(0x0F); self.cg_e8(0x05);

    } else if (self.cg_seq(fname, fnlen, "lseek", 5)) {
      // lseek(fd, offset, whence): int64 -- sys_lseek = 8
      // rdi=fd, rsi=offset, rdx=whence
      self.cg_movRaxImm(8);
      self.cg_e8(0x0F); self.cg_e8(0x05);

    } else if (self.cg_seq(fname, fnlen, "chmod", 5)) {
      // chmod(path, mode): int64 -- sys_chmod = 90
      self.cg_movRaxImm(90);
      self.cg_e8(0x0F); self.cg_e8(0x05);

    } else if (self.cg_seq(fname, fnlen, "panic", 5)) {
      // WP-12: panic(msg: pchar) — write msg to stderr, longjmp or exit(1)
      // rdi = msg pointer (set by argument evaluation above)
      // Store msg in _lyx_exn_val for catch clause to read
      self.cg_emitLeaRcxData(CG_EXN_VAL);
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x39);   // mov [rcx], rdi
      // Write msg to stderr: StrLen(rdi)→rax, then write(2, rdi, rax)
      self.cg_e8(0x57);                                         // push rdi (save msg)
      var ppSL: int64 := self.cg_emitCall();
      poke32(self.code + ppSL, CG_H_STRLEN - ppSL);
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC2);   // mov rdx, rax (length)
      self.cg_e8(0x5F);                                         // pop rdi (restore msg)
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xFE);   // mov rsi, rdi (buf)
      self.cg_e8(0xBF); self.cg_e8(0x02); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00); // mov edi, 2 (stderr)
      self.cg_e8(0xB8); self.cg_e8(0x01); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00); // mov eax, 1 (sys_write)
      self.cg_e8(0x0F); self.cg_e8(0x05);                      // syscall
      // Check for exception handler and longjmp if present
      self.cg_emitLeaRcxData(CG_EXN_PTR);
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x01);   // mov rax, [rcx]
      self.cg_e8(0x48); self.cg_e8(0x85); self.cg_e8(0xC0);   // test rax, rax
      self.cg_e8(0x0F); self.cg_e8(0x84);
      var pNH: int64 := self.codeLen;
      self.cg_e32(0);
      self.cg_genLongjmp();
      poke32(self.code + pNH, self.codeLen - pNH - 4);
      // no handler: sys_exit(1)
      self.cg_movRaxImm(1);
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC7);   // mov rdi, rax
      self.cg_movRaxImm(60);
      self.cg_e8(0x0F); self.cg_e8(0x05);                      // syscall (sys_exit)
      self.cg_zeroRax();

    } else {
      // User-defined function call: emit call + patch
      var pp: int64 := self.cg_emitCall();
      self.cg_addPatch(pp, fname as int64, fnlen, CG_PATCH_CALL);
    }
  }

  // ------------------------------------------------------------------
  // Statement code generation
  // ------------------------------------------------------------------

  fn cg_genStmt(ni: int64) {
    if (ni < 0) { return; }
    var k: int64 := self.cg_nkind(ni);

    if (k == CGN_BLOCK) {
      self.cg_genBlock(ni);

    } else if (k == CGN_VAR_DECL || k == CGN_CON_DECL) {
      var name: pchar := self.cg_nsval(ni);
      var nlen: int64 := self.cg_nslen(ni);
      var off: int64 := self.cg_addLocal(name, nlen);
      var localIdx: int64 := self.localCount - 1;
      // Track type for OOP local lookup (child0 = type node, NK_TYPE_NAME = 60)
      var typeNode: int64 := self.cg_nc0(ni);
      if (typeNode >= 0 && self.cg_nkind(typeNode) == 60) {
        self.cg_setLocalType(localIdx, self.cg_nsval(typeNode), self.cg_nslen(typeNode));
      }
      // Track array locals (NK_TYPE_ARRAY = 61)
      if (typeNode >= 0 && self.cg_nkind(typeNode) == 61) {
        poke8(self.localIsArray + localIdx, 1);
      }
      var init: int64 := self.cg_nc1(ni);
      if (init >= 0) {
        self.cg_genExpr(init);
      } else {
        // WP-10d: auto-allocate struct locals (NK_TYPE_NAME=60, vmtDataOff==-1)
        var sdoStruct: int64 := 0;
        if (typeNode >= 0 && self.cg_nkind(typeNode) == 60) {
          var sdoIdx: int64 := self.cg_findClass(self.cg_nsval(typeNode), self.cg_nslen(typeNode));
          if (sdoIdx >= 0) {
            var sdoVmt: int64 := peek64(self.classLayouts + sdoIdx * CG_CLASS_SZ + 32);
            if (sdoVmt == -1) { sdoStruct := 1; }
          }
        }
        if (sdoStruct != 0) {
          // mmap(0, 4096, 3, 34, -1, 0) → rax = struct ptr
          self.cg_movRaxImm(0);    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC7); // mov rdi,rax
          self.cg_movRaxImm(4096); self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC6); // mov rsi,rax
          self.cg_movRaxImm(3);    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC2); // mov rdx,rax
          self.cg_movRaxImm(34);
          self.cg_e8(0x49); self.cg_e8(0x89); self.cg_e8(0xC2);  // mov r10, rax
          self.cg_e8(0x4D); self.cg_e8(0x31); self.cg_e8(0xC0);  // xor r8, r8
          self.cg_e8(0x49); self.cg_e8(0xFF); self.cg_e8(0xC8);  // dec r8 → r8=-1
          self.cg_e8(0x4D); self.cg_e8(0x31); self.cg_e8(0xC9);  // xor r9, r9
          self.cg_movRaxImm(9);
          self.cg_e8(0x0F); self.cg_e8(0x05);
        } else {
          self.cg_zeroRax();
        }
      }
      self.cg_storeRax(off);

    } else if (k == CGN_ASSIGN) {
      var lhs: int64 := self.cg_nc0(ni);
      var rhs: int64 := self.cg_nc1(ni);
      if (self.cg_nkind(lhs) == CGN_IDENT) {
        self.cg_genExpr(rhs);
        var name: pchar := self.cg_nsval(lhs);
        var nlen: int64 := self.cg_nslen(lhs);
        var off: int64 := self.cg_findLocal(name, nlen);
        if (off != 0) { self.cg_storeRax(off); }
      } else if (self.cg_nkind(lhs) == CGN_FIELD) {
        // obj.field := rhs
        self.cg_genExpr(rhs);
        self.cg_pushRax();
        var obj: int64 := self.cg_nc0(lhs);
        var fieldName: pchar := self.cg_nsval(lhs);
        var fieldLen:  int64 := self.cg_nslen(lhs);
        self.cg_genExpr(obj);
        var classIdx: int64 := self.cg_objClassIdx(obj);
        var foff: int64 := -1;
        if (classIdx >= 0) { foff := self.cg_getFieldOffset(classIdx, fieldName, fieldLen); }
        self.cg_popRsi();
        if (foff == 0) {
          self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x30);
        } else if (foff > 0 && foff <= 127) {
          self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x70); self.cg_e8(foff);
        } else if (foff > 127) {
          self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xB0); self.cg_e32(foff);
        }
      } else if (self.cg_nkind(lhs) == CGN_INDEX) {
        // arr[i] := rhs
        self.cg_genExpr(rhs);              // rax = value
        self.cg_pushRax();
        self.cg_genExpr(self.cg_nc1(lhs)); // rax = index
        self.cg_pushRax();
        self.cg_genExpr(self.cg_nc0(lhs)); // rax = array ptr
        self.cg_popRbx();                  // rbx = index
        // lea rcx, [rax+16]   (data start)
        self.cg_e8(0x48); self.cg_e8(0x8D); self.cg_e8(0x48); self.cg_e8(0x10);
        // pop rsi              (value)
        self.cg_e8(0x5E);
        // mov [rcx+rbx*8], rsi
        self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x34); self.cg_e8(0xD9);
      }

    } else if (k == CGN_RETURN) {
      var expr: int64 := self.cg_nc0(ni);
      if (expr >= 0) {
        self.cg_genExpr(expr);
      } else {
        self.cg_zeroRax();
      }
      self.cg_emitEpilogue();

    } else if (k == CGN_EXPR_STMT) {
      self.cg_genExpr(self.cg_nc0(ni));

    } else if (k == CGN_IF) {
      self.cg_genIf(ni);

    } else if (k == CGN_WHILE) {
      self.cg_genWhile(ni);

    } else if (k == CGN_FOR) {
      self.cg_genFor(ni);

    } else if (k == CGN_SWITCH) {
      self.cg_genSwitch(ni);

    // WP-15: Pattern matching - generate like switch
    } else if (k == CGN_MATCH) {
      self.cg_genMatch(ni);

    } else if (k == CGN_DISPOSE) {
      // dispose obj: call munmap? Skip for bootstrap.
      // Just evaluate the expression (no-op effect on expr result)
      self.cg_genExpr(self.cg_nc0(ni));

    // WP-12: Exception handling — setjmp/longjmp based
    } else if (k == CGN_TRY) {
      // jmp_buf layout on stack (80 bytes):
      //   [rsp+0..39]: callee-saved regs (rbx,rbp,r12,r13,r14,r15)
      //   [rsp+48]: saved rsp (= jmp_buf base, since mov rax,rsp before sub)
      //   [rsp+56]: catch_label ip
      //   [rsp+64]: old _lyx_exn_ptr

      // sub rsp, 80
      self.cg_e8(0x48); self.cg_e8(0x81); self.cg_e8(0xEC);
      self.cg_e8(0x50); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00);
      // Save callee-saved registers
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x1C); self.cg_e8(0x24); // mov [rsp], rbx
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x6C); self.cg_e8(0x24); self.cg_e8(0x08); // mov [rsp+8], rbp
      self.cg_e8(0x4C); self.cg_e8(0x89); self.cg_e8(0x64); self.cg_e8(0x24); self.cg_e8(0x10); // mov [rsp+16], r12
      self.cg_e8(0x4C); self.cg_e8(0x89); self.cg_e8(0x6C); self.cg_e8(0x24); self.cg_e8(0x18); // mov [rsp+24], r13
      self.cg_e8(0x4C); self.cg_e8(0x89); self.cg_e8(0x74); self.cg_e8(0x24); self.cg_e8(0x20); // mov [rsp+32], r14
      self.cg_e8(0x4C); self.cg_e8(0x89); self.cg_e8(0x7C); self.cg_e8(0x24); self.cg_e8(0x28); // mov [rsp+40], r15
      // Save rsp value to [rsp+48] (= current rsp = jmp_buf base; longjmp restores rsp←rax)
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xE0);                     // mov rax, rsp
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x44); self.cg_e8(0x24); self.cg_e8(0x30); // mov [rsp+48], rax
      // Save catch_label address to [rsp+56] via forward-patched LEA
      self.cg_e8(0x48); self.cg_e8(0x8D); self.cg_e8(0x05);  // lea rax, [rip+disp32]
      var catchLblPatch: int64 := self.codeLen;
      self.cg_e32(0);                                           // patched after catch label is known
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x44); self.cg_e8(0x24); self.cg_e8(0x38); // mov [rsp+56], rax
      // Save old handler from _lyx_exn_ptr to [rsp+64]
      self.cg_emitLeaRcxData(CG_EXN_PTR);
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x01);   // mov rax, [rcx]
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x44); self.cg_e8(0x24); self.cg_e8(0x40); // mov [rsp+64], rax
      // Install new handler: _lyx_exn_ptr ← rsp
      self.cg_emitLeaRcxData(CG_EXN_PTR);
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xE0);   // mov rax, rsp
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x01);   // mov [rcx], rax
      // Generate try body
      self.cg_genBlock(self.cg_nc0(ni));
      // Try success: restore old handler
      self.cg_emitLeaRcxData(CG_EXN_PTR);
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x44); self.cg_e8(0x24); self.cg_e8(0x40); // mov rax, [rsp+64]
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x01);   // mov [rcx], rax
      // Generate finally block on success path (if present)
      var finallyNi: int64 := self.cg_nc2(ni);
      if (finallyNi >= 0) { self.cg_genBlock(finallyNi); }
      // Jump past catch to try_done
      self.cg_e8(0xE9);
      var tryDonePatch: int64 := self.codeLen;
      self.cg_e32(0);
      // === catch_label ===
      var catchOff: int64 := self.codeLen;
      poke32(self.code + catchLblPatch, catchOff - catchLblPatch - 4);
      // longjmp has restored registers and rsp = jmp_buf base
      // Restore old handler
      self.cg_emitLeaRcxData(CG_EXN_PTR);
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x44); self.cg_e8(0x24); self.cg_e8(0x40); // mov rax, [rsp+64]
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x01);   // mov [rcx], rax
      // Load exception value for catch binding
      self.cg_emitLeaRcxData(CG_EXN_VAL);
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x01);   // mov rax, [rcx]
      // Generate catch clauses (c1 = first catch, nnext-linked)
      var catchNi: int64 := self.cg_nc1(ni);
      while (catchNi >= 0) {
        self.cg_genBlock(self.cg_nc0(catchNi));  // catch body
        catchNi := self.cg_nnext(catchNi);
      }
      // Generate finally block on catch path
      if (finallyNi >= 0) { self.cg_genBlock(finallyNi); }
      // === try_done ===
      poke32(self.code + tryDonePatch, self.codeLen - tryDonePatch - 4);
      // add rsp, 80  — restore stack frame
      self.cg_e8(0x48); self.cg_e8(0x81); self.cg_e8(0xC4);
      self.cg_e8(0x50); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00);

    } else if (k == CGN_CATCH || k == CGN_FINALLY) {
      // Standalone catch/finally outside try — just generate body
      self.cg_genBlock(self.cg_nc0(ni));

    } else if (k == CGN_THROW) {
      // WP-12: throw expr — store exception value, longjmp or exit(1)
      self.cg_genExpr(self.cg_nc0(ni));               // rax = exception value
      self.cg_emitLeaRcxData(CG_EXN_VAL);
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x01);   // mov [rcx], rax
      self.cg_emitLeaRcxData(CG_EXN_PTR);
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x01);   // mov rax, [rcx]
      self.cg_e8(0x48); self.cg_e8(0x85); self.cg_e8(0xC0);   // test rax, rax
      self.cg_e8(0x0F); self.cg_e8(0x84);
      var throwNH: int64 := self.codeLen;
      self.cg_e32(0);
      self.cg_genLongjmp();
      poke32(self.code + throwNH, self.codeLen - throwNH - 4);
      // no handler: sys_exit(1)
      self.cg_movRaxImm(1);
      self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC7);   // mov rdi, rax
      self.cg_movRaxImm(60);
      self.cg_e8(0x0F); self.cg_e8(0x05);                      // syscall (sys_exit)

    } else if (k == CGN_BREAK) {
      // jmp rel32 to loop exit; placeholder stores previous break-list head
      self.cg_e8(0xE9);
      var bp: int64 := self.codeLen;
      self.cg_e32(self.curBreakHead);  // link to previous
      self.curBreakHead := bp;

    } else if (k == CGN_CONTINUE) {
      // jmp rel32 to loop continue; placeholder stores previous continue-list head
      self.cg_e8(0xE9);
      var cp: int64 := self.codeLen;
      self.cg_e32(self.curContHead);  // link to previous
      self.curContHead := cp;

    } else if (k == CGN_CASE) {
      // Switch case body — generate body expression/block
      // c0 = case value (or null for default), c1 = body
      var bodyNode: int64 := self.cg_nc1(ni);
      if (bodyNode >= 0) {
        self.cg_genBlock(bodyNode);
      }

    } else if (k == CGN_MATCH_CASE) {
      // Match case body — generate body expression
      // c0 = pattern, c1 = body expression
      var bodyNode: int64 := self.cg_nc1(ni);
      if (bodyNode >= 0) {
        self.cg_genExpr(bodyNode);
      }

    } else if (k == CGN_FIELD_DECL) {
      // Field declaration in struct/class — no code generation needed
      // Layout is handled by cg_buildStructLayout/cg_buildClassLayout
      // Just skip (fields are processed during layout building)

    } else if (k == CGN_PARAM) {
      // Parameter declaration — already handled during function prologue generation
      // In IR-lowering context: register parameter as local variable
      var pname: pchar := self.cg_nsval(ni);
      var plen: int64 := self.cg_nslen(ni);
      var poff: int64 := self.cg_addLocal(pname, plen);
      // Track type if present (c0 = type node)
      var ptypeNode: int64 := self.cg_nc0(ni);
      if (ptypeNode >= 0 && self.cg_nkind(ptypeNode) == 60) {
        self.cg_setLocalType(self.localCount - 1, self.cg_nsval(ptypeNode), self.cg_nslen(ptypeNode));
      }

    } else {
      // Other statement kinds: skip
    }
  }

  fn cg_genBlock(ni: int64) {
    if (ni < 0) { return; }
    var savedLocals: int64 := self.localCount;
    var stmt: int64 := self.cg_nc0(ni);
    while (stmt != -1) {
      var sk: int64 := self.cg_nkind(stmt);
      // WP-13: Nested function declaration inside a block - generate as closure
      if (sk == CGN_FUNC_DECL) {
        // Check if this is a nested function (has outer function context)
        // For now, generate nested functions with static link support
        self.cg_genNestedFunc(stmt);
      } else {
        self.cg_genStmt(stmt);
      }
      stmt := self.cg_nnext(stmt);
    }
    // Restore local scope (pop locals declared in this block)
    self.localCount := savedLocals;
  }

  // WP-13: Generate nested function with static link support
  fn cg_genNestedFunc(ni: int64) {
    // Register label for nested function (mangled with parent context)
    var fname: pchar := self.cg_nsval(ni);
    var fnlen: int64 := self.cg_nslen(ni);

    // Generate unique nested function name with parent suffix
    var nestedLabel: int64 := self._allocNestedLabel(fname, fnlen);
    self.cg_addLabel(nestedLabel, 16);  // 16 = max label length

    // Reset locals but preserve outer function's captured variables
    self.localCount := 0;
    self.frameSize := 0;

    // Check if we have a static link from parent (passed via [rbp+16])
    var hasStaticLink: int64 := 0;
    if (self.staticLinkOffset >= 0) {
      hasStaticLink := 1;
      // Save static link to local slot for captured variable access
      var slOff: int64 := self.cg_addLocal("__static_link__", 15);
      self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x45); self.cg_e8(0x10); // mov rax, [rbp+16]
      self.cg_storeRax(slOff);  // store to local slot
    }

    // Emit prologue with extra space for static link parameter
    var prologuePatch: int64 := self.cg_emitPrologueNested();

    // Spill parameters (child0 = first param, linked via next)
    var param: int64 := self.cg_nc0(ni);
    var paramIdx: int64 := 0;
    while (param != -1 && paramIdx < 6) {
      var pname: pchar := self.cg_nsval(param);
      var pnlen: int64 := self.cg_nslen(param);
      var off: int64 := self.cg_addLocal(pname, pnlen);
      if (paramIdx == 0) { self.cg_spillRdi(off); }
      else if (paramIdx == 1) { self.cg_spillRsi(off); }
      else if (paramIdx == 2) { self.cg_spillRdx(off); }
      else if (paramIdx == 3) { self.cg_spillRcx(off); }
      else if (paramIdx == 4) { self.cg_spillR8(off); }
      else if (paramIdx == 5) { self.cg_spillR9(off); }
      paramIdx := paramIdx + 1;
      param := self.cg_nnext(param);
    }

    // BUG-04: Capture analysis — scan body for identifiers not in local scope
    // These must be captured from the outer function's frame
    var body: int64 := self.cg_nc2(ni);
    self._analyzeCaptured(body);

    // Generate function body (child2 = block)
    var savedStaticLink: int64 := self.staticLinkOffset;
    var savedOuterName: pchar := self.outerFuncName;
    var savedOuterLen: int64 := self.outerFuncNameLen;

    // Set up static link context for this nested function
    self.staticLinkOffset := 16;  // rbp+16 = static link param position
    // Capture current function name as outer function

    body := self.cg_nc2(ni);
    self.cg_genBlock(body);

    // Restore outer function context
    self.staticLinkOffset := savedStaticLink;
    self.outerFuncName := savedOuterName;
    self.outerFuncNameLen := savedOuterLen;

    // Implicit return
    self.cg_zeroRax();
    self.cg_emitEpilogue();

    // Patch sub rsp with aligned frame size
    var fs: int64 := self.frameSize + 15;
    var aligned: int64 := fs - (fs & 15);
    if (aligned == 0) { aligned := 16; }
    poke32(self.code + prologuePatch, aligned);
  }

  // BUG-04: Recursively scan AST for identifiers not in local scope
  // and register them as captured variables from the outer function.
  // Must be called AFTER parameter locals are registered but BEFORE codegen.
  fn _analyzeCaptured(ni: int64) {
    if (ni < 0) { return; }
    var k: int64 := self.cg_nkind(ni);

    if (k == CGN_IDENT) {
      var name: pchar := self.cg_nsval(ni);
      var nlen: int64 := self.cg_nslen(ni);
      // Skip built-in identifiers and constants
      if (self.cg_findLocal(name, nlen) == 0 &&
          self.cg_findCon(name, nlen) == 0) {
        // Not local and not constant — check if already captured
        if (self.cg_findCapturedVar(name, nlen) == 0) {
          // Register as captured; offset resolved at runtime via static link
          self.cg_addCapturedVar(name, nlen, 0);
        }
      }
    }

    // Recurse into children (expressions and sub-statements)
    // Do NOT follow nnext here — statement lists are handled separately
    var c0: int64 := self.cg_nc0(ni);
    if (c0 >= 0) { self._analyzeCaptured(c0); }
    var c1: int64 := self.cg_nc1(ni);
    if (c1 >= 0) { self._analyzeCaptured(c1); }
    var c2: int64 := self.cg_nc2(ni);
    if (c2 >= 0) { self._analyzeCaptured(c2); }
  }

  // Walk a statement list (linked via nnext) and analyze each statement
  fn _analyzeCapturedStmtList(ni: int64) {
    var cur: int64 := ni;
    while (cur >= 0) {
      self._analyzeCaptured(cur);
      cur := self.cg_nnext(cur);
    }
  }

  // WP-13: Generate nested function prologue (accepts static link in rbp+16)
  fn cg_emitPrologueNested(): int64 {
    self.cg_e8(0x55);                          // push rbp
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xE5);  // mov rbp, rsp
    // sub rsp, imm32 (48 81 EC xx xx xx xx)
    self.cg_e8(0x48); self.cg_e8(0x81); self.cg_e8(0xEC);
    var patchPos: int64 := self.codeLen;
    self.cg_e32(0);
    // Static link is already in [rbp+16] from caller
    return patchPos;
  }

  // WP-13: Allocate nested function label (simple numbered suffix)
  fn _allocNestedLabel(baseName: pchar, baseLen: int64): pchar {
    // For simplicity, return a fixed label format "_NESTED_0", etc.
    // In full implementation, would dynamically allocate string
    // Just return placeholder - actual label registration handles it
    return "__nested__";
  }

  fn cg_genIf(ni: int64) {
    // WP-10g: dead-branch elimination — if condition is a compile-time constant
    var condNi: int64 := self.cg_nc0(ni);
    if (self.cg_tryFold(condNi) != 0) {
      if (self.foldBuf != 0) {
        self.cg_genBlock(self.cg_nc1(ni));   // condition always true → emit then only
      } else {
        var elseDead: int64 := self.cg_nc2(ni);
        if (elseDead >= 0) {
          if (self.cg_nkind(elseDead) == CGN_BLOCK) {
            self.cg_genBlock(elseDead);
          } else {
            self.cg_genStmt(elseDead);
          }
        }
      }
      return;
    }
    // Evaluate condition
    self.cg_genExpr(condNi);
    // test rax, rax; jz else_label
    self.cg_e8(0x48); self.cg_e8(0x85); self.cg_e8(0xC0);  // test rax, rax
    // jz rel32 (forward)
    self.cg_e8(0x0F); self.cg_e8(0x84);
    var jzPos: int64 := self.codeLen;
    self.cg_e32(0);  // placeholder

    // Then branch
    self.cg_genBlock(self.cg_nc1(ni));

    var elseNode: int64 := self.cg_nc2(ni);
    if (elseNode >= 0) {
      // jmp over else
      self.cg_e8(0xE9);
      var jmpPos: int64 := self.codeLen;
      self.cg_e32(0);
      // Patch jz to here (else start)
      poke32(self.code + jzPos, self.codeLen - jzPos - 4);
      // Else branch
      if (self.cg_nkind(elseNode) == CGN_BLOCK) {
        self.cg_genBlock(elseNode);
      } else {
        self.cg_genStmt(elseNode);
      }
      // Patch jmp to here (end)
      poke32(self.code + jmpPos, self.codeLen - jmpPos - 4);
    } else {
      // Patch jz to here (end, no else)
      poke32(self.code + jzPos, self.codeLen - jzPos - 4);
    }
  }

  fn cg_genWhile(ni: int64) {
    var loopTop: int64 := self.codeLen;
    // Condition
    self.cg_genExpr(self.cg_nc0(ni));
    self.cg_e8(0x48); self.cg_e8(0x85); self.cg_e8(0xC0);  // test rax, rax
    self.cg_e8(0x0F); self.cg_e8(0x84);  // jz exit (forward)
    var jzPos: int64 := self.codeLen;
    self.cg_e32(0);
    // Save and reset break/continue lists for this loop
    var savedBreakHead: int64 := self.curBreakHead;
    var savedContHead: int64 := self.curContHead;
    self.curBreakHead := -1;
    self.curContHead := -1;
    // Body
    self.cg_genBlock(self.cg_nc1(ni));
    // loop_cont: patch all continue jumps to here
    var ch: int64 := self.curContHead;
    while (ch != -1) {
      var b0: int64 := peek8(self.code + ch) as int64;
      var b1: int64 := peek8(self.code + ch + 1) as int64;
      var b2: int64 := peek8(self.code + ch + 2) as int64;
      var b3: int64 := peek8(self.code + ch + 3) as int64;
      var nextLink: int64 := b0 + b1 * 256 + b2 * 65536 + b3 * 16777216;
      if (nextLink >= 2147483648) { nextLink := nextLink - 4294967296; }
      poke32(self.code + ch, loopTop - ch - 4);
      ch := nextLink;
    }
    // jmp back to loopTop
    self.cg_e8(0xE9);
    self.cg_e32(loopTop - self.codeLen - 4);
    // Patch jz to here (loop exit)
    poke32(self.code + jzPos, self.codeLen - jzPos - 4);
    // Patch all break jumps to here (walk linked list stored in placeholders)
    var bh: int64 := self.curBreakHead;
    while (bh != -1) {
      // Read 4-byte link stored in placeholder (little-endian)
      var b0: int64 := peek8(self.code + bh) as int64;
      var b1: int64 := peek8(self.code + bh + 1) as int64;
      var b2: int64 := peek8(self.code + bh + 2) as int64;
      var b3: int64 := peek8(self.code + bh + 3) as int64;
      var nextLink: int64 := b0 + b1 * 256 + b2 * 65536 + b3 * 16777216;
      // Sign-extend if high bit set (handles -1 sentinel)
      if (nextLink >= 2147483648) { nextLink := nextLink - 4294967296; }
      // Patch this break's jmp to jump to current loop exit
      poke32(self.code + bh, self.codeLen - bh - 4);
      bh := nextLink;
    }
    // Restore outer loop's break/continue lists
    self.curBreakHead := savedBreakHead;
    self.curContHead := savedContHead;
  }

  fn cg_genFor(ni: int64) {
    // for v = start to/downto limit { body }
    var name: pchar := self.cg_nsval(ni);
    var nlen: int64 := self.cg_nslen(ni);
    var dir: int64  := self.cg_nival(ni);  // 0=to, 1=downto
    var off: int64 := self.cg_addLocal(name, nlen);
    // Init: v = start
    self.cg_genExpr(self.cg_nc0(ni));
    self.cg_storeRax(off);
    var loopTop: int64 := self.codeLen;
    // Save and reset break/continue lists for this loop
    var savedBreakHead: int64 := self.curBreakHead;
    var savedContHead: int64 := self.curContHead;
    self.curBreakHead := -1;
    self.curContHead := -1;
    // Cond: v <= limit (to) or v >= limit (downto)
    self.cg_loadRax(off);
    self.cg_pushRax();
    self.cg_genExpr(self.cg_nc1(ni));
    self.cg_popRbx();  // rbx=v, rax=limit
    // cmp rbx, rax
    self.cg_e8(0x48); self.cg_e8(0x39); self.cg_e8(0xC3);
    self.cg_e8(0x0F);
    if (dir == 0) { self.cg_e8(0x8F); }  // jg exit (v > limit)
    else { self.cg_e8(0x8C); }            // jl exit (v < limit downto)
    var jmpExit: int64 := self.codeLen;
    self.cg_e32(0);
    // Body
    self.cg_genBlock(self.cg_nc2(ni));
    // loop_cont: patch all continue jumps to here
    var ch: int64 := self.curContHead;
    while (ch != -1) {
      var b0: int64 := peek8(self.code + ch) as int64;
      var b1: int64 := peek8(self.code + ch + 1) as int64;
      var b2: int64 := peek8(self.code + ch + 2) as int64;
      var b3: int64 := peek8(self.code + ch + 3) as int64;
      var nextLink: int64 := b0 + b1 * 256 + b2 * 65536 + b3 * 16777216;
      if (nextLink >= 2147483648) { nextLink := nextLink - 4294967296; }
      poke32(self.code + ch, loopTop - ch - 4);
      ch := nextLink;
    }
    // Step: v := v + 1 (or -1 for downto)
    self.cg_loadRax(off);
    if (dir == 0) { self.cg_e8(0x48); self.cg_e8(0xFF); self.cg_e8(0xC0); }  // inc rax
    else { self.cg_e8(0x48); self.cg_e8(0xFF); self.cg_e8(0xC8); }            // dec rax
    self.cg_storeRax(off);
    // jmp back
    self.cg_e8(0xE9);
    self.cg_e32(loopTop - self.codeLen - 4);
    // Patch exit
    poke32(self.code + jmpExit, self.codeLen - jmpExit - 4);
    // Restore break/continue lists
    self.curBreakHead := savedBreakHead;
    self.curContHead := savedContHead;
  }

  // ------------------------------------------------------------------
  // Switch/case code generation (WP-10c)
  // ------------------------------------------------------------------
  // AST: NK_SWITCH { nc0=subject, nc1=first_case }
  //      NK_CASE  { ival=0/1, nc0=value(if !default), nc1=body_block }
  // Strategy: linear if-else chain; default case runs last.
  // Implicit jmp after each case body uses the curBreakHead linked list,
  // so explicit break statements and implicit end-of-case jumps are both
  // patched to the switch_end at once.
  // ------------------------------------------------------------------

  fn cg_genSwitch(ni: int64) {
    // Allocate a temp local to hold the subject value
    var swVar: pchar := "__sw__";
    var swOff: int64 := self.cg_addLocal(swVar, 6);
    self.cg_genExpr(self.cg_nc0(ni));
    self.cg_storeRax(swOff);

    // Save and reset break list (shared between explicit break and implicit case exit)
    var savedBreakHead: int64 := self.curBreakHead;
    self.curBreakHead := -1;

    var defaultCaseNode: int64 := -1;
    var caseCur: int64 := self.cg_nc1(ni);
    while (caseCur != -1) {
      var isDefault: int64 := self.cg_nival(caseCur);
      if (isDefault != 0) {
        defaultCaseNode := caseCur;
      } else {
        // subject → rbx, case value → rax
        self.cg_loadRax(swOff);
        self.cg_pushRax();
        self.cg_genExpr(self.cg_nc0(caseCur));
        self.cg_popRbx();
        // cmp rbx, rax; jne skip_case (rel32)
        self.cg_e8(0x48); self.cg_e8(0x39); self.cg_e8(0xC3);
        self.cg_e8(0x0F); self.cg_e8(0x85);
        var jnePos: int64 := self.codeLen;
        self.cg_e32(0);
        // Execute case body
        self.cg_genBlock(self.cg_nc1(caseCur));
        // Implicit jmp to switch_end (linked into break list)
        self.cg_e8(0xE9);
        var bp: int64 := self.codeLen;
        self.cg_e32(self.curBreakHead);
        self.curBreakHead := bp;
        // Patch jne to next case
        poke32(self.code + jnePos, self.codeLen - jnePos - 4);
      }
      caseCur := self.cg_nnext(caseCur);
    }

    // Default case executes last if no other case matched
    if (defaultCaseNode != -1) {
      self.cg_genBlock(self.cg_nc1(defaultCaseNode));
      // Implicit jmp to switch_end
      self.cg_e8(0xE9);
      var bpd: int64 := self.codeLen;
      self.cg_e32(self.curBreakHead);
      self.curBreakHead := bpd;
    }

    // switch_end: patch all break/implicit-break jmps here
    var bh: int64 := self.curBreakHead;
    while (bh != -1) {
      var b0: int64 := peek8(self.code + bh);
      var b1: int64 := peek8(self.code + bh + 1);
      var b2: int64 := peek8(self.code + bh + 2);
      var b3: int64 := peek8(self.code + bh + 3);
      var nextLink: int64 := b0 + b1 * 256 + b2 * 65536 + b3 * 16777216;
      if (nextLink >= 2147483648) { nextLink := nextLink - 4294967296; }
      poke32(self.code + bh, self.codeLen - bh - 4);
      bh := nextLink;
    }
    self.curBreakHead := savedBreakHead;
  }

  // WP-15: Generate match statement (like switch but for pattern matching)
  fn cg_genMatch(ni: int64) {
    // c0 = discriminant expression, c1 = cases (next-linked)
    // Allocate a temp local to hold the subject value
    var matchVar: pchar := "__match__";
    var matchOff: int64 := self.cg_addLocal(matchVar, 8);
    self.cg_genExpr(self.cg_nc0(ni));
    self.cg_storeRax(matchOff);

    // Save and reset break list
    var savedBreakHead: int64 := self.curBreakHead;
    self.curBreakHead := -1;

    var defaultCaseNode: int64 := -1;
    var caseCur: int64 := self.cg_nc1(ni);  // first match case
    while (caseCur != -1) {
      // WP-15: Match case structure:
      // c0 = pattern (NK_PATTERN_LIT or NK_PATTERN_WILD or NK_PATTERN_STRUCT)
      // c1 = body expression
      var patNode: int64 := self.cg_nc0(caseCur);
      var bodyNode: int64 := self.cg_nc1(caseCur);
      var patKind: int64 := self.cg_nkind(patNode);
      
      // Wildcard pattern - treat as default
      if (patKind == CGN_PATTERN_WILD) {
        defaultCaseNode := caseCur;
      } else if (patKind == CGN_PATTERN_STRUCT) {
        // WP-15: Struct destructure pattern: Point { x: patX, y: patY }
        // sval = struct type name, c0 = first field pattern (NK_PATTERN_BIND)
        var structName: pchar := self.cg_nsval(patNode);
        var structLen: int64 := self.cg_nslen(patNode);
        
        // Load the struct value
        self.cg_loadRax(matchOff);
        self.cg_pushRax();  // save struct value
        
        // Find the struct/class layout
        var structOff: int64 := self.cg_findClass(structName, structLen);
        if (structOff != -1) {
          // Iterate over field patterns
          var fieldPat: int64 := self.cg_nc0(patNode);
          var matchFailed: int64 := 0;
          while (fieldPat != -1) {
            // fieldPat is NK_PATTERN_BIND with sval = field name
            var fieldName: pchar := self.cg_nsval(fieldPat);
            var fieldLen: int64 := self.cg_nslen(fieldPat);
            var innerPat: int64 := self.cg_nc0(fieldPat);  // inner pattern
            
            // Find field offset in struct
            var fldOff: int64 := self.cg_findField(structOff, fieldName, fieldLen);
            if (fldOff != -1) {
              // Load field value from struct
              self.cg_popRax();
              self.cg_pushRax();
              // mov rax, [rax + fieldOffset]
              self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x40);
              self.cg_e8(fldOff as int64);
              
              // Generate code for inner pattern (recursive match on field value)
              var innerPatKind: int64 := self.cg_nkind(innerPat);
              if (innerPatKind == CGN_PATTERN_BIND) {
                // Binding pattern: bind field value to new variable
                var bindName: pchar := self.cg_nsval(innerPat);
                var bindLen: int64 := self.cg_nslen(innerPat);
                var bindOff: int64 := self.cg_addLocal(bindName, bindLen);
                self.cg_storeRax(bindOff);
              } else if (innerPatKind == CGN_PATTERN_LIT) {
                // Literal pattern: compare
                var patVal: int64 := self.cg_nival(innerPat);
                self.cg_pushRax();
                if (patVal != 0) {
                  self.cg_movRaxImm(patVal);
                } else {
                  var patName: pchar := self.cg_nsval(innerPat);
                  var patNameLen: int64 := self.cg_nslen(innerPat);
                  var patNameOff: int64 := self.cg_findLocal(patName, patNameLen);
                  if (patNameOff != 0) {
                    self.cg_loadRax(patNameOff);
                  } else {
                    self.cg_zeroRax();
                  }
                }
                self.cg_popRbx();
                // cmp rbx, rax; jne fail
                self.cg_e8(0x48); self.cg_e8(0x39); self.cg_e8(0xC3);
                self.cg_e8(0x0F); self.cg_e8(0x85);
                var jnePos2: int64 := self.codeLen;
                self.cg_e32(0);
                // Field matched - continue
                poke32(self.code + jnePos2, self.codeLen - jnePos2 - 4);
              }
              // Wildcard pattern: do nothing (field value ignored)
            }
            fieldPat := self.cg_nnext(fieldPat);
          }
          // All fields matched - execute case body
          self.cg_popRax();
          self.cg_genExpr(bodyNode);
          // Implicit jmp to match_end
          self.cg_e8(0xE9);
          var bp2: int64 := self.codeLen;
          self.cg_e32(self.curBreakHead);
          self.curBreakHead := bp2;
        } else {
          // Unknown struct type - treat as wildcard
          self.cg_popRax();
          defaultCaseNode := caseCur;
        }
      } else if (patKind == CGN_PATTERN_ENUM) {
        // BUG-08: Enum payload pattern: Ok(value) or Err(msg)
        // sval = enum variant name, c0 = binding pattern for payload
        var varName: pchar := self.cg_nsval(patNode);
        var varLen: int64 := self.cg_nslen(patNode);

        // Find the variant tag across all enums
        var foundTag: int64 := -1;
        var payloadSize: int64 := 0;
        var ei: int64 := 0;
        while (ei < self.enumCount) {
          var tagInfo: int64 := self.cg_findEnumVariant(ei, varName, varLen);
          if (tagInfo >= 0) {
            foundTag := tagInfo & 0xFFFFFFFF;
            payloadSize := tagInfo >> 32;
            break;
          }
          ei := ei + 1;
        }

        if (foundTag >= 0) {
          // Load subject value (tag is in lower 32 bits)
          self.cg_loadRax(matchOff);
          self.cg_pushRax();  // save subject for payload extraction

          // Compare subject tag with variant tag
          // mov rax, subject_tag (already in rax)
          // cmp rax, foundTag
          self.cg_e8(0x48); self.cg_e8(0x3D);
          self.cg_e32(foundTag);
          // jne skip_case
          self.cg_e8(0x0F); self.cg_e8(0x85);
          var jnePos: int64 := self.codeLen;
          self.cg_e32(0);

          // Tags match — extract payload bindings if present
          var bindPat: int64 := self.cg_nc0(patNode);
          var bindIdx: int64 := 0;
          while (bindPat != -1) {
            var bindName: pchar := self.cg_nsval(bindPat);
            var bindLen: int64 := self.cg_nslen(bindPat);
            // Payload is at subject + 8 (after tag) + bindIdx * 8
            self.cg_popRax();
            self.cg_pushRax();
            // mov rax, [rax + 8 + bindIdx*8]
            var payOff: int64 := 8 + bindIdx * 8;
            if (payOff <= 127) {
              self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x40);
              self.cg_e8(payOff);
            } else {
              self.cg_e8(0x48); self.cg_e8(0x8B); self.cg_e8(0x80);
              self.cg_e32(payOff);
            }
            // Store payload value in local variable
            var bindLocalOff: int64 := self.cg_addLocal(bindName, bindLen);
            self.cg_storeRax(bindLocalOff);
            self.cg_pushRax();  // restore subject for next binding
            bindIdx := bindIdx + 1;
            bindPat := self.cg_nnext(bindPat);
          }
          self.cg_popRax();  // discard saved subject

          // Execute case body
          self.cg_genExpr(bodyNode);
          // Implicit jmp to match_end
          self.cg_e8(0xE9);
          var bp: int64 := self.codeLen;
          self.cg_e32(self.curBreakHead);
          self.curBreakHead := bp;

          // Patch jne to next case
          poke32(self.code + jnePos, self.codeLen - jnePos - 4);
        } else {
          // Unknown variant — treat as wildcard/default
          defaultCaseNode := caseCur;
        }
      } else {
        // Load subject value, compare with pattern
        self.cg_loadRax(matchOff);
        self.cg_pushRax();
        // Pattern literal: c1 = ival for int literals, sval for identifiers
        var patVal: int64 := self.cg_nival(patNode);
        if (patVal != 0) {
          // Integer literal pattern
          self.cg_movRaxImm(patVal);
        } else {
          // Identifier pattern - load from local/symbol
          // For now, assume string-based pattern comparison
          var patName: pchar := self.cg_nsval(patNode);
          var patLen: int64 := self.cg_nslen(patNode);
          var patOff: int64 := self.cg_findLocal(patName, patLen);
          if (patOff != 0) {
            self.cg_loadRax(patOff);
          } else {
            self.cg_zeroRax();
          }
        }
        self.cg_popRbx();
        // cmp rbx, rax; jne skip_case
        self.cg_e8(0x48); self.cg_e8(0x39); self.cg_e8(0xC3);
        self.cg_e8(0x0F); self.cg_e8(0x85);
        var jnePos: int64 := self.codeLen;
        self.cg_e32(0);
        // Execute case body
        self.cg_genExpr(bodyNode);
        // Implicit jmp to match_end
        self.cg_e8(0xE9);
        var bp: int64 := self.codeLen;
        self.cg_e32(self.curBreakHead);
        self.curBreakHead := bp;
        // Patch jne to next case
        poke32(self.code + jnePos, self.codeLen - jnePos - 4);
      }
      caseCur := self.cg_nnext(caseCur);
    }

    // Default/wildcard case executes last if no other case matched
    if (defaultCaseNode != -1) {
      var bodyNode: int64 := self.cg_nc1(defaultCaseNode);
      self.cg_genExpr(bodyNode);
      self.cg_e8(0xE9);
      var bpd: int64 := self.codeLen;
      self.cg_e32(self.curBreakHead);
      self.curBreakHead := bpd;
    }

    // match_end: patch all break/implicit jmps
    var bh: int64 := self.curBreakHead;
    while (bh != -1) {
      var b0: int64 := peek8(self.code + bh);
      var b1: int64 := peek8(self.code + bh + 1);
      var b2: int64 := peek8(self.code + bh + 2);
      var b3: int64 := peek8(self.code + bh + 3);
      var nextLink: int64 := b0 + b1 * 256 + b2 * 65536 + b3 * 16777216;
      if (nextLink >= 2147483648) { nextLink := nextLink - 4294967296; }
      poke32(self.code + bh, self.codeLen - bh - 4);
      bh := nextLink;
    }
    self.curBreakHead := savedBreakHead;
  }

  // ------------------------------------------------------------------
  // Function declaration
  // ------------------------------------------------------------------

  fn cg_genFuncDecl(ni: int64) {
    // Register label for this function
    var fname: pchar := self.cg_nsval(ni);
    var fnlen: int64 := self.cg_nslen(ni);
    self.cg_addLabel(fname, fnlen);

    // Save and set outer function context for nested function capture analysis
    var savedOuterName: pchar := self.outerFuncName;
    var savedOuterLen: int64 := self.outerFuncNameLen;
    self.outerFuncName := fname;
    self.outerFuncNameLen := fnlen;

    // Reset locals
    self.localCount := 0;
    self.frameSize  := 0;

    // Emit prologue, capture patch position for sub rsp imm32
    var prologuePatch: int64 := self.cg_emitPrologue();

    // Spill parameters (child0 = first param, linked via next)
    var param: int64 := self.cg_nc0(ni);
    var paramIdx: int64 := 0;
    while (param != -1 && paramIdx < 6) {
      var pname: pchar := self.cg_nsval(param);
      var pnlen: int64 := self.cg_nslen(param);
      var off: int64 := self.cg_addLocal(pname, pnlen);
      // Track param type if it's a user type (NK_TYPE_NAME = 60)
      var ptypeNode: int64 := self.cg_nc0(param);
      if (ptypeNode >= 0 && self.cg_nkind(ptypeNode) == 60) {
        self.cg_setLocalType(self.localCount - 1, self.cg_nsval(ptypeNode), self.cg_nslen(ptypeNode));
      }
      if (paramIdx == 0) { self.cg_spillRdi(off); }
      else if (paramIdx == 1) { self.cg_spillRsi(off); }
      else if (paramIdx == 2) { self.cg_spillRdx(off); }
      else if (paramIdx == 3) { self.cg_spillRcx(off); }
      else if (paramIdx == 4) { self.cg_spillR8(off); }
      else if (paramIdx == 5) { self.cg_spillR9(off); }
      paramIdx := paramIdx + 1;
      param := self.cg_nnext(param);
    }

    // Generate function body (child2 = block)
    var body: int64 := self.cg_nc2(ni);
    self.cg_genBlock(body);

    // Implicit return (xor rax, rax; epilogue)
    self.cg_zeroRax();
    self.cg_emitEpilogue();

    // Patch sub rsp with aligned frame size
    var fs: int64 := self.frameSize + 15;
    var aligned: int64 := fs - (fs & 15);
    if (aligned == 0) { aligned := 16; }
    poke32(self.code + prologuePatch, aligned);

    // Restore outer function context
    self.outerFuncName := savedOuterName;
    self.outerFuncNameLen := savedOuterLen;
  }

  // ------------------------------------------------------------------
  // Helper functions emitted at start of code buffer
  // Fixed byte sequences encoding _start, _lyx_strlen, _lyx_print_str,
  // and _lyx_print_int.
  // ------------------------------------------------------------------

  fn cg_emitHelpers() {
    // ---- _start (65 bytes) ----
    // At Linux ABI entry: [rsp]=argc, [rsp+8]=argv[0], ...
    // First: call prlimit64 to remove RLIMIT_STACK (allows deep recursion in parser)
    // sub rsp, 16       (48 83 EC 10)
    self.cg_e8(0x48); self.cg_e8(0x83); self.cg_e8(0xEC); self.cg_e8(0x10);
    // mov rax, -1       (48 C7 C0 FF FF FF FF)  RLIM_INFINITY
    self.cg_e8(0x48); self.cg_e8(0xC7); self.cg_e8(0xC0);
    self.cg_e8(0xFF); self.cg_e8(0xFF); self.cg_e8(0xFF); self.cg_e8(0xFF);
    // mov [rsp], rax    (48 89 04 24)  rlim_cur
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x04); self.cg_e8(0x24);
    // mov [rsp+8], rax  (48 89 44 24 08)  rlim_max
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x44); self.cg_e8(0x24); self.cg_e8(0x08);
    // xor edi, edi      (31 FF)  pid = 0
    self.cg_e8(0x31); self.cg_e8(0xFF);
    // mov esi, 3        (BE 03 00 00 00)  RLIMIT_STACK
    self.cg_e8(0xBE); self.cg_e8(0x03); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00);
    // mov rdx, rsp      (48 89 E2)  new_limit = &rlimit_struct
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xE2);
    // xor r10d, r10d    (45 31 D2)  old_limit = NULL
    self.cg_e8(0x45); self.cg_e8(0x31); self.cg_e8(0xD2);
    // mov eax, 302      (B8 2E 01 00 00)  SYS_prlimit64
    self.cg_e8(0xB8); self.cg_e8(0x2E); self.cg_e8(0x01); self.cg_e8(0x00); self.cg_e8(0x00);
    // syscall           (0F 05)
    self.cg_e8(0x0F); self.cg_e8(0x05);
    // add rsp, 16       (48 83 C4 10)  restore stack
    self.cg_e8(0x48); self.cg_e8(0x83); self.cg_e8(0xC4); self.cg_e8(0x10);
    // 5F               pop rdi          -- rdi = argc
    self.cg_e8(0x5F);
    // 48 89 E6         mov rsi, rsp     -- rsi = &argv[0] (argv pointer)
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xE6);
    // E8 xx xx xx xx   call main        (patched after all functions)
    self.cg_e8(0xE8);
    var pp: int64 := self.codeLen;
    self.cg_e32(0);
    self.cg_addPatch(pp, "main" as int64, 4, CG_PATCH_CALL);
    // 48 89 C7         mov rdi, rax
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC7);
    // 48 C7 C0 3C 00 00 00   mov rax, 60 (sys_exit)
    self.cg_e8(0x48); self.cg_e8(0xC7); self.cg_e8(0xC0);
    self.cg_e8(0x3C); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00);
    // 0F 05            syscall
    self.cg_e8(0x0F); self.cg_e8(0x05);
    // _start is now 65 bytes  ✓

    // ---- _lyx_strlen (15 bytes, starts at offset 65) ----
    // xor rax, rax
    self.cg_e8(0x48); self.cg_e8(0x31); self.cg_e8(0xC0);
    // cmp byte [rdi+rax], 0
    self.cg_e8(0x80); self.cg_e8(0x3C); self.cg_e8(0x07); self.cg_e8(0x00);
    // jz +5 (to ret at offset 14 from strlen start)
    self.cg_e8(0x74); self.cg_e8(0x05);
    // inc rax
    self.cg_e8(0x48); self.cg_e8(0xFF); self.cg_e8(0xC0);
    // jmp -11 (back to cmp)
    self.cg_e8(0xEB); self.cg_e8(0xF5);
    // ret
    self.cg_e8(0xC3);
    // strlen is now 15 bytes  ✓

    // ---- _lyx_print_str (26 bytes, starts at offset 80) ----
    // push rdi
    self.cg_e8(0x57);
    // call _lyx_strlen  (rel32 = 21 - 42 = -21; relative offset unchanged after +4 shift)
    self.cg_e8(0xE8); self.cg_e32(-21);
    // mov rdx, rax
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC2);
    // pop rdi
    self.cg_e8(0x5F);
    // mov rsi, rdi
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xFE);
    // mov edi, 1  (stdout)
    self.cg_e8(0xBF); self.cg_e8(0x01); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00);
    // mov eax, 1  (sys_write)
    self.cg_e8(0xB8); self.cg_e8(0x01); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00);
    // syscall
    self.cg_e8(0x0F); self.cg_e8(0x05);
    // ret
    self.cg_e8(0xC3);
    // print_str is now 26 bytes  ✓

    // ---- _lyx_print_int (104 bytes, starts at offset 106) ----
    // sub rsp, 24          48 83 EC 18
    self.cg_e8(0x48); self.cg_e8(0x83); self.cg_e8(0xEC); self.cg_e8(0x18);
    // lea rsi, [rsp+23]    48 8D 74 24 17
    self.cg_e8(0x48); self.cg_e8(0x8D); self.cg_e8(0x74); self.cg_e8(0x24); self.cg_e8(0x17);
    // mov rax, rdi         48 89 F8
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xF8);
    // test rax, rax        48 85 C0
    self.cg_e8(0x48); self.cg_e8(0x85); self.cg_e8(0xC0);
    // jnz +8 (to .nonzero at offset+25)  75 08
    self.cg_e8(0x75); self.cg_e8(0x08);
    // mov byte [rsi], '0'  C6 06 30
    self.cg_e8(0xC6); self.cg_e8(0x06); self.cg_e8(0x30);
    // dec rsi              48 FF CE
    self.cg_e8(0x48); self.cg_e8(0xFF); self.cg_e8(0xCE);
    // jmp .emit (+48)      EB 30  (was +43=EB2B; .emit now 5 bytes further due to sign check)
    self.cg_e8(0xEB); self.cg_e8(0x30);
    // .nonzero: test rax, rax  48 85 C0
    self.cg_e8(0x48); self.cg_e8(0x85); self.cg_e8(0xC0);
    // jge +3 (.digitloop)  7D 03  (was +9; skip only neg rax, sign written after loop)
    self.cg_e8(0x7D); self.cg_e8(0x03);
    // neg rax              48 F7 D8
    self.cg_e8(0x48); self.cg_e8(0xF7); self.cg_e8(0xD8);
    // .digitloop: test rax, rax  48 85 C0
    self.cg_e8(0x48); self.cg_e8(0x85); self.cg_e8(0xC0);
    // jz +24 (.sign)       74 18  (displacement unchanged: loop shrunk 6, target shrunk 6)
    self.cg_e8(0x74); self.cg_e8(0x18);
    // xor rdx, rdx         48 31 D2
    self.cg_e8(0x48); self.cg_e8(0x31); self.cg_e8(0xD2);
    // mov rcx, 10          48 C7 C1 0A 00 00 00
    self.cg_e8(0x48); self.cg_e8(0xC7); self.cg_e8(0xC1);
    self.cg_e8(0x0A); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00);
    // idiv rcx             48 F7 F9
    self.cg_e8(0x48); self.cg_e8(0xF7); self.cg_e8(0xF9);
    // add rdx, 48          48 83 C2 30
    self.cg_e8(0x48); self.cg_e8(0x83); self.cg_e8(0xC2); self.cg_e8(0x30);
    // mov [rsi], dl        88 16
    self.cg_e8(0x88); self.cg_e8(0x16);
    // dec rsi              48 FF CE
    self.cg_e8(0x48); self.cg_e8(0xFF); self.cg_e8(0xCE);
    // jmp .digitloop (-29) EB E3  (displacement unchanged)
    self.cg_e8(0xEB); self.cg_e8(0xE3);
    // .sign: test rdi, rdi (check original sign; rdi preserved through loop)  48 85 FF
    self.cg_e8(0x48); self.cg_e8(0x85); self.cg_e8(0xFF);
    // jns +6 (skip '-' if non-negative)  79 06
    self.cg_e8(0x79); self.cg_e8(0x06);
    // mov byte [rsi], '-'  C6 06 2D
    self.cg_e8(0xC6); self.cg_e8(0x06); self.cg_e8(0x2D);
    // dec rsi              48 FF CE
    self.cg_e8(0x48); self.cg_e8(0xFF); self.cg_e8(0xCE);
    // .emit: inc rsi       48 FF C6
    self.cg_e8(0x48); self.cg_e8(0xFF); self.cg_e8(0xC6);
    // lea rdx, [rsp+23]    48 8D 54 24 17
    self.cg_e8(0x48); self.cg_e8(0x8D); self.cg_e8(0x54); self.cg_e8(0x24); self.cg_e8(0x17);
    // sub rdx, rsi         48 29 F2
    self.cg_e8(0x48); self.cg_e8(0x29); self.cg_e8(0xF2);
    // inc rdx              48 FF C2
    self.cg_e8(0x48); self.cg_e8(0xFF); self.cg_e8(0xC2);
    // mov edi, 1           BF 01 00 00 00
    self.cg_e8(0xBF); self.cg_e8(0x01); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00);
    // mov eax, 1           B8 01 00 00 00
    self.cg_e8(0xB8); self.cg_e8(0x01); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00);
    // syscall              0F 05
    self.cg_e8(0x0F); self.cg_e8(0x05);
    // add rsp, 24          48 83 C4 18
    self.cg_e8(0x48); self.cg_e8(0x83); self.cg_e8(0xC4); self.cg_e8(0x18);
    // ret                  C3
    self.cg_e8(0xC3);
    // print_int is 104 bytes  ✓

    // ---- _lyx_strsub (40 bytes, starts at offset 210) ----
    // StrSub(s: pchar, start: int64, len: int64): pchar
    // rdi=s, rsi=start, rdx=len
    // mmap(0, len+17, 3, 34, -1, 0) → rax = new buffer
    // Save rdi (s) at [rsp+0], rsi (start) at [rsp+8], rdx (len) at [rsp+16]
    // push rdi             57
    self.cg_e8(0x57);
    // push rsi             56
    self.cg_e8(0x56);
    // push rdx             52
    self.cg_e8(0x52);
    // mov rdi, 0           48 C7 C7 00 00 00 00
    self.cg_e8(0x48); self.cg_e8(0xC7); self.cg_e8(0xC7);
    self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00);
    // lea rsi, [rdx+17]    48 8D 54 24 10
    self.cg_e8(0x48); self.cg_e8(0x8D); self.cg_e8(0x54); self.cg_e8(0x24); self.cg_e8(0x10);
    // mov edx, 3           BA 03 00 00 00
    self.cg_e8(0xBA); self.cg_e8(0x03); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00);
    // mov r10, 34          49 C7 C2 22 00 00 00
    self.cg_e8(0x49); self.cg_e8(0xC7); self.cg_e8(0xC2);
    self.cg_e8(0x22); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00);
    // mov r8, -1           49 C7 C0 FF FF FF FF
    self.cg_e8(0x49); self.cg_e8(0xC7); self.cg_e8(0xC0);
    self.cg_e8(0xFF); self.cg_e8(0xFF); self.cg_e8(0xFF); self.cg_e8(0xFF);
    // mov r9, 0            49 C7 C1 00 00 00 00
    self.cg_e8(0x49); self.cg_e8(0xC7); self.cg_e8(0xC1);
    self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00);
    // mov eax, 9           B8 09 00 00 00
    self.cg_e8(0xB8); self.cg_e8(0x09); self.cg_e8(0x00); self.cg_e8(0x00); self.cg_e8(0x00);
    // syscall              0F 05
    self.cg_e8(0x0F); self.cg_e8(0x05);
    // rax = new buffer. Save at [rsp+24]
    // mov [rsp+24], rax    48 89 44 24 18
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0x44); self.cg_e8(0x24); self.cg_e8(0x18);
    // Copy loop: rdi=dest, rsi=src, rcx=count
    // pop rcx = len        5A
    self.cg_e8(0x5A);
    // pop rsi = start      5E
    self.cg_e8(0x5E);
    // pop rdi = orig src   5F
    self.cg_e8(0x5F);
    // add rsi, rdi         48 01 FE  (rsi = start + src = src + start)
    self.cg_e8(0x48); self.cg_e8(0x01); self.cg_e8(0xFE);
    // mov rdi, rax         48 89 C7  (dest = mmap result)
    self.cg_e8(0x48); self.cg_e8(0x89); self.cg_e8(0xC7);
    // rep movsb            F3 A4
    self.cg_e8(0xF3); self.cg_e8(0xA4);
    // Null-terminate: mov byte [rax+rcx], 0
    // rax has dest, rcx has len
    // add rax, rcx         48 01 C8
    self.cg_e8(0x48); self.cg_e8(0x01); self.cg_e8(0xC8);
    // mov byte [rax], 0    C6 00 00
    self.cg_e8(0xC6); self.cg_e8(0x00); self.cg_e8(0x00);
    // ret                  C3
    self.cg_e8(0xC3);
    // strsub is 40 bytes  ✓

    // ---- _lyx_strcharat (15 bytes, starts at offset 250) ----
    // StrCharAt(s: pchar, i: int64): int64
    // rdi=s, rsi=i, return rax = byte at s[i] zero-extended
    // movzx rax, byte [rdi+rsi]
    self.cg_e8(0x48); self.cg_e8(0x0F); self.cg_e8(0xB6); self.cg_e8(0x04); self.cg_e8(0x37);
    // ret                  C3
    self.cg_e8(0xC3);
    // strcharat is 15 bytes  ✓
    // Total helpers: 65+15+26+104+40+15 = 265 = CG_H_USER  ✓
  }

  // ------------------------------------------------------------------
  // Import resolution (WP-09)
  // ------------------------------------------------------------------

  // Read a file into an mmap buffer (null-terminated). Returns null on error.
  fn cg_readFile(path: pchar): pchar {
    var fd: int64 := open(path, 0, 0);
    if (fd < 0) { return 0 as pchar; }
    var size: int64 := lseek(fd, 0, 2);
    if (size <= 0) { close(fd); return 0 as pchar; }
    lseek(fd, 0, 0);
    var buf: int64 := mmap(0, size + 1, 3, 34, -1, 0);
    read(fd, buf as pchar, size);
    poke8(buf + size, 0);
    close(fd);
    return buf as pchar;
  }

  // Returns 1 if module name was already imported, 0 otherwise.
  fn cg_hasImported(name: pchar, nameLen: int64): int64 {
    var i: int64 := 0;
    while (i < self.importCount) {
      var base: int64 := self.importNames + i * 16;
      var p: pchar    := peek64(base) as pchar;
      var n: int64    := peek64(base + 8);
      if (n == nameLen && self.cg_seq(p, n, name, nameLen)) { return 1; }
      i := i + 1;
    }
    return 0;
  }

  // Mark a module as imported (add to dedup set).
  fn cg_markImported(name: pchar, nameLen: int64) {
    if (self.importCount >= self.importCap) {
      var nc: int64 := self.importCap * 2;
      var nb: int64 := mmap(0, nc * 16, 3, 34, -1, 0);
      var i: int64 := 0;
      while (i < self.importCount * 16) {
        poke8(nb + i, peek8(self.importNames + i));
        i := i + 1;
      }
      self.importNames := nb;
      self.importCap   := nc;
    }
    var base: int64 := self.importNames + self.importCount * 16;
    poke64(base,      name as int64);
    poke64(base + 8,  nameLen);
    self.importCount := self.importCount + 1;
  }

  // Process an import: find the .lyx file, parse it, codegen it.
  // Temporarily swaps pSrc/pNodes to the imported file's data.
  fn cg_processImport(modName: pchar, nameLen: int64) {
    if (self.cg_hasImported(modName, nameLen) != 0) { return; }
    self.cg_markImported(modName, nameLen);

    // Convert "bootstrap.parser" → "bootstrap/parser.lyx"
    var pathBuf: int64 := mmap(0, nameLen + 8, 3, 34, -1, 0);
    var i: int64 := 0;
    while (i < nameLen) {
      var c: int64 := StrCharAt(modName, i);
      if (c == 46) { c := 47; }  // '.' → '/'
      poke8(pathBuf + i, c);
      i := i + 1;
    }
    poke8(pathBuf + nameLen,     46);   // '.'
    poke8(pathBuf + nameLen + 1, 108);  // 'l'
    poke8(pathBuf + nameLen + 2, 121);  // 'y'
    poke8(pathBuf + nameLen + 3, 120);  // 'x'
    poke8(pathBuf + nameLen + 4, 0);

    var path: pchar := pathBuf as pchar;
    var src: pchar := self.cg_readFile(path);
    var srcSize: int64 := 0;
    if (src != 0 as pchar) { srcSize := StrLen(src); }
    // BUG-02: pathBuf no longer needed after readFile — free immediately
    munmap(pathBuf, nameLen + 8);

    if (src == 0 as pchar) {
      PrintStr("codegen: cannot read import: ");
      PrintStr(path);
      PrintStr("\n");
      return;
    }

    // Parse the imported file
    var p: Parser := new Parser();
    p.Init(src, srcSize);
    var head: int64 := p.Parse();

    if (p.hadError != 0) {
      PrintStr("codegen: parse error in import: ");
      PrintStr(path);
      PrintStr("\n");
      // BUG-03: Free src buffer before disposing parser on error
      munmap(src, srcSize);
      dispose p;
      return;
    }

    // Switch to imported file's source and nodes for codegen
    var savedSrc:   pchar := self.pSrc;
    var savedNodes: int64 := self.pNodes;
    self.pSrc   := p.src;
    self.pNodes := p.nodes;

    // Recursively generate code for the imported file
    self.cg_genFile(head);

    // Restore main file's source and nodes
    self.pSrc   := savedSrc;
    self.pNodes := savedNodes;

    dispose p;
    // BUG-02: Free imported source buffer after codegen is complete
    munmap(src, srcSize);
  }

  // ------------------------------------------------------------------
  // Top-level file generation
  // ------------------------------------------------------------------

  fn cg_genFile(head: int64) {
    var cur: int64 := head;
    while (cur != -1) {
      var k: int64 := self.cg_nkind(cur);
      if (k == CGN_FUNC_DECL) {
        self.cg_genFuncDecl(cur);
      } else if (k == CGN_IMPORT) {
        // Process the imported module (WP-09: import resolution)
        var modName: pchar := self.cg_nsval(cur);
        var modLen:  int64 := self.cg_nslen(cur);
        self.cg_processImport(modName, modLen);
      } else if (k == CGN_TYPE_DECL) {
        // NK_TYPE_DECL: class if it has methods (nc1 != -1), struct otherwise
        var hasMethods: int64 := self.cg_nc1(cur);
        if (hasMethods == -1) {
          // No methods → treat as struct (fields start at offset 0, no VMT)
          self.cg_buildStructLayout(cur);
        } else {
          // Has methods → class layout (fields at offset 8, VMT at 0)
          self.cg_buildClassLayout(cur);
          var clsName: pchar := self.cg_nsval(cur);
          var clsLen:  int64 := self.cg_nslen(cur);
          var method: int64 := hasMethods;
          while (method != -1) {
            var nextM: int64 := self.cg_nnext(method);
            self.cg_genMethodDecl(method, clsName, clsLen);
            method := nextM;
          }
        }
      } else if (k == CGN_STRUCT_DECL) {
        // Standalone struct declaration: register field layout (fields at offset 0)
        self.cg_buildStructLayout(cur);
      } else if (k == CGN_ENUM_DECL) {
        // BUG-08: Enum declaration: register variant layout for match analysis
        self.cg_buildEnumLayout(cur);
      } else if (k == CGN_CON_DECL) {
        // Populate constant table for use inside method bodies
        var initNode: int64 := self.cg_nc1(cur);
        if (initNode >= 0 && self.cg_nkind(initNode) == CGN_LIT_INT) {
          self.cg_addCon(self.cg_nsval(cur), self.cg_nslen(cur), self.cg_nival(initNode));
        }
      } else if (k == CGN_ENUM_DECL) {
        // WP-10f: register each enum member as an int64 constant
        // auto-increment from 0; explicit value overrides via child0
        var mem: int64 := self.cg_nc0(cur);
        var nextVal: int64 := 0;
        while (mem != -1) {
          var mname: pchar := self.cg_nsval(mem);
          var mlen:  int64 := self.cg_nslen(mem);
          var valNode: int64 := self.cg_nc0(mem);
          if (valNode >= 0 && self.cg_nkind(valNode) == CGN_LIT_INT) {
            nextVal := self.cg_nival(valNode);
          }
          self.cg_addCon(mname, mlen, nextVal);
          nextVal := nextVal + 1;
          mem := self.cg_nnext(mem);
        }
      }
      cur := self.cg_nnext(cur);
    }
  }

  // ------------------------------------------------------------------
  // Init and public API
  // ------------------------------------------------------------------

  fn Init(src: pchar, nodes: int64, toks: int64) {
    self.pSrc   := src;
    self.pNodes := nodes;
    self.pToks  := toks;

    self.codeCap := 65536;
    self.code    := mmap(0, self.codeCap, 3, 34, -1, 0);
    self.codeLen := 0;

    self.dataCap := 16384;
    self.data    := mmap(0, self.dataCap, 3, 34, -1, 0);
    self.dataLen := 16;  // WP-12: pre-reserve 16 bytes for exception globals (EXN_VAL@0, EXN_PTR@8)

    self.localCap  := 64;
    self.locals    := mmap(0, self.localCap * CG_LOCAL_SZ, 3, 34, -1, 0);
    self.localCount := 0;
    self.frameSize  := 0;

    self.labelCap  := 128;
    self.labels    := mmap(0, self.labelCap * CG_LABEL_SZ, 3, 34, -1, 0);
    self.labelCount := 0;

    self.patchCap  := 256;
    self.patches   := mmap(0, self.patchCap * CG_PATCH_SZ, 3, 34, -1, 0);
    self.patchCount := 0;

    self.nextLblId := 0;

    // Import dedup (WP-09)
    self.importCap   := 32;
    self.importNames := mmap(0, self.importCap * 16, 3, 34, -1, 0);
    self.importCount := 0;

    // Class layout table (WP-09 OOP)
    self.classCap    := 16;
    self.classLayouts := mmap(0, self.classCap * CG_CLASS_SZ, 3, 34, -1, 0);
    self.classCount  := 0;

    // BUG-08: Enum layout table for match tag analysis
    self.enumCap     := 16;
    self.enumLayouts := mmap(0, self.enumCap * 32, 3, 34, -1, 0);
    self.enumCount   := 0;

    // Local type tracking (parallel to locals)
    self.localTypes  := mmap(0, self.localCap * 16, 3, 34, -1, 0);

    // Method class context
    self.curClassName    := 0 as pchar;
    self.curClassNameLen := 0;

    // WP-13: Closure support - static link defaults (not in a nested function)
    self.staticLinkOffset := -1;
    self.outerFuncName    := 0 as pchar;
    self.outerFuncNameLen := 0;

    // Module-level constant table (use literal 24 for slot size, avoids bootstrap issue)
    self.conCap   := 256;
    self.conTable := mmap(0, self.conCap * 24, 3, 34, -1, 0);
    self.conCount := 0;

    // Break linked list: no pending breaks initially
    self.curBreakHead := -1;
    self.curContHead := -1;

    // VMT address patch table (WP-10a)
    self.vmtPatchCap   := 32;
    self.vmtPatches    := mmap(0, self.vmtPatchCap * 24, 3, 34, -1, 0);
    self.vmtPatchCount := 0;

    // Per-local array flag (WP-10b)
    self.localIsArray := mmap(0, self.localCap, 3, 34, -1, 0);

    // BUG-02: Temporary buffer tracking (prevent mmap leaks)
    self.tempBufCap   := 64;
    self.tempBufs     := mmap(0, self.tempBufCap * 16, 3, 34, -1, 0);
    self.tempBufCount := 0;

    // WP-13: Captured variable table for nested functions
    self.capturedCap   := 64;
    self.capturedVars  := mmap(0, self.capturedCap * 40, 3, 34, -1, 0);
    self.capturedCount := 0;

    // Emit fixed helper stubs first
    self.cg_emitHelpers();
  }

  fn Generate(head: int64) {
    self.cg_genFile(head);
    self.cg_patchAll();
    // BUG-02: Free all temporary mmap buffers after patching is complete
    self.cg_freeAllTempBufs();
  }

  fn WriteELF(path: pchar) {
    var totalCode: int64 := self.codeLen;
    var totalData: int64 := self.dataLen;
    var fileSize:  int64 := CG_CODE_OFF + totalCode + totalData;

    // Allocate ELF buffer
    var buf: int64 := mmap(0, fileSize, 3, 34, -1, 0);

    // ELF header (64 bytes)
    poke8(buf, 0x7F);
    poke8(buf + 1,  69);   // 'E'
    poke8(buf + 2,  76);   // 'L'
    poke8(buf + 3,  70);   // 'F'
    poke8(buf + 4,  2);    // ELFCLASS64
    poke8(buf + 5,  1);    // ELFDATA2LSB
    poke8(buf + 6,  1);    // EV_CURRENT
    poke8(buf + 7,  0);    // ELFOSABI_NONE
    // bytes 8-15: padding (mmap zeroed)
    poke16(buf + 16, 2);    // e_type = ET_EXEC
    poke16(buf + 18, 62);   // e_machine = EM_X86_64 (0x3E)
    poke32(buf + 20, 1);    // e_version
    // e_entry = load vaddr + ELF/phdr headers + _start offset (0)
    poke64(buf + 24, CG_ELF_BASE + CG_CODE_OFF);
    poke64(buf + 32, CG_PHDR_OFF);  // e_phoff
    poke64(buf + 40, 0);             // e_shoff (no sections)
    poke32(buf + 48, 0);             // e_flags
    poke16(buf + 52, 64);   // e_ehsize
    poke16(buf + 54, 56);   // e_phentsize
    poke16(buf + 56, 1);    // e_phnum
    poke16(buf + 58, 64);   // e_shentsize
    poke16(buf + 60, 0);    // e_shnum
    poke16(buf + 62, 0);    // e_shstrndx

    // Program header (56 bytes at offset 64)
    var ph: int64 := buf + CG_PHDR_OFF;
    poke32(ph,      1);              // p_type = PT_LOAD
    poke32(ph + 4,  7);              // p_flags = PF_R|PF_W|PF_X
    poke64(ph + 8,  0);              // p_offset = 0 (map whole file)
    poke64(ph + 16, CG_ELF_BASE);   // p_vaddr
    poke64(ph + 24, CG_ELF_BASE);   // p_paddr
    poke64(ph + 32, fileSize);       // p_filesz
    poke64(ph + 40, fileSize);       // p_memsz
    poke64(ph + 48, 2097152);        // p_align = 0x200000

    // Copy code
    var i: int64 := 0;
    while (i < totalCode) {
      poke8(buf + CG_CODE_OFF + i, peek8(self.code + i));
      i := i + 1;
    }

    // Copy string data
    i := 0;
    while (i < totalData) {
      poke8(buf + CG_CODE_OFF + totalCode + i, peek8(self.data + i));
      i := i + 1;
    }

    // Write ELF binary to file (O_WRONLY|O_CREAT|O_TRUNC = 577, mode 0755 = 493)
    var fd: int64 := open(path, 577, 493);
    if (fd >= 0) {
      write(fd, buf as pchar, fileSize);
      close(fd);
    } else {
      PrintStr("codegen: failed to open output file: ");
      PrintStr(path);
      PrintStr("\n");
    }
  }

};

// ============================================================================
// Public helper: emit count of nodes in a singly-linked list (via NNext)
// (Mirrors ParserListLen from parser.lyx for convenience)
// ============================================================================

pub fn CodegenListLen(head: int64, nodes: int64): int64 {
  var n: int64 := 0;
  var cur: int64 := head;
  while (cur != -1) {
    n := n + 1;
    cur := peek64(nodes + cur * CG_NODE_SIZE + 40);
  }
  return n;
}
