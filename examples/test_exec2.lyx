import std.os;

fn main(): void {
  PrintStr("1: before exec\n");
  var argv: int64 := mmap(0, 48, 3, 34, -1, 0);
  PrintStr("2: argv=");
  PrintInt(argv);
  PrintStr("\n");

  var path: pchar := "/bin/echo";
  var a0: pchar := "hello";

  poke64(argv + 0, path as int64);
  poke64(argv + 8, a0 as int64);
  poke64(argv + 16, 0);
  PrintStr("3: argv filled\n");

  var pid: int64 := sys_fork();
  PrintStr("4: pid=");
  PrintInt(pid);
  PrintStr("\n");

  if (pid == 0) {
    PrintStr("5: child execve\n");
    sys_execve(path, argv, 0);
    PrintStr("6: execve failed\n");
    os_exit(127);
  }

  PrintStr("7: parent waiting\n");
  var st: int64 := mmap(0, 8, 3, 34, -1, 0);
  sys_wait4(pid, st, 0);
  PrintStr("8: done\n");
  munmap(st, 8);
  munmap(argv, 48);
}
