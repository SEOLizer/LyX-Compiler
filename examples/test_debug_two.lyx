// More debug between commands
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    var sent: int64 := sys_write(conn.fd, req, 18);
    PrintStr("wrote ");
    PrintInt(sent);
    PrintStr("\n");
    
    var buf: pchar := "                    ";
    var n: int64 := sys_read(conn.fd, buf, 32);
    PrintStr("read1 ");
    PrintInt(n);
    PrintStr("\n");
    
    // Debug before second command
    PrintStr("before 2nd write\n");
    
    req := "*1\r\n$4\r\nPING\r\n";
    sent := sys_write(conn.fd, req, 18);
    PrintStr("wrote2 ");
    PrintInt(sent);
    PrintStr("\n");
    
    PrintStr("before 2nd read\n");
    n := sys_read(conn.fd, buf, 32);
    PrintStr("read2 ");
    PrintInt(n);
    PrintStr("\n");
    
    sys_close(conn.fd);
    return 0;
}