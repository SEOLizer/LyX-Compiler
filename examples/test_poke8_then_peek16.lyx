// Test poke8 THEN peek16 after
fn main(): int64 {
    PrintStr("=== Test poke8 then peek16 ===\n");
    
    var buf: int64 := mmap(0, 4096, 3, 34, -1, 0);
    PrintStr("mmap = ");
    PrintInt(buf);
    PrintStr("\n");
    
    // Just poke8
    poke8(buf, 65);
    PrintStr("Wrote 65\n");
    
    // Now peek16 (NOT peek8)
    var val: int64 := peek16(buf);
    PrintStr("peek16 = ");
    PrintInt(val);
    PrintStr("\n");
    
    munmap(buf, 4096);
    PrintStr("Done\n");
    return 0;
}