// Test with a file instead of socket
import std.fs;

fn main(): int64 {
    PrintStr("=== Test with file ===\n");
    
    // Create a test file
    var fd: int64 := sys_open("/tmp/testfile.txt", 65, 384);  // O_WRONLY|O_CREAT, 0600
    if (fd < 0) { 
        PrintStr("open failed\n"); 
        return 1; 
    }
    PrintStr("File opened for writing\n");
    
    // Write test data
    var data: pchar := "Line 1\nLine 2\nLine 3\n";
    var n: int64 := sys_write(fd, data, 18);
    PrintStr("Wrote ");
    PrintInt(n);
    PrintStr(" bytes\n");
    
    sys_close(fd);
    PrintStr("Closed file\n");
    
    // Now open for reading
    fd := sys_open("/tmp/testfile.txt", 0, 0);  // O_RDONLY
    if (fd < 0) { 
        PrintStr("open for read failed\n"); 
        return 1; 
    }
    PrintStr("File opened for reading\n");
    
    var buf: pchar := "                    ";
    
    // First read
    n := sys_read(fd, buf, 32);
    PrintStr("First read n = ");
    PrintInt(n);
    PrintStr(", buf = [");
    PrintStr(buf);
    PrintStr("]\n");
    
    // Second read
    n := sys_read(fd, buf, 32);
    PrintStr("Second read n = ");
    PrintInt(n);
    PrintStr(", buf = [");
    PrintStr(buf);
    PrintStr("]\n");
    
    sys_close(fd);
    PrintStr("Done\n");
    
    return 0;
}