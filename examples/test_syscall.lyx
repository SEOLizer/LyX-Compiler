// Test fd-basierte I/O (Builtins)
fn main(): int64 {
  var fd: int64 := 0;
  var ret: int64 := 0;
  var buf: pchar := "";
  var path: pchar := "/tmp/lyx_test.txt";
  
  PrintStr("=== Testing open/read/write/close ===\n");
  
  // Datei erstellen und beschreiben
  // O_WRONLY | O_CREAT | O_TRUNC = 1 | 64 | 512 = 577
  fd := open(path, 577, 420);
  if (fd < 0) {
    PrintStr("ERROR: Could not create file\n");
    return 1;
  }
  PrintStr("File opened, fd=");
  PrintInt(fd);
  PrintStr("\n");
  
  // String schreiben mit newline
  buf := "Hello from Lyx!\n";
  ret := write(fd, buf, 15);
  PrintStr("Written ");
  PrintInt(ret);
  PrintStr(" bytes\n");
  
  close(fd);
  PrintStr("File closed\n");
  
  // Datei erneut öffnen und lesen (O_RDONLY = 0)
  fd := open(path, 0, 0);
  if (fd < 0) {
    PrintStr("ERROR: Could not open file for reading\n");
    return 1;
  }
  PrintStr("File reopened for reading, fd=");
  PrintInt(fd);
  PrintStr("\n");
  
  // Lesepuffer - mit '\0' initialisieren für korrekte String-Ausgabe
  buf := "                ";
  ret := read(fd, buf, 10);
  PrintStr("Read ");
  PrintInt(ret);
  PrintStr(" bytes: [");
  PrintStr(buf);
  PrintStr("]\n");
  
  // Nochmal lesen (Rest)
  ret := read(fd, buf, 10);
  PrintStr("Read ");
  PrintInt(ret);
  PrintStr(" more bytes: [");
  PrintStr(buf);
  PrintStr("]\n");
  
  close(fd);
  
  // Prüfen ob Datei existiert mit erneutem open
  fd := open(path, 0, 0);
  if (fd >= 0) {
    PrintStr("File exists and can be opened\n");
    close(fd);
  }
  
  PrintStr("=== Test complete ===\n");
  
  return 0;
}
