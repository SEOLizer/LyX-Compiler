// Test erweiterte I/O-Funktionen (v0.3.1)
fn main(): int64 {
  var fd: int64 := 0;
  var ret: int64 := 0;
  var buf: pchar := "";
  var path: pchar := "/tmp/lyx_io_test.txt";
  var path2: pchar := "/tmp/lyx_io_test_renamed.txt";
  var dirpath: pchar := "/tmp/lyx_test_dir";
  
  PrintStr("=== Testing extended I/O functions ===\n\n");
  
  // 1. Datei erstellen und schreiben
  PrintStr("1. Create and write file...\n");
  fd := open(path, 577, 420);  // O_WRONLY|O_CREAT|O_TRUNC
  if (fd < 0) {
    PrintStr("ERROR: Could not create file\n");
    return 1;
  }
  buf := "Hello Lyx I/O\n";
  ret := write(fd, buf, 13);
  PrintStr("  Written ");
  PrintInt(ret);
  PrintStr(" bytes, fd=");
  PrintInt(fd);
  PrintStr("\n");
  close(fd);
  
  // 2. lseek testen - zum Anfang zurückspringen
  PrintStr("2. Test lseek (SEEK_SET=0)...\n");
  fd := open(path, 0, 0);  // O_RDONLY
  if (fd < 0) {
    PrintStr("ERROR: Could not open file\n");
    return 1;
  }
  ret := lseek(fd, 0, 0);  // SEEK_SET
  PrintStr("  lseek to start: ");
  PrintInt(ret);
  PrintStr("\n");
  
  // Lesen
  buf := "                ";
  ret := read(fd, buf, 8);
  PrintStr("  Read ");
  PrintInt(ret);
  PrintStr(" bytes: '");
  PrintStr(buf);
  PrintStr("'\n");
  close(fd);
  
  // 3. rename testen
  PrintStr("3. Test rename...\n");
  ret := rename(path, path2);
  PrintStr("  rename result: ");
  PrintInt(ret);
  PrintStr("\n");
  
  // Prüfen ob alter Name nicht mehr existiert
  fd := open(path, 0, 0);
  if (fd < 0) {
    PrintStr("  Old file correctly does not exist\n");
  } else {
    PrintStr("  ERROR: Old file still exists!\n");
    close(fd);
    return 1;
  }
  
  // Prüfen ob neuer Name existiert
  fd := open(path2, 0, 0);
  if (fd >= 0) {
    PrintStr("  New file exists\n");
    close(fd);
  } else {
    PrintStr("  ERROR: New file does not exist!\n");
    return 1;
  }
  
  // 4. unlink testen
  PrintStr("4. Test unlink...\n");
  ret := unlink(path2);
  PrintStr("  unlink result: ");
  PrintInt(ret);
  PrintStr("\n");
  
  // Prüfen ob gelöscht
  fd := open(path2, 0, 0);
  if (fd < 0) {
    PrintStr("  File correctly deleted\n");
  } else {
    PrintStr("  ERROR: File still exists!\n");
    close(fd);
    return 1;
  }
  
  // 5. mkdir testen
  PrintStr("5. Test mkdir...\n");
  ret := mkdir(dirpath, 493);  // 0755 = 493
  PrintStr("  mkdir result: ");
  PrintInt(ret);
  PrintStr("\n");
  
  // 6. chmod testen
  PrintStr("6. Test chmod...\n");
  ret := chmod(dirpath, 448);  // 0700 = 448
  PrintStr("  chmod result: ");
  PrintInt(ret);
  PrintStr("\n");
  
  // 7. rmdir testen
  PrintStr("7. Test rmdir...\n");
  ret := rmdir(dirpath);
  PrintStr("  rmdir result: ");
  PrintInt(ret);
  PrintStr("\n");
  
  PrintStr("\n=== All extended I/O tests PASSED ===\n");
  return 0;
}
