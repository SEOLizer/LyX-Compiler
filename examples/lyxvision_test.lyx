// examples/lyxvision_test.lyx
// LyxVision - Minimales Testprogramm mit ANSI-Support
// Demonstriert ANSI-Terminal-Steuerung mit \e und \xNN Escape-Sequenzen

// ============================================================================
// Terminal-Funktionen (ANSI)
// ============================================================================

fn ClearScreen() {
  PrintStr("\e[2J");   // Clear screen
  PrintStr("\e[H");    // Cursor home
}

fn MoveCursor(x: int64, y: int64) {
  PrintStr("\e[");
  PrintInt(y);
  PrintStr(";");
  PrintInt(x);
  PrintStr("H");
}

fn HideCursor() {
  PrintStr("\e[?25l");
}

fn ShowCursor() {
  PrintStr("\e[?25h");
}

fn SetForeground(color: int64) {
  // 0=black, 1=red, 2=green, 3=yellow, 4=blue, 5=magenta, 6=cyan, 7=white
  PrintStr("\e[");
  PrintInt(30 + color);
  PrintStr("m");
}

fn SetBackground(color: int64) {
  PrintStr("\e[");
  PrintInt(40 + color);
  PrintStr("m");
}

fn SetBrightForeground(color: int64) {
  PrintStr("\e[");
  PrintInt(90 + color);
  PrintStr("m");
}

fn ResetColors() {
  PrintStr("\e[0m");
}

fn SetBold() {
  PrintStr("\e[1m");
}

fn SetReverse() {
  PrintStr("\e[7m");
}

// ============================================================================
// Box-Zeichnung (Unicode)
// ============================================================================

fn DrawBox(x1: int64, y1: int64, x2: int64, y2: int64) {
  // Obere Zeile
  MoveCursor(x1, y1);
  PrintStr("+");
  var x: int64 := x1 + 1;
  while (x < x2) {
    PrintStr("-");
    x := x + 1;
  }
  PrintStr("+");
  
  // Mittlere Zeilen
  var y: int64 := y1 + 1;
  while (y < y2) {
    MoveCursor(x1, y);
    PrintStr("|");
    MoveCursor(x2, y);
    PrintStr("|");
    y := y + 1;
  }
  
  // Untere Zeile
  MoveCursor(x1, y2);
  PrintStr("+");
  x := x1 + 1;
  while (x < x2) {
    PrintStr("-");
    x := x + 1;
  }
  PrintStr("+");
}

fn FillRect(x1: int64, y1: int64, x2: int64, y2: int64) {
  var y: int64 := y1;
  while (y <= y2) {
    MoveCursor(x1, y);
    var x: int64 := x1;
    while (x <= x2) {
      PrintStr(" ");
      x := x + 1;
    }
    y := y + 1;
  }
}

// ============================================================================
// Hauptprogramm
// ============================================================================

fn main(): int64 {
  // Terminal vorbereiten
  HideCursor();
  ClearScreen();
  
  // Hintergrund: Blau
  SetBackground(4);  // Blue
  FillRect(1, 1, 80, 24);
  
  // Titelleiste
  SetBackground(7);  // White/Light gray
  SetForeground(0);  // Black
  MoveCursor(1, 1);
  var i: int64 := 0;
  while (i < 80) {
    PrintStr(" ");
    i := i + 1;
  }
  MoveCursor(28, 1);
  PrintStr(" LyxVision Test v0.1.0 ");
  
  // Statuszeile
  MoveCursor(1, 24);
  i := 0;
  while (i < 80) {
    PrintStr(" ");
    i := i + 1;
  }
  MoveCursor(2, 24);
  PrintStr(" Press Enter to exit ");
  MoveCursor(60, 24);
  PrintStr(" LyxVision 0.1.0 ");
  
  // Hauptbox
  SetBackground(4);  // Blue
  SetBrightForeground(3);  // Bright yellow
  DrawBox(20, 6, 60, 18);
  
  // Box-Inhalt
  SetBrightForeground(7);  // White
  MoveCursor(32, 8);
  PrintStr("LyxVision");
  
  SetBrightForeground(6);  // Cyan
  MoveCursor(25, 10);
  PrintStr("Text User Interface Framework");
  MoveCursor(28, 11);
  PrintStr("for the Lyx Language");
  
  // Features
  SetBrightForeground(2);  // Green
  MoveCursor(24, 13);
  PrintStr("Features:");
  
  SetForeground(7);  // Light gray
  MoveCursor(26, 14);
  PrintStr("- ANSI Terminal Support");
  MoveCursor(26, 15);
  PrintStr("- Escape sequences: \\e, \\xNN");
  MoveCursor(26, 16);
  PrintStr("- Box drawing and colors");
  
  // Hinweis
  SetBrightForeground(3);  // Yellow
  MoveCursor(30, 20);
  PrintStr("Press Enter...");
  
  // Warte auf Enter
  var buf: pchar := "          ";
  var n: int64 := read(0, buf, 1);
  
  // Aufräumen
  ResetColors();
  ShowCursor();
  ClearScreen();
  
  PrintStr("Goodbye from LyxVision!\n");
  
  return 0;
}
