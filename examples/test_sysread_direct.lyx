// Test reading with sys_read directly (not via TCPConn)
import std.net.socket;

fn main(): int64 {
    PrintStr("=== Test sys_read directly ===\n");
    
    // Connect using TCPConnect
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected, fd = ");
    PrintInt(conn.fd);
    PrintStr("\n");
    
    // Send SET
    var req: pchar := "*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n";
    var sent: int64 := sys_write(conn.fd, req, 36);  // use sys_write directly
    PrintStr("SET sent: ");
    PrintInt(sent);
    PrintStr("\n");
    
    // Read response with sys_read directly (not TCPConnRead!)
    var buf: pchar := "                    ";
    var n: int64 := sys_read(conn.fd, buf, 32);  // direct sys_read
    PrintStr("SET response n = ");
    PrintInt(n);
    PrintStr(", buf = [");
    PrintStr(buf);
    PrintStr("]\n");
    
    // Send GET
    req := "*2\r\n$3\r\nGET\r\n$3\r\nkey\r\n";
    sent := sys_write(conn.fd, req, 26);
    PrintStr("GET sent: ");
    PrintInt(sent);
    PrintStr("\n");
    
    // Read response with sys_read directly
    n := sys_read(conn.fd, buf, 32);
    PrintStr("GET response n = ");
    PrintInt(n);
    PrintStr(", buf = [");
    PrintStr(buf);
    PrintStr("]\n");
    
    sys_close(conn.fd);
    PrintStr("Done\n");
    
    return 0;
}