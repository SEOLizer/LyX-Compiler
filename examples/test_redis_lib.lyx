// Test full Redis operations with std.db.redis
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Redis SET/GET Test ===\n");
    
    // Connect to Redis
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    
    if (conn.fd < 0) {
        PrintStr("Failed to connect\n");
        return 1;
    }
    
    PrintStr("Connected!\n");
    
    // Ping
    var ping_ok: bool := RedisPing(conn);
    PrintStr("Ping: ");
    if (ping_ok) { PrintStr("OK\n"); } else { PrintStr("FAILED\n"); }
    
    // Set key
    PrintStr("Setting testkey = helloworld...\n");
    var set_reply: RedisReply := RedisSet(conn, "testkey", "helloworld");
    PrintStr("SET reply kind: ");
    PrintInt(set_reply.kind);
    PrintStr("\n");
    if (set_reply.str_val != "") {
        PrintStr("SET reply: ");
        PrintStr(set_reply.str_val);
        PrintStr("\n");
    }
    
    // Get key
    PrintStr("Getting testkey...\n");
    var get_reply: RedisReply := RedisGet(conn, "testkey");
    PrintStr("GET reply kind: ");
    PrintInt(get_reply.kind);
    PrintStr("\n");
    if (get_reply.str_val != "") {
        PrintStr("GET value: ");
        PrintStr(get_reply.str_val);
        PrintStr("\n");
    }
    
    // Close
    RedisClose(conn);
    PrintStr("Done.\n");
    
    return 0;
}