fn test1(v: int64, dst: int64): void {
  poke64(dst + 0, v);
}
fn test2(path: pchar, dst: int64): void {
  poke64(dst + 8, path as int64);
}
fn test3(path: pchar, dst: int64): void {
  poke64(dst + 0, path as int64);
}

fn main(): void {
  var buf: int64 := mmap(0, 32, 3, 34, -1, 0);
  test1(12345, buf);
  PrintStr("t1: ");
  PrintInt(peek64(buf + 0));
  PrintStr("\n");
  test2("/hello", buf);
  PrintStr("t2: ");
  PrintInt(peek64(buf + 8));
  PrintStr("\n");
  PrintStr("t3: start\n");
  test3("/world", buf);
  PrintStr("t3: done\n");
  munmap(buf, 32);
}
