// Test passing mmap result directly vs cast
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    var my_fd: int64 := conn.fd;
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(my_fd, req, 18);
    
    // Test 1: pass mmap int64 directly
    var buf_int: int64 := mmap(0, 64, 3, 34, -1, 0);
    PrintStr("mmap = ");
    PrintInt(buf_int);
    PrintStr("\n");
    
    var n: int64 := Read(my_fd, buf_int, 64);
    PrintStr("Read(int64) n = ");
    PrintInt(n);
    PrintStr("\n");
    PrintStr("peek8(buf_int) = ");
    PrintInt(peek8(buf_int));
    PrintStr("\n");
    
    // Test 2: pass same int64 as pchar
    // Can't really cast in Lyx...
    
    munmap(buf_int, 64);
    Close(conn.fd);
    return 0;
}