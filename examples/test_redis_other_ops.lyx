// Test with string concatenation to verify args
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Test with explicit args ===\n");
    
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("Connected\n");
    
    // First test HSET which also uses *4 format
    var r: RedisReply := RedisHSet(conn, "myhash", "field1", "value1");
    PrintStr("HSET result: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // Test SADD (also *3)
    r := RedisSAdd(conn, "myset", "member1");
    PrintStr("SADD result: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // Test ZADD (*4)
    r := RedisZAdd(conn, "myzset", 10, "member1");
    PrintStr("ZADD result: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // Let's try EXPIRE (*3)
    RedisSet(conn, "testkey", "testvalue");
    var exp: int64 := RedisExpire(conn, "testkey", 60);
    PrintStr("EXPIRE result: ");
    PrintInt(exp);
    PrintStr("\n");
    
    // Try HINCRBY
    r := RedisHIncrBy(conn, "myhash", "counter", 1);
    PrintStr("HINCRBY result: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}