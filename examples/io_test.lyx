fn main(): int64 {
    // Testdatei-Name
    let filename: pchar = "/tmp/testfile.txt";
    let write_text: pchar = "Hello Lyx IO!";
    let buffer: pchar = alloc(200); // Buffer für 200 Bytes

    // --- Schreiben ---
    // open(path, flags, mode)
    // O_CREAT = 64 (0o100)
    // O_WRONLY = 1 (0o1)
    // O_TRUNC = 512 (0o1000)
    // Mode: S_IRUSR = 256 (0o400), S_IWUSR = 128 (0o200) -> 0o600 = 384
    let fd_write: int64 = open(filename, 64 | 1 | 512, 384);
    if fd_write < 0 {
        PrintStr("Fehler beim Öffnen zum Schreiben!");
        return 1;
    }
    let bytes_written: int64 = write(fd_write, write_text, 13); // "Hello Lyx IO!" ist 13 Bytes
    if bytes_written != 13 {
        PrintStr("Fehler beim Schreiben!");
        close(fd_write);
        return 2;
    }
    close(fd_write);

    // --- Lesen ---
    // O_RDONLY = 0
    let fd_read: int64 = open(filename, 0, 0);
    if fd_read < 0 {
        PrintStr("Fehler beim Öffnen zum Lesen!");
        return 3;
    }
    let bytes_read: int64 = read(fd_read, buffer, 200);
    if bytes_read <= 0 {
        PrintStr("Fehler beim Lesen oder leere Datei!");
        close(fd_read);
        return 4;
    }
    close(fd_read);

    // Null-Terminierung für PrintStr
    buf_put_byte(buffer, bytes_read, 0);

    PrintStr("Gelesen: ");
    PrintStr(buffer);
    PrintStr("\n");

    return 0;
}
