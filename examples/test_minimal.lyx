// Minimal write-read-exit test
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    sys_write(conn.fd, req, 18);
    
    var buf: pchar := "                    ";
    var n: int64 := sys_read(conn.fd, buf, 32);
    
    // Print result immediately then exit
    PrintStr("n=");
    PrintInt(n);
    PrintStr(" buf=");
    PrintStr(buf);
    PrintStr("\n");
    
    sys_close(conn.fd);
    return 0;
}