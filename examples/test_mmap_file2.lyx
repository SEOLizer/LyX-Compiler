// Test mmap with a simple file write/read cycle
import std.fs;

fn main(): int64 {
    PrintStr("=== Test mmap with file ===\n");
    
    // Create file
    var fd: int64 := open("/tmp/mmap_test.txt", 65, 384);  // O_WRONLY|O_CREAT
    if (fd < 0) {
        PrintStr("open failed\n");
        return 1;
    }
    PrintStr("file opened\n");
    
    // mmap a buffer
    var buf: int64 := mmap(0, 64, 3, 34, -1, 0);
    PrintStr("mmap = ");
    PrintInt(buf);
    PrintStr("\n");
    
    // Write to mmap
    poke8(buf, 65);  // 'A'
    poke8(buf + 1, 66);  // 'B'
    poke8(buf + 2, 67);  // 'C'
    PrintStr("wrote ABC to mmap\n");
    
    // Write mmap content to file
    var n: int64 := write(fd, buf, 3);
    PrintStr("wrote to file: ");
    PrintInt(n);
    PrintStr("\n");
    
    // Close and reopen
    close(fd);
    fd := open("/tmp/mmap_test.txt", 0, 0);  // O_RDONLY
    
    // Read file into mmap
    n := read(fd, buf, 64);
    PrintStr("read from file: ");
    PrintInt(n);
    PrintStr("\n");
    
    // Check what we read
    var v1: int64 := peek8(buf);
    var v2: int64 := peek8(buf + 1);
    var v3: int64 := peek8(buf + 2);
    PrintStr("read: ");
    PrintInt(v1);
    PrintStr(" ");
    PrintInt(v2);
    PrintStr(" ");
    PrintInt(v3);
    PrintStr("\n");
    
    close(fd);
    munmap(buf, 64);
    PrintStr("done\n");
    
    return 0;
}