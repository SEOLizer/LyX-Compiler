// Test - copy the first buffer content before second read
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    
    var my_fd: int64 := conn.fd;
    
    // First command
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(my_fd, req, 18);
    
    var buf1: pchar := "                    ";
    var n: int64 := Read(my_fd, buf1, 32);
    PrintStr("read1 = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Copy buf1 to a second buffer
    var copy: pchar := "                    ";
    var i: int64 := 0;
    while (i < 16) {
        var c: int64 := StrCharAt(buf1, i);
        StrSetChar(copy, i, c);
        i := i + 1;
    }
    PrintStr("copied: [");
    PrintStr(copy);
    PrintStr("]\n");
    
    // Second command
    req := "*1\r\n$4\r\nPING\r\n";
    Write(my_fd, req, 18);
    PrintStr("wrote2\n");
    
    // Read into SAME buf1 variable again (this fails)
    PrintStr("about to read2 with buf1...\n");
    n := Read(my_fd, buf1, 32);
    PrintStr("read2 = ");
    PrintInt(n);
    PrintStr("\n");
    
    // If that didn't work, try with copy
    if (n <= 0) {
        n := Read(my_fd, copy, 32);
        PrintStr("read2 with copy = ");
        PrintInt(n);
        PrintStr("\n");
    }
    
    Close(conn.fd);
    return 0;
}