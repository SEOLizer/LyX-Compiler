// Full Redis test with proper sockaddr initialization
fn main(): int64 {
    PrintStr("=== Redis Full Test ===\n");
    
    // Create socket
    var fd: int64 := sys_socket(2, 1, 0);
    PrintStr("socket = ");
    PrintInt(fd);
    PrintStr("\n");
    
    if (fd < 0) { return 1; }
    
    // Create address buffer with mmap
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    
    // CRITICAL: Initialize buffer to zero first!
    var j: int64 := 0;
    while (j < 16) {
        poke8(addr + j, 0);
        j := j + 1;
    }
    
    // sin_family = AF_INET (2)
    poke8(addr, 2);
    poke8(addr + 1, 0);
    
    // sin_port = 6379 in network order (0x18EB)
    poke8(addr + 2, 0x18);
    poke8(addr + 3, 0xEB);
    
    // sin_addr = 127.0.0.1 in network order
    poke8(addr + 4, 127);  // first byte
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    
    // Connect
    var cr: int64 := sys_connect(fd, addr, 16);
    PrintStr("connect = ");
    PrintInt(cr);
    PrintStr("\n");
    
    if (cr != 0) {
        PrintStr("Connect failed!\n");
        sys_close(fd);
        munmap(addr, 16);
        return 1;
    }
    
    PrintStr("Connected!\n");
    
    // Send PING using poke8
    var reqbuf: int64 := mmap(0, 64, 3, 34, -1, 0);
    
    // "*1\r\n$4\r\nPING\r\n"
    poke8(reqbuf + 0, 42);  // *
    poke8(reqbuf + 1, 49);  // 1
    poke8(reqbuf + 2, 13);  // \r
    poke8(reqbuf + 3, 10);  // \n
    poke8(reqbuf + 4, 36);  // $
    poke8(reqbuf + 5, 52);  // 4
    poke8(reqbuf + 6, 13);  // \r
    poke8(reqbuf + 7, 10);  // \n
    poke8(reqbuf + 8, 80);  // P
    poke8(reqbuf + 9, 73);  // I
    poke8(reqbuf + 10, 78); // N
    poke8(reqbuf + 11, 71); // G
    poke8(reqbuf + 12, 13); // \r
    poke8(reqbuf + 13, 10); // \n
    
    var w: int64 := sys_write(fd, reqbuf, 14);
    PrintStr("write = ");
    PrintInt(w);
    PrintStr("\n");
    
    // Read response
    var respbuf: int64 := mmap(0, 256, 3, 34, -1, 0);
    var n: int64 := sys_read(fd, respbuf, 200);
    PrintStr("read n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Can't use peek8 reliably, so we can't read individual bytes
    // But the response is in the buffer - let's just try getting more data
    // or accept that this is the limitation
    
    // Actually, let's try sys_write again to verify connection still works
    // Send another PING
    w := sys_write(fd, reqbuf, 14);
    PrintStr("write2 = ");
    PrintInt(w);
    PrintStr("\n");
    
    n := sys_read(fd, respbuf + 64, 64);
    PrintStr("read2 n = ");
    PrintInt(n);
    PrintStr("\n");
    
    sys_close(fd);
    munmap(reqbuf, 64);
    munmap(respbuf, 256);
    munmap(addr, 16);
    
    PrintStr("Done\n");
    return 0;
}