// Test where crash happens after LPOP
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    } else {
        PrintStr("PING failed\n");
    }
    
    RedisDel(conn, "mylist");
    
    // 3x LPUSH
    var r: RedisReply := RedisLPush(conn, "mylist", "first");
    PrintStr("LPUSH first done\n");
    
    r := RedisLPush(conn, "mylist", "second");
    PrintStr("LPUSH second done\n");
    
    r := RedisLPush(conn, "mylist", "third");
    PrintStr("LPUSH third done\n");
    
    // LLEN
    var llen: int64 := RedisLLen(conn, "mylist");
    PrintStr("LLEN = ");
    PrintInt(llen);
    PrintStr("\n");
    
    // FIRST LPOP
    r := RedisLPop(conn, "mylist");
    PrintStr("LPOP 1 done, kind=");
    PrintInt(r.kind);
    PrintStr(" str_len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    // SECOND LPOP - this is where it might crash
    r := RedisLPop(conn, "mylist");
    PrintStr("LPOP 2 done, kind=");
    PrintInt(r.kind);
    PrintStr(" str_len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    // Third LPOP
    r := RedisLPop(conn, "mylist");
    PrintStr("LPOP 3 done, kind=");
    PrintInt(r.kind);
    PrintStr(" str_len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    // Fourth LPOP on empty list
    r := RedisLPop(conn, "mylist");
    PrintStr("LPOP 4 (empty) done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // Try LLEN after all pops
    llen := RedisLLen(conn, "mylist");
    PrintStr("LLEN after all pops = ");
    PrintInt(llen);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}