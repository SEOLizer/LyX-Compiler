// Test: 3 struct functions in sequence - simpler pattern
import std.db.redis;

fn test1(conn: RedisConn): RedisReply {
    var reqbuf: int64 := mmap(0, 256, 3, 34, -1, 0);
    if (reqbuf <= 0) {
        var empty: RedisReply;
        return empty;
    }
    var pos: int64 := 0;
    poke8(reqbuf + pos, 42); pos := pos + 1;
    poke8(reqbuf + pos, 50); pos := pos + 1;
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    pos := appendBulk(reqbuf, pos, "LPOP");
    pos := appendBulk(reqbuf, pos, "testkey");
    var reply: RedisReply := sendRaw(conn, reqbuf, pos);
    munmap(reqbuf, 256);
    return reply;
}

