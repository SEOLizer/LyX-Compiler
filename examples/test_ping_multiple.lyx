// Test individual commands
import std.net.socket;

fn main(): int64 {
    PrintStr("=== Test commands individually ===\n");
    
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { PrintStr("Connect failed\n"); return 1; }
    PrintStr("Connected\n");
    
    var buf: pchar := "                    ";
    var n: int64;
    var req: pchar;
    
    // PING 1
    req := "*1\r\n$4\r\nPING\r\n";
    sys_write(conn.fd, req, 18);
    n := sys_read(conn.fd, buf, 32);
    PrintStr("PING1 n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // PING 2
    req := "*1\r\n$4\r\nPING\r\n";
    sys_write(conn.fd, req, 18);
    n := sys_read(conn.fd, buf, 32);
    PrintStr("PING2 n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // PING 3
    req := "*1\r\n$4\r\nPING\r\n";
    sys_write(conn.fd, req, 18);
    n := sys_read(conn.fd, buf, 32);
    PrintStr("PING3 n = ");
    PrintInt(n);
    PrintStr("\n");
    
    sys_close(conn.fd);
    PrintStr("Done\n");
    
    return 0;
}