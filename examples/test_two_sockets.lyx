// Test multiple sockets vs multiple reads on same socket
fn main(): int64 {
    PrintStr("=== Test two sockets ===\n");
    
    // Socket 1: connect to Redis
    var fd1: int64 := sys_socket(2, 1, 0);
    var addr1: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(addr1, 2);
    poke8(addr1 + 2, 0x18);
    poke8(addr1 + 3, 0xEB);
    poke8(addr1 + 4, 0x7F);
    poke8(addr1 + 5, 0);
    poke8(addr1 + 6, 0);
    poke8(addr1 + 7, 1);
    sys_connect(fd1, addr1, 16);
    munmap(addr1, 16);
    PrintStr("socket1 connected\n");
    
    // Socket 2: connect to Redis again
    var fd2: int64 := sys_socket(2, 1, 0);
    var addr2: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(addr2, 2);
    poke8(addr2 + 2, 0x18);
    poke8(addr2 + 3, 0xEB);
    poke8(addr2 + 4, 0x7F);
    poke8(addr2 + 5, 0);
    poke8(addr2 + 6, 0);
    poke8(addr2 + 7, 1);
    sys_connect(fd2, addr2, 16);
    munmap(addr2, 16);
    PrintStr("socket2 connected\n");
    
    // Test read on socket1
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    sys_write(fd1, req, 18);
    
    var buf1: pchar := "                    ";
    var n: int64 := sys_read(fd1, buf1, 32);
    PrintStr("socket1 read = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Test read on socket2
    sys_write(fd2, req, 18);
    
    var buf2: pchar := "                    ";
    n := sys_read(fd2, buf2, 32);
    PrintStr("socket2 read = ");
    PrintInt(n);
    PrintStr("\n");
    
    sys_close(fd1);
    sys_close(fd2);
    return 0;
}