// Test: PING (struct) -> DEL (int64) -> LPUSH -> LPUSH -> LPOP -> RPOP
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    // PING returns bool (int64)
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    } else {
        PrintStr("PING failed\n");
    }
    
    // DEL returns int64
    var delres: int64 := RedisDel(conn, "mylist");
    PrintStr("DEL = ");
    PrintInt(delres);
    PrintStr("\n");
    
    // LPUSH returns struct
    var r: RedisReply := RedisLPush(conn, "mylist", "first");
    PrintStr("LPUSH1 done\n");
    
    // LPUSH returns struct
    r := RedisLPush(conn, "mylist", "second");
    PrintStr("LPUSH2 done\n");
    
    // LPOP returns struct (BULK string)
    r := RedisLPop(conn, "mylist");
    PrintStr("LPOP done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // RPOP returns struct
    r := RedisRPop(conn, "mylist");
    PrintStr("RPOP done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}