// Test with poll() to check if data is available
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    // Prepare pollfd
    var fds: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(fds, conn.fd);        // fd
    poke8(fds + 2, 1);          // events = POLLIN (readable)
    
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    PrintStr("wrote PING\n");
    
    // First poll
    var n: int64 := Poll(fds, 1, 1000);  // 1 second timeout
    PrintStr("poll1 n = ");
    PrintInt(n);
    PrintStr("\n");
    
    if (n > 0) {
        var buf: pchar := "                    ";
        var r: int64 := Read(conn.fd, buf, 32);
        PrintStr("read1 ");
        PrintInt(r);
        PrintStr("\n");
    }
    
    // Second command
    req := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    PrintStr("wrote PING2\n");
    
    // Second poll
    n := Poll(fds, 1, 1000);
    PrintStr("poll2 n = ");
    PrintInt(n);
    PrintStr("\n");
    
    if (n > 0) {
        var buf: pchar := "                    ";
        var r: int64 := Read(conn.fd, buf, 32);
        PrintStr("read2 ");
        PrintInt(r);
        PrintStr("\n");
    }
    
    munmap(fds, 16);
    Close(conn.fd);
    return 0;
}