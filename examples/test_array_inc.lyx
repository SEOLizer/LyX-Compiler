fn main(): int64 {
  var arr: array := [10, 20, 30];
  var idx: int64 := 0;
  
  PrintStr("arr[0] before: ");
  PrintInt(arr[0]);
  PrintStr("\n");
  
  arr[idx]++;
  
  PrintStr("arr[0] after ++: ");
  PrintInt(arr[0]);
  PrintStr("\n");
  
  idx := 1;
          arr[idx]--;
          
  PrintStr("arr[1] after --: ");
          PrintInt(arr[1]);
          PrintStr("\n");
      
          return 0;
        }
