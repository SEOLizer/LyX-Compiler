// Test with explicit fd handling
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    
    // Get the fd into a variable
    var my_fd: int64 := conn.fd;
    PrintStr("my_fd = ");
    PrintInt(my_fd);
    PrintStr("\n");
    
    // Write using the variable
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    var n: int64 := Write(my_fd, req, 18);
    PrintStr("write n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Read into pchar buffer (static allocation via pchar)
    var buf1: pchar := "                    ";
    n := Read(my_fd, buf1, 32);
    PrintStr("read1 n = ");
    PrintInt(n);
    PrintStr(", buf = [");
    PrintStr(buf1);
    PrintStr("]\n");
    
    // Second command - also using the variable
    req := "*1\r\n$4\r\nPING\r\n";
    n := Write(my_fd, req, 18);
    PrintStr("write2 n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Second read - using SAME buffer variable
    var buf2: pchar := "                    ";
    PrintStr("about to read2...\n");
    n := Read(my_fd, buf2, 32);
    PrintStr("read2 n = ");
    PrintInt(n);
    PrintStr("\n");
    
    Close(conn.fd);
    return 0;
}