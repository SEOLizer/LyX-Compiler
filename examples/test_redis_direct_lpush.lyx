// Test with explicit string building (no appendBulk)
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Direct Test ===\n");
    
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("Connected\n");
    
    // Build LPUSH manually without appendBulk
    var reqbuf: int64 := mmap(0, 256, 3, 34, -1, 0);
    var pos: int64 := 0;
    
    // *3\r\n
    poke8(reqbuf + pos, 42); pos := pos + 1;
    poke8(reqbuf + pos, 51); pos := pos + 1;
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    
    // $5\r\nLPUSH\r\n
    poke8(reqbuf + pos, 36); pos := pos + 1;
    poke8(reqbuf + pos, 53); pos := pos + 1;
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    // "LPUSH" = 76 80 85 83 72
    poke8(reqbuf + pos, 76); pos := pos + 1;
    poke8(reqbuf + pos, 80); pos := pos + 1;
    poke8(reqbuf + pos, 85); pos := pos + 1;
    poke8(reqbuf + pos, 83); pos := pos + 1;
    poke8(reqbuf + pos, 72); pos := pos + 1;
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    
    // $8\r\ntestlist\r\n
    poke8(reqbuf + pos, 36); pos := pos + 1;
    poke8(reqbuf + pos, 56); pos := pos + 1;
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    // "testlist" 
    var s: pchar := "testlist";
    var i: int64 := 0;
    while (i < 8) {
        poke8(reqbuf + pos, StrCharAt(s, i));
        pos := pos + 1;
        i := i + 1;
    }
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    
    // $6\r\nvalue1\r\n
    poke8(reqbuf + pos, 36); pos := pos + 1;
    poke8(reqbuf + pos, 54); pos := pos + 1;
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    // "value1"
    s := "value1";
    i := 0;
    while (i < 6) {
        poke8(reqbuf + pos, StrCharAt(s, i));
        pos := pos + 1;
        i := i + 1;
    }
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    
    PrintStr("Sending ");
    PrintInt(pos);
    PrintStr(" bytes\n");
    
    var reply: RedisReply := sendRaw(conn, reqbuf, pos);
    PrintStr("Reply: kind=");
    PrintInt(reply.kind);
    PrintStr("\n");
    
    if (reply.kind == 1) {
        PrintStr("Error response - trying with literals...\n");
    }
    
    munmap(reqbuf, 256);
    RedisClose(conn);
    return 0;
}