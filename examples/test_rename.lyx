// Minimaler Test für rename
fn main(): int64 {
  var ret: int64 := 0;
  var path1: pchar := "/tmp/test_old.txt";
  var path2: pchar := "/tmp/test_new.txt";
  var fd: int64 := 0;
  
  // Datei erstellen
  fd := open(path1, 577, 420);
  if (fd < 0) {
    PrintStr("Cannot create file\n");
    return 1;
  }
  close(fd);
  
  // Rename
  ret := rename(path1, path2);
  PrintStr("rename result: ");
  PrintInt(ret);
  PrintStr("\n");
  
  // Prüfen
  fd := open(path2, 0, 0);
  if (fd >= 0) {
    PrintStr("New file exists\n");
    close(fd);
    unlink(path2);
    return 0;
  }
  
  PrintStr("ERROR\n");
  return 1;
}
