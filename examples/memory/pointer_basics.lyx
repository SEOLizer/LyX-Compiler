// Pointer Basics Demo
// Demonstrates: Pointer-Konzepte, Speicheradressen, Dereferenzierung

fn main(): int64 {
    PrintStr("=== Pointer Basics Demo ===\n\n");
    
    // Pointer erklaeren
    PrintStr("Pointer Grundlagen:\n");
    PrintStr("-------------------\n");
    PrintStr("Ein Pointer speichert eine Speicheradresse.\n");
    PrintStr("Syntax: var p: Pointer\n");
    PrintStr("Dereferenzierung: p as int64 gibt den Wert an der Adresse\n");
    PrintStr("\n");
    
    // Speichergroessen erklaeren
    PrintStr("Speichergroessen (64-bit System):\n");
    PrintStr("----------------------------------\n");
    PrintStr("Pointer:  8 Bytes (64 bits)\n");
    PrintStr("int64:   8 Bytes\n");
    PrintStr("int32:   4 Bytes\n");
    PrintStr("int16:   2 Bytes\n");
    PrintStr("int8:    1 Byte\n");
    PrintStr("\n");
    
    // Adress-Berechnung erklaeren
    PrintStr("Adress-Berechnung:\n");
    PrintStr("------------------\n");
    PrintStr("Wenn Variable bei Adresse 0x1000 liegt:\n");
    PrintStr("  - int64 (8 Bytes) naechste Adresse: 0x1008\n");
    PrintStr("  - int32 (4 Bytes) naechste Adresse: 0x1004\n");
    PrintStr("  - int16 (2 Bytes) naechste Adresse: 0x1002\n");
    PrintStr("  - int8  (1 Byte) naechste Adresse: 0x1001\n");
    PrintStr("\n");
    
    // Pointer-Operationen erklaeren
    PrintStr("Pointer-Operationen:\n");
    PrintStr("--------------------\n");
    PrintStr("1. Adresse nehmen:  &var (nicht in Lyx verfuegbar)\n");
    PrintStr("2. Dereferenzieren: *ptr -> wert\n");
    PrintStr("3. Arithmetik:      ptr + 1 -> naechstes Element\n");
    PrintStr("4. Vergleiche:      ptr1 == ptr2\n");
    PrintStr("\n");
    
    // Beispiel-Speicher-Layout
    PrintStr("Beispiel Speicher-Layout:\n");
    PrintStr("-------------------------\n");
    PrintStr("Adresse   Wert    Variable\n");
    PrintStr("--------   -----   --------\n");
    PrintStr("0x1000     42      x\n");
    PrintStr("0x1008     3.14    pi (f64)\n");
    PrintStr("0x1010     0x1020  ptr (Pointer)\n");
    PrintStr("0x1020     99      y\n");
    PrintStr("\n");
    
    // NULL-Pointer erklaeren
    PrintStr("NULL-Pointer:\n");
    PrintStr("-------------\n");
    PrintStr("NULL = ungueltige Adresse (0)\n");
    PrintStr("Pruefung: if (ptr == 0) { ... }\n");
    PrintStr("Wichtig: Vor Dereferenzierung immer auf NULL pruefen!\n");
    PrintStr("\n");
    
    // void* erklaeren
    PrintStr("Generic Pointer (void*):\n");
    PrintStr("-------------------------\n");
    PrintStr("void* kann auf beliebige Typen zeigen\n");
    PrintStr("Vor Verwendung: cast zu konkretem Typ\n");
    PrintStr("Beispiel: ptr as int64\n");
    PrintStr("\n");
    
    // Konstante Pointer vs Pointer auf Konstante
    PrintStr("Konstante Pointer:\n");
    PrintStr("------------------\n");
    PrintStr("const int64* p  - Pointer auf Konstante (kann erhoeht werden, Wert nicht aenderbar)\n");
    PrintStr("int64* const p  - Konstanter Pointer (Adresse fest, Wert aenderbar)\n");
    PrintStr("const int64* const p - Beides konstant\n");
    PrintStr("\n");
    
    // Typische Fehler
    PrintStr("Typische Pointer-Fehler:\n");
    PrintStr("------------------------\n");
    PrintStr("1. Dereferenzieren von NULL -> Crash\n");
    PrintStr("2. Nach freigegebenem Speicher zugreifen -> Crash\n");
    PrintStr("3. Benutzen von uninitialisierten Pointern -> Crash\n");
    PrintStr("4. Pointer auf lokale Variable nach Funktionsende -> Crash\n");
    PrintStr("\n");
    
    PrintStr("=== Demo abgeschlossen ===\n");
    
    return 0;
}