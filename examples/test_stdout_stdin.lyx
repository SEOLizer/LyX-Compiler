// Test with stdout as sanity check
fn main(): int64 {
    PrintStr("=== Test stdout write ===\n");
    
    var buf: pchar := "ABCDEFGHIJ";
    var n: int64 := sys_write(1, buf, 10);  // Write to stdout
    PrintStr("\nWrote ");
    PrintInt(n);
    PrintStr(" bytes to stdout\n");
    
    // Now read from stdin
    PrintStr("=== Test stdin read ===\n");
    PrintStr("Enter some text:\n");
    
    var readbuf: pchar := "                    ";
    var rn: int64 := sys_read(0, readbuf, 10);  // Read from stdin
    PrintStr("Read ");
    PrintInt(rn);
    PrintStr(" bytes: [");
    PrintStr(readbuf);
    PrintStr("]\n");
    
    return 0;
}