// Simple Redis test - using TCPConn
import std.net.socket;

fn main(): int64 {
    PrintStr("=== Redis Simple Test ===\n");
    
    // Connect using high-level TCPConn
    var conn: TCPConn := TCPConnect(0x0100007F, 6379);  // 127.0.0.1
    
    if (conn.fd < 0) {
        PrintStr("Failed to connect\n");
        return 1;
    }
    
    PrintStr("Connected! FD = ");
    PrintInt(conn.fd);
    PrintStr("\n");
    
    // Send PING using TCPConn
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    var sent: int64 := TCPConnWrite(conn, req, 18);
    
    PrintStr("Sent bytes: ");
    PrintInt(sent);
    PrintStr("\n");
    
    // Read response
    var buf: pchar := "                ";
    var n: int64 := TCPConnRead(conn, buf, 32);
    
    PrintStr("Read bytes: ");
    PrintInt(n);
    PrintStr("\nResponse: ");
    PrintStr(buf);
    PrintStr("\n");
    
    // Close
    TCPConnClose(conn);
    PrintStr("Done.\n");
    
    return 0;
}