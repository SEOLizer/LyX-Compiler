// Test with 16 byte mmap (like working test)
fn main(): int64 {
    PrintStr("start\n");
    var buf: int64 := mmap(0, 16, 3, 34, -1, 0);  // 16 bytes like working test
    PrintStr("mmap = ");
    PrintInt(buf);
    PrintStr("\n");
    
    poke8(buf, 65);
    PrintStr("poke8 done\n");
    
    var v: int64 := peek8(buf);
    PrintStr("peek8 done, value = ");
    PrintInt(v);
    PrintStr("\n");
    
    munmap(buf, 16);
    PrintStr("done\n");
    return 0;
}