// Test adding another LPUSH between LPOP and SADD
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    } else {
        PrintStr("PING failed\n");
    }
    
    RedisDel(conn, "mylist");
    RedisLPush(conn, "mylist", "a");
    RedisLPush(conn, "mylist", "b");
    
    var r: RedisReply := RedisLPop(conn, "mylist");
    PrintStr("LPOP done\n");
    
    // Another LPUSH before SADD
    r := RedisLPush(conn, "mylist2", "x");
    PrintStr("LPUSH2 done\n");
    
    // Now SADD
    r := RedisSAdd(conn, "myset", "apple");
    PrintStr("SADD apple done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}