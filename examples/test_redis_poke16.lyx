// Test Redis using poke16/peek16 (workaround for broken poke8/peek8)
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Redis Test with poke16/peek16 ===\n");
    
    // Use the helper that reads using poke16/peek16
    var conn: RedisConn;
    conn.host := "127.0.0.1";
    conn.port := 6379;
    conn.timeout_ms := 5000;
    
    // Use direct syscalls workaround
    var fd: int64 := sys_socket(2, 1, 0);
    PrintStr("socket = ");
    PrintInt(fd);
    PrintStr("\n");
    
    if (fd < 0) { return 1; }
    
    // Connect
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke16(addr + 0, 2);       // sin_family = AF_INET
    poke16(addr + 2, 0x18EB);    // port 6379 in network order  
    poke32(addr + 4, 0x7F000001);  // 127.0.0.1 in network byte order
    
    var cr: int64 := sys_connect(fd, addr, 16);
    PrintStr("connect = ");
    PrintInt(cr);
    PrintStr("\n");
    
    if (cr < 0) { 
        sys_close(fd); 
        munmap(addr, 16);
        return 1; 
    }
    
    // Send PING using poke16
    var reqbuf: int64 := mmap(0, 64, 3, 34, -1, 0);
    // "*1\r\n$4\r\nPING\r\n"
    poke8(reqbuf + 0, 42);  // *
    poke8(reqbuf + 1, 49);  // 1
    poke8(reqbuf + 2, 13);  // \r
    poke8(reqbuf + 3, 10);  // \n
    poke8(reqbuf + 4, 36);  // $
    poke8(reqbuf + 5, 52);  // 4
    poke8(reqbuf + 6, 13);  // \r
    poke8(reqbuf + 7, 10);  // \n
    poke8(reqbuf + 8, 80);  // P
    poke8(reqbuf + 9, 73);  // I
    poke8(reqbuf + 10, 78); // N
    poke8(reqbuf + 11, 71); // G
    poke8(reqbuf + 12, 13); // \r
    poke8(reqbuf + 13, 10); // \n
    
    var w: int64 := sys_write(fd, reqbuf, 14);
    PrintStr("write = ");
    PrintInt(w);
    PrintStr("\n");
    
    // Read response into mmap buffer
    var respbuf: int64 := mmap(0, 256, 3, 34, -1, 0);
    var n: int64 := sys_read(fd, respbuf, 200);
    PrintStr("read n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Use poke16/peek16 workaround to read bytes
    // Since we can't use peek8, we'll use the fact that sys_read works
    // and just accept that we need a different approach
    
    // Print first few bytes using peek16
    var i: int64 := 0;
    while (i < n && i < 20) {
        // Use a workaround - cast 16-bit read to see if data is there
        var v: int64 := peek16(respbuf + i);
        PrintInt(v);
        PrintStr(" ");
        i := i + 2;
    }
    PrintStr("\n");
    
    sys_close(fd);
    munmap(reqbuf, 64);
    munmap(respbuf, 256);
    munmap(addr, 16);
    
    PrintStr("Done\n");
    return 0;
}