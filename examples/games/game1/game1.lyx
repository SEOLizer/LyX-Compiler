extern fn read(fd: int64, buf: pchar, count: int64): int64;
extern fn write(fd: int64, buf: pchar, count: int64): int64;

fn read_int(): int64 {
  var buf: pchar := "                                        ";
  var i: int64 := 0;
  var ch: int64 := 0;
  
  read(0, buf, 1);
  ch := StrCharAt(buf, 0);
  
  while (ch != 10 && i < 20) {
    if (ch >= 48 && ch <= 57) {
      StrSetChar(buf, i, ch);
      i := i + 1;
    }
    read(0, buf, 1);
    ch := StrCharAt(buf, 0);
  }
  
  StrSetChar(buf, i, 0);
  
  var result: int64 := 0;
  var j: int64 := 0;
  while (j < i) {
    var digit: int64 := StrCharAt(buf, j) - 48;
    result := result * 10 + digit;
    j := j + 1;
  }
  
  return result;
}

fn main(): int64 {
  var secret: int64 := 0;
  var guess: int64 := 0;
  var attempts: int64 := 0;
  var won: bool := false;
  
  PrintStr("=== ZAHLENRATEN ===\n");
  PrintStr("\n");
  PrintStr("GAMEMASTER: Bitte geheime Zahl eingeben (0-100): ");
  secret := read_int();
  PrintStr("\n");
  
  if (secret < 0 || secret > 100) {
    PrintStr("FEHLER: Zahl muss zwischen 0 und 100 liegen!\n");
    return 1;
  }
  
  PrintStr("\n");
  PrintStr("=== SPIEL STARTET ===\n");
  PrintStr("Rate die Zahl! Du hast 10 Versuche.\n");
  PrintStr("\n");
  
  attempts := 0;
  won := false;
  
  while (attempts < 10) {
    PrintStr("Versuch ");
    PrintInt(attempts + 1);
    PrintStr("/10 - Dein Tipp: ");
    guess := read_int();
    PrintStr("\n");
    
    if (guess == secret) {
      won := true;
      attempts := 10;
    } else {
      if (guess < secret) {
        PrintStr("Die Zahl ist GROESSER!\n");
      } else {
        PrintStr("Die Zahl ist KLEINER!\n");
      }
      attempts := attempts + 1;
    }
    PrintStr("\n");
  }
  
  if (won) {
    PrintStr("=== GEWONNEN! ===\n");
    PrintStr("Du hast die Zahl erraten!\n");
  } else {
    PrintStr("=== VERLOREN! ===\n");
    PrintStr("Die Zahl war: ");
    PrintInt(secret);
    PrintStr("\n");
    PrintStr("Mehr Glueck beim naechsten Mal!\n");
  }
  
  return 0;
}
