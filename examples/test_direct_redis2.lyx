// Test using direct syscalls without std.db.redis import
fn main(): int64 {
    PrintStr("=== Direct syscalls test ===\n");
    
    // Connect
    var fd: int64 := sys_socket(2, 1, 0);
    PrintStr("fd = ");
    PrintInt(fd);
    PrintStr("\n");
    
    if (fd < 0) { return 1; }
    
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(addr, 2);
    poke8(addr + 2, 0x18);
    poke8(addr + 3, 0xEB);
    poke8(addr + 4, 0x7F);
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    
    var result: int64 := sys_connect(fd, addr, 16);
    munmap(addr, 16);
    PrintStr("connect result = ");
    PrintInt(result);
    PrintStr("\n");
    
    if (result < 0) {
        sys_close(fd);
        return 1;
    }
    
    // SET
    var req: pchar := "*3\r\n$3\r\nSET\r\n$4\r\ntest\r\n$5\r\nworld\r\n";
    sys_write(fd, req, 40);
    var buf: pchar := "                    ";
    var n: int64 := sys_read(fd, buf, 32);
    PrintStr("SET: n=");
    PrintInt(n);
    PrintStr(" [");
    PrintStr(buf);
    PrintStr("]\n");
    
    sys_close(fd);
    
    // Reconnect for GET
    fd := sys_socket(2, 1, 0);
    addr := mmap(0, 16, 3, 34, -1, 0);
    poke8(addr, 2);
    poke8(addr + 2, 0x18);
    poke8(addr + 3, 0xEB);
    poke8(addr + 4, 0x7F);
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    sys_connect(fd, addr, 16);
    munmap(addr, 16);
    
    req := "*2\r\n$3\r\nGET\r\n$4\r\ntest\r\n";
    sys_write(fd, req, 26);
    n := sys_read(fd, buf, 32);
    PrintStr("GET: n=");
    PrintInt(n);
    PrintStr(" [");
    PrintStr(buf);
    PrintStr("]\n");
    
    sys_close(fd);
    PrintStr("Done\n");
    return 0;
}