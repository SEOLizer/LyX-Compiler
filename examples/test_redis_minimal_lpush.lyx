// Minimal test - just LPUSH
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Minimal Test ===\n");
    
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("Connected\n");
    
    // Just test LPUSH
    PrintStr("Calling LPUSH...\n");
    var r: RedisReply := RedisLPush(conn, "testlist", "value1");
    PrintStr("LPUSH done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}