// Test PING then DEL then LPUSH x2 then LPOP x2 (crashing pattern)
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    }
    
    var delres: int64 := RedisDel(conn, "mylist");
    PrintStr("DEL result = ");
    PrintInt(delres);
    PrintStr("\n");
    
    var r: RedisReply := RedisLPush(conn, "mylist", "a");
    PrintStr("LPUSH1 done\n");
    
    r := RedisLPush(conn, "mylist", "b");
    PrintStr("LPUSH2 done\n");
    
    r := RedisLPop(conn, "mylist");
    PrintStr("LPOP1 done\n");
    
    r := RedisLPop(conn, "mylist");
    PrintStr("LPOP2 done\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}