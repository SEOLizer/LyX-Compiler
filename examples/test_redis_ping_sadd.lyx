// Test just LPUSH after PING (no DEL)
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    } else {
        PrintStr("PING failed\n");
    }
    
    // Just LPUSH - no prior DEL
    var r: RedisReply := RedisLPush(conn, "mylist", "a");
    PrintStr("LPUSH done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // SADD after LPUSH
    r := RedisSAdd(conn, "myset", "apple");
    PrintStr("SADD apple done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}