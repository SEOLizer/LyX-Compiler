// Test with TCP_NODELAY to disable Nagle's algorithm
import std.net.socket;

fn main(): int64 {
    PrintStr("=== Test with TCP_NODELAY ===\n");
    
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { PrintStr("Connect failed\n"); return 1; }
    PrintStr("Connected\n");
    
    // Set TCP_NODELAY
    var ret: int64 := sys_setsockopt(conn.fd, 6, 1, 1, 4);  // IPPROTO_TCP=6, TCP_NODELAY=1
    PrintStr("setsockopt result = ");
    PrintInt(ret);
    PrintStr("\n");
    
    // SET
    var req: pchar := "*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n";
    sys_write(conn.fd, req, 36);
    
    var buf: pchar := "                    ";
    var n: int64 := sys_read(conn.fd, buf, 32);
    PrintStr("SET response n = ");
    PrintInt(n);
    PrintStr(", buf = [");
    PrintStr(buf);
    PrintStr("]\n");
    
    // GET
    req := "*2\r\n$3\r\nGET\r\n$3\r\nkey\r\n";
    sys_write(conn.fd, req, 26);
    
    n := sys_read(conn.fd, buf, 32);
    PrintStr("GET response n = ");
    PrintInt(n);
    PrintStr(", buf = [");
    PrintStr(buf);
    PrintStr("]\n");
    
    sys_close(conn.fd);
    PrintStr("Done\n");
    
    return 0;
}