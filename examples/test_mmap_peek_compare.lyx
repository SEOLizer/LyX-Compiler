// Compare: mmap vs pchar with peek8
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    
    // Test 1: mmap buffer with peek8
    var mbuf: int64 := mmap(0, 64, 3, 34, -1, 0);
    var n: int64 := Read(conn.fd, mbuf, 64);
    PrintStr("mmap read n = ");
    PrintInt(n);
    PrintStr(", peek8(mbuf) = ");
    PrintInt(peek8(mbuf));
    PrintStr("\n");
    
    // Test 2: pchar buffer with StrCharAt
    Write(conn.fd, req, 18);
    var pbuf: pchar := "                    ";
    n := Read(conn.fd, pbuf, 32);
    PrintStr("pchar read n = ");
    PrintInt(n);
    PrintStr(", StrCharAt(pbuf,0) = ");
    PrintInt(StrCharAt(pbuf, 0));
    PrintStr("\n");
    
    // Test 3: mmap buffer but use StrCharAt (via conversion)
    Write(conn.fd, req, 18);
    var mbuf2: int64 := mmap(0, 64, 3, 34, -1, 0);
    n := Read(conn.fd, mbuf2, 64);
    PrintStr("mmap2 read n = ");
    PrintInt(n);
    PrintStr(", first byte via indirect = ");
    // Can't use StrCharAt on int64 directly...
    PrintStr("\n");
    
    Close(conn.fd);
    return 0;
}