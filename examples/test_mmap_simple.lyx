// Test mmap + poke16 + peek16 without any syscalls
fn main(): int64 {
    PrintStr("=== Simple mmap test ===\n");
    
    // mmap a buffer
    var buf: int64 := mmap(0, 4096, 3, 34, -1, 0);
    PrintStr("mmap = ");
    PrintInt(buf);
    PrintStr("\n");
    
    // Write a value
    poke16(buf, 65);  // 65 = 'A'
    PrintStr("Wrote 65\n");
    
    // Read it back
    var val: int64 := peek16(buf);
    PrintStr("peek16 = ");
    PrintInt(val);
    PrintStr("\n");
    
    // Write another value at offset 2
    poke16(buf + 2, 66);  // 66 = 'B'
    PrintStr("Wrote 66 at offset 2\n");
    
    // Read both
    var val2: int64 := peek16(buf);
    var val3: int64 := peek16(buf + 2);
    PrintStr("peek16(buf) = ");
    PrintInt(val2);
    PrintStr("\n");
    PrintStr("peek16(buf+2) = ");
    PrintInt(val3);
    PrintStr("\n");
    
    munmap(buf, 4096);
    PrintStr("Done\n");
    return 0;
}