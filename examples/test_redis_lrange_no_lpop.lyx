// Test LRANGE without any preceding LPOP
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    }
    
    // Setup list but DON'T do LPOP first
    RedisDel(conn, "mylist");
    var r: RedisReply := RedisLPush(conn, "mylist", "first");
    PrintStr("LPUSH done\n");
    
    r := RedisLPush(conn, "mylist", "second");
    PrintStr("LPUSH2 done\n");
    
    r := RedisLPush(conn, "mylist", "last");
    PrintStr("LPUSH3 done\n");
    
    // Now LRANGE - no LPOP before this
    r := RedisLRange(conn, "mylist", 0, -1);
    PrintStr("LRANGE done, kind=");
    PrintInt(r.kind);
    PrintStr(" str_len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}