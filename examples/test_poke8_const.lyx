// Test poke8 with constant directly
fn main(): int64 {
    PrintStr("=== Test poke8 with constant ===\n");
    
    var buf: int64 := mmap(0, 4096, 3, 34, -1, 0);
    PrintStr("mmap = ");
    PrintInt(buf);
    PrintStr("\n");
    
    // Write constant 65 directly
    poke8(buf, 65);
    PrintStr("Wrote 65\n");
    
    // Read back
    var result: int64 := peek8(buf);
    PrintStr("peek8 = ");
    PrintInt(result);
    PrintStr("\n");
    
    // Write another constant
    poke8(buf + 1, 66);
    var result2: int64 := peek8(buf + 1);
    PrintStr("peek8+1 = ");
    PrintInt(result2);
    PrintStr("\n");
    
    munmap(buf, 4096);
    PrintStr("Done\n");
    return 0;
}