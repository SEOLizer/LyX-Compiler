// Simplest mmap test
fn main(): int64 {
    PrintStr("=== Simple mmap test ===\n");
    
    var buf: int64 := mmap(0, 4096, 3, 34, -1, 0);
    PrintStr("mmap = ");
    PrintInt(buf);
    PrintStr("\n");
    
    PrintStr("Before poke: ");
    PrintInt(peek8(buf));
    PrintStr("\n");
    
    poke8(buf, 65);
    
    PrintStr("After poke: ");
    PrintInt(peek8(buf));
    PrintStr("\n");
    
    PrintStr("After poke+1: ");
    PrintInt(peek8(buf + 1));
    PrintStr("\n");
    
    munmap(buf, 4096);
    PrintStr("Done\n");
    return 0;
}