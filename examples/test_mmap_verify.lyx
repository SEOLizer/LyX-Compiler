// Verify mmap address and write directly to it
import std.net.socket;

fn main(): int64 {
    PrintStr("=== Test mmap write then read ===\n");
    
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { PrintStr("Connect failed\n"); return 1; }
    PrintStr("Connected\n");
    
    // Allocate buffer
    var buf: int64 := mmap(0, 64, 3, 34, -1, 0);
    PrintStr("mmap returned: ");
    PrintInt(buf);
    PrintStr("\n");
    
    // First send something so we get a response
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    sys_write(conn.fd, req, 18);
    
    // Then read into buffer
    var n: int64 := sys_read(conn.fd, buf, 64);
    PrintStr("read n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Read back what we got
    var i: int64 := 0;
    while (i < 10) {
        var b: int64 := peek8(buf + i);
        PrintStr(" ");
        PrintInt(b);
        i := i + 1;
    }
    PrintStr("\n");
    
    munmap(buf, 64);
    sys_close(conn.fd);
    PrintStr("Done\n");
    
    return 0;
}