// Example: LDAP Client Test
// Tests basic LDAP functions

import std.net.ldap;
import std.io;

pub fn main(): int64 {
  var result: int64 := 0;
  
  // Test 1: Filter-Encoding
  // Test LDAPBuildFilterEqual - creates "(cn=test)"
  var filter: int64 := LDAPBuildFilterEqual("cn", "test");
  if (filter != 0) {
    PrintStr("LDAPBuildFilterEqual: OK\n");
    result := result + 1;
  }
  
  // Test 2: Filter Present
  // Test LDAPBuildFilterPresent - creates "(objectClass=*)"
  var present: int64 := LDAPBuildFilterPresent("objectClass");
  if (present != 0) {
    PrintStr("LDAPBuildFilterPresent: OK\n");
    result := result + 1;
  }
  
  // Test 3: String Escaping
  // Test LDAPStrEscapeFilter
  var escaped: int64 := LDAPStrEscapeFilter("test*value");
  if (escaped != 0) {
    PrintStr("LDAPStrEscapeFilter: OK\n");
    result := result + 1;
  }
  
  // Test 4: DN Escaping
  // Test LDAPStrEscapeDN
  var dnEscaped: int64 := LDAPStrEscapeDN("cn=test,dc=example");
  if (dnEscaped != 0) {
    PrintStr("LDAPStrEscapeDN: OK\n");
    result := result + 1;
  }
  
  // Test 5: Error Message
  // Test LDAPErrorToStr
  var errMsg: int64 := LDAPErrorToStr(0);
  if (errMsg != 0) {
    PrintStr("LDAPErrorToStr: ");
    PrintStr(errMsg);
    PrintStr("\n");
    result := result + 1;
  }
  
  // Test 6: DN parsing - count RDNs
  var count: int64 := LDAPCountRDNs("cn=admin,dc=example,dc=com");
  if (count == 3) {
    PrintStr("LDAPCountRDNs: OK\n");
    result := result + 1;
  }
  
  // Test 7: DN parsing - get RDN at index
  var rdn: int64 := LDAPGetRDNAt("cn=admin,dc=example,dc=com", 0);
  if (rdn != 0) {
    PrintStr("LDAPGetRDNAt: ");
    PrintStr(rdn);
    PrintStr("\n");
    result := result + 1;
  }
  
  PrintStr("Tests passed: ");
  PrintIntLn(result);
  PrintStr(" / 7\n");
  
  // For real LDAP connection test:
  // var ldap: LDAPConn := LDAPConnect("ldap.example.com", 389);
  // var ok: int64 := LDAPBind(ldap, "cn=admin,dc=example,dc=com", "password");
  // var results: int64 := LDAPSearch(ldap, "dc=example,dc=com", "(objectClass=*)", LDAP_SCOPE_SUBTREE);
  
  return 0;
}