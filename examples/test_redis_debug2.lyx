// Debug test - check actual error messages
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Redis Debug Test ===\n");
    
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Failed to connect\n");
        return 1;
    }
    PrintStr("Connected!\n");
    
    // First verify PING still works
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    }
    
    // Test a simple LIST operation - check the actual error
    PrintStr("\nTesting LPUSH...\n");
    var r: RedisReply := RedisLPush(conn, "testlist", "value1");
    PrintStr("LPUSH result: kind=");
    PrintInt(r.kind);
    PrintStr(" str_len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    // Try to print the error message
    if (r.kind == 1 && r.str_len > 0) {
        PrintStr("Error message: ");
        // Can't use peek8, so let's just print length
        PrintInt(r.str_len);
        PrintStr(" bytes\n");
    }
    
    // Let's try using sys_write to send a manual command
    PrintStr("\nManual LPUSH test...\n");
    var reqbuf: int64 := mmap(0, 256, 3, 34, -1, 0);
    
    // *3\r\n$5\r\nLPUSH\r\n$8\r\ntestlist\r\n$6\r\nvalue1\r\n
    var pos: int64 := 0;
    poke8(reqbuf + pos, 42); pos := pos + 1;  // *
    poke8(reqbuf + pos, 51); pos := pos + 1;  // 3
    poke8(reqbuf + pos, 13); pos := pos + 1;  // \r
    poke8(reqbuf + pos, 10); pos := pos + 1;  // \n
    
    // LPUSH
    poke8(reqbuf + pos, 36); pos := pos + 1;  // $
    poke8(reqbuf + pos, 53); pos := pos + 1;  // 5
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    poke8(reqbuf + pos, 76); pos := pos + 1;  // L
    poke8(reqbuf + pos, 80); pos := pos + 1;  // P
    poke8(reqbuf + pos, 85); pos := pos + 1;  // U
    poke8(reqbuf + pos, 83); pos := pos + 1;  // S
    poke8(reqbuf + pos, 72); pos := pos + 1;  // H
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    
    // testlist
    poke8(reqbuf + pos, 36); pos := pos + 1;
    poke8(reqbuf + pos, 56); pos := pos + 1;  // 8
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    var i: int64 := 0;
    var testlist: pchar := "testlist";
    while (i < 8) {
        poke8(reqbuf + pos, StrCharAt(testlist, i));
        pos := pos + 1;
        i := i + 1;
    }
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    
    // value1
    poke8(reqbuf + pos, 36); pos := pos + 1;
    poke8(reqbuf + pos, 54); pos := pos + 1;  // 6
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    i := 0;
    var value1: pchar := "value1";
    while (i < 6) {
        poke8(reqbuf + pos, StrCharAt(value1, i));
        pos := pos + 1;
        i := i + 1;
    }
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    
    var reply: RedisReply := sendRaw(conn, reqbuf, pos);
    PrintStr("Manual LPUSH: kind=");
    PrintInt(reply.kind);
    PrintStr(" str_len=");
    PrintInt(reply.str_len);
    PrintStr("\n");
    
    munmap(reqbuf, 256);
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}