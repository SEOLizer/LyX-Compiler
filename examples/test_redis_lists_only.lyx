// Simple test - just Lists
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Redis List Test ===\n");
    
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("Connected\n");
    
    // Clean up
    RedisDel(conn, "testlist");
    
    // LPUSH
    var r: RedisReply := RedisLPush(conn, "testlist", "first");
    PrintStr("LPUSH: kind=");
    PrintInt(r.kind);
    PrintStr(" int_val=");
    PrintInt(r.int_val);
    PrintStr("\n");
    
    // RPUSH
    r := RedisRPush(conn, "testlist", "last");
    PrintStr("RPUSH: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // LLEN
    var len: int64 := RedisLLen(conn, "testlist");
    PrintStr("LLEN: ");
    PrintInt(len);
    PrintStr("\n");
    
    // LRANGE
    r := RedisLRange(conn, "testlist", 0, -1);
    PrintStr("LRANGE: kind=");
    PrintInt(r.kind);
    PrintStr(" len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    // LPOP
    r := RedisLPop(conn, "testlist");
    PrintStr("LPOP: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // RPOP
    r := RedisRPop(conn, "testlist");
    PrintStr("RPOP: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}