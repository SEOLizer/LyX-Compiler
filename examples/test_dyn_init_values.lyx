fn main(): int64 {
  var a: array := [10, 20, 30];
  PrintStr("len: ");
  PrintInt(len(a));
  PrintStr("\n");
  PrintStr("a[0]: ");
  PrintInt(a[0]);
  PrintStr("\n");
  PrintStr("a[1]: ");
  PrintInt(a[1]);
  PrintStr("\n");
  PrintStr("a[2]: ");
  PrintInt(a[2]);
  PrintStr("\n");
  var sum: int64 := a[0] + a[1] + a[2];
  PrintStr("sum: ");
  PrintInt(sum);
  PrintStr("\n");
  free(a);
  return sum;
}
