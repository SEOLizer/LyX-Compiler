// Test DEL -> struct -> struct -> struct -> struct
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    } else {
        PrintStr("PING failed\n");
    }
    
    // DEL returns int64
    var delres: int64 := RedisDel(conn, "testkey");
    PrintStr("DEL result = ");
    PrintInt(delres);
    PrintStr("\n");
    
    // 4 struct-returning functions
    var r: RedisReply := RedisLPush(conn, "testkey", "a");
    PrintStr("1 done\n");
    
    r := RedisRPush(conn, "testkey", "b");
    PrintStr("2 done\n");
    
    r := RedisLPop(conn, "testkey");
    PrintStr("3 done\n");
    
    r := RedisLPop(conn, "testkey");
    PrintStr("4 done\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}