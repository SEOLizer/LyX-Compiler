// UDP Socket Test
// Simple test to verify UDP socket creation and basic operations

import std.net.socket;
import std.net.types;

fn main(): int64 {
  var sock: UDPSocket;
  
  PrintStr("UDP Socket Test\n");
  PrintStr("================\n");
  
  // Create UDP socket
  sock := UDPSocketNew();
  if (sock.fd < 0) {
    PrintStr("Failed to create socket\n");
    return 1;
  }
  
  PrintStr("Socket created, fd=");
  PrintInt(sock.fd);
  PrintStr("\n");
  
  // Close socket
  UDPSocketClose(sock);
  PrintStr("Socket closed\n");
  PrintStr("Test PASSED\n");
  return 0;
}
