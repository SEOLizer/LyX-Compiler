// ICMP/Ping Test
// Test raw socket and ICMP packet creation

import std.net.socket;
import std.net.types;

fn main(): int64 {
  var sock: RawSocket;
  var buf: int64;
  var addr: SockAddrIn;
  var n: int64;
  
  PrintStr("ICMP Test\n");
  PrintStr("========\n");
  
  // Try to create raw socket for ICMP
  sock := RawSocketNew(IPPROTO_ICMP);
  
  if (sock.fd < 0) {
    PrintStr("Note: Raw socket requires root privileges\n");
    PrintStr("fd = ");
    PrintInt(sock.fd);
    PrintStr("\n");
    PrintStr("This is expected when not running as root\n");
    return 0;
  }
  
  PrintStr("Raw socket created, fd=");
  PrintInt(sock.fd);
  PrintStr("\n");
  
  // Test ICMP header creation
  var hdr: ICMPHeader;
  hdr := ICMPMakeEchoRequest(1, 1);
  
  PrintStr("ICMP Header created:\n");
  PrintStr("  type = ");
  PrintInt(hdr.icmp_type as int64);
  PrintStr("\n");
  PrintStr("  code = ");
  PrintInt(hdr.icmp_code as int64);
  PrintStr("\n");
  PrintStr("  id = ");
  PrintInt(hdr.icmp_id as int64);
  PrintStr("\n");
  PrintStr("  seq = ");
  PrintInt(hdr.icmp_seq as int64);
  PrintStr("\n");
  
  // Test checksum calculation
  buf := BufferAlloc(64);
  if (buf > 0) {
    poke8(buf + 0, 8);   // type = echo request
    poke8(buf + 1, 0);    // code = 0
    poke8(buf + 2, 0);    // checksum (placeholder)
    poke8(buf + 3, 0);
    poke8(buf + 4, 1);    // id = 1
    poke8(buf + 5, 0);
    poke8(buf + 6, 1);    // seq = 1
    poke8(buf + 7, 0);
    
    var cksum: uint16 := ICMPChecksum(buf, 8);
    PrintStr("ICMP checksum = ");
    PrintInt(cksum as int64);
    PrintStr("\n");
    
    BufferFree(buf, 64);
  }
  
  // Cleanup
  RawSocketClose(sock);
  PrintStr("Test completed\n");
  return 0;
}
