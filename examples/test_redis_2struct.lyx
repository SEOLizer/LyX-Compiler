// Test just 2 struct-returning functions without Redis
import std.db.redis;

fn testHelper1(conn: RedisConn): RedisReply {
    var reply: RedisReply;
    reply.kind := 1;
    return reply;
}

fn testHelper2(conn: RedisConn): RedisReply {
    var reply: RedisReply;
    reply.kind := 2;
    return reply;
}

fn main(): int64 {
    var conn: RedisConn;
    conn.fd := 5;
    conn.buf := 0;
    
    var r: RedisReply := testHelper1(conn);
    PrintStr("Helper1 done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    r := testHelper2(conn);
    PrintStr("Helper2 done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    return 0;
}