// mmap, poke, then peek
fn main(): int64 {
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    PrintStr("addr: ");
    PrintInt(addr);
    PrintStr("\n");
    
    poke8(addr, 65);
    PrintStr("poke done\n");
    
    // Now peek - this may crash
    var v: int64 := peek8(addr);
    PrintStr("peek done: ");
    PrintInt(v);
    PrintStr("\n");
    
    return 0;
}