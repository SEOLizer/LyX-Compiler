// Test: just LRANGE + LPOP (2 struct returns)
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    }
    
    // Just setup and do LRANGE + LPOP
    RedisDel(conn, "mylist");
    var r: RedisReply := RedisLPush(conn, "mylist", "first");
    
    // No LLEN between
    r := RedisLRange(conn, "mylist", 0, -1);
    PrintStr("LRANGE done\n");
    
    // LPOP immediately after
    r := RedisLPop(conn, "mylist");
    PrintStr("LPOP done\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}