// Full Redis test with SET/GET using std.net.socket
import std.net.socket;

fn main(): int64 {
    PrintStr("=== Redis SET/GET Test ===\n");
    
    // Connect
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    
    PrintStr("Connected!\n");
    
    // === SET testkey helloworld ===
    // RESP: *3\r\n$3\r\nSET\r\n$7\r\ntestkey\r\n$10\r\nhelloworld\r\n
    var set_buf: pchar := "                                                                                                                                ";
    var pos: int64 := 0;
    
    // Array header *3
    StrSetChar(set_buf, pos, 42); pos := pos + 1;  // *
    StrSetChar(set_buf, pos, 51); pos := pos + 1;  // 3
    StrSetChar(set_buf, pos, 13); pos := pos + 1;  // \r
    StrSetChar(set_buf, pos, 10); pos := pos + 1;  // \n
    
    // SET
    StrSetChar(set_buf, pos, 36); pos := pos + 1;  // $
    StrSetChar(set_buf, pos, 51); pos := pos + 1;  // 3
    StrSetChar(set_buf, pos, 13); pos := pos + 1;
    StrSetChar(set_buf, pos, 10); pos := pos + 1;
    StrSetChar(set_buf, pos, 83); pos := pos + 1;  // S
    StrSetChar(set_buf, pos, 69); pos := pos + 1;  // E
    StrSetChar(set_buf, pos, 84); pos := pos + 1;  // T
    StrSetChar(set_buf, pos, 13); pos := pos + 1;
    StrSetChar(set_buf, pos, 10); pos := pos + 1;
    
    // testkey
    StrSetChar(set_buf, pos, 36); pos := pos + 1;
    StrSetChar(set_buf, pos, 55); pos := pos + 1;  // 7
    StrSetChar(set_buf, pos, 13); pos := pos + 1;
    StrSetChar(set_buf, pos, 10); pos := pos + 1;
    var i: int64 := 0;
    while (i < 7) { StrSetChar(set_buf, pos, 116 + i); pos := pos + 1; i := i + 1; }  // "testkey" = t,e,s,t,k,e,y
    StrSetChar(set_buf, pos, 13); pos := pos + 1;
    StrSetChar(set_buf, pos, 10); pos := pos + 1;
    
    // helloworld
    StrSetChar(set_buf, pos, 36); pos := pos + 1;
    StrSetChar(set_buf, pos, 49); pos := pos + 1;  // 10
    StrSetChar(set_buf, pos, 48); pos := pos + 1;
    StrSetChar(set_buf, pos, 13); pos := pos + 1;
    StrSetChar(set_buf, pos, 10); pos := pos + 1;
    i := 0;
    while (i < 10) { StrSetChar(set_buf, pos, 104 + i); pos := pos + 1; i := i + 1; }  // "helloworld"
    StrSetChar(set_buf, pos, 13); pos := pos + 1;
    StrSetChar(set_buf, pos, 10); pos := pos + 1;
    
    var sent: int64 := TCPConnWrite(conn, set_buf, pos);
    PrintStr("SET sent: ");
    PrintInt(sent);
    PrintStr("\n");
    
    // Read SET response
    var resp_buf: pchar := "                    ";
    var n: int64 := TCPConnRead(conn, resp_buf, 32);
    PrintStr("SET response: ");
    PrintStr(resp_buf);
    PrintStr("\n");
    
    // === GET testkey ===
    // RESP: *2\r\n$3\r\nGET\r\n$7\r\ntestkey\r\n
    pos := 0;
    StrSetChar(set_buf, pos, 42); pos := pos + 1;
    StrSetChar(set_buf, pos, 50); pos := pos + 1;  // 2
    StrSetChar(set_buf, pos, 13); pos := pos + 1;
    StrSetChar(set_buf, pos, 10); pos := pos + 1;
    
    // GET
    StrSetChar(set_buf, pos, 36); pos := pos + 1;
    StrSetChar(set_buf, pos, 51); pos := pos + 1;  // 3
    StrSetChar(set_buf, pos, 13); pos := pos + 1;
    StrSetChar(set_buf, pos, 10); pos := pos + 1;
    StrSetChar(set_buf, pos, 71); pos := pos + 1;  // G
    StrSetChar(set_buf, pos, 69); pos := pos + 1;  // E
    StrSetChar(set_buf, pos, 84); pos := pos + 1;  // T
    StrSetChar(set_buf, pos, 13); pos := pos + 1;
    StrSetChar(set_buf, pos, 10); pos := pos + 1;
    
    // testkey
    StrSetChar(set_buf, pos, 36); pos := pos + 1;
    StrSetChar(set_buf, pos, 55); pos := pos + 1;  // 7
    StrSetChar(set_buf, pos, 13); pos := pos + 1;
    StrSetChar(set_buf, pos, 10); pos := pos + 1;
    i := 0;
    while (i < 7) { StrSetChar(set_buf, pos, 116 + i); pos := pos + 1; i := i + 1; }
    StrSetChar(set_buf, pos, 13); pos := pos + 1;
    StrSetChar(set_buf, pos, 10); pos := pos + 1;
    
    sent := TCPConnWrite(conn, set_buf, pos);
    PrintStr("GET sent: ");
    PrintInt(sent);
    PrintStr("\n");
    
    // Read GET response
    var get_buf: pchar := "                                                                                                                                ";
    n := TCPConnRead(conn, get_buf, 64);
    PrintStr("GET response (");
    PrintInt(n);
    PrintStr(" bytes): [");
    PrintStr(get_buf);
    PrintStr("]\n");
    
    TCPConnClose(conn);
    PrintStr("Done!\n");
    
    return 0;
}