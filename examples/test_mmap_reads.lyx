// Test with mmap buffer instead of pchar
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    sys_write(conn.fd, req, 18);
    
    // Use mmap for buffer
    var buf: int64 := mmap(0, 64, 3, 34, -1, 0);
    var n: int64 := sys_read(conn.fd, buf, 64);
    PrintStr("read1 ");
    PrintInt(n);
    PrintStr("\n");
    
    // Second with NEW mmap
    req := "*1\r\n$4\r\nPING\r\n";
    sys_write(conn.fd, req, 18);
    
    var buf2: int64 := mmap(0, 64, 3, 34, -1, 0);
    n := sys_read(conn.fd, buf2, 64);
    PrintStr("read2 ");
    PrintInt(n);
    PrintStr("\n");
    
    munmap(buf, 64);
    munmap(buf2, 64);
    sys_close(conn.fd);
    return 0;
}