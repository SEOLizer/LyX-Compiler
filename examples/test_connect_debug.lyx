// Test using in-memory struct instead of mmap
fn main(): int64 {
    PrintStr("=== Test with static struct ===\n");
    
    var fd: int64 := sys_socket(2, 1, 0);
    PrintStr("socket = ");
    PrintInt(fd);
    PrintStr("\n");
    
    // Create a local struct for the address (on stack)
    var sockaddr: array[16]int64;
    
    // Just use mmap for the address buffer
    var testbuf: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(testbuf, 65);  // write 'A'
    var testval: int64 := peek16(testbuf);
    PrintStr("poke8 test: wrote 65, peek16 = ");
    PrintInt(testval);
    PrintStr("\n");
    munmap(testbuf, 16);
    
    // Now try socket again with simpler setup
    PrintStr("Trying socket connect again...\n");
    fd := sys_socket(2, 1, 0);
    PrintStr("socket2 = ");
    PrintInt(fd);
    PrintStr("\n");
    
    // Use a simpler address - try putting it at known stack location
    // Actually, let me check if sys_connect even accepts the address
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    
    // Clear the buffer
    var j: int64 := 0;
    while (j < 16) {
        poke8(addr + j, 0);
        j := j + 1;
    }
    
    // sin_family = AF_INET = 2
    poke8(addr, 2);
    poke8(addr + 1, 0);
    
    // sin_port = 6379 = 0x18EB (big endian)
    poke8(addr + 2, 0x18);
    poke8(addr + 3, 0xEB);
    
    // sin_addr = 127.0.0.1 (big endian: 0x7F000001)
    poke8(addr + 4, 127);  // 127
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    
    PrintStr("Address configured, calling connect...\n");
    
    var cr: int64 := sys_connect(fd, addr, 16);
    PrintStr("connect result = ");
    PrintInt(cr);
    PrintStr("\n");
    
    if (cr == 0) {
        PrintStr("Connected!\n");
    } else {
        PrintStr("Failed\n");
    }
    
    sys_close(fd);
    munmap(addr, 16);
    
    PrintStr("Done\n");
    return 0;
}