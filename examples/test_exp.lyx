// test_exp.lyx - Test ExpF64 Taylor series
import std.ml;

pub fn main(): int64 {
  // Test exp(0) should be 1
  var e0: f64 := ExpF64(0.0);
  PrintStr("exp(0): ");
  PrintInt(e0 as int64);
  PrintStr("\n");
  
  // Test exp(1) should be ~2.718
  var e1: f64 := ExpF64(1.0);
  PrintStr("exp(1): ");
  PrintInt(e1 as int64);  // ~2
  PrintStr("\n");
  
  // Test sigmoid
  var s0: f64 := SigmoidF64(0.0);
  PrintStr("sigmoid(0): ");
  PrintInt(s0 as int64);  // sollte 0.5 sein ~0
  PrintStr("\n");
  
  var s1: f64 := SigmoidF64(10.0);
  PrintStr("sigmoid(10): ");
  PrintInt(s1 as int64);  // sollte 1 sein
  PrintStr("\n");
  
  var s_1: f64 := SigmoidF64(0.0 - 10.0);
  PrintStr("sigmoid(-10): ");
  PrintInt(s_1 as int64);  // sollte 0 sein
  PrintStr("\n");
  
  PrintStr("Done\n");
  return 0;
}