// Use mmap'd buffers instead of pchar literals
import std.net.socket;

fn main(): int64 {
    PrintStr("=== Test mmap buffers ===\n");
    
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { PrintStr("Connect failed\n"); return 1; }
    PrintStr("Connected\n");
    
    // SET
    var req: pchar := "*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n";
    sys_write(conn.fd, req, 36);
    
    // mmap buffer for SET response
    var buf1: int64 := mmap(0, 64, 3, 34, -1, 0);
    var n: int64 := sys_read(conn.fd, buf1, 64);
    PrintStr("SET response n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Print first few bytes
    var i: int64 := 0;
    while (i < n) {
        var b: int64 := peek8(buf1 + i);
        PrintStr(" ");
        PrintInt(b);
        i := i + 1;
    }
    PrintStr("\n");
    
    munmap(buf1, 64);
    
    // GET with new mmap buffer
    var req2: pchar := "*2\r\n$3\r\nGET\r\n$3\r\nkey\r\n";
    sys_write(conn.fd, req2, 26);
    
    var buf2: int64 := mmap(0, 64, 3, 34, -1, 0);
    n := sys_read(conn.fd, buf2, 64);
    PrintStr("GET response n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Print first few bytes
    i := 0;
    while (i < n) {
        var b: int64 := peek8(buf2 + i);
        PrintStr(" ");
        PrintInt(b);
        i := i + 1;
    }
    PrintStr("\n");
    
    munmap(buf2, 64);
    
    sys_close(conn.fd);
    PrintStr("Done\n");
    
    return 0;
}