// Test mmap basic functionality - no sockets
fn main(): int64 {
    PrintStr("=== Test mmap ===\n");
    
    // Allocate
    var addr: int64 := mmap(0, 4096, 3, 34, -1, 0);
    PrintStr("mmap returned: ");
    PrintInt(addr);
    PrintStr("\n");
    
    if (addr <= 0) {
        PrintStr("mmap failed\n");
        return 1;
    }
    
    // Write
    PrintStr("Writing 65 to addr...\n");
    poke8(addr, 65);
    PrintStr("poke8 done\n");
    
    // Read
    var v: int64 := peek8(addr);
    PrintStr("peek8 returned: ");
    PrintInt(v);
    PrintStr("\n");
    
    if (v == 65) {
        PrintStr("SUCCESS!\n");
    } else {
        PrintStr("FAILED - expected 65\n");
    }
    
    // Write more
    poke8(addr + 1, 66);
    poke8(addr + 2, 67);
    
    // Read back
    var v2: int64 := peek8(addr + 1);
    var v3: int64 := peek8(addr + 2);
    PrintStr("v2 = ");
    PrintInt(v2);
    PrintStr(", v3 = ");
    PrintInt(v3);
    PrintStr("\n");
    
    // Free
    munmap(addr, 4096);
    PrintStr("munmap done\n");
    
    return 0;
}