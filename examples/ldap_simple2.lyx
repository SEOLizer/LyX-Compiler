// Simple LDAP Test - just strings

import std.net.ldap;
import std.io;

pub fn main(): int64 {
  var errMsg: int64 := LDAPErrorToStr(0);
  if (errMsg != 0) {
    PrintStr("Error(0): ");
    PrintStr(errMsg);
    PrintStr("\n");
  }
  errMsg := LDAPErrorToStr(49);
  if (errMsg != 0) {
    PrintStr("Error(49): ");
    PrintStr(errMsg);
    PrintStr("\n");
  }
  return 0;
}