fn main(): void {
  var argv: int64 := mmap(0, 32, 3, 34, -1, 0);
  poke64(argv + 0, "/bin/echo" as int64);
  poke64(argv + 8, "hello_from_execve" as int64);
  poke64(argv + 16, 0);

  var pid: int64 := sys_fork();
  if (pid == 0) {
    sys_execve("/bin/echo", argv, 0);
    exit(127);
  }
  var st: int64 := mmap(0, 8, 3, 34, -1, 0);
  sys_wait4(pid, st, 0);
  PrintStr("done, status=");
  PrintInt((peek64(st) >> 8) & 255);
  PrintStr("\n");
  munmap(st, 8);
  munmap(argv, 32);
}
