// Test PING only
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    } else {
        PrintStr("PING failed\n");
    }
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}