// Beispiel mit Kommandozeilenargumenten

fn main(argc: int64, argv: pchar): int64 {
  PrintStr("Programm gestartet mit ");
  PrintInt(argc);
  PrintStr(" Argument(en)\n");
  
  // Hinweis: argv ist ein Pointer auf ein Array von pchar
  // Der erste Eintrag (argv[0]) ist der Programmname
  
  return 0;
}
