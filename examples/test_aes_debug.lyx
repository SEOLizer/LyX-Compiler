// Debug test for AES components
import std.crypto.aes;

fn PrintHexBytes(label: pchar, data: pchar, len: int64) {
    PrintStr(label);
    var i: int64 := 0;
    while (i < len) {
        var b: int64 := StrCharAt(data, i);
        PrintStr(" ");
        PrintInt(b);
        i := i + 1;
    }
    PrintStr("\n");
}

fn main(): int64 {
    PrintStr("=== AES Component Debug Test ===\n\n");
    
    // Test GF inverse for known values
    PrintStr("Testing GF_inv:\n");
    PrintStr("GF_inv(1) = ");
    PrintInt(GF_inv_simple(1));
    PrintStr(" (should be 1)\n");
    
    PrintStr("GF_inv(2) = ");
    PrintInt(GF_inv_simple(2));
    PrintStr(" (should be 0xD4)\n");
    
    PrintStr("GF_inv(3) = ");
    PrintInt(GF_inv_simple(3));
    PrintStr(" (should be 0xB4)\n");
    
    PrintStr("\nTesting SubByte:\n");
    PrintStr("SubByte(0) = ");
    PrintInt(SubByte(0));
    PrintStr(" (should be 0x63)\n");
    
    PrintStr("SubByte(0xFF) = ");
    PrintInt(SubByte(0xFF));
    PrintStr(" (should be 0x16)\n");
    
    PrintStr("\nTesting InvSubByte:\n");
    // Known S-Box values
    PrintStr("InvSubByte(0x63) = ");
    PrintInt(InvSubByte(0x63));
    PrintStr(" (should be 0)\n");
    
    PrintStr("InvSubByte(0x7C) = ");
    PrintInt(InvSubByte(0x7C));
    PrintStr(" (should be 0x77)\n");
    
    // Test roundtrip
    PrintStr("\nTesting SubByte/InvSubByte roundtrip:\n");
    var test_val: int64 := 0xAB;
    var subbed: int64 := SubByte(test_val);
    var unsubbed: int64 := InvSubByte(subbed);
    PrintStr("Original: ");
    PrintInt(test_val);
    PrintStr(", Subbed: ");
    PrintInt(subbed);
    PrintStr(", Unsubbed: ");
    PrintInt(unsubbed);
    if (unsubbed == test_val) {
        PrintStr(" - PASS\n");
    } else {
        PrintStr(" - FAIL\n");
    }
    
    // Test GF multiplication
    PrintStr("\nTesting GF_mul:\n");
    PrintStr("GF_mul(141, 2) = ");
    PrintInt(GF_mul(141, 2));
    PrintStr(" (should be 1)\n");
    
    PrintStr("GF_mul(212, 2) = ");
    PrintInt(GF_mul(212, 2));
    PrintStr(" (should be 1)\n");
    
    // Test roundtrip with more values
    var k: int64 := 0;
    var failures: int64 := 0;
    while (k < 256) {
        var s: int64 := SubByte(k);
        var u: int64 := InvSubByte(s);
        if (u != k) {
            if (failures < 5) {
                PrintStr("FAIL at ");
                PrintInt(k);
                PrintStr(": Sub=");
                PrintInt(s);
                PrintStr(" InvSub=");
                PrintInt(u);
                PrintStr("\n");
            }
            failures := failures + 1;
        }
        k := k + 1;
    }
    PrintStr("Total SubByte/InvSubByte failures: ");
    PrintInt(failures);
    PrintStr("\n");
    
    // Test key expansion
    PrintStr("\nTesting Key Expansion:\n");
    var test_key: pchar := "                ";
    StrSetChar(test_key, 0, 0x2b);
    StrSetChar(test_key, 1, 0x7e);
    StrSetChar(test_key, 2, 0x15);
    StrSetChar(test_key, 3, 0x16);
    StrSetChar(test_key, 4, 0x28);
    StrSetChar(test_key, 5, 0xae);
    StrSetChar(test_key, 6, 0xd2);
    StrSetChar(test_key, 7, 0xa6);
    StrSetChar(test_key, 8, 0xab);
    StrSetChar(test_key, 9, 0xf7);
    StrSetChar(test_key, 10, 0x15);
    StrSetChar(test_key, 11, 0x88);
    StrSetChar(test_key, 12, 0x09);
    StrSetChar(test_key, 13, 0xcf);
    StrSetChar(test_key, 14, 0x4f);
    StrSetChar(test_key, 15, 0x3c);
    
    var expanded: pchar := "                                                                ";
    AES128KeyExpand(test_key, expanded);
    
    PrintStr("Expanded key[0-15]: ");
    var i: int64 := 0;
    while (i < 16) {
        PrintInt(StrCharAt(expanded, i));
        PrintStr(" ");
        i := i + 1;
    }
    PrintStr("\n");
    
    // Known AES-128 test vector (from FIPS-197)
    // Key: 2b 7e 15 16 28 ae d2 a6 ab f7 15 88 09 cf 4f 3c
    // Expected first round key word: a0 fa fe 17
    PrintStr("Expected first round key[0-3]: 160 250 254 23\n");
    
    PrintStr("\n=== Test Complete ===\n");
    exit(0);
}