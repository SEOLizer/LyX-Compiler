// Test simple: just call sendRaw manually with a struct return type
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    }
    
    RedisDel(conn, "mylist");
    
    // Setup with just one LPUSH
    var r: RedisReply := RedisLPush(conn, "mylist", "one");
    PrintStr("LPUSH done\n");
    
    // Now call LPOP - should return struct
    r := RedisLPop(conn, "mylist");
    PrintStr("LPOP done\n");
    
    // Now call another struct-returning function
    r := RedisLPush(conn, "mylist2", "two");
    PrintStr("LPUSH2 done\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}