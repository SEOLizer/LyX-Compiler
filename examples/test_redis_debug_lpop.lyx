// Debug LPOP issue specifically
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    }
    
    // Setup list the same way as test_redis_all_ops
    RedisDel(conn, "mylist");
    RedisLPush(conn, "mylist", "first");
    RedisLPush(conn, "mylist", "second");
    RedisLPush(conn, "mylist", "last");
    
    var llen: int64 := RedisLLen(conn, "mylist");
    PrintStr("LLEN = ");
    PrintInt(llen);
    PrintStr("\n");
    
    // LPOP
    var r: RedisReply := RedisLPop(conn, "mylist");
    PrintStr("LPOP result: kind=");
    PrintInt(r.kind);
    PrintStr(" int_val=");
    PrintInt(r.int_val);
    PrintStr(" str_len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    // RPOP
    r := RedisRPop(conn, "mylist");
    PrintStr("RPOP result: kind=");
    PrintInt(r.kind);
    PrintStr(" int_val=");
    PrintInt(r.int_val);
    PrintStr(" str_len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}