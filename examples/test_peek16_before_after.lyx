// Test peek16 on mmap buffer after any write
fn main(): int64 {
    PrintStr("=== Test peek16 after mmap ===\n");
    
    var buf: int64 := mmap(0, 4096, 3, 34, -1, 0);
    PrintStr("mmap = ");
    PrintInt(buf);
    PrintStr("\n");
    
    // Try to read BEFORE any poke - should be 0
    var val1: int64 := peek16(buf);
    PrintStr("peek16 (before poke) = ");
    PrintInt(val1);
    PrintStr("\n");
    
    // Now write
    poke16(buf, 65);
    PrintStr("Wrote 65\n");
    
    // Read after write
    var val2: int64 := peek16(buf);
    PrintStr("peek16 (after poke) = ");
    PrintInt(val2);
    PrintStr("\n");
    
    munmap(buf, 4096);
    PrintStr("Done\n");
    return 0;
}