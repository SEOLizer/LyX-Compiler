fn add(a: int64, b: int64): int64 {
  return a + b;
}

fn multiply(a: int64, b: int64): int64 {
  return a * b;
}

fn main(): int64 {
  var x: int64 := 10;
  
  var r1: int64 := x |> add(5);
  PrintStr("10 |> add(5) = ");
  PrintInt(r1);
  PrintStr("\n");
  
  var r2: int64 := x |> multiply(3);
  PrintStr("10 |> multiply(3) = ");
  PrintInt(r2);
  PrintStr("\n");
  
  var r3: int64 := x |> add(5) |> multiply(2);
  PrintStr("10 |> add(5) |> multiply(2) = ");
  PrintInt(r3);
  PrintStr("\n");
  
  return 0;
}
