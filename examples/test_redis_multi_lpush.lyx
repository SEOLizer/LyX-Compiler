// Test PING + multiple LPUSH + LLEN + LPOP
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    } else {
        PrintStr("PING failed\n");
    }
    
    RedisDel(conn, "testlist");
    
    // Multiple LPUSH
    var r: RedisReply := RedisLPush(conn, "testlist", "one");
    PrintStr("LPUSH one, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    r := RedisLPush(conn, "testlist", "two");
    PrintStr("LPUSH two, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    r := RedisLPush(conn, "testlist", "three");
    PrintStr("LPUSH three, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // LLEN - returns int64
    var llen: int64 := RedisLLen(conn, "testlist");
    PrintStr("LLEN = ");
    PrintInt(llen);
    PrintStr("\n");
    
    // LPOP - returns RedisReply struct (bulk string)
    r := RedisLPop(conn, "testlist");
    PrintStr("LPOP kind=");
    PrintInt(r.kind);
    PrintStr(" str_len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}