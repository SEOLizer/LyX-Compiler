// Simple AES block test using known test vector
import std.crypto.aes;

fn PrintHexBytes(label: pchar, data: pchar, len: int64) {
    PrintStr(label);
    var i: int64 := 0;
    while (i < len) {
        var b: int64 := StrCharAt(data, i);
        if (b < 16) { PrintStr("0"); }
        PrintInt(b);
        PrintStr(" ");
        i := i + 1;
    }
    PrintStr("\n");
}

fn StrEqual(a: pchar, b: pchar, len: int64): bool {
    var i: int64 := 0;
    while (i < len) {
        if (StrCharAt(a, i) != StrCharAt(b, i)) { return false; }
        i := i + 1;
    }
    return true;
}

fn main(): int64 {
    PrintStr("=== AES Known Vector Test ===\n\n");
    
    // Test from FIPS-197 appendix C (simplified)
    // Key: 2b 7e 15 16 28 ae d2 a6 ab f7 15 88 09 cf 4f 3c
    // Plaintext: 32 43 f6 a8 88 5a 30 8d 31 31 98 a2 e0 37 07 34
    // Ciphertext: 39 25 84 1e 75 19 71 92 c2 95 87 64 1a 2b de 43  (round 10)
    
    var key: pchar := "                        ";
    StrSetChar(key, 0, 0x2b); StrSetChar(key, 1, 0x7e); StrSetChar(key, 2, 0x15); StrSetChar(key, 3, 0x16);
    StrSetChar(key, 4, 0x28); StrSetChar(key, 5, 0xae); StrSetChar(key, 6, 0xd2); StrSetChar(key, 7, 0xa6);
    StrSetChar(key, 8, 0xab); StrSetChar(key, 9, 0xf7); StrSetChar(key, 10, 0x15); StrSetChar(key, 11, 0x88);
    StrSetChar(key, 12, 0x09); StrSetChar(key, 13, 0xcf); StrSetChar(key, 14, 0x4f); StrSetChar(key, 15, 0x3c);
    
    var plaintext: pchar := "                ";
    StrSetChar(plaintext, 0, 0x32); StrSetChar(plaintext, 1, 0x43); StrSetChar(plaintext, 2, 0xf6); StrSetChar(plaintext, 3, 0xa8);
    StrSetChar(plaintext, 4, 0x88); StrSetChar(plaintext, 5, 0x5a); StrSetChar(plaintext, 6, 0x30); StrSetChar(plaintext, 7, 0x8d);
    StrSetChar(plaintext, 8, 0x31); StrSetChar(plaintext, 9, 0x31); StrSetChar(plaintext, 10, 0x98); StrSetChar(plaintext, 11, 0xa2);
    StrSetChar(plaintext, 12, 0xe0); StrSetChar(plaintext, 13, 0x37); StrSetChar(plaintext, 14, 0x07); StrSetChar(plaintext, 15, 0x34);
    
    // Expected ciphertext from FIPS-197
    var expected: pchar := "                ";
    StrSetChar(expected, 0, 0x39); StrSetChar(expected, 1, 0x25); StrSetChar(expected, 2, 0x84); StrSetChar(expected, 3, 0x1e);
    StrSetChar(expected, 4, 0x75); StrSetChar(expected, 5, 0x19); StrSetChar(expected, 6, 0x71); StrSetChar(expected, 7, 0x92);
    StrSetChar(expected, 8, 0xc2); StrSetChar(expected, 9, 0x95); StrSetChar(expected, 10, 0x87); StrSetChar(expected, 11, 0x64);
    StrSetChar(expected, 12, 0x1a); StrSetChar(expected, 13, 0x2b); StrSetChar(expected, 14, 0xde); StrSetChar(expected, 15, 0x43);
    
    PrintHexBytes("Key:       ", key, 16);
    PrintHexBytes("Plaintext: ", plaintext, 16);
    PrintHexBytes("Expected:  ", expected, 16);
    
    // Expand key
    var expanded: pchar := "                                                                ";
    AES128KeyExpand(key, expanded);
    
    // Test single block encryption
    var work: pchar := "                ";
    var i: int64 := 0;
    while (i < 16) {
        StrSetChar(work, i, StrCharAt(plaintext, i));
        i := i + 1;
    }
    
    AESEncryptBlockWithKey(work, expanded, 10);
    
    PrintHexBytes("Got:       ", work, 16);
    
    if (StrEqual(work, expected, 16)) {
        PrintStr("\n*** AES BLOCK TEST PASSED! ***\n");
    } else {
        PrintStr("\n*** AES BLOCK TEST FAILED! ***\n");
    }
    
    // Now test decryption (roundtrip)
    PrintStr("\n--- Roundtrip Test ---\n");
    var cipher: pchar := "                ";
    i := 0;
    while (i < 16) {
        StrSetChar(cipher, i, StrCharAt(expected, i));
        i := i + 1;
    }
    
    // Decrypt
    var decrypted: pchar := "                ";
    i := 0;
    while (i < 16) {
        StrSetChar(decrypted, i, StrCharAt(cipher, i));
        i := i + 1;
    }
    
    AESDecryptBlockWithKey(decrypted, expanded, 10);
    
    PrintHexBytes("Original plaintext: ", plaintext, 16);
    PrintHexBytes("After decrypt:       ", decrypted, 16);
    
    if (StrEqual(decrypted, plaintext, 16)) {
        PrintStr("\n*** DECRYPT TEST PASSED! ***\n");
    } else {
        PrintStr("\n*** DECRYPT TEST FAILED! ***\n");
    }
    
    return 0;
}