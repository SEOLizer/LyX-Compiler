// Debug LPOP - just LPUSH and LPOP
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    }
    
    // Just LPUSH + LPOP - no LLEN in between
    var r: RedisReply := RedisLPush(conn, "mylist", "first");
    PrintStr("LPUSH done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // Now LPOP
    r := RedisLPop(conn, "mylist");
    PrintStr("LPOP result: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}