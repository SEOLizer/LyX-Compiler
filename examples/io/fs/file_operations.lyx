// Dateisystem-Operationen Demo
// Demonstrates: Datei-Operationen (konzeptuell)
// Hinweis: Die tatsaechliche Implementierung erfordert pchar-Handling

fn main(): int64 {
    PrintStr("=== Dateisystem Demo ===\n\n");
    
    //Dateioperationen erklaeren
    PrintStr("Dateisystem-Operationen:\n");
    PrintStr("========================\n\n");
    
    // Oeffnen
    PrintStr("1. Datei oeffnen:\n");
    PrintStr("   fd = open(\"/pfad/datei.txt\", O_RDONLY)\n");
    PrintStr("   O_RDONLY = 0 (nur lesen)\n");
    PrintStr("   O_WRONLY = 1 (nur schreiben)\n");
    PrintStr("   O_RDWR   = 2 (lesen + schreiben)\n\n");
    
    // Erstellen mit Flags
    PrintStr("2. Datei erstellen:\n");
    PrintStr("   fd = open(\"neu.txt\", O_WRONLY | O_CREAT | O_TRUNC, 0644)\n");
    PrintStr("   O_CREAT = 64  (erstellen falls nicht existent)\n");
    PrintStr("   O_TRUNC = 512 (auf 0 Bytes kuerzen)\n");
    PrintStr("   O_APPEND = 1024 (an Ende anhaengen)\n\n");
    
    // Lesen
    PrintStr("3. Datei lesen:\n");
    PrintStr("   bytes = read(fd, buffer, anzahl)\n");
    PrintStr("   Gibt Anzahl gelesener Bytes zurueck\n");
    PrintStr("   0 = EOF (Dateiende)\n");
    PrintStr("   -1 = Fehler\n\n");
    
    // Schreiben
    PrintStr("4. Datei schreiben:\n");
    PrintStr("   bytes = write(fd, buffer, anzahl)\n");
    PrintStr("   Gibt Anzahl geschriebener Bytes zurueck\n\n");
    
    // Positionieren
    PrintStr("5. Dateiposition:\n");
    PrintStr("   pos = lseek(fd, offset, SEEK_SET)\n");
    PrintStr("   SEEK_SET = 0 (vom Anfang)\n");
    PrintStr("   SEEK_CUR = 1 (von aktueller Position)\n");
    PrintStr("   SEEK_END = 2 (vom Ende)\n\n");
    
    // Schliessen
    PrintStr("6. Datei schliessen:\n");
    PrintStr("   close(fd)\n\n");
    
    // Loeschen
    PrintStr("7. Datei loeschen:\n");
    PrintStr("   unlink(\"/pfad/datei.txt\")\n");
    PrintStr("   gibt 0 zurueck bei Erfolg\n\n");
    
    // Datei-Informationen
    PrintStr("8. Datei-Informationen:\n");
    PrintStr("   fstat(fd, &stat_struct)\n");
    PrintStr("   Liefert: Groesse, Rechte, Timestamps\n\n");
    
    // Simulierte Verwendung
    PrintStr("Beispiel-Ablauf:\n");
    PrintStr("================\n\n");
    
    var count: int64 := 3;
    var i: int64 := 0;
    
    while (i < count) {
        PrintStr("Schritt ");
        PrintInt(i + 1);
        PrintStr(":\n");
        
        if (i == 0) {
            PrintStr("  - open(\"test.txt\", O_RDONLY) -> fd=3\n");
            PrintStr("  - read(fd, buf, 100) -> n Bytes\n");
        } else if (i == 1) {
            PrintStr("  - lseek(fd, 0, SEEK_SET) -> pos=0\n");
            PrintStr("  - read(fd, buf, 50) -> n Bytes\n");
        } else {
            PrintStr("  - close(fd) -> 0\n");
        }
        
        PrintStr("\n");
        i := i + 1;
    }
    
    PrintStr("=== Demo abgeschlossen ===\n");
    
    return 0;
}