// URL Parser Demo
// Demonstrates: URL in Bestandteile zerlegen, String-Manipulation

fn main(): int64 {
    PrintStr("=== URL Parser Demo ===\n\n");
    
    // URL-Struktur erklaeren
    PrintStr("URL Struktur:\n");
    PrintStr("-------------\n");
    PrintStr("scheme://username:password@hostname:port/path?query#fragment\n");
    PrintStr("\n");
    
    PrintStr("Beispiel: https://user:pass@example.com:443/abc/def?x=1&y=2#section\n");
    PrintStr("\n");
    
    // Aufschluesseln
    PrintStr("Bestandteile:\n");
    PrintStr("-------------\n");
    PrintStr("  scheme:   https\n");
    PrintStr("  username: user\n");
    PrintStr("  password: pass\n");
    PrintStr("  hostname: example.com\n");
    PrintStr("  port:     443\n");
    PrintStr("  path:     /abc/def\n");
    PrintStr("  query:    x=1&y=2\n");
    PrintStr("  fragment: section\n");
    PrintStr("\n");
    
    // Parsing-Logik erklaeren
    PrintStr("Parsing-Logik:\n");
    PrintStr("--------------\n");
    PrintStr("1. Finde '://' -> Alles davor ist scheme\n");
    PrintStr("2. Nach '://': finde '@' fuer credentials\n");
    PrintStr("3. Vor '@': finde ':' fuer user:pass\n");
    PrintStr("4. Nach '@': finde ':' oder '/' fuer host:port\n");
    PrintStr("5. Nach host: finde '?' fuer query\n");
    PrintStr("6. Nach '?': finde '#' fuer fragment\n");
    PrintStr("\n");
    
    // Beispiel-Parsing
    PrintStr("Beispiel-Parsing:\n");
    PrintStr("-----------------\n");
    
    var url: pchar := "https://api.example.com:8080/v1/users?id=123#profile";
    
    PrintStr("URL: ");
    PrintStr(url);
    PrintStr("\n\n");
    
    // Scheme
    PrintStr("1. Scheme:\n");
    PrintStr("   Suche '://'\n");
    PrintStr("   -> 'https'\n\n");
    
    // Hostname
    PrintStr("2. Hostname:\n");
    PrintStr("   Nach '://' bis ':' oder '/' oder '?' oder '#'\n");
    PrintStr("   -> 'api.example.com'\n\n");
    
    // Port
    PrintStr("3. Port (optional):\n");
    PrintStr("   Nach ':' bis '/' oder '?'\n");
    PrintStr("   -> '8080'\n\n");
    
    // Path
    PrintStr("4. Path:\n");
    PrintStr("   Nach Host bis '?' oder '#' oder Ende\n");
    PrintStr("   -> '/v1/users'\n\n");
    
    // Query
    PrintStr("5. Query (optional):\n");
    PrintStr("   Nach '?' bis '#' oder Ende\n");
    PrintStr("   -> 'id=123'\n\n");
    
    // Fragment
    PrintStr("6. Fragment (optional):\n");
    PrintStr("   Nach '#' bis Ende\n");
    PrintStr("   -> 'profile'\n\n");
    
    // Praktische Beispiele
    PrintStr("Praktische Beispiele:\n");
    PrintStr("---------------------\n\n");
    
    // HTTP vs HTTPS
    PrintStr("HTTP vs HTTPS:\n");
    var http_url: pchar := "http://localhost:8080/api";
    var https_url: pchar := "https://secure.example.com/api";
    
    PrintStr("  http:  ");
    PrintStr(http_url);
    PrintStr(" -> scheme=http, port=8080\n");
    
    PrintStr("  https: ");
    PrintStr(https_url);
    PrintStr(" -> scheme=https, port=443 (default)\n");
    PrintStr("\n");
    
    // Query-Parameter
    PrintStr("Query-Parameter:\n");
    var query_url: pchar := "https://example.com/search?q=test&page=1&lang=de";
    
    PrintStr("  URL: ");
    PrintStr(query_url);
    PrintStr("\n");
    PrintStr("  Parameter:\n");
    PrintStr("    q=    test\n");
    PrintStr("    page= 1\n");
    PrintStr("    lang= de\n");
    PrintStr("\n");
    
    // URL-Encoding erklaeren
    PrintStr("URL-Encoding (Percent-Encoding):\n");
    PrintStr("---------------------------------\n");
    PrintStr("Sonderzeichen werden durch '%XX' ersetzt.\n");
    PrintStr("  Leerzeichen -> %20\n");
    PrintStr("  ! -> %21\n");
    PrintStr("  # -> %23\n");
    PrintStr("  ? -> %3F\n");
    PrintStr("\n");
    PrintStr("Beispiel: 'hello world' -> 'hello%20world'\n");
    PrintStr("\n");
    
    // Path-Variationen
    PrintStr("Path-Variationen:\n");
    PrintStr("----------------\n");
    PrintStr("  /                    -> Root\n");
    PrintStr("  /api/v1/users        -> Mehrere Segmente\n");
    PrintStr("  /api/v1/users/123    -> Mit ID\n");
    PrintStr("  /api/v1/users/123/orders -> Verschachtelt\n");
    PrintStr("\n");
    
    // IPv4 vs Hostname
    PrintStr("IPv4 vs Hostname:\n");
    PrintStr("-----------------\n");
    PrintStr("  http://192.168.1.1:80/ -> IP-Adresse\n");
    PrintStr("  http://localhost/      -> Hostname\n");
    PrintStr("  http://example.com/    -> Domain\n");
    PrintStr("\n");
    
    // Relative URLs erklaeren
    PrintStr("Relative URLs:\n");
    PrintStr("--------------\n");
    PrintStr("Ohne scheme/host - relativ zur aktuellen Seite:\n");
    PrintStr("  /api/users     -> absolut (vom Root)\n");
    PrintStr("  api/users      -> relativ\n");
    PrintStr("  ./users        -> relativ (aktuelles Verzeichnis)\n");
    PrintStr("  ../api         -> relativ (uebergeordnetes Verzeichnis)\n");
    
    PrintStr("\n=== Demo abgeschlossen ===\n");
    
    return 0;
}