// UDP Buffer Test
// Test buffer allocation and UDP socket

import std.net.socket;
import std.net.types;

fn main(): int64 {
  var sock: UDPSocket;
  var buf: int64;
  var clientAddr: int64;
  var n: int64;
  var sent: int64;
  
  PrintStr("UDP Buffer Test\n");
  PrintStr("================\n");
  
  // Allocate receive buffer (using explicit values to ensure correctness)
  buf := mmap(0, 4096, 3, 34, -1, 0);
  if (buf == 0) {
    PrintStr("Failed to allocate buffer\n");
    return 1;
  }
  
  PrintStr("Buffer allocated at address: ");
  PrintInt(buf);
  PrintStr("\n");
  
  // Create UDP socket
  sock := UDPSocketNew();
  if (sock.fd < 0) {
    PrintStr("Failed to create socket\n");
    munmap(buf, 4096);
    return 1;
  }
  
  PrintStr("Socket created, fd=");
  PrintInt(sock.fd);
  PrintStr("\n");
  
  // Allocate client address buffer
  clientAddr := mmap(0, 128, 3, 34, -1, 0);
  if (clientAddr == 0) {
    PrintStr("Failed to allocate client address buffer\n");
    UDPSocketClose(sock);
    munmap(buf, 4096);
    return 1;
  }
  
  PrintStr("Client address buffer allocated at: ");
  PrintInt(clientAddr);
  PrintStr("\n");
  
  // Cleanup
  UDPSocketClose(sock);
  munmap(buf, 4096);
  munmap(clientAddr, 128);
  
  PrintStr("Cleanup done\n");
  PrintStr("Test PASSED\n");
  return 0;
}
