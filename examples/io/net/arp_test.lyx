// ARP Test
// Test ARP packet creation and serialization

import std.net.socket;
import std.net.types;

fn main(): int64 {
  var buf: int64;
  var len: int64;
  
  PrintStr("ARP Test\n");
  PrintStr("========\n");
  
  // Create MAC addresses
  var broadcastMac: MacAddr := MacBroadcast();
  var myMac: MacAddr := broadcastMac;
  
  PrintStr("Broadcast MAC created\n");
  
  // Create IP addresses
  var myIP: int64 := IPPack(192, 168, 1, 100);
  var gatewayIP: int64 := IPPack(10, 0, 0, 1);
  
  PrintStr("My IP: ");
  PrintInt(myIP);
  PrintStr("\n");
  
  PrintStr("Gateway IP: ");
  PrintInt(gatewayIP);
  PrintStr("\n");
  
  // Create Ethernet header
  var eth: EthernetHeader;
  eth := EthernetHeaderCreate(broadcastMac, myMac, ETH_P_ARP);
  
  PrintStr("Ethernet EtherType: ");
  PrintInt(eth.ethertype as int64);
  PrintStr("\n");
  
  // Create ARP request
  var arp: ARPPacket;
  arp := ARPMakeRequest(myMac, myIP, gatewayIP);
  
  PrintStr("ARP Operation: ");
  PrintInt(arp.ar_op as int64);
  PrintStr("\n");
  
  // Serialize to buffer
  buf := BufferAlloc(128);
  if (buf == 0) {
    PrintStr("Failed to allocate buffer\n");
    return 1;
  }
  
  len := ARPSerializePacket(eth, arp, buf);
  
  PrintStr("Serialized packet length: ");
  PrintInt(len);
  PrintStr(" bytes (expected 42)\n");
  
  // Print first few bytes of packet (Ethernet header)
  PrintStr("Ethernet header (first 14 bytes):\n");
  var i: int64 := 0;
  while (i < 14) {
    var b: int64 := peek8(buf + i);
    PrintInt(b);
    PrintStr(" ");
    i := i + 1;
  }
  PrintStr("\n");
  
  // Print ARP part (bytes 14-41)
  PrintStr("ARP header (bytes 14-27):\n");
  i := 14;
  while (i < 28) {
    var b: int64 := peek8(buf + i);
    PrintInt(b);
    PrintStr(" ");
    i := i + 1;
  }
  PrintStr("\n");
  
  // Test IP unpack
  var unpackedIP: IPAddr;
  unpackedIP := IPUnpack(gatewayIP);
  
  PrintStr("Unpacked gateway IP: ");
  PrintInt(unpackedIP.a);
  PrintStr(".");
  PrintInt(unpackedIP.b);
  PrintStr(".");
  PrintInt(unpackedIP.c);
  PrintStr(".");
  PrintInt(unpackedIP.d);
  PrintStr("\n");
  
  // Cleanup
  BufferFree(buf, 128);
  
  PrintStr("Test PASSED\n");
  return 0;
}
