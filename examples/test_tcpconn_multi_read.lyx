// Test multiple TCPConnRead calls with pchar buffer
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    // First command
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    TCPConnWrite(conn, req, 18);
    
    // First read with pchar buffer
    var buf: pchar := "                ";
    var n: int64 := TCPConnRead(conn, buf, 32);
    PrintStr("read1 = ");
    PrintInt(n);
    PrintStr(", buf = [");
    PrintStr(buf);
    PrintStr("]\n");
    
    // Second command
    req := "*1\r\n$4\r\nPING\r\n";
    TCPConnWrite(conn, req, 18);
    
    // Second read with SAME pchar buffer
    n := TCPConnRead(conn, buf, 32);
    PrintStr("read2 = ");
    PrintInt(n);
    PrintStr("\n");
    
    TCPConnClose(conn);
    return 0;
}