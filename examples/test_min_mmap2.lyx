// Minimal test with early print
fn main(): int64 {
    PrintStr("start\n");
    var buf: int64 := mmap(0, 64, 3, 34, -1, 0);
    PrintStr("after mmap\n");
    PrintInt(buf);
    PrintStr("\n");
    poke8(buf, 65);
    PrintStr("after poke\n");
    var v: int64 := peek8(buf);
    PrintStr("after peek\n");
    PrintInt(v);
    PrintStr("\n");
    munmap(buf, 64);
    PrintStr("after munmap\n");
    return 0;
}