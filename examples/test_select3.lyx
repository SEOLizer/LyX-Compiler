// Fixed: reset fd_set before second select
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    // Reusable buffers
    var readfds: int64 := mmap(0, 128, 3, 34, -1, 0);
    var timeout: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(timeout, 1);  // 1 second
    
    // First command
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    
    // Reset and set fd
    var i: int64 := 0;
    while (i < 128) { poke8(readfds + i, 0); i := i + 1; }
    poke8(readfds, 1);  // FD_SET fd=3
    
    var n: int64 := Select(conn.fd + 1, readfds, 0, 0, timeout);
    PrintStr("select1 = ");
    PrintInt(n);
    PrintStr("\n");
    
    if (n > 0) {
        var buf: pchar := "                    ";
        var r: int64 := Read(conn.fd, buf, 32);
        PrintStr("read1 = ");
        PrintInt(r);
        PrintStr("\n");
    }
    
    // Second command
    req := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    PrintStr("wrote2\n");
    
    // RESET fd_set before second select!
    i := 0;
    while (i < 128) { poke8(readfds + i, 0); i := i + 1; }
    poke8(readfds, 1);  // FD_SET fd=3 again
    
    n := Select(conn.fd + 1, readfds, 0, 0, timeout);
    PrintStr("select2 = ");
    PrintInt(n);
    PrintStr("\n");
    
    if (n > 0) {
        var buf: pchar := "                    ";
        PrintStr("about to read2...\n");
        var r: int64 := Read(conn.fd, buf, 32);
        PrintStr("read2 = ");
        PrintInt(r);
        PrintStr("\n");
    }
    
    // Third command - let's see if it works
    req := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    PrintStr("wrote3\n");
    
    i := 0;
    while (i < 128) { poke8(readfds + i, 0); i := i + 1; }
    poke8(readfds, 1);
    
    n := Select(conn.fd + 1, readfds, 0, 0, timeout);
    PrintStr("select3 = ");
    PrintInt(n);
    PrintStr("\n");
    
    if (n > 0) {
        var buf: pchar := "                    ";
        var r: int64 := Read(conn.fd, buf, 32);
        PrintStr("read3 = ");
        PrintInt(r);
        PrintStr("\n");
    }
    
    munmap(readfds, 128);
    munmap(timeout, 16);
    Close(conn.fd);
    PrintStr("Done\n");
    return 0;
}