// Debug test for AES-CBC mode
import std.crypto.aes;

fn PH(label: pchar, data: pchar, len: int64) {
    PrintStr(label);
    var i: int64 := 0;
    while (i < len) {
        if (i > 0) { PrintStr(" "); }
        if (StrCharAt(data, i) < 16) { PrintStr("0"); }
        PrintInt(StrCharAt(data, i));
        i := i + 1;
    }
    PrintStr("\n");
}

fn main(): int64 {
    PrintStr("=== AES-CBC Debug Test ===\n\n");
    
    // Use known test vector
    var key: pchar := "                        ";
    var iv: pchar := "                        ";
    var plaintext: pchar := "                                ";
    
    var i: int64 := 0;
    while (i < 16) {
        StrSetChar(key, i, i);
        StrSetChar(iv, i, 16 + i);
        i := i + 1;
    }
    
    var pt: pchar := "This is a test of the CBC mode!";
    i := 0;
    while (i < 28) {
        StrSetChar(plaintext, i, StrCharAt(pt, i));
        i := i + 1;
    }
    
    PH("Key: ", key, 16);
    PH("IV:  ", iv, 16);
    PH("Plaintext: ", plaintext, 28);
    
    var cipher: pchar := "                                        ";
    var cipher_len: int64 := AES128CBCEncrypt(key, iv, plaintext, 28, cipher);
    
    PrintStr("\nCiphertext (");
    PrintInt(cipher_len);
    PrintStr(" bytes): ");
    PH("", cipher, cipher_len);
    
    var decrypted: pchar := "                                        ";
    var decrypted_len: int64 := AES128CBCDecrypt(key, iv, cipher, cipher_len, decrypted);
    
    PrintStr("\nDecrypted (");
    PrintInt(decrypted_len);
    PrintStr(" bytes): ");
    PH("", decrypted, decrypted_len);
    
    var match: bool := true;
    if (decrypted_len != 28) { match := false; }
    i := 0;
    while (i < 28) {
        if (StrCharAt(decrypted, i) != StrCharAt(plaintext, i)) {
            match := false;
            PrintStr("Mismatch at ");
            PrintInt(i);
            PrintStr("\n");
        }
        i := i + 1;
    }
    
    if (match) { PrintStr("\n*** CBC TEST PASSED! ***\n"); }
    else { PrintStr("\n*** CBC TEST FAILED! ***\n"); }
    
    // Single block roundtrip
    PrintStr("\n=== Single Block Roundtrip ===\n");
    var single: pchar := "                ";
    var single_key: pchar := "                ";
    var expanded: pchar := "                                                                ";
    
    i := 0;
    while (i < 16) {
        StrSetChar(single_key, i, i);
        i := i + 1;
    }
    
    AES128KeyExpand(single_key, expanded);
    
    var encrypted: pchar := "                ";
    var decrypted_single: pchar := "                ";
    
    i := 0;
    while (i < 16) {
        StrSetChar(encrypted, i, StrCharAt(single, i));
        i := i + 1;
    }
    
    PH("Original: ", encrypted, 16);
    
    AESEncryptBlockWithKey(encrypted, expanded, 10);
    
    PH("Encrypted: ", encrypted, 16);
    
    i := 0;
    while (i < 16) {
        StrSetChar(decrypted_single, i, StrCharAt(encrypted, i));
        i := i + 1;
    }
    
    AESDecryptBlockWithKey(decrypted_single, expanded, 10);
    
    PH("Decrypted: ", decrypted_single, 16);
    
    match := true;
    i := 0;
    while (i < 16) {
        if (StrCharAt(decrypted_single, i) != StrCharAt(single, i)) { match := false; }
        i := i + 1;
    }
    
    if (match) { PrintStr("*** SINGLE BLOCK ROUNDTRIP PASSED! ***\n"); }
    else { PrintStr("*** SINGLE BLOCK ROUNDTRIP FAILED! ***\n"); }
    
    return 0;
}