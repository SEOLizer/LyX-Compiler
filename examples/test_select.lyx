// Test with select() instead of poll
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    // Prepare fd_set (1024 bits = 128 bytes)
    var readfds: int64 := mmap(0, 128, 3, 34, -1, 0);
    
    // FD_ZERO - clear the set
    var i: int64 := 0;
    while (i < 128) {
        poke8(readfds + i, 0);
        i := i + 1;
    }
    
    // FD_SET - set bit for our fd
    var byte_idx: int64 := conn.fd / 8;
    var bit_idx: int64 := conn.fd % 8;
    var current: int64 := peek8(readfds + byte_idx);
    current := current | (1 << bit_idx);
    poke8(readfds + byte_idx, current);
    
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    PrintStr("wrote\n");
    
    // select with timeout
    var timeout: int64 := mmap(0, 16, 3, 34, -1, 0);
    // tv_sec = 1 second
    poke8(timeout, 1);
    // tv_usec = 0
    poke8(timeout + 4, 0);
    
    var n: int64 := Select(conn.fd + 1, readfds, 0, 0, timeout);
    PrintStr("select n = ");
    PrintInt(n);
    PrintStr("\n");
    
    if (n > 0) {
        var buf: pchar := "                    ";
        var r: int64 := Read(conn.fd, buf, 32);
        PrintStr("read = ");
        PrintInt(r);
        PrintStr("\n");
    }
    
    // Second command test
    req := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    PrintStr("wrote2\n");
    
    // Reset fd_set
    i := 0;
    while (i < 128) {
        poke8(readfds + i, 0);
        i := i + 1;
    }
    byte_idx := conn.fd / 8;
    bit_idx := conn.fd % 8;
    current := peek8(readfds + byte_idx);
    current := current | (1 << bit_idx);
    poke8(readfds + byte_idx, current);
    
    n := Select(conn.fd + 1, readfds, 0, 0, timeout);
    PrintStr("select2 n = ");
    PrintInt(n);
    PrintStr("\n");
    
    if (n > 0) {
        var buf: pchar := "                    ";
        PrintStr("about to read2...\n");
        var r: int64 := Read(conn.fd, buf, 32);
        PrintStr("read2 = ");
        PrintInt(r);
        PrintStr("\n");
    }
    
    munmap(readfds, 128);
    munmap(timeout, 16);
    Close(conn.fd);
    return 0;
}