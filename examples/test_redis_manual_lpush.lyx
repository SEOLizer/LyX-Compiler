// Test to see what's actually being sent
import std.db.redis;

fn main(): int64 {
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) { return 1; }
    
    // Build the LPUSH command manually with correct format
    var reqbuf: int64 := mmap(0, 256, 3, 34, -1, 0);
    var pos: int64 := 0;
    
    // *3\r\n
    poke8(reqbuf + pos, 42); pos := pos + 1;  // *
    poke8(reqbuf + pos, 51); pos := pos + 1;  // 3
    poke8(reqbuf + pos, 13); pos := pos + 1;  // \r
    poke8(reqbuf + pos, 10); pos := pos + 1;  // \n
    
    // $5\r\nLPUSH\r\n
    poke8(reqbuf + pos, 36); pos := pos + 1;  // $
    poke8(reqbuf + pos, 53); pos := pos + 1;  // 5
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    var cmd: pchar := "LPUSH";
    var i: int64 := 0;
    while (i < 5) {
        poke8(reqbuf + pos, StrCharAt(cmd, i));
        pos := pos + 1;
        i := i + 1;
    }
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    
    // $8\r\ntestlist\r\n
    poke8(reqbuf + pos, 36); pos := pos + 1;
    poke8(reqbuf + pos, 56); pos := pos + 1;  // 8
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    var key: pchar := "testlist";
    i := 0;
    while (i < 8) {
        poke8(reqbuf + pos, StrCharAt(key, i));
        pos := pos + 1;
        i := i + 1;
    }
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    
    // $5\r\nvalue\r\n
    poke8(reqbuf + pos, 36); pos := pos + 1;
    poke8(reqbuf + pos, 53); pos := pos + 1;  // 5
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    var val: pchar := "value";
    i := 0;
    while (i < 5) {
        poke8(reqbuf + pos, StrCharAt(val, i));
        pos := pos + 1;
        i := i + 1;
    }
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    
    PrintStr("Sending ");
    PrintInt(pos);
    PrintStr(" bytes\n");
    
    // Send directly using sys_write
    var sent: int64 := sys_write(conn.fd, reqbuf, pos);
    PrintStr("Sent ");
    PrintInt(sent);
    PrintStr(" bytes\n");
    
    // Read response
    var n: int64 := sys_read(conn.fd, conn.buf, 200);
    PrintStr("Read ");
    PrintInt(n);
    PrintStr(" bytes\n");
    
    var reply: RedisReply := parseResp(conn, n);
    PrintStr("Reply kind=");
    PrintInt(reply.kind);
    PrintStr("\n");
    
    munmap(reqbuf, 256);
    RedisClose(conn);
    return 0;
}