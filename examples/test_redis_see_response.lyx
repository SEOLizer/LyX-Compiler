// Check if we can see response bytes using different method
fn main(): int64 {
    PrintStr("=== See Redis Response ===\n");
    
    var fd: int64 := sys_socket(2, 1, 0);
    
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    var j: int64 := 0;
    while (j < 16) {
        poke8(addr + j, 0);
        j := j + 1;
    }
    poke8(addr, 2);
    poke8(addr + 1, 0);
    poke8(addr + 2, 0x18);
    poke8(addr + 3, 0xEB);
    poke8(addr + 4, 127);
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    
    var cr: int64 := sys_connect(fd, addr, 16);
    if (cr != 0) { return 1; }
    
    // Send PING
    var reqbuf: int64 := mmap(0, 64, 3, 34, -1, 0);
    poke8(reqbuf + 0, 42);
    poke8(reqbuf + 1, 49);
    poke8(reqbuf + 2, 13);
    poke8(reqbuf + 3, 10);
    poke8(reqbuf + 4, 36);
    poke8(reqbuf + 5, 52);
    poke8(reqbuf + 6, 13);
    poke8(reqbuf + 7, 10);
    poke8(reqbuf + 8, 80);
    poke8(reqbuf + 9, 73);
    poke8(reqbuf + 10, 78);
    poke8(reqbuf + 11, 71);
    poke8(reqbuf + 12, 13);
    poke8(reqbuf + 13, 10);
    
    sys_write(fd, reqbuf, 14);
    
    // Read into buffer
    var respbuf: int64 := mmap(0, 256, 3, 34, -1, 0);
    var n: int64 := sys_read(fd, respbuf, 200);
    PrintStr("Got ");
    PrintInt(n);
    PrintStr(" bytes\n");
    
    // Can we use peek16 to see bytes?
    // Try reading 16-bit values
    var i: int64 := 0;
    while (i < n) {
        var v16: int64 := peek16(respbuf + i);
        // Print as hex
        var v: int64 := v16;
        // Just print the number
        PrintInt(v16);
        PrintStr(" ");
        i := i + 2;
    }
    PrintStr("\n");
    
    // Try writing the response to stdout
    var w: int64 := sys_write(1, respbuf, n);
    PrintStr("\nWrote to stdout: ");
    PrintInt(w);
    PrintStr("\n");
    
    sys_close(fd);
    munmap(reqbuf, 64);
    munmap(respbuf, 256);
    munmap(addr, 16);
    
    return 0;
}