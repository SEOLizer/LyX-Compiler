// Test exact sequence from all_ops: LPOP + RPOP + DEL + SADD + SADD + SISMEMBER
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    } else {
        PrintStr("PING failed\n");
    }
    
    // Setup list and pop
    RedisDel(conn, "mylist");
    RedisLPush(conn, "mylist", "a");
    RedisLPush(conn, "mylist", "b");
    
    var r: RedisReply := RedisLPop(conn, "mylist");
    PrintStr("LPOP done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    r := RedisRPop(conn, "mylist");
    PrintStr("RPOP done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // Int64 return (DEL)
    var delres: int64 := RedisDel(conn, "myset");
    PrintStr("DEL result = ");
    PrintInt(delres);
    PrintStr("\n");
    
    // Struct returns (SADD)
    r := RedisSAdd(conn, "myset", "apple");
    PrintStr("SADD apple done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    r := RedisSAdd(conn, "myset", "banana");
    PrintStr("SADD banana done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // Int64 return (SISMEMBER)
    var ismem: int64 := RedisSIsMember(conn, "myset", "apple");
    PrintStr("SISMEMBER apple = ");
    PrintInt(ismem);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}