// More detailed peek8 test
import std.fs;

fn main(): int64 {
    PrintStr("=== Test peek8 details ===\n");
    
    var fd: int64 := open("/tmp/test_peek.txt", 65, 384);
    if (fd < 0) { return 1; }
    
    // mmap
    var buf: int64 := mmap(0, 64, 3, 34, -1, 0);
    PrintStr("mmap = ");
    PrintInt(buf);
    PrintStr("\n");
    
    // Write 'X' to mmap
    poke8(buf, 88);  // 'X'
    PrintStr("poke8 done\n");
    
    // Immediately peek
    var v: int64 := peek8(buf);
    PrintStr("peek8 result: ");
    PrintInt(v);
    PrintStr("\n");
    
    // Write mmap to file
    write(fd, buf, 1);
    
    // Peek again after write
    v := peek8(buf);
    PrintStr("peek8 after write: ");
    PrintInt(v);
    PrintStr("\n");
    
    // Close file, reopen
    close(fd);
    fd := open("/tmp/test_peek.txt", 0, 0);
    
    // Read into mmap
    var n: int64 := read(fd, buf, 64);
    PrintStr("read n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Peek after read
    v := peek8(buf);
    PrintStr("peek8 after read: ");
    PrintInt(v);
    PrintStr("\n");
    
    // Try poke after read
    poke8(buf, 89);  // 'Y'
    v := peek8(buf);
    PrintStr("peek8 after poke: ");
    PrintInt(v);
    PrintStr("\n");
    
    close(fd);
    munmap(buf, 64);
    return 0;
}