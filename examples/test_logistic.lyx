// test_logistic.lyx - Test Logistic Regression
import std.ml;

pub fn main(): int64 {
  // Binary classification: x < 2.5 -> 0, x >= 2.5 -> 1
  // Training data: (1,2) -> 0, (3,4) -> 1
  LogisticRegressionInit();
LogisticRegressionFit(1.0, 2.0, 0.0, 1.0, 0.1, 1000);
  
var weight: f64 := LogisticRegressionWeight();
var bias: f64 := LogisticRegressionBias();
  var loss: f64 := LogisticRegressionLoss();
  var acc: f64 := LogisticRegressionAccuracy();
  
  PrintStr("Logistic Regression:\n");
  PrintStr("Weight: ");
  PrintInt(weight as int64);  // ~1
  PrintStr("\nBias: ");
  PrintInt(bias as int64);   // ~-2.5
  PrintStr("\nLoss: ");
  PrintInt(loss as int64);  // sollte klein sein
  PrintStr("\nAccuracy: ");
  PrintInt(acc as int64);   // sollte 1 sein (100%)
  PrintStr("\n");
  
  // Test predictions
  var prob1: f64 := LogisticRegressionPredictProb(1.5);
  var prob2: f64 := LogisticRegressionPredictProb(3.5);
  
  PrintStr("Prob(x=1.5): ");
  PrintInt(prob1 as int64);
  PrintStr("\nProb(x=3.5): ");
  PrintInt(prob2 as int64);
  PrintStr("\n");
  
  var class1: int64 := LogisticRegressionPredict(1.5);
  var class2: int64 := LogisticRegressionPredict(3.5);
  
  PrintStr("Class(x=1.5): ");
  PrintInt(class1);  // sollte 0 sein
  PrintStr("\nClass(x=3.5): ");
  PrintInt(class2);  // sollte 1 sein
  PrintStr("\nDone\n");
  
  return 0;
}