// Minimal Redis syscall test - working pattern
fn main(): int64 {
    PrintStr("=== Minimal Test ===\n");
    
    // Step 1: socket
    var fd: int64 := sys_socket(2, 1, 0);
    PrintStr("socket fd = ");
    PrintInt(fd);
    PrintStr("\n");
    
    if (fd < 0) { return 1; }
    
    // Step 2: mmap for sockaddr
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    PrintStr("mmap addr = ");
    PrintInt(addr);
    PrintStr("\n");
    
    if (addr <= 0) {
        sys_close(fd);
        return 1;
    }
    
    // Step 3: fill sockaddr_in (127.0.0.1:6379)
    poke8(addr, 2);           // sin_family
    poke8(addr + 2, 0x18);    // port high
    poke8(addr + 3, 0xEB);    // port low
    poke8(addr + 4, 0x7F);    // IP first
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    
    // Step 4: connect
    var result: int64 := sys_connect(fd, addr, 16);
    PrintStr("connect result = ");
    PrintInt(result);
    PrintStr("\n");
    
    munmap(addr, 16);
    
    if (result < 0) {
        sys_close(fd);
        return 1;
    }
    
    PrintStr("Connected!\n");
    
    // Step 5: write PING
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    var sent: int64 := sys_write(fd, req, 18);
    PrintStr("write sent = ");
    PrintInt(sent);
    PrintStr("\n");
    
    // Step 6: read
    var buf: pchar := "                    ";
    var n: int64 := sys_read(fd, buf, 32);
    PrintStr("read n = ");
    PrintInt(n);
    PrintStr("\nResponse: [");
    PrintStr(buf);
    PrintStr("]\n");
    
    sys_close(fd);
    PrintStr("Done\n");
    
    return 0;
}