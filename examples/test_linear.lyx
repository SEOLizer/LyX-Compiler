// test_linear.lyx - Test Linear Regression fix
import std.ml;

pub fn main(): int64 {
  // y = 2x + 1
  LinearRegressionInit();
  LinearRegressionFit(1.0, 2.0, 3.0, 4.0, 3.0, 5.0, 7.0, 9.0, 0.1, 1000);
  
  var weight: f64 := LinearRegressionWeight();
  var bias: f64 := LinearRegressionBias();
  var loss: f64 := LinearRegressionLoss();
  var epochs: int64 := LinearRegressionEpochs();
  
  PrintStr("Linear Regression:\n");
  PrintStr("Weight: ");
  PrintInt(weight as int64);  // ~2
  PrintStr("\nBias: ");
  PrintInt(bias as int64);   // ~1
  PrintStr("\nLoss: ");
  PrintInt(loss as int64);  // sollte klein sein
  PrintStr("\nEpochs: ");
  PrintInt(epochs);
  PrintStr("\n");
  
  // Test prediction
  var pred: f64 := LinearRegressionPredict(5.0);
  PrintStr("Pred(x=5): ");
  PrintInt(pred as int64);  // ~11
  PrintStr("\nDone\n");
  
  return 0;
}