// Minimal crash reproduction: LPUSH + LLEN + LRANGE + LPOP + RPOP
import std.db.redis;

fn main(): int64 {
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) { return 1; }
    
    var ping_result: bool := RedisPing(conn);
    
    var del_result: int64 := RedisDel(conn, "mylist");
    var r1: RedisReply := RedisLPush(conn, "mylist", "first");
    var r2: RedisReply := RedisLPush(conn, "mylist", "second");
    var r3: RedisReply := RedisRPush(conn, "mylist", "last");
    
    var llen: int64 := RedisLLen(conn, "mylist");
    if (llen != 3) { return 1; }
    
    var r: RedisReply := RedisLRange(conn, "mylist", 0, -1);
    r := RedisLPop(conn, "mylist");
    r := RedisRPop(conn, "mylist");  // <-- CRASH HERE
    
    RedisClose(conn);
    return 0;
}