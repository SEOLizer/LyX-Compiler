// Exact same test but different key name
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    }
    
    // Use "testlist2" instead of "mylist"
    var r: RedisReply := RedisLPush(conn, "testlist2", "a");
    PrintStr("LPUSH1 done\n");
    
    r := RedisLPush(conn, "testlist2", "b");
    PrintStr("LPUSH2 done\n");
    
    r := RedisLPop(conn, "testlist2");
    PrintStr("LPOP1 done\n");
    
    r := RedisLPop(conn, "testlist2");
    PrintStr("LPOP2 done\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}