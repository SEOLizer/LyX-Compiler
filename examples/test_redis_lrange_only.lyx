// Test just LRANGE specifically
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    }
    
    // Setup list
    RedisDel(conn, "mylist");
    RedisLPush(conn, "mylist", "first");
    RedisLPush(conn, "mylist", "second");
    RedisLPush(conn, "mylist", "last");
    
    // LRANGE - try different stop values
    var r: RedisReply := RedisLRange(conn, "mylist", 0, -1);
    PrintStr("LRANGE 0,-1: kind=");
    PrintInt(r.kind);
    PrintStr(" str_len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    r := RedisLRange(conn, "mylist", 0, 2);
    PrintStr("LRANGE 0,2: kind=");
    PrintInt(r.kind);
    PrintStr(" str_len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}