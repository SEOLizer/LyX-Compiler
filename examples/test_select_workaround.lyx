// Workaround: Use select() before each read to "reset" the socket state
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    var my_fd: int64 := conn.fd;
    
    // Prepare fd_set
    var readfds: int64 := mmap(0, 128, 3, 34, -1, 0);
    var timeout: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(timeout, 1);  // 1 second
    
    // First read
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(my_fd, req, 18);
    
    // Select before read
    poke8(readfds, 1);  // FD_SET
    var n: int64 := Select(my_fd + 1, readfds, 0, 0, timeout);
    PrintStr("select1 = ");
    PrintInt(n);
    PrintStr("\n");
    
    var buf: pchar := "                    ";
    n := Read(my_fd, buf, 32);
    PrintStr("read1 = ");
    PrintInt(n);
    PrintStr(", buf = [");
    PrintStr(buf);
    PrintStr("]\n");
    
    // Reset fd_set for second select
    poke8(readfds, 0);  // FD_CLR (clear bit 0 by setting to 0)
    
    // Second read - use select first
    Write(my_fd, req, 18);
    poke8(readfds, 1);  // FD_SET again
    n := Select(my_fd + 1, readfds, 0, 0, timeout);
    PrintStr("select2 = ");
    PrintInt(n);
    PrintStr("\n");
    
    n := Read(my_fd, buf, 32);
    PrintStr("read2 = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Third read
    Write(my_fd, req, 18);
    poke8(readfds, 0);
    poke8(readfds, 1);
    n := Select(my_fd + 1, readfds, 0, 0, timeout);
    PrintStr("select3 = ");
    PrintInt(n);
    PrintStr("\n");
    
    n := Read(my_fd, buf, 32);
    PrintStr("read3 = ");
    PrintInt(n);
    PrintStr("\n");
    
    munmap(readfds, 128);
    munmap(timeout, 16);
    Close(conn.fd);
    return 0;
}