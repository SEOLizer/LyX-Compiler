// Test with pchar buffer instead of mmap
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Test pchar buffer ===\n");
    
    // Manual setup
    var fd: int64 := sys_socket(2, 1, 0);
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(addr, 2);
    poke8(addr + 1, 0);
    poke8(addr + 2, 0x18);
    poke8(addr + 3, 0xEB);
    poke8(addr + 4, 0x7F);
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    sys_connect(fd, addr, 16);
    munmap(addr, 16);
    
    PrintStr("Connected\n");
    
    // Send PING
    var reqbuf: int64 := mmap(0, 64, 3, 34, -1, 0);
    var pos: int64 := 0;
    poke8(reqbuf + pos, 42); pos := pos + 1;
    poke8(reqbuf + pos, 49); pos := pos + 1;
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    poke8(reqbuf + pos, 36); pos := pos + 1;
    poke8(reqbuf + pos, 52); pos := pos + 1;
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    poke8(reqbuf + pos, 80); pos := pos + 1;
    poke8(reqbuf + pos, 73); pos := pos + 1;
    poke8(reqbuf + pos, 78); pos := pos + 1;
    poke8(reqbuf + pos, 71); pos := pos + 1;
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    
    sys_write(fd, reqbuf, pos);
    munmap(reqbuf, 64);
    
    // Read into pchar buffer
    var pbuf: pchar := "                    ";
    var n: int64 := sys_read(fd, pbuf, 32);
    PrintStr("pchar read n = ");
    PrintInt(n);
    PrintStr(", buf = [");
    PrintStr(pbuf);
    PrintStr("]\n");
    
    // Now read into mmap buffer
    var mbuf: int64 := mmap(0, 64, 3, 34, -1, 0);
    n := sys_read(fd, mbuf, 64);
    PrintStr("mmap read n = ");
    PrintInt(n);
    PrintStr("\nbytes: ");
    var i: int64 := 0;
    while (i < n) {
        PrintInt(peek8(mbuf + i));
        PrintStr(" ");
        i := i + 1;
    }
    PrintStr("\n");
    
    munmap(mbuf, 64);
    sys_close(fd);
    
    PrintStr("Done\n");
    return 0;
}