// Test select on stdout (sanity check for select)
import std.net.syscalls;

fn main(): int64 {
    PrintStr("=== Test select on stdout ===\n");
    
    // Prepare fd_set for stdout (fd=1)
    var readfds: int64 := mmap(0, 128, 3, 34, -1, 0);
    
    // FD_ZERO
    var i: int64 := 0;
    while (i < 128) {
        poke8(readfds + i, 0);
        i := i + 1;
    }
    
    // FD_SET stdout
    var byte_idx: int64 := 1 / 8;
    var bit_idx: int64 := 1 % 8;
    var current: int64 := peek8(readfds + byte_idx);
    current := current | (1 << bit_idx);
    poke8(readfds + byte_idx, current);
    
    // Timeout 0
    var timeout: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(timeout, 0);  // tv_sec = 0
    
    var n: int64 := Select(2, readfds, 0, 0, timeout);
    PrintStr("select(stdout) n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Try reading from stdout (should fail - not readable)
    var buf: pchar := "                    ";
    var r: int64 := Read(1, buf, 32);
    PrintStr("Read(stdout) = ");
    PrintInt(r);
    PrintStr("\n");
    
    munmap(readfds, 128);
    munmap(timeout, 16);
    
    // Test select on stdin with input
    PrintStr("=== Test select on stdin ===\n");
    
    readfds := mmap(0, 128, 3, 34, -1, 0);
    i := 0;
    while (i < 128) {
        poke8(readfds + i, 0);
        i := i + 1;
    }
    
    // FD_SET stdin (fd=0)
    poke8(readfds, 1);  // set bit 0
    
    timeout := mmap(0, 16, 3, 34, -1, 0);
    poke8(timeout, 2);  // 2 second timeout
    
    n := Select(1, readfds, 0, 0, timeout);
    PrintStr("select(stdin) n = ");
    PrintInt(n);
    PrintStr("\n");
    
    if (n > 0) {
        r := Read(0, buf, 10);
        PrintStr("Read(stdin) = ");
        PrintInt(r);
        PrintStr(", [");
        PrintStr(buf);
        PrintStr("]\n");
    }
    
    munmap(readfds, 128);
    munmap(timeout, 16);
    
    PrintStr("Done\n");
    return 0;
}