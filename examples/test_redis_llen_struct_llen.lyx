// Test PING + 2x LPUSH + LLEN + LPOP + LLEN
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    } else {
        PrintStr("PING failed\n");
    }
    
    RedisDel(conn, "testlist");
    
    var r: RedisReply := RedisLPush(conn, "testlist", "one");
    PrintStr("LPUSH one done\n");
    
    r := RedisLPush(conn, "testlist", "two");
    PrintStr("LPUSH two done\n");
    
    // First LLEN returns int64
    var llen: int64 := RedisLLen(conn, "testlist");
    PrintStr("LLEN 1 = ");
    PrintInt(llen);
    PrintStr("\n");
    
    // LPOP returns struct
    r := RedisLPop(conn, "testlist");
    PrintStr("LPOP done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // Second LLEN - this might be problematic
    llen := RedisLLen(conn, "testlist");
    PrintStr("LLEN 2 = ");
    PrintInt(llen);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}