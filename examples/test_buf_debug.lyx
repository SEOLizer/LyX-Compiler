// Debug buffer addresses
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    
    // First command
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    
    // First buffer
    var buf1: pchar := "                    ";
    var r1: int64 := Read(conn.fd, buf1, 32);
    PrintStr("read1 = ");
    PrintInt(r1);
    PrintStr(", buf1 = [");
    PrintStr(buf1);
    PrintStr("]\n");
    
    // Get address of buf1
    var addr1: int64 := mmap(0, 8, 3, 34, -1, 0);
    var buf1_int: int64 := 0;
    var i: int64 := 0;
    // Copy buf1 pointer (which is in a local slot) - but we can't get that directly
    
    // Second command - print what's being sent
    req := "*1\r\n$4\r\nPING\r\n";
    var w2: int64 := Write(conn.fd, req, 18);
    PrintStr("write2 = ");
    PrintInt(w2);
    PrintStr("\n");
    
    // Second buffer with DIFFERENT NAME
    var buf2: pchar := "                    ";
    PrintStr("about to call Read for buf2\n");
    
    var r2: int64 := Read(conn.fd, buf2, 32);
    PrintStr("read2 = ");
    PrintInt(r2);
    PrintStr(", buf2 = [");
