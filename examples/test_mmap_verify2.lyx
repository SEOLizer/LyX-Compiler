// Test mmap read/write before sys_read
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Test mmap read/write ===\n");
    
    // mmap buffer
    var buf: int64 := mmap(0, 512, 3, 34, -1, 0);
    PrintStr("mmap buf = ");
    PrintInt(buf);
    PrintStr("\n");
    
    // Write pattern
    poke8(buf, 65);  // 'A'
    poke8(buf + 1, 66);  // 'B'
    poke8(buf + 2, 67);  // 'C'
    
    // Read back
    var a: int64 := peek8(buf);
    var b: int64 := peek8(buf + 1);
    var c: int64 := peek8(buf + 2);
    
    PrintStr("Read: ");
    PrintInt(a);
    PrintStr(" ");
    PrintInt(b);
    PrintStr(" ");
    PrintInt(c);
    PrintStr("\n");
    
    // Now test socket + read
    var fd: int64 := sys_socket(2, 1, 0);
    PrintStr("socket = ");
    PrintInt(fd);
    PrintStr("\n");
    
    // Connect to localhost:6379
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(addr + 0, 2);      // sin_family = AF_INET (2)
    poke8(addr + 1, 0);
    poke8(addr + 2, 0x18);   // port 6379 in network order (0x18EB = 6379)
    poke8(addr + 3, 0xEB);
    poke8(addr + 4, 0x7F);   // 127.0.0.1
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    
    var r: int64 := sys_connect(fd, addr, 16);
    PrintStr("connect = ");
    PrintInt(r);
    PrintStr("\n");
    
    // Send PING
    var req: int64 := mmap(0, 32, 3, 34, -1, 0);
    poke8(req + 0, 42);  // *
    poke8(req + 1, 49);  // 1
    poke8(req + 2, 13);  // \r
    poke8(req + 3, 10);  // \n
    poke8(req + 4, 36);  // $
    poke8(req + 5, 52);  // 4
    poke8(req + 6, 13);  // \r
    poke8(req + 7, 10);  // \n
    poke8(req + 8, 80);  // P
    poke8(req + 9, 73);  // I
    poke8(req + 10, 78); // N
    poke8(req + 11, 71); // G
    poke8(req + 12, 13); // \r
    poke8(req + 13, 10); // \n
    
    var w: int64 := sys_write(fd, req, 14);
    PrintStr("write = ");
    PrintInt(w);
    PrintStr("\n");
    
    // Read response into buf (at offset 0)
    PrintStr("Reading into buf (before read): ");
    PrintInt(peek8(buf));
    PrintStr("\n");
    
    var n: int64 := sys_read(fd, buf, 256);
    PrintStr("read n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Check buffer after read
    PrintStr("After read: ");
    var i: int64 := 0;
    while (i < n) {
        PrintInt(peek8(buf + i));
        PrintStr(" ");
        i := i + 1;
    }
    PrintStr("\n");
    
    // Double check with addr
    PrintStr("Direct peek8(buf) = ");
    PrintInt(peek8(buf));
    PrintStr("\n");
    
    sys_close(fd);
    munmap(buf, 512);
    munmap(req, 32);
    munmap(addr, 16);
    
    PrintStr("Done\n");
    return 0;
}