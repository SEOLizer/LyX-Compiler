var globalCounter: int64 := 0;

fn tick() {
  globalCounter++;
}

fn tock() {
  globalCounter--;
}

fn main(): int64 {
  PrintStr("Initial: ");
  PrintInt(globalCounter);
  PrintStr("\n");
  
  tick();
  tick();
  tick();
  PrintStr("After 3 ticks: ");
  PrintInt(globalCounter);
  PrintStr("\n");
  
  tock();
  PrintStr("After 1 tock: ");
  PrintInt(globalCounter);
  PrintStr("\n");
  
  return 0;
}
