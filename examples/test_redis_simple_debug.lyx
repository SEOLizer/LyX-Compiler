// Simple Redis debug test
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Redis Debug ===\n");
    
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    PrintStr("conn.fd = ");
    PrintInt(conn.fd);
    PrintStr("\n");
    PrintStr("conn.buf = ");
    PrintInt(conn.buf);
    PrintStr("\n");
    PrintStr("conn.buf_len = ");
    PrintInt(conn.buf_len);
    PrintStr("\n");
    
    if (conn.fd < 0) { return 1; }
    
    // Manual PING via syscalls
    var reqbuf: int64 := mmap(0, 64, 3, 34, -1, 0);
    var pos: int64 := 0;
    // Build *1\r\n$4\r\nPING\r\n
    poke8(reqbuf + pos, 42); pos := pos + 1;  // *
    poke8(reqbuf + pos, 49); pos := pos + 1;  // 1
    poke8(reqbuf + pos, 13); pos := pos + 1;  // \r
    poke8(reqbuf + pos, 10); pos := pos + 1;  // \n
    poke8(reqbuf + pos, 36); pos := pos + 1;  // $
    poke8(reqbuf + pos, 52); pos := pos + 1;  // 4
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    poke8(reqbuf + pos, 80); pos := pos + 1;  // P
    poke8(reqbuf + pos, 73); pos := pos + 1;  // I
    poke8(reqbuf + pos, 78); pos := pos + 1;  // N
    poke8(reqbuf + pos, 71); pos := pos + 1;  // G
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    
    var sent: int64 := sys_write(conn.fd, reqbuf, pos);
    PrintStr("sent = ");
    PrintInt(sent);
    PrintStr("\n");
    
    // Read using conn.buf
    var n: int64 := sys_read(conn.fd, conn.buf, conn.buf_len - 1);
    PrintStr("read n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Print bytes
    var i: int64 := 0;
    while (i < n) {
        var b: int64 := peek8(conn.buf + i);
        PrintInt(b);
        PrintStr(" ");
        i := i + 1;
    }
    PrintStr("\n");
    
    munmap(reqbuf, 64);
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}