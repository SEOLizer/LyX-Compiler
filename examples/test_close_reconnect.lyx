// Try closing socket between operations
fn main(): int64 {
    PrintStr("=== Test open-read-close-open-read ===\n");
    
    // First connection
    var fd: int64 := sys_socket(2, 1, 0);
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(addr, 2);
    poke8(addr + 2, 0x18);
    poke8(addr + 3, 0xEB);
    poke8(addr + 4, 0x7F);
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    sys_connect(fd, addr, 16);
    munmap(addr, 16);
    PrintStr("connected\n");
    
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    sys_write(fd, req, 18);
    
    var buf: pchar := "                    ";
    var n: int64 := sys_read(fd, buf, 32);
    PrintStr("read1 = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Close socket
    sys_close(fd);
    PrintStr("socket closed\n");
    
    // Reconnect
    fd := sys_socket(2, 1, 0);
    addr := mmap(0, 16, 3, 34, -1, 0);
    poke8(addr, 2);
    poke8(addr + 2, 0x18);
    poke8(addr + 3, 0xEB);
    poke8(addr + 4, 0x7F);
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    sys_connect(fd, addr, 16);
    munmap(addr, 16);
    PrintStr("reconnected\n");
    
    sys_write(fd, req, 18);
    n := sys_read(fd, buf, 32);
    PrintStr("read2 = ");
    PrintInt(n);
    PrintStr("\n");
    
    sys_close(fd);
    return 0;
}