// Minimal test of syscalls for Redis connection
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Minimal Redis Test ===\n");
    
    // Just call RedisConnect - but it expects a string which might cause issues
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    
    PrintStr("fd = ");
    PrintInt(conn.fd);
    PrintStr("\n");
    
    return 0;
}