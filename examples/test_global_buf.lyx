// Test with global buffer
import std.net.syscalls;
import std.net.socket;

// Global buffer
var g_buf: pchar := "                    ";

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    // First command
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    
    // Use global buffer
    var r1: int64 := RecvFrom(conn.fd, g_buf, 32, 0, 0, 0);
    PrintStr("recv1 = ");
    PrintInt(r1);
    PrintStr("\n");
    
    // Second command
    req := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    
    // Use global buffer again
    var r2: int64 := RecvFrom(conn.fd, g_buf, 32, 0, 0, 0);
    PrintStr("recv2 = ");
    PrintInt(r2);
    PrintStr("\n");
    
    Close(conn.fd);
    return 0;
}