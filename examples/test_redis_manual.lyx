// Direct test of RedisConnect without using return value
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Direct Test ===\n");
    
    // Manually do what RedisConnect does
    var conn: RedisConn;
    conn.host := "127.0.0.1";
    conn.port := 6379;
    conn.timeout_ms := 5000;
    conn.fd := -1;
    conn.buf := 0;
    conn.buf_len := 0;
    
    PrintStr("After init: conn.fd=");
    PrintInt(conn.fd);
    PrintStr(" conn.buf=");
    PrintInt(conn.buf);
    PrintStr("\n");
    
    // Manual mmap for buffer
    var buf: int64 := mmap(0, 512, 3, 34, -1, 0);
    PrintStr("Direct mmap result = ");
    PrintInt(buf);
    PrintStr("\n");
    
    if (buf <= 0) {
        PrintStr("mmap failed\n");
        return 1;
    }
    
    conn.buf := buf;
    conn.buf_len := 512;
    
    PrintStr("After mmap: conn.fd=");
    PrintInt(conn.fd);
    PrintStr(" conn.buf=");
    PrintInt(conn.buf);
    PrintStr(" conn.buf_len=");
    PrintInt(conn.buf_len);
    PrintStr("\n");
    
    // Now try socket + connect
    var fd: int64 := sys_socket(2, 1, 0);
    PrintStr("socket = ");
    PrintInt(fd);
    PrintStr("\n");
    
    if (fd < 0) { return 1; }
    
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(addr, 2);
    poke8(addr + 1, 0);
    poke8(addr + 2, 0x18);
    poke8(addr + 3, 0xEB);
    poke8(addr + 4, 0x7F);
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    
    var r: int64 := sys_connect(fd, addr, 16);
    PrintStr("connect = ");
    PrintInt(r);
    PrintStr("\n");
    
    if (r < 0) { return 1; }
    
    conn.fd := fd;
    
    PrintStr("Final: conn.fd=");
    PrintInt(conn.fd);
    PrintStr(" conn.buf=");
    PrintInt(conn.buf);
    PrintStr("\n");
    
    // Send PING
    var reqbuf: int64 := mmap(0, 64, 3, 34, -1, 0);
    var pos: int64 := 0;
    poke8(reqbuf + pos, 42); pos := pos + 1;
    poke8(reqbuf + pos, 49); pos := pos + 1;
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    poke8(reqbuf + pos, 36); pos := pos + 1;
    poke8(reqbuf + pos, 52); pos := pos + 1;
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    poke8(reqbuf + pos, 80); pos := pos + 1;
    poke8(reqbuf + pos, 73); pos := pos + 1;
    poke8(reqbuf + pos, 78); pos := pos + 1;
    poke8(reqbuf + pos, 71); pos := pos + 1;
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    
    sys_write(conn.fd, reqbuf, pos);
    munmap(reqbuf, 64);
    
    // Read into conn.buf
    var n: int64 := sys_read(conn.fd, conn.buf, conn.buf_len - 1);
    PrintStr("read n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Print bytes
    var i: int64 := 0;
    while (i < n) {
        PrintInt(peek8(conn.buf + i));
        PrintStr(" ");
        i := i + 1;
    }
    PrintStr("\n");
    
    sys_close(fd);
    munmap(conn.buf, 512);
    PrintStr("Done\n");
    return 0;
}