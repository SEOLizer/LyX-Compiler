// Test exactly: LPUSH x3 + RPUSH + LLEN + LRANGE + (don't do LPOP/RPOP at all)
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    }
    
    RedisDel(conn, "mylist");
    var r: RedisReply := RedisLPush(conn, "mylist", "first");
    r := RedisLPush(conn, "mylist", "second");
    r := RedisRPush(conn, "mylist", "last");
    PrintStr("Setup done\n");
    
    var llen: int64 := RedisLLen(conn, "mylist");
    PrintStr("LLEN = ");
    PrintInt(llen);
    PrintStr("\n");
    
    r := RedisLRange(conn, "mylist", 0, -1);
    PrintStr("LRANGE done, str_len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    // DON'T DO LPOP - just stop here
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}