// Compare pchar vs mmap buffer for same operation
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    var my_fd: int64 := conn.fd;
    
    // Test 1: pchar buffer
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(my_fd, req, 18);
    
    var pbuf: pchar := "                    ";
    var n: int64 := Read(my_fd, pbuf, 32);
    PrintStr("pchar read n = ");
    PrintInt(n);
    PrintStr(", pbuf = [");
    PrintStr(pbuf);
    PrintStr("]\n");
    
    // Test 2: mmap buffer (same operation)
    Write(my_fd, req, 18);
    
    var mbuf: int64 := mmap(0, 64, 3, 34, -1, 0);
    PrintStr("mmap returned = ");
    PrintInt(mbuf);
    PrintStr("\n");
    
    n := Read(my_fd, mbuf, 64);
    PrintStr("mmap read n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Check bytes
    var i: int64 := 0;
    PrintStr("mmap bytes: ");
    while (i < 10) {
        PrintInt(peek8(mbuf + i));
        PrintStr(" ");
        i := i + 1;
    }
    PrintStr("\n");
    
    munmap(mbuf, 64);
    Close(conn.fd);
    return 0;
}