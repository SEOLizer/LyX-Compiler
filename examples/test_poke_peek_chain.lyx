// Test direct mmap -> poke -> peek without intermediate variable
fn main(): int64 {
    // Direct chain: store mmap result in variable, then use it
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    
    // Use addr in poke8
    poke8(addr, 42);
    
    // Use addr in peek8 - get result directly without storing
    var result: int64 := peek8(addr);
    
    PrintInt(result);
    PrintStr("\n");
    
    // Try again to see if first peek affected anything
    var result2: int64 := peek8(addr);
    PrintInt(result2);
    PrintStr("\n");
    
    munmap(addr, 16);
    return 0;
}