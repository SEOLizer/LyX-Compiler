// Add second read to working pattern
fn main(): int64 {
    PrintStr("=== Test with second read ===\n");
    
    var fd: int64 := sys_socket(2, 1, 0);
    PrintStr("socket fd = ");
    PrintInt(fd);
    PrintStr("\n");
    
    if (fd < 0) { return 1; }
    
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    PrintStr("mmap addr = ");
    PrintInt(addr);
    PrintStr("\n");
    
    if (addr <= 0) {
        sys_close(fd);
        return 1;
    }
    
    poke8(addr, 2);
    poke8(addr + 2, 0x18);
    poke8(addr + 3, 0xEB);
    poke8(addr + 4, 0x7F);
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    
    var result: int64 := sys_connect(fd, addr, 16);
    PrintStr("connect result = ");
    PrintInt(result);
    PrintStr("\n");
    
    munmap(addr, 16);
    
    if (result < 0) {
        sys_close(fd);
        return 1;
    }
    
    PrintStr("Connected!\n");
    
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    var sent: int64 := sys_write(fd, req, 18);
    PrintStr("write sent = ");
    PrintInt(sent);
    PrintStr("\n");
    
    var buf: pchar := "                    ";
    var n: int64 := sys_read(fd, buf, 32);
    PrintStr("read n = ");
    PrintInt(n);
    PrintStr("\nResponse: [");
    PrintStr(buf);
    PrintStr("]\n");
    
    // Second read - same pattern
    PrintStr("=== Second read ===\n");
    req := "*1\r\n$4\r\nPING\r\n";
    sent := sys_write(fd, req, 18);
    PrintStr("write2 sent = ");
    PrintInt(sent);
    PrintStr("\n");
    
    // Add debug before read
    PrintStr("About to call second read...\n");
    
    n := sys_read(fd, buf, 32);
    PrintStr("read2 n = ");
    PrintInt(n);
    PrintStr("\n");
    
    sys_close(fd);
    PrintStr("Done\n");
    
    return 0;
}