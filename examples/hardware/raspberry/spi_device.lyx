// SPI Device Demo - Kommunikation mit SPI-Slave
// Demonstrates: SPI-Kommunikation ueber /dev/spi*
// Hardware: Raspberry Pi mit SPI-Geraet (z.B. Display, Sensor)
//
// SPI-Verkabelung (Beschriftung am Raspberry Pi):
// - SCLK: GPIO11 (Pin 23) - Serial Clock
// - MISO: GPIO9 (Pin 21) - Master In Slave Out
// - MOSI: GPIO10 (Pin 19) - Master Out Slave In
// - CE0: GPIO8 (Pin 24) - Chip Enable 0
// - CE1: GPIO7 (Pin 26) - Chip Enable 1
// - VCC: 3.3V (Pin 1)
// - GND: GND (Pin 6, 9, 14, 20, 25, 30, 34 oder 39)
//
// SPI-Modi:
// - Mode 0: CPOL=0, CPHA=0 (Clock low bei idle, Daten an steigender Flanke)
// - Mode 1: CPOL=0, CPHA=1 (Clock low bei idle, Daten an fallender Flanke)
// - Mode 2: CPOL=1, CPHA=0 (Clock high bei idle, Daten an fallender Flanke)
// - Mode 3: CPOL=1, CPHA=1 (Clock high bei idle, Daten an steigender Flanke)
//
// WICHTIG: SPI muss in raspi-config aktiviert sein!

fn main(): int64 {
    PrintStr("SPI Device Demo\n");
    PrintStr("===============\n");
    PrintStr("\n");
    
    // SPI-Erklaerung
    PrintStr("SPI (Serial Peripheral Interface):\n");
    PrintStr("- Voll-Duplex Kommunikation (gleichzeitig senden und empfangen)\n");
    PrintStr("- Master steuert Clock (SCLK)\n");
    PrintStr("- Mehrere Slaves ueber Chip-Select (CE0, CE1)\n");
    PrintStr("- Verschiedene Takt-Frequenzen moeglich\n");
    PrintStr("\n");
    
    // Typische SPI-Geraete
    PrintStr("Typische SPI-Geraete:\n");
    PrintStr("- ST7735: TFT Display (1.8\" Farbdisplay)\n");
    PrintStr("- MAX6675: Thermoelement-Verstaerker\n");
    PrintStr("- nRF24L01+: Funkmodul (2.4GHz)\n");
    PrintStr("- MFRC522: RFID-Leser\n");
    PrintStr("- MCP3008: 8-Kanal ADC\n");
    PrintStr("\n");
    
    // SPI-Parameter erklaeren
    PrintStr("SPI-Parameter:\n");
    PrintStr("- Takt-Frequenz: bis zu 32 MHz (Raspberry Pi 3)\n");
    PrintStr("- Bit-Order: MSB first oder LSB first\n");
    PrintStr("- Data-Mode: 0, 1, 2, oder 3\n");
    PrintStr("- Chip-Select: CE0 oder CE1\n");
    PrintStr("\n");
    
    // Simuliere SPI-Transaktion
    PrintStr("Simulierte SPI-Transaktion:\n\n");
    
    // Beispiel: ST7735 Display Initialisierung
    PrintStr("1. Display-Reset (CS=0, MOSI=0, SCLK toggeln)\n");
    PrintStr("2. Register 0x01 schreiben (Software Reset)\n");
    PrintStr("3. Warten 150ms\n");
    PrintStr("4. Register 0x11 schreiben (Sleep Out)\n");
    PrintStr("5. Warten 10ms\n");
    PrintStr("6. Register 0x29 schreiben (Display On)\n");
    PrintStr("\n");
    
    // Empfangene Daten anzeigen
    PrintStr("Empfangene Daten (simuliert):\n");
    var i: int64 := 0;
    while (i < 5) {
        PrintStr("  Byte ");
        PrintInt(i);
        PrintStr(": 0x");
        PrintInt(65 + i);  // 0x41, 0x42, ...
        PrintStr(" (ASCII '");
        PrintInt(65 + i);
        PrintStr("')\n");
        i := i + 1;
    }
    
    PrintStr("\nLinux SPI-Zugriff:\n");
    PrintStr("1. /dev/spi0.0 oeffnen\n");
    PrintStr("2. ioctl mit SPI_IOC_WR_MODE setzen\n");
    PrintStr("3. write() mit struct spi_ioc_transfer\n");
    PrintStr("\n");
    
    PrintStr("Demo abgeschlossen.\n");
    
    return 0;
}