// Test using extern functions without pchar
extern fn sys_socket(domain: int64, socktype: int64, protocol: int64): int64;
extern fn sys_connect(fd: int64, addr: int64, len: int64): int64;
extern fn sys_write(fd: int64, buf: int64, count: int64): int64;
extern fn sys_read(fd: int64, buf: int64, count: int64): int64;
extern fn sys_close(fd: int64): int64;
extern fn mmap(addr: int64, len: int64, prot: int64, flags: int64, fd: int64, offset: int64): int64;
extern fn munmap(addr: int64, len: int64): int64;
extern fn poke8(addr: int64, value: int64): void;

fn main(): int64 {
    PrintStr("=== Test ===\n");
    
    var fd: int64 := sys_socket(2, 1, 0);
    PrintStr("fd = ");
    PrintInt(fd);
    PrintStr("\n");
    
    if (fd < 0) { return 1; }
    
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(addr, 2);
    poke8(addr + 2, 0x18);
    poke8(addr + 3, 0xEB);
    poke8(addr + 4, 0x7F);
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    
    var result: int64 := sys_connect(fd, addr, 16);
    munmap(addr, 16);
    
    if (result < 0) {
        sys_close(fd);
        return 1;
    }
    
    PrintStr("connected\n");
    
    // PING using inline bytes
    // "*1\r\n$4\r\nPING\r\n" = 42 49 13 10 36 52 13 10 80 73 78 71 13 10
    var req_addr: int64 := mmap(0, 32, 3, 34, -1, 0);
    poke8(req_addr, 42);
    poke8(req_addr + 1, 49);
    poke8(req_addr + 2, 13);
    poke8(req_addr + 3, 10);
    poke8(req_addr + 4, 36);
    poke8(req_addr + 5, 52);
    poke8(req_addr + 6, 13);
    poke8(req_addr + 7, 10);
    poke8(req_addr + 8, 80);
    poke8(req_addr + 9, 73);
    poke8(req_addr + 10, 78);
    poke8(req_addr + 11, 71);
    poke8(req_addr + 12, 13);
    poke8(req_addr + 13, 10);
    
    sys_write(fd, req_addr, 18);
    munmap(req_addr, 32);
    
    var buf: int64 := mmap(0, 64, 3, 34, -1, 0);
    var n: int64 := sys_read(fd, buf, 64);
    PrintStr("read = ");
    PrintInt(n);
    PrintStr("\n");
    
    munmap(buf, 64);
    sys_close(fd);
    
    PrintStr("Done\n");
    return 0;
}