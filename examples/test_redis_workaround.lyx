// Redis test with socket reconnect workaround
fn main(): int64 {
    PrintStr("=== Redis Test ===\n");
    
    // Helper: create connection
    fn connect(): int64 {
        var fd: int64 := sys_socket(2, 1, 0);
        if (fd < 0) { return -1; }
        
        var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
        poke8(addr, 2);
        poke8(addr + 2, 0x18);
        poke8(addr + 3, 0xEB);
        poke8(addr + 4, 0x7F);
        poke8(addr + 5, 0);
        poke8(addr + 6, 0);
        poke8(addr + 7, 1);
        
        var result: int64 := sys_connect(fd, addr, 16);
        munmap(addr, 16);
        
        if (result < 0) {
            sys_close(fd);
            return -1;
        }
        
        return fd;
    }
    
    // SET testkey
    var fd: int64 := connect();
    if (fd < 0) { PrintStr("connect failed\n"); return 1; }
    PrintStr("Connected\n");
    
    var req: pchar := "*3\r\n$3\r\nSET\r\n$7\r\ntestkey\r\n$5\r\nhello\r\n";
    sys_write(fd, req, 40);
    
    var buf: pchar := "                    ";
    var n: int64 := sys_read(fd, buf, 32);
    PrintStr("SET response: ");
    PrintStr(buf);
    sys_close(fd);
    
    // GET testkey
    fd := connect();
    if (fd < 0) { return 1; }
    PrintStr("Reconnected for GET\n");
    
    req := "*2\r\n$3\r\nGET\r\n$7\r\ntestkey\r\n";
    sys_write(fd, req, 26);
    
    n := sys_read(fd, buf, 32);
    PrintStr("GET response: ");
    PrintStr(buf);
    sys_close(fd);
    
    PrintStr("Done\n");
    return 0;
}