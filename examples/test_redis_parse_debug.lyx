// Debug test - check what's happening
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Debug parseResp ===\n");
    
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) { return 1; }
    
    // Test 1: SET (should return status +OK, kind=2)
    var r: RedisReply := RedisSet(conn, "debugkey", "value");
    PrintStr("SET: kind=");
    PrintInt(r.kind);
    PrintStr(" str_len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    // Test 2: GET integer (EXISTS returns integer, kind=3)
    var exists: int64 := RedisExists(conn, "debugkey");
    PrintStr("EXISTS: ");
    PrintInt(exists);
    PrintStr("\n");
    
    // Test 3: DEL returns integer
    var del: int64 := RedisDel(conn, "debugkey");
    PrintStr("DEL: ");
    PrintInt(del);
    PrintStr("\n");
    
    // Let's check what happens if we look at the raw buffer
    // Send a simple command that returns an integer
    var reqbuf: int64 := mmap(0, 64, 3, 34, -1, 0);
    var pos: int64 := 0;
    
    // INCR counter (returns integer)
    poke8(reqbuf + pos, 42); pos := pos + 1;  // *
    poke8(reqbuf + pos, 51); pos := pos + 1;  // 3
    poke8(reqbuf + pos, 13); pos := pos + 1;
    poke8(reqbuf + pos, 10); pos := pos + 1;
    pos := appendBulk(reqbuf, pos, "INCR");
    pos := appendBulk(reqbuf, pos, "testcounter");
    
    // First set counter to 0
    var setbuf: int64 := mmap(0, 64, 3, 34, -1, 0);
    var p: int64 := 0;
    poke8(setbuf + p, 51); p := p + 1;
    poke8(setbuf + p, 51); p := p + 1;
    poke8(setbuf + p, 13); p := p + 1;
    poke8(setbuf + p, 10); p := p + 1;
    p := appendBulk(setbuf, p, "SET");
    p := appendBulk(setbuf, p, "testcounter");
    p := appendBulk(setbuf, p, "0");
    
    var r2: RedisReply := sendRaw(conn, setbuf, p);
    PrintStr("SET 0: kind=");
    PrintInt(r2.kind);
    PrintStr("\n");
    munmap(setbuf, 64);
    
    r2 := sendRaw(conn, reqbuf, pos);
    PrintStr("INCR: kind=");
    PrintInt(r2.kind);
    PrintStr(" int_val=");
    PrintInt(r2.int_val);
    PrintStr("\n");
    
    // Now test LPUSH
    PrintStr("\n=== Testing LPUSH ===\n");
    var lpushReply: RedisReply := RedisLPush(conn, "testlist", "value1");
    PrintStr("LPUSH result: kind=");
    PrintInt(lpushReply.kind);
    PrintStr("\n");
    
    // Get the raw bytes to see what's there
    r2 := sendRaw(conn, reqbuf, pos);
    // Use peek16 workaround to check first byte
    var first16: int64 := peek16(conn.buf);
    PrintStr("Raw first16: ");
    PrintInt(first16);
    PrintStr(" first byte: ");
    PrintInt(first16 & 0xFF);
    PrintStr("\n");
    
    munmap(reqbuf, 64);
    RedisClose(conn);
    return 0;
}