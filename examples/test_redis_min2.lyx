// Minimal test for Redis library
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Test Redis ===\n");
    
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    PrintStr("conn.fd = ");
    PrintInt(conn.fd);
    PrintStr("\n");
    
    if (conn.fd < 0) {
        PrintStr("connect failed\n");
        return 1;
    }
    
    PrintStr("connected, now pinging...\n");
    var ok: bool := RedisPing(conn);
    PrintStr("ping result = ");
    PrintInt(ok as int64);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("done\n");
    return 0;
}