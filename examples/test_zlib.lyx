// Test zlib compression
import std.zlib;

fn main(): int64 {
    // Test with a longer string
    var test_str: pchar := "Hello, this is a test string for compression!";
    var len: int64 := 0;
    var i: int64 := 0;
    while (StrCharAt(test_str, i) != 0) {
        len := len + 1;
        i := i + 1;
    }
    
    // Calculate Adler-32
    var adler: int64 := Adler32(test_str, len);
    PrintStr("Adler32 of test string: ");
    PrintInt(adler);
    PrintStr("\n");
    
    // Test compression bound
    var bound: int64 := ZlibCompressBound(len);
    PrintStr("Compress bound for ");
    PrintInt(len);
    PrintStr(" bytes: ");
    PrintInt(bound);
    PrintStr(" bytes\n");
    
    PrintStr("Zlib unit tests passed!\n");
    return 0;
}