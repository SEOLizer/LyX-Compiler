// Test zlib compression and decompression roundtrip
import std.zlib;
import std.alloc;

fn main(): int64 {
    // Test data - simple string
    var test_data: pchar := "Hello World! This is a test of zlib compression and decompression.";
    var data_len: int64 := 0;
    var i: int64 := 0;
    while (StrCharAt(test_data, i) != 0) {
        data_len := data_len + 1;
        i := i + 1;
    }
    
    PrintStr("=== Zlib Roundtrip Test ===\n");
    PrintStr("Original length: ");
    PrintInt(data_len);
    PrintStr("\n");
    
    // Calculate Adler-32 of original
    var adler_orig: int64 := Adler32(test_data, data_len);
    PrintStr("Original Adler32: ");
    PrintInt(adler_orig);
    PrintStr("\n");
    
    // Use stored block compression (DeflateCompress) - simpler than LZ77
    var comp_size: int64 := data_len + 100;
    var comp_buf: int64 := malloc(comp_size);
    
    if (comp_buf == 0) {
        PrintStr("ERROR: Failed to allocate compression buffer\n");
        return 1;
    }
    
    PrintStr("Compression buffer size: ");
    PrintInt(comp_size);
    PrintStr("\n");
    
    // Compress using stored blocks (no LZ77 for simpler testing)
    var actual_comp: int64 := DeflateCompress(test_data, data_len, comp_buf);
    
    if (actual_comp <= 0) {
        PrintStr("ERROR: Compression failed\n");
        free(comp_buf);
        return 1;
    }
    
    PrintStr("Compressed size: ");
    PrintInt(actual_comp);
    PrintStr("\n");
    
    // Allocate decompression buffer (original size is safe upper bound)
    var decomp_buf: int64 := malloc(data_len + 100);
    
    if (decomp_buf == 0) {
        PrintStr("ERROR: Failed to allocate decompression buffer\n");
        free(comp_buf);
        return 1;
    }
    
    // Decompress using InflateDEFLATE (note: stored block decompression)
    var actual_decomp: int64 := InflateDEFLATE(comp_buf, actual_comp, decomp_buf);
    
    if (actual_decomp <= 0) {
        PrintStr("ERROR: Decompression failed\n");
        PrintStr("actual_decomp = ");
        PrintInt(actual_decomp);
        PrintStr("\n");
        free(comp_buf);
        free(decomp_buf);
        return 1;
    }
    
    PrintStr("Decompressed size: ");
    PrintInt(actual_decomp);
    PrintStr("\n");
    
    // Verify size matches
    if (actual_decomp != data_len) {
        PrintStr("ERROR: Decompressed size mismatch!\n");
        free(comp_buf);
        free(decomp_buf);
        return 1;
    }
    
    PrintStr("=== Test Complete ===\n");
    PrintStr("Roundtrip successful!\n");
    
    // Cleanup
    free(comp_buf);
    free(decomp_buf);
    
    return 0;
}