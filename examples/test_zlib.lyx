// Test zlib compression with LZ77
import std.zlib;

fn main(): int64 {
    // Test with a longer string
    var test_str: pchar := "Hello, this is a test string for compression!";
    var len: int64 := 0;
    var i: int64 := 0;
    while (StrCharAt(test_str, i) != 0) {
        len := len + 1;
        i := i + 1;
    }
    
    // Calculate Adler-32
    var adler: int64 := Adler32(test_str, len);
    PrintStr("Adler32 of test string: ");
    PrintInt(adler);
    PrintStr("\n");
    
    // Test compression bound
    var bound: int64 := ZlibCompressBound(len);
    PrintStr("Compress bound for ");
    PrintInt(len);
    PrintStr(" bytes: ");
    PrintInt(bound);
    PrintStr(" bytes\n");
    
    // Test LZ77 compression functions
    var lz77_code: int64 := GetFixedLiteralCode(65);  // Test 'A'
    PrintStr("GetFixedLiteralCode(65) = ");
    PrintInt(lz77_code);
    PrintStr("\n");
    
    var dist_code: int64 := GetFixedDistCode(10);
    PrintStr("GetFixedDistCode(10) = ");
    PrintInt(dist_code);
    PrintStr("\n");
    
    PrintStr("Zlib LZ77 unit tests passed!\n");
    return 0;
}