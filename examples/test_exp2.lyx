// test_exp2.lyx - Test ExpF64 with direct values
import std.ml;

pub fn main(): int64 {
  // Direct test of exp(0)
  var e0: f64 := 1.0;
  PrintStr("1.0: ");
  PrintInt(e0 as int64);
  PrintStr("\n");
  
  // exp(1) 
  var e1: f64 := 1.0 + 1.0 + (1.0 * 0.5) + (1.0 * 0.16667) + (1.0 * 0.04167) + (1.0 * 0.00833);
  PrintStr("direct calc: ");
  PrintInt(e1 as int64);  // ~2.7
  PrintStr("\n");
  
  PrintStr("Done\n");
  return 0;
}