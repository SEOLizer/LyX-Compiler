// Test DEL (int64) -> GET (struct) -> GET (struct)
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    } else {
        PrintStr("PING failed\n");
    }
    
    // SET first
    RedisSet(conn, "testkey", "value1");
    PrintStr("SET done\n");
    
    // DEL returns int64
    var delres: int64 := RedisDel(conn, "testkey");
    PrintStr("DEL result = ");
    PrintInt(delres);
    PrintStr("\n");
    
    // GET returns struct - first one
    var r: RedisReply := RedisGet(conn, "testkey");
    PrintStr("GET 1 done\n");
    
    // GET returns struct - second one
    r := RedisGet(conn, "nonexistent");
    PrintStr("GET 2 done\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}