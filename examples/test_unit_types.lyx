// test_unit_types.lyx — Unit Types / Dimensional Analysis demo

unit test.unit_types;

// ── Dimensions ──────────────────────────────────────────────────────────────

pub dim Length;
pub dim Time;
pub dim Mass;
pub dim Speed = Length / Time;
pub dim Angle;
pub dim Data;

// ── Units: base ──────────────────────────────────────────────────────────────

pub utype m:   Length = 1.0;
pub utype km:  Length = 1000.0;
pub utype nmi: Length = 1852.0;

pub utype s:   Time = 1.0;
pub utype ms:  Time = 0.001;
pub utype h:   Time = 3600.0;

pub utype kg:  Mass = 1.0;

// Speed units use the derived dimension name "Speed"
pub utype mps: Speed = 1.0;
pub utype kmh: Speed = 0.27778;
pub utype kts: Speed = 0.51444;

pub utype deg: Angle = 1.0;
pub utype rad: Angle = 57.29578;

pub utype B:   Data = 1.0;
pub utype KB:  Data = 1024.0;
pub utype MB:  Data = 1048576.0;

// ── Test ──────────────────────────────────────────────────────────────────────

pub fn Main(): int64 {
  // Basic unit-typed variables
  var dist: km := 100.0;
  var t: h     := 2.0;
  var w: kg    := 80.0;

  // Arithmetic within same dimension is fine
  var dist2: km := dist + 50.0;

  // Comparison within same dimension: ok
  if (dist > dist2) {
    return 1;
  }

  return 0;
}
