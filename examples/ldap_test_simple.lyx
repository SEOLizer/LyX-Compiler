// Simple LDAP String Test

import std.io;

pub fn main(): int64 {
  var result: int64 := 0;
  
  // Test LDAPErrorToStr
  var errMsg: int64 := LDAPErrorToStr(0);
  if (errMsg != 0) {
    PrintStr("LDAPErrorToStr(0): ");
    PrintStr(errMsg);
    PrintStr("\n");
    result := result + 1;
  }
  
  // Test error message for invalid credentials
  errMsg := LDAPErrorToStr(49);
  if (errMsg != 0) {
    PrintStr("LDAPErrorToStr(49): ");
    PrintStr(errMsg);
    PrintStr("\n");
    result := result + 1;
  }
  
  PrintStr("Basic tests passed: ");
  PrintIntLn(result);
  
  return 0;
}