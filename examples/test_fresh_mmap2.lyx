// Test with fresh mmap each time
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    
    // First: allocate mmap, cast to pchar by passing to Read
    var buf1: int64 := mmap(0, 64, 3, 34, -1, 0);
    var r1: int64 := Read(conn.fd, buf1, 64);
    PrintStr("read1 = ");
    PrintInt(r1);
    PrintStr("\n");
    PrintStr("buf1[0] = ");
    PrintInt(peek8(buf1));
    PrintStr("\n");
    
    munmap(buf1, 64);
    
    // Second: fresh mmap
    req := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    
    var buf2: int64 := mmap(0, 64, 3, 34, -1, 0);
    PrintStr("about to read2...\n");
    var r2: int64 := Read(conn.fd, buf2, 64);
    PrintStr("read2 = ");
    PrintInt(r2);
    PrintStr("\n");
    PrintStr("buf2[0] = ");
    PrintInt(peek8(buf2));
    PrintStr("\n");
    
    munmap(buf2, 64);
    Close(conn.fd);
    return 0;
}