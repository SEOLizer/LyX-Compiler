// Debug - just 3 LPUSH + LLEN + LPOP + (don't even do RPOP)
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    }
    
    RedisDel(conn, "mylist");
    
    var r: RedisReply := RedisLPush(conn, "mylist", "first");
    PrintStr("LPUSH1 done\n");
    
    r := RedisLPush(conn, "mylist", "second");
    PrintStr("LPUSH2 done\n");
    
    r := RedisLPush(conn, "mylist", "last");
    PrintStr("LPUSH3 done\n");
    
    var llen: int64 := RedisLLen(conn, "mylist");
    PrintStr("LLEN = ");
    PrintInt(llen);
    PrintStr("\n");
    
    // Just LPOP - STOP HERE, don't do anything after
    r := RedisLPop(conn, "mylist");
    PrintStr("LPOP result: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // DON'T DO RPOP! Just return
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}