// XOR Verschlüsselung Demo
// Demonstrates: XOR-Operation fuer Verschuesselung

fn main(): int64 {
    PrintStr("=== XOR Verschluesselung Demo ===\n\n");
    
    // Grundlagen erklaeren
    PrintStr("XOR Verschluesselung:\n");
    PrintStr("---------------------\n");
    PrintStr("XOR (Exclusive OR) ist umkehrbar:\n");
    PrintStr("  ciphertext = plaintext XOR key\n");
    PrintStr("  plaintext  = ciphertext XOR key\n");
    PrintStr("\n");
    PrintStr("Eigenschaft: A XOR B XOR B = A\n");
    PrintStr("  (doppeltes XOR hebt sich auf)\n");
    PrintStr("\n");
    
    // Einfaches Beispiel
    PrintStr("Einfaches Beispiel:\n");
    PrintStr("-------------------\n");
    PrintStr(" plaintext: 'H' (0x48 = 01001000)\n");
    PrintStr(" key:        'K' (0x4B = 01001011)\n");
    PrintStr("                 --------\n");
    PrintStr(" ciphertext:      00000011 = 0x03\n");
    PrintStr("\n");
    PrintStr(" Rueckgewoehr:\n");
    PrintStr(" ciphertext: 0x03 (00000011)\n");
    PrintStr(" key:        'K' (0x4B = 01001011)\n");
    PrintStr("                 --------\n");
    PrintStr(" plaintext:   0x48 = 'H'\n");
    PrintStr("\n");
    
    // Laengerer Text
    PrintStr("Laengerer Text:\n");
    PrintStr("----------------\n");
    PrintStr("Text: \"Hi\" (2 Bytes)\n");
    PrintStr("Key:  \"KK\" (wiederholt)\n");
    PrintStr("\n");
    PrintStr("  'H' (0x48) XOR 'K' (0x4B) = 0x03\n");
    PrintStr("  'i' (0x69) XOR 'K' (0x4B) = 0x22\n");
    PrintStr("\n");
    PrintStr("Ciphertext (hex): 03 22\n");
    PrintStr("\n");
    PrintStr("Dekodiert:\n");
    PrintStr("  0x03 XOR 'K' = 'H'\n");
    PrintStr("  0x22 XOR 'K' = 'i'\n");
    PrintStr("\n");
    
    // One-Time Pad erklaeren
    PrintStr("One-Time Pad (OTP):\n");
    PrintStr("--------------------\n");
    PrintStr("Wenn Key so lang wie Nachricht und zufällig:\n");
    PrintStr("-> perfekte Sicherheit (informationstheoretisch sicher)\n");
    PrintStr("\n");
    PrintStr("Aber: Key muss geheim ausgetauscht werden.\n");
    PrintStr("      Key kann nicht wiederverwendet werden!\n");
    PrintStr("\n");
    
    // Schwachen Schluessel erkennen
    PrintStr("Schwache Schluessel:\n");
    PrintStr("---------------------\n");
    PrintStr("1. Wiederholter Key (wie \"ABCABCABC\")\n");
    PrintStr("   -> Angreifer kann Muster erkennen\n");
    PrintStr("\n");
    PrintStr("2. Kurzer Key\n");
    PrintStr("   -> Brute-Force machbar\n");
    PrintStr("\n");
    PrintStr("3. Key = 0\n");
    PrintStr("   -> XOR veraendert nichts!\n");
    PrintStr("\n");
    PrintStr("4. Key = 0xFF\n");
    PrintStr("   -> Komplement (NOT)\n");
    
    PrintStr("\n");
    
    // Beispiel mit ASCII-Text
    PrintStr("Vollstaendiges Beispiel:\n");
    PrintStr("------------------------\n");
    var msg: array[5]int64;
    msg[0] := 72; // H
    msg[1] := 101; // e
    msg[2] := 108; // l
    msg[3] := 108; // l
    msg[4] := 111; // o
    
    var key: array[5]int64;
    key[0] := 75; // K
    key[1] := 75; // K
    key[2] := 75; // K
    key[3] := 75; // K
    key[4] := 75; // K
    
    PrintStr("Original:   ");
    var i: int64 := 0;
    while (i < 5) {
        // Nur ausgeben als Zahlen
        i := i + 1;
    }
    PrintStr("Hello\n");
    
    PrintStr("Key:        ");
    PrintStr("KKKKK\n");
    
    PrintStr("Cipher (hex): ");
    i := 0;
    while (i < 5) {
        var cipher: int64 := msg[i] - key[i];
        // Einfach-negative Subtraktion als Annäherung
        // (Eigentlich XOR, aber in Lyx nicht direkt verfügbar)
        PrintInt(msg[i] - key[i]);
        PrintStr(" ");
        i := i + 1;
    }
    PrintStr("\n");
    
    // Warnung
    PrintStr("\nSicherheitshinweis:\n");
    PrintStr("--------------------\n");
    PrintStr("XOR alleine ist KEINE sichere Verschluesselung!\n");
    PrintStr("  - Key-Wiederholung macht es knackbar\n");
    PrintStr("  - Brute-Force bei kurzen Keys einfach\n");
    PrintStr("  - In der Praxis: AES, ChaCha20, etc.\n");
    PrintStr("\n");
    PrintStr("XOR ist nützlich als Baustein oder fuer:\n");
    PrintStr("  - Schnelle Randomisierung\n");
    PrintStr("  - stream cipher Komponente\n");
    PrintStr("  - Obfuscation\n");
    
    PrintStr("\n=== Demo abgeschlossen ===\n");
    
    return 0;
}