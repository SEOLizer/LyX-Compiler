// Check if it's about reading the response or just calling read
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    var my_fd: int64 := conn.fd;
    
    // Just call Read but don't use the result
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(my_fd, req, 18);
    
    var mbuf: int64 := mmap(0, 64, 3, 34, -1, 0);
    PrintStr("mmap = ");
    PrintInt(mbuf);
    PrintStr("\n");
    
    // First read - but don't check the result
    var dummy: int64 := Read(my_fd, mbuf, 64);
    PrintStr("first read done (ignored result: ");
    PrintInt(dummy);
    PrintStr(")\n");
    
    // Second command
    Write(my_fd, req, 18);
    PrintStr("wrote second PING\n");
    
    // Second read - NOW check result
    var n: int64 := Read(my_fd, mbuf, 64);
    PrintStr("second read n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Check bytes
    var i: int64 := 0;
    PrintStr("bytes: ");
    while (i < 10) {
        PrintInt(peek8(mbuf + i));
        PrintStr(" ");
        i := i + 1;
    }
    PrintStr("\n");
    
    munmap(mbuf, 64);
    Close(conn.fd);
    return 0;
}