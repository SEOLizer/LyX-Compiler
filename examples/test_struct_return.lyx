// Test struct return
type Test = struct {
    a: int64;
    b: int64;
};

fn makeTest(): Test {
    var t: Test;
    t.a := 123;
    t.b := 456;
    return t;
}

fn main(): int64 {
    var result: Test := makeTest();
    PrintInt(result.a);
    PrintStr(" ");
    PrintInt(result.b);
    PrintStr("\n");
    return 0;
}