// Test Redis client - simplified version
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Redis Client Test ===\n");
    
    // Connect to Redis
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    
    if (conn.fd < 0) {
        PrintStr("Failed to connect to Redis (fd < 0)\n");
        return 1;
    }
    
    PrintStr("Connected to Redis!\n");
    
    // Ping
    if (RedisPing(conn)) {
        PrintStr("PING: OK\n");
    } else {
        PrintStr("PING: failed\n");
    }
    
    RedisClose(conn);
    PrintStr("Done.\n");
    
    return 0;
}