// Threading Library Test

import std.thread;
import std.io;

pub fn main(): int64 {
  // Test 1: ThreadSelf
  var tid: int64 := ThreadSelf();
  PrintStr("ThreadSelf: ");
  PrintIntLn(tid);
  
  // Test 2: Mutex
  var mutex: Mutex := MutexInit();
  MutexLock(mutex);
  PrintStr("Mutex lock: OK\n");
  MutexUnlock(mutex);
  PrintStr("Mutex unlock: OK\n");
  
  // Test 3: Atomic
  var atomic: Atomic := AtomicInit(10);
  var old: int64 := AtomicAdd(atomic, 5);
  PrintStr("AtomicAdd old value: ");
  PrintIntLn(old);
  
  // Test 4: CAS
  var result: int64 := CAS(atomic, 15, 20);
  PrintStr("CAS result: ");
  PrintIntLn(result);
  
  // Test 5: Shared memory
  var mem: SharedMem := SharedMemCreate(1024);
  if (mem.data != 0) {
    PrintStr("SharedMemCreate: OK\n");
    SharedMemFree(mem);
  }
  
  PrintStr("All tests passed!\n");
  
  return 0;
}