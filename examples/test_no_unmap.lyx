// Test - DON'T munmap between reads
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    
    var my_fd: int64 := conn.fd;
    
    // First mmap
    var buf1: int64 := mmap(0, 64, 3, 34, -1, 0);
    PrintStr("buf1 = ");
    PrintInt(buf1);
    PrintStr("\n");
    
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(my_fd, req, 18);
    
    var n: int64 := Read(my_fd, buf1, 64);
    PrintStr("read1 = ");
    PrintInt(n);
    PrintStr("\n");
    PrintStr("buf1[0] = ");
    PrintInt(peek8(buf1));
    PrintStr("\n");
    
    // DON'T munmap - keep buf1
    
    // Second mmap for different address
    var buf2: int64 := mmap(0, 64, 3, 34, -1, 0);
    PrintStr("buf2 = ");
    PrintInt(buf2);
    PrintStr("\n");
    
    // Second command
    req := "*1\r\n$4\r\nPING\r\n";
    Write(my_fd, req, 18);
    PrintStr("wrote2\n");
    
    n := Read(my_fd, buf2, 64);
    PrintStr("read2 = ");
    PrintInt(n);
    PrintStr("\n");
    PrintStr("buf2[0] = ");
    PrintInt(peek8(buf2));
    PrintStr("\n");
    
    munmap(buf1, 64);
    munmap(buf2, 64);
    Close(conn.fd);
    return 0;
}