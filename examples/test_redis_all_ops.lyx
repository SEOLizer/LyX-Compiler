// Test all Redis data structure operations
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Redis Data Structures Test ===\n");
    
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Failed to connect\n");
        return 1;
    }
    PrintStr("Connected!\n");
    
    // PING
    if (RedisPing(conn)) {
        PrintStr("PING: OK\n");
    } else {
        PrintStr("PING: FAILED\n");
    }
    
    // ========== STRING Operations ==========
    PrintStr("\n--- Strings ---\n");
    var r: RedisReply := RedisSet(conn, "mykey", "Hello Redis!");
    PrintStr("SET mykey: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    r := RedisGet(conn, "mykey");
    PrintStr("GET mykey: kind=");
    PrintInt(r.kind);
    PrintStr(" str_len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    var exists: int64 := RedisExists(conn, "mykey");
    PrintStr("EXISTS mykey: ");
    PrintInt(exists);
    PrintStr("\n");
    
    // ========== LIST Operations ==========
    PrintStr("\n--- Lists ---\n");
    
    // Clear test list
    RedisDel(conn, "mylist");
    
    // LPUSH
    r := RedisLPush(conn, "mylist", "first");
    PrintStr("LPUSH: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    r := RedisLPush(conn, "mylist", "second");
    PrintStr("LPUSH again: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // RPUSH
    r := RedisRPush(conn, "mylist", "last");
    PrintStr("RPUSH: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // LLEN
    var llen: int64 := RedisLLen(conn, "mylist");
    PrintStr("LLEN mylist: ");
    PrintInt(llen);
    PrintStr("\n");
    
    // LRANGE
    r := RedisLRange(conn, "mylist", 0, -1);
    PrintStr("LRANGE 0,-1: kind=");
    PrintInt(r.kind);
    PrintStr(" len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    // LPOP
    r := RedisLPop(conn, "mylist");
    PrintStr("LPOP: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // RPOP
    r := RedisRPop(conn, "mylist");
    PrintStr("RPOP: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // ========== HASH Operations ==========
    PrintStr("\n--- Hashes ---\n");
    
    // Clear test hash
    RedisDel(conn, "myhash");
    
    // HSET
    r := RedisHSet(conn, "myhash", "name", "Alice");
    PrintStr("HSET name: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    r := RedisHSet(conn, "myhash", "age", "30");
    PrintStr("HSET age: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // HGET
    r := RedisHGet(conn, "myhash", "name");
    PrintStr("HGET name: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // HGETALL
    r := RedisHGetAll(conn, "myhash");
    PrintStr("HGETALL: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // HINCRBY
    r := RedisHIncrBy(conn, "myhash", "age", 1);
    PrintStr("HINCRBY age +1: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // HDEL
    var hdel: int64 := RedisHDel(conn, "myhash", "age");
    PrintStr("HDEL age: ");
    PrintInt(hdel);
    PrintStr("\n");
    
    // ========== SET Operations ==========
    PrintStr("\n--- Sets ---\n");
    
    // Clear test set
    RedisDel(conn, "myset");
    
    // SADD
    r := RedisSAdd(conn, "myset", "apple");
    PrintStr("SADD apple: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    r := RedisSAdd(conn, "myset", "banana");
    PrintStr("SADD banana: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // SISMEMBER
    var ismem: int64 := RedisSIsMember(conn, "myset", "apple");
    PrintStr("SISMEMBER apple: ");
    PrintInt(ismem);
    PrintStr("\n");
    
    ismem := RedisSIsMember(conn, "myset", "cherry");
    PrintStr("SISMEMBER cherry: ");
    PrintInt(ismem);
    PrintStr("\n");
    
    // SREM
    r := RedisSRem(conn, "myset", "banana");
    PrintStr("SREM banana: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // ========== SORTED SET Operations ==========
    PrintStr("\n--- Sorted Sets ---\n");
    
    // Clear test zset
    RedisDel(conn, "myzset");
    
    // ZADD
    r := RedisZAdd(conn, "myzset", 100, "player1");
    PrintStr("ZADD player1: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    r := RedisZAdd(conn, "myzset", 200, "player2");
    PrintStr("ZADD player2: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    r := RedisZAdd(conn, "myzset", 150, "player3");
    PrintStr("ZADD player3: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // ZRANGE
    r := RedisZRange(conn, "myzset", 0, -1);
    PrintStr("ZRANGE: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // ZREVRANK
    var rank: int64 := RedisZRevRank(conn, "myzset", "player1");
    PrintStr("ZREVRANK player1: ");
    PrintInt(rank);
    PrintStr("\n");
    
    // ========== KEY Expiration ==========
    PrintStr("\n--- Key Expiration ---\n");
    
    // Set a key with expiration
    RedisSet(conn, "tempkey", "expires");
    var expire: int64 := RedisExpire(conn, "tempkey", 60);
    PrintStr("EXPIRE tempkey 60: ");
    PrintInt(expire);
    PrintStr("\n");
    
    var ttl: int64 := RedisTTL(conn, "tempkey");
    PrintStr("TTL tempkey: ");
    PrintInt(ttl);
    PrintStr("\n");
    
    // UNLINK
    var unlink: int64 := RedisUnlink(conn, "tempkey");
    PrintStr("UNLINK tempkey: ");
    PrintInt(unlink);
    PrintStr("\n");
    
    // ========== Cleanup ==========
    PrintStr("\n--- Cleanup ---\n");
    RedisDel(conn, "mylist");
    RedisDel(conn, "myhash");
    RedisDel(conn, "myset");
    RedisDel(conn, "myzset");
    RedisDel(conn, "mykey");
    PrintStr("Cleaned up test keys\n");
    
    RedisClose(conn);
    PrintStr("\nDone!\n");
    return 0;
}