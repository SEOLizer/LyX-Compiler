// Fresh buffers each time
import std.net.socket;

fn main(): int64 {
    PrintStr("=== Test fresh buffers ===\n");
    
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { PrintStr("Connect failed\n"); return 1; }
    PrintStr("Connected\n");
    
    // SET
    var req: pchar := "*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n";
    sys_write(conn.fd, req, 36);
    
    var buf1: pchar := "                    ";
    var n: int64 := sys_read(conn.fd, buf1, 32);
    PrintStr("SET response n = ");
    PrintInt(n);
    PrintStr(", buf = [");
    PrintStr(buf1);
    PrintStr("]\n");
    
    // GET with completely different buffer
    req := "*2\r\n$3\r\nGET\r\n$3\r\nkey\r\n";
    sys_write(conn.fd, req, 26);
    
    var buf2: pchar := "                    ";
    n := sys_read(conn.fd, buf2, 32);
    PrintStr("GET response n = ");
    PrintInt(n);
    PrintStr(", buf = [");
    PrintStr(buf2);
    PrintStr("]\n");
    
    sys_close(conn.fd);
    PrintStr("Done\n");
    
    return 0;
}