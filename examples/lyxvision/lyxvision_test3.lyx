// Test mit StaticText
import std.lyxvision.main as lv;
import std.lyxvision.consts;
import std.lyxvision.window;
import std.lyxvision.statictext;

fn main(): int64 {
  lv.Init();
  
  lv.SetColors(colorLightGray, colorBlue);
  lv.FillRect(1, 1, 80, 24);
  
  var win1: TWindow := WindowNew(5, 3, 35, 14, "Test");
  WindowDraw(win1);
  
  var st1: TStaticText := StaticTextNew(7, 5, 25, "Hello World");
  StaticTextDraw(st1);
  
  lv.WriteStr(2, 24, " Press ESC or q ");
  
  lv.RunSimple();
  
  lv.Done();
  PrintStr("\nOK\n");
  return 0;
}
