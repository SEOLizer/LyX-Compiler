// Test poke/peek on stack using local variable address
fn main(): int64 {
    PrintStr("=== Stack test ===\n");
    
    // Just use an int64 and assume it's at a known stack location
    var x: int64 := 0;
    var y: int64 := 0;
    
    // Write using poke16 at y's address
    poke16(&y, 65);
    
    // Read from y
    var val: int64 := peek16(&y);
    PrintStr("peek16(&y) = ");
    PrintInt(val);
    PrintStr("\n");
    
    PrintStr("Done\n");
    return 0;
}