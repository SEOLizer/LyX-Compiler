// Test if second write succeeds
import std.net.socket;

fn main(): int64 {
    PrintStr("=== Test write verification ===\n");
    
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { PrintStr("Connect failed\n"); return 1; }
    PrintStr("Connected, fd = ");
    PrintInt(conn.fd);
    PrintStr("\n");
    
    // First command
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    PrintStr("Before first write\n");
    var n: int64 := sys_write(conn.fd, req, 18);
    PrintStr("First write n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Read response
    var buf: pchar := "                    ";
    n := sys_read(conn.fd, buf, 32);
    PrintStr("First read n = ");
    PrintInt(n);
    PrintStr(", buf = [");
    PrintStr(buf);
    PrintStr("]\n");
    
    // Check socket state
    PrintStr("Checking socket state...\n");
    
    // Second command
    PrintStr("About to do second write\n");
    req := "*1\r\n$4\r\nPING\r\n";
    n := sys_write(conn.fd, req, 18);
    PrintStr("Second write n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // If second write succeeds, try reading
    if (n > 0) {
        PrintStr("Second write succeeded, reading...\n");
        n := sys_read(conn.fd, buf, 32);
        PrintStr("Second read n = ");
        PrintInt(n);
    } else {
        PrintStr("Second write failed!\n");
    }
    
    sys_close(conn.fd);
    PrintStr("Done\n");
    
    return 0;
}