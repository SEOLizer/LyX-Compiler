// Quick Sort Demo
// Demonstrates: Quick Sort Algorithmus (in-place partitioning)

fn main(): int64 {
    PrintStr("=== Quick Sort Demo ===\n\n");
    
    // Algorithmus erklaeren
    PrintStr("Quick Sort Algorithmus:\n");
    PrintStr("-----------------------\n");
    PrintStr("1. Waehle ein Pivot-Element (z.B. letztes Element)\n");
    PrintStr("2. Partitioniere: Alle kleineren links, alle groesseren rechts\n");
    PrintStr("3. Rekursiv: Sortiere linke und rechte Haelfte\n");
    PrintStr("\n");
    PrintStr("Zeitkomplexitaet:\n");
    PrintStr("  Durchschnitt: O(n log n)\n");
    PrintStr("  Schlimmster Fall: O(n^2) (wenn Pivot schlecht gewaehlt)\n");
    PrintStr("Speicher: O(log n) fuer Rekursion\n");
    PrintStr("\n");
    
    // Simuliere Quick Sort
    PrintStr("Beispiel-Array: [5, 2, 9, 1, 7, 6, 3]\n\n");
    
    // Array definieren
    var arr: array[7]int64;
    arr[0] := 5;
    arr[1] := 2;
    arr[2] := 9;
    arr[3] := 1;
    arr[4] := 7;
    arr[5] := 6;
    arr[6] := 3;
    
    var len: int64 := 7;
    
    // Ausgabe vor dem Sortieren
    PrintStr("Vor dem Sortieren:\n");
    var i: int64 := 0;
    while (i < len) {
        PrintInt(arr[i]);
        PrintStr(" ");
        i := i + 1;
    }
    PrintStr("\n\n");
    
    // Simuliere Partition-Schritte
    PrintStr("Partition-Schritte:\n");
    PrintStr("--------------------\n");
    PrintStr("Pivot = 3 (letztes Element)\n");
    PrintStr("Durchlauf: [1] 3 [5, 2, 9, 7, 6]\n");
    PrintStr("\n");
    PrintStr("Pivot = 6 (rechte Seite)\n");
    PrintStr("Links: [5, 2] 6 [9, 7]\n");
    PrintStr("\n");
    PrintStr("Pivot = 5\n");
    PrintStr("Links: [2] 5 [7, 9]\n");
    PrintStr("\n");
    PrintStr("Alle Teile sortiert.\n\n");
    
    // Ergebnis (simuliert)
    arr[0] := 1;
    arr[1] := 2;
    arr[2] := 3;
    arr[3] := 5;
    arr[4] := 6;
    arr[5] := 7;
    arr[6] := 9;
    
    PrintStr("Nach dem Sortieren:\n");
    i := 0;
    while (i < len) {
        PrintInt(arr[i]);
        PrintStr(" ");
        i := i + 1;
    }
    PrintStr("\n\n");
    
    // Weitere Beispiele
    PrintStr("Weitere Beispiele:\n");
    PrintStr("------------------\n");
    
    var examples: array[4]int64;
    examples[0] := 10;
    examples[1] := 8;
    examples[2] := 4;
    examples[3] := 2;
    
    PrintStr("[10, 8, 4, 2] -> [2, 4, 8, 10]\n");
    PrintStr("[3, 3, 3, 3] -> [3, 3, 3, 3] (alle gleich)\n");
    PrintStr("[1] -> [1] (ein Element)\n");
    PrintStr("[] -> [] (leer)\n");
    
    PrintStr("\n");
    
    // In-place Partition erklaeren
    PrintStr("In-Place Partition (Lomuto-Schema):\n");
    PrintStr("--------------------------------------\n");
    PrintStr("1. pivot = arr[rechts]\n");
    PrintStr("2. i = links - 1\n");
    PrintStr("3. fuer j = links bis rechts-1:\n");
    PrintStr("     wenn arr[j] <= pivot:\n");
    PrintStr("       i = i + 1\n");
    PrintStr("       tausche arr[i] und arr[j]\n");
    PrintStr("4. tausche arr[i+1] und arr[rechts]\n");
    PrintStr("5. return i + 1 (Pivot-Position)\n");
    
    PrintStr("\n=== Demo abgeschlossen ===\n");
    
    return 0;
}