// Minimal LPOP test
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    // PING first
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    } else {
        PrintStr("PING failed\n");
    }
    
    // Clear and setup list
    RedisDel(conn, "testlist");
    RedisLPush(conn, "testlist", "one");
    RedisLPush(conn, "testlist", "two");
    RedisLPush(conn, "testlist", "three");
    
    var llen: int64 := RedisLLen(conn, "testlist");
    PrintStr("LLEN = ");
    PrintInt(llen);
    PrintStr("\n");
    
    // Single LPOP
    var r: RedisReply := RedisLPop(conn, "testlist");
    PrintStr("LPOP kind=");
    PrintInt(r.kind);
    PrintStr(" str_len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    llen := RedisLLen(conn, "testlist");
    PrintStr("LLEN after LPOP = ");
    PrintInt(llen);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}