// Inline test without importing redis unit to trace struct return
import std.net.syscalls;

fn main(): int64 {
    // Simulate what RedisConnect does
    var fd: int64   := -1;
    var buf: int64  := 0;
    var blen: int64 := 0;

    // mmap buf
    buf := mmap(0, 512, 3, 34, -1, 0);
    PrintStr("mmap buf = ");
    PrintInt(buf);
    PrintStr("\n");
    if (buf <= 0) { PrintStr("mmap failed\n"); return 1; }
    blen := 512;

    // socket
    fd := sys_socket(2, 1, 0);
    PrintStr("socket fd = ");
    PrintInt(fd);
    PrintStr("\n");

    // connect
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(addr,     2);
    poke8(addr + 1, 0);
    poke8(addr + 2, 0x18);   // port 6379 high byte
    poke8(addr + 3, 0xEB);   // port 6379 low byte
    poke8(addr + 4, 0x7F);
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    var r: int64 := sys_connect(fd, addr, 16);
    munmap(addr, 16);

    PrintStr("connect = ");
    PrintInt(r);
    PrintStr("\n");
    if (r < 0) { return 1; }

    // PING
    var reqbuf: int64 := mmap(0, 64, 3, 34, -1, 0);
    poke8(reqbuf, 42); poke8(reqbuf+1, 49); poke8(reqbuf+2, 13); poke8(reqbuf+3, 10);
    poke8(reqbuf+4, 36); poke8(reqbuf+5, 52); poke8(reqbuf+6, 13); poke8(reqbuf+7, 10);
    poke8(reqbuf+8, 80); poke8(reqbuf+9, 73); poke8(reqbuf+10, 78); poke8(reqbuf+11, 71);
    poke8(reqbuf+12, 13); poke8(reqbuf+13, 10);

    var sent: int64 := sys_write(fd, reqbuf, 14);
    PrintStr("sent = ");
    PrintInt(sent);
    PrintStr("\n");

    var n: int64 := sys_read(fd, buf, blen - 1);
    PrintStr("n = ");
    PrintInt(n);
    PrintStr("\n");

    if (n > 0) {
        PrintStr("response byte0 = ");
        PrintInt(peek8(buf));
        PrintStr("\n");
    }

    munmap(reqbuf, 64);
    munmap(buf, blen);
    sys_close(fd);
    PrintStr("Done\n");
    return 0;
}
