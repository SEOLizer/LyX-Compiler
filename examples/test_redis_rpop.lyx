// Test RPOP specifically
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    } else {
        PrintStr("PING failed\n");
    }
    
    RedisDel(conn, "testlist");
    
    // Setup with RPUSH (since lists are typically used with RPUSH)
    var r: RedisReply := RedisRPush(conn, "testlist", "one");
    PrintStr("RPUSH one done\n");
    
    r := RedisRPush(conn, "testlist", "two");
    PrintStr("RPUSH two done\n");
    
    r := RedisRPush(conn, "testlist", "three");
    PrintStr("RPUSH three done\n");
    
    var llen: int64 := RedisLLen(conn, "testlist");
    PrintStr("LLEN = ");
    PrintInt(llen);
    PrintStr("\n");
    
    // First RPOP
    r := RedisRPop(conn, "testlist");
    PrintStr("RPOP 1 done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // Second RPOP
    r := RedisRPop(conn, "testlist");
    PrintStr("RPOP 2 done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}