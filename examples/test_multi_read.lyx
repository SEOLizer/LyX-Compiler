// Test read behavior after first read
import std.net.socket;

fn main(): int64 {
    PrintStr("=== Test read after read ===\n");
    
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { PrintStr("Connect failed\n"); return 1; }
    PrintStr("Connected\n");
    
    // PING - will get response
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    var sent: int64 := sys_write(conn.fd, req, 18);
    PrintStr("Sent PING\n");
    
    // First read
    var buf: pchar := "                    ";
    var n: int64 := sys_read(conn.fd, buf, 32);
    PrintStr("First read n = ");
    PrintInt(n);
    PrintStr(", buf = [");
    PrintStr(buf);
    PrintStr("]\n");
    
    // Second read immediately (nothing written)
    n := sys_read(conn.fd, buf, 32);
    PrintStr("Second read n = ");
    PrintInt(n);
    
    // Third read after writing
    req := "*1\r\n$4\r\nPING\r\n";
    sys_write(conn.fd, req, 18);
    n := sys_read(conn.fd, buf, 32);
    PrintStr("Third read n = ");
    PrintInt(n);
    PrintStr(", buf = [");
    PrintStr(buf);
    PrintStr("]\n");
    
    sys_close(conn.fd);
    PrintStr("Done\n");
    
    return 0;
}