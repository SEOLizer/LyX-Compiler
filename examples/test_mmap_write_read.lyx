// Verify mmap address is correct by writing THEN reading
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    var my_fd: int64 := conn.fd;
    
    // Allocate mmap
    var mbuf: int64 := mmap(0, 64, 3, 34, -1, 0);
    PrintStr("mmap = ");
    PrintInt(mbuf);
    PrintStr("\n");
    
    // Write to mmap BEFORE reading
    poke8(mbuf, 65);  // 'A'
    poke8(mbuf + 1, 66);  // 'B'
    PrintStr("Wrote AB to mmap\n");
    
    // Verify what we wrote
    PrintStr("peek8(mbuf) = ");
    PrintInt(peek8(mbuf));
    PrintStr("\n");
    PrintStr("peek8(mbuf+1) = ");
    PrintInt(peek8(mbuf + 1));
    PrintStr("\n");
    
    // Now write PING
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(my_fd, req, 18);
    PrintStr("wrote PING\n");
    
    // Now read into same mmap buffer
    var n: int64 := Read(my_fd, mbuf, 64);
    PrintStr("read n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Check what we got
    PrintStr("peek8(mbuf) after read = ");
    PrintInt(peek8(mbuf));
    PrintStr("\n");
    PrintStr("peek8(mbuf+1) = ");
    PrintInt(peek8(mbuf + 1));
    PrintStr("\n");
    
    // Print as string
    var i: int64 := 0;
    PrintStr("read content: ");
    while (i < 10) {
        var b: int64 := peek8(mbuf + i);
        if (b >= 32 && b < 127) {
            var c: pchar := " ";
            StrSetChar(c, 0, b);
            PrintStr(c);
        }
        i := i + 1;
    }
    PrintStr("\n");
    
    munmap(mbuf, 64);
    Close(conn.fd);
    return 0;
}