// Simple Redis SET/GET test with hex debugging
import std.net.socket;

fn main(): int64 {
    PrintStr("=== Redis SET/GET Debug ===\n");
    
    // Connect
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    // SET key
    var req: pchar := "*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n";
    var sent: int64 := TCPConnWrite(conn, req, 36);
    PrintStr("SET sent: ");
    PrintInt(sent);
    PrintStr("\n");
    
    var buf: pchar := "                    ";
    var n: int64 := TCPConnRead(conn, buf, 32);
    PrintStr("SET response: [");
    PrintStr(buf);
    PrintStr("]\n");
    
    // GET key
    req := "*2\r\n$3\r\nGET\r\n$3\r\nkey\r\n";
    sent := TCPConnWrite(conn, req, 26);
    PrintStr("GET sent: ");
    PrintInt(sent);
    PrintStr("\n");
    
    n := TCPConnRead(conn, buf, 32);
    PrintStr("GET response: [");
    PrintStr(buf);
    PrintStr("]\n");
    
    TCPConnClose(conn);
    PrintStr("Done\n");
    
    return 0;
}