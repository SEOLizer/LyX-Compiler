// Test PING -> DEL -> LPUSH -> LPUSH -> LPOP -> RPOP
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    } else {
        PrintStr("PING failed\n");
    }
    
    RedisDel(conn, "mylist");
    PrintStr("DEL done\n");
    
    var r: RedisReply := RedisLPush(conn, "mylist", "one");
    PrintStr("LPUSH1 done\n");
    
    r := RedisLPush(conn, "mylist", "two");
    PrintStr("LPUSH2 done\n");
    
    r := RedisLPop(conn, "mylist");
    PrintStr("LPOP done\n");
    
    r := RedisRPop(conn, "mylist");
    PrintStr("RPOP done\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}