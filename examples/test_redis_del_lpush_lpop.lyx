// Test DEL (int64) -> LPOP (struct)
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    } else {
        PrintStr("PING failed\n");
    }
    
    // DEL returns int64
    var delres: int64 := RedisDel(conn, "mylist");
    PrintStr("DEL result = ");
    PrintInt(delres);
    PrintStr("\n");
    
    // Setup list
    RedisLPush(conn, "mylist", "a");
    RedisLPush(conn, "mylist", "b");
    PrintStr("Setup done\n");
    
    // LPOP returns struct
    var r: RedisReply := RedisLPop(conn, "mylist");
    PrintStr("LPOP done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}