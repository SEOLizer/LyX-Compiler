// Test LLEN which returns int64 (not a struct)
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    } else {
        PrintStr("PING failed\n");
    }
    
    // Setup list using integer-returning functions
    RedisDel(conn, "testlist");
    RedisLPush(conn, "testlist", "one");
    RedisLPush(conn, "testlist", "two");
    RedisLPush(conn, "testlist", "three");
    
    // LLEN returns int64
    var llen: int64 := RedisLLen(conn, "testlist");
    PrintStr("LLEN = ");
    PrintInt(llen);
    PrintStr("\n");
    
    // Test DEL (returns int64)
    var delres: int64 := RedisDel(conn, "testlist");
    PrintStr("DEL result = ");
    PrintInt(delres);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}