// Test with poll() and more debug
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    // Prepare pollfd
    var fds: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(fds, conn.fd);        // fd
    poke8(fds + 2, 1);          // events = POLLIN (readable)
    
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    PrintStr("wrote PING\n");
    
    var n: int64 := Poll(fds, 1, 1000);
    PrintStr("poll1 n = ");
    PrintInt(n);
    PrintStr("\n");
    
    if (n > 0) {
        var buf: pchar := "                    ";
        var r: int64 := Read(conn.fd, buf, 32);
        PrintStr("read1 = ");
        PrintInt(r);
        PrintStr(", buf = [");
        PrintStr(buf);
        PrintStr("]\n");
    }
    
    // Second command
    req := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    PrintStr("wrote PING2\n");
    
    n := Poll(fds, 1, 1000);
    PrintStr("poll2 n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Check what's in pollfd after poll2
    var revents: int64 := peek8(fds + 4);  // revents field
    PrintStr("poll revents = ");
    PrintInt(revents);
    PrintStr("\n");
    
    // Try reading even though poll shows data
    var buf: pchar := "                    ";
    PrintStr("about to read2...\n");
    var r: int64 := Read(conn.fd, buf, 32);
    PrintStr("read2 = ");
    PrintInt(r);
    PrintStr("\n");
    
    munmap(fds, 16);
    Close(conn.fd);
    PrintStr("done\n");
    return 0;
}