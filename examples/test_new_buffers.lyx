// Test without reconnect but new variable
import std.net.socket;

fn main(): int64 {
    PrintStr("=== Test without reconnect ===\n");
    
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { PrintStr("Connect failed\n"); return 1; }
    PrintStr("Connected\n");
    
    // First read with buffer1
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    sys_write(conn.fd, req, 18);
    var buf1: pchar := "                    ";
    var n1: int64 := sys_read(conn.fd, buf1, 32);
    PrintStr("buf1 read n = ");
    PrintInt(n1);
    PrintStr("\n");
    
    // Second read with NEW buffer variable
    req := "*1\r\n$4\r\nPING\r\n";
    sys_write(conn.fd, req, 18);
    var buf2: pchar := "                    ";
    var n2: int64 := sys_read(conn.fd, buf2, 32);
    PrintStr("buf2 read n = ");
    PrintInt(n2);
    PrintStr("\n");
    
    // Third read with another NEW buffer
    req := "*1\r\n$4\r\nPING\r\n";
    sys_write(conn.fd, req, 18);
    var buf3: pchar := "                    ";
    var n3: int64 := sys_read(conn.fd, buf3, 32);
    PrintStr("buf3 read n = ");
    PrintInt(n3);
    PrintStr("\n");
    
    sys_close(conn.fd);
    PrintStr("Done\n");
    
    return 0;
}