fn double(x: int64): int64 {
  return x * 2;
}

fn addOne(x: int64): int64 {
  return x + 1;
}

fn main(): int64 {
  var x: int64 := 5;
  
  var pipeResult: int64 := x |> double() |> addOne();
  var classicResult: int64 := addOne(double(x));
  
  PrintStr("Pipe:     5 |> double |> addOne = ");
  PrintInt(pipeResult);
  PrintStr("\n");
  
  PrintStr("Classic:  addOne(double(5)) = ");
  PrintInt(classicResult);
  PrintStr("\n");
  
  if (pipeResult == classicResult) {
    PrintStr("Both are equal!\n");
  } else {
    PrintStr("ERROR: Results differ!\n");
  }
  
  return 0;
}
