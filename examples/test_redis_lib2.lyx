// Test updated std.db.redis
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Test Redis Library ===\n");
    
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    
    if (conn.fd < 0) {
        PrintStr("Failed to connect\n");
        return 1;
    }
    
    PrintStr("Connected!\n");
    
    // Ping
    var ok: bool := RedisPing(conn);
    PrintStr("Ping: ");
    if (ok) { PrintStr("OK\n"); } else { PrintStr("FAILED\n"); }
    
    // Set
    var reply: RedisReply := RedisSet(conn, "testkey", "hello");
    PrintStr("SET: kind=");
    PrintInt(reply.kind);
    PrintStr("\n");
    
    // Get
    reply := RedisGet(conn, "testkey");
    PrintStr("GET: kind=");
    PrintInt(reply.kind);
    PrintStr(", val=[");
    PrintStr(reply.str_val);
    PrintStr("]\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    
    return 0;
}