// Simpler test to verify output
import std.db.redis;

fn main(): int64 {
    PrintStr("Starting test...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    PrintStr("After connect\n");
    if (conn.fd < 0) { 
        PrintStr("Connection failed\n");
        return 1; 
    }
    
    PrintStr("Pinging...\n");
    var ping_result: bool := RedisPing(conn);
    PrintStr("After ping\n");
    
    PrintStr("Doing list ops...\n");
    var r: RedisReply := RedisLPush(conn, "mylist", "first");
    PrintStr("After LPUSH 1\n");
    r := RedisLPush(conn, "mylist", "second");
    PrintStr("After LPUSH 2\n");
    r := RedisRPush(conn, "mylist", "last");
    PrintStr("After RPUSH\n");
    var llen: int64 := RedisLLen(conn, "mylist");
    PrintStr("After LLEN\n");
    r := RedisLRange(conn, "mylist", 0, -1);
    PrintStr("After LRANGE\n");
    r := RedisLPop(conn, "mylist");
    PrintStr("After LPOP\n");
    r := RedisRPop(conn, "mylist");
    PrintStr("After RPOP\n");
    
    PrintStr("Doing hash ops...\n");
    var del_result: int64 := RedisDel(conn, "myhash");
    PrintStr("After DEL\n");
    r := RedisHSet(conn, "myhash", "name", "Alice");
    PrintStr("After HSET 1\n");
    r := RedisHSet(conn, "myhash", "age", "30");
    PrintStr("After HSET 2\n");
    r := RedisHGet(conn, "myhash", "name");
    PrintStr("After HGET\n");
    r := RedisHGetAll(conn, "myhash");
    PrintStr("After HGETALL\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}