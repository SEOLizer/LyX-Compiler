// Test LRANGE after 2 LPOPs
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    }
    
    RedisDel(conn, "mylist");
    var r: RedisReply := RedisLPush(conn, "mylist", "first");
    r := RedisLPush(conn, "mylist", "second");
    r := RedisLPush(conn, "mylist", "last");
    PrintStr("Setup done\n");
    
    // TWO LPOPs
    r := RedisLPop(conn, "mylist");
    PrintStr("LPOP1 done\n");
    
    r := RedisLPop(conn, "mylist");
    PrintStr("LPOP2 done\n");
    
    // Now LRANGE - might crash
    r := RedisLRange(conn, "mylist", 0, -1);
    PrintStr("LRANGE done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}