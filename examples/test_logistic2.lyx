// test_logistic2.lyx - Test Logistic Regression with simpler data
import std.ml;

pub fn main(): int64 {
  // Very simple: x=0 -> 0, x=10 -> 1
  // Should learn threshold around x=5
  LogisticRegressionInit();
  
  // Higher learning rate, more epochs
  LogisticRegressionFit(
    0.0, 10.0, 10.0, 20.0,  // x values
    0.0, 1.0, 1.0, 1.0,   // y values (0,1,1,1)
    1.0,                     // high learning rate
    5000                      // many epochs
  );
  
  PrintStr("Weight: ");
  PrintInt(LogisticRegressionWeight() as int64);
  PrintStr("\nBias: ");
  PrintInt(LogisticRegressionBias() as int64);
  PrintStr("\nLoss: ");
  PrintInt(LogisticRegressionLoss() as int64);
  PrintStr("\nAcc: ");
  PrintInt(LogisticRegressionAccuracy() as int64);
  PrintStr("\n");
  
  // Test
  PrintStr("P(0): ");
  PrintInt(LogisticRegressionPredictProb(0.0) as int64);
  PrintStr("\nP(5): ");
  PrintInt(LogisticRegressionPredictProb(5.0) as int64);
  PrintStr("\nP(10): ");
  PrintInt(LogisticRegressionPredictProb(10.0) as int64);
  PrintStr("\nDone\n");
  
  return 0;
}