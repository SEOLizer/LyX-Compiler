// Test if output flushes something - do stdout between network ops
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    var my_fd: int64 := conn.fd;
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    
    // First network op
    Write(my_fd, req, 18);
    
    var mbuf: int64 := mmap(0, 64, 3, 34, -1, 0);
    var n: int64 := Read(my_fd, mbuf, 64);
    PrintStr("read1 n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // DO stdout between operations
    PrintStr("--- output between network ops ---\n");
    
    // Second network op
    Write(my_fd, req, 18);
    PrintStr("wrote2\n");
    
    n := Read(my_fd, mbuf, 64);
    PrintStr("read2 n = ");
    PrintInt(n);
    PrintStr("\n");
    
    munmap(mbuf, 64);
    Close(conn.fd);
    return 0;
}