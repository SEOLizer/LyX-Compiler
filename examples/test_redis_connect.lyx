// Test just the connection part of std.db.redis
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Redis Connect Test ===\n");
    
    // Connect to Redis - simplified call
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    
    PrintStr("After RedisConnect, fd = ");
    PrintInt(conn.fd);
    PrintStr("\n");
    
    if (conn.fd < 0) {
        PrintStr("Failed to connect\n");
        return 1;
    }
    
    PrintStr("Connected successfully!\n");
    
    // Just ping
    var ping_ok: bool := RedisPing(conn);
    PrintStr("Ping: ");
    PrintInt(ping_ok as int64);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done.\n");
    
    return 0;
}