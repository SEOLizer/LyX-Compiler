// Test just connect (no send/receive)
fn main(): int64 {
    PrintStr("=== Test connect only ===\n");
    
    var fd: int64 := sys_socket(2, 1, 0);
    PrintStr("socket = ");
    PrintInt(fd);
    PrintStr("\n");
    
    if (fd < 0) { return 1; }
    
    // Create address using mmap + poke16
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    
    // sin_family = AF_INET (2)
    poke16(addr + 0, 2);
    
    // sin_port = 6379 in network order (0x18EB)
    poke16(addr + 2, 0x18EB);
    
    // sin_addr = 127.0.0.1 in network order (0x0100007F -> 0x7F000001)
    // Actually need to write each byte: 127 = 0x7F, 0, 0, 1
    poke8(addr + 4, 127);   // first byte of IP
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    
    PrintStr("Attempting connect...\n");
    
    var cr: int64 := sys_connect(fd, addr, 16);
    PrintStr("connect = ");
    PrintInt(cr);
    PrintStr("\n");
    
    if (cr == 0) {
        PrintStr("Connected successfully!\n");
        sys_close(fd);
    } else {
        PrintStr("Connection failed\n");
    }
    
    munmap(addr, 16);
    PrintStr("Done\n");
    return 0;
}