// Simple Redis SET/GET test with hex debugging
import std.net.socket;

// Helper to print hex dump
fn hexChar(n: int64): int64 {
    if (n < 10) { return 48 + n; }  // '0'-'9'
    return 87 + n;                   // 'a'-'f'
}

fn printHex(buf: pchar, n: int64) {
    var i: int64 := 0;
    while (i < n) {
        var b: int64 := StrCharAt(buf, i);
        var hi: int64 := (b >> 4) & 0xF;
        var lo: int64 := b & 0xF;
        
        var c1: int64 := hexChar(hi);
        var c2: int64 := hexChar(lo);
        
        // Print as string via pchar
        var hex_str: pchar := "..";
        StrSetChar(hex_str, 0, c1);
        StrSetChar(hex_str, 1, c2);
        PrintStr(hex_str);
        PrintStr(" ");
        
        i := i + 1;
    }
    PrintStr("\n");
}

fn main(): int64 {
    PrintStr("=== Redis SET/GET Debug ===\n");
    
    // Connect
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    // SET key
    var req: pchar := "*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n";
    var sent: int64 := TCPConnWrite(conn, req, 36);
    PrintStr("SET sent: ");
    PrintInt(sent);
    PrintStr("\n");
    
    var buf: pchar := "                    ";
    var n: int64 := TCPConnRead(conn, buf, 32);
    PrintStr("SET response (");
    PrintInt(n);
    PrintStr(" bytes): ");
    PrintStr(buf);
    PrintStr("\n");
    PrintStr("Hex: ");
    printHex(buf, n);
    
    // GET key
    req := "*2\r\n$3\r\nGET\r\n$3\r\nkey\r\n";
    sent := TCPConnWrite(conn, req, 26);
    PrintStr("GET sent: ");
    PrintInt(sent);
    PrintStr("\n");
    
    n := TCPConnRead(conn, buf, 32);
    PrintStr("GET response (");
    PrintInt(n);
    PrintStr(" bytes): ");
    PrintStr(buf);
    PrintStr("\n");
    PrintStr("Hex: ");
    printHex(buf, n);
    
    TCPConnClose(conn);
    PrintStr("Done\n");
    
    return 0;
}