// Exactly match test_redis_all_ops: LPUSH x3, LLEN, LRANGE, LPOP, RPOP
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    }
    
    // Setup list
    RedisDel(conn, "mylist");
    var r: RedisReply := RedisLPush(conn, "mylist", "first");
    PrintStr("LPUSH1 done\n");
    
    r := RedisLPush(conn, "mylist", "second");
    PrintStr("LPUSH2 done\n");
    
    r := RedisRPush(conn, "mylist", "last");
    PrintStr("RPUSH done\n");
    
    // LLEN
    var llen: int64 := RedisLLen(conn, "mylist");
    PrintStr("LLEN = ");
    PrintInt(llen);
    PrintStr("\n");
    
    // LRANGE - this is the one that crashes!
    r := RedisLRange(conn, "mylist", 0, -1);
    PrintStr("LRANGE done, kind=");
    PrintInt(r.kind);
    PrintStr(" str_len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    // LPOP
    r := RedisLPop(conn, "mylist");
    PrintStr("LPOP done\n");
    
    // RPOP
    r := RedisRPop(conn, "mylist");
    PrintStr("RPOP done\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}