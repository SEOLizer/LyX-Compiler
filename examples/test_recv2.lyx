// Test if RecvFrom has the same issue
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    
    // First buffer
    var buf1: pchar := "                    ";
    var r1: int64 := RecvFrom(conn.fd, buf1, 32, 0, 0, 0);
    PrintStr("recv1 = ");
    PrintInt(r1);
    PrintStr("\n");
    
    // Second command
    req := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    
    // Second buffer
    var buf2: pchar := "                    ";
    PrintStr("about to recv2...\n");
    var r2: int64 := RecvFrom(conn.fd, buf2, 32, 0, 0, 0);
    PrintStr("recv2 = ");
    PrintInt(r2);
    PrintStr("\n");
    
    Close(conn.fd);
    return 0;
}