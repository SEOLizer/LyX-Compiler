// Test reading from TCP socket after select shows data
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected, fd = ");
    PrintInt(conn.fd);
    PrintStr("\n");
    
    // First command
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    PrintStr("wrote PING\n");
    
    // select
    var readfds: int64 := mmap(0, 128, 3, 34, -1, 0);
    poke8(readfds, 1);  // FD_SET for fd=3
    var timeout: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(timeout, 1);  // 1 second
    
    var n: int64 := Select(conn.fd + 1, readfds, 0, 0, timeout);
    PrintStr("select n = ");
    PrintInt(n);
    PrintStr("\n");
    
    if (n > 0) {
        PrintStr("About to read...\n");
        var buf: pchar := "                    ";
        var r: int64 := Read(conn.fd, buf, 32);
        PrintStr("read = ");
        PrintInt(r);
        PrintStr("\n");
    }
    
    // Second command - check if socket still works
    PrintStr("=== Second command ===\n");
    req := "*1\r\n$4\r\nPING\r\n";
    n := Write(conn.fd, req, 18);
    PrintStr("wrote2 n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Check what's in the socket
    n := Select(conn.fd + 1, readfds, 0, 0, timeout);
    PrintStr("select2 n = ");
    PrintInt(n);
    PrintStr("\n");
    
    if (n > 0) {
        // Try read with smaller count
        var buf2: pchar := "                    ";
        PrintStr("about to read2...\n");
        var r2: int64 := Read(conn.fd, buf2, 1);  // Try 1 byte
        PrintStr("read2 = ");
        PrintInt(r2);
        PrintStr("\n");
        
        // If that worked, read rest
        if (r2 > 0) {
            var r3: int64 := Read(conn.fd, buf2, 31);
            PrintStr("read3 = ");
            PrintInt(r3);
            PrintStr("\n");
        }
    }
    
    munmap(readfds, 128);
    munmap(timeout, 16);
    Close(conn.fd);
    PrintStr("Done\n");
    return 0;
}