// Test AES encryption and decryption with verification
import std.crypto.aes;

fn main(): int64 {
    PrintStr("=== AES Encryption/Decryption Test ===\n\n");
    
    // Test 1: AES-128-CBC
    PrintStr("--- AES-128-CBC Test ---\n");
    
    var plaintext: pchar := "Test123";
    var plain_len: int64 := 7;
    var key128: pchar := "0123456789ABCDEF";
    var iv128: pchar := "FEDCBA9876543210";
    
    var cipher_buf: pchar := "                                        ";
    var decrypted_buf: pchar := "                                        ";
    
    PrintStr("Original: ");
    PrintStr(plaintext);
    PrintStr("\n");
    
    var cipher_len: int64 := AES128CBCEncrypt(key128, iv128, plaintext, plain_len, cipher_buf);
    PrintStr("Encrypted OK, len: ");
    PrintInt(cipher_len);
    PrintStr("\n");
    
    var decrypted_len: int64 := AES128CBCDecrypt(key128, iv128, cipher_buf, cipher_len, decrypted_buf);
    PrintStr("Decrypted len: ");
    PrintInt(decrypted_len);
    PrintStr("\n");
    
    // Verify first 7 chars match original
    var match: bool := true;
    var i: int64 := 0;
    while (i < plain_len) {
        if (StrCharAt(decrypted_buf, i) != StrCharAt(plaintext, i)) {
            match := false;
        }
        i := i + 1;
    }
    
    if (match) {
        PrintStr("SUCCESS: Decrypted matches original!\n");
    } else {
        PrintStr("FAIL: Decrypted does not match!\n");
    }
    
    // Test 2: AES-256-CBC
    PrintStr("\n--- AES-256-CBC Test ---\n");
    
    var key256: pchar := "0123456789ABCDEF0123456789ABCDEF";
    var iv256: pchar := "FEDCBA9876543210FEDCBA9876543210";
    var cipher256: pchar := "                                        ";
    var decrypted256: pchar := "                                        ";
    
    var cipher256_len: int64 := AES256CBCEncrypt(key256, iv256, plaintext, plain_len, cipher256);
    var decrypted256_len: int64 := AES256CBCDecrypt(key256, iv256, cipher256, cipher256_len, decrypted256);
    
    // Verify
    match := true;
    i := 0;
    while (i < plain_len) {
        if (StrCharAt(decrypted256, i) != StrCharAt(plaintext, i)) {
            match := false;
        }
        i := i + 1;
    }
    
    if (match) {
        PrintStr("SUCCESS: AES-256 decrypt matches!\n");
    } else {
        PrintStr("FAIL: AES-256 decrypt mismatch!\n");
    }
    
    // Test 3: Longer data
    PrintStr("\n--- Longer Data Test ---\n");
    
    var longer_text: pchar := "Hello World! This is a test of AES encryption and decryption!";
    var long_len: int64 := 0;
    i := 0;
    while (StrCharAt(longer_text, i) != 0) {
        long_len := long_len + 1;
        i := i + 1;
    }
    
    var cipher_long: pchar := "                                                                                ";
    var decrypted_long: pchar := "                                                                                ";
    
    PrintStr("Long text length: ");
    PrintInt(long_len);
    PrintStr("\n");
    
    var cipher_long_len: int64 := AES128CBCEncrypt(key128, iv128, longer_text, long_len, cipher_long);
    var decrypted_long_len: int64 := AES128CBCDecrypt(key128, iv128, cipher_long, cipher_long_len, decrypted_long);
    
    PrintStr("Decrypted length: ");
    PrintInt(decrypted_long_len);
    PrintStr("\n");
    
    // Verify all
    match := true;
    i := 0;
    while (i < long_len) {
        if (StrCharAt(decrypted_long, i) != StrCharAt(longer_text, i)) {
            match := false;
        }
        i := i + 1;
    }
    
    if (match) {
        PrintStr("SUCCESS: Long text roundtrip OK!\n");
    } else {
        PrintStr("FAIL: Long text mismatch!\n");
    }
    
    PrintStr("\n=== All Tests Complete ===\n");
    return 0;
}