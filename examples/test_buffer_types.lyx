// Test with explicit variable vs literal
import std.net.socket;

fn main(): int64 {
    PrintStr("=== Test buffer type ===\n");
    
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { PrintStr("Connect failed\n"); return 1; }
    PrintStr("Connected\n");
    
    // Case 1: Literal buffer
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    sys_write(conn.fd, req, 18);
    var buf1: pchar := "                    ";
    var n1: int64 := sys_read(conn.fd, buf1, 32);
    PrintStr("Literal buffer read n = ");
    PrintInt(n1);
    PrintStr("\n");
    
    // Reconnect
    sys_close(conn.fd);
    conn := TCPConnect(0x7F000001, 6379);
    PrintStr("Reconnected\n");
    
    // Case 2: New variable allocated in var section
    req := "*1\r\n$4\r\nPING\r\n";
    sys_write(conn.fd, req, 18);
    var buf2: pchar := "                    ";
    var n2: int64 := sys_read(conn.fd, buf2, 32);
    PrintStr("Var buffer read n = ");
    PrintInt(n2);
    PrintStr("\n");
    
    sys_close(conn.fd);
    PrintStr("Done\n");
    
    return 0;
}