// Test DEL -> struct -> struct -> struct
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    } else {
        PrintStr("PING failed\n");
    }
    
    // DEL returns int64
    var delres: int64 := RedisDel(conn, "testkey");
    PrintStr("DEL result = ");
    PrintInt(delres);
    PrintStr("\n");
    
    // LPUSH returns struct
    var r: RedisReply := RedisLPush(conn, "testkey", "value");
    PrintStr("LPUSH done\n");
    
    // RPUSH returns struct
    r := RedisRPush(conn, "testkey", "value2");
    PrintStr("RPUSH done\n");
    
    // LPOP returns struct - the 3rd one!
    r := RedisLPop(conn, "testkey");
    PrintStr("LPOP done\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}