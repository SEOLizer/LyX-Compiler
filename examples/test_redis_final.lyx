// Test that Redis SET/GET works on the same persistent connection
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting to Redis...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);

    if (conn.fd < 0) {
        PrintStr("Connect failed!\n");
        return 1;
    }
    PrintStr("Connected! fd = ");
    PrintInt(conn.fd);
    PrintStr("\n");

    // PING
    var ok: bool := RedisPing(conn);
    if (ok) {
        PrintStr("PING -> PONG OK\n");
    } else {
        PrintStr("PING failed\n");
    }

    // SET
    var setKey: pchar   := "lyx_test";
    var setVal: pchar   := "hello_from_lyx";
    var setReply: RedisReply := RedisSet(conn, setKey, setVal);
    PrintStr("SET reply kind = ");
    PrintInt(setReply.kind);
    PrintStr("\n");

    // GET
    var getKey: pchar   := "lyx_test";
    var getReply: RedisReply := RedisGet(conn, getKey);
    PrintStr("GET reply kind = ");
    PrintInt(getReply.kind);
    PrintStr("\n");

    RedisClose(conn);
    PrintStr("Done.\n");
    return 0;
}
