// Test with RecvFrom instead of sys_read
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    sys_write(conn.fd, req, 18);
    
    // Use RecvFrom instead of sys_read
    var buf: pchar := "                    ";
    var n: int64 := RecvFrom(conn.fd, buf, 32, 0, 0, 0);
    PrintStr("read1 ");
    PrintInt(n);
    PrintStr("\n");
    
    // Second command
    req := "*1\r\n$4\r\nPING\r\n";
    sys_write(conn.fd, req, 18);
    
    n := RecvFrom(conn.fd, buf, 32, 0, 0, 0);
    PrintStr("read2 ");
    PrintInt(n);
    PrintStr("\n");
    
    sys_close(conn.fd);
    return 0;
}