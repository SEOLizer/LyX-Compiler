// Qt Menu Full Test — Tests WP8 with real Menu implementation
import std.qt5_app;

pub fn main(): int64 {
  PrintStr("=== Qt Menu FULL Test (WP8) ===\n");
  
  // Initialize Qt
  var ok: int64 := qt_init();
  if (ok == 0) { PrintStr("Qt init failed\n"); return 1; }

  // Create main window
  var win: int64 := qt_create_window("Menu Test", 500, 300);
  
  // Test menu API (WP8) - jetzt mit echten calls!
  PrintStr("\n--- Testing REAL WP8 Menu API ---\n");
  
  // Create menu bar
  var menubar: int64 := qt_menubar_create(win);
  PrintStr("MenuBar handle: "); PrintInt(menubar); PrintStr("\n");
  
  // Create menu
  var file_menu: int64 := qt_menu_create("File");
  PrintStr("File Menu handle: "); PrintInt(file_menu); PrintStr("\n");
  
  // Create action 
  var exit_action: int64 := qt_action_create("Exit", 0);
  PrintStr("Exit Action handle: "); PrintInt(exit_action); PrintStr("\n");
  
  // Add menu to menubar
  if (menubar != 0 && file_menu != 0) {
    qt_menu_add_menu(menubar, file_menu);
    PrintStr("Added File menu to menubar\n");
  }
  
  // Add action to menu
  if (file_menu != 0 && exit_action != 0) {
    qt_menu_add_action(file_menu, exit_action);
    PrintStr("Added Exit action to menu\n");
  }
  
  // Create toolbar
  var toolbar: int64 := qt_toolbar_create(win, "Main Toolbar");
  PrintStr("Toolbar handle: "); PrintInt(toolbar); PrintStr("\n");
  
  // Test dialogs (WP9)
  PrintStr("\n--- Testing Dialogs ---\n");
  
  // Test message box (blocks, show for 1 sec)
  // qt_msgbox_show(0, "Test Message Box", 1); // type 1 = Warning
  PrintStr("MessageBox: (commented out to avoid blocking)\n");
  
  // Show window
  qt_show(win);
  PrintStr("\nWindow shown with menu - close it to exit\n");
  
  // Run event loop
  var code: int64 := qt_exec();
  
  PrintStr("Qt exited with code: ");
  PrintInt(code);
  PrintStr("\n=== TEST COMPLETE ===\n");
  
  return code;
}