// qt_only_fn_test.lyx — Only function, NO globals

import std.qt5_app;

pub fn onToolbarAction(): int64 {
  return 0;
}

pub fn main(): int64 {
  qt_init();
  
  var win: int64 := qt_create_window("Toolbar Test", 600, 400);
  var menubar: int64 := qt_menubar_create(win);
  var file_menu: int64 := qt_menu_create("File");
  qt_menu_add_menu(menubar, file_menu);
  
  var act: int64 := qt_action_create("New", 0);
  qt_menu_add_action(file_menu, act);
  
  var toolbar: int64 := qt_toolbar_create(win, "Main Toolbar");
  
  qt_show(win);
  return qt_exec();
}