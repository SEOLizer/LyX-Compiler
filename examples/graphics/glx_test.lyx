// Test: GLX OpenGL Window
// Demonstrates: std.x11 + std.qt5_glx + std.qt5_gl
//
// This creates an X11 window with OpenGL context and renders a simple triangle.

import std.x11;
import std.qt5_glx;
import std.qt5_gl;

pub con WINDOW_WIDTH: int64 := 640;
pub con WINDOW_HEIGHT: int64 := 480;

pub fn main(): int64 {
  // Open X11 display
  var display: XDisplay := XOpen(0);
  
  if (display.valid == 0) {
    PrintStr("Error: Cannot open X display\n");
    return 1;
  }
  
  PrintStr("X11 display opened successfully\n");
  
  var screen: int64 := display.screen;
  var root: int64 := GetRootWindow(display.display);
  
  // GLX: Get visual with OpenGL attributes
  // Attributes: RGBA, doublebuffer, depth=16
  var attribs: int64 := 0;
  var visual: int64 := glXChooseVisual(display.display, screen, attribs);
  
  if (visual == 0) {
    PrintStr("Error: Cannot get GLX visual\n");
    XClose(display);
    return 1;
  }
  
  PrintStr("GLX visual obtained\n");
  
  // Create X window
  var window: int64 := XCreateWindow(
    display.display,
    root,
    100, 100,  // x, y
    WINDOW_WIDTH, WINDOW_HEIGHT,
    0,         // border width
    0,         // depth (CopyFromParent)
    1,         // class (InputOutput)
    0,         // visual
    0,         // mask
    0          // attributes
  );
  
  if (window == 0) {
    PrintStr("Error: Cannot create X window\n");
    XClose(display);
    return 1;
  }
  
  PrintStr("X window created\n");
  
  // Select input events (expose, key press, close)
  XSelectInput(display.display, window, 0x00000001 | 0x00000008); // ExposureMask | KeyPressMask
  
  // Map window (make visible)
  XMapWindow(display.display, window);
  XFlushDisplay(display);
  
  // Create GLX context
  var ctx: GLXContext := GLXCreateContextLegacy(display.display, visual, 0, 1);
  
  if (ctx.ctx == 0) {
    PrintStr("Error: Cannot create GLX context\n");
    XDestroyWindow(display.display, window);
    XClose(display);
    return 1;
  }
  
  PrintStr("GLX context created\n");
  
  // Make context current
  var result: int64 := GLXMakeCurrent(display.display, window, ctx);
  if (result == 0) {
    PrintStr("Error: Cannot make GLX context current\n");
    GLXDestroyContext(display.display, ctx);
    XDestroyWindow(display.display, window);
    XClose(display);
    return 1;
  }
  
  PrintStr("GLX context made current\n");
  
  // Initialize OpenGL
  var glOk: int64 := glInit();
  if (glOk == 0) {
    PrintStr("Error: OpenGL not available\n");
    GLXDestroyContext(display.display, ctx);
    XDestroyWindow(display.display, window);
    XClose(display);
    return 1;
  }
  
  // Get OpenGL version
  var ver: int64 := glGetVersion();
  PrintStr("OpenGL version: ");
  // Would need to print string - placeholder
  
  // Set viewport
  glViewport(0, 0, WINDOW_WIDTH, WINDOW_HEIGHT);
  
  // Clear to blue color
  glClearColor(0.0, 0.0, 0.5, 1.0);
  glClear(GL_COLOR_BUFFER_BIT);
  
  // Swap buffers (show the blue screen)
  GLXSwapBuffers(display.display, window);
  
  PrintStr("Rendered first frame - blue screen\n");
  
  // Simple event loop - wait for key press
  PrintStr("Press any key to exit...\n");
  
  // Note: Event loop not fully implemented - would need XEvent structure
  // For now, just render and exit
  
  // Clean up
  GLXDestroyContext(display.display, ctx);
  XDestroyWindow(display.display, window);
  XClose(display);
  
  PrintStr("Test completed successfully!\n");
  return 0;
}