// Minimal test - just X11
import std.x11;

pub fn main(): int64 {
  var display: XDisplay := XOpen(0);
  
  if (display.valid == 0) {
    PrintStr("Cannot open X display\n");
    return 1;
  }
  
  PrintStr("X11 display opened!\n");
  PrintStr("Screen: ");
  // Print screen number
  
  XClose(display);
  PrintStr("Test completed!\n");
  return 0;
}