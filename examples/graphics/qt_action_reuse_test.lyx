// qt_action_reuse_test.lyx — Test REUSING action variable

import std.qt5_app;

var act: int64;  // Global variable like original

pub fn main(): int64 {
  qt_init();
  
  var win: int64 := qt_create_window("Test", 500, 300);
  var menubar: int64 := qt_menubar_create(win);
  var file_menu: int64 := qt_menu_create("File");
  qt_menu_add_menu(menubar, file_menu);
  
  // Reuse same variable
  act := qt_action_create("New", 0);
  qt_menu_add_action(file_menu, act);
  
  act := qt_action_create("Open", 0);
  qt_menu_add_action(file_menu, act);
  
  act := qt_action_create("Save", 0);
  qt_menu_add_action(file_menu, act);
  
  // Toolbar
  var toolbar: int64 := qt_toolbar_create(win, "Main");
  
  // Reuse again
  act := qt_action_create("Click", 0);
  qt_toolbar_add_action(toolbar, act);
  
  act := qt_action_create("Settings", 0);
  qt_toolbar_add_action(toolbar, act);
  
  qt_set_label(win, "Hello");
  qt_show(win);
  return qt_exec();
}