// qt_widgets_events_test.lyx — WP6: Test für alle Widget Events
// Testet: Button, CheckBox, Slider, LineEdit mit Event-Marker System

import std.qt5_app;

pub fn main(): int64 {
  qt_init();
  
  var win: int64 := qt_create_window("Widget Events Test", 400, 300);
  
  // Layout erstellen
  var vbox: int64 := qt_vbox_create();
  
  // 1. Checkbox Test
  var checkbox: int64 := qt_checkbox_create(0, "Checkbox test");
  qt_checkbox_on_toggled(checkbox, 1);
  qt_vbox_add_widget(vbox, checkbox);
  
  // 2. Slider Test
  var slider: int64 := qt_slider_create(0, 0);  // horizontal
  qt_slider_set_range(slider, 0, 100);
  qt_slider_set_value(slider, 50);
  qt_slider_on_valuechanged(slider, 2);
  qt_vbox_add_widget(vbox, slider);
  
  // 3. Button (eigentlich QPushButton, aber qt_add_button)
  var btn: int64 := qt_add_button(win, "Klickmich");
  qt_button_on_clicked(btn, 4);
  qt_vbox_add_widget(vbox, btn);
  
  // 4. Label
  var label: int64 := qt_set_label(win, "Test Label");
  qt_vbox_add_widget(vbox, label);
  
  // Layout setzen
  qt_widget_set_layout(win, vbox);
  
  qt_show(win);
  
  // Event-Loop für 3 Sekunden
  var i: int64 := 0;
  while i < 3 {
    // Checkbox Events pollen
    if qt_checkbox_was_toggled(checkbox) == 1 {
      var state: int64 := qt_checkbox_state(checkbox);
      PrintStr("Checkbox: ");
      if state == 1 { PrintStr("checked\n"); } else { PrintStr("unchecked\n"); }
    }
    
    // Slider Events pollen  
    if qt_slider_was_changed(slider) == 1 {
      var val: int64 := qt_slider_get_value(slider);
      PrintStr("Slider Wert: ");
      PrintInt(val);
      PrintStr("\n");
    }
    
    // LineEdit Events pollen
    // Hinweis: qt_lineedit_was_changed() muss noch separat aufgerufen werden
    // qt_process_events();
    
    // Button Events pollen
    if qt_button_was_clicked(btn) == 1 {
      PrintStr("Button geklickt!\n");
    }
    
    qt_process_events();
    i := i + 1;
  }
  
  PrintStr("Widget Events Test beendet.\n");
  return 0;
}