// qt_tabwidget_test.lyx — Test für QTabWidget
import std.qt5_app;

pub fn main(): int64 {
  qt_init();
  
  var win: int64 := qt_create_window("QTabWidget Test", 400, 300);
  
  // TabWidget erstellen und Tabs hinzufügen
  var tabs: int64 := qt_tabwidget_create(0);
  qt_tabwidget_add_tab(tabs, win, "Erster Tab");
  qt_tabwidget_add_tab(tabs, win, "Zweiter Tab");
  
  // Zeigen dass es funktioniert hat
  var count: int64 := qt_tabwidget_count(tabs);
  PrintStr("Anzahl Tabs: ");
  PrintInt(count);
  PrintStr("\n");
  
  // Ersten Tab aktivieren
  qt_tabwidget_set_current_index(tabs, 0);
  
  PrintStr("TabWidget Test abgeschlossen.\n");
  
  return 0;
}