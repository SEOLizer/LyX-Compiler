// qt_toolbar_label.lyx — Test toolbar + label

import std.qt5_app;

pub fn main(): int64 {
  qt_init();
  
  var win: int64 := qt_create_window("Test", 500, 300);
  
  // Create toolbar
  var toolbar: int64 := qt_toolbar_create(win, "Toolbar");
  
  // Add action
  var act: int64 := qt_action_create("Test", 0);
  qt_toolbar_add_action(toolbar, act);
  
  // THIS is where it might crash - set label AFTER toolbar
  qt_set_label(win, "Hello");
  
  qt_show(win);
  return qt_exec();
}