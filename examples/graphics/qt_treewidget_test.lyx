// qt_treewidget_test.lyx — Test für QTreeView
import std.qt5_app;

pub fn main(): int64 {
  qt_init();
  
  var win: int64 := qt_create_window("QTreeWidget Test", 400, 300);
  
  // TreeWidget erstellen
  var tree: int64 := qt_treewidget_create(0);
  
  // Ein Element hinzufügen (Platzhalter)
  qt_treewidget_add_item(tree, "Root Item");
  
  // Header sichtbar
  qt_treewidget_set_header_visible(tree, 1);
  
  PrintStr("QTreeWidget Test OK.\n");
  
  return 0;
}