// qt_callback_test.lyx — WP6 Signal/Callback Test mit Event-Marker System
// Testet: Button-Clicks und Menu-Actions via Polling

import std.qt5_app;

// Callback-Handler (als separate Funktionen)
fn on_button_clicked() {
  PrintStr("Button wurde geklickt!\n");
}

fn on_quit_action() {
  PrintStr("Quit Menu Item geklickt!\n");
  qt_quit();
}

fn on_about_action() {
  PrintStr("About Menu Item geklickt!\n");
  qt_msgbox_show("About", "Qt Callback Test v1.0\nWP6 Event-Marker System funktioniert!", 0);
}

pub fn main(): int64 {
  qt_init();
  
  var win: int64 := qt_create_window("WP6 Callback Test", 400, 200);
  
  // Create menu bar
  var menubar: int64 := qt_menubar_create(win);
  var file_menu: int64 := qt_menu_create("File");
  qt_menu_add_menu(menubar, file_menu);
  
  // Create actions mit Callbacks
  // Callback-IDs: 1 = quit, 2 = about
  var quit_action: int64 := qt_action_create_with_callback("Quit", 1);
  var about_action: int64 := qt_action_create_with_callback("About", 2);
  
  // Actions zu Menu hinzufügen
  qt_menu_add_action(file_menu, quit_action);
  qt_menu_add_action(file_menu, about_action);
  
  // Ein Button für weiteren Test
  var btn: int64 := qt_add_button(win, "Klick mich!");
  qt_button_on_clicked(btn, 0);  // Registrieren für Event-Marker
  
  // Toolbar erstellen
  var toolbar: int64 := qt_toolbar_create(win, "Actions");
  qt_toolbar_add_action(toolbar, quit_action);
  qt_toolbar_add_action(toolbar, about_action);
  
  qt_show(win);
  
  // Event-Loop mit Polling für Callbacks
  var running: int64 := 1;
  while running == 1 {
    // Event-Marker pollen
    if qt_button_was_clicked(btn) == 1 {
      on_button_clicked();
    }
    
    if qt_action_was_triggered(quit_action) == 1 {
      on_quit_action();
    }
    
    if qt_action_was_triggered(about_action) == 1 {
      on_about_action();
    }
    
    // Events verarbeiten (non-blocking)
    qt_process_events();
  }
  
  return 0;
}