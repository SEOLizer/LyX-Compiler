// Test dlopen only - no casts
extern fn dlopen(filename: pchar, flags: int64): int64 link "libdl.so.2";
extern fn dlclose(handle: int64): int64 link "libdl.so.2";

fn main(): int64 {
  var handle: int64 := dlopen("libGL.so.1", 1);
  if (handle == 0) { return 1; }
  dlclose(handle);
  PrintStr("dlopen OK\n");
  return 0;
}