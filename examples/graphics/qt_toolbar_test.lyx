// qt_toolbar_test.lyx — Test for Toolbar functionality (WP8)

import std.qt5_app;

pub fn onToolbarAction(): int64 {
  qt_set_status(toolbar_win, "Toolbar action triggered!");
  return 0;
}

var toolbar_win: int64;
var toolbar: int64;
var action: int64;

pub fn main(): int64 {
  // Initialize Qt
  qt_init();
  
  // Create window
  toolbar_win := qt_create_window("Toolbar Test", 600, 400);
  
  // Create menu bar
  var menubar: int64 := qt_menubar_create(toolbar_win);
  
  // Create file menu with actions
  var file_menu: int64 := qt_menu_create("File");
  qt_menu_add_menu(menubar, file_menu);
  
  action := qt_action_create("New", 0);  // No callback for now
  qt_menu_add_action(file_menu, action);
  
  action := qt_action_create("Open", 0);
  qt_menu_add_action(file_menu, action);
  
  action := qt_action_create("Save", 0);
  qt_menu_add_action(file_menu, action);
  
  // Create TOOLBAR (this was the broken part!)
  toolbar := qt_toolbar_create(toolbar_win, "Main Toolbar");
  
  // Create toolbar action
  var tb_action: int64 := qt_action_create("Click Me", 0);
  qt_toolbar_add_action(toolbar, tb_action);
  
  // Add another toolbar action
  tb_action := qt_action_create("Settings", 0);
  qt_toolbar_add_action(toolbar, tb_action);
  
  // Set a simple label to show window is working
  qt_set_label(toolbar_win, "Toolbar should appear below menu bar");
  
  // Show window
  qt_show(toolbar_win);
  
  // Run event loop
  return qt_exec();
}