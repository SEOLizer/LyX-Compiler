// Test EGL directly
extern fn eglGetDisplay(displayId: int64): int64 link "libEGL.so.1";
extern fn eglInitialize(dpy: int64, major: int64, minor: int64): int64 link "libEGL.so.1";
extern fn eglTerminate(dpy: int64): int64 link "libEGL.so.1";

fn main(): int64 {
  var disp: int64 := eglGetDisplay(0);
  if (disp == 0) { return 1; }
  
  // Just initialize with 0 for version
  var result: int64 := eglInitialize(disp, 0, 0);
  if (result == 0) { return 2; }
  
  eglTerminate(disp);
  PrintStr("EGL OK\n");
  return 0;
}