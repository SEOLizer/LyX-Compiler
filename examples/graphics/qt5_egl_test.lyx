// qt5_egl_test.lyx — Test für EGL Library
import std.qt5_egl;

pub fn main(): int64 {
  // EGL Display holen (direkt mit Default Display)
  var disp: EGLDisplay;
  var major: int64;
  var minor: int64;
  disp.display := eglGetDisplay(EGL_DEFAULT_DISPLAY);
  disp.initialized := 0;
  
  if disp.display == 0 {
    PrintStr("EGL: Kein Display verfuegbar\n");
    return 1;
  }
  
  // Initialize
  if eglInitialize(disp.display, 0, 0) == EGL_FALSE {
    PrintStr("EGL: Konnte nicht initialisieren\n");
    return 1;
  }
  disp.initialized := 1;
  
  if disp.initialized == 0 {
    PrintStr("EGL: Konnte nicht initialisieren\n");
    return 1;
  }
  
  PrintStr("EGL Display erhalten!\n");
  PrintStr("EGL Version: ");
  
  // EGL Version abfragen
  var version_str: int64 := eglQueryString(disp.display, 12352);  // EGL_VERSION
  // Note: returning string pointer - we'd need pchar handling
  
  PrintStr("\n");
  
  // API binden
  if EGLBindOpenGL(disp) == EGL_TRUE {
    PrintStr("OpenGL API gebunden\n");
  } else {
    PrintStr("Konnte OpenGL nicht binden, versuche OpenGL ES\n");
    if EGLBindOpenGLES(disp) == EGL_TRUE {
      PrintStr("OpenGL ES API gebunden\n");
    }
  }
  
  // Cleanup
  EGLTerminate(disp);
  
  PrintStr("EGL Test abgeschlossen.\n");
  return 0;
}