// Qt Simple Demo — Test mit QWidget ohne Layout
//
// Requires: libqtlyx.so in LD_LIBRARY_PATH

import std.qt5_app;

pub fn main(): int64 {
  PrintStr("=== Qt Simple Demo ===\n");
  
  var ok: int64 := qt_init();
  if (ok == 0) {
    PrintStr("Qt init failed\n");
    return 1;
  }

  // Create main window
  var win: int64 := qt_create_window("Qt Simple Demo", 300, 400);
  
  // Add a label directly
  qt_set_label(win, "Lyx Qt Demo Works!");
  
  // Show window
  qt_show(win);
  PrintStr("Window shown, close it to exit\n");
  
  return qt_exec();
}