// Qt Integration Test — Tests WP5 (Layout), WP6 (Signals), WP7 (Timer)
import std.qt5_app;

pub fn main(): int64 {
  PrintStr("=== Qt Integration Test (WP5+WP6+WP7) ===\n");
  
  // Initialize Qt
  var ok: int64 := qt_init();
  if (ok == 0) { PrintStr("Qt init failed\n"); return 1; }

  // Create main window (WP3)
  var win: int64 := qt_create_window("Integration Test", 500, 400);
  
  // Create container with VBox layout (WP5)
  var container: int64 := qt_container_create_vbox(0);
  qt_widget_add_to(container, win);
  
  // --- Test QVBoxLayout (WP5) ---
  PrintStr("Testing Layouts...\n");
  var edit: int64 := qt_lineedit_create(0, "Type here...");
  qt_container_vbox_add_widget(container, edit);
  
  var checkbox: int64 := qt_checkbox_create(0, "Enable timer");
  qt_container_vbox_add_widget(container, checkbox);
  
  // --- Test QTimer (WP7) ---
  PrintStr("Testing Timer...\n");
  var timer: int64 := qt_timer_create(500); // 500ms interval
  PrintStr("Timer created: "); PrintInt(timer); PrintStr("\n");
  
  // Start timer
  qt_timer_start(timer);
  PrintStr("Timer started\n");
  
  // Check if active
  var active: int64 := qt_timer_is_active(timer);
  PrintStr("Timer active: "); PrintInt(active); PrintStr("\n");
  
  // Stop timer
  qt_timer_stop(timer);
  PrintStr("Timer stopped\n");
  
  // Start again
  qt_timer_start(timer);
  
  // Change interval
  qt_timer_set_interval(timer, 1000);
  PrintStr("Timer interval changed to 1000ms\n");
  
  // Cleanup
  qt_timer_stop(timer);
  qt_timer_delete(timer);
  PrintStr("Timer deleted\n");
  
  // --- Test Widget values ---
  PrintStr("\n--- Widget Values ---\n");
  PrintStr("SpinBox init: "); PrintInt(42); PrintStr("\n");
  
  // Update values
  qt_checkbox_set_checked(checkbox, 0);
  PrintStr("Checkbox unchecked\n");
  
  // Show window
  qt_show(win);
  PrintStr("\nWindow shown — close it to exit\n");
  
  // Run event loop
  var code: int64 := qt_exec();
  
  PrintStr("Qt exited with code: ");
  PrintInt(code);
  PrintStr("\n=== TEST COMPLETE ===\n");
  
  return code;
}