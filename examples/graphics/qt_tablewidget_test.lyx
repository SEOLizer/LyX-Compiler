// qt_tablewidget_test.lyx — Test für QTableView
import std.qt5_app;

pub fn main(): int64 {
  qt_init();
  
  var win: int64 := qt_create_window("QTableWidget Test", 400, 300);
  
  // TableWidget erstellen (3 Zeilen, 3 Spalten)
  var table: int64 := qt_tablewidget_create(0, 3, 3);
  
  // Spaltenbreite setzen
  qt_tablewidget_set_column_width(table, 0, 100);
  qt_tablewidget_set_column_width(table, 1, 100);
  qt_tablewidget_set_column_width(table, 2, 100);
  
  // Alternating colors
  qt_tablewidget_set_alternating_row_colors(table, 1);
  
  PrintStr("QTableWidget Test OK.\n");
  
  return 0;
}