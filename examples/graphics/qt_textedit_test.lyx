// qt_textedit_test.lyx — Test für QPlainTextEdit (TMemo)
import std.qt5_app;

pub fn main(): int64 {
  qt_init();
  
  var win: int64 := qt_create_window("QPlainTextEdit Test", 400, 300);
  
  // TextEdit erstellen (multi-line Input)
  var textedit: int64 := qt_textedit_create(0, "Hier kann man\nmehrzeiligen\nText eingeben...");
  
  // Text anhängen
  qt_textedit_append(textedit, "\nNeuer Absatz hinzugefügt!");
  
  // Text setzen
  qt_textedit_set_text(textedit, "Komplett neuer Textinhalt");
  
  // Test erfolgreich
  PrintStr("QPlainTextEdit Test OK.\n");
  
  return 0;
}