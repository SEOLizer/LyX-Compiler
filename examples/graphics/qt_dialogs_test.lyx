// qt_dialogs_test.lyx — Test für Qt Dialoge
// Testet: QMessageBox, QFileDialog, QInputDialog

import std.qt5_app;

pub fn main(): int64 {
  qt_init();
  
  var win: int64 := qt_create_window("Dialog Test", 300, 150);
  var label: int64 := qt_set_label(win, "Drücke Button für Dialog...");
  
  // Zuerst eine MessageBox
  qt_msgbox_show("Willkommen", "Qt Dialog Test\nQMessageBox, File- und Input-Dialog", 0);
  
  // Input Dialog - Benutzer nach Name fragen
  var name_result: int64 := qt_input_dialog(0, "Name eingeben", "Wie heißt du?", "");
  
  // Den eingegebenen Namen anzeigen (als String via pchar)
  // Hinweis: Wir zeigen nur dass der Dialog funktioniert hat
  
  // File Open Dialog (öffnet Datei-Auswahl)
  var file_result: int64 := qt_file_open_dialog(0, "Wähle eine Datei", "*");
  
  // File Save Dialog
  var save_result: int64 := qt_file_save_dialog(0, "Speichern unter", "*");
  
  // Noch eine MessageBox zur Bestätigung
  qt_msgbox_show("Fertig", "Alle Dialoge wurden getestet!", 1);  // 1 = Warning icon
  
  PrintStr("Dialog Test abgeschlossen.\n");
  PrintStr("Input: OK\n");
  PrintStr("FileOpen: OK\n");
  PrintStr("FileSave: OK\n");
  
  return 0;
}