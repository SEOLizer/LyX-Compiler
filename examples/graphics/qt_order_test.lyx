// qt_order_test.lyx — Test exact order

import std.qt5_app;

pub fn main(): int64 {
  qt_init();
  
  var win: int64 := qt_create_window("Toolbar Test", 600, 400);
  
  var menubar: int64 := qt_menubar_create(win);
  var file_menu: int64 := qt_menu_create("File");
  qt_menu_add_menu(menubar, file_menu);
  
  var act: int64 := qt_action_create("New", 0);
  qt_menu_add_action(file_menu, act);
  act := qt_action_create("Open", 0);
  qt_menu_add_action(file_menu, act);
  act := qt_action_create("Save", 0);
  qt_menu_add_action(file_menu, act);  // <-- This is 5th create_action for actions
  
  var toolbar: int64 := qt_toolbar_create(win, "Main Toolbar");
  
  var tb_act: int64 := qt_action_create("Click Me", 0);
  qt_toolbar_add_action(toolbar, tb_act);
  tb_act := qt_action_create("Settings", 0);
  qt_toolbar_add_action(toolbar, tb_act);  // <-- 7th create_action total
  
  qt_set_label(win, "Toolbar should appear below menu bar");
  
  qt_show(win);
  return qt_exec();
}