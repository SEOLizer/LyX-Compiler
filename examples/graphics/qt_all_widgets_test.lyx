// qt_all_widgets_test.lyx — Test für ALLE Qt Widgets (vereinfacht)
import std.qt5_app;

pub fn main(): int64 {
  qt_init();
  
  var win: int64 := qt_create_window("Alle Widgets Test", 400, 300);
  PrintStr("=== Test Alle Widgets ===\n");
  
  // 1. Input Widgets
  var le: int64 := qt_lineedit_create(0, "Test");
  var sb: int64 := qt_spinbox_create(0);
  var sl: int64 := qt_slider_create(0, 0);
  
  // 2. Selection
  var cb: int64 := qt_checkbox_create(0, "Check");
  var rb: int64 := qt_radiobutton_create(0, "Radio");
  var cmb: int64 := qt_combobox_create(0);
  
  // 3. Display
  var pb: int64 := qt_progressbar_create(0);
  var lw: int64 := qt_listwidget_create(0);
  
  // 4. Tab
  var twi: int64 := qt_tabwidget_create(0);
  
  // 5. Tree
  var tr: int64 := qt_treewidget_create(0);
  
  // 6. Table
  var tbl: int64 := qt_tablewidget_create(0, 3, 3);
  
  // 7. TextEdit
  var te: int64 := qt_textedit_create(0, "Text...");
  
  // Properties
  qt_widget_set_enabled(le, 1);
  
  PrintStr("\n=== ALLE WIDGETS OK! ===\n");
  PrintStr("LineEdit, SpinBox, Slider\n");
  PrintStr("CheckBox, RadioButton, ComboBox\n");
  PrintStr("ProgressBar, ListWidget\n");
  PrintStr("TabWidget, TreeWidget\n");
  PrintStr("TableWidget, TextEdit\n");
  
  return 0;
}