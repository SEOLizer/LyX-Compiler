// Simple test - just call LPUSH with literal strings
import std.db.redis;

fn main(): int64 {
    PrintStr("=== Simple LPUSH Test ===\n");
    
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("Connected\n");
    
    // First do a simple SET to verify connection works
    var r: RedisReply := RedisSet(conn, "testkey", "testvalue");
    PrintStr("SET result: kind=");
    PrintInt(r.kind);
    PrintStr(" str_len=");
    PrintInt(r.str_len);
    PrintStr("\n");
    
    // Now test LPUSH
    r := RedisLPush(conn, "mylist", "first");
    PrintStr("LPUSH result: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // Also check GET after SET
    r := RedisGet(conn, "testkey");
    PrintStr("GET testkey: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    // Try DEL first then LPUSH
    RedisDel(conn, "mylist");
    r := RedisLPush(conn, "mylist", "first");
    PrintStr("LPUSH after DEL: kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}