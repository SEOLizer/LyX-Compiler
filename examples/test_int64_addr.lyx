// Test if large int64 constants work
fn main(): int64 {
    var x: int64 := 12345678901234;
    PrintStr("x = ");
    PrintInt(x);
    PrintStr("\n");
    
    // Test if mmap result is being stored correctly
    var addr: int64 := mmap(0, 4096, 3, 34, -1, 0);
    PrintStr("mmap addr = ");
    PrintInt(addr);
    PrintStr("\n");
    
    // Compare addresses
    if (addr > 1000000000) {
        PrintStr("addr is large (good)\n");
    } else {
        PrintStr("addr is small (bad)\n");
    }
    
    return 0;
}