// Test poke8 ONLY, no peek8 after
fn main(): int64 {
    PrintStr("=== Test poke8 only ===\n");
    
    var buf: int64 := mmap(0, 4096, 3, 34, -1, 0);
    PrintStr("mmap = ");
    PrintInt(buf);
    PrintStr("\n");
    
    // Just poke8, NO peek8 after
    poke8(buf, 65);
    PrintStr("Wrote 65\n");
    
    // Print something else to see if we get here
    PrintStr("After poke8\n");
    
    munmap(buf, 4096);
    PrintStr("Done\n");
    return 0;
}