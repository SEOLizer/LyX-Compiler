// Use integer pointer instead of pchar
fn main(): int64 {
    PrintStr("=== Test with int64 pointer ===\n");
    
    var fd: int64 := sys_socket(2, 1, 0);
    PrintStr("socket = ");
    PrintInt(fd);
    PrintStr("\n");
    
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(addr, 2);
    poke8(addr + 2, 0x18);
    poke8(addr + 3, 0xEB);
    poke8(addr + 4, 0x7F);
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    
    sys_connect(fd, addr, 16);
    munmap(addr, 16);
    
    PrintStr("connected\n");
    
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    sys_write(fd, req, 18);
    
    // Allocate buffer and convert to int64
    var buf: int64 := mmap(0, 64, 3, 34, -1, 0);
    PrintStr("buf = ");
    PrintInt(buf);
    PrintStr("\n");
    
    // First read
    var n: int64 := sys_read(fd, buf, 32);
    PrintStr("read1 = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Second read
    sys_write(fd, req, 18);
    PrintStr("write2 done\n");
    
    n := sys_read(fd, buf, 32);
    PrintStr("read2 = ");
    PrintInt(n);
    PrintStr("\n");
    
    sys_close(fd);
    munmap(buf, 64);
    return 0;
}