// Test PING then DEL then LPUSH then LPOP
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    // PING
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    }
    
    // DEL (returns int64)
    var delres: int64 := RedisDel(conn, "mylist");
    PrintStr("DEL result = ");
    PrintInt(delres);
    PrintStr("\n");
    
    // LPUSH (returns struct)
    var r: RedisReply := RedisLPush(conn, "mylist", "a");
    PrintStr("LPUSH done\n");
    
    r := RedisLPush(conn, "mylist", "b");
    PrintStr("LPUSH2 done\n");
    
    // LPOP (returns struct - THE CRASH!)
    r := RedisLPop(conn, "mylist");
    PrintStr("LPOP done, kind=");
    PrintInt(r.kind);
    PrintStr("\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}