// Test profiler builtins (WP-3)
fn add(a: int64, b: int64): int64 {
  return a + b;
}

fn main(): int64 {
  // Direct builtin calls
  profile_enter("main");
  profile_enter("add");
  
  var i: int64 := 0;
  while i < 10 {
    var result: int64 := add(i, i + 1);
    i := i + 1;
  }
  
  profile_leave("add");
  profile_leave("main");
  profile_report();
  
  return 0;
}