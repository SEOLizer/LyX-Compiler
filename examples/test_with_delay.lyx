// Test with debug after first read
import std.net.socket;

fn main(): int64 {
    PrintStr("=== Test with debug ===\n");
    
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { PrintStr("Connect failed\n"); return 1; }
    PrintStr("Connected\n");
    
    var buf: pchar := "                    ";
    var req: pchar;
    
    // PING 1
    req := "*1\r\n$4\r\nPING\r\n";
    PrintStr("Writing PING1...\n");
    sys_write(conn.fd, req, 18);
    PrintStr("Reading PING1...\n");
    var n: int64 := sys_read(conn.fd, buf, 32);
    PrintStr("PING1 read n = ");
    PrintInt(n);
    PrintStr("\n");
    
    PrintStr("After PING1, sleeping...\n");
    // Simple delay - just print something
    var i: int64 := 0;
    while (i < 100000000) { i := i + 1; }
    PrintStr("Sleep done\n");
    
    // PING 2
    req := "*1\r\n$4\r\nPING\r\n";
    PrintStr("Writing PING2...\n");
    sys_write(conn.fd, req, 18);
    PrintStr("Reading PING2...\n");
    n := sys_read(conn.fd, buf, 32);
    PrintStr("PING2 read n = ");
    PrintInt(n);
    PrintStr("\n");
    
    sys_close(conn.fd);
    PrintStr("Done\n");
    
    return 0;
}