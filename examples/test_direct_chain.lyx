// Direct chain: mmap -> poke -> peek without intermediate storage
fn main(): int64 {
    PrintStr("=== Direct chain test ===\n");
    
    // Just mmap - don't store
    var addr: int64 := mmap(0, 64, 3, 34, -1, 0);
    PrintStr("mmap = ");
    PrintInt(addr);
    PrintStr("\n");
    
    // Poke directly
    poke8(addr, 65);
    PrintStr("poke8 done\n");
    
    // Peek directly
    var v: int64 := peek8(addr);
    PrintStr("peek8 = ");
    PrintInt(v);
    PrintStr("\n");
    
    // Print hex
    PrintStr("peek8 hex: ");
    PrintInt(v & 0xFF);
    PrintStr("\n");
    
    // Second poke at offset
    poke8(addr + 1, 66);
    v := peek8(addr + 1);
    PrintStr("peek8+1 = ");
    PrintInt(v);
    PrintStr("\n");
    
    munmap(addr, 64);
    PrintStr("done\n");
    return 0;
}