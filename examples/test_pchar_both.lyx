// Test: pchar local vs pchar param in poke64
fn poke_via_param(path: pchar, dst: int64): void {
  var val: int64 := path as int64;
  PrintStr("param as int64: ");
  PrintInt(val);
  PrintStr("\n");
  poke64(dst, val);
}

fn poke_via_local(dst: int64): void {
  var path: pchar := "/bin/echo";
  var val: int64 := path as int64;
  PrintStr("local as int64: ");
  PrintInt(val);
  PrintStr("\n");
  poke64(dst, val);
}

fn main(): void {
  var buf: int64 := mmap(0, 16, 3, 34, -1, 0);
  PrintStr("buf=");
  PrintInt(buf);
  PrintStr("\n");

  PrintStr("Test local:\n");
  poke_via_local(buf);
  PrintStr("local ok\n");

  PrintStr("Test param:\n");
  poke_via_param("/bin/echo", buf);
  PrintStr("param ok\n");
  munmap(buf, 16);
}
