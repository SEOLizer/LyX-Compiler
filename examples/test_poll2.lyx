// Test poll with corrected structure
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    // pollfd is: fd (4 bytes), events (2 bytes), revents (2 bytes)
    // Total 8 bytes but we use mmap
    var fds: int64 := mmap(0, 24, 3, 34, -1, 0);
    
    // Set fd at offset 0
    var fd_val: int64 := conn.fd;
    var i: int64 := 0;
    while (i < 4) {
        poke8(fds + i, fd_val & 0xFF);
        fd_val := fd_val >> 8;
        i := i + 1;
    }
    
    // Set events at offset 4 (POLLIN = 1)
    poke8(fds + 4, 1);
    
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(conn.fd, req, 18);
    PrintStr("wrote\n");
    
    var n: int64 := Poll(fds, 1, 1000);
    PrintStr("poll n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // Read revents at offset 6
    var rev: int64 := peek8(fds + 6);
    PrintStr("revents = ");
    PrintInt(rev);
    PrintStr("\n");
    
    // If revents shows data, try reading
    if (rev == 1) {
        var buf: pchar := "                    ";
        var r: int64 := Read(conn.fd, buf, 32);
        PrintStr("read = ");
        PrintInt(r);
        PrintStr("\n");
    }
    
    munmap(fds, 24);
    Close(conn.fd);
    return 0;
}