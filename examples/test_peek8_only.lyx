// Test peek8 only - does it work at all?
fn main(): int64 {
    PrintStr("=== Test peek8 only ===\n");
    
    var buf: int64 := mmap(0, 4096, 3, 34, -1, 0);
    PrintStr("mmap = ");
    PrintInt(buf);
    PrintStr("\n");
    
    // Just peek8, NO poke before
    var val: int64 := peek8(buf);
    PrintStr("peek8 (no poke before) = ");
    PrintInt(val);
    PrintStr("\n");
    
    // Now poke and peek again
    poke8(buf, 65);
    var val2: int64 := peek8(buf);
    PrintStr("peek8 (after poke) = ");
    PrintInt(val2);
    PrintStr("\n");
    
    munmap(buf, 4096);
    PrintStr("Done\n");
    return 0;
}