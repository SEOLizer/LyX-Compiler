// Check what sys_read actually returns vs what peek8 sees
import std.net.syscalls;
import std.net.socket;

fn main(): int64 {
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { return 1; }
    PrintStr("connected\n");
    
    var my_fd: int64 := conn.fd;
    var req: pchar := "*1\r\n$4\r\nPING\r\n";
    Write(my_fd, req, 18);
    
    // Allocate mmap
    var buf: int64 := mmap(0, 64, 3, 34, -1, 0);
    PrintStr("mmap = ");
    PrintInt(buf);
    PrintStr("\n");
    
    // Write something to mmap first
    poke8(buf, 99);
    PrintStr("poked 99 to buf\n");
    var check: int64 := peek8(buf);
    PrintInt(check);
    PrintStr("\n");
    
    // Now call read
    var n: int64 := Read(my_fd, buf, 64);
    PrintStr("Read returned: ");
    PrintInt(n);
    PrintStr("\n");
    
    // Check if poke still works after read
    poke8(buf, 88);
    check := peek8(buf);
    PrintInt(check);
    PrintStr("\n");
    
    // Try reading again
    n := Read(my_fd, buf, 64);
    PrintStr("Read2 returned: ");
    PrintInt(n);
    PrintStr("\n");
    
    // Check again
    check := peek8(buf);
    PrintInt(check);
    PrintStr("\n");
    
    // Poke a different spot
    poke8(buf + 16, 77);
    check := peek8(buf + 16);
    PrintInt(check);
    PrintStr("\n");
    
    munmap(buf, 64);
    Close(conn.fd);
    return 0;
}