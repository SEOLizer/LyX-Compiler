// Test LRANGE with just 1 struct after it, no int64 in between
import std.db.redis;

fn main(): int64 {
    PrintStr("Connecting...\n");
    var conn: RedisConn := RedisConnect("127.0.0.1", 6379);
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    PrintStr("Connected\n");
    
    if (RedisPing(conn)) {
        PrintStr("PING OK\n");
    }
    
    // Setup
    RedisDel(conn, "mylist");
    var r: RedisReply := RedisLPush(conn, "mylist", "first");
    r := RedisLPush(conn, "mylist", "second");
    r := RedisRPush(conn, "mylist", "last");
    PrintStr("Setup done\n");
    
    // LRANGE - returns struct
    r := RedisLRange(conn, "mylist", 0, -1);
    PrintStr("LRANGE done\n");
    
    // Another LRANGE - try returning struct again
    r := RedisLRange(conn, "mylist", 0, 0);
    PrintStr("LRANGE2 done\n");
    
    RedisClose(conn);
    PrintStr("Done\n");
    return 0;
}