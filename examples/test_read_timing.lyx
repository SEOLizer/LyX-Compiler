// Debug sys_read
import std.net.socket;

fn main(): int64 {
    PrintStr("=== Test sys_read timing ===\n");
    
    var conn: TCPConn := TCPConnect(0x7F000001, 6379);
    if (conn.fd < 0) { PrintStr("Connect failed\n"); return 1; }
    PrintStr("Connected\n");
    
    // SET
    var req: pchar := "*3\r\n$3\r\nSET\r\n$3\r\nkey\r\n$5\r\nvalue\r\n";
    var sent: int64 := sys_write(conn.fd, req, 36);
    PrintStr("SET sent: ");
    PrintInt(sent);
    PrintStr("\n");
    PrintStr("About to read SET response...\n");
    
    var buf: pchar := "                    ";
    var n: int64 := sys_read(conn.fd, buf, 32);
    PrintStr("SET response n = ");
    PrintInt(n);
    PrintStr("\n");
    
    // GET
    PrintStr("About to send GET...\n");
    req := "*2\r\n$3\r\nGET\r\n$3\r\nkey\r\n";
    sent := sys_write(conn.fd, req, 26);
    PrintStr("GET sent: ");
    PrintInt(sent);
    PrintStr("\n");
    PrintStr("About to read GET response...\n");
    
    n := sys_read(conn.fd, buf, 32);
    PrintStr("GET response n = ");
    PrintInt(n);
    PrintStr(", buf = [");
    PrintStr(buf);
    PrintStr("]\n");
    
    sys_close(conn.fd);
    PrintStr("Done\n");
    
    return 0;
}