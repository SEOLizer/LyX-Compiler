// test_ml_kmeans.lyx - k-Means Clustering Tests
// Unsupervised clustering with std.ml

import std.io;
import std.ml;

pub fn main(): int64 {
  PrintStr("=== k-Means Clustering Test ===\n");
  
  // Test 1: Simple 2-cluster with 2 points
  PrintStr("\n[Test 1] 2-Point 2-Cluster\n");
  KMeansInit2(0.0, 10.0);  // Initial centroids
  KMeansFit2(2.0, 8.0, 10);  // Fit with 2 data points
  
  var c0: f64 := KMeansCentroid0();
  var c1: f64 := KMeansCentroid1();
  PrintStr("Centroid 0 = ");
  PrintFloat(c0);
  PrintStr("\n");
  PrintStr("Centroid 1 = ");
  PrintFloat(c1);
  PrintStr("\n");
  
  // Test 2: Predict clusters
  PrintStr("\n[Test 2] Cluster Prediction\n");
  var cluster1: int64 := KMeansPredict(1.0);
  var cluster2: int64 := KMeansPredict(5.0);
  var cluster3: int64 := KMeansPredict(9.0);
  
  PrintStr("x=1.0 -> Cluster ");
  PrintInt(cluster1);
  PrintStr("\n");
  PrintStr("x=5.0 -> Cluster ");
  PrintInt(cluster2);
  PrintStr("\n");
  PrintStr("x=9.0 -> Cluster ");
  PrintInt(cluster3);
  PrintStr("\n");
  
  // Test 3: More iterations
  PrintStr("\n[Test 3] More Iterations\n");
  KMeansInit2(0.0, 10.0);
  KMeansFit2(1.0, 9.0, 100);  // More iterations
  
  var c0b: f64 := KMeansCentroid0();
  var c1b: f64 := KMeansCentroid1();
  PrintStr("Centroid 0 (100 iter) = ");
  PrintFloat(c0b);
  PrintStr("\n");
  PrintStr("Centroid 1 (100 iter) = ");
  PrintFloat(c1b);
  PrintStr("\n");
  
  PrintStr("\n=== Done ===\n");
  
  return 0;
}