// Debug what's happening in lexer
fn main(): int64 {
  // Create a simple source buffer
  var src: int64 := mmap(0, 64, 3, 34, -1, 0);
  
  // Put "fn main(): int64 { return 42; }" in it
  poke8(src + 0, 102); // 'f'
  poke8(src + 1, 110); // 'n'
  poke8(src + 2, 32);  // ' '
  poke8(src + 3, 109); // 'm'
  poke8(src + 4, 97);  // 'a'
  poke8(src + 5, 105); // 'i'
  poke8(src + 6, 110); // 'n'
  poke8(src + 7, 40);  // '('
  poke8(src + 8, 41);  // ')'
  poke8(src + 9, 58);  // ':'
  poke8(src + 10, 32); // ' '
  poke8(src + 11, 123); // '{'
  poke8(src + 12, 32); // ' '
  poke8(src + 13, 114); // 'r'
  poke8(src + 14, 101); // 'e'
  poke8(src + 15, 116); // 't'
  poke8(src + 16, 117); // 'u'
  poke8(src + 17, 114); // 'r'
  poke8(src + 18, 110); // 'n'
  poke8(src + 19, 32);  // ' '
  poke8(src + 20, 52);  // '4'
  poke8(src + 21, 50);  // '2'
  poke8(src + 22, 59);  // ';'
  poke8(src + 23, 32);  // ' '
  poke8(src + 24, 125); // '}'
  poke8(src + 25, 0);   // null
  
  PrintStr("Source created, length: 25\n");
  
  // Simulate lexer.TokText() for token at position 0, length 2 ("fn")
  var tokenText: int64 := StrSub(src, 0, 2);
  
  PrintStr("Token text address: ");
  PrintInt(tokenText);
  PrintStr("\n");
  
  PrintStr("Token bytes: ");
  var i: int64 := 0;
  while i < 2 {
    var c: int64 := peek8(tokenText + i);
    PrintInt(c);
    PrintStr(" ");
    i := i + 1;
  }
  PrintStr("\n");
  
  // Another token
  var tokenText2: int64 := StrSub(src, 3, 4);  // "main"
  
  PrintStr("Token2 bytes: ");
  var j: int64 := 0;
  while j < 4 {
    var c2: int64 := peek8(tokenText2 + j);
    PrintInt(c2);
    PrintStr(" ");
    j := j + 1;
  }
  PrintStr("\n");
  
  munmap(src, 64);
  return 0;
}