// Test: Function pointer with int64 (opaque)
// This is the pragmatic approach - use int64 as function pointer
fn double(x: int64): int64 {
  return x * 2;
}

// Declare double as an extern that returns its address
extern fn get_double_addr(): int64;

fn main(): int64 {
  // Get function address
  var addr: int64 := get_double_addr();
  
  // For now, we need a workaround: call the function directly
  var result: int64 := double(21);
  PrintInt(result);
  
  return 0;
