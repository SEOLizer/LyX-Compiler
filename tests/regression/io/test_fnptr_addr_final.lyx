// Test: function pointer - debug address after init
type Callback = fn(int64, int64) -> int64;

fn add(a: int64, b: int64): int64 {
  return a + b;
}

fn main(): int64 {
  // Initialize with function address
  var cb: Callback := add;
  // Print the address - should be non-zero now
  var addr: int64 := cb as int64;
  PrintInt(addr);
  return addr;
}
