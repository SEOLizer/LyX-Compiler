// Test: variable declaration inside control structures
fn foo(): int64 {
  return 42;
}

fn main(): int64 {
  var cond: bool := true;
  
  // Test 1: var inside if block (NO semicolon after block)
  if (cond) {
    var x: int64 := foo();
    PrintInt(x);
  }
  
  // Test 2: var inside while block (NO semicolon after block)
  var i: int64 := 0;
  while (i < 1) {
    var y: int64 := foo();
    PrintInt(y);
    i := i + 1;
  }
  
  return 0;
}
