// Test: function pointer - debug
type Callback = fn(int64, int64) -> int64;

fn add(a: int64, b: int64): int64 {
  return a + b;
}

fn main(): int64 {
  var cb: Callback := add;
  // Print address of cb
  var addr: int64 := cb as int64;
  PrintInt(addr);
  // Print result (just to use add)
  var result: int64 := add(10, 20);
  PrintInt(result);
  return 0;
}
