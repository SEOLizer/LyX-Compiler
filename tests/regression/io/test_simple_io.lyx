// Test open/write/close
fn main(): int64 {
  var fd: int64 := 0;
  var ret: int64 := 0;
  var path: pchar := "/tmp/test_simple.txt";
  
  fd := open(path, 577, 420);
  if (fd < 0) {
    PrintStr("Cannot open\n");
    return 1;
  }
  
  ret := write(fd, "Hello\n", 6);
  PrintStr("Written: ");
  PrintInt(ret);
  PrintStr("\n");
  
  close(fd);
  
  // erneut öffnen
  fd := open(path, 0, 0);
  if (fd < 0) {
    PrintStr("Cannot open again\n");
    return 1;
  }
  
  close(fd);
  unlink(path);
  
  PrintStr("OK\n");
  return 0;
}
