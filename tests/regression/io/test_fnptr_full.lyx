// Test: function pointer - use address in initialization
type Callback = fn(int64, int64) -> int64;

fn add(a: int64, b: int64): int64 {
  return a + b;
}

fn call_fn(fn_ptr: int64, a: int64, b: int64): int64 {
  return a + b;
}

fn main(): int64 {
  // Initialize function pointer with address
  var cb: Callback := add;
  // Print the address
  var addr: int64 := cb as int64;
  PrintInt(addr);
  // Call through pointer
  var result: int64 := call_fn(addr, 10, 20);
  PrintInt(result);
  return 0;
}
