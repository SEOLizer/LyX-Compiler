fn main(): int64 {
  var a: array := [];
  PrintStr("Array init: ");
  PrintInt(len(a));
  PrintStr("\n");

  push(a, 10);
  PrintStr("After push 10, len: ");
  PrintInt(len(a));
  PrintStr("\n");

  push(a, 20);
  PrintStr("After push 20, len: ");
  PrintInt(len(a));
  PrintStr("\n");

  PrintStr("a[0]: ");
  PrintInt(a[0]);
  PrintStr("\n");

  PrintStr("a[1]: ");
  PrintInt(a[1]);
  PrintStr("\n");

  var popped: int64 := pop(a);
  PrintStr("Popped: ");
  PrintInt(popped);
  PrintStr("\n");
  PrintStr("After pop, len: ");
  PrintInt(len(a));
  PrintStr("\n");

  a[0] := 100;
  PrintStr("a[0] after assign: ");
  PrintInt(a[0]);
  PrintStr("\n");

  free(a);
  PrintStr("After free.\n");

  return 0;
}
