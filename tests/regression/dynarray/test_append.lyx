// test_append.lyx
// Teste den append-Builtin (Alias für push)
fn main(): int64 {
  var a: array := [];

  append(a, 10);
  append(a, 20);
  append(a, 30);

  PrintStr("len after 3 appends: ");
  PrintInt(len(a));
  PrintStr("\n");

  PrintStr("a[0]: ");
  PrintInt(a[0]);
  PrintStr("\n");

  PrintStr("a[1]: ");
  PrintInt(a[1]);
  PrintStr("\n");

  PrintStr("a[2]: ");
  PrintInt(a[2]);
  PrintStr("\n");

  free(a);
  return 0;
}
