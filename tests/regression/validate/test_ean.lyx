// Test EAN Validation Module
// Demonstrates EAN, ISBN, and UPC validation

import std.validate.ean;

fn main(): int64 {
  PrintStr("Testing EAN Validation Module...\n");
  
  // Test 1: EAN-13 Validation
  PrintStr("Test 1: EAN-13 Validation\n");
  
  var valid: int64 := EAN13Validate("4006381333931");
  PrintStr("  4006381333931 -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID (code ");
    PrintInt(valid);
    PrintStr(")")
  }
  PrintStr("\n");
  
  valid := EAN13Validate("4006381333930");
  PrintStr("  4006381333930 -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID (code ");
    PrintInt(valid);
    PrintStr(")")
  }
  PrintStr("\n");
  
  // Test 2: EAN-13 Check Digit
  PrintStr("Test 2: EAN-13 Check Digit\n");
  var check: int64 := EAN13CheckDigit("400638133393");
  PrintStr("  400638133393 -> check digit: ");
  PrintInt(check);
  PrintStr("\n");
  
  // Test 3: EAN-8 Validation
  PrintStr("Test 3: EAN-8 Validation\n");
  valid := EAN8Validate("96385074");
  PrintStr("  96385074 -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  // Test 4: ISBN-13 Validation
  PrintStr("Test 4: ISBN-13 Validation\n");
  valid := ISBN13Validate("9783161484100");
  PrintStr("  9783161484100 -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  // Test 5: ISBN-10 Validation
  PrintStr("Test 5: ISBN-10 Validation\n");
  valid := ISBN10Validate("0306406152");
  PrintStr("  0306406152 -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  valid := ISBN10Validate("030640615X");
  PrintStr("  030640615X -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  // Test 6: UPC-A Validation
  PrintStr("Test 6: UPC-A Validation\n");
  valid := UPCAValidate("012345678905");
  PrintStr("  012345678905 -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  // Test 7: EAN-13 Formatting
  PrintStr("Test 7: EAN-13 Formatting\n");
  var formatted: int64 := EAN13Format("4006381333931");
  if (formatted != 0) {
    PrintStr("  Formatted: ");
    sys_write(1, formatted, 16);
    PrintStr("\n");
    munmap(formatted, 16);
  }
  
  // Test 8: Country Detection
  PrintStr("Test 8: Country Detection\n");
  var country: int64 := EAN13GetCountry("4006381333931");
  PrintStr("  400... -> ");
  sys_write(1, country, 20);
  PrintStr("\n");
  
  country := EAN13GetCountry("5901234123457");
  PrintStr("  590... -> ");
  sys_write(1, country, 20);
  PrintStr("\n");
  
  country := EAN13GetCountry("8401234567890");
  PrintStr("  840... -> ");
  sys_write(1, country, 20);
  PrintStr("\n");
  
  PrintStr("\nAll tests completed!\n");
  return 0;
}
