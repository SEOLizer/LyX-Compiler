// Test ISBN/ISSN Module
// Demonstrates ISBN-10, ISBN-13, and ISSN validation and conversion

import std.validate.isbn;

fn main(): int64 {
  PrintStr("Testing ISBN/ISSN Module...\n");
  
  // Test 1: ISBN-13 Validation
  PrintStr("Test 1: ISBN-13 Validation\n");
  var valid: int64 := ISBN13ValidateFull("978-3-16-148410-0");
  PrintStr("  978-3-16-148410-0 -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID (");
    PrintInt(valid);
    PrintStr(")")
  }
  PrintStr("\n");
  
  valid := ISBN13ValidateFull("9783161484100");
  PrintStr("  9783161484100 -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  // Test 2: ISBN-10 Validation
  PrintStr("Test 2: ISBN-10 Validation\n");
  valid := ISBN10ValidateFull("0-306-40615-2");
  PrintStr("  0-306-40615-2 -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  valid := ISBN10ValidateFull("030640615X");
  PrintStr("  030640615X -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  // Test 3: ISBN-10 to ISBN-13 Conversion
  PrintStr("Test 3: ISBN-10 to ISBN-13 Conversion\n");
  var isbn13: int64 := ISBN10To13("0306406152");
  if (isbn13 != 0) {
    PrintStr("  0306406152 -> ");
    sys_write(1, isbn13, 13);
    PrintStr("\n");
    // Verify the result
    valid := ISBN13ValidateFull(isbn13);
    PrintStr("  Result valid: ");
    if (valid == 0) {
      PrintStr("YES")
    } else {
      PrintStr("NO")
    }
    PrintStr("\n");
    munmap(isbn13, 14);
  }
  
  // Test 4: ISBN-13 to ISBN-10 Conversion
  PrintStr("Test 4: ISBN-13 to ISBN-10 Conversion\n");
  var isbn10: int64 := ISBN13To10("9783161484100");
  if (isbn10 != 0) {
    PrintStr("  9783161484100 -> ");
    sys_write(1, isbn10, 10);
    PrintStr("\n");
    valid := ISBN10ValidateFull(isbn10);
    PrintStr("  Result valid: ");
    if (valid == 0) {
      PrintStr("YES")
    } else {
      PrintStr("NO")
    }
    PrintStr("\n");
    munmap(isbn10, 11);
  }
  
  // Test 5: ISBN-13 Formatting
  PrintStr("Test 5: ISBN-13 Formatting\n");
  var formatted: int64 := ISBN13Format("9783161484100");
  if (formatted != 0) {
    PrintStr("  9783161484100 -> ");
    sys_write(1, formatted, 17);
    PrintStr("\n");
    munmap(formatted, 18);
  }
  
  // Test 6: ISBN-10 Formatting
  PrintStr("Test 6: ISBN-10 Formatting\n");
  formatted := ISBN10Format("0306406152");
  if (formatted != 0) {
    PrintStr("  0306406152 -> ");
    sys_write(1, formatted, 13);
    PrintStr("\n");
    munmap(formatted, 14);
  }
  
  // Test 7: ISSN Validation
  PrintStr("Test 7: ISSN Validation\n");
  valid := ISSNValidate("0020-0255");
  PrintStr("  0020-0255 -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  valid := ISSNValidate("2049-3630");
  PrintStr("  2049-3630 -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  // Test 8: ISSN Check Digit
  PrintStr("Test 8: ISSN Check Digit\n");
  var check: int64 := ISSNCheckDigit("0020-025");
  PrintStr("  0020-025 -> check digit: ");
  var charBuf: int64 := mmap(0, 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (charBuf != 0) {
    poke8(charBuf, check);
    sys_write(1, charBuf, 1);
    munmap(charBuf, 8);
  }
  PrintStr("\n");
  
  // Test 9: ISSN Formatting
  PrintStr("Test 9: ISSN Formatting\n");
  var issnFmt: int64 := ISSNFormat("00200255");
  if (issnFmt != 0) {
    PrintStr("  00200255 -> ");
    sys_write(1, issnFmt, 9);
    PrintStr("\n");
    munmap(issnFmt, 10);
  }
  
  // Test 10: Type Detection
  PrintStr("Test 10: Type Detection\n");
  var t: int64 := ISBNDetectType("9783161484100");
  PrintStr("  9783161484100 -> type ");
  PrintInt(t);
  if (t == 13) { PrintStr(" (ISBN-13)") }
  PrintStr("\n");
  
  t := ISBNDetectType("0306406152");
  PrintStr("  0306406152 -> type ");
  PrintInt(t);
  if (t == 10) { PrintStr(" (ISBN-10)") }
  PrintStr("\n");
  
  t := ISBNDetectType("0020-0255");
  PrintStr("  0020-0255 -> type ");
  PrintInt(t);
  if (t == 8) { PrintStr(" (ISSN)") }
  PrintStr("\n");
  
  PrintStr("\nAll tests completed!\n");
  return 0;
}
