// Test IBAN Validation Module
// Demonstrates IBAN validation, check digit calculation, and formatting

import std.validate.iban;

fn main(): int64 {
  PrintStr("Testing IBAN Validation Module...\n");
  
  // Test 1: IBAN Validation
  PrintStr("Test 1: IBAN Validation\n");
  var valid: int64 := IBANValidate("DE89370400440532013000");
  PrintStr("  DE89370400440532013000 -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID (");
    PrintInt(valid);
    PrintStr(")")
  }
  PrintStr("\n");
  
  valid := IBANValidate("GB29NWBK60161331926819");
  PrintStr("  GB29NWBK60161331926819 -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  valid := IBANValidate("FR7630006000011234567890189");
  PrintStr("  FR7630006000011234567890189 -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  valid := IBANValidate("CH9300762011623852957");
  PrintStr("  CH9300762011623852957 -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  // Test 2: Invalid IBANs (transposition errors)
  PrintStr("Test 2: Invalid IBAN Detection\n");
  valid := IBANValidate("DE89370400440532013001");
  PrintStr("  DE89370400440532013001 (last digit wrong) -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID (transposition!)")
  }
  PrintStr("\n");
  
  valid := IBANValidate("DE88370400440532013000");
  PrintStr("  DE88370400440532013000 (check digit wrong) -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  // Test 3: IBAN with spaces
  PrintStr("Test 3: IBAN with Spaces\n");
  valid := IBANValidate("DE89 3704 0044 0532 0130 00");
  PrintStr("  DE89 3704 0044 0532 0130 00 -> ");
  if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  // Test 4: Country Detection
  PrintStr("Test 4: Country Detection\n");
  var country: int64 := IBANGetCountry("DE89370400440532013000");
  if (country != 0) {
    PrintStr("  DE89... -> ");
    sys_write(1, country, 2);
    PrintStr(" (");
    sys_write(1, IBANGetCountryName(country), 20);
    PrintStr(")\n");
    munmap(country, 3);
  }
  
  country := IBANGetCountry("GB29NWBK60161331926819");
  if (country != 0) {
    PrintStr("  GB29... -> ");
    sys_write(1, country, 2);
    PrintStr(" (");
    sys_write(1, IBANGetCountryName(country), 20);
    PrintStr(")\n");
    munmap(country, 3);
  }
  
  // Test 5: IBAN Formatting
  PrintStr("Test 5: IBAN Formatting\n");
  var formatted: int64 := IBANFormat("DE89370400440532013000");
  if (formatted != 0) {
    PrintStr("  DE89370400440532013000 -> ");
    sys_write(1, formatted, 28);
    PrintStr("\n");
    munmap(formatted, 30);
  }
  
  // Test 6: Check Digit Calculation
  PrintStr("Test 6: Check Digit Calculation\n");
  var check: int64 := IBANCalculateCheck("DE00370400440532013000");
  if (check != 0) {
    PrintStr("  DE00370400440532013000 -> check digits: ");
    sys_write(1, check, 2);
    PrintStr("\n");
    munmap(check, 3);
  }
  
  check := IBANCalculateCheck("GB00NWBK60161331926819");
  if (check != 0) {
    PrintStr("  GB00NWBK60161331926819 -> check digits: ");
    sys_write(1, check, 2);
    PrintStr("\n");
    munmap(check, 3);
  }
  
  // Test 7: Bank ID Extraction
  PrintStr("Test 7: Bank ID Extraction\n");
  var bankId: int64 := IBANGetBankId("DE89370400440532013000");
  if (bankId != 0) {
    PrintStr("  DE89... -> bank ID: ");
    sys_write(1, bankId, 8);
    PrintStr("\n");
    munmap(bankId, 9);
  }
  
  // Test 8: Country Length Validation
  PrintStr("Test 8: Country Length Validation\n");
  // German IBAN must be 22 chars
  valid := IBANValidate("DE893704004405320130");  // Too short (21)
  PrintStr("  DE893704004405320130 (21 chars) -> ");
  if (valid == 5) {
    PrintStr("INVALID LENGTH (expected 22)")
  } else if (valid == 0) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID (");
    PrintInt(valid);
    PrintStr(")")
  }
  PrintStr("\n");
  
  PrintStr("\nAll tests completed!\n");
  return 0;
}
