// Test: std/log minimal

import std.log;

fn main(): int64 {
  PrintStr("Test 1: get_log_level\n");
  var level: int64 := get_log_level();
  PrintInt(level);
  PrintStr("\n");
  
  PrintStr("Test 2: log_level_to_string\n");
  PrintStr(log_level_to_string(0));
  PrintStr("\n");
  PrintStr(log_level_to_string(1));
  PrintStr("\n");
  
  PrintStr("Test 3: log_info\n");
  log_info("Hello from log!");
  
  PrintStr("Test 4: log_warn\n");
  log_warn("This is a warning");
  
  PrintStr("Test 5: log_error\n");
  log_error("This is an error");
  
  PrintStr("Test 7: log_debug_if\n");
  log_debug_if(true, "Conditional true");
  log_debug_if(false, "Conditional false");
  
  PrintStr("Done!\n");
  return 0;
}
