// Test: std/log basic functions

import std.log;

fn main(): int64 {
  PrintStr("=== std/log Tests ===\n");
  
  // Test get_log_level
  var level: int64 := get_log_level();
  PrintStr("Default log level: ");
  PrintInt(level);
  PrintStr("\n");
  
  // Test log_level_to_string
  PrintStr("\n--- Testing level strings ---\n");
  PrintStr("0: ");
  PrintStr(log_level_to_string(0));
  PrintStr("\n");
  
  // Test log functions (single call)
  PrintStr("\n--- Testing log levels ---\n");
  
  log_info("This is an INFO message");
  
  // Test conditional logging
  PrintStr("\n--- Testing conditional ---\n");
  log_debug_if(true, "Conditional: true");
  
  PrintStr("=== Tests done! ===\n");
  
  return 0;
}
