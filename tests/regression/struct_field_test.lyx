// tests/lyx/struct_field_test.lyx
// Minimaler Test fuer Struct-Feldzugriff

type TPoint = struct {
  x: int64;
  y: int64;
};

fn main(): int64 {
  // Test 1: Struct erstellen und Feld lesen
  var p: TPoint := TPoint { x: 42, y: 100 };
  
  // Test 2: Direkter Feldzugriff (CRASH?)
  var xVal: int64 := p.x;
  var yVal: int64 := p.y;
  
  PrintStr("x = ");
  PrintInt(xVal);
  PrintStr("\ny = ");
  PrintInt(yVal);
  PrintStr("\n");
  
  return 0;
}
