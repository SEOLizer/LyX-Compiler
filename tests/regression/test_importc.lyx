// Test importC: Auto-import from C header file
// Uses string.h from the system for strlen/strcpy

importC "string.h" link "libc.so.6";

fn main(): int64 {
  var s: pchar := "importC works!";
  var n: int64 := strlen(s);
  PrintStr("strlen via importC: ");
  PrintInt(n);
  PrintStr("\n");
  return 0;
}
