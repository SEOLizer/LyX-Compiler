// Test importC auf ARM64: C-Header auto-import mit --target=linux-arm64
// Verifies that importC "string.h" generates dynamic ELF via PLT/GOT

importC "string.h" link "libc.so.6";

fn main(): int64 {
  var s: pchar := "importC on ARM64!";
  var n: int64 := strlen(s);
  PrintStr("strlen via importC (ARM64): ");
  PrintInt(n);
  PrintStr("\n");
  return 0;
}
