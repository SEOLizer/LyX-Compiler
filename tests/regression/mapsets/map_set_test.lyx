// Map/Set test program
fn main() {
  // Test map literal
  var m: Map<int64, int64> := {1: 10, 2: 20, 3: 30};
  
  // Test map access
  var x: int64 := m[1];
  PrintInt(x);  // should print 10
  
  // Test map assignment
  m[1] := 100;
  x := m[1];
  PrintInt(x);  // should print 100
  
  // Test "in" operator
  var found: bool := 1 in m;
  if (found) {
    PrintStr("found");
  }
  
  // Test set literal
  var s: Set<int64> := {1, 2, 3};
  
  // Test set "in" operator
  found := 2 in s;
  if (found) {
    PrintStr("set found");
  }
  
  exit(0);
}
