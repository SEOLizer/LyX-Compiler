// Test: In-Situ Data Visualizer - Inspect() Builtin
// Testet die Debug-Ausgabe für verschiedene Datentypen

fn main(): int64 {
  // Test 1: Integer
  var count: int64 := 42;
  Inspect(count);

  // Test 2: Boolean
  var isActive: bool := true;
  Inspect(isActive);

  // Test 3: String
  var message: pchar := "Hello, Debug!";
  Inspect(message);

  // Test 4: Negative Integer
  var negValue: int64 := -123;
  Inspect(negValue);

  // Test 5: Zero
  var zero: int64 := 0;
  Inspect(zero);

  return 0;
}
