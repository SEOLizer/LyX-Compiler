// Test BGP Client
// Demonstrates BGP message building and protocol operations

import std.net.bgp;

fn main(): int64 {
  PrintStr("Testing BGP client (RFC 4271)...\n");
  
  // Test 1: Build OPEN message
  PrintStr("Test 1: Build BGP OPEN Message\n");
  var localId: int64 := BGPIPv4(10, 0, 0, 1);
  var open: int64 := BGPBuildOpen(4, 65001, 180, localId);
  if (open != 0) {
    PrintStr("  OPEN message built!\n");
    PrintStr("  Length: ");
    PrintInt(BGPGetMessageLength(open));
    PrintStr(" bytes\n");
    PrintStr("  Type: ");
    PrintInt(BGPGetMessageType(open));
    if (BGPGetMessageType(open) == BGP_MSG_OPEN) {
      PrintStr(" (OPEN)")
    }
    PrintStr("\n");
    munmap(open, 29);
  }
  
  // Test 2: Build KEEPALIVE message
  PrintStr("Test 2: Build BGP KEEPALIVE Message\n");
  var keepalive: int64 := BGPBuildKeepalive();
  if (keepalive != 0) {
    PrintStr("  KEEPALIVE message built!\n");
    PrintStr("  Length: ");
    PrintInt(BGPGetMessageLength(keepalive));
    PrintStr(" bytes\n");
    PrintStr("  Type: ");
    PrintInt(BGPGetMessageType(keepalive));
    if (BGPGetMessageType(keepalive) == BGP_MSG_KEEPALIVE) {
      PrintStr(" (KEEPALIVE)")
    }
    PrintStr("\n");
    munmap(keepalive, 19);
  }
  
  // Test 3: Build NOTIFICATION message
  PrintStr("Test 3: Build BGP NOTIFICATION Message\n");
  var notif: int64 := BGPBuildNotification(BGP_ERR_CEASE, 0);
  if (notif != 0) {
    PrintStr("  NOTIFICATION message built!\n");
    PrintStr("  Length: ");
    PrintInt(BGPGetMessageLength(notif));
    PrintStr(" bytes\n");
    munmap(notif, 21);
  }
  
  // Test 4: Build UPDATE message
  PrintStr("Test 4: Build BGP UPDATE Message\n");
  var prefix: int64 := BGPIPv4(10, 0, 0, 0);
  var nextHop: int64 := BGPIPv4(192, 168, 1, 1);
  var update: int64 := BGPBuildUpdate(prefix, 24, nextHop, BGP_ORIGIN_IGP);
  if (update != 0) {
    PrintStr("  UPDATE message built!\n");
    PrintStr("  Length: ");
    PrintInt(BGPGetMessageLength(update));
    PrintStr(" bytes\n");
    PrintStr("  Type: ");
    PrintInt(BGPGetMessageType(update));
    if (BGPGetMessageType(update) == BGP_MSG_UPDATE) {
      PrintStr(" (UPDATE)")
    }
    PrintStr("\n");
    munmap(update, 64);
  }
  
  // Test 5: IPv4 address formatting
  PrintStr("Test 5: IPv4 Address Formatting\n");
  var ip: int64 := BGPIPv4(192, 168, 1, 100);
  var ipStr: int64 := BGPFormatIPv4(ip);
  if (ipStr != 0) {
    PrintStr("  IP: ");
    sys_write(1, ipStr, 16);
    PrintStr("\n");
    munmap(ipStr, 16);
  }
  
  ip := BGPIPv4(10, 0, 0, 1);
  ipStr := BGPFormatIPv4(ip);
  if (ipStr != 0) {
    PrintStr("  IP: ");
    sys_write(1, ipStr, 16);
    PrintStr("\n");
    munmap(ipStr, 16);
  }
  
  // Test 6: Connect to BGP peer (if available)
  // Uncomment to test with real router:
