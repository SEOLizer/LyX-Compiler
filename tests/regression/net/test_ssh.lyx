// Test SSH Client
// Demonstrates SSH protocol flow using libssh2

import std.net.ssh;

fn main(): int64 {
  PrintStr("Testing SSH client (libssh2)...\n");
  
  // Test 1: Initialize SSH library
  PrintStr("Test 1: Initialize SSH library\n");
  var ret: int64 := SSHGlobalInit();
  if (ret == 0) {
    PrintStr("  SSH library initialized!\n");
  } else {
    PrintStr("  ERROR: SSH initialization failed\n");
    return 1;
  }
  
  // Test 2: Create session
  PrintStr("Test 2: Create SSH session\n");
  var session: SSHSession := SSHSessionNew();
  if (session.session != 0) {
    PrintStr("  Session created!\n");
    PrintStr("  Session ptr: ");
    PrintInt(session.session);
    PrintStr("\n");
  } else {
    PrintStr("  ERROR: Session creation failed\n");
    SSHGlobalCleanup();
    return 1;
  }
  
