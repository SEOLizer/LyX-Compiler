// Test mmap usage
import std.net.types;

fn main(): int64 {
  var p1: int64;
  var p2: int64;
  
  PrintStr("=== mmap Test ===\n");
  
  p1 := mmap(0, 128, PROT_RW, MAP_ANON, FD_NONE, 0);
  PrintStr("First mmap: ");
  PrintInt(p1);
  PrintStr("\n");
  
  p2 := mmap(0, 128, PROT_RW, MAP_ANON, FD_NONE, 0);
  PrintStr("Second mmap: ");
  PrintInt(p2);
  PrintStr("\n");
  
  if (p1 != 0) {
    munmap(p1, 128);
  }
  if (p2 != 0) {
    munmap(p2, 128);
  }
  
  PrintStr("=== Test Complete ===\n");
  return 0;
}
