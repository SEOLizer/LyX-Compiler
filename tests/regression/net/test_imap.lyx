// Test IMAP Client
// Demonstrates IMAP protocol flow without actual server connection

import std.net.imap;

fn main(): int64 {
  PrintStr("Testing IMAP client...\n");
  
  // Test 1: Build tagged command
  PrintStr("Test 1: Build tagged command\n");
  var conn: IMAPConn;
  conn.cmdTag := 1;
  
  var cmd: int64 := IMAPBuildTaggedCmd(conn, "LOGIN user pass");
  if (cmd != 0) {
    PrintStr("  Command: ");
    sys_write(1, cmd, 30);
    PrintStr("\n");
    munmap(cmd, 1024);
  }
  
  // Test 2: Build another tagged command
  conn.cmdTag := 42;
  cmd := IMAPBuildTaggedCmd(conn, "SELECT INBOX");
  if (cmd != 0) {
    PrintStr("  Command: ");
    sys_write(1, cmd, 30);
    PrintStr("\n");
    munmap(cmd, 1024);
  }
  
  // Test 3: Build FETCH command
  conn.cmdTag := 100;
  cmd := IMAPBuildTaggedCmd(conn, "1 FETCH (FLAGS ENVELOPE)");
  if (cmd != 0) {
    PrintStr("  Command: ");
    sys_write(1, cmd, 40);
    PrintStr("\n");
    munmap(cmd, 1024);
  }
  
  // Test 4: Build LIST command
  conn.cmdTag := 2;
  cmd := IMAPBuildTaggedCmd(conn, "LIST \"\" \"%\"");
  if (cmd != 0) {
    PrintStr("  Command: ");
    sys_write(1, cmd, 30);
    PrintStr("\n");
    munmap(cmd, 1024);
  }
  
  // Test 5: Parse response
  PrintStr("Test 5: Parse response\n");
  var respOk: int64 := mmap(0, 64, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (respOk != 0) {
    var i: int64 := 0;
    var s: int64 := "A001 OK LOGIN completed";
    while (i < 23) {
      poke8(respOk + i, peek8(s + i));
      i := i + 1;
    }
    poke8(respOk + 23, 0);
    
    var result: int64 := IMAPParseResponse(respOk);
    PrintStr("  A001 OK LOGIN completed -> ");
    PrintInt(result);
    if (result == 0) {
      PrintStr(" (OK)");
    }
    PrintStr("\n");
    munmap(respOk, 64);
  }
  
  // Test 6: Connect to IMAP server (if available)
  // Uncomment to test with real server:
  /*
  PrintStr("\nTest 6: Connect to IMAP server\n");
