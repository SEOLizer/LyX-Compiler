// Test SMTP Client
// Demonstrates SMTP protocol flow without actually sending email

import std.net.smtp;

fn main(): int64 {
  PrintStr("Testing SMTP client...\n");
  
  // Test 1: Build EHLO command
  PrintStr("Test 1: Build EHLO command\n");
  var ehloCmd: int64 := SMTPBuildEhlo("localhost");
  if (ehloCmd != 0) {
    PrintStr("  EHLO: ");
    sys_write(1, ehloCmd, 20);
    PrintStr("...\n");
    munmap(ehloCmd, 256);
  }
  
  // Test 2: Build MAIL FROM command
  PrintStr("Test 2: Build MAIL FROM command\n");
  var mailCmd: int64 := SMTPBuildMailFrom("test@example.com");
  if (mailCmd != 0) {
    PrintStr("  MAIL FROM: ");
    sys_write(1, mailCmd, 30);
    PrintStr("...\n");
    munmap(mailCmd, 512);
  }
  
  // Test 3: Build RCPT TO command
  PrintStr("Test 3: Build RCPT TO command\n");
  var rcptCmd: int64 := SMTPBuildRcptTo("user@example.com");
  if (rcptCmd != 0) {
    PrintStr("  RCPT TO: ");
    sys_write(1, rcptCmd, 30);
    PrintStr("...\n");
    munmap(rcptCmd, 512);
  }
  
  // Test 4: Build email message
  PrintStr("Test 4: Build email message\n");
  var email: SMTPEmail;
  email.from := "sender@example.com";
  email.to := "recipient@example.com";
  email.subject := "Test from Lyx";
  email.body := "Hello from the Lyx SMTP client!";
  
  var msg: int64 := SMTPBuildMessage(email);
  if (msg != 0) {
    var msgLen: int64 := SMTPStrLen(msg);
    PrintStr("  Message length: ");
    PrintInt(msgLen);
    PrintStr(" bytes\n");
    sys_write(1, msg, msgLen);
    munmap(msg, 8192);
  }
  
  // Test 5: Connect to SMTP server (if available)
  // This test connects to a real SMTP server
  // Uncomment and set your SMTP server details:
  /*
  PrintStr("\nTest 5: Connect to SMTP server\n");
