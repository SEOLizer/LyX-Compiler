  if (conn.connected == 1) {
    PrintStr("  Connected!\n");
    
    // EHLO
    var code: int64 := SMTPEhlo(conn, 0);
    PrintStr("  EHLO response: ");
    PrintInt(code);
    PrintStr("\n");
    
    // Send email
    code := SMTPSend(conn, email);
    PrintStr("  SMTP send result: ");
    PrintInt(code);
    PrintStr("\n");
    
    // QUIT
    code := SMTPQuit(conn);
    PrintStr("  QUIT response: ");
    PrintInt(code);
    PrintStr("\n");
    
    SMTPClose(conn);
  } else {
    PrintStr("  Connection failed (expected in test environment)\n");
  }
  */
  
  PrintStr("\nAll tests completed!\n");
  return 0;
}
