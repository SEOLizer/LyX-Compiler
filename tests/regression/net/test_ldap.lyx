// Test LDAP Client
// Demonstrates LDAP protocol message building

import std.net.ldap;
import std.net.asn1;

fn main(): int64 {
  PrintStr("Testing LDAP client...\n");
  
  // Test 1: Build Bind Request
  PrintStr("Test 1: Build LDAP Bind Request\n");
  var msg: int64 := LDAPBuildBindRequest("cn=admin,dc=example,dc=com", "secret");
  if (msg != 0) {
    PrintStr("  Bind request built!\n");
    PrintStr("  First bytes: ");
    var i: int64 := 0;
    while (i < 16) {
      var b: int64 := peek8(msg + i);
      if (b < 16) { PrintStr("0"); }
      PrintInt(b);
      i := i + 1;
    }
    PrintStr("\n");
    
    // Check outer SEQUENCE tag
    var tag: int64 := peek8(msg);
    PrintStr("  Tag: 0x");
    PrintInt(tag);
    PrintStr(" (expect 0x30 = SEQUENCE)\n");
    
    munmap(msg, 2048);
  }
  
  // Test 2: Build Search Request
  PrintStr("Test 2: Build LDAP Search Request\n");
  msg := LDAPBuildSearchRequest("dc=example,dc=com", "(objectClass=*)", LDAP_SCOPE_SUBTREE);
  if (msg != 0) {
    PrintStr("  Search request built!\n");
    
    var tag: int64 := peek8(msg);
    PrintStr("  Tag: 0x");
    PrintInt(tag);
    PrintStr(" (expect 0x30 = SEQUENCE)\n");
    
    munmap(msg, 4096);
  }
  
  // Test 3: Build Unbind Request
  PrintStr("Test 3: Build LDAP Unbind Request\n");
  msg := LDAPBuildUnbindRequest();
  if (msg != 0) {
    PrintStr("  Unbind request built!\n");
    PrintStr("  Size: 9 bytes (fixed)\n");
    munmap(msg, 32);
  }
  
  // Test 4: Connect to LDAP server (if available)
  // Uncomment to test with real server:
