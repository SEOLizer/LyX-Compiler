fn testTCPSocket() {
  var listener: TCPListener := TCPListenerNew();
  
  if (listener.fd >= 0) {
    PrintStr("TCP socket created successfully!\n");
    PrintStr("FD: ");
    PrintInt(listener.fd);
    PrintStr("\n");
    
    // Set reuse addr
    var ret: int64 := TCPListenerSetReuseAddr(listener);
    PrintStr("Set SO_REUSEADDR: ");
    PrintInt(ret);
    PrintStr("\n");
    
    // Try to bind
    ret := TCPListenerBindTo(listener, 0, 8080);
    PrintStr("Bind to port 8080: ");
    PrintInt(ret);
    PrintStr("\n");
    
    if (ret >= 0) {
      // Listen
      ret := TCPListenerListen(listener, 10);
      PrintStr("Listen: ");
      PrintInt(ret);
      PrintStr("\n");
      
      if (ret >= 0) {
        PrintStr("TCP server ready on port 8080!\n");
      }
    }
    
    TCPListenerClose(listener);
  } else {
    PrintStr("Failed to create TCP socket\n");
  }
}

fn testUDPSocket() {
  var sock: UDPSocket := UDPSocketNew();
  
  if (sock.fd >= 0) {
    PrintStr("UDP socket created successfully!\n");
    PrintStr("FD: ");
    PrintInt(sock.fd);
    PrintStr("\n");
    
    // Set reuse addr
    var ret: int64 := UDPSocketSetReuseAddr(sock);
    PrintStr("Set SO_REUSEADDR: ");
    PrintInt(ret);
    PrintStr("\n");
    
    // Try to bind
    ret := UDPSocketBindTo(sock, 0, 8081);
    PrintStr("Bind to port 8081: ");
    PrintInt(ret);
    PrintStr("\n");
    
    if (ret >= 0) {
      PrintStr("UDP socket ready on port 8081!\n");
    }
    
    UDPSocketClose(sock);
  } else {
    PrintStr("Failed to create UDP socket\n");
  }
}
