fn testIPParsing() {
  // Test IP without port
  var ip1: int64 := IPPack(192, 168, 1, 1);
  PrintStr("IP packed: ");
  PrintInt(ip1);
  PrintStr("\n");
  
  var addr1: IPAddr := IPUnpack(ip1);
  PrintStr("IP unpacked: ");
  PrintInt(addr1.a as int64);
  PrintStr(".");
  PrintInt(addr1.b as int64);
  PrintStr(".");
  PrintInt(addr1.c as int64);
  PrintStr(".");
  PrintInt(addr1.d as int64);
  PrintStr("\n");
  
  // Test ParseIPAddr (if implemented)
  // This would require string literals which may not be fully supported
}

fn testDNS_A() {
  // Test resolving A record for google.com
  var result: int64 := mmap(0, 128, 3, 34, -1, 0);
  
  // google.com as string (allocated with mmap)
  var hostname: int64 := mmap(0, 32, 3, 34, -1, 0);
  poke8(hostname + 0, 103);  // g
  poke8(hostname + 1, 111);  // o
  poke8(hostname + 2, 111);  // o
  poke8(hostname + 3, 103);  // g
  poke8(hostname + 4, 108);  // l
  poke8(hostname + 5, 101);  // e
  poke8(hostname + 6, 46);   // .
  poke8(hostname + 7, 99);   // c
  poke8(hostname + 8, 111);  // o
  poke8(hostname + 9, 109);  // m
  
  var success: bool := DNSResolveGoogle(hostname, 10, result);
  
  if (success) {
    PrintStr("DNS A record resolved!\n");
    var ip: int64 := DNSResultGetIPv4(result);
    PrintStr("IP: ");
    PrintInt((ip >> 24) & 0xFF);
    PrintStr(".");
    PrintInt((ip >> 16) & 0xFF);
    PrintStr(".");
    PrintInt((ip >> 8) & 0xFF);
    PrintStr(".");
    PrintInt(ip & 0xFF);
    PrintStr("\n");
  } else {
    PrintStr("DNS resolution failed\n");
  }
  
  munmap(hostname, 32);
  munmap(result, 128);
}

