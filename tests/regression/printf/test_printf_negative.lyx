// examples/test_Printf_negative.lyx
// Negative and additional Printf tests

import std.io;
import std.string;

fn main(): int64 {
  // Full substitution (4 args)
  var a1: pchar := "one";
  var a2: pchar := IntToStr(2);
  var a3: pchar := FloatToStr(3.14 as f64, 6);
  var a4: pchar := "four";
  Printf("A:%s B:%d C:%f D:%s\n", a1, a2, a3, a4);

  // Missing argument: second placeholder should be empty
  Printf("X:%s Y:%d\n", "onlyone");

  // Unsupported specifier should Print '%q'
  Printf("unknown:%q\n");

  // Escaped percent
  Printf("literal percent: %% done\n");

  return 0;
}
