// Test panic and assert functionality

fn testPanic(): void {
    panic("This is a panic message!");
}

fn testAssertPass(): void {
    // This should pass - condition is true
    assert(1 == 1, "Math is broken!");
}

fn testAssertFail(): void {
    // This should fail - condition is false
    assert(1 == 0, "This should have failed!");
}

fn main(): int64 {
    // Test 1: panic
    // testPanic();  // Uncomment to test panic

    // Test 2: passing assert
    testAssertPass();

    // Test 3: failing assert (uncomment to test)
    // testAssertFail();

    PrintStr("All tests passed!");
    return 0;
}
