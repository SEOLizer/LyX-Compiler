// Test: uint8 to int64 cast in function return

fn testCast(x: uint8): int64 {
  return x as int64;
}

fn main(): int64 {
  var val: uint8 := 192;
  var result: int64 := testCast(val);
  
  PrintStr("result = ");
  PrintInt(result);
  PrintStr("\n");
  
  // Also test direct return
  return result;
}
