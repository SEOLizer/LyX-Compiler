// Minimal super call test
// Expected output: 10 (5 * 2)

type Base = class {
  value: int64;
  
  fn Set(v: int64) {
    self.value := v;
  }
};

type Derived = class extends Base {
  fn SetAndDouble(v: int64) {
    super.Set(v);
    self.value := self.value * 2;
  }
};

fn main(): int64 {
  var d: Derived := new Derived();
  d.SetAndDouble(5);
  PrintInt(d.value);
  PrintStr("\n");
  dispose d;
  return 0;
}
