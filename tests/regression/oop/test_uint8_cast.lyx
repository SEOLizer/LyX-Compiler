// Test: uint8 cast to int64 bug

fn testUint8ToInt64(x: uint8): int64 {
  return x as int64;
}

fn main(): int64 {
  var val: uint8 := 192;
  var result: int64 := testUint8ToInt64(val);
  
  PrintStr("val (uint8) = ");
  PrintInt(val as int64);
  PrintStr("\n");
  
  PrintStr("result (int64 from uint8) = ");
  PrintInt(result);
  PrintStr("\n");
  
  return 0;
}
