// Test: uint8 struct field - simpler test

type TTest = struct {
  a: uint8;
  b: uint8;
};

fn main(): int64 {
  var s: TTest;
  s.a := 10;
  s.b := 20;
  
  PrintStr("s.a (after assignment) = ");
  PrintInt(s.a as int64);
  PrintStr("\n");
  
  PrintStr("s.b (after assignment) = ");
  PrintInt(s.b as int64);
  PrintStr("\n");
  
  return 0;
}
