// VMT test with multiple virtual methods and partial override
type Base = class {
  virtual fn Method1(): int64 {
    return 1;
  }
  virtual fn Method2(): int64 {
    return 2;
  }
  virtual fn Method3(): int64 {
    return 3;
  }
};

type Derived = class extends Base {
  override fn Method1(): int64 {
    return 10;
  }
  // Method2 and Method3 are not overridden, so they use Base's implementation
};

fn main(): int64 {
  var b: Base := new Derived();
  
  PrintStr("Method1: ");
  PrintInt(b.Method1()); // expect 10
  PrintStr("\n");
  
  PrintStr("Method2: ");
  PrintInt(b.Method2()); // expect 2 (from base)
  PrintStr("\n");
  
  PrintStr("Method3: ");
  PrintInt(b.Method3()); // expect 3 (from base)
  PrintStr("\n");
  
  dispose b;
  return 0;
}