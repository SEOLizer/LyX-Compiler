// VMT test that prints results
type Base = class {
  virtual fn Foo(): int64 {
    return 0;
  }
};

type Derived = class extends Base {
  override fn Foo(): int64 {
    return 1;
  }
};

fn main(): int64 {
  var b: Base := new Base();
  var d: Derived := new Derived();
  
  PrintStr("Base.Foo(): ");
  PrintInt(b.Foo());
  PrintStr("\n");
  
  PrintStr("Derived.Foo(): ");
  PrintInt(d.Foo());
  PrintStr("\n");
  
  dispose b;
  dispose d;
  
  return 0;
}