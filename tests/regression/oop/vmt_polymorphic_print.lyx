// Polymorphic VMT test: base class pointer to derived object
type Base = class {
  virtual fn Foo(): int64 {
    return 0;
  }
};

type Derived = class extends Base {
  override fn Foo(): int64 {
    return 42;
  }
};

fn main(): int64 {
  var b: Base := new Derived();
  PrintInt(b.Foo()); // should print 42 if VMT works
  dispose b;
  return 0;
}