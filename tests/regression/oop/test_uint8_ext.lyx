// Test to see if extension is happening - use a value that would show sign extension issues

type TTest = struct {
  a: uint8;
};

fn main(): int64 {
  var s: TTest;
  // Use a value that has the high bit set (>= 128) to see if it's treated as signed
  s.a := 200;  // binary 11001000
  
  // Return the value - if zero-extended correctly, should be 200
  // If sign-extended incorrectly (treating as signed int8), would be -56
  return s.a;  
}
