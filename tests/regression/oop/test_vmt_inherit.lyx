// Simple VMT test: inheritance without super call
type TBase = class {
  val: int64;
  
  virtual fn GetValue(): int64 {
    return self.val;
  }
};

type TDerived = class extends TBase {
  extra: int64;
  
  override fn GetValue(): int64 {
    return self.val + self.extra;
  }
};

fn main(): int64 {
  var b: TBase := new TBase();
  b.val := 10;
  var d: TDerived := new TDerived();
  d.val := 20;
  d.extra := 30;
  
  // This should call TDerived.GetValue() via VMT
  PrintStr("d.GetValue(): ");
  PrintInt(d.GetValue());
  PrintStr("\n");
  
  dispose b;
  dispose d;
  
  return 0;
}
