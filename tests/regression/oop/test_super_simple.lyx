// Simple super call test
type TBase = class {
  fn Foo() {
    PrintStr("Base.Foo\n");
  }
};

type TDerived = class extends TBase {
  override fn Foo() {
    super.Foo();
    PrintStr("Derived.Foo\n");
  }
};

fn main(): int64 {
  var d: TDerived := new TDerived();
  d.Foo();
  dispose d;
  return 0;
}
