// test_alloc.lyx - Test für Alloc-Funktionen

import std.alloc;
import std.io;

fn main(): int64 {
  var ptr: int64 := 0;
  var result: int64 := 0;
  
  Printf("Testing Alloc Functions\n");
  Printf("=======================\n\n");
  
  // Test 1: malloc
  Printf("Test 1: malloc\n");
  
  ptr := malloc(1024);
  Printf("  malloc(1024): %d\n", ptr);
  
  if (ptr != 0) {
    Printf("  SUCCESS: Got valid pointer\n");
    free_mem(ptr);
  } else {
    Printf("  FAILED: Out of memory?\n");
  }
  
  Printf("\n");
  
  // Test 2: is_aligned
  Printf("Test 2: is_aligned\n");
  
  ptr := malloc(100);
  if (ptr != 0) {
    var aligned: bool := is_aligned(ptr);
    Printf("  malloc(100) at %d, aligned(8): ", ptr);
    if (aligned) { Printf("true\n"); }
    else { Printf("false\n"); }
    
    free_mem(ptr);
  }
  
  Printf("\n");
  
  // Test 3: size_of
  Printf("Test 3: size_of\n");
  
  var size8: int64 := size_of_int64();
  var size_ptr: int64 := size_of_ptr();
  
  Printf("  size_of_int64: %d\n", size8);
  Printf("  size_of_ptr: %d\n", size_ptr);
  
  Printf("\n");
  
  // Test 4: Pool erstellen
  Printf("Test 4: Pool Allocator\n");
  
  var pool: int64 := createPool(4096);
  Printf("  createPool(4096): %d\n", pool);
  
  if (pool != 0) {
    // Aus Pool allozieren
    var p1: int64 := pool_alloc(pool, 128);
    var p2: int64 := pool_alloc(pool, 256);
    var p3: int64 := pool_alloc(pool, 64);
    
    Printf("  pool_alloc(128): %d\n", p1);
    Printf("  pool_alloc(256): %d\n", p2);
    Printf("  pool_alloc(64): %d\n", p3);
    
    // Pool freigeben
    pool_release(pool);
    Printf("  pool released\n");
  }
  
  Printf("\n");
  
  // Test 5: malloc_safe
  Printf("Test 5: malloc_safe\n");
  
  var safe_ptr: int64 := malloc_safe(0);
  Printf("  malloc_safe(0): %d\n", safe_ptr);
  
  safe_ptr := malloc_safe(1000000000000);  // Sehr groß
  Printf("  malloc_safe(1TB): %d\n", safe_ptr);
  
  if (safe_ptr != 0) {
    free_mem(safe_ptr);
  }
  
  Printf("\n=======================\n");
  Printf("Alloc tests complete!\n");
  
  return 0;
}
