// test_json.lyx - Test für JSON-Funktionen

import std.json;
import std.io;

fn main(): int64 {
  var buf1: pchar := "                                                                                ";
  var buf2: pchar := "                                                                                ";
  var result: int64 := 0;
  
  Printf("Testing JSON Functions\n");
  Printf("======================\n\n");
  
  // Test 1: isValidJSON
  Printf("Test 1: isValidJSON\n");
  
  var valid: bool := isValidJSON("[1,2,3]");
  Printf("  [1,2,3] valid: ");
  if (valid) { Printf("true\n"); }
  else { Printf("false\n"); }
  
  valid := isValidJSON("[]");
  Printf("  [] valid: ");
  if (valid) { Printf("true\n"); }
  else { Printf("false\n"); }
  
  valid := isValidJSON('["a","b"]');
  Printf("  [\"a\",\"b\"] valid: ");
  if (valid) { Printf("true\n"); }
  else { Printf("false\n"); }
  
  valid := isValidJSON("not json");
  Printf("  'not json' valid: ");
  if (valid) { Printf("true\n"); }
  else { Printf("false\n"); }
  
  Printf("\n");
  
  // Test 2: parseArray - einfache Arrays
  Printf("Test 2: parseArray - einfache Arrays\n");
  
  result := parseArray(buf1, "[1,2,3]");
  Printf("  [1,2,3] -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  result := parseArray(buf1, '["a","b","c"]');
  Printf("  [\"a\",\"b\",\"c\"] -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  result := parseArray(buf1, "[true,false,null]");
  Printf("  [true,false,null] -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  Printf("\n");
  
  // Test 3: parseArray - Strings mit Leerzeichen
  Printf("Test 3: parseArray - Strings\n");
  
  result := parseArray(buf1, '["Node1","Node2","Node3"]');
  Printf("  [\"Node1\",\"Node2\",\"Node3\"] -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  result := parseArray(buf1, '["hello world","test","foo"]');
  Printf("  [\"hello world\",\"test\"] -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  Printf("\n");
  
  // Test 4: JSONEscape
  Printf("Test 4: JSONEscape\n");
  
  JSONEscape(buf1, "hello");
  Printf("  \"hello\" -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  JSONEscape(buf1, 'hello "world"');
  Printf("  'hello \"world\"' -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  JSONEscape(buf1, "line1\nline2");
  Printf("  'line1\\nline2' -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  Printf("\n");
  
  // Test 5: serializeArray
  Printf("Test 5: serializeArray\n");
  
  serializeArray(buf1, "a|b|c");
  Printf("  a|b|c -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  serializeArray(buf1, "1|2|3");
  Printf("  1|2|3 -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  serializeArray(buf1, "hello|world");
  Printf("  hello|world -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  Printf("\n");
  
  // Test 6: Roundtrip
  Printf("Test 6: Roundtrip\n");
  
  // Parse -> Serialize
  result := parseArray(buf1, "[1,2,3]");
  Printf("  Parse [1,2,3]: ");
  if (result == 0) { Printf("OK\n"); }
  else { Printf("Error %d\n", result); }
  
  serializeArray(buf2, buf1);
  Printf("  Serialize: ");
  PrintStr(buf2);
  PrintStr("\n");
  
  Printf("\n");
  
  // Test 7: API-Wrapper
  Printf("Test 7: API Wrapper\n");
  
  toArray(buf1, '["Node1","Node2","Node3"]');
  Printf("  JSON.toArray: ");
  PrintStr(buf1);
  PrintStr("\n");
  
  stringify(buf1, "Status|200|OK");
  Printf("  JSON.stringify: ");
  PrintStr(buf1);
  PrintStr("\n");
  
  Printf("\n======================\n");
  Printf("JSON tests complete!\n");
  
  return 0;
}
