// test_process.lyx - Test für Process-Funktionen

import std.process;
import std.io;

fn main(): int64 {
  Printf("Testing Process Functions\n");
  Printf("==========================\n\n");
  
  // Test 1: Process.run() - synchron
  Printf("Test 1: Process.run() - synchron\n");
  var exit_code: int64 := run("/bin/echo");
  Printf("  /bin/echo exit code: %d\n", exit_code);
  
  // Test 2: Process.shell() 
  Printf("\nTest 2: Process.shell()\n");
  exit_code := shell("echo 'Hello from shell'");
  Printf("  shell echo exit code: %d\n", exit_code);
  
  // Test 3: Process.spawn() + wait() - asynchron
  Printf("\nTest 3: Process.spawn() + wait()\n");
  var pid: int64 := spawn("/bin/echo");
  Printf("  Spawned echo with pid: %d\n", pid);
  
  if (pid > 0) {
    exit_code := wait(pid);
    Printf("  Wait completed, exit code: %d\n", exit_code);
  }
  
  // Test 4: is_running
  Printf("\nTest 4: Process.is_running()\n");
  pid := spawn("/bin/sleep");
  Printf("  Spawned sleep with pid: %d\n", pid);
  
  if (pid > 0) {
    var running: bool := is_running(pid);
    Printf("  Before wait - is_running: ");
    if (running) { Printf("true\n"); }
    else { Printf("false\n"); }
    
    exit_code := wait(pid);
    Printf("  After wait - exit code: %d\n", exit_code);
    
    running := is_running(pid);
    Printf("  After wait - is_running: ");
    if (running) { Printf("true\n"); }
    else { Printf("false\n"); }
  }
  
  // Test 5: getpid
  Printf("\nTest 5: Process.self_pid()\n");
  var my_pid: int64 := self_pid();
  Printf("  Current process PID: %d\n", my_pid);
  
  // Test 6: Shell-Befehl mit exit code
  Printf("\nTest 6: Shell exit codes\n");
  exit_code := shell("exit 0");
  Printf("  shell 'exit 0': %d\n", exit_code);
  
  exit_code := shell("exit 1");
  Printf("  shell 'exit 1': %d\n", exit_code);
  
  exit_code := shell("exit 42");
  Printf("  shell 'exit 42': %d\n", exit_code);
  
  Printf("\n==========================\n");
  Printf("Process tests complete!\n");
  
  return 0;
}
