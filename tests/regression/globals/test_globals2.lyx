var counter: int64 := 0;
var total: int64 := 100;

fn add(val: int64) {
  counter := counter + val;
  total := total + val;
}

fn main(): int64 {
  PrintStr("Initial:\n");
  PrintStr("  counter = ");
  PrintInt(counter);
  PrintStr("\n");
  PrintStr("  total = ");
  PrintInt(total);
  PrintStr("\n");
  
  add(10);
  add(20);
  add(5);
  
  PrintStr("After adds:\n");
  PrintStr("  counter = ");
  PrintInt(counter);
  PrintStr("\n");
  PrintStr("  total = ");
  PrintInt(total);
  PrintStr("\n");
  
  return 0;
}
