// Test Pandas-Complete Features
// Sort, Head/Tail, Concat, Replace, Rank, Shift, CumSum, Duplicates

import data.core;

fn main(): int64 {
  PrintStr("Testing Pandas-Complete Features...\n");
  
  // Create test data
  var df: DataFrame := DataFrameNew();
  DataFrameAddColumn(df, "name", COL_STRING);
  DataFrameAddColumn(df, "score", COL_INT64);
  DataFrameAddColumn(df, "city", COL_INT64);
  
  DataFrameAppendRow(df); DataFrameSetString(df, "name", 0, "Alice"); DataFrameSetInt(df, "score", 0, 85); DataFrameSetInt(df, "city", 0, 1);
  DataFrameAppendRow(df); DataFrameSetString(df, "name", 1, "Bob"); DataFrameSetInt(df, "score", 1, 92); DataFrameSetInt(df, "city", 1, 2);
  DataFrameAppendRow(df); DataFrameSetString(df, "name", 2, "Charlie"); DataFrameSetInt(df, "score", 2, 78); DataFrameSetInt(df, "city", 2, 1);
  DataFrameAppendRow(df); DataFrameSetString(df, "name", 3, "Diana"); DataFrameSetInt(df, "score", 3, 95); DataFrameSetInt(df, "city", 3, 3);
  DataFrameAppendRow(df); DataFrameSetString(df, "name", 4, "Eve"); DataFrameSetInt(df, "score", 4, 85); DataFrameSetInt(df, "city", 4, 2);
  
  PrintStr("Original:\n");
  DataFramePrint(df);
  
  // Test 1: Sort
  PrintStr("\nTest 1: SortBy score (ascending)\n");
  var sorted: DataFrame := DataFrameSortBy(df, "score");
  DataFramePrint(sorted);
  
  // Test 2: Head/Tail
  PrintStr("\nTest 2: Head(3) and Tail(2)\n");
  var head: DataFrame := DataFrameHead(df, 3);
  PrintStr("Head(3):\n");
  DataFramePrint(head);
  
  var tail: DataFrame := DataFrameTail(df, 2);
  PrintStr("Tail(2):\n");
  DataFramePrint(tail);
  
  // Test 3: Shape/Info
  PrintStr("\nTest 3: Shape and Info\n");
  PrintStr("  Shape: ");
  DataFrameShape(df);
  PrintStr("\n");
  DataFrameInfo(df);
  
  // Test 4: Concat
  PrintStr("\nTest 4: Concat\n");
  var df2: DataFrame := DataFrameNew();
  DataFrameAddColumn(df2, "name", COL_STRING);
  DataFrameAddColumn(df2, "score", COL_INT64);
  DataFrameAddColumn(df2, "city", COL_INT64);
  DataFrameAppendRow(df2); DataFrameSetString(df2, "name", 0, "Frank"); DataFrameSetInt(df2, "score", 0, 88); DataFrameSetInt(df2, "city", 0, 1);
  
  var concatenated: DataFrame := DataFrameConcat(df, df2);
  PrintStr("After concat:\n");
  DataFramePrint(concatenated);
  
  // Test 5: Replace
  PrintStr("\nTest 5: Replace city=1 -> 10\n");
  DataFrameReplace(df, "city", 1, 10);
  DataFramePrint(df);
  
  // Test 6: Clip
  PrintStr("\nTest 6: Clip score to [80, 90]\n");
  DataFrameClip(df, "score", 80, 90);
  DataFramePrint(df);
  
  // Test 7: Rank
  PrintStr("\nTest 7: Rank\n");
  var s: Series := DataFrameGetSeries(df, "score");
  var ranked: Series := SeriesRank(s);
  PrintStr("  Scores ranked: ");
  var i: int64 := 0;
  while (i < ranked.length) {
    PrintInt(SeriesGetInt(ranked, i));
    if (i < ranked.length - 1) { PrintStr(","); }
    i := i + 1;
  end;
  PrintStr("\n");
  
  // Test 8: CumSum
  PrintStr("\nTest 8: CumSum\n");
  var cumSum: Series := SeriesCumSum(s);
  PrintStr("  CumSum: ");
  i := 0;
  while (i < cumSum.length) {
    PrintInt(SeriesGetInt(cumSum, i));
    if (i < cumSum.length - 1) { PrintStr(","); }
    i := i + 1;
  end;
  PrintStr("\n");
  
  // Test 9: Diff
  PrintStr("\nTest 9: Diff\n");
  var diff: Series := SeriesDiff(s);
  PrintStr("  Diff: ");
  i := 0;
  while (i < diff.length) {
    PrintInt(SeriesGetInt(diff, i));
    if (i < diff.length - 1) { PrintStr(","); }
    i := i + 1;
  end;
  PrintStr("\n");
  
  // Test 10: Shift
  PrintStr("\nTest 10: Shift(1)\n");
  var shifted: Series := SeriesShift(s, 1);
  PrintStr("  Shifted: ");
  i := 0;
  while (i < shifted.length) {
    PrintInt(SeriesGetInt(shifted, i));
    if (i < shifted.length - 1) { PrintStr(","); }
    i := i + 1;
  end;
  PrintStr("\n");
  
  // Test 11: DropDuplicates
  PrintStr("\nTest 11: DropDuplicates on score\n");
  var unique: DataFrame := DataFrameDropDuplicates(df, "score");
  DataFramePrint(unique);
  
  // Test 12: Map
  PrintStr("\nTest 12: MapMul score * 10\n");
  DataFrameMapMul(df, "score", 10);
  DataFramePrint(df);
  
  PrintStr("\nAll Pandas-Complete tests completed!\n");
  return 0;
}
