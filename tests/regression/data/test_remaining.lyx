// Test Remaining Pandas Features
// String Ops, CorrMatrix, GetDummies, Right/Outer Join, Normalize, Datetime, Sample, Cut, MultiIndex

import data.core;

fn main(): int64 {
  PrintStr("Testing Remaining Pandas Features...\n");
  
  // Test 1: String Operations
  PrintStr("Test 1: String Operations\n");
  PrintStr("  Upper: ");
  var s: int64 := StrToUpper("hello world");
  sys_write(1, s, 20);
  PrintStr("\n");
  PrintStr("  Lower: ");
  s := StrToLower("HELLO WORLD");
  sys_write(1, s, 20);
  PrintStr("\n");
  PrintStr("  Trim: '");
  s := StrTrim("  hello  ");
  sys_write(1, s, 20);
  PrintStr("'\n");
  PrintStr("  Contains 'world': ");
  if (StrContains("hello world", "world") == 1) { PrintStr("true") } else { PrintStr("false") }
  PrintStr("\n");
  PrintStr("  StartsWith 'hello': ");
  if (StrStartsWith("hello world", "hello") == 1) { PrintStr("true") } else { PrintStr("false") }
  PrintStr("\n");
  
  // Test 2: CorrMatrix
  PrintStr("\nTest 2: Correlation Matrix\n");
  var df: DataFrame := DataFrameNew();
  DataFrameAddColumn(df, "a", COL_INT64);
  DataFrameAddColumn(df, "b", COL_INT64);
  DataFrameAddColumn(df, "c", COL_INT64);
  DataFrameAppendRow(df); DataFrameSetInt(df, "a", 0, 1); DataFrameSetInt(df, "b", 0, 2); DataFrameSetInt(df, "c", 0, 3);
  DataFrameAppendRow(df); DataFrameSetInt(df, "a", 1, 2); DataFrameSetInt(df, "b", 1, 4); DataFrameSetInt(df, "c", 1, 5);
  DataFrameAppendRow(df); DataFrameSetInt(df, "a", 2, 3); DataFrameSetInt(df, "b", 2, 6); DataFrameSetInt(df, "c", 2, 7);
  var corr: DataFrame := DataFrameCorrMatrix(df);
  DataFramePrint(corr);
  
  // Test 3: GetDummies
  PrintStr("\nTest 3: One-Hot Encoding (GetDummies)\n");
  var df2: DataFrame := DataFrameNew();
  DataFrameAddColumn(df2, "color", COL_INT64);
  DataFrameAppendRow(df2); DataFrameSetInt(df2, "color", 0, 1);
  DataFrameAppendRow(df2); DataFrameSetInt(df2, "color", 1, 2);
  DataFrameAppendRow(df2); DataFrameSetInt(df2, "color", 2, 1);
  DataFrameAppendRow(df2); DataFrameSetInt(df2, "color", 3, 3);
  var dummies: DataFrame := DataFrameGetDummies(df2, "color");
  DataFramePrint(dummies);
  
  // Test 4: Outer Join
  PrintStr("\nTest 4: Outer Join\n");
  var left: DataFrame := DataFrameNew();
  DataFrameAddColumn(left, "id", COL_INT64);
  DataFrameAddColumn(left, "name", COL_STRING);
  DataFrameAppendRow(left); DataFrameSetInt(left, "id", 0, 1); DataFrameSetString(left, "name", 0, "Alice");
  DataFrameAppendRow(left); DataFrameSetInt(left, "id", 1, 2); DataFrameSetString(left, "name", 1, "Bob");
  
  var right: DataFrame := DataFrameNew();
  DataFrameAddColumn(right, "id", COL_INT64);
  DataFrameAddColumn(right, "score", COL_INT64);
  DataFrameAppendRow(right); DataFrameSetInt(right, "id", 0, 2); DataFrameSetInt(right, "score", 0, 95);
  DataFrameAppendRow(right); DataFrameSetInt(right, "id", 1, 3); DataFrameSetInt(right, "score", 1, 87);
  
  var outer: DataFrame := DataFrameJoinOuter(left, "id", right, "id");
  DataFramePrint(outer);
  
  // Test 5: Normalize
  PrintStr("\nTest 5: Normalize (Min-Max)\n");
  var s2: Series := DataFrameGetSeries(df, "a");
  var norm: Series := SeriesNormalizeMinMax(s2);
  PrintStr("  Normalized: ");
  var i: int64 := 0;
  while (i < norm.length) {
    PrintInt(SeriesGetInt(norm, i));
    if (i < norm.length - 1) { PrintStr(","); }
    i := i + 1;
  end;
  PrintStr("\n");
  
  // Test 6: Datetime
  PrintStr("\nTest 6: DateTime\n");
  var dt: DateTime := UnixToDateTime(1710000000);
  PrintStr("  Year: "); PrintInt(dt.year);
  PrintStr("  Month: "); PrintInt(dt.month);
  PrintStr("  Day: "); PrintInt(dt.day);
  PrintStr("  Hour: "); PrintInt(dt.hour);
  PrintStr("\n");
  
  // Test 7: Sample
  PrintStr("\nTest 7: Sample (50%)\n");
  var sampled: DataFrame := DataFrameSample(df, 50);
  DataFramePrint(sampled);
  
  // Test 8: Cut
  PrintStr("\nTest 8: Cut (3 bins)\n");
  var binned: Series := SeriesCut(s2, 3);
  PrintStr("  Binned: ");
  i := 0;
  while (i < binned.length) {
    PrintInt(SeriesGetInt(binned, i));
    if (i < binned.length - 1) { PrintStr(","); }
    i := i + 1;
  end;
  PrintStr("\n");
  
  // Test 9: MultiIndex
  PrintStr("\nTest 9: MultiIndex\n");
  DataFrameSetMultiIndex(df, "a", "b");
  PrintStr("  Multi-index set (a_b): ");
  i := 0;
  while (i < df.rowCount) {
    var label: int64 := DataFrameGetIndexLabel(df, i);
    if (label != 0) { sys_write(1, label, 10); }
    if (i < df.rowCount - 1) { PrintStr(", "); }
    i := i + 1;
  end;
  PrintStr("\n");
  
  // Test 10: Interpolate
  PrintStr("\nTest 10: Interpolate\n");
  var s3: Series := SeriesNewInt64("test", 5);
  s3.length := 5;
  SeriesSetInt(s3, 0, 10);
  SeriesSetInt(s3, 1, 0);  // NA
  SeriesSetInt(s3, 2, 0);  // NA
  SeriesSetInt(s3, 3, 0);  // NA
  SeriesSetInt(s3, 4, 30);
  var interp: Series := SeriesInterpolate(s3);
  PrintStr("  Interpolated: ");
  i := 0;
  while (i < interp.length) {
    PrintInt(SeriesGetInt(interp, i));
    if (i < interp.length - 1) { PrintStr(","); }
    i := i + 1;
  end;
  PrintStr(" (expected: 10,15,20,25,30)\n");
  
  PrintStr("\nAll remaining tests completed!\n");
  return 0;
}
