// Test Data Library
// Demonstrates DataFrame, Series, CSV I/O, and GroupBy

import data.core;

fn main(): int64 {
  PrintStr("Testing Data Library...\n");
  
  // Test 1: Create DataFrame
  PrintStr("Test 1: Create DataFrame\n");
  var df: DataFrame := DataFrameNew();
  DataFrameAddColumn(df, "name", COL_STRING);
  DataFrameAddColumn(df, "age", COL_INT64);
  DataFrameAddColumn(df, "city", COL_STRING);
  
  // Add rows
  DataFrameAppendRow(df);
  DataFrameSetString(df, "name", 0, "Alice");
  DataFrameSetInt(df, "age", 0, 25);
  DataFrameSetString(df, "city", 0, "Berlin");
  
  DataFrameAppendRow(df);
  DataFrameSetString(df, "name", 1, "Bob");
  DataFrameSetInt(df, "age", 1, 30);
  DataFrameSetString(df, "city", 1, "Munich");
  
  DataFrameAppendRow(df);
  DataFrameSetString(df, "name", 2, "Charlie");
  DataFrameSetInt(df, "age", 2, 25);
  DataFrameSetString(df, "city", 2, "Berlin");
  
  DataFrameAppendRow(df);
  DataFrameSetString(df, "name", 3, "Diana");
  DataFrameSetInt(df, "age", 3, 35);
  DataFrameSetString(df, "city", 3, "Hamburg");
  
  DataFramePrint(df);
  
  // Test 2: Filter
  PrintStr("\nTest 2: Filter (age > 25)\n");
  var filtered: DataFrame := DataFrameFilter(df, "age", OP_GT, 25);
  DataFramePrint(filtered);
  
  // Test 3: Slice
  PrintStr("\nTest 3: Slice (rows 1-2)\n");
  var sliced: DataFrame := DataFrameSlice(df, 1, 3);
  DataFramePrint(sliced);
  
  // Test 4: Column Statistics
  PrintStr("\nTest 4: Column Statistics (age)\n");
  var ageSeries: Series := DataFrameGetSeries(df, "age");
  PrintStr("  Sum: ");
  PrintInt(SeriesSum(ageSeries));
  PrintStr("\n");
  
  PrintStr("  Mean: ");
  PrintInt(SeriesMean(ageSeries));
  PrintStr("\n");
  
  PrintStr("  Min: ");
  PrintInt(SeriesMin(ageSeries));
  PrintStr("\n");
  
  PrintStr("  Max: ");
  PrintInt(SeriesMax(ageSeries));
  PrintStr("\n");
  
  PrintStr("  Count: ");
  PrintInt(SeriesCount(ageSeries));
  PrintStr("\n");
  
  // Test 5: Value Counts
  PrintStr("\nTest 5: Value Counts (age)\n");
  var counts: DataFrame := SeriesValueCounts(ageSeries);
  DataFramePrint(counts);
  
  // Test 6: GroupBy + Sum
  PrintStr("\nTest 6: GroupBy city -> Sum(age)\n");
  var gb: GroupByResult := DataFrameGroupBy(df, "city");
  var grouped: DataFrame := GroupBySum(gb, "age");
  DataFramePrint(grouped);
  
  // Test 7: Drop Column
  PrintStr("\nTest 7: Drop 'city' column\n");
  DataFrameDropColumn(df, "city");
  DataFramePrint(df);
  
  // Test 8: Fill NA
  PrintStr("\nTest 8: DataFrame with NA values\n");
  var df2: DataFrame := DataFrameNew();
  DataFrameAddColumn(df2, "x", COL_INT64);
  DataFrameAddColumn(df2, "y", COL_INT64);
  
  DataFrameAppendRow(df2);
  DataFrameSetInt(df2, "x", 0, 10);
  DataFrameSetInt(df2, "y", 0, 20);
  
  DataFrameAppendRow(df2);
  DataFrameSetInt(df2, "x", 1, 0);  // NA
  DataFrameSetInt(df2, "y", 1, 30);
  
  DataFrameAppendRow(df2);
  DataFrameSetInt(df2, "x", 2, 40);
  DataFrameSetInt(df2, "y", 2, 0);  // NA
  
  DataFramePrint(df2);
  
  DataFrameFillNA(df2, "x", -1);
  PrintStr("After FillNA(x, -1):\n");
  DataFramePrint(df2);
  
  PrintStr("\nAll tests completed!\n");
  return 0;
}
