// Energy-Aware-Compiling Integration Tests

fn test_arith(): int64 {
  var a: int64 := 10;
  var b: int64 := 20;
  var c: int64 := a + b;
  return c;
}

fn test_loop(): int64 {
  var i: int64 := 0;
  var sum: int64 := 0;
  while i < 10 {
    sum := sum + i;
    i := i + 1;
  }
  return sum;
}

fn test_memory(): int64 {
  var arr: int64[5];
  arr[0] := 1;
  arr[1] := 2;
  arr[2] := 3;
  arr[3] := 4;
  arr[4] := 5;
  return arr[0] + arr[4];
}

fn main(): int64 {
  var result: int64 := 0;
  
  result := test_arith();
  result := result + test_loop();
  result := result + test_memory();
  
  PrintStr("Result: ");
  PrintInt(result);
  PrintStr("\n");
  
  // Expected: 30 (10+20) + 45 (0+1+2+...+9) + 6 (1+5) = 81
  return 0;
}
