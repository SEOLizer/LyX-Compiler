// WP-10h-2: Test String Builtins S0 für ARM64
// Testet: StrLen, StrCharAt, StrSetChar, StrNew, StrFree, StrAppend, StrFromInt, str_concat, PrintLn
// Kompilieren: ./lyxc tests/lyx/arm64/test_str_builtins.lyx --target=arm64 -o /tmp/test_arm64_strings
// Ausfuehren:  qemu-aarch64-static /tmp/test_arm64_strings

fn main(): int64 {
  // Test 1: StrLen
  let s: pchar = "Hello";
  let n: int64 = StrLen(s);
  // n sollte 5 sein
  PrintInt(n);  // → 5
  PrintStr("\n");

  // Test 2: StrCharAt
  let c: int64 = StrCharAt(s, 0);  // 'H' = 72
  PrintInt(c);
  PrintStr("\n");

  // Test 3: StrNew + StrSetChar + StrFree
  let buf: pchar = StrNew(16);
  StrSetChar(buf, 0, 65);   // 'A'
  StrSetChar(buf, 1, 66);   // 'B'
  StrSetChar(buf, 2, 67);   // 'C'
  StrSetChar(buf, 3, 10);   // '\n'
  StrSetChar(buf, 4, 0);    // null-terminator
  PrintStr(buf);             // → ABC\n

  // Test 4: StrFromInt
  let si: pchar = StrFromInt(12345);
  PrintLn(si);               // → 12345

  let si2: pchar = StrFromInt(-99);
  PrintLn(si2);              // → -99

  // Test 5: str_concat
  let hello: pchar = "Hello, ";
  let world: pchar = "Lyx!";
  let hw: pchar = hello + world;
  PrintLn(hw);               // → Hello, Lyx!

  // Test 6: StrAppend
  let a: pchar = StrNew(32);
  StrSetChar(a, 0, 70);      // 'F'
  StrSetChar(a, 1, 111);     // 'o'
  StrSetChar(a, 2, 111);     // 'o'
  StrSetChar(a, 3, 0);       // null
  // Store length in header (offset -8 from data ptr):
  // For StrAppend to work, dest needs a proper StrNew header
  // We use StrAppend to append to empty-looking string:
  // Actually StrAppend reads *(dest-8) as destLen — but StrNew sets length=0 initially
  let a2: pchar = StrAppend(a, "Bar");
  PrintLn(a2);               // → Bar (since StrNew length=0, only src appended)

  StrFree(si);
  StrFree(si2);
  StrFree(hw);
  StrFree(a2);

  return 0;
}
