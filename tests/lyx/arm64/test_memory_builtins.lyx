// WP-10h-1: Test mmap, poke/peek, munmap, write_raw, buf_put_byte, buf_get_byte
// Kompilieren: ./lyxc tests/lyx/arm64/test_memory_builtins.lyx --target=arm64 -o /tmp/test_arm64_mem
// Ausfuehren:  qemu-aarch64 /tmp/test_arm64_mem  (oder nativ auf ARM64)

fn main(): int64 {
  // === Test 1: mmap + poke8 + peek8 + munmap ===
  // Allokiere 4096 Bytes mit mmap (anonym, PROT_READ|PROT_WRITE, MAP_PRIVATE|MAP_ANONYMOUS)
  let buf: int64 = mmap(0, 4096, 3, 34, -1, 0);

  // Schreibe Bytes via poke8
  poke8(buf, 0x41);        // 'A'
  poke8(buf + 1, 0x42);   // 'B'
  poke8(buf + 2, 0x43);   // 'C'
  poke8(buf + 3, 0x0A);   // '\n'

  // Lese zurueck und pruefe via peek8
  let a: int64 = peek8(buf);
  let b: int64 = peek8(buf + 1);
  let c: int64 = peek8(buf + 2);

  // Ausgabe: "ABC" via write_raw
  write_raw(1, buf, 4);

  // === Test 2: poke16 / peek16 ===
  poke16(buf + 8, 0x4445);  // 'DE' als 16-bit
  let de: int64 = peek16(buf + 8);
  // de sollte 0x4445 = 17477 sein

  // === Test 3: poke32 / peek32 ===
  poke32(buf + 16, 12345678);
  let val32: int64 = peek32(buf + 16);

  // === Test 4: poke64 / peek64 ===
  poke64(buf + 24, 9876543210987654321);
  let val64: int64 = peek64(buf + 24);

  // === Test 5: buf_put_byte / buf_get_byte ===
  buf_put_byte(buf, 32, 0x58);  // 'X' at offset 32
  buf_put_byte(buf, 33, 0x59);  // 'Y' at offset 33
  buf_put_byte(buf, 34, 0x5A);  // 'Z' at offset 34
  buf_put_byte(buf, 35, 0x0A);  // '\n' at offset 35

  let x: int64 = buf_get_byte(buf, 32);
  let y: int64 = buf_get_byte(buf, 33);
  let z: int64 = buf_get_byte(buf, 34);

  // Ausgabe "XYZ\n"
  write_raw(1, buf + 32, 4);

  // Freigabe
  munmap(buf, 4096);

  return 0;
}
