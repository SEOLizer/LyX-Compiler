fn classify(n: int64): int64 {
    match n {
        case 0 => {
            PrintStr("zero\n");
        }
        case 1 | 2 | 3 => {
            PrintStr("small\n");
        }
        case 10 | 20 | 30 => {
            PrintStr("tens\n");
        }
        default => {
            PrintStr("other\n");
        }
    }
    return 0;
}

fn main(): int64 {
    classify(0);
    classify(1);
    classify(2);
    classify(3);
    classify(5);
    classify(10);
    classify(20);
    classify(99);
    return 0;
}
