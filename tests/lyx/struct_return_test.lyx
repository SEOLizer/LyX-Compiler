// tests/lyx/struct_return_test.lyx
// Test: Struct als Rueckgabewert einer Funktion

type TPoint = struct {
  x: int64;
  y: int64;
};

fn makePoint(px: int64, py: int64): TPoint {
  var p: TPoint := TPoint { x: px, y: py };
  return p;
}

fn main(): int64 {
  // Test 1: Funktion aufrufen, Ergebnis speichern
  var p: TPoint := makePoint(42, 100);
  
  // Test 2: Feld vom gespeicherten Ergebnis lesen
  var xVal: int64 := p.x;
  var yVal: int64 := p.y;
  
  PrintStr("x = ");
  PrintInt(xVal);
  PrintStr("\ny = ");
  PrintInt(yVal);
  PrintStr("\n");
  
  return 0;
}
