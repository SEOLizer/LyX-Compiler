// Test: Play any WAV file via ALSA (reads sample rate from header)
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
   var wavPath: pchar := "/tmp/playback_30s.wav";
   PrintStr("=== ALSA Play WAV File ===\n");
   PrintStr("File: ");
   PrintStr(wavPath);
   PrintStr("\n");

   // Read WAV header to get actual sample rate / channels / bits
   var fd: int64;
   fd := open(wavPath, 0, 0);
   if (fd < 0) {
     PrintStr("ERROR: Cannot open file\n");
     return 1;
   }

   // WAV header offsets (little-endian):
   //   22: channels (uint16)
   //   24: sample rate (uint32)
   //   34: bits per sample (uint16)
   //   40: data chunk size (uint32)

   var hdr: int64;
   hdr := mmap(0, 44, 3, 34, -1, 0);
   sys_read(fd, hdr, 44);

   var channels: int64;
   channels := peek8(hdr + 22) | (peek8(hdr + 23) << 8);
   var sampleRate: int64;
   sampleRate := peek8(hdr + 24) | (peek8(hdr + 25) << 8) | (peek8(hdr + 26) << 16) | (peek8(hdr + 27) << 24);
   var bitsPerSample: int64;
   bitsPerSample := peek8(hdr + 34) | (peek8(hdr + 35) << 8);
   var dataSize: int64;
   dataSize := peek8(hdr + 40) | (peek8(hdr + 41) << 8) | (peek8(hdr + 42) << 16) | (peek8(hdr + 43) << 24);
   munmap(hdr, 44);

   PrintStr("WAV Header:\n");
   PrintStr("  Sample Rate: "); PrintInt(sampleRate); PrintStr(" Hz\n");
   PrintStr("  Channels:    "); PrintInt(channels); PrintStr("\n");
   PrintStr("  Bits:        "); PrintInt(bitsPerSample); PrintStr("\n");
   PrintStr("  Data size:   "); PrintInt(dataSize); PrintStr(" bytes\n");
   PrintStr("  Duration:    "); PrintInt(dataSize / (sampleRate * channels * (bitsPerSample / 8))); PrintStr(" sec\n");

   // Read PCM data
   lseek(fd, 44, SEEK_SET);
   var playBuf: int64;
   playBuf := mmap(0, dataSize, 3, 34, -1, 0);
   var bytesRead: int64;
   bytesRead := sys_read(fd, playBuf, dataSize);
   close(fd);

   PrintStr("Read: "); PrintInt(bytesRead); PrintStr(" bytes\n");

   // Open ALSA
   var hp: int64;
   hp := mmap(0, 8, 3, 34, -1, 0);
   var res: int64;
   res := snd_pcm_open(hp, "hw:0", 0, 0);
   if (res != 0) {
     PrintStr("ERROR: Cannot open ALSA\n");
     munmap(playBuf, dataSize);
     return 1;
   }
   var alsaHandle: int64;
   alsaHandle := peek64(hp);
   munmap(hp, 8);

   // Set params
   var pp: int64;
   pp := mmap(0, 8, 3, 34, -1, 0);
   snd_pcm_hw_params_malloc(pp);
   var params: int64;
   params := peek64(pp);

   snd_pcm_hw_params_any(alsaHandle, params);
   snd_pcm_hw_params_set_access(alsaHandle, params, 3);        // RW_INTERLEAVED
   snd_pcm_hw_params_set_format(alsaHandle, params, 2);        // S16_LE

   var periodSize: int64 := 6000; // 6000 frames
   var bufferSize: int64 := 24000; // 4 periods

   // Note: snd_pcm_hw_params_set_period_size_near not available in current interface
   // Using default buffer settings

   var ratePtr: int64;
   ratePtr := mmap(0, 8, 3, 34, -1, 0);
   poke32(ratePtr, sampleRate);
   snd_pcm_hw_params_set_rate_near(alsaHandle, params, ratePtr, 0);
   var alsaRate: int64;
   alsaRate := peek32(ratePtr);
   munmap(ratePtr, 8);
   PrintStr("ALSA rate: "); PrintInt(alsaRate); PrintStr(" Hz\n");

   snd_pcm_hw_params_set_channels(alsaHandle, params, channels);
   res := snd_pcm_hw_params(alsaHandle, params);
   if (res != 0) {
     PrintStr("ERROR: Cannot set ALSA params\n");
     snd_pcm_close(alsaHandle);
     snd_pcm_hw_params_free(params);
     munmap(pp, 8);
     munmap(playBuf, dataSize);
     return 1;
   }
   snd_pcm_hw_params_free(params);
   munmap(pp, 8);

   // Play
   var bytesPerFrame: int64 := channels * (bitsPerSample / 8);
   var frames: int64 := bytesRead / bytesPerFrame;
   PrintStr("Playing "); PrintInt(frames); PrintStr(" frames...\n");

   res := snd_pcm_writei(alsaHandle, playBuf, frames);
   PrintStr("Written: "); PrintInt(res); PrintStr(" frames\n");

   snd_pcm_drain(alsaHandle);
   snd_pcm_close(alsaHandle);
   munmap(playBuf, dataSize);

   PrintStr("=== Done ===\n");
   return 0;
}