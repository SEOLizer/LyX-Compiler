// Test struct with local vars
import std.audio;

pub fn main(): int64 {
  var info: AudioInfo;
  
  // First, set local vars
  var fmt: int64;
  var sr: int64;
  var ch: int64;
  var bps: int64;
  var doff: int64;
  var dsz: int64;
  var dur: int64;
  
  fmt := 10;
  sr := 44100;
  ch := 2;
  bps := 16;
  doff := 100;
  dsz := 200;
  dur := 300;
  
  // Now copy to struct
  info.format := fmt;
  info.sampleRate := sr;
  info.channels := ch;
  info.bitsPerSample := bps;
  info.dataOffset := doff;
  info.dataSize := dsz;
  info.durationMs := dur;
  
  // Read back
  PrintStr("format: ");
  PrintInt(info.format);
  PrintStr("\n");
  PrintStr("sampleRate: ");
  PrintInt(info.sampleRate);
  PrintStr("\n");
  PrintStr("channels: ");
  PrintInt(info.channels);
  PrintStr("\n");
  
  return 0;
}
