// Test: Minimal file write
import std.audio;

pub fn main(): int64 {
  PrintStr("=== Minimal Write Test ===\n");
  
  // Open file
  var fd: int64;
  fd := open("/tmp/minimal_test.bin", O_WRONLY | O_CREAT | O_TRUNC, 420);
  
  PrintStr("fd = ");
  PrintInt(fd);
  PrintStr("\n");
  
  if (fd < 0) {
    PrintStr("open failed\n");
    return 1;
  }
  
  // Write simple byte
  var buf: int64;
  buf := mmap(0, 10, 3, 34, -1, 0);
  
  poke8(buf, 65);  // 'A'
  poke8(buf + 1, 66);  // 'B'
  poke8(buf + 2, 67);  // 'C'
  
  var written: int64;
  written := write(fd, buf, 3);
  
  PrintStr("written = ");
  PrintInt(written);
  PrintStr("\n");
  
  close(fd);
  munmap(buf, 10);
  
  PrintStr("=== Done ===\n");
  return 0;
}
