// Direct file read test
pub fn main() {
  var fd: int64;
  var buf: int64;
  var size: int64;
  
  fd := open("test.wav", 0, 0);
  
  size := lseek(fd, 0, 2);
  lseek(fd, 0, 0);
  
  // mmap file directly
  buf := mmap(0, size, 1, 34, fd, 0);
  close(fd);
  
  PrintInt(size);
  PrintStr("\n");
  PrintInt(buf);
  PrintStr("\n");
  
  if (buf != 0 && size > 0) {
    // Print first bytes using buffer+offset syntax
    PrintInt(peek8(buf + 0));
    PrintStr(" ");
    PrintInt(peek8(buf + 1));
    PrintStr(" ");
    PrintInt(peek8(buf + 2));
    PrintStr(" ");
    PrintInt(peek8(buf + 3));
    PrintStr(" ");
    PrintInt(peek8(buf + 4));
    PrintStr("\n");
    
    PrintInt(peek8(buf + 8));
    PrintStr(" ");
    PrintInt(peek8(buf + 9));
    PrintStr(" ");
    PrintInt(peek8(buf + 10));
    PrintStr(" ");
    PrintInt(peek8(buf + 11));
    PrintStr("\n");
  }
  
  munmap(buf, size);
}