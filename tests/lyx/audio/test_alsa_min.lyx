// Test: Minimal ALSA open
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== Minimal ALSA Test ===\n");
  
  var handlePtr: int64;
  handlePtr := mmap(0, 8, 3, 34, -1, 0);
  
  PrintStr("handlePtr = ");
  PrintInt(handlePtr);
  PrintStr("\n");
  
  if (handlePtr == 0) {
    PrintStr("ERROR: mmap failed\n");
    return 1;
  }
  
  PrintStr("Calling snd_pcm_open...\n");
  
  var result: int64;
  result := snd_pcm_open(handlePtr, "default", SND_PCM_STREAM_PLAYBACK, 0);
  
  PrintStr("result = ");
  PrintInt(result);
  PrintStr("\n");
  
  if (result != ALSA_OK) {
    PrintStr("ERROR: open failed\n");
    munmap(handlePtr, 8);
    return 1;
  }
  
  PrintStr("Success!\n");
  
  var handle: int64;
  handle := peek64(handlePtr);
  PrintStr("handle = ");
  PrintInt(handle);
  PrintStr("\n");
  
  // Try to close
  if (handle != 0) {
    snd_pcm_close(handle);
  }
  
  munmap(handlePtr, 8);
  
  PrintStr("=== Done ===\n");
  return 0;
}
