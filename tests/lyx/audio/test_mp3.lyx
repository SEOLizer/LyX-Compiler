// Test MP3 Parser
import std.audio;

pub fn main(): int64 {
  var info: AudioInfo;
  var result: int64;
  
  result := MP3Parse("/home/andreas/PhpstormProjects/aurum/music_test.mp3", info);
  
  if (result == AUDIO_OK) {
    PrintStr("MP3 Parse OK!\n");
    PrintStr("Format: ");
    PrintInt(info.format);
    PrintStr("\n");
    PrintStr("Sample Rate: ");
    PrintInt(info.sampleRate);
    PrintStr(" Hz\n");
    PrintStr("Channels: ");
    PrintInt(info.channels);
    PrintStr("\n");
    PrintStr("Bits: ");
    PrintInt(info.bitsPerSample);
    PrintStr("\n");
    PrintStr("Data Offset: ");
    PrintInt(info.dataOffset);
    PrintStr("\n");
    PrintStr("Data Size: ");
    PrintInt(info.dataSize);
    PrintStr(" bytes\n");
    PrintStr("Duration: ");
    PrintInt(info.durationMs);
    PrintStr(" ms\n");
  } else {
    PrintStr("MP3 Parse failed: ");
    PrintInt(result);
    PrintStr("\n");
  }
  
  return 0;
}