// Test MP3 Decoder via libmpg123 FFI - debug version
import std.audio;
import std.audio.mpg123;

pub fn main(): int64 {
  PrintStr("=== MP3 Decoder Test ===\n");
  
  // Try calling mpg123_init directly first
  PrintStr("Calling mpg123_init...\n");
  var initResult: int64;
  initResult := mpg123_init();
  
  PrintStr("mpg123_init returned: ");
  PrintInt(initResult);
  PrintStr("\n");
  
  if (initResult != MPG123_OK) {
    PrintStr("ERROR: mpg123_init failed\n");
    return 1;
  }
  
  // Try creating handle
  PrintStr("Creating mpg123 handle...\n");
  var err: int64;
  err := 0;
  var handle: int64;
  handle := mpg123_new(err);
  
  PrintStr("mpg123_new returned: ");
  PrintInt(handle);
  PrintStr(" err=");
  PrintInt(err);
  PrintStr("\n");
  
  if (handle == 0) {
    PrintStr("ERROR: Failed to create handle\n");
    mpg123_exit();
    return 1;
  }
  
  // Open MP3 file
  PrintStr("Opening file...\n");
  var openResult: int64;
  openResult := mpg123_open(handle, "/home/andreas/PhpstormProjects/aurum/music_test.mp3");
  
  PrintStr("mpg123_open returned: ");
  PrintInt(openResult);
  PrintStr("\n");
  
  if (openResult != MPG123_OK) {
    PrintStr("ERROR: Failed to open MP3\n");
    mpg123_delete(handle);
    mpg123_exit();
    return 1;
  }
  
  PrintStr("OK: MP3 file opened!\n");
  
  // Cleanup
  mpg123_close(handle);
  mpg123_delete(handle);
  mpg123_exit();
  
  PrintStr("=== Test Complete ===\n");
  return 0;
}
