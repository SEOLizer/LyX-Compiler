// Test: Check if drain actually waits
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== ALSA: Drain timing test ===\n");
  
  // Generate 1 second of audio
  var sampleRate: int64 := 48000;
  var channels: int64 := 2;
  var bytesPerFrame: int64 := 4;
  var oneSecond: int64 := sampleRate * bytesPerFrame;
  
  var playBuf: int64;
  playBuf := mmap(0, oneSecond, 3, 34, -1, 0);
  
  // Fill with silence
  var i: int64 := 0;
  while (i < oneSecond) {
    poke8(playBuf + i, 0);
    i := i + 1;
  }
  
  PrintStr("Buffer allocated: "); PrintInt(oneSecond); PrintStr(" bytes\n");
  
  // Open ALSA
  var hp: int64;
  hp := mmap(0, 8, 3, 34, -1, 0);
  var res: int64;
  res := snd_pcm_open(hp, "hw:0", 0, 0);
  
  if (res != 0) {
    PrintStr("Open failed: "); PrintInt(res); PrintStr("\n");
    return 1;
  }
  
  var alsaHandle: int64;
  alsaHandle := peek64(hp);
  munmap(hp, 8);
  
  // Set params
  var pp: int64;
  pp := mmap(0, 8, 3, 34, -1, 0);
  snd_pcm_hw_params_malloc(pp);
  var params: int64;
  params := peek64(pp);

  snd_pcm_hw_params_any(alsaHandle, params);
  snd_pcm_hw_params_set_access(alsaHandle, params, 3);
  snd_pcm_hw_params_set_format(alsaHandle, params, 2);
  
  var ratePtr: int64;
  ratePtr := mmap(0, 8, 3, 34, -1, 0);
  poke32(ratePtr, sampleRate);
  snd_pcm_hw_params_set_rate_near(alsaHandle, params, ratePtr, 0);
  var actualRate: int64;
  actualRate := peek32(ratePtr);
  munmap(ratePtr, 8);
  
  snd_pcm_hw_params_set_channels(alsaHandle, params, channels);
  res := snd_pcm_hw_params(alsaHandle, params);
  
  if (res != 0) {
    PrintStr("Params failed: "); PrintInt(res); PrintStr("\n");
    return 1;
  }
  
  snd_pcm_hw_params_free(params);
  munmap(pp, 8);
  
  PrintStr("Playing 1 second of audio...\n");
  PrintStr("Start time: NOW\n");
  
  // Write 1 second
  res := snd_pcm_writei(alsaHandle, playBuf, sampleRate);
  
  PrintStr("Write done: "); PrintInt(res); PrintStr(" frames\n");
  PrintStr("Drain starting...\n");
  
  // This should block for ~1 second
  snd_pcm_drain(alsaHandle);
  
  PrintStr("Drain done!\n");
  PrintStr("End time: NOW\n");
  PrintStr("If timing is correct, ~1 second passed between Start and End\n");
  
  snd_pcm_close(alsaHandle);
  munmap(playBuf, oneSecond);
  
  PrintStr("=== Done ===\n");
  return 0;
}