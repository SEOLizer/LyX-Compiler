// Test: Play fresh WAV file that we know works
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== ALSA Fresh WAV Test ===\n");
  
  // Use the fresh WAV that works with aplay
  var wavPath: pchar := "/tmp/fresh.wav";
  
  var fd: int64;
  fd := open(wavPath, 0, 0);
  
  // Read header to get actual format
  lseek(fd, 22, SEEK_SET);  // Channels position
  var channels: int8;
  channels := peek8(fd);
  lseek(fd, 24, SEEK_SET);  // Sample rate
  var sampleRate: int32;
  sampleRate := peek8(fd) | (peek8(fd+1) << 8) | (peek8(fd+2) << 16) | (peek8(fd+3) << 24);
  
  lseek(fd, 34, SEEK_SET);  // Bits per sample
  var bits: int8;
  bits := peek8(fd);
  
  PrintStr("Format: ");
  PrintInt(channels);
  PrintStr(" channels, ");
  PrintInt(sampleRate);
  PrintStr(" Hz, ");
  PrintInt(bits);
  PrintStr(" bit\n");
  
  // Get file size
  var fsize: int64;
  fsize := lseek(fd, 0, SEEK_END);
  var dataSize: int64;
  dataSize := fsize - 44;
  close(fd);
  
  // Re-open and read data
  fd := open(wavPath, 0, 0);
  lseek(fd, 44, SEEK_SET);
  
  var buffer: int64;
  buffer := mmap(0, dataSize, 3, 34, -1, 0);
  sys_read(fd, buffer, dataSize);
  close(fd);
  
  PrintStr("Data: ");
  PrintInt(dataSize);
  PrintStr(" bytes\n");
  
  // Open ALSA
  var hp: int64;
  hp := mmap(0, 8, 3, 34, -1, 0);
  snd_pcm_open(hp, "hw:0", 0, 0);
  var handle: int64;
  handle := peek64(hp);
  munmap(hp, 8);
  
  // Set params using ACTUAL values from header
  var pp: int64;
  pp := mmap(0, 8, 3, 34, -1, 0);
  snd_pcm_hw_params_malloc(pp);
  var params: int64;
  params := peek64(pp);
  
  snd_pcm_hw_params_any(handle, params);
  snd_pcm_hw_params_set_access(handle, params, SND_PCM_ACCESS_RW_INTERLEAVED);
  snd_pcm_hw_params_set_format(handle, params, SND_PCM_FORMAT_S16_LE);
  snd_pcm_hw_params_set_rate_near(handle, params, sampleRate, 0);
  snd_pcm_hw_params_set_channels(handle, params, 2);
  var res: int64;
  res := snd_pcm_hw_params(handle, params);
  
  snd_pcm_hw_params_free(params);
  munmap(pp, 8);
  
  PrintStr("hw_params result: ");
  PrintInt(res);
  PrintStr("\n");
  
  if (res != ALSA_OK) {
    snd_pcm_close(handle);
    return 1;
  }
  
  // Write 1 second only for quick test
  PrintStr("Playing 1 second...\n");
  var frames: int64;
  frames := sampleRate;  // 1 second
  var written: int64;
  written := snd_pcm_writei(handle, buffer, frames);
  
  PrintStr("Written: ");
  PrintInt(written);
  PrintStr(" frames\n");
  
  snd_pcm_drain(handle);
  snd_pcm_close(handle);
  munmap(buffer, dataSize);
  
  PrintStr("=== Done ===\n");
  return 0;
}
