// Test: Detailed ALSA error debugging
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== ALSA Detailed Debug ===\n");
  
  // Open ALSA device
  var handle: int64;
  handle := ALSAAudioOpen();
  
  if (handle == 0) {
    PrintStr("ERROR: Cannot open ALSA\n");
    return 1;
  }
  
  PrintStr("Handle: ");
  PrintInt(handle);
  PrintStr("\n");
  
  // Now try setting params
  var paramsPtr: int64;
  paramsPtr := mmap(0, 8, 3, 34, -1, 0);
  
  if (paramsPtr == 0) {
    ALSAClose(handle);
    PrintStr("ERROR: mmap failed\n");
    return 1;
  }
  
  var result: int64;
  result := snd_pcm_hw_params_malloc(paramsPtr);
  PrintStr("malloc: ");
  PrintInt(result);
  if (result != 0) { PrintStr(" ERROR"); }
  PrintStr("\n");
  
  if (result != ALSA_OK) {
    ALSAClose(handle);
    munmap(paramsPtr, 8);
    return 1;
  }
  
  var params: int64;
  params := peek64(paramsPtr);
  PrintStr("params ptr: ");
  PrintInt(params);
  PrintStr("\n");
  
  // Step 1: hw_params_any
  result := snd_pcm_hw_params_any(handle, params);
  PrintStr("hw_params_any: ");
  PrintInt(result);
  if (result < 0) { PrintStr(" (negative)"); }
  PrintStr("\n");
  
  if (result < 0) {
    // Print more info
    PrintStr("Error code: ");
    PrintInt(result);
    PrintStr("\n");
    // Try with no params
    snd_pcm_hw_params_free(params);
    munmap(paramsPtr, 8);
    ALSAClose(handle);
    PrintStr("FAILED at hw_params_any\n");
    return 1;
  }
  
  // Step 2: set access
  result := snd_pcm_hw_params_set_access(handle, params, SND_PCM_ACCESS_RW_INTERLEAVED);
  PrintStr("set_access: ");
  PrintInt(result);
  if (result < 0) { PrintStr(" (ERROR)"); }
  PrintStr("\n");
  
  if (result < 0) {
    snd_pcm_hw_params_free(params);
    munmap(paramsPtr, 8);
    ALSAClose(handle);
    PrintStr("FAILED at set_access\n");
    return 1;
  }
  
  // Step 3: set format
  result := snd_pcm_hw_params_set_format(handle, params, SND_PCM_FORMAT_S16_LE);
  PrintStr("set_format: ");
  PrintInt(result);
  if (result < 0) { PrintStr(" (ERROR)"); }
  PrintStr("\n");
  
  if (result < 0) {
    snd_pcm_hw_params_free(params);
    munmap(paramsPtr, 8);
    ALSAClose(handle);
    PrintStr("FAILED at set_format\n");
    return 1;
  }
  
  // Step 4: set rate
  result := snd_pcm_hw_params_set_rate_near(handle, params, 44100, 0);
  PrintStr("set_rate: ");
  PrintInt(result);
  if (result < 0) { PrintStr(" (ERROR)"); }
  PrintStr("\n");
  
  if (result < 0) {
    snd_pcm_hw_params_free(params);
    munmap(paramsPtr, 8);
    ALSAClose(handle);
    PrintStr("FAILED at set_rate\n");
    return 1;
  }
  
  // Step 5: set channels
  result := snd_pcm_hw_params_set_channels(handle, params, 2);
  PrintStr("set_channels: ");
  PrintInt(result);
  if (result < 0) { PrintStr(" (ERROR)"); }
  PrintStr("\n");
  
  if (result < 0) {
    snd_pcm_hw_params_free(params);
    munmap(paramsPtr, 8);
    ALSAClose(handle);
    PrintStr("FAILED at set_channels\n");
    return 1;
  }
  
  // Step 6: Apply params
  PrintStr("Applying hw_params...\n");
  result := snd_pcm_hw_params(handle, params);
  PrintStr("hw_params: ");
  PrintInt(result);
  if (result < 0) { PrintStr(" (ERROR)"); }
  PrintStr("\n");
  
  if (result < 0) {
    PrintStr("Error applying params: ");
    PrintInt(result);
    PrintStr("\n");
  }
  
  // Cleanup
  snd_pcm_hw_params_free(params);
  munmap(paramsPtr, 8);
  ALSAClose(handle);
  
  PrintStr("=== Done ===\n");
  return 0;
}
