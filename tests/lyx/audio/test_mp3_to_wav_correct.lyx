// Test: MP3 to WAV with correct sample rate
import std.audio;
import std.audio.mpg123;

pub fn main(): int64 {
  PrintStr("=== MP3 to WAV (Correct Format) ===\n");
  
  var mp3Path: pchar := "/home/andreas/PhpstormProjects/aurum/music_test.mp3";
  var wavPath: pchar := "/tmp/correct_output.wav";
  
  // Step 1: Initialize MP3 decoder
  mpg123_init();
  var handle: int64;
  handle := mpg123_new(0, 0);
  
  // Open MP3 without fixed format
  var res: int64;
  res := mpg123_open(handle, mp3Path);
  
  if (res != MPG123_OK) {
    PrintStr("ERROR: Cannot open MP3\n");
    mpg123_exit();
    return 1;
  }
  
  // Query actual format
  var ratePtr: int64;
  var chanPtr: int64;
  var encPtr: int64;
  ratePtr := mmap(0, 8, 3, 34, -1, 0);
  chanPtr := mmap(0, 8, 3, 34, -1, 0);
  encPtr := mmap(0, 8, 3, 34, -1, 0);
  
  res := mpg123_getformat(handle, ratePtr, chanPtr, encPtr);
  
  var sampleRate: int64;
  sampleRate := peek64(ratePtr);
  var channels: int64;
  channels := peek64(chanPtr);
  var encoding: int64;
  encoding := peek64(encPtr);
  
  PrintStr("MP3 Format:\n");
  PrintStr("  Sample Rate: ");
  PrintInt(sampleRate);
  PrintStr(" Hz\n");
  PrintStr("  Channels: ");
  PrintInt(channels);
  PrintStr("\n");
  PrintStr("  Encoding: ");
  PrintInt(encoding);
  PrintStr("\n");
  
  munmap(ratePtr, 8);
  munmap(chanPtr, 8);
  munmap(encPtr, 8);
  
  // Now re-open with fixed format to decode
  mpg123_close(handle);
  res := mpg123_open_fixed(handle, mp3Path, channels, MPG123_ENC_SIGNED_16);
  
  if (res != MPG123_OK) {
    PrintStr("ERROR: Cannot open with fixed format\n");
    mpg123_delete(handle);
    mpg123_exit();
    return 1;
  }
  
  // Allocate buffer and decode
  var buf: int64;
  buf := mmap(0, 10485760, 3, 34, -1, 0);
  var done: int64;
  done := mmap(0, 8, 3, 34, -1, 0);
  
  var total: int64;
  total := 0;
  
  while (total < 10485760) {
    res := mpg123_read(handle, buf + total, 16384, done);
    
    if (res == MPG123_DONE) {
      break;
    }
    if (res < 0 and res != MPG123_NEW_FORMAT) {
      PrintStr("Decode error: ");
      PrintInt(res);
      PrintStr("\n");
      munmap(buf, 10485760);
      munmap(done, 8);
      mpg123_close(handle);
      mpg123_delete(handle);
      mpg123_exit();
      return 1;
    }
    
    total := total + 4096;
  }
  
  PrintStr("Decoded ");
  PrintInt(total);
  PrintStr(" bytes\n");
  
  // Save as WAV with CORRECT sample rate
  var bitsPerSample: int64;
  bitsPerSample := 16;
  
  // Determine bytes per sample
  if (encoding == 4) {
    bitsPerSample := 16;
  } else if (encoding == 1) {
    bitsPerSample := 8;
  }
  
  res := WAVSaveFile(wavPath, buf, total, sampleRate, channels, bitsPerSample);
  
  munmap(buf, 10485760);
  munmap(done, 8);
  mpg123_close(handle);
  mpg123_delete(handle);
  mpg123_exit();
  
  if (res != 0) {
    PrintStr("ERROR: Cannot save WAV\n");
    return 1;
  }
  
  PrintStr("WAV saved: ");
  PrintStr(wavPath);
  PrintStr("\n");
  
  // Verify the file
  var fd: int64;
  fd := open(wavPath, 0, 0);
  if (fd >= 0) {
    lseek(fd, 22, SEEK_SET);
    var rate: int32;
    rate := peek8(fd) | (peek8(fd+1) << 8) | (peek8(fd+2) << 16) | (peek8(fd+3) << 24);
    lseek(fd, 34, SEEK_SET);
    var bits: int8;
    bits := peek8(fd);
    lseek(fd, 36, SEEK_SET);
    var ch: int8;
    ch := peek8(fd);
    
    PrintStr("WAV Header:\n");
    PrintStr("  Sample Rate: ");
    PrintInt(rate);
    PrintStr(" Hz\n");
    PrintStr("  Bits: ");
    PrintInt(bits);
    PrintStr("\n");
    PrintStr("  Channels: ");
    PrintInt(ch);
    PrintStr("\n");
    
    close(fd);
  }
  
  PrintStr("=== Done ===\n");
  return 0;
}
