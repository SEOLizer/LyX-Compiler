// Test: Check device state during/after playback
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== ALSA: State check test ===\n");
  
  var sampleRate: int64 := 48000;
  var totalBytes: int64 := sampleRate * 4; // 1 second
  var playBuf: int64;
  playBuf := mmap(0, totalBytes, 3, 34, -1, 0);
  
  // Fill with tone
  var i: int64 := 0;
  while (i < totalBytes) {
    var val: int64 := (i / 4) % 256 - 128;
    poke8(playBuf + i, val);
    if (i + 1 < totalBytes) {
      poke8(playBuf + i + 1, val >> 8);
    }
    i := i + 2;
  }
  
  // Open ALSA
  var hp: int64;
  hp := mmap(0, 8, 3, 34, -1, 0);
  var res: int64;
  res := snd_pcm_open(hp, "hw:0", 0, 0);
  
  if (res != 0) { return 1; }
  
  var alsaHandle: int64;
  alsaHandle := peek64(hp);
  munmap(hp, 8);
  
  // Set params
  var pp: int64;
  pp := mmap(0, 8, 3, 34, -1, 0);
  snd_pcm_hw_params_malloc(pp);
  var params: int64;
  params := peek64(pp);

  snd_pcm_hw_params_any(alsaHandle, params);
  snd_pcm_hw_params_set_access(alsaHandle, params, 3);
  snd_pcm_hw_params_set_format(alsaHandle, params, 2);
  
  var ratePtr: int64;
  ratePtr := mmap(0, 8, 3, 34, -1, 0);
  poke32(ratePtr, sampleRate);
  snd_pcm_hw_params_set_rate_near(alsaHandle, params, ratePtr, 0);
  var actualRate: int64;
  actualRate := peek32(ratePtr);
  munmap(ratePtr, 8);
  
  snd_pcm_hw_params_set_channels(alsaHandle, params, 2);
  res := snd_pcm_hw_params(alsaHandle, params);
  
  if (res != 0) { return 1; }
  
  snd_pcm_hw_params_free(params);
  munmap(pp, 8);
  
  PrintStr("State before write: running\n");
  // Note: We don't have snd_pcm_state function in interface
  
  PrintStr("Writing 48000 frames...\n");
  res := snd_pcm_writei(alsaHandle, playBuf, sampleRate);
  PrintStr("Write result: "); PrintInt(res); PrintStr("\n");
  
  PrintStr("State after write: (should be RUNNING or PREPARED)\n");
  
  // Try recover after write - sometimes needed
  // res := snd_pcm_recover(alsaHandle, res, 0);
  // PrintStr("Recover result: "); PrintInt(res); PrintStr("\n");
  
  PrintStr("About to drain - this should block for ~1 second...\n");
  var drainStart: int64;
  drainStart := 0; // Approximate start
  
  snd_pcm_drain(alsaHandle);
  
  var drainEnd: int64;
  drainEnd := 1; // Approximate end
  
  PrintStr("Drain completed!\n");
  
  // Try again with more data
  PrintStr("Writing more data...\n");
  
  playBuf := mmap(0, sampleRate * 4, 3, 34, -1, 0);
  res := snd_pcm_writei(alsaHandle, playBuf, sampleRate);
  
  PrintStr("Write2 result: "); PrintInt(res); PrintStr("\n");
  PrintStr("Draining again...\n");
  
  snd_pcm_drain(alsaHandle);
  PrintStr("Drain2 done\n");
  
  snd_pcm_close(alsaHandle);
  munmap(playBuf, sampleRate * 4);
  
  PrintStr("=== Done ===\n");
  return 0;
}