// Test WAV parser
import std.audio;

pub fn main(): int64 {
  var info: AudioInfo;
  var result: int64;
  var path: pchar;
  
  // Use /tmp/test.wav (created earlier)
  path := "/tmp/test.wav";
  
  result := WAVParse(path, info);
  
  if (result == AUDIO_OK) {
    PrintStr("WAV parsed!\n");
    PrintStr("Format: ");
    PrintInt(info.format);
    PrintStr("\n");
    PrintStr("Sample Rate: ");
    PrintInt(info.sampleRate);
    PrintStr(" Hz\n");
    PrintStr("Channels: ");
    PrintInt(info.channels);
    PrintStr("\n");
    PrintStr("Bits: ");
    PrintInt(info.bitsPerSample);
    PrintStr("\n");
    PrintStr("Duration: ");
    PrintInt(info.durationMs);
    PrintStr(" ms\n");
  } else {
    PrintStr("Failed: ");
    PrintInt(result);
    PrintStr("\n");
  }
  
  return 0;
}