// 20 second playback test
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== 20 Second Playback Test ===\n");
  
  // Use 20 seconds of fresh.wav
  var fd: int64;
  fd := open("/tmp/fresh.wav", 0, 0);
  
  // Skip header
  lseek(fd, 44, SEEK_SET);
  
  // Read 20 seconds = 20 * 176400 bytes = 3,528,000 bytes
  var bufSize: int64;
  bufSize := 3528000;
  
  var buf: int64;
  buf := mmap(0, bufSize, 3, 34, -1, 0);
  
  var read: int64;
  read := sys_read(fd, buf, bufSize);
  
  close(fd);
  
  PrintStr("Read: ");
  PrintInt(read);
  PrintStr(" bytes (~");
  PrintInt(read / 176400);
  PrintStr(" seconds)\n");
  
  // Open ALSA
  var hp: int64;
  hp := mmap(0, 8, 3, 34, -1, 0);
  var res: int64;
  res := snd_pcm_open(hp, "hw:0", 0, 0);
  
  if (res != 0) {
    PrintStr("ERROR: Cannot open ALSA\n");
    munmap(buf, bufSize);
    return 1;
  }
  
  PrintStr("ALSA opened\n");
  
  var handle: int64;
  handle := peek64(hp);
  munmap(hp, 8);
  
  // Setup params
  var pp: int64;
  pp := mmap(0, 8, 3, 34, -1, 0);
  snd_pcm_hw_params_malloc(pp);
  var params: int64;
  params := peek64(pp);
  
  snd_pcm_hw_params_any(handle, params);
  snd_pcm_hw_params_set_access(handle, params, 3);
  snd_pcm_hw_params_set_format(handle, params, 2);
  snd_pcm_hw_params_set_rate_near(handle, params, 44100, 0);
  snd_pcm_hw_params_set_channels(handle, params, 2);
  res := snd_pcm_hw_params(handle, params);
  
  if (res != 0) {
    PrintStr("ERROR: Cannot set params\n");
    snd_pcm_close(handle);
    snd_pcm_hw_params_free(params);
    munmap(pp, 8);
    munmap(buf, bufSize);
    return 1;
  }
  
  PrintStr("Params set, playing...\n");
  
  snd_pcm_hw_params_free(params);
  munmap(pp, 8);
  
  // Calculate frames
  var frames: int64;
  frames := read / 4;  // 4 bytes per frame (2 channels * 2 bytes)
  
  // Write in chunks to avoid blocking too long
  var written: int64;
  written := snd_pcm_writei(handle, buf, frames);
  
  PrintStr("Written: ");
  PrintInt(written);
  PrintStr(" frames\n");
  
  // Wait for playback to finish
  snd_pcm_drain(handle);
  snd_pcm_close(handle);
  munmap(buf, bufSize);
  
  PrintStr("=== Done ===\n");
  return 0;
}
