// Minimal debug with smaller file
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== Fresh File Test ===\n");
  
  // Use small portion of fresh.wav
  var fd: int64;
  fd := open("/tmp/fresh.wav", 0, 0);
  
  // Skip header
  lseek(fd, 44, SEEK_SET);
  
  // Read just 1 second = 176400 bytes
  var buf: int64;
  buf := mmap(0, 176400, 3, 34, -1, 0);
  
  var read: int64;
  read := sys_read(fd, buf, 176400);
  
  close(fd);
  
  PrintStr("Read: ");
  PrintInt(read);
  PrintStr(" bytes\n");
  
  // Open ALSA with small buffer
  var hp: int64;
  hp := mmap(0, 8, 3, 34, -1, 0);
  var res: int64;
  res := snd_pcm_open(hp, "default", 0, 0);
  PrintStr("open result: ");
  PrintInt(res);
  PrintStr("\n");
  
  var handle: int64;
  handle := peek64(hp);
  munmap(hp, 8);
  
  // Quick params setup
  var pp: int64;
  pp := mmap(0, 8, 3, 34, -1, 0);
  snd_pcm_hw_params_malloc(pp);
  var params: int64;
  params := peek64(pp);
  
  snd_pcm_hw_params_any(handle, params);
  snd_pcm_hw_params_set_access(handle, params, 3);
  snd_pcm_hw_params_set_format(handle, params, 2);
  snd_pcm_hw_params_set_rate_near(handle, params, 44100, 0);
  snd_pcm_hw_params_set_channels(handle, params, 2);
  res := snd_pcm_hw_params(handle, params);
  
  PrintStr("params result: ");
  PrintInt(res);
  PrintStr("\n");
  
  snd_pcm_hw_params_free(params);
  munmap(pp, 8);
  
  if (res != 0) {
    snd_pcm_close(handle);
    munmap(buf, 176400);
    return 1;
  }
  
  // Play 1 second
  PrintStr("Playing...\n");
  res := snd_pcm_writei(handle, buf, 44100);
  PrintStr("write result: ");
  PrintInt(res);
  PrintStr("\n");
  
  snd_pcm_drain(handle);
  snd_pcm_close(handle);
  munmap(buf, 176400);
  
  PrintStr("=== Done ===\n");
  return 0;
}
