// Test program for audio parser
import std.audio;

pub fn main(): int64 {
  var info: AudioInfo;
  var result: int64;
  var path: pchar;
  
  path := "/home/andreas/PhpstormProjects/aurum/music_test.mp3";
  
  result := MP3Parse(path, info);
  
  if (result == AUDIO_OK) {
    PrintStr("Success!\n");
    PrintStr("Format: ");
    PrintInt(info.format);
    PrintStr("\n");
    PrintStr("Sample Rate: ");
    PrintInt(info.sampleRate);
    PrintStr(" Hz\n");
    PrintStr("Channels: ");
    PrintInt(info.channels);
    PrintStr("\n");
    PrintStr("Duration: ");
    PrintInt(info.durationMs);
    PrintStr(" ms\n");
  } else {
    PrintStr("Failed: ");
    PrintInt(result);
    PrintStr("\n");
  }
  
  return 0;
}