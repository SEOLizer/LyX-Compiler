// Test: Play exactly 1 second of audio to verify timing
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  var wavPath: pchar := "/tmp/playback_30s.wav";
  PrintStr("=== ALSA: Exactly 1 second test ===\n");

  // Open file
  var fd: int64;
  fd := open(wavPath, 0, 0);
  if (fd < 0) {
    PrintStr("ERROR: Cannot open file\n");
    return 1;
  }

  // Read header
  var hdr: int64;
  hdr := mmap(0, 44, 3, 34, -1, 0);
  var bytesRead: int64;
  bytesRead := sys_read(fd, hdr, 44);
  
  if (bytesRead < 44) {
    PrintStr("ERROR: Short header read\n");
    close(fd);
    return 1;
  }

  var sampleRate: int64 := peek8(hdr + 24) | (peek8(hdr + 25) << 8) | (peek8(hdr + 26) << 16) | (peek8(hdr + 27) << 24);
  var channels: int64 := peek8(hdr + 22) | (peek8(hdr + 23) << 8);
  var bitsPerSample: int64 := peek8(hdr + 34) | (peek8(hdr + 35) << 8);
  munmap(hdr, 44);

  // Calculate exactly 1 second of data
  var bytesPerSecond: int64 := sampleRate * channels * (bitsPerSample / 8);
  var oneSecondSize: int64 := bytesPerSecond;
  
  PrintStr("Sample Rate: "); PrintInt(sampleRate); PrintStr(" Hz\n");
  PrintStr("Channels: "); PrintInt(channels); PrintStr("\n");
  PrintStr("Bits: "); PrintInt(bitsPerSample); PrintStr("\n");
  PrintStr("1 second = "); PrintInt(oneSecondSize); PrintStr(" bytes\n");

  // Read exactly 1 second
  var playBuf: int64;
  playBuf := mmap(0, oneSecondSize, 3, 34, -1, 0);
  bytesRead := sys_read(fd, playBuf, oneSecondSize);
  close(fd);

  PrintStr("Read: "); PrintInt(bytesRead); PrintStr(" bytes\n");

  // Open ALSA
  var hp: int64;
  hp := mmap(0, 8, 3, 34, -1, 0);
  var res: int64;
  res := snd_pcm_open(hp, "plughw:0", 0, 0);
  
  if (res != 0) {
    PrintStr("ERROR: Cannot open ALSA: "); PrintInt(res); PrintStr("\n");
    munmap(playBuf, oneSecondSize);
    munmap(hp, 8);
    return 1;
  }
  
  var alsaHandle: int64;
  alsaHandle := peek64(hp);
  munmap(hp, 8);

  // Set params
  var pp: int64;
  pp := mmap(0, 8, 3, 34, -1, 0);
  snd_pcm_hw_params_malloc(pp);
  var params: int64;
  params := peek64(pp);

  snd_pcm_hw_params_any(alsaHandle, params);
  snd_pcm_hw_params_set_access(alsaHandle, params, 3);
  snd_pcm_hw_params_set_format(alsaHandle, params, 2);
  
  var ratePtr: int64;
  ratePtr := mmap(0, 8, 3, 34, -1, 0);
  poke32(ratePtr, sampleRate);
  snd_pcm_hw_params_set_rate_near(alsaHandle, params, ratePtr, 0);
  var actualRate: int64;
  actualRate := peek32(ratePtr);
  munmap(ratePtr, 8);
  
  PrintStr("Rate set to: "); PrintInt(actualRate); PrintStr(" Hz\n");
  
  snd_pcm_hw_params_set_channels(alsaHandle, params, channels);
  res := snd_pcm_hw_params(alsaHandle, params);
  
  if (res != 0) {
    PrintStr("ERROR: Cannot set params: "); PrintInt(res); PrintStr("\n");
    snd_pcm_close(alsaHandle);
    munmap(playBuf, oneSecondSize);
    return 1;
  }
  
  snd_pcm_hw_params_free(params);
  munmap(pp, 8);
  
  // Play
  var bytesPerFrame: int64 := channels * (bitsPerSample / 8);
  var frames: int64 := bytesRead / bytesPerFrame;
  
  PrintStr("Writing "); PrintInt(frames); PrintStr(" frames (1 sec)...\n");
  
  res := snd_pcm_writei(alsaHandle, playBuf, frames);
  
  if (res < 0) {
    PrintStr("Write error: "); PrintInt(res); PrintStr("\n");
  } else {
    PrintStr("Written: "); PrintInt(res); PrintStr(" frames\n");
  }
  
  // Wait a moment to ensure playback completes
  // (This is a workaround since we don't have drain)
  var waitCount: int64 := 0;
  while (waitCount < 1000000) {
    waitCount := waitCount + 1;
  }
  
  snd_pcm_close(alsaHandle);
  munmap(playBuf, oneSecondSize);

  PrintStr("=== Done ===\n");
  return 0;
}