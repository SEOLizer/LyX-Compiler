// Test struct assignment - using std.audio
import std.audio;

pub fn main(): int64 {
  var info: AudioInfo;
  
  // Direct assignment inside main - this works!
  info.format := 10;
  info.sampleRate := 48000;
  info.channels := 2;
  info.bitsPerSample := 16;
  info.dataOffset := 1000;
  info.dataSize := 2000;
  info.durationMs := 3000;
  
  PrintStr("After direct assignment:\n");
  PrintStr("format: ");
  PrintInt(info.format);
  PrintStr("\n");
  PrintStr("sampleRate: ");
  PrintInt(info.sampleRate);
  PrintStr("\n");
  PrintStr("channels: ");
  PrintInt(info.channels);
  PrintStr("\n");
  PrintStr("dataSize: ");
  PrintInt(info.dataSize);
  PrintStr("\n");
  PrintStr("durationMs: ");
  PrintInt(info.durationMs);
  PrintStr("\n");
  
  return 0;
}
