// Test mpg123 - minimal version with just init
import std.audio;
import std.audio.mpg123;

pub fn main(): int64 {
  PrintStr("=== mpg123 Minimal Test ===\n");
  
  // Step 1: Initialize
  PrintStr("1. mpg123_init...\n");
  var result: int64;
  result := mpg123_init();
  
  if (result != MPG123_OK) {
    PrintStr("ERROR: init failed\n");
    return 1;
  }
  PrintStr("   OK, result=");
  PrintInt(result);
  PrintStr("\n");
  
  // Step 2: Create handle
  PrintStr("2. mpg123_new...\n");
  var handle: int64;
  handle := mpg123_new(0, 0);
  
  PrintStr("   handle=");
  PrintInt(handle);
  PrintStr("\n");
  
  if (handle == 0) {
    PrintStr("ERROR: new failed\n");
    mpg123_exit();
    return 1;
  }
  
  // Step 3: Exit without opening anything
  PrintStr("3. mpg123_delete + mpg123_exit...\n");
  mpg123_delete(handle);
  mpg123_exit();
  
  PrintStr("=== Complete ===\n");
  return 0;
}
