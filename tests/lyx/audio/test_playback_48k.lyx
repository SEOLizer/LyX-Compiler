// Test: Convert MP3 to WAV and play (20 seconds, 48000 Hz)
import std.audio;
import std.audio.mpg123;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== MP3 to WAV to Playback (48000 Hz) ===\n");
  
  var mp3Path: pchar := "/home/andreas/PhpstormProjects/aurum/music_test.mp3";
  var wavPath: pchar := "/tmp/playback_48k.wav";
  
  // Step 1: Get MP3 format
  PrintStr("1. Getting MP3 format...\n");
  
  mpg123_init();
  var handle: int64;
  handle := mpg123_new(0, 0);
  
  var res: int64;
  res := mpg123_open(handle, mp3Path);
  
  var ratePtr: int64;
  var chanPtr: int64;
  var encPtr: int64;
  ratePtr := mmap(0, 8, 3, 34, -1, 0);
  chanPtr := mmap(0, 8, 3, 34, -1, 0);
  encPtr := mmap(0, 8, 3, 34, -1, 0);
  
  res := mpg123_getformat(handle, ratePtr, chanPtr, encPtr);
  
  var sampleRate: int64;
  sampleRate := peek64(ratePtr);
  var channels: int64;
  channels := peek64(chanPtr);
  
  PrintStr("   Sample Rate: ");
  PrintInt(sampleRate);
  PrintStr(" Hz\n");
  PrintStr("   Channels: ");
  PrintInt(channels);
  PrintStr("\n");
  
  munmap(ratePtr, 8);
  munmap(chanPtr, 8);
  munmap(encPtr, 8);
  
  // Close and re-open with fixed format
  mpg123_close(handle);
  
  // Step 2: Decode MP3
  PrintStr("2. Decoding MP3...\n");
  
  res := mpg123_open_fixed(handle, mp3Path, channels, MPG123_ENC_SIGNED_16);
  
  var buf: int64;
  buf := mmap(0, 10485760, 3, 34, -1, 0);  // 10MB max
  var done: int64;
  done := mmap(0, 8, 3, 34, -1, 0);
  
  var total: int64;
  total := 0;
  
  while (total < 10485760) {
    res := mpg123_read(handle, buf + total, 16384, done);
    
    if (res == MPG123_DONE) {
      break;
    }
    if (res < 0 and res != MPG123_NEW_FORMAT) {
      PrintStr("   Decode error: ");
      PrintInt(res);
      PrintStr("\n");
      munmap(buf, 10485760);
      munmap(done, 8);
      mpg123_close(handle);
      mpg123_delete(handle);
      mpg123_exit();
      return 1;
    }
    
    var bytesRead: int64;
    bytesRead := peek64(done);
    if (bytesRead > 0) {
      total := total + bytesRead;
    }
  }

  PrintStr("   Decoded: ");
  PrintInt(total);
  PrintStr(" bytes\n");
  
  // Step 3: Save WAV with CORRECT sample rate
  PrintStr("3. Saving WAV (");
  PrintInt(sampleRate);
  PrintStr(" Hz)...\n");
  
  res := WAVSaveFile(wavPath, buf, total, sampleRate, channels, 16);
  
  if (res != 0) {
    PrintStr("   ERROR: Cannot save WAV\n");
    munmap(buf, 10485760);
    munmap(done, 8);
    mpg123_close(handle);
    mpg123_delete(handle);
    mpg123_exit();
    return 1;
  }
  
  PrintStr("   Saved: ");
  PrintStr(wavPath);
  PrintStr("\n");
  
  // Cleanup MP3
  munmap(buf, 10485760);
  munmap(done, 8);
  mpg123_close(handle);
  mpg123_delete(handle);
  mpg123_exit();
  
  // Step 4: Play via ALSA
  PrintStr("4. Playing...\n");

  // Read decoded WAV data (total = actual decoded bytes)
  var fd: int64;
  fd := open(wavPath, 0, 0);
  lseek(fd, 44, SEEK_SET);  // Skip WAV header

  var playSize: int64;
  playSize := total;  // Use actual decoded byte count

  var playBuf: int64;
  playBuf := mmap(0, playSize, 3, 34, -1, 0);

  var read: int64;
  read := sys_read(fd, playBuf, playSize);
  close(fd);
  
  PrintStr("   Read: ");
  PrintInt(read);
  PrintStr(" bytes = ");
  PrintInt(read / (sampleRate * channels * 2));
  PrintStr(" sec\n");
  
  // Open ALSA
  var hp: int64;
  hp := mmap(0, 8, 3, 34, -1, 0);
  res := snd_pcm_open(hp, "hw:0", 0, 0);
  
  if (res != 0) {
    PrintStr("   ERROR: Cannot open ALSA\n");
    munmap(playBuf, playSize);
    return 1;
  }
  
  var alsaHandle: int64;
  alsaHandle := peek64(hp);
  munmap(hp, 8);
  
  // Set params with CORRECT sample rate (48000 Hz!)
  var pp: int64;
  pp := mmap(0, 8, 3, 34, -1, 0);
  snd_pcm_hw_params_malloc(pp);
  var params: int64;
  params := peek64(pp);
  
  snd_pcm_hw_params_any(alsaHandle, params);
  snd_pcm_hw_params_set_access(alsaHandle, params, 3);
  snd_pcm_hw_params_set_format(alsaHandle, params, 2);  // S16_LE
  snd_pcm_hw_params_set_rate_near(alsaHandle, params, sampleRate, 0);  // 48000 Hz!
  snd_pcm_hw_params_set_channels(alsaHandle, params, channels);
  res := snd_pcm_hw_params(alsaHandle, params);
  
  if (res != 0) {
    PrintStr("   ERROR: Cannot set ALSA params\n");
    snd_pcm_close(alsaHandle);
    snd_pcm_hw_params_free(params);
    munmap(pp, 8);
    munmap(playBuf, playSize);
    return 1;
  }
  
  snd_pcm_hw_params_free(params);
  munmap(pp, 8);
  
  // Play
  PrintStr("   Playing...\n");
  
  var frames: int64;
  frames := read / 4;  // 2 channels * 2 bytes = 4
  
  res := snd_pcm_writei(alsaHandle, playBuf, frames);
  
  PrintStr("   Written: ");
  PrintInt(res);
  PrintStr(" frames\n");
  
  snd_pcm_drain(alsaHandle);
  snd_pcm_close(alsaHandle);
  munmap(playBuf, playSize);
  
  PrintStr("=== Done ===\n");
  return 0;
}
