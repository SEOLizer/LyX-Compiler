// Simple MP3 test - minimal version
import std.net.socket;

pub fn main(): int64 {
  var path: pchar;
  path := "/home/andreas/PhpstormProjects/aurum/music_test.mp3";
  
  var fd: int64;
  fd := open(path, O_RDONLY, 0);
  PrintStr("fd: ");
  PrintInt(fd);
  PrintStr("\n");
  if (fd < 0) { return 1; }
  
  var sz: int64;
  sz := lseek(fd, 0, SEEK_END);
  lseek(fd, 0, SEEK_SET);
  PrintStr("size: ");
  PrintInt(sz);
  PrintStr("\n");
  
  var buf: int64;
  buf := mmap(0, 32768, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) { close(fd); return 1; }
  
  var rd: int64;
  rd := read(fd, 32768);
  close(fd);
  
  PrintStr("read: ");
  PrintInt(rd);
  PrintStr("\n");
  
  if (rd < 10) { munmap(buf, 32768); return 1; }
  
  // Check bytes manually
  var b0: int64;
  b0 := peek8(buf);
  var b1: int64;
  b1 := peek8(buf + 1);
  var b2: int64;
  b2 := peek8(buf + 2);
  
  PrintStr("bytes: ");
  PrintInt(b0);
  PrintStr(" ");
  PrintInt(b1);
  PrintStr(" ");
  PrintInt(b2);
  PrintStr("\n");
  
  // ID3 check
  if (b0 == 73 && b1 == 68 && b2 == 51) {
    PrintStr("ID3 found!\n");
    
    // Calculate ID3 size
    var id3sz: int64;
    id3sz := 0;
    var tmp: int64;
    tmp := peek8(buf + 4);
    tmp := tmp & 127;
    id3sz := tmp << 21;
    tmp := peek8(buf + 5);
    tmp := tmp & 127;
    id3sz := id3sz | (tmp << 14);
    tmp := peek8(buf + 6);
    tmp := tmp & 127;
    id3sz := id3sz | (tmp << 7);
    tmp := peek8(buf + 7);
    id3sz := id3sz | tmp;
    
    PrintStr("ID3 size: ");
    PrintInt(id3sz);
    PrintStr("\n");
  } else {
    PrintStr("No ID3\n");
  }
  
  munmap(buf, 32768);
  return 0;
}