// Test: WAV header write only (no MP3 decoding)
import std.audio;

pub fn main(): int64 {
  PrintStr("=== WAV Header Test ===\n");
  
  // Create a test buffer
  var buf: int64;
  buf := mmap(0, 4096, 3, 34, -1, 0);
  PrintStr("Buffer: ");
  PrintInt(buf);
  PrintStr("\n");
  
  // Write header to buffer
  var headerSize: int64;
  headerSize := WAVWriteHeader(buf, 1000, 44100, 2, 16);
  
  PrintStr("Header size: ");
  PrintInt(headerSize);
  PrintStr("\n");
  
  PrintStr("Calling WAVSaveFile...\n");
  
  // Try to save to file
  var result: int64;
  result := WAVSaveFile("/tmp/test_header.wav", buf + 44, 1000, 44100, 2, 16);
  
  PrintStr("Save result: ");
  PrintInt(result);
  PrintStr("\n");
  
  if (result == 0) {
    PrintStr("SUCCESS!\n");
  }
  
  munmap(buf, 4096);
  
  PrintStr("=== Done ===\n");
  return 0;
}
