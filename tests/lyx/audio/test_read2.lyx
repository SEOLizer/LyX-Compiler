// Simple file read test with read()
pub fn main() {
  var fd: int64;
  var buf: int64;
  var size: int64;
  var ret: int64;
  
  fd := open("test.wav", 0, 0);
  
  size := lseek(fd, 0, 2);
  lseek(fd, 0, 0);
  
  // Allocate buffer
  buf := mmap(0, size, 3, 34, -1, 0);
  
  // Read directly into buffer
  ret := sys_read(fd, buf, size);
  close(fd);
  
  PrintStr("ret: ");
  PrintInt(ret);
  PrintStr("\n");
  
  // Show first 12 bytes
  PrintStr("bytes: ");
  PrintInt(peek8(buf + 0));
  PrintStr(" ");
  PrintInt(peek8(buf + 1));
  PrintStr(" ");
  PrintInt(peek8(buf + 2));
  PrintStr(" ");
  PrintInt(peek8(buf + 3));
  PrintStr(" ");
  PrintInt(peek8(buf + 4));
  PrintStr(" ");
  PrintInt(peek8(buf + 5));
  PrintStr(" ");
  PrintInt(peek8(buf + 6));
  PrintStr(" ");
  PrintInt(peek8(buf + 7));
  PrintStr(" ");
  PrintInt(peek8(buf + 8));
  PrintStr(" ");
  PrintInt(peek8(buf + 9));
  PrintStr(" ");
  PrintInt(peek8(buf + 10));
  PrintStr(" ");
  PrintInt(peek8(buf + 11));
  PrintStr("\n");
  
  munmap(buf, size);
}