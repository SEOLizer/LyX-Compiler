// Test: Verify WAV data is correct in memory
import std.audio;

pub fn main(): int64 {
  var wavPath: pchar := "/tmp/playback_30s.wav";
  PrintStr("=== Verify WAV data ===\n");

  // Read first 100 bytes of PCM data
  var fd: int64;
  fd := open(wavPath, 0, 0);
  if (fd < 0) {
    PrintStr("ERROR: Cannot open file\n");
    return 1;
  }

  // Skip header
  lseek(fd, 44, SEEK_SET);
  
  var buf: int64;
  buf := mmap(0, 100, 3, 34, -1, 0);
  var bytesRead: int64;
  bytesRead := sys_read(fd, buf, 100);
  close(fd);
  
  PrintStr("Read "); PrintInt(bytesRead); PrintStr(" bytes from data section\n");
  
  // Check first 16 samples (first few frames)
  PrintStr("First 8 samples (L R L R format):\n");
  var i: int64 := 0;
  while (i < 16) {
    var sample: int64;
    sample := peek8(buf + i) | (peek8(buf + i + 1) << 8);
    // Convert to signed
    if (sample >= 32768) {
      sample := sample - 65536;
    }
    PrintInt(sample); PrintStr(" ");
    i := i + 2;
    if (i % 4 == 0) {
      PrintStr(" | ");
    }
  }
  PrintStr("\n");
  
  // Check last bytes before EOF
  var offset: int64 := 44 + 192000;
  offset := offset - 16;
  PrintStr("Last 16 bytes of 1 second chunk (offset "); PrintInt(offset); PrintStr("):\n");
  var lastPtr: int64;
  lastPtr := mmap(0, 16, 3, 34, -1, 0);
  fd := open(wavPath, 0, 0);
  lseek(fd, offset, SEEK_SET);
  sys_read(fd, lastPtr, 16);
  close(fd);
  
  i := 0;
  while (i < 16) {
    var b: int64 := peek8(lastPtr + i);
    PrintInt(b); PrintStr(" ");
    i := i + 1;
  }
  PrintStr("\n");
  
  munmap(buf, 100);
  munmap(lastPtr, 16);
  
  PrintStr("=== Done ===\n");
  return 0;
}