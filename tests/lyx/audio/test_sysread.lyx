// sys_read test
pub fn main(): int64 {
  var fd: int64;
  var buf: int64;
  
  fd := open("test.wav", O_RDONLY, 0);
  PrintStr("fd=");
  PrintInt(fd);
  PrintStr("\n");
  
  // mmap buffer
  buf := mmap(0, 100, 3, 34, -1, 0);
  PrintStr("buf=");
  PrintInt(buf);
  PrintStr("\n");
  
  // sys_read with buffer
  var ret: int64;
  ret := sys_read(fd, buf, 50);
  PrintStr("ret=");
  PrintInt(ret);
  PrintStr("\n");
  
  if (ret > 0) {
    PrintStr("content: ");
    PrintInt(peek8(buf + 0));
    PrintStr(" ");
    PrintInt(peek8(buf + 1));
    PrintStr(" ");
    PrintInt(peek8(buf + 2));
    PrintStr(" ");
    PrintInt(peek8(buf + 3));
    PrintStr("\n");
  }
  
  close(fd);
  
  return 0;
}