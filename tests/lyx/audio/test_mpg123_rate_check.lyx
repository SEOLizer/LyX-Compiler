// Debug: Check actual mpg123 output rate after open_fixed
import std.audio;
import std.audio.mpg123;

pub fn main(): int64 {
  var mp3Path: pchar := "/home/andreas/PhpstormProjects/aurum/music_test.mp3";

  mpg123_init();
  var handle: int64;
  handle := mpg123_new(0, 0);

  // Step 1: open and get format
  mpg123_open(handle, mp3Path);

  var ratePtr: int64;  var chanPtr: int64;  var encPtr: int64;
  ratePtr := mmap(0, 8, 3, 34, -1, 0);
  chanPtr := mmap(0, 8, 3, 34, -1, 0);
  encPtr  := mmap(0, 8, 3, 34, -1, 0);
  mpg123_getformat(handle, ratePtr, chanPtr, encPtr);

  var rate1: int64;  var chan1: int64;  var enc1: int64;
  rate1 := peek64(ratePtr);
  chan1 := peek64(chanPtr);
  enc1  := peek64(encPtr);

  PrintStr("Before open_fixed:\n");
  PrintStr("  rate="); PrintInt(rate1); PrintStr(" Hz\n");
  PrintStr("  chan="); PrintInt(chan1); PrintStr("\n");
  PrintStr("  enc=");  PrintInt(enc1); PrintStr("\n");

  mpg123_close(handle);

  // Step 2: open_fixed and check format again
  var res: int64;
  res := mpg123_open_fixed(handle, mp3Path, chan1, MPG123_ENC_SIGNED_16);
  PrintStr("open_fixed result: "); PrintInt(res); PrintStr("\n");

  // Reset pointers to 0 before reading
  poke64(ratePtr, 0);
  poke64(chanPtr, 0);
  poke64(encPtr,  0);

  res := mpg123_getformat(handle, ratePtr, chanPtr, encPtr);
  PrintStr("getformat result: "); PrintInt(res); PrintStr("\n");

  var rate2: int64;  var chan2: int64;  var enc2: int64;
  rate2 := peek64(ratePtr);
  chan2 := peek64(chanPtr);
  enc2  := peek64(encPtr);

  PrintStr("After open_fixed:\n");
  PrintStr("  rate="); PrintInt(rate2); PrintStr(" Hz\n");
  PrintStr("  chan="); PrintInt(chan2); PrintStr("\n");
  PrintStr("  enc=");  PrintInt(enc2); PrintStr("\n");

  munmap(ratePtr, 8);
  munmap(chanPtr, 8);
  munmap(encPtr,  8);

  // Step 3: Decode 5 seconds and count bytes
  // 5 sec * rate2 * chan2 * 2 bytes = expected bytes
  var expected: int64;
  expected := 5 * rate2 * chan2 * 2;
  PrintStr("Expected for 5 sec: "); PrintInt(expected); PrintStr(" bytes\n");

  var buf: int64;
  buf := mmap(0, 1048576, 3, 34, -1, 0);  // 1 MB
  var done: int64;
  done := mmap(0, 8, 3, 34, -1, 0);

  var total: int64;
  total := 0;
  var iterations: int64;
  iterations := 0;

  while (total < 1048576) {
    res := mpg123_read(handle, buf + total, 16384, done);
    if (res == MPG123_DONE) { break; }
    if (res < 0 and res != MPG123_NEW_FORMAT) {
      PrintStr("Decode error: "); PrintInt(res); PrintStr("\n");
      break;
    }
    var n: int64;
    n := peek64(done);
    if (n > 0) {
      total := total + n;
    }
    iterations := iterations + 1;
  }

  PrintStr("Decoded: "); PrintInt(total); PrintStr(" bytes in ");
  PrintInt(iterations); PrintStr(" iterations\n");
  PrintStr("Avg per iteration: "); PrintInt(total / iterations); PrintStr(" bytes\n");

  var actualSecs: int64;
  actualSecs := total / (rate2 * chan2 * 2);
  PrintStr("Duration at rate2: "); PrintInt(actualSecs); PrintStr(" sec\n");

  if (rate1 > 0) {
    var actualSecsR1: int64;
    actualSecsR1 := total / (rate1 * chan1 * 2);
    PrintStr("Duration at rate1: "); PrintInt(actualSecsR1); PrintStr(" sec\n");
  }

  munmap(buf, 1048576);
  munmap(done, 8);
  mpg123_close(handle);
  mpg123_delete(handle);
  mpg123_exit();

  return 0;
}
