// Test: Check ALSA available frames after write
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== ALSA: Check available frames ===\n");
  
  var sampleRate: int64 := 48000;
  var channels: int64 := 2;
  var duration: int64 := 3; // 3 seconds
  
  var totalBytes: int64 := sampleRate * duration * 4;
  var playBuf: int64;
  playBuf := mmap(0, totalBytes, 3, 34, -1, 0);
  
  // Fill with a pattern so we can hear it
  var i: int64 := 0;
  while (i < totalBytes) {
    var val: int64 := (i / 4) % 256 - 128;
    poke8(playBuf + i, val);
    if (i + 1 < totalBytes) {
      poke8(playBuf + i + 1, val >> 8);
    }
    i := i + 2;
  }
  
  PrintStr("Buffer filled\n");
  
  // Open ALSA
  var hp: int64;
  hp := mmap(0, 8, 3, 34, -1, 0);
  var res: int64;
  res := snd_pcm_open(hp, "hw:0", 0, 0);
  
  if (res != 0) {
    PrintStr("Open failed: "); PrintInt(res); PrintStr("\n");
    return 1;
  }
  
  var alsaHandle: int64;
  alsaHandle := peek64(hp);
  munmap(hp, 8);
  
  // Set params
  var pp: int64;
  pp := mmap(0, 8, 3, 34, -1, 0);
  snd_pcm_hw_params_malloc(pp);
  var params: int64;
  params := peek64(pp);

  snd_pcm_hw_params_any(alsaHandle, params);
  snd_pcm_hw_params_set_access(alsaHandle, params, 3);
  snd_pcm_hw_params_set_format(alsaHandle, params, 2);
  
  var ratePtr: int64;
  ratePtr := mmap(0, 8, 3, 34, -1, 0);
  poke32(ratePtr, sampleRate);
  snd_pcm_hw_params_set_rate_near(alsaHandle, params, ratePtr, 0);
  var actualRate: int64;
  actualRate := peek32(ratePtr);
  munmap(ratePtr, 8);
  
  snd_pcm_hw_params_set_channels(alsaHandle, params, channels);
  res := snd_pcm_hw_params(alsaHandle, params);
  
  if (res != 0) {
    PrintStr("Params failed: "); PrintInt(res); PrintStr("\n");
    return 1;
  }
  
  snd_pcm_hw_params_free(params);
  munmap(pp, 8);
  
  PrintStr("Playing "); PrintInt(duration); PrintStr(" seconds at "); PrintInt(actualRate); PrintStr(" Hz...\n");
  
  // Write all frames
  var framesWritten: int64 := 0;
  var remainingFrames: int64 := sampleRate * duration;
  var offset: int64 := 0;
  var chunkSize: int64 := 4096;
  
  while (remainingFrames > 0) {
    var toWrite: int64 := chunkSize;
    if (toWrite > remainingFrames) {
      toWrite := remainingFrames;
    }
    
    res := snd_pcm_writei(alsaHandle, playBuf + offset, toWrite);
    
    if (res < 0) {
      PrintStr("Write error: "); PrintInt(res); PrintStr("\n");
      break;
    }
    
    framesWritten := framesWritten + res;
    remainingFrames := remainingFrames - res;
    offset := offset + (res * 4);
  }
  
  PrintStr("Total written: "); PrintInt(framesWritten); PrintStr(" frames\n");
  PrintStr("Draining...\n");
  
  snd_pcm_drain(alsaHandle);
  PrintStr("Done\n");
  
  snd_pcm_close(alsaHandle);
  munmap(playBuf, totalBytes);
  
  PrintStr("=== Done ===\n");
  return 0;
}