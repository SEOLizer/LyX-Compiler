// Test MP3 decoder using libmpg123
import std.audio;
import std.audio.mpg123;

pub fn main(): int64 {
  PrintStr("=== MP3 Decoder Test ===\n");
  
  // Initialize
  mpg123_init();
  var handle: int64;
  handle := mpg123_new(0, 0);
  
  if (handle == 0) {
    PrintStr("ERROR: Failed to create mpg123 handle\n");
    mpg123_exit();
    return 1;
  }
  
  // Open MP3 file
  var res: int64;
  res := mpg123_open_fixed(handle, "/home/andreas/PhpstormProjects/aurum/music_test.mp3", 2, 4);
  
  if (res != MPG123_OK) {
    PrintStr("ERROR: Failed to open MP3 file\n");
    mpg123_delete(handle);
    mpg123_exit();
    return 1;
  }
  PrintStr("MP3 file opened successfully\n");
  
  // Allocate buffers
  var buf: int64;
  buf := mmap(0, 16384, 3, 34, -1, 0);
  var done: int64;
  done := mmap(0, 8, 3, 34, -1, 0);
  
  // Decode loop
  var totalBytes: int64;
  totalBytes := 0;
  
  var iterations: int64;
  iterations := 0;
  
  while (iterations < 500) {
    res := mpg123_read(handle, buf, 16384, done);
    
    if (res == MPG123_DONE) {
      PrintStr("Decoding complete at iteration ");
      PrintInt(iterations);
      PrintStr("\n");
      iterations := 1000;  // break
    } else if (res < 0 and res != MPG123_NEW_FORMAT) {
      PrintStr("Error at iteration ");
      PrintInt(iterations);
      PrintStr(": ");
      PrintInt(res);
      PrintStr("\n");
      iterations := 1000;  // break
    }
    
    // Assume some bytes decoded on MPG123_OK
    if (res == MPG123_OK or res == 0) {
      totalBytes := totalBytes + 4096;
    }
    
    iterations := iterations + 1;
  }
  
  PrintStr("Total bytes decoded: ");
  PrintInt(totalBytes);
  PrintStr("\n");
  
  // Cleanup
  munmap(buf, 16384);
  munmap(done, 8);
  mpg123_close(handle);
  mpg123_delete(handle);
  mpg123_exit();
  
  PrintStr("=== Test Complete ===\n");
  return 0;
}
