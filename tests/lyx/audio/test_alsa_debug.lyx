// Test: ALSA set format debug - try prepare first
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== ALSA Format Debug v2 ===\n");
  
  // Step 1: Open ALSA
  var handle: int64;
  handle := ALSAAudioOpen();
  
  if (handle == 0) {
    PrintStr("ERROR: Cannot open ALSA\n");
    return 1;
  }
  
  PrintStr("Handle: ");
  PrintInt(handle);
  PrintStr("\n");
  
  // Try prepare first
  var result: int64;
  result := snd_pcm_prepare(handle);
  PrintStr("prepare result: ");
  PrintInt(result);
  PrintStr("\n");
  
  // Step 2: Try to set format with debug
  PrintStr("Setting format...\n");
  
  var paramsPtr: int64;
  paramsPtr := mmap(0, 8, 3, 34, -1, 0);
  
  if (paramsPtr == 0) {
    ALSAClose(handle);
    PrintStr("ERROR: mmap failed\n");
    return 1;
  }
  
  result := snd_pcm_hw_params_malloc(paramsPtr);
  PrintStr("malloc result: ");
  PrintInt(result);
  PrintStr("\n");
  
  if (result != ALSA_OK) {
    ALSAClose(handle);
    munmap(paramsPtr, 8);
    PrintStr("ERROR: malloc failed\n");
    return 1;
  }
  
  var params: int64;
  params := peek64(paramsPtr);
  PrintStr("params: ");
  PrintInt(params);
  PrintStr("\n");
  
  // Initialize
  result := snd_pcm_hw_params_any(handle, params);
  PrintStr("hw_params_any result: ");
  PrintInt(result);
  PrintStr("\n");
  
  // Try simpler operations
  if (result == ALSA_OK) {
    // Set access
    result := snd_pcm_hw_params_set_access(handle, params, SND_PCM_ACCESS_RW_INTERLEAVED);
    PrintStr("set_access result: ");
    PrintInt(result);
    PrintStr("\n");
  }
  
  snd_pcm_hw_params_free(params);
  munmap(paramsPtr, 8);
  ALSAClose(handle);
  
  PrintStr("=== Done ===\n");
  return 0;
}
