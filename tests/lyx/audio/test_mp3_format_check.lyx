// Test: Check actual MP3 format
import std.audio;
import std.audio.mpg123;

pub fn main(): int64 {
  PrintStr("=== MP3 Format Check ===\n");
  
  mpg123_init();
  var handle: int64;
  handle := mpg123_new(0, 0);
  
  // Open WITHOUT fixed format first
  var res: int64;
  res := mpg123_open(handle, "/home/andreas/PhpstormProjects/aurum/music_test.mp3");
  
  PrintStr("Open result: ");
  PrintInt(res);
  PrintStr("\n");
  
  // Allocate pointers for format query
  var ratePtr: int64;
  var chanPtr: int64;
  var encPtr: int64;
  ratePtr := mmap(0, 8, 3, 34, -1, 0);
  chanPtr := mmap(0, 8, 3, 34, -1, 0);
  encPtr := mmap(0, 8, 3, 34, -1, 0);
  
  // Query format
  res := mpg123_getformat(handle, ratePtr, chanPtr, encPtr);
  
  PrintStr("GetFormat result: ");
  PrintInt(res);
  PrintStr("\n");
  
  if (res == MPG123_OK or res == MPG123_NEW_FORMAT) {
    var rate: int64;
    rate := peek64(ratePtr);
    var channels: int64;
    channels := peek64(chanPtr);
    var encoding: int64;
    encoding := peek64(encPtr);
    
    PrintStr("Sample Rate: ");
    PrintInt(rate);
    PrintStr(" Hz\n");
    
    PrintStr("Channels: ");
    PrintInt(channels);
    PrintStr("\n");
    
    PrintStr("Encoding: ");
    PrintInt(encoding);
    PrintStr("\n");
    
    // Check what encoding value means
    if (encoding == 4) {
      PrintStr("Encoding = 4 = SIGNED_16\n");
    } else if (encoding == 1) {
      PrintStr("Encoding = 1 = UNSIGNED_8\n");
    } else if (encoding == 2) {
      PrintStr("Encoding = 2 = SIGNED_8\n");
    }
  }
  
  munmap(ratePtr, 8);
  munmap(chanPtr, 8);
  munmap(encPtr, 8);
  
  mpg123_close(handle);
  mpg123_delete(handle);
  mpg123_exit();
  
  PrintStr("=== Done ===\n");
  return 0;
}
