// Test WAVParse
import std.audio;

pub fn main(): int64 {
  var info: AudioInfo;
  var r: int64;
  
  r := WAVParse("/home/andreas/PhpstormProjects/aurum/test.wav", info);
  
  if (r == AUDIO_OK) {
    PrintStr("WAV OK!\n");
    PrintStr("Rate: ");
    PrintInt(info.sampleRate);
    PrintStr(" Hz\n");
    PrintStr("Channels: ");
    PrintInt(info.channels);
    PrintStr("\n");
    PrintStr("Bits: ");
    PrintInt(info.bitsPerSample);
    PrintStr("\n");
    PrintStr("Duration: ");
    PrintInt(info.durationMs);
    PrintStr(" ms\n");
  } else {
    PrintStr("Failed: ");
    PrintInt(r);
    PrintStr("\n");
  }
  
  return 0;
}