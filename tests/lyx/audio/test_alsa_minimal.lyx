// Test: Minimal WAV parsing and ALSA open test
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  var wavPath: pchar := "/tmp/playback_30s.wav";
  PrintStr("=== Minimal ALSA Test ===\n");

  // Open file
  var fd: int64;
  fd := open(wavPath, 0, 0);
  if (fd < 0) {
    PrintStr("ERROR: Cannot open file\n");
    return 1;
  }
  PrintStr("File opened, fd="); PrintInt(fd); PrintStr("\n");

  // Read first 44 bytes
  var hdr: int64;
  hdr := mmap(0, 44, 3, 34, -1, 0);
  var bytesRead: int64;
  bytesRead := sys_read(fd, hdr, 44);
  close(fd);
  PrintStr("Read header: "); PrintInt(bytesRead); PrintStr(" bytes\n");
  
  if (bytesRead < 44) {
    PrintStr("ERROR: Short read\n");
    return 1;
  }

  // Parse key values
  var sampleRate: int64;
  sampleRate := peek8(hdr + 24) | (peek8(hdr + 25) << 8) | (peek8(hdr + 26) << 16) | (peek8(hdr + 27) << 24);
  var channels: int64;
  channels := peek8(hdr + 22) | (peek8(hdr + 23) << 8);
  var dataSize: int64;
  dataSize := peek8(hdr + 40) | (peek8(hdr + 41) << 8) | (peek8(hdr + 42) << 16) | (peek8(hdr + 43) << 24);
  
  PrintStr("Sample Rate: "); PrintInt(sampleRate); PrintStr(" Hz\n");
  PrintStr("Channels: "); PrintInt(channels); PrintStr("\n");
  PrintStr("Data size: "); PrintInt(dataSize); PrintStr(" bytes\n");
  
  munmap(hdr, 44);
  
  // Try ALSA open
  PrintStr("Opening ALSA...\n");
  var hp: int64;
  hp := mmap(0, 8, 3, 34, -1, 0);
  var res: int64;
  res := snd_pcm_open(hp, "hw:0", 0, 0);
  PrintStr("ALSA open result: "); PrintInt(res); PrintStr("\n");
  
  if (res != 0) {
    PrintStr("ERROR: Cannot open ALSA\n");
    munmap(hp, 8);
    return 1;
  }
  
  var alsaHandle: int64;
  alsaHandle := peek64(hp);
  PrintStr("ALSA handle: "); PrintInt(alsaHandle); PrintStr("\n");
  munmap(hp, 8);
  
  snd_pcm_close(alsaHandle);
  PrintStr("=== Done ===\n");
  return 0;
}