// Simple 1-second 440Hz sine wave test
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== Simple 440Hz test ===\n");
  
  var sampleRate: int64 := 48000;
  var bytesPerFrame: int64 := 4;
  var oneSec: int64 := sampleRate * bytesPerFrame;
  
  var buf: int64;
  buf := mmap(0, oneSec, 3, 34, -1, 0);
  
  // Generate 440Hz sine wave
  var i: int64 := 0;
  while (i < sampleRate) {
    var phase: int64 := (i * 440 * 6283) / sampleRate;
    phase := phase % 6284;
    
    // Simple sin approximation
    var val: int64;
    if (phase < 3142) {
      val := (phase * 32768) / 3142 - 32768;
    } else {
      val := ((6284 - phase) * 32768) / 3142 - 32768;
    }
    
    val := (val * 20000) / 32768;
    
    var offset: int64 := i * 4;
    var s: int64 := val;
    if (s < 0) { s := s + 65536; }
    
    poke8(buf + offset, s & 255);
    poke8(buf + offset + 1, (s >> 8) & 255);
    poke8(buf + offset + 2, s & 255);
    poke8(buf + offset + 3, (s >> 8) & 255);
    
    i := i + 1;
  }
  
// Open ALSA
   var alsaHandleStorage: int64;
   var res: int64;
   res := snd_pcm_open(@alsaHandleStorage, "hw:0", 0, 0);
   
   if (res != 0) {
     PrintStr("Open failed: "); PrintInt(res); PrintStr("\n");
     return 1;
   }
   
   var alsaHandle: int64;
   alsaHandle := peek64(@alsaHandleStorage);
  
  var pp: int64;
  pp := mmap(0, 8, 3, 34, -1, 0);
  snd_pcm_hw_params_malloc(pp);
  var params: int64;
  params := peek64(pp);
  
  snd_pcm_hw_params_any(handle, params);
  snd_pcm_hw_params_set_access(handle, params, 3);
  snd_pcm_hw_params_set_format(handle, params, 2);
  
  var ratePtr: int64;
  ratePtr := mmap(0, 8, 3, 34, -1, 0);
  poke32(ratePtr, sampleRate);
  snd_pcm_hw_params_set_rate_near(handle, params, ratePtr, 0);
  var actualRate: int64;
  actualRate := peek32(ratePtr);
  munmap(ratePtr, 8);
  
  snd_pcm_hw_params_set_channels(handle, params, 2);
  res := snd_pcm_hw_params(handle, params);
  
  if (res != 0) {
    PrintStr("Params failed: "); PrintInt(res); PrintStr("\n");
    return 1;
  }
  
  snd_pcm_hw_params_free(params);
  munmap(pp, 8);
  
  PrintStr("Playing 1 second 440Hz tone...\n");
  PrintStr("(This should take ~1 second to complete...)\n");
  res := snd_pcm_writei(handle, buf, sampleRate);
  PrintStr("Written: "); PrintInt(res); PrintStr("\n");
  
  PrintStr("Now draining (should wait for playback)...\n");
  snd_pcm_drain(handle);
  PrintStr("Drain done\n");
  snd_pcm_close(handle);
  munmap(buf, oneSec);
  
  PrintStr("=== Done ===\n");
  return 0;
}