// Test mpg123 - just open file
import std.audio;
import std.audio.mpg123;

pub fn main(): int64 {
  PrintStr("=== mpg123 Open Test ===\n");
  
  // Step 1: Initialize
  mpg123_init();
  
  // Step 2: Create handle
  var handle: int64;
  handle := mpg123_new(0, 0);
  
  if (handle == 0) {
    PrintStr("ERROR: new failed\n");
    mpg123_exit();
    return 1;
  }
  PrintStr("handle=");
  PrintInt(handle);
  PrintStr("\n");
  
  // Step 3: Open file
  PrintStr("3. mpg123_open...\n");
  var openRes: int64;
  openRes := mpg123_open(handle, "/home/andreas/PhpstormProjects/aurum/music_test.mp3");
  PrintStr("openRes=");
  PrintInt(openRes);
  PrintStr("\n");
  
  if (openRes != MPG123_OK) {
    PrintStr("ERROR: open failed\n");
    mpg123_delete(handle);
    mpg123_exit();
    return 1;
  }
  
  // Step 4: Cleanup
  PrintStr("4. cleanup...\n");
  mpg123_close(handle);
  mpg123_delete(handle);
  mpg123_exit();
  
  PrintStr("=== Complete ===\n");
  return 0;
}
