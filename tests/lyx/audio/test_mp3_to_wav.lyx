// Test: MP3 to WAV conversion
// This test includes the MP3ToWAV function inline since imports in functions don't work
import std.audio;
import std.audio.mpg123;

pub fn MP3ToWAVTest(mp3Path: pchar, wavPath: pchar): int64 {
  // Initialize
  mpg123_init();
  var handle: int64;
  handle := mpg123_new(0, 0);
  
  if (handle == 0) {
    mpg123_exit();
    return AUDIO_ERROR;
  }
  
  // Open MP3 file
  var res: int64;
  res := mpg123_open_fixed(handle, mp3Path, 2, MPG123_ENC_SIGNED_16);
  
  if (res != MPG123_OK) {
    mpg123_delete(handle);
    mpg123_exit();
    return AUDIO_ERROR;
  }
  
  // Allocate buffer for decoded audio
  var buf: int64;
  buf := mmap(0, 10485760, 3, 34, -1, 0);  // 10MB max
  
  if (buf == 0) {
    mpg123_close(handle);
    mpg123_delete(handle);
    mpg123_exit();
    return AUDIO_ERROR;
  }
  
  // Decode
  var done: int64;
  done := mmap(0, 8, 3, 34, -1, 0);
  var total: int64;
  total := 0;
  
  while (total < 10485760) {
    res := mpg123_read(handle, buf + total, 16384, done);
    
    // MPG123_DONE means no more data
    if (res == MPG123_DONE) {
      break;
    }
    // Only error if negative AND not DONE or NEW_FORMAT
    if (res < 0 and res != MPG123_NEW_FORMAT) {
      PrintStr("MP3 decode error: ");
      PrintInt(res);
      PrintStr("\n");
      munmap(buf, 10485760);
      munmap(done, 8);
      mpg123_close(handle);
      mpg123_delete(handle);
      mpg123_exit();
      return AUDIO_ERROR;
    }
    
    // Conservative estimate - assume some data was decoded
    total := total + 4096;
  }
  
  PrintStr("Decoded ");
  PrintInt(total);
  PrintStr(" bytes\n");
  
  // Save as WAV (44100 Hz, stereo, 16-bit)
  res := WAVSaveFile(wavPath, buf, total, 44100, 2, 16);
  
  // Cleanup
  munmap(buf, 10485760);
  munmap(done, 8);
  mpg123_close(handle);
  mpg123_delete(handle);
  mpg123_exit();
  
  return res;
}

pub fn main(): int64 {
  PrintStr("=== MP3 to WAV Test ===\n");
  
  var result: int64;
  result := MP3ToWAVTest("/home/andreas/PhpstormProjects/aurum/music_test.mp3", "/tmp/test_output.wav");
  
  if (result == 0) {
    PrintStr("SUCCESS: WAV file created!\n");
  } else {
    PrintStr("ERROR: ");
    PrintInt(result);
    PrintStr("\n");
  }
  
  PrintStr("=== Done ===\n");
  return 0;
}
