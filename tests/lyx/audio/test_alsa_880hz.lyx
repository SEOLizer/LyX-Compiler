// Test: Generate known tone and play to verify pitch
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== ALSA: 880Hz tone test (A above middle C) ===\n");
  
  var sampleRate: int64 := 48000;
  var channels: int64 := 2;
  var duration: int64 := 2; // 2 seconds
  
  var totalBytes: int64 := sampleRate * duration * 4; // 4 bytes/frame
  var playBuf: int64;
  playBuf := mmap(0, totalBytes, 3, 34, -1, 0);
  
  // Generate 880Hz sine wave (A above middle C)
  var freq: int64 := 880;
  var i: int64 := 0;
  
  while (i < sampleRate * duration) {
    // Simple sine: sin(2*PI*880*t)
    // Using integer math approximation
    var phase: int64 := (i * freq * 6283) / sampleRate; // 2*PI*freq/sampleRate
    phase := phase % 6284;
    
    // Simple triangle wave approximation for simplicity
    var val: int64;
    if (phase < 3142) {
      val := (phase * 32768) / 3142 - 32768;
    } else {
      val := ((6284 - phase) * 32768) / 3142 - 32768;
    }
    
    // Clamp
    if (val > 30000) { val := 30000; }
    if (val < -30000) { val := -30000; }
    
    // Write to buffer (stereo)
    var offset: int64 := i * 4;
    var sample: int64 := val;
    
    // Little endian 16-bit
    if (sample < 0) {
      sample := sample + 65536;
    }
    
    poke8(playBuf + offset, sample & 255);
    poke8(playBuf + offset + 1, (sample >> 8) & 255);
    poke8(playBuf + offset + 2, sample & 255);
    poke8(playBuf + offset + 3, (sample >> 8) & 255);
    
    i := i + 1;
  }
  
  PrintStr("Generated 880Hz tone, 2 seconds\n");
  
  // Open ALSA
  var hp: int64;
  hp := mmap(0, 8, 3, 34, -1, 0);
  var res: int64;
  res := snd_pcm_open(hp, "hw:0", 0, 0);
  
  if (res != 0) {
    PrintStr("Open failed: "); PrintInt(res); PrintStr("\n");
    return 1;
  }
  
  var alsaHandle: int64;
  alsaHandle := peek64(hp);
  munmap(hp, 8);
  
  // Set params
  var pp: int64;
  pp := mmap(0, 8, 3, 34, -1, 0);
  snd_pcm_hw_params_malloc(pp);
  var params: int64;
  params := peek64(pp);

  snd_pcm_hw_params_any(alsaHandle, params);
  snd_pcm_hw_params_set_access(alsaHandle, params, 3);
  snd_pcm_hw_params_set_format(alsaHandle, params, 2);
  
  var ratePtr: int64;
  ratePtr := mmap(0, 8, 3, 34, -1, 0);
  poke32(ratePtr, sampleRate);
  snd_pcm_hw_params_set_rate_near(alsaHandle, params, ratePtr, 0);
  var actualRate: int64;
  actualRate := peek32(ratePtr);
  munmap(ratePtr, 8);
  
  PrintStr("Rate: "); PrintInt(actualRate); PrintStr(" Hz\n");
  
  snd_pcm_hw_params_set_channels(alsaHandle, params, channels);
  res := snd_pcm_hw_params(alsaHandle, params);
  
  if (res != 0) {
    PrintStr("Params failed: "); PrintInt(res); PrintStr("\n");
    return 1;
  }
  
  snd_pcm_hw_params_free(params);
  munmap(pp, 8);
  
  PrintStr("Playing 2 seconds...\n");
  
  res := snd_pcm_writei(alsaHandle, playBuf, sampleRate * duration);
  PrintStr("Written: "); PrintInt(res); PrintStr(" frames\n");
  
  PrintStr("Draining...\n");
  snd_pcm_drain(alsaHandle);
  PrintStr("Done\n");
  
  snd_pcm_close(alsaHandle);
  munmap(playBuf, totalBytes);
  
  PrintStr("=== Done ===\n");
  return 0;
}