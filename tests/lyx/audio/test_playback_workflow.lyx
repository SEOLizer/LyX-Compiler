// Test: Complete MP3 to WAV to Playback workflow
import std.audio;
import std.audio.mpg123;

pub fn main(): int64 {
  PrintStr("=== MP3 Decode & Playback Test ===\n");
  
  var mp3Path: pchar := "/home/andreas/PhpstormProjects/aurum/music_test.mp3";
  var wavPath: pchar := "/tmp/playback_test.wav";
  
  // Step 1: Decode MP3 to WAV
  PrintStr("1. Decoding MP3 to WAV...\n");
  
  mpg123_init();
  var handle: int64;
  handle := mpg123_new(0, 0);
  
  if (handle == 0) {
    PrintStr("ERROR: Failed to create mpg123 handle\n");
    mpg123_exit();
    return 1;
  }
  
  var res: int64;
  res := mpg123_open_fixed(handle, mp3Path, 2, 4);
  
  if (res != MPG123_OK) {
    PrintStr("ERROR: Failed to open MP3\n");
    mpg123_delete(handle);
    mpg123_exit();
    return 1;
  }
  
  // Allocate buffer
  var buf: int64;
  buf := mmap(0, 10485760, 3, 34, -1, 0);
  var done: int64;
  done := mmap(0, 8, 3, 34, -1, 0);
  
  var total: int64;
  total := 0;
  
  while (total < 10485760) {
    res := mpg123_read(handle, buf + total, 16384, done);
    
    if (res == MPG123_DONE) {
      break;
    }
    if (res < 0 and res != MPG123_NEW_FORMAT) {
      PrintStr("Decode error: ");
      PrintInt(res);
      PrintStr("\n");
      munmap(buf, 10485760);
      munmap(done, 8);
      mpg123_close(handle);
      mpg123_delete(handle);
      mpg123_exit();
      return 1;
    }
    
    total := total + 4096;
  }
  
  PrintStr("Decoded ");
  PrintInt(total);
  PrintStr(" bytes\n");
  
  // Save as WAV
  res := WAVSaveFile(wavPath, buf, total, 44100, 2, 16);
  
  munmap(buf, 10485760);
  munmap(done, 8);
  mpg123_close(handle);
  mpg123_delete(handle);
  mpg123_exit();
  
  if (res != 0) {
    PrintStr("ERROR: Failed to save WAV\n");
    return 1;
  }
  
  PrintStr("2. WAV file created: ");
  PrintStr(wavPath);
  PrintStr("\n");
  
  // Step 2: Playback info
  PrintStr("3. File info:\n");
  var fd: int64;
  fd := open(wavPath, 0, 0);
  if (fd >= 0) {
    var fsize: int64;
    fsize := lseek(fd, 0, SEEK_END);
    close(fd);
    PrintStr("   Size: ");
    PrintInt(fsize);
    PrintStr(" bytes\n");
    PrintStr("   Format: 16-bit stereo 44100 Hz PCM\n");
  }
  
  PrintStr("\n=== To play, run: ===\n");
  PrintStr("  aplay ");
  PrintStr(wavPath);
  PrintStr("\n");
  PrintStr("  # or\n");
  PrintStr("  paplay ");
  PrintStr(wavPath);
  PrintStr("\n");
  
  PrintStr("=== Done ===\n");
  return 0;
}
