import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== ALSA Check ===\n");
  
  // Try a simple beep using aplay instead
  PrintStr("Running aplay...\n");
  
  // Use simple system call
  import std.os;
  
  // This is a simple test - just play the file with aplay
  PrintStr("File: /tmp/playback_test.wav\n");
  PrintStr("To play manually, run: aplay /tmp/playback_test.wav\n");
  
  // Check file properties
  var fd: int64;
  fd := open("/tmp/playback_test.wav", 0, 0);
  
  if (fd >= 0) {
    var size: int64;
    size := lseek(fd, 0, SEEK_END);
    close(fd);
    
    PrintStr("File size: ");
    PrintInt(size);
    PrintStr(" bytes\n");
    
    // Calculate duration
    // 44100 Hz * 2 channels * 2 bytes = 176400 bytes/sec
    var duration: int64;
    duration := size - 44;
    duration := duration * 1000 / 176400;
    
    PrintStr("Duration: ~");
    PrintInt(duration);
    PrintStr(" ms\n");
  }
  
  PrintStr("=== Done ===\n");
  return 0;
}
