// Test: Generate simple sine wave tone
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== ALSA: Sine wave tone ===\n");
  
  var sampleRate: int64 := 48000;
  var channels: int64 := 2;
  var bitsPerSample: int64 := 16;
  var duration: int64 := 2; // 2 seconds
  
  var bytesPerSample: int64 := bitsPerSample / 8;
  var bytesPerFrame: int64 := channels * bytesPerSample;
  var totalBytes: int64 := sampleRate * duration * bytesPerFrame;
  
  PrintStr("Generating "); PrintInt(duration); PrintStr(" sec sine wave...\n");
  
  // Allocate buffer
  var playBuf: int64;
  playBuf := mmap(0, totalBytes, 3, 34, -1, 0);
  
  // Generate 440Hz sine wave
  var freq: int64 := 440;
  var amplitude: int64 := 16000;
  var i: int64 := 0;
  
  while (i < sampleRate * duration) {
    // Calculate sine value
    var t: int64 := i * 6283; // 2*PI*440 ≈ 6283
    t := t / sampleRate;
    
    // Simple approximation: sin(t) ≈ t - t³/6 + t⁵/120
    var x: int64 := t % 6284;
    if (x > 3142) {
      x := x - 6284;
    }
    x := x / 100; // Scale down
    
    // Sine approximation
    var sinVal: int64 := x - (x * x * x) / 6000000 + (x * x * x * x * x) / 120000000;
    sinVal := (sinVal * amplitude) / 1000;
    
    // Write stereo (same sample on both channels)
    var sample: int64 := sinVal;
    
    // Left channel
    var ptr: int64 := playBuf + (i * bytesPerFrame);
    var low: int64 := sample & 255;
    var high: int64 := (sample >> 8) & 255;
    poke8(ptr, low);
    poke8(ptr + 1, high);
    
    // Right channel  
    ptr := playBuf + (i * bytesPerFrame) + 2;
    poke8(ptr, low);
    poke8(ptr + 1, high);
    
    i := i + 1;
  }
  
  PrintStr("Generated "); PrintInt(sampleRate * duration); PrintStr(" frames\n");
  
  // Open ALSA
  var hp: int64;
  hp := mmap(0, 8, 3, 34, -1, 0);
  var res: int64;
  res := snd_pcm_open(hp, "hw:0", 0, 0);
  
  if (res != 0) {
    PrintStr("ERROR: Cannot open ALSA: "); PrintInt(res); PrintStr("\n");
    munmap(playBuf, totalBytes);
    return 1;
  }
  
  var alsaHandle: int64;
  alsaHandle := peek64(hp);
  munmap(hp, 8);
  
  // Set params
  var pp: int64;
  pp := mmap(0, 8, 3, 34, -1, 0);
  snd_pcm_hw_params_malloc(pp);
  var params: int64;
  params := peek64(pp);

  snd_pcm_hw_params_any(alsaHandle, params);
  snd_pcm_hw_params_set_access(alsaHandle, params, 3);
  snd_pcm_hw_params_set_format(alsaHandle, params, 2);
  
  var ratePtr: int64;
  ratePtr := mmap(0, 8, 3, 34, -1, 0);
  poke32(ratePtr, sampleRate);
  snd_pcm_hw_params_set_rate_near(alsaHandle, params, ratePtr, 0);
  var actualRate: int64;
  actualRate := peek32(ratePtr);
  munmap(ratePtr, 8);
  
  PrintStr("Rate: "); PrintInt(actualRate); PrintStr(" Hz\n");
  
  snd_pcm_hw_params_set_channels(alsaHandle, params, channels);
  res := snd_pcm_hw_params(alsaHandle, params);
  
  if (res != 0) {
    PrintStr("ERROR: Cannot set params: "); PrintInt(res); PrintStr("\n");
    return 1;
  }
  
  snd_pcm_hw_params_free(params);
  munmap(pp, 8);
  
  // Play
  var frames: int64 := sampleRate * duration;
  PrintStr("Playing "); PrintInt(frames); PrintStr(" frames...\n");
  
  res := snd_pcm_writei(alsaHandle, playBuf, frames);
  
  PrintStr("Written: "); PrintInt(res); PrintStr(" frames\n");
  
  snd_pcm_drain(alsaHandle);
  snd_pcm_close(alsaHandle);
  munmap(playBuf, totalBytes);
  
  PrintStr("=== Done ===\n");
  return 0;
}