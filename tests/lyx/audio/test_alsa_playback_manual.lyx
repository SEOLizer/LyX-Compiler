// Test: ALSA playback - with proper timing (chunked writes)
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== ALSA Playback (Chunked) ===\n");
  
  // Load WAV file
  var wavPath: pchar := "/tmp/playback_test.wav";
  
  var fd: int64;
  fd := open(wavPath, 0, 0);
  lseek(fd, 44, SEEK_SET);
  var fsize: int64;
  fsize := lseek(fd, 0, SEEK_END);
  var dataSize: int64;
  dataSize := fsize - 44;
  close(fd);
  
  fd := open(wavPath, 0, 0);
  lseek(fd, 44, SEEK_SET);
  
  var buffer: int64;
  buffer := mmap(0, dataSize, 3, 34, -1, 0);
  sys_read(fd, buffer, dataSize);
  close(fd);
  
  PrintStr("Loaded ");
  PrintInt(dataSize);
  PrintStr(" bytes\n");
  
  // Open ALSA device
  var handlePtr: int64;
  handlePtr := mmap(0, 8, 3, 34, -1, 0);
  var result: int64;
  result := snd_pcm_open(handlePtr, "hw:0", SND_PCM_STREAM_PLAYBACK, 0);
  
  if (result != ALSA_OK) {
    PrintStr("ERROR: Cannot open ALSA\n");
    return 1;
  }
  
  var handle: int64;
  handle := peek64(handlePtr);
  munmap(handlePtr, 8);
  
  // Setup params step by step
  var paramsPtr: int64;
  paramsPtr := mmap(0, 8, 3, 34, -1, 0);
  result := snd_pcm_hw_params_malloc(paramsPtr);
  
  var params: int64;
  params := peek64(paramsPtr);
  
  snd_pcm_hw_params_any(handle, params);
  snd_pcm_hw_params_set_access(handle, params, SND_PCM_ACCESS_RW_INTERLEAVED);
  snd_pcm_hw_params_set_format(handle, params, SND_PCM_FORMAT_S16_LE);
  snd_pcm_hw_params_set_rate_near(handle, params, 44100, 0);
  snd_pcm_hw_params_set_channels(handle, params, 2);
  result := snd_pcm_hw_params(handle, params);
  
  snd_pcm_hw_params_free(params);
  munmap(paramsPtr, 8);
  
  if (result != ALSA_OK) {
    snd_pcm_close(handle);
    PrintStr("ERROR: hw_params failed\n");
    return 1;
  }
  
  PrintStr("Playing in chunks...\n");
  
  // Write in chunks of ~0.1 seconds
  // 44100 * 2 channels * 2 bytes = 176400 bytes per second
  // 0.1 second = 17640 bytes per chunk
  var chunkSize: int64;
  chunkSize := 17640;
  
  var offset: int64;
  offset := 0;
  
  while (offset < dataSize) {
    var toWrite: int64;
    toWrite := chunkSize;
    if (offset + toWrite > dataSize) {
      toWrite := dataSize - offset;
    }
    
    var frames: int64;
    frames := toWrite / 4;
    
    var written: int64;
    written := snd_pcm_writei(handle, buffer + offset, frames);
    
    if (written < 0) {
      PrintStr("Write error: ");
      PrintInt(written);
      PrintStr("\n");
      break;
    }
    
    offset := offset + (written * 4);
    
    // Print progress every ~1MB
    if (offset / 1048576 != (offset - toWrite) / 1048576) {
      PrintStr("Progress: ");
      PrintInt(offset / 1048576);
      PrintStr(" MB\n");
    }
  }
  
  PrintStr("Draining...\n");
  snd_pcm_drain(handle);
  snd_pcm_close(handle);
  munmap(buffer, dataSize);
  
  PrintStr("=== Done ===\n");
  return 0;
}
