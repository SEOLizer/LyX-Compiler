// Test: ALSA playback - step by step without wrapper
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== ALSA Playback Manual ===\n");
  
  // Load WAV file
  var wavPath: pchar := "/tmp/playback_test.wav";
  
  var fd: int64;
  fd := open(wavPath, 0, 0);
  lseek(fd, 44, SEEK_SET);
  var fsize: int64;
  fsize := lseek(fd, 0, SEEK_END);
  var dataSize: int64;
  dataSize := fsize - 44;
  close(fd);
  
  fd := open(wavPath, 0, 0);
  lseek(fd, 44, SEEK_SET);
  
  var buffer: int64;
  buffer := mmap(0, dataSize, 3, 34, -1, 0);
  sys_read(fd, buffer, dataSize);
  close(fd);
  
  PrintStr("Loaded ");
  PrintInt(dataSize);
  PrintStr(" bytes\n");
  
  // Open ALSA device
  var handlePtr: int64;
  handlePtr := mmap(0, 8, 3, 34, -1, 0);
  var result: int64;
  result := snd_pcm_open(handlePtr, "default", SND_PCM_STREAM_PLAYBACK, 0);
  
  if (result != ALSA_OK) {
    PrintStr("ERROR: Cannot open ALSA\n");
    return 1;
  }
  
  var handle: int64;
  handle := peek64(handlePtr);
  munmap(handlePtr, 8);
  
  PrintStr("Handle: ");
  PrintInt(handle);
  PrintStr("\n");
  
  // Setup params step by step (like debug test)
  var paramsPtr: int64;
  paramsPtr := mmap(0, 8, 3, 34, -1, 0);
  result := snd_pcm_hw_params_malloc(paramsPtr);
  
  if (result != ALSA_OK) {
    snd_pcm_close(handle);
    munmap(paramsPtr, 8);
    PrintStr("ERROR: malloc failed\n");
    return 1;
  }
  
  var params: int64;
  params := peek64(paramsPtr);
  
  result := snd_pcm_hw_params_any(handle, params);
  PrintStr("hw_params_any: ");
  PrintInt(result);
  PrintStr("\n");
  
  result := snd_pcm_hw_params_set_access(handle, params, SND_PCM_ACCESS_RW_INTERLEAVED);
  PrintStr("set_access: ");
  PrintInt(result);
  PrintStr("\n");
  
  result := snd_pcm_hw_params_set_format(handle, params, SND_PCM_FORMAT_S16_LE);
  PrintStr("set_format: ");
  PrintInt(result);
  PrintStr("\n");
  
  result := snd_pcm_hw_params_set_rate_near(handle, params, 44100, 0);
  PrintStr("set_rate: ");
  PrintInt(result);
  PrintStr("\n");
  
  result := snd_pcm_hw_params_set_channels(handle, params, 2);
  PrintStr("set_channels: ");
  PrintInt(result);
  PrintStr("\n");
  
  result := snd_pcm_hw_params(handle, params);
  PrintStr("hw_params: ");
  PrintInt(result);
  PrintStr("\n");
  
  if (result != ALSA_OK) {
    snd_pcm_hw_params_free(params);
    munmap(paramsPtr, 8);
    snd_pcm_close(handle);
    PrintStr("ERROR: hw_params failed\n");
    return 1;
  }
  
  snd_pcm_hw_params_free(params);
  munmap(paramsPtr, 8);
  
  PrintStr("Format set successfully!\n");
  PrintStr("Playing audio...\n");
  
  // Write audio
  var frames: int64;
  frames := dataSize / 4;
  var written: int64;
  written := snd_pcm_writei(handle, buffer, frames);
  
  PrintStr("Written frames: ");
  PrintInt(written);
  PrintStr("\n");
  
  snd_pcm_drain(handle);
  snd_pcm_close(handle);
  munmap(buffer, dataSize);
  
  PrintStr("=== Done ===\n");
  return 0;
}
