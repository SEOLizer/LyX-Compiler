// Test: Just play 1 frame and verify timing
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== ALSA: 1 frame test ===\n");
  
  // Generate tiny buffer: 1 frame = 4 bytes (2 channels * 16 bits / 8)
  var playBuf: int64;
  playBuf := mmap(0, 4, 3, 34, -1, 0);
  
  // Write some test pattern
  poke8(playBuf + 0, 0);
  poke8(playBuf + 1, 0);
  poke8(playBuf + 2, 0);
  poke8(playBuf + 3, 0);
  
  // Open ALSA
  var hp: int64;
  hp := mmap(0, 8, 3, 34, -1, 0);
  var res: int64;
  res := snd_pcm_open(hp, "hw:0", 0, 0);
  
  if (res != 0) {
    PrintStr("ERROR: Cannot open ALSA: "); PrintInt(res); PrintStr("\n");
    return 1;
  }
  
  var alsaHandle: int64;
  alsaHandle := peek64(hp);
  munmap(hp, 8);
  
  // Set params
  var pp: int64;
  pp := mmap(0, 8, 3, 34, -1, 0);
  snd_pcm_hw_params_malloc(pp);
  var params: int64;
  params := peek64(pp);

  snd_pcm_hw_params_any(alsaHandle, params);
  snd_pcm_hw_params_set_access(alsaHandle, params, 3);
  snd_pcm_hw_params_set_format(alsaHandle, params, 2);
  
  var ratePtr: int64;
  ratePtr := mmap(0, 8, 3, 34, -1, 0);
  poke32(ratePtr, 48000);
  snd_pcm_hw_params_set_rate_near(alsaHandle, params, ratePtr, 0);
  var actualRate: int64;
  actualRate := peek32(ratePtr);
  munmap(ratePtr, 8);
  
  snd_pcm_hw_params_set_channels(alsaHandle, params, 2);
  res := snd_pcm_hw_params(alsaHandle, params);
  
  if (res != 0) {
    PrintStr("ERROR: Cannot set params: "); PrintInt(res); PrintStr("\n");
    return 1;
  }
  
  snd_pcm_hw_params_free(params);
  munmap(pp, 8);
  
  // Play 1 frame - this should take 1/48000 sec ≈ 20 microseconds
  PrintStr("Playing 1 frame at "); PrintInt(actualRate); PrintStr(" Hz...\n");
  PrintStr("Expected duration: ~20 microseconds\n");
  
  var startTime: int64;
  var endTime: int64;
  
  // Get start time - we'll approximate with a counter
  var counter: int64 := 0;
  startTime := counter;
  
  res := snd_pcm_writei(alsaHandle, playBuf, 1);
  
  // Burn some CPU cycles
  counter := 0;
  while (counter < 10000000) {
    counter := counter + 1;
  }
  endTime := counter;
  
  PrintStr("Written: "); PrintInt(res); PrintStr(" frames\n");
  PrintStr("Done burning cycles\n");
  
  snd_pcm_close(alsaHandle);
  munmap(playBuf, 4);
  
  PrintStr("=== Done ===\n");
  return 0;
}