// Test struct pass by reference vs value
import std.audio;

pub fn testModify(info: AudioInfo): int64 {
  info.format := 123;
  info.sampleRate := 456;
  return 0;
}

pub fn main(): int64 {
  var info: AudioInfo;
  
  info.format := 100;
  info.sampleRate := 200;
  
  PrintStr("Before call: format=");
  PrintInt(info.format);
  PrintStr(" sr=");
  PrintInt(info.sampleRate);
  PrintStr("\n");
  
  testModify(info);
  
  PrintStr("After call: format=");
  PrintInt(info.format);
  PrintStr(" sr=");
  PrintInt(info.sampleRate);
  PrintStr("\n");
  
  return 0;
}
