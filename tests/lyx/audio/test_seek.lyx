// Test lseek
pub fn main(): int64 {
  var path: pchar;
  path := "/home/andreas/PhpstormProjects/aurum/test.wav";
  
  var fd: int64;
  fd := open(path, O_RDONLY, 0);
  PrintStr("fd: ");
  PrintInt(fd);
  PrintStr("\n");
  
  if (fd < 0) {
    PrintStr("open failed\n");
    return 1;
  }
  
  var sz: int64;
  
  // Test 1: SEEK_END from current (beginning)
  sz := lseek(fd, 0, SEEK_END);
  PrintStr("SEEK_END: ");
  PrintInt(sz);
  PrintStr("\n");
  
  // Test 2: SEEK_SET
  var pos: int64;
  pos := lseek(fd, 0, SEEK_SET);
  PrintStr("SEEK_SET: ");
  PrintInt(pos);
  PrintStr("\n");
  
  // Test 3: SEEK_END again
  sz := lseek(fd, 0, SEEK_END);
  PrintStr("SEEK_END 2: ");
  PrintInt(sz);
  PrintStr("\n");
  
  close(fd);
  
  return 0;
}