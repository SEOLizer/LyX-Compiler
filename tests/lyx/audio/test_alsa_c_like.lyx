// Compare: Known working pattern from C code
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== ALSA: C-like pattern test ===\n");

  // Open ALSA like C code does
  var hp: int64;
  hp := mmap(0, 8, 3, 34, -1, 0);
  var res: int64;
  
  PrintStr("Opening ALSA...\n");
  res := snd_pcm_open(hp, "hw:0", 0, 0);
  PrintStr("Open result: "); PrintInt(res); PrintStr("\n");
  
  if (res != 0) {
    PrintStr("ERROR: Cannot open ALSA\n");
    return 1;
  }
  
  var alsaHandle: int64;
  alsaHandle := peek64(hp);
  PrintStr("Handle (from peek64): "); PrintInt(alsaHandle); PrintStr("\n");
  munmap(hp, 8);

  // Allocate params like C code
  PrintStr("Allocating params...\n");
  var pp: int64;
  pp := mmap(0, 8, 3, 34, -1, 0);
  snd_pcm_hw_params_malloc(pp);
  var params: int64;
  params := peek64(pp);
  PrintStr("Params allocated\n");

  // Set params - exact same order as C
  PrintStr("Setting params...\n");
  snd_pcm_hw_params_any(alsaHandle, params);
  snd_pcm_hw_params_set_access(alsaHandle, params, 3);  // RW_INTERLEAVED
  snd_pcm_hw_params_set_format(alsaHandle, params, 2);  // S16_LE
  
  var rate: int64 := 48000;
  var ratePtr: int64;
  ratePtr := mmap(0, 8, 3, 34, -1, 0);
  poke32(ratePtr, rate);
  snd_pcm_hw_params_set_rate_near(alsaHandle, params, ratePtr, 0);
  var actualRate: int64;
  actualRate := peek32(ratePtr);
  PrintStr("Rate requested: "); PrintInt(rate); PrintStr(", actual: "); PrintInt(actualRate); PrintStr("\n");
  munmap(ratePtr, 8);
  
  snd_pcm_hw_params_set_channels(alsaHandle, params, 2);
  
  res := snd_pcm_hw_params(alsaHandle, params);
  PrintStr("hw_params result: "); PrintInt(res); PrintStr("\n");
  
  if (res != 0) {
    PrintStr("ERROR: Cannot set params: "); PrintInt(res); PrintStr("\n");
    return 1;
  }
  
  snd_pcm_hw_params_free(params);
  munmap(pp, 8);
  PrintStr("Params set and freed\n");

  // Read audio data
  var fd: int64;
  fd := open("/tmp/playback_30s.wav", 0, 0);
  
  // Debug: check first few bytes of file
  var testBuf: int64;
  testBuf := mmap(0, 16, 3, 34, -1, 0);
  var testRead: int64;
  testRead := sys_read(fd, testBuf, 16);
  munmap(testBuf, 16);
  
  // Now read from offset 44
  lseek(fd, 44, SEEK_SET);
  
  var playBuf: int64;
  playBuf := mmap(0, 192000, 3, 34, -1, 0);
  var bytesRead: int64;
  bytesRead := sys_read(fd, playBuf, 192000);
  close(fd);
  
  PrintStr("Read "); PrintInt(bytesRead); PrintStr(" bytes\n");

  // Write exactly like C code
  PrintStr("Writing "); PrintInt(48000); PrintStr(" frames...\n");
  res := snd_pcm_writei(alsaHandle, playBuf, 48000);
  PrintStr("Write result: "); PrintInt(res); PrintStr(" frames\n");
  
  if (res < 0) {
    PrintStr("Write error: ");
    PrintInt(res); PrintStr("\n");
  }
  
  // Skip drain - just close immediately
  PrintStr("Closing...\n");
  snd_pcm_close(alsaHandle);
  
  munmap(playBuf, 192000);
  
  PrintStr("=== Done ===\n");
  return 0;
}