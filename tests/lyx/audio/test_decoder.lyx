// Test WAV Decoder
import std.audio;

pub fn main(): int64 {
  var info: AudioInfo;
  var result: int64;
  var data: int64;
  
  // Parse WAV
  result := WAVParse("/home/andreas/PhpstormProjects/aurum/test.wav", info);
  
  if (result == AUDIO_OK) {
    PrintStr("Parse OK!\n");
    PrintStr("Sample Rate: ");
    PrintInt(info.sampleRate);
    PrintStr(" Hz\n");
    PrintStr("Channels: ");
    PrintInt(info.channels);
    PrintStr("\n");
    PrintStr("Bits/Sample: ");
    PrintInt(info.bitsPerSample);
    PrintStr("\n");
    PrintStr("Data Offset: ");
    PrintInt(info.dataOffset);
    PrintStr("\n");
    PrintStr("Data Size: ");
    PrintInt(info.dataSize);
    PrintStr(" bytes\n");
    
    // Read audio data
    data := WAVReadData("/home/andreas/PhpstormProjects/aurum/test.wav", info);
    
    if (data != 0) {
      PrintStr("\nAudio data loaded!\n");
      PrintStr("First 8 bytes: ");
      PrintInt(peek8(data + 0));
      PrintStr(" ");
      PrintInt(peek8(data + 1));
      PrintStr(" ");
      PrintInt(peek8(data + 2));
      PrintStr(" ");
      PrintInt(peek8(data + 3));
      PrintStr(" ");
      PrintInt(peek8(data + 4));
      PrintStr(" ");
      PrintInt(peek8(data + 5));
      PrintStr(" ");
      PrintInt(peek8(data + 6));
      PrintStr(" ");
      PrintInt(peek8(data + 7));
      PrintStr("\n");
      
      munmap(data, info.dataSize);
    } else {
      PrintStr("Failed to load audio data\n");
    }
  } else {
    PrintStr("Parse failed: ");
    PrintInt(result);
    PrintStr("\n");
  }
  
  return 0;
}