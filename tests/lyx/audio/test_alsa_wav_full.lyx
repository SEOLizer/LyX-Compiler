// Test: Play WAV file via ALSA with full playback
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  var wavPath: pchar := "/tmp/playback_30s.wav";
  PrintStr("=== ALSA WAV Playback ===\n");

  // Open file
  var fd: int64;
  fd := open(wavPath, 0, 0);
  if (fd < 0) {
    PrintStr("ERROR: Cannot open file\n");
    return 1;
  }

  // Read header
  var hdr: int64;
  hdr := mmap(0, 44, 3, 34, -1, 0);
  var bytesRead: int64;
  bytesRead := sys_read(fd, hdr, 44);
  
  if (bytesRead < 44) {
    PrintStr("ERROR: Short header read\n");
    munmap(hdr, 44);
    close(fd);
    return 1;
  }

  var sampleRate: int64 := peek8(hdr + 24) | (peek8(hdr + 25) << 8) | (peek8(hdr + 26) << 16) | (peek8(hdr + 27) << 24);
  var channels: int64 := peek8(hdr + 22) | (peek8(hdr + 23) << 8);
  var bitsPerSample: int64 := peek8(hdr + 34) | (peek8(hdr + 35) << 8);
  var dataSize: int64 := peek8(hdr + 40) | (peek8(hdr + 41) << 8) | (peek8(hdr + 42) << 16) | (peek8(hdr + 43) << 24);
  munmap(hdr, 44);

  PrintStr("WAV: "); PrintInt(sampleRate); PrintStr("Hz, ");
  PrintInt(channels); PrintStr("ch, "); PrintInt(bitsPerSample); PrintStr("bit, ");
  PrintInt(dataSize); PrintStr(" bytes\n");

  // Read PCM data - limit to first 1MB for safety
  var readSize: int64 := dataSize;
  if (readSize > 1048576) {
    readSize := 1048576;
    PrintStr("NOTE: Limiting to 1MB for test\n");
  }
  
  var playBuf: int64;
  playBuf := mmap(0, readSize, 3, 34, -1, 0);
  bytesRead := sys_read(fd, playBuf, readSize);
  close(fd);

  PrintStr("Read: "); PrintInt(bytesRead); PrintStr(" bytes\n");

  // Open ALSA
  var hp: int64;
  hp := mmap(0, 8, 3, 34, -1, 0);
  var res: int64;
  res := snd_pcm_open(hp, "plughw:0", 0, 0);
  
  if (res != 0) {
    PrintStr("ERROR: Cannot open ALSA: "); PrintInt(res); PrintStr("\n");
    munmap(playBuf, readSize);
    munmap(hp, 8);
    return 1;
  }
  
  var alsaHandle: int64;
  alsaHandle := peek64(hp);
  munmap(hp, 8);

  // Set params
  var pp: int64;
  pp := mmap(0, 8, 3, 34, -1, 0);
  snd_pcm_hw_params_malloc(pp);
  var params: int64;
  params := peek64(pp);

  PrintStr("Setting up ALSA params...\n");
  
  snd_pcm_hw_params_any(alsaHandle, params);
  snd_pcm_hw_params_set_access(alsaHandle, params, 3);  // RW_INTERLEAVED
  
  // Try different format - maybe S16_BE works better
  snd_pcm_hw_params_set_format(alsaHandle, params, 2); // S16_LE
  
  var ratePtr: int64;
  ratePtr := mmap(0, 8, 3, 34, -1, 0);
  poke32(ratePtr, sampleRate);
  
  // Get available rates first
  PrintStr("Requesting rate: "); PrintInt(sampleRate); PrintStr("\n");
  
  snd_pcm_hw_params_set_rate_near(alsaHandle, params, ratePtr, 0);
  var actualRate: int64;
  actualRate := peek32(ratePtr);
  munmap(ratePtr, 8);
  
  PrintStr("Actual rate set: "); PrintInt(actualRate); PrintStr(" Hz\n");
  
  snd_pcm_hw_params_set_channels(alsaHandle, params, channels);
  res := snd_pcm_hw_params(alsaHandle, params);
  
  if (res != 0) {
    PrintStr("ERROR: Cannot set params: "); PrintInt(res); PrintStr("\n");
    snd_pcm_close(alsaHandle);
    snd_pcm_hw_params_free(params);
    munmap(pp, 8);
    munmap(playBuf, readSize);
    return 1;
  }
  
  // Prepare the device before playback
  PrintStr("Preparing ALSA device...\n");
  res := snd_pcm_prepare(alsaHandle);
  if (res < 0) {
    PrintStr("WARNING: prepare failed: "); PrintInt(res); PrintStr("\n");
  }
  
  snd_pcm_hw_params_free(params);
  munmap(pp, 8);
  
  PrintStr("Playing "); PrintInt(readSize / (channels * (bitsPerSample / 8))); PrintStr(" frames...\n");

  // Play in chunks
  var bytesPerFrame: int64 := channels * (bitsPerSample / 8);
  var framesToPlay: int64 := bytesRead / bytesPerFrame;
  var periodFrames: int64 := 4096;
  
  var playedFrames: int64 := 0;
  var offset: int64 := 0;
  
  while (playedFrames < framesToPlay) {
    var framesNow: int64 := periodFrames;
    if (framesNow > (framesToPlay - playedFrames)) {
      framesNow := framesToPlay - playedFrames;
    }
    
    res := snd_pcm_writei(alsaHandle, playBuf + offset, framesNow);
    
    if (res < 0) {
      PrintStr("Write error: "); PrintInt(res); PrintStr("\n");
      break;
    }
    
    playedFrames := playedFrames + res;
    offset := offset + (res * bytesPerFrame);
    
    // Small delay between chunks
    // var sleepTime: int64 := 100000; // 100ms
    // usleep(sleepTime);
  }
  
  PrintStr("Played: "); PrintInt(playedFrames); PrintStr(" frames\n");
  
  // Drain and close - skip for now to test
  // snd_pcm_drain(alsaHandle);
  // snd_pcm_close(alsaHandle);
  munmap(playBuf, readSize);

  PrintStr("=== Done ===\n");
  return 0;
}