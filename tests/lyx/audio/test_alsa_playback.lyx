// Test: Play WAV file using ALSA
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== ALSA Playback Test ===\n");
  
  // Step 1: Load WAV file
  var wavPath: pchar := "/tmp/playback_test.wav";
  
  PrintStr("1. Opening WAV file...\n");
  
  var fd: int64;
  fd := open(wavPath, 0, 0);
  
  if (fd < 0) {
    PrintStr("ERROR: Cannot open file\n");
    return 1;
  }
  
  // Skip 44-byte header
  lseek(fd, 44, SEEK_SET);
  
  // Get file size
  var fsize: int64;
  fsize := lseek(fd, 0, SEEK_END);
  var dataSize: int64;
  dataSize := fsize - 44;
  
  close(fd);
  
  PrintStr("   Data size: ");
  PrintInt(dataSize);
  PrintStr(" bytes\n");
  
  // Re-open and read data
  fd := open(wavPath, 0, 0);
  lseek(fd, 44, SEEK_SET);
  
  var buffer: int64;
  buffer := mmap(0, dataSize, 3, 34, -1, 0);
  
  if (buffer == 0) {
    close(fd);
    PrintStr("ERROR: mmap failed\n");
    return 1;
  }
  
  var read: int64;
  read := sys_read(fd, buffer, dataSize);
  close(fd);
  
  PrintStr("   Read: ");
  PrintInt(read);
  PrintStr(" bytes\n");
  
  // Step 2: Open ALSA device
  PrintStr("2. Opening ALSA device...\n");
  
  var handle: int64;
  handle := ALSAAudioOpen();
  
  if (handle == 0) {
    munmap(buffer, dataSize);
    PrintStr("ERROR: Cannot open ALSA device\n");
    return 1;
  }
  
  PrintStr("   Handle: ");
  PrintInt(handle);
  PrintStr("\n");
  
  // Step 3: Configure format - this also applies hw_params
  PrintStr("3. Configuring format (44100 Hz, 2 channels, 16-bit)...\n");
  
  var result: int64;
  result := ALSASetFormat(handle, 44100, 2, 16);
  
  PrintStr("   SetFormat result: ");
  PrintInt(result);
  PrintStr("\n");
  
  if (result != ALSA_OK) {
    ALSAClose(handle);
    munmap(buffer, dataSize);
    PrintStr("ERROR: Cannot set format\n");
    return 1;
  }
  
  // Step 4: Device is already prepared by hw_params!
  PrintStr("4. Device ready (hw_params auto-prepares)...\n");
  
  // Step 5: Play audio
  PrintStr("5. Playing audio...\n");
  
  var written: int64;
  written := ALSAWrite(handle, buffer, dataSize);
  
  PrintStr("   Written: ");
  PrintInt(written);
  PrintStr(" bytes\n");
  
  // Wait a bit for playback to finish
  // (In a real app, we'd wait for callback or drain)
  
  // Step 6: Cleanup
  PrintStr("6. Closing device...\n");
  
  ALSAClose(handle);
  munmap(buffer, dataSize);
  
  PrintStr("=== Playback Complete ===\n");
  return 0;
}
