// Test mpg123 using the older read API (simpler for now)
import std.audio;
import std.audio.mpg123;

pub fn main(): int64 {
  PrintStr("=== mpg123_read Test (old API) ===\n");
  
  // Step 1: Initialize
  PrintStr("1. mpg123_init...\n");
  var initResult: int64;
  initResult := mpg123_init();
  
  if (initResult != MPG123_OK) {
    PrintStr("ERROR: mpg123_init failed\n");
    return 1;
  }
  PrintStr("   OK\n");
  
  // Step 2: Create handle
  PrintStr("2. mpg123_new...\n");
  var err: int64;
  err := 0;
  var handle: int64;
  handle := mpg123_new(0, err);
  
  if (handle == 0) {
    PrintStr("ERROR: Failed to create handle\n");
    mpg123_exit();
    return 1;
  }
  PrintStr("   handle=");
  PrintInt(handle);
  PrintStr("\n");
  
  // Step 3: Open MP3 file
  PrintStr("3. mpg123_open...\n");
  var openResult: int64;
  openResult := mpg123_open(handle, "/home/andreas/PhpstormProjects/aurum/music_test.mp3");
  
  if (openResult != MPG123_OK) {
    PrintStr("ERROR: Failed to open MP3\n");
    mpg123_delete(handle);
    mpg123_exit();
    return 1;
  }
  PrintStr("   OK\n");
  
  // Step 4: Allocate audio buffer
  PrintStr("4. Allocating audio buffer (32KB)...\n");
  var audioBuffer: int64;
  audioBuffer := mmap(0, 32768, 3, 34, -1, 0);
  
  if (audioBuffer == 0) {
    PrintStr("ERROR: mmap failed\n");
    mpg123_close(handle);
    mpg123_delete(handle);
    mpg123_exit();
    return 1;
  }
  PrintStr("   buffer=");
  PrintInt(audioBuffer);
  PrintStr("\n");
  
  // Step 5: Read audio data
  PrintStr("5. mpg123_read...\n");
  var bytesRead: int64;
  bytesRead := mpg123_read(handle, audioBuffer, 32768);
  
  PrintStr("   bytesRead=");
  PrintInt(bytesRead);
  PrintStr("\n");
  
  if (bytesRead > 0) {
    PrintStr("   SUCCESS! Got ");
    PrintInt(bytesRead);
    PrintStr(" bytes of PCM data\n");
  } else if (bytesRead == 0) {
    PrintStr("   No more data\n");
  } else {
    PrintStr("   Error reading\n");
  }
  
  // Step 6: Cleanup
  PrintStr("6. Cleanup...\n");
  munmap(audioBuffer, 32768);
  mpg123_close(handle);
  mpg123_delete(handle);
  mpg123_exit();
  
  PrintStr("=== Test Complete ===\n");
  return 0;
}
