// Test AudioInfo struct field access
import std.audio;

pub fn main(): int64 {
  var info: AudioInfo;
  
  // Test direct assignment
  info.format := 100;
  info.sampleRate := 200;
  info.channels := 300;
  info.bitsPerSample := 400;
  info.dataOffset := 500;
  info.dataSize := 600;
  info.durationMs := 700;
  
  PrintStr("After assignment:\n");
  PrintStr("format: ");
  PrintInt(info.format);
  PrintStr("\n");
  PrintStr("sampleRate: ");
  PrintInt(info.sampleRate);
  PrintStr("\n");
  PrintStr("channels: ");
  PrintInt(info.channels);
  PrintStr("\n");
  PrintStr("bitsPerSample: ");
  PrintInt(info.bitsPerSample);
  PrintStr("\n");
  PrintStr("dataOffset: ");
  PrintInt(info.dataOffset);
  PrintStr("\n");
  PrintStr("dataSize: ");
  PrintInt(info.dataSize);
  PrintStr("\n");
  PrintStr("durationMs: ");
  PrintInt(info.durationMs);
  PrintStr("\n");
  
  return 0;
}
