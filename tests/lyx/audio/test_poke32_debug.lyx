// Debug: Check actual sample rate written to memory
import std.audio;
import std.audio.alsa;

pub fn main(): int64 {
  PrintStr("=== Debug: poke32 test ===\n");
  
  var ptr: int64;
  ptr := mmap(0, 8, 3, 34, -1, 0);
  
  // Test writing 48000
  poke32(ptr, 48000);
  
  var val: int64;
  val := peek32(ptr);
  PrintStr("Wrote 48000, read back: "); PrintInt(val); PrintStr("\n");
  
  // Check individual bytes
  var b0: int64 := peek8(ptr + 0);
  var b1: int64 := peek8(ptr + 1);
  var b2: int64 := peek8(ptr + 2);
  var b3: int64 := peek8(ptr + 3);
  PrintStr("Bytes: "); PrintInt(b0); PrintStr(" "); PrintInt(b1); PrintStr(" ");
  PrintInt(b2); PrintStr(" "); PrintInt(b3); PrintStr("\n");
  
  // 48000 decimal = 0xBB80 in hex
  // Little endian: 80 BB 00 00
  PrintStr("Expected: 0x80 0xBB 0x00 0x00\n");
  
  munmap(ptr, 8);
  PrintStr("=== Done ===\n");
  return 0;
}