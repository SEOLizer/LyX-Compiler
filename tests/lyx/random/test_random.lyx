// test_random.lyx
// Teste Random und RandomSeed Builtins
fn main(): int64 {
  // Seed setzen für reproduzierbare Ergebnisse
  RandomSeed(42);

  var r1: int64 := Random();
  var r2: int64 := Random();
  var r3: int64 := Random();

  PrintStr("r1: ");
  PrintInt(r1);
  PrintStr("\n");

  PrintStr("r2: ");
  PrintInt(r2);
  PrintStr("\n");

  PrintStr("r3: ");
  PrintInt(r3);
  PrintStr("\n");

  // Seed erneut setzen -> gleiche Sequenz
  RandomSeed(42);
  var r1b: int64 := Random();

  PrintStr("r1b (nach reseed): ");
  PrintInt(r1b);
  PrintStr("\n");

  if (r1 == r1b) {
    PrintStr("OK: reseed liefert gleiche Sequenz\n");
  } else {
    PrintStr("FAIL: reseed liefert andere Sequenz\n");
  }

  return 0;
}
