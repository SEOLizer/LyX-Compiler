// Test Mathematical Constants Module
// Verifies constant values and conversion functions

import std.math.constants;

fn main(): int64 {
  PrintStr("Testing Mathematical Constants...\n");
  
  // Test 1: Circle Constants
  PrintStr("Test 1: Circle Constants\n");
  PrintStr("  PI = ");
  PrintFloat(PI);
  PrintStr("\n");
  
  PrintStr("  TAU = ");
  PrintFloat(TAU);
  PrintStr("\n");
  
  PrintStr("  TAU / PI = ");
  PrintFloat(TAU / PI);
  PrintStr(" (expected ~2.0)\n");
  
  PrintStr("  HALF_PI = ");
  PrintFloat(HALF_PI);
  PrintStr("\n");
  
  PrintStr("  INV_PI = ");
  PrintFloat(INV_PI);
  PrintStr("\n");
  
  // Test 2: Euler's Number
  PrintStr("Test 2: Euler's Number\n");
  PrintStr("  E = ");
  PrintFloat(E);
  PrintStr("\n");
  
  PrintStr("  INV_E = ");
  PrintFloat(INV_E);
  PrintStr("\n");
  
  PrintStr("  E * INV_E = ");
  PrintFloat(E * INV_E);
  PrintStr(" (expected ~1.0)\n");
  
  // Test 3: Golden Ratio
  PrintStr("Test 3: Golden Ratio\n");
  PrintStr("  PHI = ");
  PrintFloat(PHI);
  PrintStr("\n");
  
  PrintStr("  INV_PHI = ");
  PrintFloat(INV_PHI);
  PrintStr("\n");
  
  PrintStr("  PHI * INV_PHI = ");
  PrintFloat(PHI * INV_PHI);
  PrintStr(" (expected ~1.0)\n");
  
  PrintStr("  PHI² = ");
  PrintFloat(PHI_SQUARED);
  PrintStr(" (expected ~2.618)\n");
  
  // Test 4: Square Roots
  PrintStr("Test 4: Square Roots\n");
  PrintStr("  SQRT2 = ");
  PrintFloat(SQRT2);
  PrintStr("\n");
  
  PrintStr("  SQRT3 = ");
  PrintFloat(SQRT3);
  PrintStr("\n");
  
  PrintStr("  SQRT5 = ");
  PrintFloat(SQRT5);
  PrintStr("\n");
  
  PrintStr("  SQRT2 * SQRT2 = ");
  PrintFloat(SQRT2 * SQRT2);
  PrintStr(" (expected ~2.0)\n");
  
  PrintStr("  SQRT3 * SQRT3 = ");
  PrintFloat(SQRT3 * SQRT3);
  PrintStr(" (expected ~3.0)\n");
  
  PrintStr("  INV_SQRT2 = ");
  PrintFloat(INV_SQRT2);
  PrintStr("\n");
  
  // Test 5: Logarithm Constants
  PrintStr("Test 5: Logarithm Constants\n");
  PrintStr("  LN2 = ");
  PrintFloat(LN2);
  PrintStr("\n");
  
  PrintStr("  LN10 = ");
  PrintFloat(LN10);
  PrintStr("\n");
  
  PrintStr("  LOG2E = ");
  PrintFloat(LOG2E);
  PrintStr("\n");
  
  PrintStr("  LOG10E = ");
  PrintFloat(LOG10E);
  PrintStr("\n");
  
  // Test 6: Degree/Radian Conversion
  PrintStr("Test 6: Degree/Radian Conversion\n");
  PrintStr("  DegToRad(180) = ");
  PrintFloat(DegToRad(180.0));
  PrintStr(" (expected ~3.14159)\n");
  
  PrintStr("  RadToDeg(PI) = ");
  PrintFloat(RadToDeg(PI));
  PrintStr(" (expected ~180.0)\n");
  
  PrintStr("  DegToRad(90) = ");
  PrintFloat(DegToRad(90.0));
  PrintStr(" (expected ~1.5708)\n");
  
  PrintStr("  DegToRad(360) = ");
  PrintFloat(DegToRad(360.0));
  PrintStr(" (expected ~6.2832)\n");
  
  // Test 7: Machine Constants
  PrintStr("Test 7: Machine Constants\n");
  PrintStr("  EPSILON = ");
  PrintFloat(EPSILON);
  PrintStr("\n");
  
  PrintStr("  MAX_SAFE_INT = ");
  PrintInt(MAX_SAFE_INT);
  PrintStr("\n");
  
  // Test 8: Approximate Equality
  PrintStr("Test 8: Approximate Equality\n");
  PrintStr("  ApproxEqual(PI, 3.14159265, EPSILON) = ");
  if (ApproxEqual(PI, 3.14159265, EPSILON)) {
    PrintStr("true")
  } else {
    PrintStr("false")
  }
  PrintStr("\n");
  
  PrintStr("  ApproxZero(0.000000001, EPSILON) = ");
  if (ApproxZero(0.000000001, EPSILON)) {
    PrintStr("true")
  } else {
    PrintStr("false")
  }
  PrintStr("\n");
  
  PrintStr("  ApproxOne(0.999999999999999, EPSILON) = ");
  if (ApproxOne(0.999999999999999, EPSILON)) {
    PrintStr("true")
  } else {
    PrintStr("false")
  }
  PrintStr("\n");
  
  PrintStr("\nAll tests completed!\n");
  return 0;
}
