// Test-Programm für std/systeminfo
// Erweitert mit Thread-/Prozess-Informationen

import std.systeminfo;
import std.io;

fn main(): int64 {
  PrintStr("=== System Information ===\n\n");
  
  // OS
  var os: int64 := GetOS();
  if (os == 0) {
    PrintStr("OS: Linux\n");
  }
  else {
    PrintStr("OS: Unknown\n");
  }
  
  PrintStr("\n--- CPU ---\n");
  var logical: int64 := GetLogicalCores();
  var physical: int64 := GetPhysicalCores();
  var smt: int64 := GetSMTWidth();
  
  PrintStr("Logical Cores: ");
  PrintInt(logical);
  PrintStr("\n");
  
  PrintStr("Physical Cores: ");
  PrintInt(physical);
  PrintStr("\n");
  
  PrintStr("SMT Width: ");
  PrintInt(smt);
  PrintStr("\n");
  
  PrintStr("\n--- Memory ---\n");
  var total: int64 := GetTotalMemory();
  var avail: int64 := GetAvailableMemory();
  var free: int64 := GetFreeMemory();
  
  PrintStr("Total Memory: ");
  PrintInt(total / 1024);
  PrintStr(" MB\n");
  
  PrintStr("Available Memory: ");
  PrintInt(avail / 1024);
  PrintStr(" MB\n");
  
  PrintStr("Free Memory: ");
  PrintInt(free / 1024);
  PrintStr(" MB\n");
  
  PrintStr("\n--- Load Average ---\n");
  var load1: int64 := GetLoadAverage1();
  var load5: int64 := GetLoadAverage5();
  var load15: int64 := GetLoadAverage15();
  
  PrintStr("Load 1min: ");
  PrintInt(load1 / 100);
  PrintStr(".");
  PrintInt(load1 % 100);
  PrintStr("\n");
  
  PrintStr("Load 5min: ");
  PrintInt(load5 / 100);
  PrintStr(".");
  PrintInt(load5 % 100);
  PrintStr("\n");
  
  PrintStr("Load 15min: ");
  PrintInt(load15 / 100);
  PrintStr(".");
  PrintInt(load15 % 100);
  PrintStr("\n");
  
  PrintStr("\n--- Uptime ---\n");
  var uptime: int64 := GetUptime();
  
  var days: int64 := uptime / 86400;
  var hours: int64 := (uptime % 86400) / 3600;
  var mins: int64 := (uptime % 3600) / 60;
  var secs: int64 := uptime % 60;
  
  if (days > 0) {
    PrintInt(days);
    PrintStr("d ");
  }
  PrintInt(hours);
  PrintStr("h ");
  PrintInt(mins);
  PrintStr("m ");
  PrintInt(secs);
  PrintStr("s\n");
  
  PrintStr("\n--- Current Process ---\n");
  var pid: int64 := GetProcessId();
  var ppid: int64 := GetParentProcessId();
  var utime: int64 := GetUserTime();
  var stime: int64 := GetSystemTime();
  var threads: int64 := GetNumThreads();
  
  PrintStr("PID: ");
  PrintInt(pid);
  PrintStr("\n");
  
  PrintStr("Parent PID: ");
  PrintInt(ppid);
  PrintStr("\n");
  
  PrintStr("User Time: ");
  PrintInt(utime);
  PrintStr(" ticks\n");
  
  PrintStr("System Time: ");
  PrintInt(stime);
  PrintStr(" ticks\n");
  
  PrintStr("Threads: ");
  PrintInt(threads);
  PrintStr("\n");
  
  PrintStr("\n--- CPU Stats (/proc/stat) ---\n");
  var cpu_user: int64 := GetCpuUserTime();
  var cpu_sys: int64 := GetCpuSystemTime();
  var cpu_idle: int64 := GetCpuIdleTime();
  
  PrintStr("User Time: ");
  PrintInt(cpu_user);
  PrintStr(" jiffies\n");
  
  PrintStr("System Time: ");
  PrintInt(cpu_sys);
  PrintStr(" jiffies\n");
  
  PrintStr("Idle Time: ");
  PrintInt(cpu_idle);
  PrintStr(" jiffies\n");
  
  var total_cpu: int64 := cpu_user + cpu_sys + cpu_idle;
  if (total_cpu > 0) {
    var idle_pct: int64 := (cpu_idle * 100) / total_cpu;
    PrintStr("CPU Usage: ");
    PrintInt(100 - idle_pct);
    PrintStr("%\n");
  }
  
  PrintStr("\n--- Processes ---\n");
  var running: int64 := GetRunningProcesses();
  
  PrintStr("Running/Runnable: ");
  PrintInt(running);
  PrintStr("\n");
  
  PrintStr("\n=== Test Complete ===\n");
  
  return 0;
}