// Test Country Codes Module
// Demonstrates ISO 3166-1 alpha-2 country code lookups

import std.country;

fn main(): int64 {
  PrintStr("Testing Country Codes Module (ISO 3166-1)...\n");
  
  // Test 1: Country Name Lookup
  PrintStr("Test 1: Country Name Lookup\n");
  var name: int64 := CountryGetName("DE");
  PrintStr("  DE -> ");
  sys_write(1, name, 20);
  PrintStr("\n");
  
  name := CountryGetName("US");
  PrintStr("  US -> ");
  sys_write(1, name, 20);
  PrintStr("\n");
  
  name := CountryGetName("JP");
  PrintStr("  JP -> ");
  sys_write(1, name, 20);
  PrintStr("\n");
  
  name := CountryGetName("XX");
  PrintStr("  XX -> ");
  sys_write(1, name, 20);
  PrintStr("\n");
  
  // Test 2: Code Lookup by Name
  PrintStr("Test 2: Code Lookup by Name\n");
  var code: int64 := CountryGetCode("Germany");
  PrintStr("  Germany -> ");
  sys_write(1, code, 2);
  PrintStr("\n");
  
  code := CountryGetCode("Switzerland");
  PrintStr("  Switzerland -> ");
  sys_write(1, code, 2);
  PrintStr("\n");
  
  code := CountryGetCode("Japan");
  PrintStr("  Japan -> ");
  sys_write(1, code, 2);
  PrintStr("\n");
  
  // Test 3: Currency Lookup
  PrintStr("Test 3: Currency Lookup\n");
  var currency: int64 := CountryGetCurrency("DE");
  PrintStr("  DE -> ");
  sys_write(1, currency, 3);
  PrintStr("\n");
  
  currency := CountryGetCurrency("GB");
  PrintStr("  GB -> ");
  sys_write(1, currency, 3);
  PrintStr("\n");
  
  currency := CountryGetCurrency("JP");
  PrintStr("  JP -> ");
  sys_write(1, currency, 3);
  PrintStr("\n");
  
  currency := CountryGetCurrency("CH");
  PrintStr("  CH -> ");
  sys_write(1, currency, 3);
  PrintStr("\n");
  
  // Test 4: Region Lookup
  PrintStr("Test 4: Region Lookup\n");
  var region: int64 := CountryGetRegion("DE");
  PrintStr("  DE -> ");
  sys_write(1, CountryGetRegionName(region), 20);
  PrintStr("\n");
  
  region := CountryGetRegion("US");
  PrintStr("  US -> ");
  sys_write(1, CountryGetRegionName(region), 20);
  PrintStr("\n");
  
  region := CountryGetRegion("JP");
  PrintStr("  JP -> ");
  sys_write(1, CountryGetRegionName(region), 20);
  PrintStr("\n");
  
  region := CountryGetRegion("BR");
  PrintStr("  BR -> ");
  sys_write(1, CountryGetRegionName(region), 20);
  PrintStr("\n");
  
  region := CountryGetRegion("AU");
  PrintStr("  AU -> ");
  sys_write(1, CountryGetRegionName(region), 20);
  PrintStr("\n");
  
  // Test 5: ISO Numeric Code
  PrintStr("Test 5: ISO Numeric Code\n");
  var num: int64 := CountryGetNumeric("DE");
  PrintStr("  DE -> ");
  PrintInt(num);
  PrintStr("\n");
  
  num := CountryGetNumeric("US");
  PrintStr("  US -> ");
  PrintInt(num);
  PrintStr("\n");
  
  num := CountryGetNumeric("CH");
  PrintStr("  CH -> ");
  PrintInt(num);
  PrintStr("\n");
  
  // Test 6: Validation
  PrintStr("Test 6: Code Validation\n");
  var valid: int64 := CountryIsValid("DE");
  PrintStr("  DE -> ");
  if (valid == 1) { PrintStr("VALID") } else { PrintStr("INVALID") }
  PrintStr("\n");
  
  valid := CountryIsValid("XX");
  PrintStr("  XX -> ");
  if (valid == 1) { PrintStr("VALID") } else { PrintStr("INVALID") }
  PrintStr("\n");
  
  valid := CountryIsValid("US");
  PrintStr("  US -> ");
  if (valid == 1) { PrintStr("VALID") } else { PrintStr("INVALID") }
  PrintStr("\n");
  
  // Test 7: Database Stats
  PrintStr("Test 7: Database Stats\n");
  PrintStr("  Countries in database: ");
  PrintInt(CountryGetCount());
  PrintStr("\n");
  
  PrintStr("\nAll tests completed!\n");
  return 0;
}
