// test_bitwise_ops.lyx
// Umfassender Test aller bitweisen Operatoren
fn main(): int64 {
  // --- Bitwise AND ---
  var a: int64 := 12;
  var b: int64 := 10;
  var r_and: int64 := a & b;
  PrintStr("12 & 10 = ");
  PrintInt(r_and);
  PrintStr("\n");

  // --- Bitwise OR ---
  var r_or: int64 := a | b;
  PrintStr("12 | 10 = ");
  PrintInt(r_or);
  PrintStr("\n");

  // --- Bitwise XOR ---
  var r_xor: int64 := a ^ b;
  PrintStr("12 ^ 10 = ");
  PrintInt(r_xor);
  PrintStr("\n");

  // --- Shift Left ---
  var c: int64 := 1;
  var r_shl: int64 := c << 4;
  PrintStr("1 << 4 = ");
  PrintInt(r_shl);
  PrintStr("\n");

  // --- Shift Right ---
  var d: int64 := 256;
  var r_shr: int64 := d >> 3;
  PrintStr("256 >> 3 = ");
  PrintInt(r_shr);
  PrintStr("\n");

  // --- Bitwise NOT ---
  var e: int64 := 0;
  var r_not: int64 := ~e;
  PrintStr("~0 = ");
  PrintInt(r_not);
  PrintStr("\n");

  // --- Kombiniert: Mask-and-Shift ---
  var val: int64 := 255;
  var mask: int64 := val & 15;
  PrintStr("255 & 15 = ");
  PrintInt(mask);
  PrintStr("\n");

  // --- Shift und OR kombiniert ---
  var high: int64 := 5 << 4;
  var low: int64 := 3;
  var combined: int64 := high | low;
  PrintStr("(5 << 4) | 3 = ");
  PrintInt(combined);
  PrintStr("\n");

  return 0;
}
