// ============================================================================
// Test 4: Verify ELF magic bytes in output file
// ============================================================================

fn test4() {
  PrintStr("=== Test 4: verify ELF magic ===\n");
  var src: pchar := "fn main(): int64 { return 42; }";
  var p: Parser := new Parser();
  p.Init(src, StrLen(src));
  var head: int64 := p.Parse();

  if (p.hadError == 0 && head >= 0) {
    var cg: Codegen := new Codegen();
    cg.Init(p.src, p.nodes, p.toks);
    cg.Generate(head);
    cg.WriteELF("/tmp/test_cg_ret42");
    dispose cg;
  }
  dispose p;

  // Read back and check ELF magic
  var buf: pchar := mmap(0, 8, 3, 34, -1, 0) as pchar;
  var addr: int64 := buf as int64;
  var fd: int64 := open("/tmp/test_cg_ret42", 0, 0);  // O_RDONLY
  if (fd >= 0) {
    read(fd, buf, 8);
    close(fd);
    var b0: int64 := StrCharAt(buf, 0);
    var b1: int64 := StrCharAt(buf, 1);
    var b2: int64 := StrCharAt(buf, 2);
    var b3: int64 := StrCharAt(buf, 3);
    PrintStr("ELF magic: ");
    PrintInt(b0); PrintStr(" ");
    PrintInt(b1); PrintStr(" ");
    PrintInt(b2); PrintStr(" ");
    PrintInt(b3); PrintStr("\n");
    // Expect: 127 69 76 70
    PrintStr("magic ok=");
    if (b0 == 127 && b1 == 69 && b2 == 76 && b3 == 70) {
      PrintStr("1 (expect=1)\n");
    } else {
      PrintStr("0 (expect=1)\n");
    }
  } else {
    PrintStr("could not read output file\n");
  }
}

// ============================================================================
// Test 5: Variable declarations and local scope
// ============================================================================

fn test5() {
  PrintStr("=== Test 5: codegen locals ===\n");
  var src: pchar :=
    "fn sum(n: int64): int64 { " +
    "  var acc: int64 := 0; " +
    "  var i: int64 := 1; " +
    "  while (i <= n) { acc := acc + i; i := i + 1; } " +
    "  return acc; " +
    "} " +
    "fn main(): int64 { PrintInt(sum(10)); PrintStr(\"\\n\"); return 0; }";
  var p: Parser := new Parser();
  p.Init(src, StrLen(src));
  var head: int64 := p.Parse();
  PrintStr("parse hadError="); PrintInt(p.hadError); PrintStr("\n");

  if (p.hadError == 0 && head >= 0) {
    var cg: Codegen := new Codegen();
    cg.Init(p.src, p.nodes, p.toks);
    cg.Generate(head);
    PrintStr("codeLen="); PrintInt(cg.codeLen); PrintStr("\n");
    cg.WriteELF("/tmp/test_cg_sum");
    PrintStr("wrote /tmp/test_cg_sum\n");
    dispose cg;
  }
  dispose p;
}

// ============================================================================
// main
// ============================================================================

fn main(argc: int64, argv: pchar) {
  test1();
  test2();
  test3();
  test4();
  test5();
  PrintStr("=== All codegen tests done ===\n");
  PrintStr("Run with: chmod +x /tmp/test_cg_* && /tmp/test_cg_hello\n");
}
