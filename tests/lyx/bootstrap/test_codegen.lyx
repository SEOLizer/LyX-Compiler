// tests/lyx/bootstrap/test_codegen.lyx
// WP-08: Self-Hosted x86_64 Code Generator Test
//
// Strategy: parse a small Lyx program, run the codegen, write an ELF binary,
// then verify the binary was produced.

import bootstrap.parser;
import bootstrap.codegen_x86;

// ============================================================================
// Helper: print N chars from a pchar (length-delimited, no null needed)
// ============================================================================

fn PrintN(p: pchar, n: int64) {
  var buf: pchar := mmap(0, n + 1, 3, 34, -1, 0) as pchar;
  var addr: int64 := buf as int64;
  var i: int64 := 0;
  while (i < n) {
    poke8(addr + i, StrCharAt(p, i));
    i := i + 1;
  }
  poke8(addr + n, 0);
  PrintStr(buf);
}

// ============================================================================
// Test 1: Emit an ELF that prints "hello" and returns 0
// ============================================================================

fn test1() {
  PrintStr("=== Test 1: codegen hello world ===\n");
  var src: pchar :=
    "fn main(): int64 { PrintStr(\"hello\\n\"); return 0; }";
  var p: Parser := new Parser();
  p.Init(src, StrLen(src));
  var head: int64 := p.Parse();
  PrintStr("parse hadError="); PrintInt(p.hadError); PrintStr("\n");
  PrintStr("nodeCount=");      PrintInt(p.nodeCount); PrintStr("\n");

  if (p.hadError == 0 && head >= 0) {
    var cg: Codegen := new Codegen();
    cg.Init(p.src, p.nodes, p.toks);
    cg.Generate(head);
    PrintStr("codeLen="); PrintInt(cg.codeLen); PrintStr("\n");
    PrintStr("dataLen="); PrintInt(cg.dataLen); PrintStr("\n");
    cg.WriteELF("/tmp/test_cg_hello");
    PrintStr("wrote /tmp/test_cg_hello\n");
    dispose cg;
  }
  dispose p;
}

