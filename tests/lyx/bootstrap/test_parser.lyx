// ============================================================================
// Test 9: Assignment statement
// ============================================================================

fn test9() {
  PrintStr("=== Test 9: assignment ===\n");
  var src: pchar := "fn f() { var x: int64 := 0; x := x + 1; }";
  var p: Parser := new Parser();
  p.Init(src, StrLen(src));
  var head: int64 := p.Parse();

  PrintStr("hadError="); PrintInt(p.hadError); PrintStr("\n");
  if (head >= 0) {
    var body: int64 := p.NChild2(head);
    var s0: int64 := p.NChild0(body);
    var s1: int64 := p.NNext(s0);
    PrintStr("s0="); PrintStr(ParserNodeKindStr(p.NKind(s0))); PrintStr("\n");
    PrintStr("s1="); PrintStr(ParserNodeKindStr(p.NKind(s1))); PrintStr("\n");
  }
  dispose p;
}

// ============================================================================
// Test 10: switch/case
// ============================================================================

fn test10() {
  PrintStr("=== Test 10: switch ===\n");
  var src: pchar := "fn f(x: int64) { switch (x) { case 1: { return; } default: { return; } } }";
  var p: Parser := new Parser();
  p.Init(src, StrLen(src));
  var head: int64 := p.Parse();

  PrintStr("hadError="); PrintInt(p.hadError); PrintStr("\n");
  if (head >= 0) {
    var body: int64 := p.NChild2(head);
    var sw: int64 := p.NChild0(body);
    PrintStr("switch="); PrintStr(ParserNodeKindStr(p.NKind(sw))); PrintStr("\n");
    var cases: int64 := p.NChild1(sw);
    PrintStr("cases="); PrintInt(ParserListLen(p, cases)); PrintStr("\n");
  }
  dispose p;
}

fn main(): int64 {
  test1();
  test2();
  test3();
  test4();
  test5();
  test6();
  test7();
  test8();
  test9();
  test10();
  PrintStr("=== All parser tests done ===\n");
  return 0;
}
