// ============================================================================
// Test 5: Parse if/while/return statements
// ============================================================================

fn test5() {
  PrintStr("=== Test 5: if/while/return ===\n");
  var src: pchar := "fn foo(n: int64): int64 { if (n > 0) { return n; } else { return 0; } }";
  var p: Parser := new Parser();
  p.Init(src, StrLen(src));
  var head: int64 := p.Parse();

  PrintStr("hadError="); PrintInt(p.hadError); PrintStr("\n");
  if (head >= 0) {
    var body: int64 := p.NChild2(head);  // child2 = block
    PrintStr("body kind="); PrintStr(ParserNodeKindStr(p.NKind(body))); PrintStr("\n");
    var stmts: int64 := p.NChild0(body);
    PrintStr("stmt[0] kind="); PrintStr(ParserNodeKindStr(p.NKind(stmts))); PrintStr("\n");
    // if-node: child0=cond, child1=then, child2=else
    var elseBlk: int64 := p.NChild2(stmts);
    PrintStr("else kind="); PrintStr(ParserNodeKindStr(p.NKind(elseBlk))); PrintStr("\n");
  }
  dispose p;
}

