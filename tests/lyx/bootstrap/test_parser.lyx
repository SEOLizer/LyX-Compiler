// tests/lyx/bootstrap/test_parser.lyx
// WP-06: Self-Hosted Parser Test

import bootstrap.parser;

// ============================================================================
// Helper: print N chars from a pointer (no null terminator required)
// ============================================================================

fn PrintN(p: pchar, n: int64) {
  // Copy n bytes into a null-terminated mmap buffer, then PrintStr
  var buf: pchar := mmap(0, n + 1, 3, 34, -1, 0) as pchar;
  var addr: int64 := buf as int64;
  var i: int64 := 0;
  while (i < n) {
    poke8(addr + i, StrCharAt(p, i));
    i := i + 1;
  }
  poke8(addr + n, 0);
  PrintStr(buf);
}

// ============================================================================
// Test 1: Parse a simple function declaration
// ============================================================================

fn test1() {
  PrintStr("=== Test 1: fn decl ===\n");
  var src: pchar := "fn add(x: int64, y: int64): int64 { return x + y; }";
  var p: Parser := new Parser();
  p.Init(src, StrLen(src));
  PrintStr("tokCount="); PrintInt(p.tokCount); PrintStr("\n");
  PrintStr("firstTokKind="); PrintInt(p.TokKind(0)); PrintStr("\n");
  var head: int64 := p.Parse();

  PrintStr("hadError="); PrintInt(p.hadError); PrintStr("\n");
  PrintStr("nodeCount="); PrintInt(p.nodeCount); PrintStr("\n");
  PrintStr("head="); PrintInt(head); PrintStr("\n");
  PrintStr("p.nodes="); PrintInt(p.nodes); PrintStr("\n");
  PrintStr("topDecls="); PrintInt(ParserListLen(p, head)); PrintStr("\n");

  // Check we got one FUNC_DECL
  if (head >= 0) {
    PrintStr("decl[0] kind="); PrintStr(ParserNodeKindStr(p.NKind(head))); PrintStr("\n");
    PrintStr("decl[0] name=");
    PrintN(p.NSVal(head), p.NSLen(head));
    PrintStr("\n");
    // params: child0 = param list
    var params: int64 := p.NChild0(head);
    PrintStr("params="); PrintInt(ParserListLen(p, params)); PrintStr("\n");
  }
  dispose p;
}

// ============================================================================
// Test 2: Parse var/con declarations
// ============================================================================

fn test2() {
  PrintStr("=== Test 2: var/con decls ===\n");
  var src: pchar := "var x: int64 := 42; con MAX: int64 := 100; var msg: pchar := \"hello\";";
  var p: Parser := new Parser();
  p.Init(src, StrLen(src));
  var head: int64 := p.Parse();

  PrintStr("hadError="); PrintInt(p.hadError); PrintStr("\n");
  PrintStr("topDecls="); PrintInt(ParserListLen(p, head)); PrintStr("\n");

  var cur: int64 := head;
  while (cur != -1) {
    PrintStr("  "); PrintStr(ParserNodeKindStr(p.NKind(cur)));
    PrintStr(" name="); PrintN(p.NSVal(cur), p.NSLen(cur));
    PrintStr("\n");
    cur := p.NNext(cur);
  }
  dispose p;
}

