// ============================================================================
// Test 7: Parse expressions (binop, call, field access)
// ============================================================================

fn test7() {
  PrintStr("=== Test 7: expressions ===\n");
  var src: pchar := "fn f(): int64 { var r: int64 := a + b * c; return foo(r, 1 + 2); }";
  var p: Parser := new Parser();
  p.Init(src, StrLen(src));
  var head: int64 := p.Parse();

  PrintStr("hadError="); PrintInt(p.hadError); PrintStr("\n");
  PrintStr("nodeCount="); PrintInt(p.nodeCount); PrintStr("\n");
  // Drill into body
  if (head >= 0) {
    var body: int64 := p.NChild2(head);
    var stmt0: int64 := p.NChild0(body);  // var decl
    PrintStr("stmt0="); PrintStr(ParserNodeKindStr(p.NKind(stmt0))); PrintStr("\n");
    var stmt1: int64 := p.NNext(stmt0);  // return
    PrintStr("stmt1="); PrintStr(ParserNodeKindStr(p.NKind(stmt1))); PrintStr("\n");
    // return expr should be a CALL
    var retExpr: int64 := p.NChild0(stmt1);
    PrintStr("retExpr="); PrintStr(ParserNodeKindStr(p.NKind(retExpr))); PrintStr("\n");
  }
  dispose p;
}

