// tests/lyx/bootstrap/test_lexer.lyx
// WP-05: Self-Hosted Lexer Test

import bootstrap.lexer;

fn main(): int64 {
  // === Test 1: Keywords, identifiers, operators ===
  PrintStr("=== Test 1: Keywords and operators ===\n");
  var src1: pchar := "fn add(x: int64, y: int64): int64 { return x + y; }";
  var lex1: Lexer := new Lexer();
  lex1.Init(src1, StrLen(src1));

  var k: int64 := lex1.Next();
  while (k != TK_EOF) {
    PrintStr(LexerTokKindStr(k));
    PrintStr("(");
    PrintStr(lex1.TokText());
    PrintStr(") ");
    k := lex1.Next();
  }
  PrintStr("\n");
  dispose lex1;

  // === Test 2: Integer literals (decimal, hex, binary) ===
  PrintStr("=== Test 2: Number literals ===\n");
  var src2: pchar := "42 0xFF 0b1010 3.14";
  var lex2: Lexer := new Lexer();
  lex2.Init(src2, StrLen(src2));

  k := lex2.Next();
  while (k != TK_EOF) {
    if (k == TK_INT) {
      PrintStr("INT(");
      PrintInt(lex2.tokIVal);
      PrintStr(") ");
    } else if (k == TK_FLOAT) {
      PrintStr("FLOAT(");
      PrintStr(lex2.TokText());
      PrintStr(") ");
    } else {
      PrintStr(LexerTokKindStr(k));
      PrintStr("(");
      PrintStr(lex2.TokText());
      PrintStr(") ");
    }
    k := lex2.Next();
  }
  PrintStr("\n");
  dispose lex2;

  // === Test 3: String and char literals ===
  PrintStr("=== Test 3: String and char literals ===\n");
  var src3: pchar := "\"hello\" 'x'";
  var lex3: Lexer := new Lexer();
  lex3.Init(src3, StrLen(src3));

  k := lex3.Next();
  while (k != TK_EOF) {
    if (k == TK_CHAR) {
      PrintStr("CHAR(");
      PrintInt(lex3.tokIVal);
      PrintStr(") ");
    } else {
      PrintStr(LexerTokKindStr(k));
      PrintStr("(");
      PrintStr(lex3.TokText());
      PrintStr(") ");
    }
    k := lex3.Next();
  }
  PrintStr("\n");
  dispose lex3;

  // === Test 4: Comments (should be skipped) ===
  PrintStr("=== Test 4: Comments skipped ===\n");
  var src4: pchar := "var x /* block */ := 1; // line\nreturn x;";
  var lex4: Lexer := new Lexer();
  lex4.Init(src4, StrLen(src4));

  k := lex4.Next();
  while (k != TK_EOF) {
    PrintStr(LexerTokKindStr(k));
    PrintStr(" ");
    k := lex4.Next();
  }
  PrintStr("\n");
  dispose lex4;

  // === Test 5: Keyword recognition ===
  PrintStr("=== Test 5: Keyword recognition ===\n");
  var src5: pchar := "if else while return true false null enum class";
  var lex5: Lexer := new Lexer();
  lex5.Init(src5, StrLen(src5));

  k := lex5.Next();
  while (k != TK_EOF) {
    if (k == TK_IDENT) {
      PrintStr("IDENT(");
      PrintStr(lex5.TokText());
      PrintStr(") ");
    } else {
      PrintStr(LexerTokKindStr(k));
      PrintStr(" ");
    }
    k := lex5.Next();
  }
  PrintStr("\n");
  dispose lex5;

  // === Test 6: Peek does not consume ===
  PrintStr("=== Test 6: Peek ===\n");
  var src6: pchar := "fn main()";
  var lex6: Lexer := new Lexer();
  lex6.Init(src6, StrLen(src6));

  var p: int64 := lex6.Peek();
  PrintStr("peek="); PrintStr(LexerTokKindStr(p)); PrintStr(" ");
  k := lex6.Next();
  PrintStr("next="); PrintStr(LexerTokKindStr(k)); PrintStr("\n");
  dispose lex6;

  // === Test 7: Multi-char operators ===
  PrintStr("=== Test 7: Operators ===\n");
  var src7: pchar := ":= == != <= >= && || << >> |> => ...";
  var lex7: Lexer := new Lexer();
  lex7.Init(src7, StrLen(src7));

  k := lex7.Next();
  while (k != TK_EOF) {
    PrintStr(LexerTokKindStr(k));
    PrintStr(" ");
    k := lex7.Next();
  }
  PrintStr("\n");
  dispose lex7;

  PrintStr("=== All tests done ===\n");
  return 0;
}
