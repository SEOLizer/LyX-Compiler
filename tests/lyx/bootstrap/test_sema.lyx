// tests/lyx/bootstrap/test_sema.lyx
// WP-07: Self-Hosted Semantic Analyzer Test

import bootstrap.parser;
import bootstrap.sema;

// ============================================================================
// Helper: print N chars from a pchar (length-delimited)
// ============================================================================

fn PrintN(p: pchar, n: int64) {
  var buf: pchar := mmap(0, n + 1, 3, 34, -1, 0) as pchar;
  var addr: int64 := buf as int64;
  var i: int64 := 0;
  while (i < n) {
    poke8(addr + i, StrCharAt(p, i));
    i := i + 1;
  }
  poke8(addr + n, 0);
  PrintStr(buf);
}

// ============================================================================
// Test 1: Primitive type resolution and function registration
// ============================================================================

fn test1() {
  PrintStr("=== Test 1: primitive type resolution ===\n");
  var src: pchar := "fn add(x: int64, y: int64): int64 { return x + y; }";
  var p: Parser := new Parser();
  p.Init(src, StrLen(src));
  var head: int64 := p.Parse();
  var s: Sema := new Sema();
  s.Init(p.src, p.srcLen, p.nodes, p.nodeCount, p.toks, p.tokCount);
  if (head >= 0) { s.Check(head); }
  PrintStr("hadError="); PrintInt(s.hadError); PrintStr("\n");
  PrintStr("symCount="); PrintInt(s.symCount); PrintStr("\n");
  var found: int64 := s.Lookup("add", 3);
  PrintStr("sym 'add' found="); PrintInt(found); PrintStr("\n");
  if (found >= 0) {
    PrintStr("kind="); PrintInt(s.SymKind(found));
    PrintStr(" (expect="); PrintInt(SYM_FUNC); PrintStr(")\n");
  }
  dispose p;
  dispose s;
}

