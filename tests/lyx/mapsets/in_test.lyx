// Test "in" operator for maps and sets
fn main() {
  // Map test
  var m: Map<int64, int64> := {1: 10, 2: 20};
  
  if (1 in m) {
    PrintStr("1 in map: yes\n");
  } else {
    PrintStr("1 in map: no\n");
  }
  
  if (3 in m) {
    PrintStr("3 in map: yes\n");
  } else {
    PrintStr("3 in map: no\n");
  }
  
  // Set test
  var s: Set<int64> := {10, 20, 30};
  
  if (20 in s) {
    PrintStr("20 in set: yes\n");
  } else {
    PrintStr("20 in set: no\n");
  }
  
  if (99 in s) {
    PrintStr("99 in set: yes\n");
  } else {
    PrintStr("99 in set: no\n");
  }
  
  exit(0);
}
