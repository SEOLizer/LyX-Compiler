// Comprehensive Map/Set test
fn main() {
  PrintStr("=== Map Tests ===\n");
  
  // 1. Empty map creation
  var m: Map<int64, int64> := {};
  PrintStr("1. Empty map created\n");
  
  // 2. Map insertion
  m[1] := 100;
  m[2] := 200;
  m[3] := 300;
  PrintStr("2. Inserted 3 entries\n");
  
  // 3. Map access
  PrintStr("3. m[1] = ");
  PrintInt(m[1]);
  PrintStr(", m[2] = ");
  PrintInt(m[2]);
  PrintStr(", m[3] = ");
  PrintInt(m[3]);
  PrintStr("\n");
  
  // 4. Map update
  m[2] := 999;
  PrintStr("4. Updated m[2] = ");
  PrintInt(m[2]);
  PrintStr("\n");
  
  // 5. Map contains (in operator)
  if (1 in m) {
    PrintStr("5. Key 1 exists in map\n");
  }
  if (99 in m) {
    PrintStr("ERROR: Key 99 should not exist\n");
  } else {
    PrintStr("   Key 99 does not exist (correct)\n");
  }
  
  // 6. Map with literal initialization
  var m2: Map<int64, int64> := {10: 1000, 20: 2000};
  PrintStr("6. m2[10] = ");
  PrintInt(m2[10]);
  PrintStr(", m2[20] = ");
  PrintInt(m2[20]);
  PrintStr("\n");
  
  PrintStr("\n=== Set Tests ===\n");
  
  // 7. Set with single element (empty set not supported yet)
  var s: Set<int64> := {0};
  PrintStr("7. Set with initial element created\n");
  
  // 8. Set with literal initialization
  var s2: Set<int64> := {5, 10, 15, 20};
  PrintStr("8. Set with 4 elements created\n");
  
  // 9. Set contains (in operator)
  if (10 in s2) {
    PrintStr("9. Value 10 exists in set\n");
  }
  if (99 in s2) {
    PrintStr("ERROR: Value 99 should not exist\n");
  } else {
    PrintStr("   Value 99 does not exist (correct)\n");
  }
  
  PrintStr("\n=== All tests passed! ===\n");
  exit(0);
}
