// Test Windows x64 FFI: extern fn via IAT (msvcrt.dll)
// Tests that GetExternLibrary is used to route the call to the correct DLL

extern fn strlen(s: pchar): int64 link "msvcrt.dll";

fn main(): int64 {
  var s: pchar := "Hello Windows FFI!";
  var n: int64 := strlen(s);
  PrintStr("strlen result: ");
  PrintInt(n);
  PrintStr("\n");
  return 0;
}
