// Test: multi-return / tuple
// Expected output:
//   divmod(17, 5): q=3 r=2
//   divmod(100, 7): q=14 r=2

fn divmod(a: int64, b: int64): (int64, int64) {
  return (a / b, a % b);
}

fn main(): int64 {
  var q, r := divmod(17, 5);
  PrintStr("divmod(17, 5): q=");
  PrintInt(q);
  PrintStr(" r=");
  PrintInt(r);
  PrintStr("\n");

  var q2, r2 := divmod(100, 7);
  PrintStr("divmod(100, 7): q=");
  PrintInt(q2);
  PrintStr(" r=");
  PrintInt(r2);
  PrintStr("\n");

  return 0;
}
