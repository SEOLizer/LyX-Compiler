// Test: try/catch/throw — exception handling
// Expected output:
//   before try
//   caught: 42
//   after try
//   no throw path: done

fn main(): int64 {
  // Basic throw + catch
  PrintStr("before try\n");
  try {
    throw 42;
    PrintStr("unreachable\n");
  } catch (e: int64) {
    PrintStr("caught: ");
    PrintInt(e);
    PrintStr("\n");
  }
  PrintStr("after try\n");

  // No-throw path
  try {
    var x: int64 := 7;
  } catch (e: int64) {
    PrintStr("should not happen\n");
  }
  PrintStr("no throw path: done\n");

  return 0;
}
