// Test: Import vs local function
import data.core;

fn localNewInt64(name: int64, cap: int64): Series {
  var s: Series;
  var bmpSize: int64;
  var i: int64;
  
  s.data := mmap(0, cap * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  bmpSize := (cap + 7) / 8;
  s.nullBitmap := mmap(0, bmpSize, PROT_RW, MAP_ANON, FD_NONE, 0);
  i := 0;
  while (i < bmpSize) {
    poke8(s.nullBitmap + i, 0);
    i := i + 1;
  }
  s.labels := 0;
  s.length := 0;
  s.capacity := cap;
  s.colType := 1;
  s.name := name;
  s.memFlags := 1;
  return s;
}

fn main(): int64 {
  PrintStr("Test localNewInt64:\n");
  var s1: Series := localNewInt64(0, 10);
  SeriesSetInt(s1, 0, 42);
  var v1: int64 := SeriesGetInt(s1, 0);
  PrintInt(v1);
  PrintStr("\n");
  
  PrintStr("Test SeriesNewInt64 (imported):\n");
  var s2: Series := SeriesNewInt64(0, 10);
  SeriesSetInt(s2, 0, 99);
  var v2: int64 := SeriesGetInt(s2, 0);
  PrintInt(v2);
  PrintStr("\n");
  
  return 0;
}
