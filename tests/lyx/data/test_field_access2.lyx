// Test: Print struct field offsets
import tests.lyx.data.pointmod;

fn printPoint(p: Point): int64 {
  PrintStr("point at ");
  PrintInt(p.x);
  PrintStr(",");
  PrintInt(p.y);
  PrintStr("\n");
  return 0;
}

fn main(): int64 {
  var pt: Point;
  // Directly access fields before passing to function
  pt.x := 100;
  pt.y := 200;
  PrintStr("Direct access: x=");
  PrintInt(pt.x);
  PrintStr(" y=");
  PrintInt(pt.y);
  PrintStr("\n");
  
  // Now test via function
  printPoint(pt);
  return 0;
}
