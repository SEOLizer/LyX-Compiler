// Test: Compare working vs broken
import data.core;

fn makeSeriesManual(): Series {
  var s: Series;
  var bmpSize: int64;
  var i: int64;
  
  s.data := mmap(0, 80, PROT_RW, MAP_ANON, FD_NONE, 0);
  bmpSize := 2;
  s.nullBitmap := mmap(0, bmpSize, PROT_RW, MAP_ANON, FD_NONE, 0);
  i := 0;
  while (i < bmpSize) {
    poke8(s.nullBitmap + i, 0);
    i := i + 1;
  }
  s.labels := 0;
  s.length := 0;
  s.capacity := 10;
  s.colType := 1;
  s.name := 0;
  s.memFlags := 1;
  return s;
}

fn makeSeriesAuto(): Series {
  return SeriesNewInt64(0, 10);
}

fn main(): int64 {
  PrintStr("Manual:\n");
  var s1: Series := makeSeriesManual();
  SeriesSetInt(s1, 0, 42);
  var v1: int64 := SeriesGetInt(s1, 0);
  PrintInt(v1);
  PrintStr("\n");
  
  PrintStr("Auto:\n");
  var s2: Series := makeSeriesAuto();
  SeriesSetInt(s2, 0, 99);
  var v2: int64 := SeriesGetInt(s2, 0);
  PrintInt(v2);
  PrintStr("\n");
  
  return 0;
}
