// Test High-Priority Pandas Features
// Float, Rolling, agg, Apply, Boolean Indexing

import data.core;

fn main(): int64 {
  PrintStr("Testing High-Priority Pandas Features...\n");
  
  // Create test DataFrame
  var df: DataFrame := DataFrameNew();
  DataFrameAddColumn(df, "value", COL_INT64);
  DataFrameAddColumn(df, "score", COL_INT64);
  
  DataFrameAppendRow(df); DataFrameSetInt(df, "value", 0, 10); DataFrameSetInt(df, "score", 0, 85);
  DataFrameAppendRow(df); DataFrameSetInt(df, "value", 1, 20); DataFrameSetInt(df, "score", 1, 92);
  DataFrameAppendRow(df); DataFrameSetInt(df, "value", 2, 30); DataFrameSetInt(df, "score", 2, 78);
  DataFrameAppendRow(df); DataFrameSetInt(df, "value", 3, 15); DataFrameSetInt(df, "score", 3, 95);
  DataFrameAppendRow(df); DataFrameSetInt(df, "value", 4, 25); DataFrameSetInt(df, "score", 4, 88);
  
  PrintStr("DataFrame:\n");
  DataFramePrint(df);
  
  // Test 1: Float64 Series
  PrintStr("\nTest 1: Float64 Series\n");
  var floatS: Series := SeriesNewFloat64("temperature", 5);
  pokef64(floatS.data + 0, 20.5);
  pokef64(floatS.data + 8, 22.3);
  pokef64(floatS.data + 16, 19.8);
  pokef64(floatS.data + 24, 25.1);
  pokef64(floatS.data + 32, 21.7);
  floatS.length := 5;
  
  PrintStr("  Sum: ");
  PrintFloat(SeriesSumF64(floatS));
  PrintStr("\n");
  PrintStr("  Mean: ");
  PrintFloat(SeriesMeanF64(floatS));
  PrintStr("\n");
  PrintStr("  Min: ");
  PrintFloat(SeriesMinF64(floatS));
  PrintStr("\n");
  PrintStr("  Max: ");
  PrintFloat(SeriesMaxF64(floatS));
  PrintStr("\n");
  PrintStr("  StdDev: ");
  PrintFloat(SeriesStdDevF64(floatS));
  PrintStr("\n");
  
  // Test 2: Rolling Window
  PrintStr("\nTest 2: Rolling Window (3)\n");
  var vSeries: Series := DataFrameGetSeries(df, "value");
  var rolling: Series := SeriesRollingMean(vSeries, 3);
  PrintStr("  Rolling Mean(3): ");
  var i: int64 := 0;
  while (i < rolling.length) {
    PrintInt(SeriesGetInt(rolling, i));
    if (i < rolling.length - 1) { PrintStr(","); }
    i := i + 1;
  end;
  PrintStr("\n");
  
  rolling := SeriesRollingSum(vSeries, 3);
  PrintStr("  Rolling Sum(3):  ");
  i := 0;
  while (i < rolling.length) {
    PrintInt(SeriesGetInt(rolling, i));
    if (i < rolling.length - 1) { PrintStr(","); }
    i := i + 1;
  end;
  PrintStr("\n");
  
  // Test 3: agg()
  PrintStr("\nTest 3: agg() on all columns\n");
  var aggResult: DataFrame := DataFrameAgg(df, AGG_SUM);
  PrintStr("  Sum:\n");
  DataFramePrint(aggResult);
  
  aggResult := DataFrameAgg(df, AGG_MAX);
  PrintStr("  Max:\n");
  DataFramePrint(aggResult);
  
  // Test 4: GroupBy + Multi-Agg
  PrintStr("\nTest 4: GroupBy + Multi-Agg\n");
  var df2: DataFrame := DataFrameNew();
  DataFrameAddColumn(df2, "dept", COL_INT64);
  DataFrameAddColumn(df2, "salary", COL_INT64);
  DataFrameAppendRow(df2); DataFrameSetInt(df2, "dept", 0, 1); DataFrameSetInt(df2, "salary", 0, 50000);
  DataFrameAppendRow(df2); DataFrameSetInt(df2, "dept", 0, 1); DataFrameSetInt(df2, "salary", 1, 60000);
  DataFrameAppendRow(df2); DataFrameSetInt(df2, "dept", 0, 2); DataFrameSetInt(df2, "salary", 2, 70000);
  DataFrameAppendRow(df2); DataFrameSetInt(df2, "dept", 0, 2); DataFrameSetInt(df2, "salary", 3, 80000);
  DataFrameAppendRow(df2); DataFrameSetInt(df2, "dept", 0, 1); DataFrameSetInt(df2, "salary", 4, 55000);
  
  var gb: GroupByResult := DataFrameGroupBy(df2, "dept");
  var grouped: DataFrame := GroupByAgg(gb, "salary");
  PrintStr("  GroupBy dept -> Multi-Agg(salary):\n");
  DataFramePrint(grouped);
  
  // Test 5: Apply (Transform)
  PrintStr("\nTest 5: Apply/Transform\n");
  var doubled: Series := SeriesTransformMul(vSeries, 2);
  PrintStr("  Values * 2: ");
  i := 0;
  while (i < doubled.length) {
    PrintInt(SeriesGetInt(doubled, i));
    if (i < doubled.length - 1) { PrintStr(","); }
    i := i + 1;
  end;
  PrintStr("\n");
  
  var normalized: Series := SeriesTransformNormalize(vSeries);
  PrintStr("  Normalized: ");
  i := 0;
  while (i < normalized.length) {
    PrintInt(SeriesGetInt(normalized, i));
    if (i < normalized.length - 1) { PrintStr(","); }
    i := i + 1;
  end;
  PrintStr("\n");
  
  var absS: Series := SeriesApplyAbs(vSeries);
  PrintStr("  Abs: ");
  i := 0;
  while (i < absS.length) {
    PrintInt(SeriesGetInt(absS, i));
    if (i < absS.length - 1) { PrintStr(","); }
    i := i + 1;
  end;
  PrintStr("\n");
  
  // Test 6: Boolean Indexing
  PrintStr("\nTest 6: Boolean Indexing\n");
  var mask: BoolSeries := SeriesGreaterThan(vSeries, 15);
  PrintStr("  value > 15: ");
  i := 0;
  while (i < mask.length) {
    if (peek8(mask.data + i * 8) == 1) { PrintStr("T"); }
    else { PrintStr("F"); }
    i := i + 1;
  end;
  PrintStr("\n");
  
  var filtered: DataFrame := DataFrameFilterByMask(df, mask);
  PrintStr("  Filtered DataFrame:\n");
  DataFramePrint(filtered);
  
  // Test 7: Boolean operations
  PrintStr("\nTest 7: Boolean Operations\n");
  var mask2: BoolSeries := SeriesLessThan(vSeries, 25);
  var combined: BoolSeries := BoolSeriesAnd(mask, mask2);
  PrintStr("  (value > 15) AND (value < 25): ");
  i := 0;
  while (i < combined.length) {
    if (peek8(combined.data + i * 8) == 1) { PrintStr("T"); }
    else { PrintStr("F"); }
    i := i + 1;
  end;
  PrintStr("\n");
  
  PrintStr("  Any true: ");
  PrintInt(BoolSeriesAny(combined));
  PrintStr("\n");
  PrintStr("  All true: ");
  PrintInt(BoolSeriesAll(combined));
  PrintStr("\n");
  PrintStr("  Count true: ");
  PrintInt(BoolSeriesCount(combined));
  PrintStr("\n");
  
  // Test 8: Range filter
  PrintStr("\nTest 8: Range Filter (15 <= value <= 25)\n");
  var rangeMask: BoolSeries := SeriesInRange(vSeries, 15, 25);
  filtered := DataFrameFilterByMask(df, rangeMask);
  DataFramePrint(filtered);
  
  PrintStr("\nAll high-priority tests completed!\n");
  return 0;
}
