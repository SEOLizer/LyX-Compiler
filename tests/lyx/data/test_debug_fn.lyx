// Debug: print values inside function
import data.core;

fn debugNewInt64(name: int64, cap: int64): Series {
  PrintStr("F: start\n");
  var s: Series;
  PrintStr("F: var done\n");
  
  var dataPtr: int64 := mmap(0, cap * 8, 3, 34, -1, 0);
  PrintStr("F: data mmap done: ");
  PrintInt(dataPtr);
  PrintStr("\n");
  
  s.data := dataPtr;
  
  var bmpSize: int64 := (cap + 7) / 8;
  var bmpPtr: int64 := mmap(0, bmpSize, 3, 34, -1, 0);
  PrintStr("F: bmp mmap done: ");
  PrintInt(bmpPtr);
  PrintStr("\n");
  
  s.nullBitmap := bmpPtr;
  s.labels := 0;
  s.length := 0;
  s.capacity := cap;
  s.colType := 1;
  s.name := name;
  s.memFlags := 1;
  
  PrintStr("F: returning\n");
  return s;
}

fn main(): int64 {
  PrintStr("Vor debugNewInt64\n");
  var s: Series := debugNewInt64(0, 10);
  PrintStr("Nach debugNewInt64\n");
  
  PrintStr("data: ");
  PrintInt(s.data);
  PrintStr("\n");
  
  return 0;
}
