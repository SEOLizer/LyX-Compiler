// Test: Import module with struct-returning function - with debug
import tests.lyx.data.structmod;

fn main(): int64 {
  // First, test local creation
  var localP: Pair;
  localP.x := 1000;
  localP.y := 2000;
  PrintStr("Local: ");
  PrintInt(localP.x);
  PrintStr(" ");
  PrintInt(localP.y);
  PrintStr("\n");
  
  // Now test imported function
  PrintStr("Calling makePair...\n");
  var p: Pair := makePair(100, 200);
  PrintStr("After call, p = ");
  PrintInt(p.x);
  PrintStr(" ");
  PrintInt(p.y);
  PrintStr("\n");
  return 0;
}
