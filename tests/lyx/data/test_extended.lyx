// Test Extended Data Library Features
// Join, Pivot, Melt, Correlation, Multi-column GroupBy

import data.core;

fn main(): int64 {
  PrintStr("Testing Extended Data Library Features...\n");
  
  // Test 1: Inner Join
  PrintStr("Test 1: Inner Join\n");
  var left: DataFrame := DataFrameNew();
  DataFrameAddColumn(left, "id", COL_INT64);
  DataFrameAddColumn(left, "name", COL_STRING);
  DataFrameAppendRow(left); DataFrameSetInt(left, "id", 0, 1); DataFrameSetString(left, "name", 0, "Alice");
  DataFrameAppendRow(left); DataFrameSetInt(left, "id", 1, 2); DataFrameSetString(left, "name", 1, "Bob");
  DataFrameAppendRow(left); DataFrameSetInt(left, "id", 2, 3); DataFrameSetString(left, "name", 2, "Charlie");
  
  var right: DataFrame := DataFrameNew();
  DataFrameAddColumn(right, "id", COL_INT64);
  DataFrameAddColumn(right, "score", COL_INT64);
  DataFrameAppendRow(right); DataFrameSetInt(right, "id", 0, 1); DataFrameSetInt(right, "score", 0, 95);
  DataFrameAppendRow(right); DataFrameSetInt(right, "id", 1, 2); DataFrameSetInt(right, "score", 1, 87);
  DataFrameAppendRow(right); DataFrameSetInt(right, "id", 1, 3); DataFrameSetInt(right, "score", 1, 92);
  
  PrintStr("  Left:\n");
  DataFramePrint(left);
  PrintStr("  Right:\n");
  DataFramePrint(right);
  
  var joined: DataFrame := DataFrameJoinInner(left, "id", right, "id");
  PrintStr("  Inner Join Result:\n");
  DataFramePrint(joined);
  
  // Test 2: Left Join
  PrintStr("Test 2: Left Join\n");
  var leftJoin: DataFrame := DataFrameJoinLeft(left, "id", right, "id");
  DataFramePrint(leftJoin);
  
  // Test 3: Pivot
  PrintStr("\nTest 3: Pivot\n");
  var longDf: DataFrame := DataFrameNew();
  DataFrameAddColumn(longDf, "id", COL_INT64);
  DataFrameAddColumn(longDf, "type", COL_INT64);
  DataFrameAddColumn(longDf, "value", COL_INT64);
  
  DataFrameAppendRow(longDf); DataFrameSetInt(longDf, "id", 0, 1); DataFrameSetInt(longDf, "type", 0, 10); DataFrameSetInt(longDf, "value", 0, 100);
  DataFrameAppendRow(longDf); DataFrameSetInt(longDf, "id", 0, 1); DataFrameSetInt(longDf, "type", 0, 20); DataFrameSetInt(longDf, "value", 0, 200);
  DataFrameAppendRow(longDf); DataFrameSetInt(longDf, "id", 1, 2); DataFrameSetInt(longDf, "type", 1, 10); DataFrameSetInt(longDf, "value", 1, 150);
  DataFrameAppendRow(longDf); DataFrameSetInt(longDf, "id", 1, 2); DataFrameSetInt(longDf, "type", 1, 20); DataFrameSetInt(longDf, "value", 1, 250);
  
  PrintStr("  Long format:\n");
  DataFramePrint(longDf);
  
  var pivoted: DataFrame := DataFramePivot(longDf, "id", "type", "value");
  PrintStr("  Pivoted (wide format):\n");
  DataFramePrint(pivoted);
  
  // Test 4: Melt
  PrintStr("\nTest 4: Melt (Unpivot)\n");
  var wideDf: DataFrame := DataFrameNew();
  DataFrameAddColumn(wideDf, "id", COL_INT64);
  DataFrameAddColumn(wideDf, "a", COL_INT64);
  DataFrameAddColumn(wideDf, "b", COL_INT64);
  
  DataFrameAppendRow(wideDf); DataFrameSetInt(wideDf, "id", 0, 1); DataFrameSetInt(wideDf, "a", 0, 10); DataFrameSetInt(wideDf, "b", 0, 20);
  DataFrameAppendRow(wideDf); DataFrameSetInt(wideDf, "id", 1, 2); DataFrameSetInt(wideDf, "a", 1, 30); DataFrameSetInt(wideDf, "b", 1, 40);
  
  PrintStr("  Wide format:\n");
  DataFramePrint(wideDf);
  
  var melted: DataFrame := DataFrameMelt(wideDf, "id", 1, 2);
  PrintStr("  Melted (long format):\n");
  DataFramePrint(melted);
  
  // Test 5: Correlation
  PrintStr("\nTest 5: Correlation\n");
  var s1: Series := DataFrameGetSeries(left, "id");
  var s2: Series := DataFrameGetSeries(right, "score");
  PrintStr("  Corr(id, score) * 1000 = ");
  PrintInt(SeriesCorr(s1, s2));
  PrintStr("\n");
  
  PrintStr("  Cov(id, score) = ");
  PrintInt(SeriesCov(s1, s2));
  PrintStr("\n");
  
  // Test 6: Describe
  PrintStr("\nTest 6: Describe\n");
  var desc: DataFrame := SeriesDescribe(s2);
  DataFramePrint(desc);
  
  // Test 7: Multi-Column GroupBy
  PrintStr("\nTest 7: Multi-Column GroupBy\n");
  var sales: DataFrame := DataFrameNew();
  DataFrameAddColumn(sales, "region", COL_INT64);
  DataFrameAddColumn(sales, "product", COL_INT64);
  DataFrameAddColumn(sales, "amount", COL_INT64);
  
  DataFrameAppendRow(sales); DataFrameSetInt(sales, "region", 0, 1); DataFrameSetInt(sales, "product", 0, 10); DataFrameSetInt(sales, "amount", 0, 100);
  DataFrameAppendRow(sales); DataFrameSetInt(sales, "region", 0, 1); DataFrameSetInt(sales, "product", 0, 20); DataFrameSetInt(sales, "amount", 0, 200);
  DataFrameAppendRow(sales); DataFrameSetInt(sales, "region", 1, 1); DataFrameSetInt(sales, "product", 1, 10); DataFrameSetInt(sales, "amount", 1, 150);
  DataFrameAppendRow(sales); DataFrameSetInt(sales, "region", 1, 2); DataFrameSetInt(sales, "product", 1, 10); DataFrameSetInt(sales, "amount", 1, 300);
  
  PrintStr("  Sales data:\n");
  DataFramePrint(sales);
  
  // Create key columns array
  var keyCols: int64 := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
  poke8(keyCols, "region");
  poke8(keyCols + 8, "product");
  
  var mgb: MultiGroupByResult := DataFrameGroupByMulti(sales, keyCols, 2);
  var mcount: DataFrame := GroupByMultiCount(mgb);
  PrintStr("  Multi-Column GroupBy (region, product) -> Count:\n");
  DataFramePrint(mcount);
  
  PrintStr("\nAll extended tests completed!\n");
  return 0;
}
