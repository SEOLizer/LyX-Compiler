// Test Index Labels
// Demonstrates string labels, set_index, reset_index

import data.core;

fn main(): int64 {
  PrintStr("Testing Index Labels...\n");
  
  // Create DataFrame
  var df: DataFrame := DataFrameNew();
  DataFrameAddColumn(df, "name", COL_STRING);
  DataFrameAddColumn(df, "age", COL_INT64);
  DataFrameAddColumn(df, "city", COL_INT64);
  
  DataFrameAppendRow(df); DataFrameSetString(df, "name", 0, "Alice"); DataFrameSetInt(df, "age", 0, 25); DataFrameSetInt(df, "city", 0, 100);
  DataFrameAppendRow(df); DataFrameSetString(df, "name", 1, "Bob"); DataFrameSetInt(df, "age", 1, 30); DataFrameSetInt(df, "city", 1, 200);
  DataFrameAppendRow(df); DataFrameSetString(df, "name", 2, "Charlie"); DataFrameSetInt(df, "age", 2, 35); DataFrameSetInt(df, "city", 2, 100);
  
  PrintStr("Original DataFrame:\n");
  DataFramePrint(df);
  
  // Test 1: Set index from name column
  PrintStr("\nTest 1: Set index from 'name' column\n");
  DataFrameSetIndexFromColumn(df, "name");
  PrintStr("  Has index: ");
  PrintInt(DataFrameHasIndex(df));
  PrintStr("\n");
  
  var i: int64 := 0;
  while (i < df.rowCount) {
    var label: int64 := DataFrameGetIndexLabel(df, i);
    PrintStr("  Row ");
    PrintInt(i);
    PrintStr(" -> ");
    if (label != 0) {
      PrintStr(label);
    } else {
      PrintStr("(none)");
    }
    PrintStr("\n");
    i := i + 1;
  end;
  
  // Test 2: Lookup by label
  PrintStr("\nTest 2: Lookup by label\n");
  var row: int64 := DataFrameIndexLookup(df, "Bob");
  PrintStr("  Lookup 'Bob' -> row ");
  PrintInt(row);
  PrintStr("\n");
  
  // Test 3: Get value by label
  PrintStr("\nTest 3: Get value by label\n");
  var val: int64 := DataFrameGetIntByLabel(df, "age", "Bob");
  PrintStr("  Bob's age = ");
  PrintInt(val);
  PrintStr("\n");
  
  val := DataFrameGetIntByLabel(df, "age", "Charlie");
  PrintStr("  Charlie's age = ");
  PrintInt(val);
  PrintStr("\n");
  
  // Test 4: Set value by label
  PrintStr("\nTest 4: Set value by label\n");
  DataFrameSetIntByLabel(df, "age", "Bob", 31);
  val := DataFrameGetIntByLabel(df, "age", "Bob");
  PrintStr("  Bob's new age = ");
  PrintInt(val);
  PrintStr("\n");
  
  // Test 5: Print with index
  PrintStr("\nTest 5: DataFrame with index:\n");
  i := 0;
  while (i < df.rowCount) {
    var label: int64 := DataFrameGetIndexLabel(df, i);
    PrintStr("[");
    if (label != 0) {
      PrintStr(label);
    } else {
      PrintInt(i);
    }
    PrintStr("] ");
    PrintStr("age=");
    PrintInt(DataFrameGetInt(df, "age", i));
    PrintStr(", city=");
    PrintInt(DataFrameGetInt(df, "city", i));
    PrintStr("\n");
    i := i + 1;
  end;
  
  // Test 6: Reset index
  PrintStr("\nTest 6: Reset index\n");
  DataFrameResetIndex(df);
  PrintStr("  Has index: ");
  PrintInt(DataFrameHasIndex(df));
  PrintStr("\n");
  
  PrintStr("\nAll index tests completed!\n");
  return 0;
}
