// Test: Same code but in single module
pub type Point = struct {
  x: int64;
  y: int64;
};

fn makePoint(px: int64, py: int64): Point {
  var p: Point;
  p.x := px;
  p.y := py;
  return p;
}

fn getX(p: Point): int64 {
  return p.x;
}

fn getY(p: Point): int64 {
  return p.y;
}

fn main(): int64 {
  var pt: Point := makePoint(10, 20);
  
  PrintStr("pt.x = ");
  PrintInt(getX(pt));
  PrintStr("\n");
  
  PrintStr("pt.y = ");
  PrintInt(getY(pt));
  PrintStr("\n");
  
  return 0;
}
