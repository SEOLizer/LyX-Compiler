// Simple module that returns a struct - with debug
pub type Pair = struct {
  x: int64;
  y: int64;
};

pub fn makePair(a: int64, b: int64): Pair {
  PrintStr("makePair called with: ");
  PrintInt(a);
  PrintStr(" ");
  PrintInt(b);
  PrintStr("\n");
  
  var p: Pair;
  p.x := a;
  p.y := b;
  
  PrintStr("Returning p.x=");
  PrintInt(p.x);
  PrintStr(" p.y=");
  PrintInt(p.y);
  PrintStr("\n");
  
  return p;
}
