// Test: Simple struct return from function in same module
pub type Simple = struct {
  a: int64;
  b: int64;
};

fn makeSimple(x: int64, y: int64): Simple {
  var s: Simple;
  s.a := x;
  s.b := y;
  return s;
}

fn main(): int64 {
  var s: Simple := makeSimple(10, 20);
  PrintInt(s.a);
  PrintStr(" ");
  PrintInt(s.b);
  PrintStr("\n");
  return 0;
}
