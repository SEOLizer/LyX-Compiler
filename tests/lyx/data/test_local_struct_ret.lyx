// Test: Local function returning struct - verify it works
pub type Pair = struct {
  x: int64;
  y: int64;
};

fn makePairLocal(a: int64, b: int64): Pair {
  var p: Pair;
  p.x := a;
  p.y := b;
  return p;
}

fn main(): int64 {
  var p: Pair := makePairLocal(100, 200);
  PrintInt(p.x);
  PrintStr(" ");
  PrintInt(p.y);
  PrintStr("\n");
  return 0;
}
