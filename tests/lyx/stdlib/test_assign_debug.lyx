// Test struct field assignment
import std.io;

type TConn = struct {
    fd: int64;
    pass: pchar;
};

fn createConn(passArg: pchar): TConn {
    var conn: TConn;
    conn.fd := 100;
    // Hier ist die Zuweisung
    conn.pass := passArg;
    return conn;
}

pub fn main(): int64 {
    PrintStr("=== Struct Field Assign Test ===\n");
    
    var conn: TConn := createConn("mypassword");
    
    PrintStr("conn.pass = ");
    PrintStr(conn.pass);
    PrintStr("\n");
    
    PrintStr("=== Address Test ===\n");
    var passAddr: int64 := conn.pass as int64;
    PrintStr("addr = ");
    PrintInt(passAddr);
    PrintStr("\n");
    
    if (passAddr > 0) {
        PrintStr("first char = ");
        PrintInt(peek8(passAddr));
        PrintStr("\n");
    }
    
    PrintStr("=== Test Complete ===\n");
    return 0;
}