// Test struct return + field cast - wie MySQL
import std.io;

type TConn = struct {
    fd: int64;
    pass: pchar;
    other: int64;
};

fn createConn(passArg: pchar): TConn {
    var conn: TConn;
    conn.fd := 100;
    conn.pass := passArg;
    conn.other := 200;
    return conn;
}

pub fn main(): int64 {
    PrintStr("=== Struct Return + Field Cast Test ===\n");
    
    var conn: TConn := createConn("mypassword");
    
    // Cast field to int64
    var addr: int64 := conn.pass as int64;
    PrintStr("Result addr = ");
    PrintInt(addr);
    PrintStr("\n");
    
    if (addr > 0) {
        var firstChar: int64 := peek8(addr);
        PrintStr("First char = ");
        PrintInt(firstChar);
        PrintStr(" (expected 109 = 'm')\n");
    }
    
    PrintStr("=== Test Complete ===\n");
    return 0;
}