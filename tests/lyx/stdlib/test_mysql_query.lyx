import std.db.mysql;
import std.io;

pub fn main(): int64 {
    PrintStr("=== MySQL Full Query Test ===\n");
    
    // Connect with username 'lyx' and password 'test12345'
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx", "test12345", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connect FAILED: error=");
        PrintInt(conn.error_num);
        PrintStr("\n");
        return 1;
    }
    
    PrintStr("Connected!\n");
    
    // Send COM_QUERY: SELECT 1
    var result: int64 := MySQLQuery(conn, "SELECT 1 AS test_value");
    
    if (result < 0) {
        PrintStr("Query failed: ");
        PrintInt(result);
        PrintStr("\n");
        sys_close(conn.fd);
        return 1;
    }
    
    PrintStr("Query result rows: ");
    PrintInt(result);
    PrintStr("\n");
    
    // Read result
    if (result > 0) {
        var rows: int64 := MySQLFetchRow(conn);
        if (rows > 0) {
            PrintStr("Row 0, Col 0: ");
            PrintInt(peek8(rows));
            PrintStr("\n");
        }
    }
    
    // Cleanup
    sys_close(conn.fd);
    
    PrintStr("=== SUCCESS ===\n");
    return 0;
}