import std.db.mysql;
import std.io;

pub fn main(): int64 {
    PrintStr("=== MySQL Stepwise Test ===\n");
    
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx", "test12345", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connect FAILED: error=");
        PrintInt(conn.error_num);
        return 1;
    }
    
    PrintStr("Step 1: Connected\n");
    
    // Test MySQLSendPacket with COM_QUERY (=3)
    var sql: pchar := "SELECT 1";
    var sqlLen: int64 := 8;
    
    PrintStr("Step 2: Before MySQLSendPacket\n");
    var sqlBuf: int64 := mmap(0, sqlLen, 3, 34, -1, 0);
    var i: int64 := 0;
    while (i < sqlLen) {
        poke8(sqlBuf + i, peek8(sql + i));
        i := i + 1;
    }
    var sendOk: bool := MySQLSendPacket(conn, sqlBuf, sqlLen);
    PrintStr("Step 3: After MySQLSendPacket, result=");
    if (sendOk) { PrintStr("true"); } else { PrintStr("false"); }
    PrintStr("\n");
    
    if (sendOk) {
        munmap(sqlBuf, sqlLen);
        sys_close(conn.fd);
        return 0;
    }
    
    PrintStr("Step 4: Before MySQLReadPacket\n");
    var pkt: int64 := MySQLReadPacket(conn);
    PrintStr("Step 5: After MySQLReadPacket, pkt=");
    PrintInt(pkt);
    PrintStr("\n");
    
    if (pkt > 0) {
        PrintStr("payload_len=");
        PrintInt(conn.last_payload_len);
        PrintStr("\n");
        PrintStr("first byte=");
        PrintInt(peek8(pkt));
        PrintStr("\n");
    }
    
    sys_close(conn.fd);
    
    PrintStr("=== Done ===\n");
    return 0;
}