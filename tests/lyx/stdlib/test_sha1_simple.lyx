// Einfacher SHA1 Test
import std.io;
import std.crypto.sha1;

pub fn main(): int64 {
    PrintStr("=== Simple SHA1 Test ===\n");
    
    var data: int64 := mmap(0, 10, 3, 34, -1, 0);
    poke8(data, 72); // 'H'
    poke8(data + 1, 101); // 'e'
    poke8(data + 2, 108); // 'l'
    poke8(data + 3, 108); // 'l'
    poke8(data + 4, 111); // 'o'
    
    var out: int64 := mmap(0, 20, 3, 34, -1, 0);
    
    PrintStr("Calling SHA1...\n");
    SHA1(data, 5, out);
    PrintStr("Back!\n");
    
    PrintStr("Hash: ");
    var i: int64 := 0;
    while (i < 20) {
        PrintInt(peek8(out + i));
        PrintStr(" ");
        i := i + 1;
    }
    PrintStr("\n");
    
    munmap(data, 10);
    munmap(out, 20);
    
    PrintStr("=== Done ===\n");
    return 0;
}