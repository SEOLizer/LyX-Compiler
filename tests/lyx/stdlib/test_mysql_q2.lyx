import std.db.mysql;
import std.io;

pub fn main(): int64 {
    PrintStr("=== MySQL Simple Query Test ===\n");
    
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx", "test12345", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connect FAILED: error=");
        PrintInt(conn.error_num);
        return 1;
    }
    
    PrintStr("Connected OK!\n");
    
    // Build SQL buffer directly
    var sql: pchar := "SELECT 1";
    var sqlLen: int64 := 8;
    var sqlBuf: int64 := mmap(0, sqlLen, 3, 34, -1, 0);
    
    // Copy string to buffer
    var i: int64 := 0;
    while (i < sqlLen) {
        poke8(sqlBuf + i, peek8(sql + i));
        i := i + 1;
    }
    
    PrintStr("Sending packet...\n");
    var ok: bool := MySQLSendPacket(conn, sqlBuf, sqlLen);
    if (ok) { PrintStr("Send OK\n"); } else { PrintStr("Send FAIL\n"); }
    munmap(sqlBuf, sqlLen);
    
    if (!ok) {
        sys_close(conn.fd);
        return 1;
    }
    
    PrintStr("Reading response packet...\n");
    var pkt: int64 := MySQLReadPacket(conn);
    if (pkt > 0) {
        PrintStr("Got packet: len=");
        PrintInt(conn.last_payload_len);
        PrintStr(", first=");
        PrintInt(peek8(pkt));
        PrintStr("\n");
        munmap(pkt, conn.last_payload_len + 1);
    } else {
        PrintStr("No packet\n");
    }
    
    sys_close(conn.fd);
    
    PrintStr("=== SUCCESS ===\n");
    return 0;
}