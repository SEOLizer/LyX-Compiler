// Test: std/os basic functions
// Tests: sleep, get_pid, env_get, env_set, get_cwd

import std.os;

fn main(): int64 {
  PrintStr("=== std/os Tests ===\n");
  
  // Test get_pid
  var pid: int64 := get_pid();
  PrintStr("PID: ");
  PrintInt(pid);
  PrintStr("\n");
  
  // Test env_get
  var home: pchar := env_get("HOME");
  PrintStr("HOME: ");
  PrintStr(home);
  PrintStr("\n");
  
  var path: pchar := env_get("PATH");
  PrintStr("PATH exists: ");
  if (path != "") {
    PrintStr("yes\n");
  } else {
    PrintStr("no\n");
  }
  
  // Test env_has
  var has_home: bool := env_has("HOME");
  PrintStr("env_has(HOME): ");
  if (has_home) {
    PrintStr("true\n");
  } else {
    PrintStr("false\n");
  }
  
  // Test get_cwd
  var cwd: pchar := get_cwd();
  PrintStr("CWD: ");
  PrintStr(cwd);
  PrintStr("\n");
  
  // Test time
  var t: int64 := time();
  PrintStr("Unix time: ");
  PrintInt(t);
  PrintStr("\n");
  
  // Test get_os_name
  var os_name: pchar := get_os_name();
  PrintStr("OS: ");
  PrintStr(os_name);
  PrintStr("\n");
  
  // Test get_arch
  var arch: pchar := get_arch();
  PrintStr("Architecture: ");
  PrintStr(arch);
  PrintStr("\n");
  
  // Test get_user_name
  var user: pchar := get_user_name();
  PrintStr("User: ");
  PrintStr(user);
  PrintStr("\n");
  
  // Test get_temp_dir
  var tmp: pchar := get_temp_dir();
  PrintStr("Temp dir: ");
  PrintStr(tmp);
  PrintStr("\n");
  
  // Test sleep (brief)
  PrintStr("Testing sleep(100ms)...\n");
  sleep(100);
  PrintStr("Sleep done!\n");
  
  PrintStr("=== All tests passed! ===\n");
  
  return 0;
}
