// Debug: Test was im Feld passiert
import std.io;

type TConn = struct {
    fd: int64;
    pass: pchar;
};

fn testFn(conn: TConn): int64 {
    // Einfach zuweisen und dann casten
    var temp: pchar := conn.pass;
    var addr: int64 := temp as int64;
    return addr;
}

pub fn main(): int64 {
    var conn: TConn;
    conn.fd := 100;
    conn.pass := "secret";
    
    PrintStr("Direct cast: ");
    var r1: int64 := conn.pass as int64;
    PrintInt(r1);
    PrintStr("\n");
    
    PrintStr("Via temp: ");
    var r2: int64 := testFn(conn);
    PrintInt(r2);
    PrintStr("\n");
    
    return 0;
}