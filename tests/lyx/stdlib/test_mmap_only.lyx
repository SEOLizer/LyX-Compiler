// Simple mmap test
import std.io;

pub fn main(): int64 {
    PrintStr("=== mmap Test ===\n");
    
    var data: int64 := mmap(0, 4096, 3, 34, -1, 0);
    PrintStr("mmap returned: ");
    PrintInt(data);
    PrintStr("\n");
    
    if data == 0 {
        PrintStr("ERROR: mmap failed\n");
        return 1;
    }
    
    // Write some data
    poke8(data, 72); // 'H'
    poke8(data + 1, 101); // 'e'
    poke8(data + 2, 108); // 'l'
    poke8(data + 3, 108); // 'l'
    poke8(data + 4, 111); // 'o'
    
    // Read it back
    var b: int64 := peek8(data);
    PrintStr("peek8(data) = ");
    PrintInt(b);
    PrintStr("\n");
    
    var i: int64 := 0;
    while i < 5 {
        var c: int64 := peek8(data + i);
        PrintStr("byte ");
        PrintInt(i);
        PrintStr(" = ");
        PrintInt(c);
        PrintStr("\n");
        i := i + 1;
    }
    
    munmap(data, 4096);
    
    PrintStr("=== Done ===\n");
    return 0;
}