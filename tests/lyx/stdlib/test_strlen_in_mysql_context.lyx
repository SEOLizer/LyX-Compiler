import std.db.mysql;
import std.io;
import std.string;

pub fn main(): int64 {
    PrintStr("=== StrLen in MySQL Context Test ===\n");
    
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx", "test12345", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connect FAILED: error=");
        PrintInt(conn.error_num);
        return 1;
    }
    
    PrintStr("Connected OK!\n");
    
    // Test StrLen inside the same function that MySQLQuery uses
    // (We pass the pchar through MySQLConn - need to test this way)
    var testSql: pchar := "SELECT 1";
    var sqlLen: int64 := StrLen(testSql);
    PrintStr("StrLen('SELECT 1') = ");
    PrintInt(sqlLen);
    PrintStr("\n");
    
    // Reset packet_num for query
    conn.packet_num := 0;
    
    // Try to call mysqlSendCommand via the SQL we pass
    // But wait, mysqlSendCommand is internal function - we can't call it directly
    
    sys_close(conn.fd);
    
    PrintStr("=== SUCCESS ===\n");
    return 0;
}