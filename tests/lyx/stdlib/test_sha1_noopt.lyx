// SHA1 test with no optimization
import std.io;
import std.crypto.sha1;

fn dummy(): int64 {
    return 42;
}

pub fn main(): int64 {
    PrintStr("=== SHA1 NoOpt Test ===\n");
    
    var data: int64 := mmap(0, 10, 3, 34, -1, 0);
    poke8(data, 72); // 'H'
    poke8(data + 1, 101); // 'e'
    poke8(data + 2, 108); // 'l'
    poke8(data + 3, 108); // 'l'
    poke8(data + 4, 111); // 'o'
    
    var out: int64 := mmap(0, 20, 3, 34, -1, 0);
    
    var d: int64 := dummy();
    PrintStr("dummy returned: ");
    PrintInt(d);
    PrintStr("\n");
    
    PrintStr("Calling SHA1...\n");
    SHA1(data, 5, out);
    PrintStr("Back!\n");
    
    munmap(data, 10);
    munmap(out, 20);
    
    PrintStr("=== Done ===\n");
    return 0;
}