import std.db.mysql;
import std.io;

pub fn main(): int64 {
    PrintStr("MySQL Test (User: lyx, Pass: test12345)\n");
    
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx", "test12345", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connect failed: ");
        PrintInt(conn.error_num);
        PrintStr("\n");
        return 1;
    }
    
    PrintStr("Connected!\n");
    
    // Simple query
    var res: MySQLResult := MySQLQuery(conn, "SELECT 1");
    
    if (conn.error_num != 0) {
        PrintStr("Query failed with error code: ");
        PrintInt(conn.error_num);
        PrintStr("\n");
    }
    else {
        PrintStr("Query success!\n");
        PrintStr("Affected Rows: ");
        PrintInt(MySQLAffectedRows(conn));
        PrintStr("\n");
        // Hier sollten die Ergebnisdaten ausgelesen werden, falls gewünscht.
    }

    MySQLFreeResult(res); 
    MySQLClose(conn);
    PrintStr("Test abgeschlossen.\n");
    return 0;
}