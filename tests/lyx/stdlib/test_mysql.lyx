// Test program for MySQL connection
// Tests connection to local MySQL/MariaDB

import std.db.mysql;
import std.io;

pub fn main(): int64 {
    PrintStr("Testing MySQL connection...\n");
    PrintStr("===========================\n");
    
    // Connect to localhost:3306
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx", "test12345", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connection failed!\n");
        PrintStr("Error: ");
        PrintStr(MySQLError(conn));
        PrintStr("\n");
        PrintStr("Error number: ");
        PrintInt(MySQLErrno(conn));
        PrintStr("\n");
        return 1;
    }
    
    PrintStr("Connected successfully!\n");
    
    // Test a simple query
    var res: MySQLResult := MySQLQuery(conn, "SELECT 1 AS test");
    
    if (conn.error_num != 0) {
        PrintStr("Query failed!\n");
        PrintStr("Error: ");
        PrintStr(MySQLError(conn));
        PrintStr("\n");
        MySQLClose(conn);
        return 1;
    }
    
    PrintStr("Query successful!\n");
    PrintStr("Rows returned: ");
    PrintInt(MySQLNumRows(res));
    PrintStr("\n");
    
    MySQLFreeResult(res);
    
    // Test SHOW DATABASES
    var res2: MySQLResult := MySQLQuery(conn, "SHOW DATABASES");
    
    if (conn.error_num != 0) {
        PrintStr("SHOW DATABASES failed!\n");
        PrintStr("Error: ");
        PrintStr(MySQLError(conn));
        PrintStr("\n");
        MySQLClose(conn);
        return 1;
    }
    
    PrintStr("SHOW DATABASES - Rows: ");
    PrintInt(MySQLNumRows(res2));
    PrintStr("\n");
    
    MySQLFreeResult(res2);
    
    // Close connection
    MySQLClose(conn);
    PrintStr("Connection closed.\n");
    PrintStr("Test passed!\n");
    
    return 0;
}