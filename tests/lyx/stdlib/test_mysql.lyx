import std.db.mysql;
import std.io;

pub fn main(): int64 {
    PrintStr("MySQL Test\n");
    
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx2", "", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Failed: ");
        PrintInt(conn.error_num);
        PrintStr("\n");
        return 1;
    }
    
    PrintStr("Connected!\n");
    
    var res: MySQLResult := MySQLQuery(conn, "SELECT 1 AS test");
    PrintStr("Rows: ");
    PrintInt(MySQLNumRows(res));
    PrintStr("\n");
    
    MySQLFreeResult(res);
    
    var res2: MySQLResult := MySQLQuery(conn, "SHOW DATABASES");
    PrintStr("DBs: ");
    PrintInt(MySQLNumRows(res2));
    PrintStr("\n");
    
    MySQLFreeResult(res2);
    
    MySQLClose(conn);
    PrintStr("OK\n");
    
    return 0;
}