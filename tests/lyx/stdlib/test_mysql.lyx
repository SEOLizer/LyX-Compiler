import std.db.mysql;
import std.io;

pub fn main(): int64 {
    PrintStr("MySQL Test\n");
    
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx2", "", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connect failed: ");
        PrintInt(conn.error_num);
        PrintStr("\n");
        return 1;
    }
    
    PrintStr("Connected!\n");
    
    // Simple query
    var res: MySQLResult := MySQLQuery(conn, "SELECT 1");
    
    PrintStr("Query done, error_num: ");
    PrintInt(conn.error_num);
    PrintStr("\n");
    
    PrintStr("Rows: ");
    PrintInt(MySQLNumRows(res));
    PrintStr("\n");
    PrintStr("Fields: ");
    PrintInt(MySQLNumFields(res));
    PrintStr("\n");
    
    MySQLFreeResult(res);
    
    MySQLClose(conn);
    PrintStr("OK\n");
    
    return 0;
}