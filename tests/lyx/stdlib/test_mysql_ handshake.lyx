// Simple debug test for MySQL handshake

import std.net.syscalls;
import std.io;

pub fn main(): int64 {
    var fd: int64 := sys_socket(2, 1, 0);
    if (fd < 0) {
        PrintStr("Socket error\n");
        return 1;
    }
    
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    poke8(addr, 2);
    poke8(addr + 1, 0);
    poke8(addr + 2, 51);
    poke8(addr + 3, 51);
    poke8(addr + 4, 127);
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    var i: int64 := 0;
    while (i < 8) {
        poke8(addr + 8 + i, 0);
        i := i + 1;
    }
    
    var res: int64 := sys_connect(fd, addr, 16);
    if (res < 0) {
        PrintStr("Connect error\n");
        return 1;
    }
    
    var buf: int64 := mmap(0, 10, 3, 34, -1, 0);
    n := sys_read(fd, buf, 10);
    if (n <= 0) {
        PrintStr("Read error\n");
        return 1;
    }
    
    i := 0;
    while (i < n) {
        var b: int64 := peek8(buf + i);
        PrintInt(b);
        PrintStr(" ");
        i := i + 1;
    }
    PrintStr("\n");
    
    return 0;
}