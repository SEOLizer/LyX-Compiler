// Debug SHA1 in MySQLConnect
import std.io;
import std.crypto.sha1;

pub fn main(): int64 {
    PrintStr("=== SHA1 Debug ===\n");
    
    // Passwort String
    var pass: pchar := "test12345";
    var passAddr: int64 := pass as int64;
    
    PrintStr("passAddr = ");
    PrintInt(passAddr);
    PrintStr("\n");
    
    // Passwort Laenge
    var passLen: int64 := 0;
    while (peek8(passAddr + passLen) != 0) { 
        passLen := passLen + 1; 
    }
    PrintStr("passLen = ");
    PrintInt(passLen);
    PrintStr("\n");
    
    // Scramble (20 Bytes)
    var scramble: int64 := mmap(0, 20, 3, 34, -1, 0);
    var i: int64 := 0;
    while (i < 20) { 
        poke8(scramble + i, i + 65); 
        i := i + 1; 
    }
    
    // Output buffer
    var out: int64 := mmap(0, 20, 3, 34, -1, 0);
    
    PrintStr("Calling SHA1MySQLNativePassword...\n");
    
    // AUFRUF - hier crashet es
    SHA1MySQLNativePassword(passAddr, passLen, scramble, out);
    
    PrintStr("After SHA1!\n");
    
    PrintStr("Result: ");
    i := 0;
    while (i < 20) {
        PrintInt(peek8(out + i));
        PrintStr(" ");
        i := i + 1;
    }
    PrintStr("\n");
    
    munmap(scramble, 20);
    munmap(out, 20);
    
    PrintStr("=== Done ===\n");
    return 0;
}