// Debug: Test Cast on struct field passed to function
import std.io;

type TConn = struct {
    fd: int64;
    pass: pchar;
};

fn computeHash(conn: TConn): int64 {
    // Schauen was im Feld ist
    var val: pchar := conn.pass;
    PrintStr("  val = ");
    PrintStr(val);
    PrintStr("\n");
    
    // Adresse der connection selbst
    var connAddr: int64 := &conn;
    PrintStr("  &conn = ");
    PrintInt(connAddr);
    PrintStr("\n");
    
    // Cast
    var addr: int64 := conn.pass as int64;
    PrintStr("  cast = ");
    PrintInt(addr);
    PrintStr("\n");
    
    return addr;
}

pub fn main(): int64 {
    PrintStr("=== Debug Struct Field Cast ===\n");
    
    var conn: TConn;
    conn.fd := 100;
    conn.pass := "secret123";
    
    var result: int64 := computeHash(conn);
    PrintStr("Result = ");
    PrintInt(result);
    PrintStr("\n");
    
    PrintStr("=== Test Complete ===\n");
    return 0;
}