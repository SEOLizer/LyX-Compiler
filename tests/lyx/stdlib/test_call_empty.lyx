// Test calling an empty function
import std.io;

fn myFunc(a: int64): int64 {
    return a + 1;
}

pub fn main(): int64 {
    PrintStr("=== Call Test ===\n");
    
    var result: int64 := myFunc(5);
    
    PrintStr("Result: ");
    PrintInt(result);
    PrintStr("\n");
    
    PrintStr("=== Done ===\n");
    return 0;
}