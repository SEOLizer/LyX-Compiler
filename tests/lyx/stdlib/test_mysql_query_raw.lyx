import std.db.mysql;
import std.io;

pub fn main(): int64 {
    PrintStr("MySQL Simple Query Test\n");
    
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx2", "", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connect failed: ");
        PrintInt(conn.error_num);
        PrintStr("\n");
        return 1;
    }
    
    PrintStr("Connected! packet_num=");
    PrintInt(conn.packet_num);
    PrintStr("\n");
    
    // Reset packet_num explicitly
    conn.packet_num := 0;
    PrintStr("After reset packet_num=");
    PrintInt(conn.packet_num);
    PrintStr("\n");
    
    // Build query packet: len(1 byte) + COM_QUERY + "SELECT 1"
    var q: pchar := "SELECT 1";
    var qlen: int64 := 8;
    var buf: int64 := mmap(0, 13, 3, 34, -1, 0);
    
    // Header: 3 bytes len + 1 byte seq
    poke8(buf, qlen);
    poke8(buf + 1, 0);
    poke8(buf + 2, 0);
    poke8(buf + 3, 0);  // seq 0
    
    // Command
    poke8(buf + 4, 3);  // COM_QUERY
    
    // Query string "SELECT 1"
    poke8(buf + 5, 83);  // S
    poke8(buf + 6, 69);  // E
    poke8(buf + 7, 76);  // L
    poke8(buf + 8, 69);  // E
    poke8(buf + 9, 67);  // C
    poke8(buf + 10, 84); // T
    poke8(buf + 11, 32); // space
    poke8(buf + 12, 49); // 1
    
    PrintStr("Sending packet...\n");
    var written: int64 := sys_write(conn.fd, buf, 13);
    munmap(buf, 13);
    
    PrintStr("Written: ");
    PrintInt(written);
    PrintStr("\n");
    
    // Read response header
    PrintStr("Reading header...\n");
    var hdr: int64 := mmap(0, 4, 3, 34, -1, 0);
    var nr: int64 := sys_read(conn.fd, hdr, 4);
    
    if (nr <= 0) {
        PrintStr("No header read, nr=");
        PrintInt(nr);
        PrintStr("\n");
        MySQLClose(conn);
        return 1;
    }
    
    var plen: int64 := peek8(hdr) | (peek8(hdr + 1) << 8) | (peek8(hdr + 2) << 16);
    var seq: int64 := peek8(hdr + 3);
    munmap(hdr, 4);
    
    PrintStr("Header: plen=");
    PrintInt(plen);
    PrintStr(" seq=");
    PrintInt(seq);
    PrintStr("\n");
    
    if (plen <= 0 || plen > 65535) {
        PrintStr("Invalid payload length!\n");
        MySQLClose(conn);
        return 1;
    }
    
    // Read payload
    var payload: int64 := mmap(0, plen + 1, 3, 34, -1, 0);
    nr := sys_read(conn.fd, payload, plen);
    
    if (nr <= 0) {
        PrintStr("No payload read, nr=");
        PrintInt(nr);
        PrintStr("\n");
        MySQLClose(conn);
        return 1;
    }
    
    var first: int64 := peek8(payload);
    PrintStr("First byte: ");
    PrintInt(first);
    PrintStr(" (");
    if (first == 0) { PrintStr("OK"); }
    else if (first == 255) { PrintStr("ERR"); }
    else { PrintStr("?"); }
    PrintStr(")\n");
    
    if (first == 0) {
        PrintStr("Query OK!\n");
        // Parse OK packet
        var aff: int64 := peek8(payload + 1);
        PrintStr("Affected: ");
        PrintInt(aff);
        PrintStr("\n");
    } else if (first == 255) {
        var e1: int64 := peek8(payload + 1);
        var e2: int64 := peek8(payload + 2);
        var err: int64 := e1 | (e2 << 8);
        PrintStr("Error: ");
        PrintInt(err);
        PrintStr("\n");
    }
    
    munmap(payload, plen + 1);
    MySQLClose(conn);
    PrintStr("Done\n");
    
    return 0;
}