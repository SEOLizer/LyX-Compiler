// Einfacher MySQL Parameter Debug
import std.io;

type TestConn = struct {
    a: int64;
    b: pchar;
    c: pchar;
};

fn createConn(host: pchar, port: int64, user: pchar, pass: pchar, db: pchar): TestConn {
    var conn: TestConn;
    conn.a := port;
    conn.b := host;
    conn.c := pass;
    PrintStr("  Inside createConn:\n");
    PrintStr("    port = ");
    PrintInt(conn.a);
    PrintStr("\n");
    PrintStr("    host = ");
    PrintStr(conn.b);
    PrintStr("\n");
    PrintStr("    pass = ");
    PrintStr(conn.c);
    PrintStr("\n");
    return conn;
}

pub fn main(): int64 {
    PrintStr("=== MySQL Parameter Debug ===\n");
    
    var conn: TestConn := createConn("myhost", 3306, "myuser", "mypass", "mydb");
    
    PrintStr("After return:\n");
    PrintStr("  port = ");
    PrintInt(conn.a);
    PrintStr("\n");
    PrintStr("  host = ");
    PrintStr(conn.b);
    PrintStr("\n");
    PrintStr("  pass = ");
    PrintStr(conn.c);
    PrintStr("\n");
    
    PrintStr("=== Test Complete ===\n");
    return 0;
}