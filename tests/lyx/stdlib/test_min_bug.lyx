// Minimal reproduction of the bug
import std.io;

type Large = struct {
    a: int64;
    b: int64;
    pass: pchar;
    c: int64;
    d: int64;
    e: int64;
};

fn test(param: Large): int64 {
    // Direkter Feld-Zugriff
    var result: int64 := param.pass as int64;
    return result;
}

fn test2(param: Large): int64 {
    // Workaround: Erst zuweisen
    var temp: pchar := param.pass;
    var result: int64 := temp as int64;
    return result;
}

pub fn main(): int64 {
    var l: Large;
    l.a := 1;
    l.b := 2;
    l.pass := "test";
    l.c := 3;
    l.d := 4;
    l.e := 5;
    
    PrintStr("Direct: ");
    var r1: int64 := test(l);
    PrintInt(r1);
    PrintStr("\n");
    
    PrintStr("Workaround: ");
    var r2: int64 := test2(l);
    PrintInt(r2);
    PrintStr("\n");
    
    return 0;
}