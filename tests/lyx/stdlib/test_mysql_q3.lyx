import std.db.mysql;
import std.io;

pub fn main(): int64 {
    PrintStr("=== MySQL Query with Reset Test ===\n");
    
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx", "test12345", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connect FAILED: error=");
        PrintInt(conn.error_num);
        return 1;
    }
    
    PrintStr("Connected OK!\n");
    PrintStr("packet_num before reset: ");
    PrintInt(conn.packet_num);
    PrintStr("\n");
    
    // Reset packet_num BEFORE sending any command
    conn.packet_num := 0;
    PrintStr("packet_num after reset: ");
    PrintInt(conn.packet_num);
    PrintStr("\n");
    
    // Build SQL command manually
    var sql: pchar := "SELECT 1";
    var sqlLen: int64 := 8;
    var cmdBuf: int64 := mmap(0, 9, 3, 34, -1, 0);
    poke8(cmdBuf, 3);  // COM_QUERY = 3
    
    var i: int64 := 0;
    while (i < sqlLen) {
        poke8(cmdBuf + 1 + i, peek8(sql + i));
        i := i + 1;
    }
    
    PrintStr("Sending MySQLSendPacket...\n");
    var ok: bool := MySQLSendPacket(conn, cmdBuf, sqlLen + 1);
    if (ok) { PrintStr("Send OK\n"); } else { PrintStr("Send FAIL\n"); }
    munmap(cmdBuf, sqlLen + 1);
    
    if (!ok) {
        sys_close(conn.fd);
        return 1;
    }
    
    // Try to read response
    // Drain any extra packets first
    var drain: int64 := MySQLReadPacket(conn);
    if (drain > 0) {
        var plen: int64 := conn.last_payload_len;
        var pfirst: int64 := peek8(drain);
        PrintStr("Response: len=");
        PrintInt(plen);
        PrintStr(", first=hex:");
        PrintInt(pfirst);
        PrintStr("\n");
        munmap(drain, plen + 1);
    } else {
        PrintStr("No response or read error\n");
    }
    
    sys_close(conn.fd);
    
    PrintStr("=== SUCCESS ===\n");
    return 0;
}