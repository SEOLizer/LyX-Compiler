import std.db.mysql;
import std.io;

pub fn main(): int64 {
    PrintStr("=== MySQL Authentication Complete Test ===\n");
    
    // Connect with username 'lyx' and password 'test12345'
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx", "test12345", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("FAILED: Could not connect, error=");
        PrintInt(conn.error_num);
        return 1;
    }
    
    PrintStr("SUCCESS: Connected! fd=");
    PrintInt(conn.fd);
    PrintStr("\n");
    
    // Simple query
    var res: MySQLResult := MySQLQuery(conn, "SELECT 1");
    if (res.field_count > 0) {
        PrintStr("Query success! field_count=");
        PrintInt(res.field_count);
        PrintStr("\n");
    }
    
    MySQLFreeResult(res);
    MySQLClose(conn);
    
    PrintStr("=== ALL TESTS PASSED ===\n");
    return 0;
}