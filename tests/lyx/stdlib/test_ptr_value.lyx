// Test printing pointer values
import std.io;

fn testFunc(buf: int64, len: int64): int64 {
    PrintStr("In testFunc, buf = ");
    PrintInt(buf);
    PrintStr("\n");
    PrintStr("In testFunc, len = ");
    PrintInt(len);
    PrintStr("\n");
    return 0;
}

pub fn main(): int64 {
    PrintStr("=== Pointer Test ===\n");
    
    var buf: int64 := mmap(0, 4096, 3, 34, -1, 0);
    if buf == 0 {
        PrintStr("ERROR: mmap failed\n");
        return 1;
    }
    
    var len: int64 := 5;
    
    PrintStr("Before call, buf = ");
    PrintInt(buf);
    PrintStr("\n");
    PrintStr("Before call, len = ");
    PrintInt(len);
    PrintStr("\n");
    
    PrintStr("Calling testFunc...\n");
    var result: int64 := testFunc(buf, len);
    
    PrintStr("After call\n");
    
    munmap(buf, 4096);
    
    PrintStr("=== Done ===\n");
    return 0;
}