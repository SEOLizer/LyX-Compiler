// Test Struct Field Address
import std.io;
import std.net.syscalls;

type TestConn = struct {
    fd: int64;
    host: pchar;
    password: pchar;
};

pub fn main(): int64 {
    PrintStr("=== Struct Field Address Test ===\n");
    
    var conn: TestConn;
    conn.fd := 10;
    conn.host := "localhost";
    conn.password := "mypassword";
    
    PrintStr("conn.fd = ");
    PrintInt(conn.fd);
    PrintStr("\n");
    
    // Try to access password field via struct
    PrintStr("conn.password = ");
    PrintStr(conn.password);
    PrintStr("\n");
    
    PrintStr("=== Test Complete ===\n");
    return 0;
}