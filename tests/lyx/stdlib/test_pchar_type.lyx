// Check what we actually get from the field
import std.io;

type TConn = struct {
    fd: int64;
    pass: pchar;  // ist das 8 bytes inline oder ein pointer?
};

fn testCheck(conn: TConn): int64 {
    // Was ist der tatsaechliche Wert des Feldes (ohne Cast)?
    // Nutze es als pchar und konvertiere zu int64
    var temp: pchar := conn.pass;
    // return address of what's in temp
    return temp as int64;
}

pub fn main(): int64 {
    var conn: TConn;
    conn.fd := 100;
    conn.pass := "hello";
    
    // Direkt aus dem Struct
    PrintStr("Direct: ");
    var addr1: int64 := conn.pass as int64;
    PrintInt(addr1);
    PrintStr("\n");
    
    // Ueber Zwischenvariable
    var temp: pchar := conn.pass;
    var addr2: int64 := temp as int64;
    PrintStr("Temp: ");
    PrintInt(addr2);
    PrintStr("\n");
    
    // Mit Funktion
    var addr3: int64 := testCheck(conn);
    PrintStr("Func: ");
    PrintInt(addr3);
    PrintStr("\n");
    
    return 0;
}