import std.db.mysql;
import std.io;
import std.string;

pub fn main(): int64 {
    PrintStr("=== Minimal MySQLQuery Test ===\n");
    
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx", "test12345", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connect FAILED: error=");
        PrintInt(conn.error_num);
        return 1;
    }
    
    PrintStr("Connected OK!\n");
    
    // Step 1: StrLen
    var testSql: pchar := "SELECT 1";
    var slen: int64 := StrLen(testSql);
    PrintStr("Step 1: StrLen = ");
    PrintInt(slen);
    PrintStr("\n");
    
    // Step 2: Reset packet_num
    conn.packet_num := 0;
    PrintStr("Step 2: packet_num reset to 0\n");
    
    // Step 3: Create command buffer manually (like mysqlSendCommand)
    // NOT using the internal function, doing same logic here
    var cmd: int64 := 3;  // COM_QUERY
    var data: int64 := mmap(0, slen, 3, 34, -1, 0);
    var i: int64 := 0;
    while (i < slen) {
        poke8(data + i, peek8(testSql + i));
        i := i + 1;
    }
    var bufLen: int64 := slen + 1;
    var cmdBuf: int64 := mmap(0, bufLen, 3, 34, -1, 0);
    poke8(cmdBuf, cmd);
    i := 0;
    while (i < slen) {
        poke8(cmdBuf + 1 + i, peek8(data + i));
        i := i + 1;
    }
    PrintStr("Step 3: Buffer created, calling MySQLSendPacket\n");
    
    var ok: bool := MySQLSendPacket(conn, cmdBuf, bufLen);
    if (ok) { PrintStr("Step 4: Send OK\n"); } else { PrintStr("Step 4: Send FAIL\n"); }
    
    munmap(cmdBuf, bufLen);
    munmap(data, slen);
    
    if (!ok) {
        sys_close(conn.fd);
        return 1;
    }
    
    PrintStr("Step 5: Reading packet\n");
    var pkt: int64 := MySQLReadPacket(conn);
    if (pkt > 0) {
        var first: int64 := peek8(pkt);
        PrintStr("First byte: ");
        PrintInt(first);
        PrintStr("\n");
        munmap(pkt, conn.last_payload_len + 1);
    }
    
    sys_close(conn.fd);
    
    PrintStr("=== SUCCESS ===\n");
    return 0;
}