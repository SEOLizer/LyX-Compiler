// Test wie MySQLConnect - 5 Parameter, großer Struct
import std.io;
import std.net.syscalls;

type TConn = struct {
    a: int64;  // fd
    b: pchar;  // host
    c: int64; // port
    d: pchar;  // user
    e: pchar;  // password
    f: pchar;  // database
    // ... mehr Felder
    x: int64;
    y: int64;
    z: pchar;
};

fn MySQLConnect2(host: pchar, port: int64, user: pchar, pass: pchar, db: pchar): TConn {
    var conn: TConn;
    conn.a := sys_socket(2, 1, 0);
    conn.b := host;
    conn.c := port;
    conn.d := user;
    conn.e := pass;
    conn.f := db;
    conn.x := 0;
    conn.y := 0;
    conn.z := "";
    return conn;
}

pub fn main(): int64 {
    PrintStr("=== MySQLLike Test ===\n");
    
    var conn: TConn := MySQLConnect2("127.0.0.1", 3306, "lyx", "test12345", "lyx");
    
    PrintStr("conn password = ");
    PrintStr(conn.e);
    PrintStr("\n");
    
    var addr: int64 := conn.e as int64;
    PrintStr("addr = ");
    PrintInt(addr);
    PrintStr("\n");
    
    if (addr > 0) {
        PrintStr("first char = ");
        PrintInt(peek8(addr));
        PrintStr("\n");
    }
    
    PrintStr("=== Test Complete ===\n");
    return 0;
}