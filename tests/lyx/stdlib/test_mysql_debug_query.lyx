import std.db.mysql;
import std.io;
import std.string;

pub fn main(): int64 {
    PrintStr("=== MySQL Debug Query Test ===\n");
    
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx", "test12345", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connect FAILED: error=");
        PrintInt(conn.error_num);
        PrintStr("\n");
        return 1;
    }
    
    PrintStr("Connected OK!\n");
    
    // Test StrLen on a simple string
    var testStr: pchar := "SELECT 1";
    var slen: int64 := StrLen(testStr);
    PrintStr("StrLen('SELECT 1') = ");
    PrintInt(slen);
    PrintStr("\n");
    
    PrintStr("Calling MySQLQuery...\n");
    
    var result: int64 := MySQLQuery(conn, testStr);
    
    PrintStr("MySQLQuery returned: ");
    PrintInt(result);
    PrintStr("\n");
    
    sys_close(conn.fd);
    
    PrintStr("=== Done ===\n");
    return 0;
}