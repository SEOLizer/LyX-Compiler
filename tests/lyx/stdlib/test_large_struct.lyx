// Test Large Struct - wie MySQLConn (18 Felder, 144 Bytes)
import std.io;

type LargeConn = struct {
    fd: int64;
    host: pchar;
    port: int64;
    user: pchar;
    password: pchar;
    database: pchar;
    packet_num: int64;
    last_payload: int64;
    server_ver: int64;
    cap_flags: int64;
    charset: int64;
    status: int64;
    scramble: int64;
    last_error: int64;
    errmsg: pchar;
    error_num: int64;
    affected: int64;
    insert_id: int64;
    field_count: int64;
};

fn createLarge(host: pchar, pass: pchar): LargeConn {
    var conn: LargeConn;
    conn.host := host;
    conn.password := pass;
    PrintStr("  Inside create:\n");
    PrintStr("    conn.host = ");
    PrintStr(conn.host);
    PrintStr("\n");
    PrintStr("    conn.pass = ");
    PrintStr(conn.password);
    PrintStr("\n");
    return conn;
}

pub fn main(): int64 {
    PrintStr("=== Large Struct Test ===\n");
    
    var conn: LargeConn := createLarge("myhost", "mypass");
    
    PrintStr("After return:\n");
    PrintStr("  conn.host = ");
    PrintStr(conn.host);
    PrintStr("\n");
    PrintStr("  conn.pass = ");
    PrintStr(conn.password);
    PrintStr("\n");
    
    PrintStr("=== Test Complete ===\n");
    return 0;
}