// Debug: Test Cast on struct field passed to function
import std.io;

type TConn = struct {
    fd: int64;
    pass: pchar;
};

fn computeHash(conn: TConn): int64 {
    var addr: int64 := conn.pass as int64;
    return addr;
}

pub fn main(): int64 {
    PrintStr("=== Debug Struct Field Cast ===\n");
    
    var conn: TConn;
    conn.fd := 100;
    conn.pass := "secret123";
    
    // Test cast inside function
    var result: int64 := computeHash(conn);
    PrintStr("Result = ");
    PrintInt(result);
    PrintStr("\n");
    
    // Direct cast
    var addr2: int64 := conn.pass as int64;
    PrintStr("Direct addr = ");
    PrintInt(addr2);
    PrintStr("\n");
    
    if (result > 0) {
        PrintStr("First char = ");
        PrintInt(peek8(result));
        PrintStr("\n");
    }
    
    PrintStr("=== Test Complete ===\n");
    return 0;
}