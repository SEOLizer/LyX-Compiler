import std.db.mysql;
import std.io;

pub fn main(): int64 {
    PrintStr("=== MySQL with Password Test ===\n");
    
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx", "test12345", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("FAILED: ");
        PrintInt(conn.error_num);
        PrintStr("\n");
        return 1;
    }
    
    PrintStr("Connected successfully!\n");
    PrintStr("packet_num after auth: ");
    PrintInt(conn.packet_num);
    PrintStr("\n");
    
    // Reset and send COM_PING
    conn.packet_num := 0;
    
    var cmd: int64 := mmap(0, 5, 3, 34, -1, 0);
    poke8(cmd, 1);        // length = 1 byte
    poke8(cmd + 1, 0);   // zero
    poke8(cmd + 2, 0);   // zero
    poke8(cmd + 3, 0);   // packet_num
    poke8(cmd + 4, 14);  // COM_PING = 0x0E
    
    var written: int64 := sys_write(conn.fd, cmd, 5);
    munmap(cmd, 5);
    
    PrintStr("Wrote ping: ");
    PrintInt(written);
    PrintStr("\n");
    
    // Read response
    var hdr: int64 := mmap(0, 4, 3, 34, -1, 0);
    var nr: int64 := sys_read(conn.fd, hdr, 4);
    
    if (nr <= 0) {
        PrintStr("Read error: ");
        PrintInt(nr);
        PrintStr("\n");
    } else {
        var respLen: int64 := peek8(hdr) | (peek8(hdr + 1) << 8) | (peek8(hdr + 2) << 16);
        var pktNum: int64 := peek8(hdr + 3);
        PrintStr("Response: len=");
        PrintInt(respLen);
        PrintStr(" pkt=");
        PrintInt(pktNum);
        PrintStr("\n");
        
        if (respLen > 0) {
            var body: int64 := mmap(0, respLen, 3, 34, -1, 0);
            sys_read(conn.fd, body, respLen);
            PrintStr("First byte: ");
            PrintInt(peek8(body));
            PrintStr("\n");
            munmap(body, respLen);
        }
    }
    
    munmap(hdr, 4);
    
    // Close connection
    sys_close(conn.fd);
    
    PrintStr("=== SUCCESS ===\n");
    return 0;
}