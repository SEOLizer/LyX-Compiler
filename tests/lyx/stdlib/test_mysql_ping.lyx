import std.db.mysql;
import std.io;

pub fn main(): int64 {
    PrintStr("MySQL Ping Test\n");
    
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx2", "", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connect failed: ");
        PrintInt(conn.error_num);
        PrintStr("\n");
        return 1;
    }
    
    PrintStr("Connected!\n");
    
    // Reset packet_num to 0 for commands
    conn.packet_num := 0;
    
    // Send COM_PING = 14 (0x0E)
    var pingBuf: int64 := mmap(0, 5, 3, 34, -1, 0);
    poke8(pingBuf, 14);  // COM_PING
    
    var sent: bool := MySQLSendPacket(conn, pingBuf, 1);
    munmap(pingBuf, 5);
    
    PrintStr("PING sent: ");
    if (sent) { PrintStr("yes"); } else { PrintStr("no"); }
    PrintStr("\n");
    
    if (!sent) {
        MySQLClose(conn);
        return 1;
    }
    
    // Read response
    PrintStr("Reading response...\n");
    var response: int64 := MySQLReadPacket(conn);
    
    if (response <= 0) {
        PrintStr("No response\n");
        MySQLClose(conn);
        return 1;
    }
    
    var first: int64 := peek8(response);
    var payLen: int64 := conn.last_payload_len;
    
    PrintStr("Response first: ");
    PrintInt(first);
    PrintStr(" (len=");
    PrintInt(payLen);
    PrintStr(")\n");
    
    if (first == 0x00) {
        PrintStr("PONG OK!\n");
    }
    
    munmap(response, payLen + 1);
    MySQLClose(conn);
    PrintStr("Done\n");
    
    return 0;
}