// Direct pchar field to int64 test
import std.io;

type TConn = struct {
    fd: int64;
    pass: pchar;
};

fn testFn(passArg: pchar): int64 {
    var conn: TConn;
    conn.fd := 100;
    conn.pass := passArg;
    
    // Cast field to int64
    var addr: int64 := conn.pass as int64;
    return addr;
}

pub fn main(): int64 {
    PrintStr("=== pchar Field Cast Test ===\n");
    
    var result: int64 := testFn("hello");
    
    PrintStr("Result = ");
    PrintInt(result);
    PrintStr("\n");
    
    // Check result
    if (result > 0) {
        var firstChar: int64 := peek8(result);
        PrintStr("First char = ");
        PrintInt(firstChar);
        PrintStr(" (expected 104 = 'h')\n");
    }
    
    PrintStr("=== Test Complete ===\n");
    return 0;
}