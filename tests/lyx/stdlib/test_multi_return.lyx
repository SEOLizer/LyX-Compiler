// Test multiple returns - wie MySQLConnect
import std.io;

type TConn = struct {
    a: int64;
    pass: pchar;
    b: int64;
    c: int64;
    d: int64;
};

fn createConn(passArg: pchar, shouldFail: bool): TConn {
    var conn: TConn;
    conn.a := 1;
    conn.pass := passArg;
    conn.b := 2;
    conn.c := 3;
    conn.d := 4;
    
    // Early return (wie MySQLConnect bei Fehlern)
    if (shouldFail) {
        return conn;
    }
    
    // Normal return am Ende
    conn.a := 100;
    return conn;
}

pub fn main(): int64 {
    PrintStr("=== Multiple Return Test ===\n");
    
    var conn1: TConn := createConn("password1", true);
    PrintStr("conn1 (early fail): pass=");
    PrintStr(conn1.pass);
    PrintStr(", addr=");
    PrintInt(conn1.pass as int64);
    PrintStr("\n");
    
    var conn2: TConn := createConn("password2", false);
    PrintStr("conn2 (normal): pass=");
    PrintStr(conn2.pass);
    PrintStr(", addr=");
    PrintInt(conn2.pass as int64);
    PrintStr("\n");
    
    PrintStr("=== Test Complete ===\n");
    return 0;
}