import std.db.mysql;
import std.io;

pub fn main(): int64 {
    PrintStr("=== Two Queries Test ===\n");
    
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx", "test12345", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connect FAILED: ");
        PrintInt(conn.error_num);
        return 1;
    }
    
    PrintStr("Query 1...\n");
    var res1: MySQLResult := MySQLQuery(conn, "SELECT 1");
    PrintStr("res1 field_count = ");
    PrintInt(res1.field_count);
    PrintStr("\n");
    
    var row1: int64 := MySQLFetchRow(res1);
    if (row1 > 0) {
        PrintStr("Got row1\n");
    }
    MySQLFreeResult(res1);
    PrintStr("Freed res1\n");
    
    PrintStr("Query 2...\n");
    var res2: MySQLResult := MySQLQuery(conn, "SHOW DATABASES");
    PrintStr("res2 field_count = ");
    PrintInt(res2.field_count);
    PrintStr("\n");
    
    MySQLClose(conn);
    
    PrintStr("=== SUCCESS ===\n");
    return 0;
}