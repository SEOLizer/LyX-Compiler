// MySQL Debug Test - minimal
import std.db.mysql;
import std.io;
import std.net.syscalls;

pub fn main(): int64 {
    PrintStr("MySQL Debug Test\n");
    
    // Create socket
    var fd: int64 := sys_socket(2, 1, 0);
    PrintStr("Socket: ");
    PrintInt(fd);
    PrintStr("\n");
    
    if (fd < 0) { return 1; }
    
    // Create address
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    var port: int64 := 3306;
    poke8(addr, 2);
    poke8(addr + 1, 0);
    poke8(addr + 2, (port >> 8) & 0xFF);
    poke8(addr + 3, port & 0xFF);
    poke8(addr + 4, 127);
    poke8(addr + 5, 0);
    poke8(addr + 6, 0);
    poke8(addr + 7, 1);
    
    // Clear padding
    var i: int64 := 0;
    while (i < 8) {
        poke8(addr + 8 + i, 0);
        i := i + 1;
    }
    
    PrintStr("Connecting...\n");
    var res: int64 := sys_connect(fd, addr, 16);
    munmap(addr, 16);
    PrintStr("Connect result: ");
    PrintInt(res);
    PrintStr("\n");
    
    if (res < 0) {
        sys_close(fd);
        return 1;
    }
    
    PrintStr("Reading handshake...\n");
    
    // Read packet header
    var header: int64 := mmap(0, 4, 3, 34, -1, 0);
    var n: int64 := sys_read(fd, header, 4);
    PrintStr("Read header: ");
    PrintInt(n);
    PrintStr("\n");
    
    if (n <= 0) {
        sys_close(fd);
        return 1;
    }
    
    // Parse length
    var b0: int64 := peek8(header);
    var b1: int64 := peek8(header + 1);
    var b2: int64 := peek8(header + 2);
    var payLen: int64 := b0 | (b1 << 8) | (b2 << 16);
    PrintStr("Payload len: ");
    PrintInt(payLen);
    PrintStr("\n");
    
    // Read payload
    var bufSize: int64 := payLen + 1;
    var payload: int64 := mmap(0, bufSize, 3, 34, -1, 0);
    n := sys_read(fd, payload, payLen);
    var n2: int64 := n;
    PrintStr("Read payload: ");
    PrintInt(n2);
    PrintStr("\n");
    
    if (n > 0) {
        var first: int64 := peek8(payload);
        PrintStr("First byte (proto): ");
        PrintInt(first);
        PrintStr("\n");
    }
    
    munmap(header, 4);
    if (payload > 0) { munmap(payload, payLen + 1); }
    sys_close(fd);
    
    PrintStr("Debug test done.\n");
    return 0;
}