// test_mysql_prepared.lyx - Test für Prepared Statements
// 
// Testet die Prepared Statement Funktionalität:
// - MySQLStmtPrepare
// - MySQLStmtBindInt / MySQLStmtBindStr
// - MySQLStmtExecute
// - MySQLStmtClose

unit stdlib.test_mysql_prepared;

import std.db.mysql;
import std.io;

pub fn main(): int64 {
    var host: pchar := "127.0.0.1";
    var port: int64 := 3306;
    var user: pchar := "root";
    var pass: pchar := "";
    var db: pchar := "test";

    PrintStr("MySQL Prepared Statements Test");
    PrintStr("======================");
    PrintStr("");

    // Connect to MySQL
    PrintStr("Connecting to MySQL...");
    var conn: MySQLConn := MySQLConnect(host, port, user, pass, db);
    
    if (conn.fd < 0) {
        PrintStr("Connection failed!");
        PrintStr("Error: ");
        PrintInt(conn.error_num);
        PrintStr("");
        return 1;
    }
    PrintStr("Connected successfully!");
    PrintStr("");

    // Create test table if it doesn't exist
    PrintStr("Creating test table...");
    var createRes: MySQLResult := MySQLQuery(conn, "CREATE TABLE IF NOT EXISTS test_prepared (id INT PRIMARY KEY, name VARCHAR(100), value INT)");
    if (conn.error_num != 0) {
        PrintStr("Create table error: ");
        PrintStr(MySQLError(conn));
        MySQLClose(conn);
        return 1;
    }
    MySQLFreeResult(createRes);
    PrintStr("Table ready.");
    PrintStr("");

    // Insert test data with regular query
    PrintStr("Inserting test data...");
    var insertRes: MySQLResult := MySQLQuery(conn, "INSERT INTO test_prepared VALUES (1, 'test1', 100), (2, 'test2', 200), (3, 'test3', 300)");
    if (conn.error_num != 0) {
        PrintStr("Insert error: ");
        PrintStr(MySQLError(conn));
        MySQLClose(conn);
        return 1;
    }
    MySQLFreeResult(insertRes);
    PrintStr("Data inserted.");
    PrintStr("");

    // Test Prepared Statement: SELECT with parameters
    PrintStr("=== Test 1: Prepared SELECT ===");
    var sql1: pchar := "SELECT id, name, value FROM test_prepared WHERE id > ?";
    PrintStr("SQL: ");
    PrintStr(sql1);
    PrintStr("");

    var stmt1: MySQLStmt := MySQLStmtPrepare(conn, sql1);
    
    if (stmt1.stmt_id == 0) {
        PrintStr("Prepare failed!");
        PrintStr("Error: ");
        PrintInt(conn.error_num);
        PrintStr(MySQLError(conn));
        MySQLClose(conn);
        return 1;
    }

    PrintStr("Statement prepared. ID: ");
    PrintInt(stmt1.stmt_id);
    PrintStr(", Params: ");
    PrintInt(stmt1.param_count);
    PrintStr(", Columns: ");
    PrintInt(stmt1.column_count);
    PrintStr("");

    // Bind parameter (id > 1)
    var bound: bool := MySQLStmtBindInt(stmt1, 0, 1);
    if (!bound) {
        PrintStr("BindInt failed!");
    } else {
        PrintStr("Parameter bound: id > 1");
    }

    // Execute
    PrintStr("Executing...");
    var res1: MySQLResult := MySQLStmtExecute(conn, stmt1);
    
    if (conn.error_num != 0) {
        PrintStr("Execute error: ");
        PrintStr(MySQLError(conn));
        MySQLStmtClose(stmt1);
        MySQLClose(conn);
        return 1;
    }

    PrintStr("Results: ");
    PrintInt(MySQLNumRows(res1));
    PrintStr(" rows");
    PrintStr("");

    // Fetch results
    var rowIdx: int64 := 0;
    while (rowIdx < MySQLNumRows(res1)) {
        var row: int64 := MySQLFetchRow(res1);
        if (row == 0) { break; }

        var idVal: pchar := MySQLGetRowStr(res1, row, 0);
        var nameVal: pchar := MySQLGetRowStr(res1, row, 1);
        var valueVal: pchar := MySQLGetRowStr(res1, row, 2);

        PrintStr("Row ");
        PrintInt(rowIdx);
        PrintStr(": id=");
        PrintStr(idVal);
        PrintStr(", name=");
        PrintStr(nameVal);
        PrintStr(", value=");
        PrintStr(valueVal);
        PrintStr("");

        rowIdx := rowIdx + 1;
    }

    MySQLFreeResult(res1);
    MySQLStmtClose(stmt1);
    PrintStr("Statement closed.");
    PrintStr("");

    // Test Prepared Statement: INSERT with parameters
    PrintStr("=== Test 2: Prepared INSERT ===");
    var sql2: pchar := "INSERT INTO test_prepared (id, name, value) VALUES (?, ?, ?)";
    PrintStr("SQL: ");
    PrintStr(sql2);
    PrintStr("");

    var stmt2: MySQLStmt := MySQLStmtPrepare(conn, sql2);
    
    if (stmt2.stmt_id == 0) {
        PrintStr("Prepare INSERT failed!");
        PrintStr("Error: ");
        PrintInt(conn.error_num);
        PrintStr(MySQLError(conn));
        MySQLClose(conn);
        return 1;
    }

    PrintStr("Statement prepared. ID: ");
    PrintInt(stmt2.stmt_id);
    PrintStr("");

    // Bind parameters
    bound := MySQLStmtBindInt(stmt2, 0, 4);
    bound := MySQLStmtBindStr(stmt2, 1, "prepared_row") && bound;
    bound := MySQLStmtBindInt(stmt2, 2, 400);
    
    if (!bound) {
        PrintStr("Bind failed!");
    } else {
        PrintStr("Parameters bound: id=4, name='prepared_row', value=400");
    }

    // Execute INSERT
    var res2: MySQLResult := MySQLStmtExecute(conn, stmt2);
    
    if (conn.error_num != 0) {
        PrintStr("Execute INSERT error: ");
        PrintStr(MySQLError(conn));
        MySQLStmtClose(stmt2);
        MySQLClose(conn);
        return 1;
    }

    var affected: int64 := MySQLAffectedRows(conn);
    PrintStr("Inserted rows: ");
    PrintInt(affected);
    PrintStr("");

    MySQLFreeResult(res2);
    MySQLStmtClose(stmt2);
    PrintStr("Statement closed.");
    PrintStr("");

    // Test Prepared Statement: UPDATE
    PrintStr("=== Test 3: Prepared UPDATE ===");
    var sql3: pchar := "UPDATE test_prepared SET value = ? WHERE id = ?";
    PrintStr("SQL: ");
    PrintStr(sql3);
    PrintStr("");

    var stmt3: MySQLStmt := MySQLStmtPrepare(conn, sql3);
    
    if (stmt3.stmt_id == 0) {
        PrintStr("Prepare UPDATE failed!");
        PrintStr("Error: ");
        PrintInt(conn.error_num);
        PrintStr(MySQLError(conn));
        MySQLClose(conn);
        return 1;
    }

    // Bind parameters: value = 999, id = 1
    bound := MySQLStmtBindInt(stmt3, 0, 999);
    bound := MySQLStmtBindInt(stmt3, 1, 1) && bound;
    
    if (!bound) {
        PrintStr("Bind failed!");
    } else {
        PrintStr("Parameters bound: value=999, id=1");
    }

    var res3: MySQLResult := MySQLStmtExecute(conn, stmt3);
    
    if (conn.error_num != 0) {
        PrintStr("Execute UPDATE error: ");
        PrintStr(MySQLError(conn));
        MySQLStmtClose(stmt3);
        MySQLClose(conn);
        return 1;
    }

    affected := MySQLAffectedRows(conn);
    PrintStr("Updated rows: ");
    PrintInt(affected);
    PrintStr("");

    // Verify update
    var verifyRes: MySQLResult := MySQLQuery(conn, "SELECT value FROM test_prepared WHERE id = 1");
    if (MySQLNumRows(verifyRes) > 0) {
        var verifyRow: int64 := MySQLFetchRow(verifyRes);
        var verifyVal: pchar := MySQLGetRowStr(verifyRes, verifyRow, 0);
        PrintStr("Verified: id=1, value=");
        PrintStr(verifyVal);
        PrintStr("");
    }
    MySQLFreeResult(verifyRes);

    MySQLFreeResult(res3);
    MySQLStmtClose(stmt3);
    PrintStr("");

    // Cleanup
    PrintStr("Cleaning up...");
    var cleanup: MySQLResult := MySQLQuery(conn, "DROP TABLE IF EXISTS test_prepared");
    MySQLFreeResult(cleanup);

    MySQLClose(conn);
    PrintStr("Connection closed.");
    PrintStr("");

    PrintStr("======================");
    PrintStr("All tests passed!");
    PrintStr("======================");

    return 0;
}