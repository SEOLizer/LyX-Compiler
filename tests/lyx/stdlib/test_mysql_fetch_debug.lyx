import std.db.mysql;
import std.io;

pub fn main(): int64 {
    PrintStr("=== Fetch Debug Test ===\n");
    
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx", "test12345", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connect failed\n");
        return 1;
    }
    
    PrintStr("Query: SHOW DATABASES\n");
    var res: MySQLResult := MySQLQuery(conn, "SHOW DATABASES");
    PrintStr("res field_count = ");
    PrintInt(res.field_count);
    PrintStr("\n");
    
    PrintStr("Fetching row 1...\n");
    var row: int64 := MySQLFetchRow(res);
    PrintStr("row = ");
    PrintInt(row);
    PrintStr("\n");
    
    if (row > 0) {
        res.current_row := res.current_row + 1;
    }
    
    PrintStr("Fetching row 2...\n");
    var row2: int64 := MySQLFetchRow(res);
    PrintStr("row2 = ");
    PrintInt(row2);
    PrintStr("\n");
    
    MySQLFreeResult(res);
    MySQLClose(conn);
    
    PrintStr("=== Done ===\n");
    return 0;
}