import std.db.mysql;
import std.io;

pub fn main(): int64 {
    PrintStr("=== Full MySQL Query Test ===\n");
    
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx", "test12345", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connect FAILED: error=");
        PrintInt(conn.error_num);
        return 1;
    }
    
    PrintStr("Testing 'SELECT 1 AS test_value'...\n");
    var res: MySQLResult := MySQLQuery(conn, "SELECT 1 AS test_value");
    
    if (res.field_count > 0) {
        PrintStr("field_count = ");
        PrintInt(res.field_count);
        PrintStr("\n");
        
        // Fetch row
        var row: int64 := MySQLFetchRow(res);
        if (row > 0) {
            var val: int64 := MySQLGetRowInt(res, row, 0);
            PrintStr("row value = ");
            PrintInt(val);
            PrintStr("\n");
        }
        
        // Free result
        MySQLFreeResult(res);
    }
    
    PrintStr("\nTesting 'SHOW DATABASES'...\n");
    var res2: MySQLResult := MySQLQuery(conn, "SHOW DATABASES");
    PrintStr("Result field_count = ");
    PrintInt(res2.field_count);
    PrintStr("\n");
    
    var rowCount: int64 := 0;
    while (MySQLFetchRow(res2) > 0) {
        var dbname: int64 := MySQLGetRowStr(res2, res2.current_row - 1, 0);
        rowCount := rowCount + 1;
    }
    PrintStr("Databases found: ");
    PrintInt(rowCount);
    PrintStr("\n");
    
    MySQLFreeResult(res2);
    MySQLClose(conn);
    
    PrintStr("=== ALL TESTS SUCCESS ===\n");
    return 0;
}