// Test calling function with pointer
import std.io;

fn processBuffer(buf: int64, len: int64): int64 {
    var sum: int64 := 0;
    var i: int64 := 0;
    while i < len {
        sum := sum + peek8(buf + i);
        i := i + 1;
    }
    return sum;
}

pub fn main(): int64 {
    PrintStr("=== Pointer Call Test ===\n");
    
    var buf: int64 := mmap(0, 4096, 3, 34, -1, 0);
    if buf == 0 {
        PrintStr("ERROR: mmap failed\n");
        return 1;
    }
    
    poke8(buf, 10);
    poke8(buf + 1, 20);
    poke8(buf + 2, 30);
    
    PrintStr("Calling processBuffer...\n");
    var result: int64 := processBuffer(buf, 3);
    
    PrintStr("Result: ");
    PrintInt(result);
    PrintStr("\n");
    
    munmap(buf, 4096);
    
    PrintStr("=== Done ===\n");
    return 0;
}