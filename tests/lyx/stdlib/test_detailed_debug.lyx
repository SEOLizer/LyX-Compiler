// Genauer Debug: Wo genau versagt der Cast
import std.io;

type TConn = struct {
    fd: int64;
    pass: pchar;
};

fn testInside(conn: TConn): int64 {
    // Cast innerhlab der Funktion - das ist das Problem
    var addr: int64 := conn.pass as int64;
    return addr;
}

fn testWithIntermediate(conn: TConn): int64 {
    // Workaround: Zwischen-variable
    var temp: pchar := conn.pass;
    var addr: int64 := temp as int64;
    return addr;
}

fn testWithLoad(conn: TConn): int64 {
    // Noch ein Workaround
    var temp: pchar;
    temp := conn.pass;
    var addr: int64 := temp as int64;
    return addr;
}

pub fn main(): int64 {
    PrintStr("=== Detailed Debug ===\n");
    
    var conn: TConn;
    conn.fd := 100;
    conn.pass := "secret";
    
    PrintStr("Direct in main: ");
    var addrMain: int64 := conn.pass as int64;
    PrintInt(addrMain);
    PrintStr("\n");
    
    PrintStr("Inside testInside: ");
    var addr1: int64 := testInside(conn);
    PrintInt(addr1);
    PrintStr("\n");
    
    PrintStr("Inside testWithIntermediate: ");
    var addr2: int64 := testWithIntermediate(conn);
    PrintInt(addr2);
    PrintStr("\n");
    
    PrintStr("Inside testWithLoad: ");
    var addr3: int64 := testWithLoad(conn);
    PrintInt(addr3);
    PrintStr("\n");
    
    PrintStr("=== Test Complete ===\n");
    return 0;
}