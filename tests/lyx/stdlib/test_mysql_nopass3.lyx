import std.db.mysql;
import std.io;

pub fn main(): int64 {
    PrintStr("MySQL Test (User: lyx, no password)\n");
    
    // Connect OHNE Passwort
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx", "", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connect failed: ");
        PrintInt(conn.error_num);
        PrintStr("\n");
        return 1;
    }
    
    PrintStr("Connected!\n");
    
    // Simple query
    var res: MySQLResult := MySQLQuery(conn, "SELECT 1 AS test");
    
    if (conn.error_num != 0) {
        PrintStr("Query failed: ");
        PrintInt(conn.error_num);
        PrintStr("\n");
    }
    else {
        PrintStr("Query success!\n");
    }

    MySQLFreeResult(res); 
    MySQLClose(conn);
    PrintStr("Test abgeschlossen.\n");
    return 0;
}