import std.db.mysql;
import std.io;

pub fn main(): int64 {
    PrintStr("=== Direct MySQLQuery Test ===\n");
    
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx", "test12345", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connect FAILED: error=");
        PrintInt(conn.error_num);
        return 1;
    }
    
    PrintStr("Connected OK! Calling MySQLQuery with 'SELECT 1'...\n");
    
    // Call MySQLQuery directly with a literal pchar
    var res: MySQLResult := MySQLQuery(conn, "SELECT 1");
    
    PrintStr("MySQLQuery returned!\n");
    PrintStr("field_count = ");
    PrintInt(res.field_count);
    PrintStr("\n");
    
    sys_close(conn.fd);
    
    PrintStr("=== SUCCESS ===\n");
    return 0;
}