// TCP connection test to debug MySQL issue
import std.io;
import std.net.syscalls;

pub fn main(): int64 {
    PrintStr("TCP Test to 127.0.0.1:3306\n");
    
    var fd: int64 := sys_socket(2, 1, 0); // AF_INET, SOCK_STREAM, IPPROTO_TCP
    PrintStr("Socket fd: ");
    PrintInt(fd);
    PrintStr("\n");
    
    if (fd < 0) {
        PrintStr("socket FAILED\n");
        return 1;
    }
    
    var addr: int64 := mmap(0, 16, 3, 34, -1, 0);
    if (addr <= 0) {
        PrintStr("mmap FAILED\n");
        sys_close(fd);
        return 1;
    }
    
    // sockaddr_in: AF_INET (2), port 3306 (0x0CEE), IP 127.0.0.1 (0x0100007F)
    // port in network byte order = big endian
    var port: int64 := 3306;
    poke8(addr, 2);     // family AF_INET
    poke8(addr + 1, 0);  // padding
    poke8(addr + 2, (port >> 8) & 0xFF); // port high byte
    poke8(addr + 3, port & 0xFF); // port low byte
    poke8(addr + 4, 127); // IP: 127
    poke8(addr + 5, 0); // IP: 0
    poke8(addr + 6, 0); // IP: 0
    poke8(addr + 7, 1); // IP: 1
    
    // Clear padding bytes
    poke8(addr + 8, 0);
    poke8(addr + 9, 0);
    poke8(addr + 10, 0);
    poke8(addr + 11, 0);
    poke8(addr + 12, 0);
    poke8(addr + 13, 0);
    poke8(addr + 14, 0);
    poke8(addr + 15, 0);
    
    PrintStr("Attempting connect...\n");
    var result: int64 := sys_connect(fd, addr, 16);
    munmap(addr, 16);
    
    PrintStr("Connect result: ");
    PrintInt(result);
    PrintStr("\n");
    
    if (result < 0) {
        PrintStr("connect FAILED\n");
        sys_close(fd);
        return 1;
    }
    
    PrintStr("Connected! Testing read...\n");
    
    // Try to read initial handshake (should come automatically)
    var buf: int64 := mmap(0, 100, 3, 34, -1, 0);
    var n: int64 := sys_read(fd, buf, 100);
    
    PrintStr("Read bytes: ");
    PrintInt(n);
    PrintStr("\n");
    
    if (n > 0) {
        PrintStr("First byte: ");
        PrintInt(peek8(buf));
        PrintStr("\n");
    }
    
    munmap(buf, 100);
    sys_close(fd);
    
    PrintStr("TCP test complete.\n");
    return 0;
}