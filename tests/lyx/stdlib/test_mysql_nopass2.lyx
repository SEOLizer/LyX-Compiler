import std.db.mysql;
import std.io;

// Test without password first
pub fn main(): int64 {
    PrintStr("MySQL Test (User: lyx, no password)\n");
    
    var conn: MySQLConn := MySQLConnect("127.0.0.1", 3306, "lyx", "", "lyx");
    
    if (conn.fd < 0) {
        PrintStr("Connect failed: ");
        PrintInt(conn.error_num);
        PrintStr("\n");
        return 1;
    }
    
    PrintStr("Connected!\n");
    MySQLClose(conn);
    PrintStr("Test done.\n");
    return 0;
}