fn main(): int64 {
    // Test StrLen on literal
    var len: int64 := StrLen("Hello");
    PrintStr("StrLen(Hello) = "); PrintInt(len); PrintStr("\n");

    // Test StrCharAt
    var c: int64 := StrCharAt("ABC", 0);
    PrintStr("StrCharAt(ABC,0) = "); PrintInt(c); PrintStr("\n");

    // Test StrNew + StrSetChar + PrintStr
    var s: pchar := StrNew(16);
    StrSetChar(s, 0, 72);   // 'H'
    StrSetChar(s, 1, 105);  // 'i'
    StrSetChar(s, 2, 0);    // null terminator
    PrintStr(s); PrintStr("\n");
    StrFree(s);

    // Test StrAppend
    var a: pchar := StrNew(32);
    var b: pchar := StrAppend(a, "Hello");
    var c2: pchar := StrAppend(b, " World");
    PrintStr(c2); PrintStr("\n");
    StrFree(c2);

    // Test StrFromInt
    var ns: pchar := StrFromInt(42);
    PrintStr("StrFromInt(42) = "); PrintStr(ns); PrintStr("\n");
    StrFree(ns);

    var ns2: pchar := StrFromInt(-7);
    PrintStr("StrFromInt(-7) = "); PrintStr(ns2); PrintStr("\n");
    StrFree(ns2);

    return 0;
}
