// Test: multiple function pointers
type Callback = fn(int64, int64) -> int64;

fn add(a: int64, b: int64): int64 {
  return a + b;
}

fn sub(a: int64, b: int64): int64 {
  return a - b;
}

fn call_fn(cb: Callback, a: int64, b: int64): int64 {
  return cb(a, b);
}

fn main(): int64 {
  var cb1: Callback := add;
  var cb2: Callback := sub;
  
  var result1: int64 := cb1(10, 20);  // 30
  var result2: int64 := cb2(100, 50);  // 50
  
  PrintInt(result1);
  PrintInt(result2);
  
  // Test passing function pointer to another function
  var result3: int64 := call_fn(cb1, 5, 15);  // 20
  PrintInt(result3);
  
  return 0;
}
