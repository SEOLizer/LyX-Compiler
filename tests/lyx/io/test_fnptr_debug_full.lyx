// Test: function pointer - debug full
type Callback = fn(int64, int64) -> int64;

fn add(a: int64, b: int64): int64 {
  return a + b;
}

fn main(): int64 {
  // Initialize with function address
  var cb: Callback := add;
  // Print the address
  var addr: int64 := cb as int64;
  PrintInt(addr);
  // Call add directly
  var result: int64 := add(10, 20);
  PrintInt(result);
  return 0;
}
