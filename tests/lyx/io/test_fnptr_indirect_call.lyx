// Test indirect function call via function pointer
type Callback = fn(int64, int64) -> int64;

fn add(a: int64, b: int64): int64 {
  return a + b;
}

fn main(): int64 {
  // Initialize function pointer
  var cb: Callback := add;
  
  // Call through function pointer
  var result: int64 := cb(10, 20);
  PrintInt(result);
  
  return 0;
}
