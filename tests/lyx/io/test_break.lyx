// Test: break in while loops
fn main(): int64 {
  var sum: int64 := 0;
  var i: int64 := 0;
  
  // Test 1: break exits loop early
  while (i < 10) {
    i := i + 1;
    if (i == 5) {
      break;
    }
    sum := sum + i;
  }
  
  // sum should be 1+2+3+4 = 10
  PrintInt(sum);
  
  // Test 2: break in nested loops  
  var j: int64 := 0;
  var total: int64 := 0;
  
  while (j < 3) {
    j := j + 1;
    var k: int64 := 0;
    while (k < 3) {
      k := k + 1;
      if (k == 2) {
        break;
      }
      total := total + 1;
    }
  }
  
  // total should be: j=1: k=1 -> total=1, k=2 (break)
  //                   j=2: k=1 -> total=2, k=2 (break)  
  //                   j=3: k=1 -> total=3, k=2 (break)
  PrintInt(total);
  
  return 0;
}
