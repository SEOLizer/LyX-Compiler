// Test: function pointer - check symbol types
type Callback = fn(int64, int64) -> int64;

fn add(a: int64, b: int64): int64 {
  return a + b;
}

fn call_fn(cb: Callback, a: int64, b: int64): int64 {
  return cb(a, b);
}

fn main(): int64 {
  var cb1: Callback := add;
  
  // First just call it directly
  var result: int64 := cb1(10, 20);
  PrintInt(result);
  
  return 0;
}
