// Test std.net after refactoring
// Note: Using built-in PrintInt and PrintStr from std

fn main(): int64 {
  // Test IP packing  
  var ip: int64 := IPPack(192, 168, 1, 1);
  
  // Test IP unpacking
  var addr: IPAddr := IPUnpack(ip);
  
  // Test TCPListener
  var listener: TCPListener;
  listener := TCPListenerNew();
  
  if (listener.fd < 0) {
    return 1;
  }
  
  // Test binding
  var result: int64 := TCPListenerBindTo(listener, ip, 18080);
  if (result < 0) {
    TCPListenerClose(listener);
    return 1;
  }
  
  TCPListenerClose(listener);
  
  return 0;
}
