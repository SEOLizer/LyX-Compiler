// Test VAT ID Validation Module
// Demonstrates EU VAT number validation

import std.validate.vat;

fn main(): int64 {
  PrintStr("Testing VAT ID Validation Module...\n");
  
  // Test 1: German VAT (USt-IdNr.)
  PrintStr("Test 1: German VAT\n");
  var valid: int64 := VATValidate("DE123456789");
  PrintStr("  DE123456789 -> ");
  if (valid == 0) { PrintStr("VALID") } else { PrintStr("INVALID") }
  PrintStr("\n");
  
  // Test 2: Austrian VAT (UID)
  PrintStr("Test 2: Austrian VAT\n");
  valid := VATValidate("ATU12345678");
  PrintStr("  ATU12345678 -> ");
  if (valid == 0) { PrintStr("VALID") } else { PrintStr("INVALID") }
  PrintStr("\n");
  
  valid := VATValidate("AT123456789");
  PrintStr("  AT123456789 (missing U) -> ");
  if (valid == 0) { PrintStr("VALID") } else { PrintStr("INVALID") }
  PrintStr("\n");
  
  // Test 3: Belgian VAT
  PrintStr("Test 3: Belgian VAT\n");
  valid := VATValidate("BE0123456749");
  PrintStr("  BE0123456749 -> ");
  if (valid == 0) { PrintStr("VALID") } else { PrintStr("INVALID") }
  PrintStr("\n");
  
  // Test 4: French VAT
  PrintStr("Test 4: French VAT\n");
  valid := VATValidate("FR12345678901");
  PrintStr("  FR12345678901 -> ");
  if (valid == 0) { PrintStr("VALID") } else { PrintStr("INVALID") }
  PrintStr("\n");
  
  // Test 5: Italian VAT
  PrintStr("Test 5: Italian VAT\n");
  valid := VATValidate("IT12345678901");
  PrintStr("  IT12345678901 -> ");
  if (valid == 0) { PrintStr("VALID") } else { PrintStr("INVALID") }
  PrintStr("\n");
  
  // Test 6: Spanish VAT
  PrintStr("Test 6: Spanish VAT\n");
  valid := VATValidate("ESB12345678");
  PrintStr("  ESB12345678 -> ");
  if (valid == 0) { PrintStr("VALID") } else { PrintStr("INVALID") }
  PrintStr("\n");
  
  // Test 7: Dutch VAT
  PrintStr("Test 7: Dutch VAT\n");
  valid := VATValidate("NL123456789B12");
  PrintStr("  NL123456789B12 -> ");
  if (valid == 0) { PrintStr("VALID") } else { PrintStr("INVALID") }
  PrintStr("\n");
  
  // Test 8: Polish VAT
  PrintStr("Test 8: Polish VAT\n");
  valid := VATValidate("PL1234567890");
  PrintStr("  PL1234567890 -> ");
  if (valid == 0) { PrintStr("VALID") } else { PrintStr("INVALID") }
  PrintStr("\n");
  
  // Test 9: Swedish VAT
  PrintStr("Test 9: Swedish VAT\n");
  valid := VATValidate("SE123456789001");
  PrintStr("  SE123456789001 -> ");
  if (valid == 0) { PrintStr("VALID") } else { PrintStr("INVALID") }
  PrintStr("\n");
  
  valid := VATValidate("SE123456789011");
  PrintStr("  SE123456789011 (wrong ending) -> ");
  if (valid == 0) { PrintStr("VALID") } else { PrintStr("INVALID") }
  PrintStr("\n");
  
  // Test 10: VAT name lookup
  PrintStr("Test 10: VAT Name Lookup\n");
  var name: int64 := VATGetCountryName("DE");
  PrintStr("  DE -> ");
  sys_write(1, name, 20);
  PrintStr("\n");
  
  name := VATGetCountryName("AT");
  PrintStr("  AT -> ");
  sys_write(1, name, 20);
  PrintStr("\n");
  
  name := VATGetCountryName("FR");
  PrintStr("  FR -> ");
  sys_write(1, name, 20);
  PrintStr("\n");
  
  // Test 11: Format description
  PrintStr("Test 11: Format Description\n");
  var fmt: int64 := VATGetFormat("DE");
  PrintStr("  DE -> ");
  sys_write(1, fmt, 20);
  PrintStr("\n");
  
  fmt := VATGetFormat("AT");
  PrintStr("  AT -> ");
  sys_write(1, fmt, 20);
  PrintStr("\n");
  
  PrintStr("\nAll tests completed!\n");
  return 0;
}
