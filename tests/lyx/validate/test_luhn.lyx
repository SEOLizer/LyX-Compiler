// Test Luhn/Credit Card Validation Module
// Demonstrates Luhn algorithm, card type detection, and formatting

import std.validate.luhn;

fn main(): int64 {
  PrintStr("Testing Luhn/Credit Card Module...\n");
  
  // Test 1: Luhn Validation
  PrintStr("Test 1: Luhn Validation\n");
  var valid: int64 := LuhnValidate("4532015112830366");
  PrintStr("  4532015112830366 -> ");
  if (valid == 1) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  valid := LuhnValidate("4532015112830367");
  PrintStr("  4532015112830367 -> ");
  if (valid == 1) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  // Test 2: Luhn Check Digit
  PrintStr("Test 2: Luhn Check Digit\n");
  var check: int64 := LuhnCheckDigit("7992739871");
  PrintStr("  7992739871 -> check digit: ");
  PrintInt(check);
  PrintStr(" (expected: 3)\n");
  
  // Test 3: Credit Card Type Detection
  PrintStr("Test 3: Credit Card Type Detection\n");
  var t: int64 := CreditCardType("4532015112830366");
  PrintStr("  4532... -> ");
  sys_write(1, CreditCardTypeName(t), 20);
  PrintStr("\n");
  
  t := CreditCardType("5425233430109903");
  PrintStr("  5425... -> ");
  sys_write(1, CreditCardTypeName(t), 20);
  PrintStr("\n");
  
  t := CreditCardType("374245455400126");
  PrintStr("  3742... -> ");
  sys_write(1, CreditCardTypeName(t), 20);
  PrintStr("\n");
  
  t := CreditCardType("6011111111111117");
  PrintStr("  6011... -> ");
  sys_write(1, CreditCardTypeName(t), 20);
  PrintStr("\n");
  
  // Test 4: Credit Card Validation
  PrintStr("Test 4: Credit Card Validation\n");
  valid := CreditCardValidate("4532015112830366");
  PrintStr("  4532015112830366 -> ");
  if (valid == 1) {
    PrintStr("VALID CARD")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  // Test 5: Credit Card Formatting
  PrintStr("Test 5: Credit Card Formatting\n");
  var formatted: int64 := CreditCardFormat("4532015112830366");
  if (formatted != 0) {
    PrintStr("  4532015112830366 -> ");
    sys_write(1, formatted, 19);
    PrintStr("\n");
    munmap(formatted, 20);
  }
  
  // Test 6: Credit Card Masking
  PrintStr("Test 6: Credit Card Masking\n");
  var masked: int64 := CreditCardMask("4532015112830366");
  if (masked != 0) {
    PrintStr("  4532015112830366 -> ");
    sys_write(1, masked, 19);
    PrintStr("\n");
    munmap(masked, 20);
  }
  
  // Test 7: Generate Test Card Numbers
  PrintStr("Test 7: Generate Test Card Numbers\n");
  var testVisa: int64 := CreditCardGenerateTest(CARD_VISA);
  if (testVisa != 0) {
    PrintStr("  Visa test:   ");
    sys_write(1, testVisa, 16);
    PrintStr(" (Luhn: ");
    if (LuhnValidate(testVisa) == 1) {
      PrintStr("OK")
    } else {
      PrintStr("FAIL")
    }
    PrintStr(")\n");
    munmap(testVisa, 17);
  }
  
  var testAmex: int64 := CreditCardGenerateTest(CARD_AMEX);
  if (testAmex != 0) {
    PrintStr("  Amex test:   ");
    sys_write(1, testAmex, 15);
    PrintStr(" (Luhn: ");
    if (LuhnValidate(testAmex) == 1) {
      PrintStr("OK")
    } else {
      PrintStr("FAIL")
    }
    PrintStr(")\n");
    munmap(testAmex, 16);
  }
  
  // Test 8: IMEI Validation
  PrintStr("Test 8: IMEI Validation\n");
  valid := IMEIValidate("352099001761481");
  PrintStr("  352099001761481 -> ");
  if (valid == 1) {
    PrintStr("VALID IMEI")
  } else {
    PrintStr("INVALID")
  }
  PrintStr("\n");
  
  // Test 9: Luhn transposition detection
  PrintStr("Test 9: Transposition Error Detection\n");
  valid := LuhnValidate("79927398713");
  PrintStr("  79927398713 -> ");
  if (valid == 1) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID (transposition detected!)")
  }
  PrintStr("\n");
  
  valid := LuhnValidate("79927398714");
  PrintStr("  79927398714 -> ");
  if (valid == 1) {
    PrintStr("VALID")
  } else {
    PrintStr("INVALID (transposition detected!)")
  }
  PrintStr("\n");
  
  PrintStr("\nAll tests completed!\n");
  return 0;
}
