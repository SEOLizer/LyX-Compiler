// tests/lyx/simd/vector_batch_test.lyx
// Test für Vektor-Array-Operationen (ohne Array-Parameter)

// Einfache Tests für Vektor-Operationen, die später SIMD-optimiert werden können

fn Vec2New(x: int64, y: int64): int64[2] {
  var arr: int64[2];
  arr[0] := x;
  arr[1] := y;
  return arr;
}

fn Vec2GetX(v: int64[2]): int64 {
  return v[0];
}

fn Vec2GetY(v: int64[2]): int64 {
  return v[1];
}

// Inline Sum - keine Array-Parameter
fn main(): int64 {
  // Test 1: Einfache Vektor-Addition
  var v1: int64[2] = Vec2New(1, 2);
  var v2: int64[2] = Vec2New(3, 4);
  
  // Manuelle Addition (später SIMD)
  var sumX: int64 = v1[0] + v2[0];  // 1 + 3 = 4
  var sumY: int64 = v1[1] + v2[1];  // 2 + 4 = 6
  
  // Test 2: Array-Iteration (simuliert Batch-Operation)
  var vectors: int64[4][2];
  vectors[0][0] := 1; vectors[0][1] := 2;
  vectors[1][0] := 3; vectors[1][1] := 4;
  vectors[2][0] := 5; vectors[2][1] := 6;
  vectors[3][0] := 7; vectors[3][1] := 8;
  
  var totalX: int64 = 0;
  var totalY: int64 = 0;
  var i: int64 = 0;
  
  while (i < 4) {
    totalX := totalX + vectors[i][0];
    totalY := totalY + vectors[i][1];
    i := i + 1;
  }
  
  // totalX sollte 1+3+5+7 = 16 sein
  // totalY sollte 2+4+6+8 = 20 sein
  
  // Rückgabe: Summe aller Komponenten = 16 + 20 = 36
  return totalX + totalY;
}
