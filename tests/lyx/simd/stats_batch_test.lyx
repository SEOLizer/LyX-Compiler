// tests/lyx/simd/stats_batch_test.lyx
// Test für stats Batch-Funktionen

import std.stats_batch;

fn main(): int64 {
  // Test ArraySum4
  var sum4: int64 = ArraySum4(1, 2, 3, 4);  // Sollte 10 sein
  
  // Test ArraySum8
  var sum8: int64 = ArraySum8(1, 2, 3, 4, 5, 6, 7, 8);  // Sollte 36 sein
  
  // Test ArrayMin4
  var min4: int64 = ArrayMin4(5, 2, 8, 1);  // Sollte 1 sein
  
  // Test ArrayMax4
  var max4: int64 = ArrayMax4(5, 2, 8, 1);  // Sollte 8 sein
  
  // Test ArrayAvg4
  var avg4: int64 = ArrayAvg4(10, 20, 30, 40);  // Sollte 25 sein
  
  // Test ArrayVariance4
  var variance: int64 = ArrayVariance4(10, 20, 30, 40);
  // mean = 25
  // (10-25)² + (20-25)² + (30-25)² + (40-25)² = 225+25+25+225 = 500
  // 500 / 4 = 125
  
  // Test ArrayStdDev4
  var stddev: int64 = ArrayStdDev4(10, 20, 30, 40);
  // sqrt(125) ≈ 11
  
  // Test ArrayRange4
  var range: int64 = ArrayRange4(5, 2, 8, 1);  // 8 - 1 = 7
  
  // Test ArraySumSquares4
  var sumSq: int64 = ArraySumSquares4(1, 2, 3, 4);  // 1+4+9+16 = 30
  
  // Test ArrayMin8
  var min8: int64 = ArrayMin8(5, 2, 8, 1, 9, 3, 7, 4);  // Sollte 1 sein
  
  // Test ArrayMax8
  var max8: int64 = ArrayMax8(5, 2, 8, 1, 9, 3, 7, 4);  // Sollte 9 sein
  
  // Test ArrayAvg8
  var avg8: int64 = ArrayAvg8(10, 20, 30, 40, 50, 60, 70, 80);
  // Sum = 360, / 8 = 45
  
  // Rückgabe: Summe aller Testergebnisse zur Verifikation
  // sum4(10) + sum8(36) + min4(1) + max4(8) + avg4(25) + variance(125) + stddev(11) + range(7) + sumSq(30) + min8(1) + max8(9) + avg8(45) = 308
  return sum4 + sum8 + min4 + max4 + avg4 + variance + stddev + range + sumSq + min8 + max8 + avg8;
}
