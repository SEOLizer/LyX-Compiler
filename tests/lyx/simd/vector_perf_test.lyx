// tests/lyx/simd/vector_perf_test.lyx
// Performance-Test für Vektor-Operationen
// Misst die Zeit für viele Vektor-Additionen

fn main(): int64 {
  // Initialisiere 100 Vektor-Paare
  // Da keine Arrays unterstützt, verwenden wir viele Variablen
  
  // Wir messen die Zeit durch viele Iterationen
  var iterations: int64 = 1000;
  
  // Initiale Vektoren
  var ax: int64 = 1;
  var ay: int64 = 2;
  var bx: int64 = 3;
  var by: int64 = 4;
  
  var resultX: int64 = 0;
  var resultY: int64 = 0;
  
  var i: int64 = 0;
  while (i < iterations) {
    // Vektor-Addition
    resultX := ax + bx;
    resultY := ay + by;
    
    // Vektor-Subtraktion
    resultX := resultX - ax;
    resultY := resultY - ay;
    
    // Skalarprodukt
    var dot: int64 = ax * bx + ay * by;
    
    // Kreuzprodukt
    var cross: int64 = ax * by - ay * bx;
    
    // Addiere zum Ergebnis (verhindert Optimization)
    resultX := resultX + dot + cross;
    resultY := resultY + dot - cross;
    
    i := i + 1;
  }
  
  // Rückgabe: Irgendein Wert, um sicherzustellen, dass die Berechnungen stattfinden
  return resultX + resultY;
}
