// Test für math Batch-Funktionen

import std.math_batch;

fn main(): int64 {
  // Test Min4
  var min4: int64 = Min4(5, 2, 8, 1);  // Sollte 1 sein
  
  // Test Min8
  var min8: int64 = Min8(5, 2, 8, 1, 9, 3, 7, 4);  // Sollte 1 sein
  
  // Test Max4
  var max4: int64 = Max4(5, 2, 8, 1);  // Sollte 8 sein
  
  // Test Max8
  var max8: int64 = Max8(5, 2, 8, 1, 9, 3, 7, 4);  // Sollte 9 sein
  
  // Rückgabe: Summe aller Testergebnisse
  return min4 + min8 + max4 + max8;
}
