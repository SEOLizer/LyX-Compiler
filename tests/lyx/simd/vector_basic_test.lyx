// tests/lyx/simd/vector_basic_test.lyx
// Einfacher Test für Vektor-Grundoperationen

fn main(): int64 {
  // Einfache Variablen als Vektor-Komponenten
  var x1: int64 = 1;
  var y1: int64 = 2;
  
  var x2: int64 = 3;
  var y2: int64 = 4;
  
  // Vektor-Addition (skalar, aber später SIMD)
  var sumX: int64 = x1 + x2;  // 1 + 3 = 4
  var sumY: int64 = y1 + y2;  // 2 + 4 = 6
  
  // Vektor-Subtraktion
  var diffX: int64 = x2 - x1;  // 3 - 1 = 2
  var diffY: int64 = y2 - y1;  // 4 - 2 = 2
  
  // Skalarprodukt (Dot Product)
  var dot: int64 = x1 * x2 + y1 * y2;  // 1*3 + 2*4 = 11
  
  // Kreuzprodukt (2D)
  var cross: int64 = x1 * y2 - y1 * x2;  // 1*4 - 2*3 = -2
  
  // Quadratische Länge
  var lenSq: int64 = x1 * x1 + y1 * y1;  // 1 + 4 = 5
  
  // Rückgabe: Summe aller Ergebnisse
  // sumX(4) + sumY(6) + diffX(2) + diffY(2) + dot(11) + cross(-2) + lenSq(5) = 28
  return sumX + sumY + diffX + diffY + dot + cross + lenSq;
}
