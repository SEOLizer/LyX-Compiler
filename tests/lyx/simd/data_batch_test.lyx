// tests/lyx/simd/data_batch_test.lyx
// Test für data Batch-Funktionen (aufgeteilt wegen Compiler-Limit)

import data.stats_batch;

// Part 1: Sum und Min/Max
fn testSumMinMax(): int64 {
  var r: int64 = 0;
  r := r + Sum4(1, 2, 3, 4);
  r := r + Sum8(1, 2, 3, 4, 5, 6, 7, 8);
  r := r + Min4(5, 2, 8, 1);
  r := r + Max4(5, 2, 8, 1);
  return r;
}

// Part 2: Avg, Variance, StdDev, Range
fn testStats(): int64 {
  var r: int64 = 0;
  r := r + Avg4(10, 20, 30, 40);
  r := r + Variance4(10, 20, 30, 40);
  r := r + StdDev4(10, 20, 30, 40);
  r := r + Range4(5, 2, 8, 1);
  return r;
}

// Part 3: 8-element functions
fn test8Elements(): int64 {
  var r: int64 = 0;
  r := r + Min8(5, 2, 8, 1, 9, 3, 7, 4);
  r := r + Max8(5, 2, 8, 1, 9, 3, 7, 4);
  r := r + Avg8(10, 20, 30, 40, 50, 60, 70, 80);
  return r;
}

fn main(): int64 {
  var result: int64 = 0;
  result := result + testSumMinMax();   // 10+36+1+8 = 55
  result := result + testStats();       // 25+125+11+7 = 168
  result := result + test8Elements();    // 1+9+45 = 55
  // Total: 55 + 168 + 55 = 278
  return result;
}
