// tests/lyx/simd/vector_loop_test.lyx
// Test für Vektor-Operationen mit Schleifen (Batch-Operation Simulation)

fn main(): int64 {
  // Simuliere ein Array von Vektoren durch einzelne Variablen
  // Da mehrdimensionale Arrays nicht unterstützt werden
  
  // 4 Vektoren: (1,2), (3,4), (5,6), (7,8)
  var x0: int64 = 1; var y0: int64 = 2;
  var x1: int64 = 3; var y1: int64 = 4;
  var x2: int64 = 5; var y2: int64 = 6;
  var x3: int64 = 7; var y3: int64 = 8;
  
  // Batch-Addition (simuliert Vec2ArraySum)
  var totalX: int64 = 0;
  var totalY: int64 = 0;
  
  // Iteration 0
  totalX := totalX + x0;
  totalY := totalY + y0;
  
  // Iteration 1
  totalX := totalX + x1;
  totalY := totalY + y1;
  
  // Iteration 2
  totalX := totalX + x2;
  totalY := totalY + y2;
  
  // Iteration 3
  totalX := totalX + x3;
  totalY := totalY + y3;
  
  // totalX sollte 1+3+5+7 = 16 sein
  // totalY sollte 2+4+6+8 = 20 sein
  
  // Rückgabe: Summe = 36
  return totalX + totalY;
}
