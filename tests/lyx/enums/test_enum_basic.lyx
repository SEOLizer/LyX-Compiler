// tests/lyx/enums/test_enum_basic.lyx
// WP-04: Enum-Typen – Grundtest
// Syntax: enum Name { VAL, VAL = explicit }
// Enums werden zu int64-Konstanten (0, 1, 2, ...) compiliert

// Automatische Nummerierung (0, 1, 2, ...)
pub enum TokenKind {
  tkEof,
  tkIdent,
  tkInt,
  tkPlus,
  tkMinus,
  tkStar,
};

// Explizite Werte mit '='
pub enum HttpStatus {
  OK           = 200,
  NOT_FOUND    = 404,
  SERVER_ERROR = 500,
};

// Gemischt: explizit + auto-increment
pub enum Direction {
  NORTH,        // 0
  SOUTH,        // 1
  EAST  = 10,   // 10
  WEST,         // 11 (continues from last explicit)
};

// Hilfsfunktion: gibt TokenKind-Namen zurück
fn tokenKindName(k: TokenKind): pchar {
  if (k == tkEof)    { return "EOF"; }
  if (k == tkIdent)  { return "IDENT"; }
  if (k == tkInt)    { return "INT"; }
  if (k == tkPlus)   { return "PLUS"; }
  if (k == tkMinus)  { return "MINUS"; }
  if (k == tkStar)   { return "STAR"; }
  return "?";
}

fn main(): int64 {
  // === Auto-nummerierung ===
  PrintStr("=== TokenKind (auto) ===\n");
  PrintStr("tkEof   = "); PrintInt(tkEof);   PrintStr("\n");
  PrintStr("tkIdent = "); PrintInt(tkIdent); PrintStr("\n");
  PrintStr("tkInt   = "); PrintInt(tkInt);   PrintStr("\n");
  PrintStr("tkPlus  = "); PrintInt(tkPlus);  PrintStr("\n");
  PrintStr("tkMinus = "); PrintInt(tkMinus); PrintStr("\n");
  PrintStr("tkStar  = "); PrintInt(tkStar);  PrintStr("\n");

  // === Explizite Werte ===
  PrintStr("=== HttpStatus (explicit) ===\n");
  PrintStr("OK           = "); PrintInt(OK);           PrintStr("\n");
  PrintStr("NOT_FOUND    = "); PrintInt(NOT_FOUND);    PrintStr("\n");
  PrintStr("SERVER_ERROR = "); PrintInt(SERVER_ERROR); PrintStr("\n");

  // === Gemischt ===
  PrintStr("=== Direction (mixed) ===\n");
  PrintStr("NORTH = "); PrintInt(NORTH); PrintStr("\n");
  PrintStr("SOUTH = "); PrintInt(SOUTH); PrintStr("\n");
  PrintStr("EAST  = "); PrintInt(EAST);  PrintStr("\n");
  PrintStr("WEST  = "); PrintInt(WEST);  PrintStr("\n");

  // === Variable mit Enum-Typ ===
  PrintStr("=== Typed variable ===\n");
  var kind: TokenKind := tkIdent;
  PrintStr("kind = "); PrintStr(tokenKindName(kind)); PrintStr("\n");

  // === switch auf Enum-Wert ===
  PrintStr("=== switch on enum ===\n");
  var status: HttpStatus := OK;
  switch (status) {
    case 200: { PrintStr("status: OK\n"); }
    case 404: { PrintStr("status: Not Found\n"); }
    case 500: { PrintStr("status: Server Error\n"); }
    default:  { PrintStr("status: unknown\n"); }
  }

  // === Enum in Ausdrücken ===
  PrintStr("=== arithmetic ===\n");
  var sum: int64 := tkPlus + tkMinus + tkStar;
  PrintStr("tkPlus+tkMinus+tkStar = "); PrintInt(sum); PrintStr("\n");

  // === Vergleiche ===
  PrintStr("=== comparisons ===\n");
  if (kind == tkIdent) {
    PrintStr("kind is IDENT\n");
  }
  if (tkEof < tkIdent) {
    PrintStr("tkEof < tkIdent: true\n");
  }

  return 0;
}
