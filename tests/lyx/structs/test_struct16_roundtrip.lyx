// Test 16-byte struct return + parameter passing (B1 fix)
// A Pair struct has two int64 fields (= 16 bytes).
// makePair() returns it via irReturnStruct (RAX=a, RDX=b).
// getA/getB receive it by reference (SysV: hidden pointer in RDI).
type Pair := struct {
  a: int64;
  b: int64;
};

fn makePair(a: int64, b: int64): Pair {
  return Pair { a: a, b: b };
}

fn getA(p: Pair): int64 {
  return p.a;
}

fn getB(p: Pair): int64 {
  return p.b;
}

fn main(): int64 {
  var p: Pair := makePair(42, 99);

  PrintStr("a: ");
  PrintInt(getA(p));
  PrintStr("\n");
  // Expected: 42

  PrintStr("b: ");
  PrintInt(getB(p));
  PrintStr("\n");
  // Expected: 99

  return 0;
}
