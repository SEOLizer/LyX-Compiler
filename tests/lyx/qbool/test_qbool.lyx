// test_qbool.lyx
// Test file for QBool probabilistic type

import std.qbool;
import std.io;

fn test_basic(): void {
  PrintStr("=== Test: Basic QBool Operations ===\n");
  
  // Create QBools with different probabilities
  var likely_true: QBool := Maybe(0.8);
  var likely_false: QBool := Maybe(0.2);
  var uncertain: QBool := Maybe(0.5);
  
  PrintStr("likely_true probability: ");
  PrintFloat(GetProbability(likely_true));
  PrintStr("\n");
  
  PrintStr("likely_false probability: ");
  PrintFloat(GetProbability(likely_false));
  PrintStr("\n");
  
  // Test NOT operator
  var not_likely: QBool := QBoolNot(likely_true);
  PrintStr("NOT likely_true probability: ");
  PrintFloat(GetProbability(not_likely));
  PrintStr("\n");
}

fn test_logical(): void {
  PrintStr("\n=== Test: Logical Operators ===\n");
  
  var a: QBool := Maybe(0.7);
  var b: QBool := Maybe(0.4);
  
  var and_result: QBool := QBoolAnd(a, b);
  var or_result: QBool := QBoolOr(a, b);
  var xor_result: QBool := QBoolXor(a, b);
  
  PrintStr("A = 0.7, B = 0.4\n");
  PrintStr("A AND B = ");
  PrintFloat(GetProbability(and_result));
  PrintStr(" (expected: 0.28)\n");
  
  PrintStr("A OR B = ");
  PrintFloat(GetProbability(or_result));
  PrintStr(" (expected: 0.82)\n");
  
  PrintStr("A XOR B = ");
  PrintFloat(GetProbability(xor_result));
  PrintStr(" (expected: 0.54)\n");
}

fn test_observe(): void {
  PrintStr("\n=== Test: Observe (Collapse) ===\n");
  
  var q: QBool := Maybe(0.5);
  
  // Observe multiple times - should give roughly 50% true
  var true_count: int64 := 0;
  var false_count: int64 := 0;
  var i: int64 := 0;
  
  while (i < 100) {
    if (Observe(q)) {
      true_count := true_count + 1;
    } else {
      false_count := false_count + 1;
    };
    i := i + 1;
  };
  
  PrintStr("Observed 100 times:\n");
  PrintStr("  True: ");
  PrintInt(true_count);
  PrintStr("\n");
  PrintStr("  False: ");
  PrintInt(false_count);
  PrintStr("\n");
}

fn test_entanglement(): void {
  PrintStr("\n=== Test: Entanglement ===\n");
  
  // Create entangled pair (same outcome)
  var pair: EntangledPair := Entangle(true);
  
  var i: int64 := 0;
  while (i < 5) {
    var a_result: bool := ObserveA(pair);
    var b_result: bool := ObserveB(pair);
    
    PrintStr("Observation pair: ");
    if (a_result) { PrintStr("T"); } else { PrintStr("F"); };
    PrintStr(" - ");
    if (b_result) { PrintStr("T"); } else { PrintStr("F"); };
    PrintStr("\n");
    i := i + 1;
  };
}

fn test_ai_decision(): void {
  PrintStr("\n=== Test: AI Decision Making ===\n");
  
  // Weather prediction
  RandomSeed(42);
  var take_umbrella: bool := WeatherPrediction(0.3, 0.7);
  PrintStr("Weather decision (sunny=0.3, rain=0.7): ");
  if (take_umbrella) { PrintStr("Take umbrella\n"); } else { PrintStr("No umbrella\n"); };
  
  // Medical diagnosis
  var is_sick: bool := Diagnose(0.8, 0.6, 0.7);
  PrintStr("Diagnosis (fever=0.8, cough=0.6, fatigue=0.7): ");
  if (is_sick) { PrintStr("Probably sick\n"); } else { PrintStr("Probably okay\n"); };
}

fn main(): int64 {
  test_basic();
  test_logical();
  test_observe();
  test_entanglement();
  test_ai_decision();
  
  PrintStr("\n=== All tests completed ===\n");
  return 0;
}
