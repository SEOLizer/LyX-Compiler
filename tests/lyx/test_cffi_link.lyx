// Test C FFI: extern fn with explicit link annotation
// Verifies that library name propagates correctly through the pipeline

extern fn strlen(s: pchar): int64 link "libc.so.6";

fn main(): int64 {
  var s: pchar := "Hello C FFI!";
  var n: int64 := strlen(s);
  PrintStr("strlen result: ");
  PrintInt(n);
  PrintStr("\n");
  return 0;
}
