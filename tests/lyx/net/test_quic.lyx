// Test QUIC Module
// Demonstrates QUIC packet structure and framing

import std.net.quic;

fn main(): int64 {
  PrintStr("Testing QUIC module (RFC 9000)...\n");
  
  // Test 1: Variable-length integer encoding
  PrintStr("Test 1: QUIC Varint Encoding\n");
  var buf: int64 := mmap(0, 32, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf != 0) {
    // Encode values
    var n1: int64 := QUICWriteVarint(buf, 0, 37);
    var n2: int64 := QUICWriteVarint(buf, n1, 15293);
    var n3: int64 := QUICWriteVarint(buf, n1 + n2, 494878333);
    
    PrintStr("  37 -> ");
    PrintInt(n1);
    PrintStr(" bytes: ");
    var i: int64 := 0;
    while (i < n1) {
      var b: int64 := peek8(buf + i);
      if (b < 16) { PrintStr("0"); }
      PrintInt(b);
      i := i + 1;
    }
    PrintStr("\n");
    
    PrintStr("  15293 -> ");
    PrintInt(n2);
    PrintStr(" bytes: ");
    i := 0;
    while (i < n2) {
      var b: int64 := peek8(buf + n1 + i);
      if (b < 16) { PrintStr("0"); }
      PrintInt(b);
      i := i + 1;
    }
    PrintStr("\n");
    
    // Decode
    var v1: int64 := QUICReadVarint(buf, 0);
    var v2: int64 := QUICReadVarint(buf, n1);
    PrintStr("  Decoded: ");
    PrintInt(v1);
    PrintStr(", ");
    PrintInt(v2);
    PrintStr("\n");
    
    munmap(buf, 32);
  }
  
  // Test 2: Build Initial packet
  PrintStr("Test 2: Build QUIC Initial Packet\n");
  var srcId: int64 := mmap(0, 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  var dstId: int64 := mmap(0, 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (srcId != 0 && dstId != 0) {
    // Generate connection IDs
    var i: int64 := 0;
    while (i < 8) {
      poke8(srcId + i, i + 1);
      poke8(dstId + i, 255 - i);
      i := i + 1;
    }
    
    var pkt: int64 := QUICBuildInitialPacket(dstId, 8, srcId, 8);
    if (pkt != 0) {
      PrintStr("  Initial packet built!\n");
      
      // Parse header byte
      var hb: int64 := peek8(pkt);
      PrintStr("  Header: 0x");
      PrintInt(hb);
      PrintStr(" (long form, Initial type)\n");
      
      // Parse version
      var ver: int64 := (peek8(pkt + 1) * 16777216) + (peek8(pkt + 2) * 65536) + (peek8(pkt + 3) * 256) + peek8(pkt + 4);
      PrintStr("  Version: 0x");
      PrintInt(ver);
      if (ver == QUIC_VERSION_1) {
        PrintStr(" (QUIC v1)");
      }
      PrintStr("\n");
      
      munmap(pkt, QUIC_MAX_PACKET_SIZE);
    }
    
    munmap(srcId, 8);
    munmap(dstId, 8);
  }
  
  // Test 3: Build STREAM frame
  PrintStr("Test 3: Build STREAM Frame\n");
  var data: int64 := mmap(0, 32, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (data != 0) {
    // "Hello QUIC!"
    var msg: int64 := "Hello QUIC!";
    var i: int64 := 0;
    while (i < 11) {
      poke8(data + i, peek8(msg + i));
      i := i + 1;
    }
    
    var frame: int64 := QUICBuildStreamFrame(0, data, 11, 1);
    if (frame != 0) {
      PrintStr("  Stream frame built!\n");
      
      var ft: int64 := peek8(frame);
      PrintStr("  Frame type: 0x");
      PrintInt(ft);
      PrintStr(" (STREAM with offset+length+fin)\n");
      
      munmap(frame, 64);
    }
    
    munmap(data, 32);
  }
  
  // Test 4: Build ACK frame
  PrintStr("Test 4: Build ACK Frame\n");
  var ack: int64 := QUICBuildAckFrame(5, 0);
  if (ack != 0) {
    PrintStr("  ACK frame built!\n");
    PrintStr("  Largest ACKed: 5, Delay: 0\n");
    munmap(ack, 32);
  }
  
  // Test 5: Build CONNECTION_CLOSE frame
  PrintStr("Test 5: Build CONNECTION_CLOSE Frame\n");
  var close: int64 := QUICBuildConnectionClose(QUIC_ERR_NO_ERROR, "Normal shutdown");
  if (close != 0) {
    PrintStr("  CONNECTION_CLOSE frame built!\n");
    var ft: int64 := peek8(close);
    PrintStr("  Frame type: 0x");
    PrintInt(ft);
    PrintStr(" (CONNECTION_CLOSE)\n");
    munmap(close, 128);
  }
  
  // Test 6: Build PADDING frame
  PrintStr("Test 6: Build PADDING Frame\n");
  var pad: int64 := QUICBuildPaddingFrame(100);
  if (pad != 0) {
    PrintStr("  Padding frame: 100 bytes (all zeros)\n");
    var allZero: int64 := 1;
    var i: int64 := 0;
    while (i < 100) {
      if (peek8(pad + i) != 0) {
        allZero := 0;
      }
      i := i + 1;
    }
    if (allZero == 1) {
      PrintStr("  Verified: all bytes are 0\n");
    }
    munmap(pad, 100);
  }
  
  PrintStr("\nAll tests completed!\n");
  PrintStr("Note: Full QUIC requires TLS 1.3 integration.\n");
  PrintStr("This module provides the protocol framing layer.\n");
  return 0;
}
