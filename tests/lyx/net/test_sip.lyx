// Test SIP Client
// Demonstrates SIP message building and protocol operations

import std.net.sip;

fn main(): int64 {
  PrintStr("Testing SIP client (RFC 3261)...\n");
  
  // Test 1: Generate Call-ID
  PrintStr("Test 1: Generate Call-ID\n");
  var callId: int64 := SIPGenerateRandom(16);
  if (callId != 0) {
    PrintStr("  Call-ID: ");
    sys_write(1, callId, 32);
    PrintStr("\n");
    munmap(callId, 33);
  }
  
  // Test 2: Build REGISTER message
  PrintStr("Test 2: Build SIP REGISTER\n");
  var regMsg: int64 := SIPBuildRegister("alice", "example.com", 0, "abc123", 1);
  if (regMsg != 0) {
    PrintStr("  REGISTER message built!\n");
    PrintStr("  First line: ");
    // Print first line
    var i: int64 := 0;
    while (i < 80) {
      var c: int64 := peek8(regMsg + i);
      if (c == 13 || c == 10) {
        break;
      }
      var charBuf: int64 := mmap(0, 8, PROT_RW, MAP_ANON, FD_NONE, 0);
      if (charBuf != 0) {
        poke8(charBuf, c);
        sys_write(1, charBuf, 1);
        munmap(charBuf, 8);
      }
      i := i + 1;
    }
    PrintStr("\n");
    munmap(regMsg, 2048);
  }
  
  // Test 3: Build MESSAGE
  PrintStr("Test 3: Build SIP MESSAGE\n");
  var msgMsg: int64 := SIPBuildMessage("alice", "bob", "example.com", "Hello Bob!", "def456", 1);
  if (msgMsg != 0) {
    PrintStr("  MESSAGE message built!\n");
    PrintStr("  First line: ");
    var i: int64 := 0;
    while (i < 80) {
      var c: int64 := peek8(msgMsg + i);
      if (c == 13 || c == 10) {
        break;
      }
      var charBuf: int64 := mmap(0, 8, PROT_RW, MAP_ANON, FD_NONE, 0);
      if (charBuf != 0) {
        poke8(charBuf, c);
        sys_write(1, charBuf, 1);
        munmap(charBuf, 8);
      }
      i := i + 1;
    }
    PrintStr("\n");
    munmap(msgMsg, 4096);
  }
  
  // Test 4: Build OPTIONS
  PrintStr("Test 4: Build SIP OPTIONS\n");
  var optMsg: int64 := SIPBuildOptions("alice", "example.com", "ghi789", 1);
  if (optMsg != 0) {
    PrintStr("  OPTIONS message built!\n");
    munmap(optMsg, 1024);
  }
  
  // Test 5: Parse status code
  PrintStr("Test 5: Parse Status Code\n");
  var response: int64 := mmap(0, 64, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (response != 0) {
    var testResp: int64 := "SIP/2.0 200 OK\r\n";
    var i: int64 := 0;
    while (i < 16) {
      poke8(response + i, peek8(testResp + i));
      i := i + 1;
    }
    var code: int64 := SIPParseStatusCode(response);
    PrintStr("  Parsed status: ");
    PrintInt(code);
    if (code == 200) {
      PrintStr(" (OK)");
    }
    PrintStr("\n");
    munmap(response, 64);
  }
  
  // Test 6: Connect to SIP server (if available)
  // Uncomment to test with real server:
  /*
  PrintStr("\nTest 6: SIP Connect\n");
  var sip: SIPConn := SIPConnect("sip.example.com", 5060);
  if (sip.connected == 1) {
    PrintStr("  Connected!\n");
    
    var code: int64 := SIPRegister(sip, "alice", "secret", "example.com");
    PrintStr("  REGISTER: ");
    PrintInt(code);
    PrintStr("\n");
    
    if (code == SIP_OK) {
      code := SIPOptions(sip, "alice", "example.com");
      PrintStr("  OPTIONS: ");
      PrintInt(code);
      PrintStr("\n");
    }
    
    SIPDisconnect(sip);
  }
  */
  
  PrintStr("\nAll tests completed!\n");
  return 0;
}
