// Test NTP Client
// Demonstrates NTP packet building and time formatting

import std.net.ntp;

fn main(): int64 {
  PrintStr("Testing NTP client...\n");
  
  // Test 1: Build NTP request packet
  PrintStr("Test 1: Build NTP request packet\n");
  var req: int64 := NTPBuildRequest();
  if (req != 0) {
    PrintStr("  Packet size: ");
    PrintInt(48);
    PrintStr(" bytes\n");
    
    // Show first few bytes
    PrintStr("  First bytes: ");
    var i: int64 := 0;
    while (i < 8) {
      var b: int64 := peek8(req + i);
      PrintInt(b);
      PrintStr(" ");
      i := i + 1;
    }
    PrintStr("\n");
    
    // Check LI+VN+Mode byte
    var lv: int64 := peek8(req);
    PrintStr("  LI+VN+Mode: 0x");
    PrintInt(lv);
    PrintStr(" (VN=4, Mode=3)\n");
    
    munmap(req, 48);
  }
  
  // Test 2: Parse a fake NTP response
  PrintStr("Test 2: Parse NTP response\n");
  var resp: int64 := mmap(0, 48, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (resp != 0) {
    // Clear response
    var i: int64 := 0;
    while (i < 48) {
      poke8(resp + i, 0);
      i := i + 1;
    }
    
    // Set server mode (byte 0: LI=0, VN=4, Mode=4)
    // 00 100 100 = 0x24 = 36
    poke8(resp, 36);
    
    // Set stratum (byte 1)
    poke8(resp + 1, 2);
    
    // Set transmit timestamp (bytes 40-47)
    // Unix time 1710000000 = NTP time 1710000000 + 2208988800 = 3918988800
    // 3918988800 in hex = 0xE98C5E00
    // Big-endian: E9 8C 5E 00
    poke8(resp + 40, 0xE9);
    poke8(resp + 41, 0x8C);
    poke8(resp + 42, 0x5E);
    poke8(resp + 43, 0x00);
    
    // Fractional part (bytes 44-47) = 0
    poke8(resp + 44, 0);
    poke8(resp + 45, 0);
    poke8(resp + 46, 0);
    poke8(resp + 47, 0);
    
    var time: NTPTime := NTPParseResponse(resp, 0, 0);
    
    PrintStr("  Stratum: ");
    PrintInt(time.stratum);
    PrintStr("\n");
    
    PrintStr("  Unix time: ");
    PrintInt(time.unixTime);
    PrintStr("\n");
    
    // Format time
    var formatted: int64 := NTPFormatTime(time.unixTime);
    if (formatted != 0) {
      PrintStr("  Formatted: ");
      sys_write(1, formatted, 25);
      PrintStr("\n");
      munmap(formatted, 32);
    }
    
    munmap(resp, 48);
  }
  
  // Test 3: Connect to real NTP server (if network available)
  // Uncomment to test with real server:
  /*
