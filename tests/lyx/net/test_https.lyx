// Test HTTPS Client - OpenSSL 3.x via FFI
// Requires: libssl.so.3, libcrypto.so.3

import std.net.https;
import std.net.tls;

fn main(): int64 {
  PrintStr("Testing HTTPS client with OpenSSL 3.x...\n");
  
  // Test TLS initialization
  var ctx: TLSContext := TLSInit();
  if (ctx.initialized == 0) {
    PrintStr("ERROR: TLS initialization failed\n");
    return 1;
  }
  PrintStr("TLS initialized successfully!\n");
  
  // Test HTTPS GET to a simple endpoint
  PrintStr("Attempting HTTPS GET to httpbin.org...\n");
  var resp: HTTPResponse := HTTPSGet("httpbin.org", "/get");
  
  if (resp.statusCode > 0) {
    PrintStr("Status: ");
    PrintInt(resp.statusCode);
    PrintStr("\n");
    
    if (resp.bodyPtr != 0 && resp.bodySize > 0) {
      PrintStr("Body received (");
      PrintInt(resp.bodySize);
      PrintStr(" bytes)\n");
      // Print first 200 chars of body
      var i: int64 := 0;
      while (i < resp.bodySize && i < 200) {
        var c: int64 := peek8(resp.bodyPtr + i);
        // Print printable ASCII
        if (c >= 32 && c < 127) {
          // Write single char
          var charBuf: int64 := mmap(0, 8, PROT_RW, MAP_ANON, FD_NONE, 0);
          if (charBuf != 0) {
            poke8(charBuf, c);
            sys_write(1, charBuf, 1);
            munmap(charBuf, 8);
          }
        }
        i := i + 1;
      }
      PrintStr("\n");
    }
    
    HTTPResponseFree(resp);
  } else {
    PrintStr("HTTPS request failed\n");
  }
  
  TLSFree(ctx);
  PrintStr("Done!\n");
  return 0;
}
