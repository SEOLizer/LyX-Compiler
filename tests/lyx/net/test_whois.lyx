// Test Whois Client
// Demonstrates Whois protocol operations

import std.net.whois;

fn main(): int64 {
  PrintStr("Testing Whois client (RFC 3912)...\n");
  
  // Test 1: Server selection for TLDs
  PrintStr("Test 1: Whois Server Selection\n");
  
  var com: int64 := WhoisServerForDomain("example.com");
  PrintStr("  .com -> ");
  sys_write(1, com, 25);
  PrintStr("\n");
  
  var org: int64 := WhoisServerForDomain("example.org");
  PrintStr("  .org -> ");
  sys_write(1, org, 18);
  PrintStr("\n");
  
  var net: int64 := WhoisServerForDomain("example.net");
  PrintStr("  .net -> ");
  sys_write(1, net, 25);
  PrintStr("\n");
  
  var de: int64 := WhoisServerForDomain("example.de");
  PrintStr("  .de  -> ");
  sys_write(1, de, 16);
  PrintStr("\n");
  
  var uk: int64 := WhoisServerForDomain("example.co.uk");
  PrintStr("  .uk  -> ");
  sys_write(1, uk, 18);
  PrintStr("\n");
  
  // Test 2: IPv4 Formatting
  PrintStr("Test 2: IPv4 Formatting\n");
  var ip: int64 := 192 * 16777216 + 168 * 65536 + 1 * 256 + 1;
  var ipStr: int64 := WhoisFormatIPv4(ip);
  if (ipStr != 0) {
    PrintStr("  IP: ");
    sys_write(1, ipStr, 16);
    PrintStr("\n");
    munmap(ipStr, 16);
  }
  
  // Test 3: Whois query (if network available)
  // Uncomment to test with real whois server:
  /*
