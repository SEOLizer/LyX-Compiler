// Test Telnet Client
// Connects to a Telnet server and reads welcome message

import std.net.telnet;
import std.net.dns;

fn main(): int64 {
  PrintStr("Testing Telnet client...\n");
  
  // Connect to a public Telnet server
  // towel.blinkenlights.nl shows Star Wars in ASCII
  PrintStr("Connecting to towel.blinkenlights.nl:23...\n");
  
  var conn: TelnetConn := TelnetConnect("towel.blinkenlights.nl", 23);
  
  if (conn.connected == 0) {
    PrintStr("ERROR: Connection failed\n");
    return 1;
  }
  
  PrintStr("Connected!\n");
  
  // Read data from server
  var buf: int64 := mmap(0, 4096, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    PrintStr("ERROR: Buffer allocation failed\n");
    TelnetClose(conn);
    return 1;
  }
  
  // Read multiple chunks (Telnet sends data in chunks)
  var totalRead: int64 := 0;
  var chunk: int64 := 0;
  
  while (chunk < 10) {
    var n: int64 := TelnetRead(conn, buf, 4096);
    if (n <= 0) {
      break;
    }
    
    // Print received data
    sys_write(1, buf, n);
    totalRead := totalRead + n;
    chunk := chunk + 1;
    
    // Small delay between reads (data arrives in chunks)
    var i: int64 := 0;
    while (i < 100000) {
      i := i + 1;
    }
  }
  
  PrintStr("\n\n");
  PrintStr("Total bytes received: ");
  PrintInt(totalRead);
  PrintStr("\n");
  
  // Cleanup
  munmap(buf, 4096);
  TelnetClose(conn);
  
  PrintStr("Done!\n");
  return 0;
}
