// Test SNMP Client
// Demonstrates ASN.1 encoding and SNMP packet building

import std.net.asn1;
import std.net.snmp;

fn main(): int64 {
  PrintStr("Testing SNMP client...\n");
  
  // Test 1: ASN.1 Encode Integer
  PrintStr("Test 1: ASN.1 Encode Integer\n");
  var buf: int64 := mmap(0, 32, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf != 0) {
    var n: int64 := ASN1EncodeInteger(buf, 0, 42);
    PrintStr("  Encoded ");
    PrintInt(n);
    PrintStr(" bytes: ");
    var i: int64 := 0;
    while (i < n) {
      var b: int64 := peek8(buf + i);
      if (b < 16) { PrintStr("0"); }
      PrintInt(b);
      i := i + 1;
    }
    PrintStr("\n");
    munmap(buf, 32);
  }
  
  // Test 2: ASN.1 Encode OID (1.3.6.1.2.1.1.1.0 = sysDescr)
  PrintStr("Test 2: ASN.1 Encode OID (sysDescr)\n");
  buf := mmap(0, 64, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf != 0) {
    var oid: int64 := mmap(0, 72, PROT_RW, MAP_ANON, FD_NONE, 0);
    if (oid != 0) {
      // Store OID sub-identifiers (8 bytes each)
      poke8(oid + 0, 1);
      poke8(oid + 8, 3);
      poke8(oid + 16, 6);
      poke8(oid + 24, 1);
      poke8(oid + 32, 2);
      poke8(oid + 40, 1);
      poke8(oid + 48, 1);
      poke8(oid + 56, 1);
      poke8(oid + 64, 0);
      
      var n: int64 := ASN1EncodeOID(buf, 0, oid, 9);
      PrintStr("  Encoded ");
      PrintInt(n);
      PrintStr(" bytes\n");
      
      // Verify OID tag
      var tag: int64 := peek8(buf);
      PrintStr("  Tag: 0x");
      PrintInt(tag);
      PrintStr(" (expect 0x06)\n");
      
      munmap(oid, 72);
    }
    munmap(buf, 64);
  }
  
  // Test 3: Build SNMP GET packet
  PrintStr("Test 3: Build SNMP GET packet\n");
  var oid: int64 := mmap(0, 72, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (oid != 0) {
    poke8(oid + 0, 1);
    poke8(oid + 8, 3);
    poke8(oid + 16, 6);
    poke8(oid + 24, 1);
    poke8(oid + 32, 2);
    poke8(oid + 40, 1);
    poke8(oid + 48, 1);
    poke8(oid + 56, 1);
    poke8(oid + 64, 0);
    
    var packet: int64 := SNMPBuildGetRequest(1, "public", oid, 9);
    if (packet != 0) {
      PrintStr("  SNMP packet built!\n");
      
      // Show first 16 bytes
      PrintStr("  Header: ");
      var i: int64 := 0;
      while (i < 16) {
        var b: int64 := peek8(packet + i);
        if (b < 16) { PrintStr("0"); }
        PrintInt(b);
        i := i + 1;
      }
      PrintStr("\n");
      
      // Verify SEQUENCE tag
      var tag: int64 := peek8(packet);
      PrintStr("  Outer tag: 0x");
      PrintInt(tag);
      PrintStr(" (expect 0x30 = SEQUENCE)\n");
      
      munmap(packet, 2048);
    }
    
    munmap(oid, 72);
  }
  
  // Test 4: Connect to SNMP agent (if available)
