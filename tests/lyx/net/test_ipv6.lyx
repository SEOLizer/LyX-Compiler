// Test IPv6 Support: ParseIPv6, IPv6Format, SockAddrIn6Create, TCPConnectIPv6
// Verifies that IPv6 address parsing, packing, formatting, and socket creation work

import std.net.types;
import std.net.socket;

fn main(): int64 {
  // ── Test 1: IPv6 loopback address ────────────────────────────────────────
  PrintStr("Loopback hi: ");
  PrintInt(IPv6LoopbackHi());
  PrintStr("\n");
  PrintStr("Loopback lo: ");
  PrintInt(IPv6LoopbackLo());
  PrintStr("\n");
  // Expected: hi=0, lo=1

  // ── Test 2: Pack/unpack roundtrip ─────────────────────────────────────────
  var hi: int64 := IPv6MakeHi(0x2001, 0x0db8, 0, 0);
  var lo: int64 := IPv6MakeLo(0, 0, 0, 1);

  PrintStr("Roundtrip group 0: ");
  PrintInt(IPv6GetGroup(hi, lo, 0));
  PrintStr("\n");
  // Expected: 8193 (0x2001)

  PrintStr("Roundtrip group 7: ");
  PrintInt(IPv6GetGroup(hi, lo, 7));
  PrintStr("\n");
  // Expected: 1

  // ── Test 3: ParseIPv6 ─────────────────────────────────────────────────────
  var p1hi: int64 := mmap(0, 8, 3, 34, -1, 0);
  var p1lo: int64 := mmap(0, 8, 3, 34, -1, 0);

  var s1: pchar := "::1";
  ParseIPv6(s1 as int64, 3, p1hi, p1lo);
  PrintStr("ParseIPv6 ::1 -> hi: ");
  PrintInt(peek64(p1hi));
  PrintStr(", lo: ");
  PrintInt(peek64(p1lo));
  PrintStr("\n");
  // Expected: hi=0, lo=1

  var p2hi: int64 := mmap(0, 8, 3, 34, -1, 0);
  var p2lo: int64 := mmap(0, 8, 3, 34, -1, 0);

  var s2: pchar := "2001:db8::1";
  ParseIPv6(s2 as int64, 11, p2hi, p2lo);
  PrintStr("ParseIPv6 2001:db8::1 -> group0: ");
  PrintInt(IPv6GetGroup(peek64(p2hi), peek64(p2lo), 0));
  PrintStr(", group7: ");
  PrintInt(IPv6GetGroup(peek64(p2hi), peek64(p2lo), 7));
  PrintStr("\n");
  // Expected: group0=8193 (0x2001), group7=1

  var p3hi: int64 := mmap(0, 8, 3, 34, -1, 0);
  var p3lo: int64 := mmap(0, 8, 3, 34, -1, 0);

  var s3: pchar := "::";
  ParseIPv6(s3 as int64, 2, p3hi, p3lo);
  PrintStr("ParseIPv6 :: -> hi: ");
  PrintInt(peek64(p3hi));
  PrintStr(", lo: ");
  PrintInt(peek64(p3lo));
  PrintStr("\n");
  // Expected: hi=0, lo=0

  // ── Test 4: IPv6Format ────────────────────────────────────────────────────
  var fmtBuf: int64 := mmap(0, 64, 3, 34, -1, 0);

  IPv6Format(peek64(p1hi), peek64(p1lo), fmtBuf);
  PrintStr("Format ::1: ");
  PrintStr(fmtBuf as pchar);
  PrintStr("\n");
  // Expected: ::1

  IPv6Format(hi, lo, fmtBuf);
  PrintStr("Format 2001:db8::1: ");
  PrintStr(fmtBuf as pchar);
  PrintStr("\n");
  // Expected: 2001:db8::1

  munmap(fmtBuf, 64);

  // ── Test 5: sockaddr_in6 layout ───────────────────────────────────────────
  var sa: int64 := mmap(0, 28, 3, 34, -1, 0);
  SockAddrIn6Create(sa, IPv6LoopbackHi(), IPv6LoopbackLo(), 8080);

  // Check family byte (should be 10 = AF_INET6)
  PrintStr("sockaddr_in6 family: ");
  PrintInt(peek8(sa + 0));
  PrintStr("\n");
  // Expected: 10

  // Check port bytes (8080 = 0x1F90, big-endian: 0x1F, 0x90)
  PrintStr("sockaddr_in6 port[0]: ");
  PrintInt(peek8(sa + 2));
  PrintStr("\n");
  // Expected: 31 (0x1F)
  PrintStr("sockaddr_in6 port[1]: ");
  PrintInt(peek8(sa + 3));
  PrintStr("\n");
  // Expected: 144 (0x90)

  // Check last byte of addr (should be 1 for ::1)
  PrintStr("sockaddr_in6 addr[15]: ");
  PrintInt(peek8(sa + 23));
  PrintStr("\n");
  // Expected: 1

  munmap(sa, 28);

  munmap(p1hi, 8);
  munmap(p1lo, 8);
  munmap(p2hi, 8);
  munmap(p2lo, 8);
  munmap(p3hi, 8);
  munmap(p3lo, 8);

  // ── Test 6: TCPConnectIPv6 to loopback (likely fails, just checks no crash) ──
  var conn: TCPConn := TCPConnectIPv6(IPv6LoopbackHi(), IPv6LoopbackLo(), 19999);
  PrintStr("TCPConnectIPv6 ::1:19999 fd (expected <0): ");
  PrintInt(conn.fd);
  PrintStr("\n");

  return 0;
}
