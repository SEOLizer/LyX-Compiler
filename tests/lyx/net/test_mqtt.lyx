  if (mqtt.connected == 1) {
    PrintStr("  Connected!\n");
    
    // Subscribe
    var rc: int64 := MQTTSubscribe(mqtt, "test/lyx", 0);
    PrintStr("  Subscribe result: ");
    PrintInt(rc);
    PrintStr("\n");
    
    // Publish
