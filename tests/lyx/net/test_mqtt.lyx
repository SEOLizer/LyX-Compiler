// Test MQTT Client
// Demonstrates MQTT packet building and protocol operations

import std.net.mqtt;

fn main(): int64 {
  PrintStr("Testing MQTT client (v3.1.1)...\n");
  
  // Test 1: Build CONNECT packet
  PrintStr("Test 1: Build MQTT CONNECT Packet\n");
  var connectPkt: int64 := MQTTBuildConnect("test-client", 60, "user", "pass");
  if (connectPkt != 0) {
    PrintStr("  CONNECT packet built!\n");
    PrintStr("  Packet type: ");
    var pktType: int64 := peek8(connectPkt) / 16;
    PrintInt(pktType);
    if (pktType == MQTT_PKT_CONNECT) {
      PrintStr(" (CONNECT)");
    }
    PrintStr("\n");
    munmap(connectPkt, 256);
  }
  
  // Test 2: Build PUBLISH packet
  PrintStr("Test 2: Build MQTT PUBLISH Packet\n");
  var topic: int64 := "sensor/temp";
  var payload: int64 := "22.5";
  var publishPkt: int64 := MQTTPublish(topic, payload, 4, MQTT_QOS_AT_MOST_ONCE, 0);
  if (publishPkt != 0) {
    PrintStr("  PUBLISH packet built!\n");
    PrintStr("  Topic: ");
    sys_write(1, topic, 11);
    PrintStr("\n");
    PrintStr("  Packet type: ");
    var pktType: int64 := peek8(publishPkt) / 16;
    PrintInt(pktType);
    if (pktType == MQTT_PKT_PUBLISH) {
      PrintStr(" (PUBLISH)");
    }
    PrintStr("\n");
    munmap(publishPkt, 64);
  }
  
  // Test 3: Build SUBSCRIBE packet
  PrintStr("Test 3: Build MQTT SUBSCRIBE Packet\n");
  var subPkt: int64 := MQTTBuildSubscribe("sensor/#", MQTT_QOS_AT_LEAST_ONCE);
  if (subPkt != 0) {
    PrintStr("  SUBSCRIBE packet built!\n");
    PrintStr("  Topic: sensor/#\n");
    munmap(subPkt, 64);
  }
  
  // Test 4: Build UNSUBSCRIBE packet
  PrintStr("Test 4: Build MQTT UNSUBSCRIBE Packet\n");
  var unsubPkt: int64 := MQTTBuildUnsubscribe("sensor/#");
  if (unsubPkt != 0) {
    PrintStr("  UNSUBSCRIBE packet built!\n");
    munmap(unsubPkt, 64);
  }
  
  // Test 5: Build PINGREQ packet
  PrintStr("Test 5: Build MQTT PINGREQ Packet\n");
  var pingPkt: int64 := MQTTBuildPingReq();
  if (pingPkt != 0) {
    PrintStr("  PINGREQ packet built!\n");
    PrintStr("  Size: 2 bytes (fixed)\n");
    munmap(pingPkt, 2);
  }
  
  // Test 6: Build DISCONNECT packet
  PrintStr("Test 6: Build MQTT DISCONNECT Packet\n");
  var discPkt: int64 := MQTTBuildDisconnect();
  if (discPkt != 0) {
    PrintStr("  DISCONNECT packet built!\n");
    PrintStr("  Size: 2 bytes (fixed)\n");
    munmap(discPkt, 2);
  }
  
  // Test 7: Variable-length encoding
  PrintStr("Test 7: MQTT Remaining Length Encoding\n");
  var buf: int64 := mmap(0, 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf != 0) {
    var n: int64 := MQTTWriteRemainingLen(buf, 0, 128);
    PrintStr("  128 -> ");
    PrintInt(n);
    PrintStr(" bytes: ");
    var i: int64 := 0;
    while (i < n) {
      var b: int64 := peek8(buf + i);
      if (b < 16) { PrintStr("0"); }
      PrintInt(b);
      i := i + 1;
    }
    PrintStr("\n");
    
    n := MQTTWriteRemainingLen(buf, 0, 16384);
    PrintStr("  16384 -> ");
    PrintInt(n);
    PrintStr(" bytes\n");
    
    munmap(buf, 8);
  }
  
  // Test 8: Connect to MQTT broker (if available)
  // Uncomment to test with real broker:
  /*
  PrintStr("\nTest 8: Connect to MQTT broker\n");
