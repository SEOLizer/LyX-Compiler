// Simple Network Test
// Tests basic socket creation

pub fn main() {
  PrintStr("=== Simple Network Test ===\n");
  
  // Just test IPPack
  var ip: int64 := (192 << 24) | (168 << 16) | (1 << 8) | 1;
  PrintStr("IP: ");
  PrintInt((ip >> 24) & 0xFF);
  PrintStr(".");
  PrintInt((ip >> 16) & 0xFF);
  PrintStr(".");
  PrintInt((ip >> 8) & 0xFF);
  PrintStr(".");
  PrintInt(ip & 0xFF);
  PrintStr("\n");
  
  PrintStr("Test complete!\n");
}
