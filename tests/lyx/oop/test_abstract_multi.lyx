// Test: abstract - class with multiple abstract methods

type Shape = class {
  abstract fn Area(): int64;
  abstract fn Perimeter(): int64;
};

// Concrete implementations
type Rectangle = class extends Shape {
  fn Area(): int64 { return 12; }
  fn Perimeter(): int64 { return 14; }
};

type Circle = class extends Shape {
  fn Area(): int64 { return 9; }
  fn Perimeter(): int64 { return 6; }
};

fn main(): int64 {
  var r: Rectangle := new Rectangle();
  var c: Circle := new Circle();
  
  return r.Area() + r.Perimeter() + c.Area() + c.Perimeter();
  // 12 + 14 + 9 + 6 = 41
}
