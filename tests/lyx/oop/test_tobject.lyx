// Test TObject - implizite Basisklasse und RTTI
// Testet: implizite Vererbung von TObject, ClassName-Methode

// Eine einfache Klasse ohne explizites "extends" erbt von TObject
type TMyClass = class {
  val: int64;
  
  fn SetVal(v: int64) {
    self.val := v;
  }
  
  fn GetVal(): int64 {
    return self.val;
  }
};

// Eine abgeleitete Klasse
type TDerivedClass = class extends TMyClass {
  extra: int64;
  
  fn SetExtra(e: int64) {
    self.extra := e;
  }
};

fn main(): int64 {
  // Test 1: Instanziierung einer Klasse ohne explizites extends
  var obj: TMyClass := new TMyClass();
  obj.SetVal(42);
  
  PrintStr("TMyClass val: ");
  PrintInt(obj.GetVal());
  PrintStr("\n");
  
  if (obj.GetVal() == 42) {
    PrintStr("Test 1 PASSED: TMyClass works correctly\n");
  } else {
    PrintStr("Test 1 FAILED\n");
    return 1;
  }
  
  // Test 2: ClassName() method
  PrintStr("Test 2: ClassName() method\n");
  var name: pchar := obj.ClassName();
  PrintStr("  TMyClass.ClassName() = ");
  PrintStr(name);
  PrintStr("\n");
  
  dispose obj;
  
  // Test 3: Abgeleitete Klasse
  var derived: TDerivedClass := new TDerivedClass();
  derived.SetVal(100);
  derived.SetExtra(50);
  
  PrintStr("TDerivedClass val: ");
  PrintInt(derived.GetVal());
  PrintStr(", extra: ");
  PrintInt(derived.extra);
  PrintStr("\n");
  
  if (derived.GetVal() == 100) {
    PrintStr("Test 3 PASSED: TDerivedClass inheritance works\n");
  } else {
    PrintStr("Test 3 FAILED\n");
    return 2;
  }
  
  // Test 4: ClassName() on derived class
  PrintStr("Test 4: ClassName() on derived class\n");
  var derivedName: pchar := derived.ClassName();
  PrintStr("  TDerivedClass.ClassName() = ");
  PrintStr(derivedName);
  PrintStr("\n");
  
  dispose derived;
  
  PrintStr("\nAll TObject tests PASSED!\n");
  return 0;
}
