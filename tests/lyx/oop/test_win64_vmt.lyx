// Windows x64 VMT Test - Virtual Method Table
// Tests: virtual methods, override, polymorphism
// Expected output: 50 (via d.GetValue() = 20 + 30)
// Expected exit code: 50

type TBase = class {
  val: int64;
  
  virtual fn GetValue(): int64 {
    return self.val;
  }
};

type TDerived = class extends TBase {
  extra: int64;
  
  override fn GetValue(): int64 {
    return self.val + self.extra;
  }
};

fn main(): int64 {
  var d: TDerived := new TDerived();
  d.val := 20;
  d.extra := 30;
  
  // Virtual method call - should use TDerived.GetValue
  var result: int64 := d.GetValue();
  
  dispose d;
  
  return result;  // Expected: 50
}
