// Test: abstract - should fail at runtime when calling abstract method
// Expected: Program should print "Abstract method called" and exit with code 1

type Animal = class {
  abstract fn Speak(): int64;
};

fn main(): int64 {
  // Instantiate abstract class (allowed at compile time)
  var a: Animal := new Animal();
  
  // Call abstract method - should trigger runtime error
  var result: int64 := a.Speak();
  
  // This should never be reached
  return result;
}
