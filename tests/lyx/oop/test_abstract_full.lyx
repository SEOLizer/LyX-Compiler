// Test: abstract - class with abstract method and concrete subclass

// Abstract base class
type Animal = class {
  abstract fn Speak(): int64;
};

// Concrete subclass - must implement abstract method
type Dog = class extends Animal {
  fn Speak(): int64 {
    return 1;
  }
};

fn main(): int64 {
  // Create concrete instance
  var d: Dog := new Dog();
  var result: int64 := d.Speak();
  
  return result;  // Expected: 1
}
