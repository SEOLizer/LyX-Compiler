// Simple test: just load and print a uint8 field without casting first

type TTest = struct {
  a: uint8;
};

fn main(): int64 {
  var s: TTest;
  s.a := 10;
  
  // Print as uint8 directly - we don't have PrintUInt8, so let's see what happens
  // Actually, let's just return the value and see what we get
  return s.a;  // implicit cast to int64 for return
}
