// Test TObject - implizite Basisklasse (Grundfunktionalität)
// Testet: implizite Vererbung von TObject, Mehrfach-Vererbung

// Eine einfache Klasse ohne explizites "extends" erbt von TObject
type TMyClass = class {
  val: int64;
  
  fn SetVal(v: int64) {
    self.val := v;
  }
  
  fn GetVal(): int64 {
    return self.val;
  }
};

// Eine abgeleitete Klasse
type TDerivedClass = class extends TMyClass {
  extra: int64;
  
  fn SetExtra(e: int64) {
    self.extra := e;
  }
};

fn main(): int64 {
  // Test 1: Instanziierung einer Klasse ohne explizites extends
  PrintStr("Test 1: TMyClass (implicit TObject inheritance)\n");
  var obj: TMyClass := new TMyClass();
  obj.SetVal(42);
  
  PrintStr("  obj.val = ");
  PrintInt(obj.GetVal());
  PrintStr("\n");
  
  if (obj.GetVal() != 42) {
    PrintStr("  FAILED\n");
    return 1;
  }
  PrintStr("  PASSED\n");
  
  dispose obj;
  
  // Test 2: Abgeleitete Klasse
  PrintStr("Test 2: TDerivedClass (extends TMyClass)\n");
  var derived: TDerivedClass := new TDerivedClass();
  derived.SetVal(100);
  derived.SetExtra(50);
  
  PrintStr("  derived.val = ");
  PrintInt(derived.GetVal());
  PrintStr(", derived.extra = ");
  PrintInt(derived.extra);
  PrintStr("\n");
  
  if (derived.GetVal() != 100) {
    PrintStr("  FAILED: GetVal() wrong\n");
    return 2;
  }
  if (derived.extra != 50) {
    PrintStr("  FAILED: extra wrong\n");
    return 3;
  }
  PrintStr("  PASSED\n");
  
  dispose derived;
  
  PrintStr("\nAll TObject tests PASSED!\n");
  return 0;
}
