// Test: abstract method override via VMT
type Shape = class {
  abstract fn area(): int64;
};

type Rectangle = class extends Shape {
  width: int64;
  height: int64;

  fn Init(w: int64, h: int64) {
    width := w;
    height := h;
  }

  fn area(): int64 {
    return width * height;
  }
};

fn main(): int64 {
  var s: Shape := new Rectangle();
  s.Init(5, 3);
  PrintStr("Rectangle area: ");
  PrintInt(s.area());
  PrintStr("\n");
  dispose s;
  return 0;
}