// Test: int64 struct field - simpler test

type TTest = struct {
  a: int64;
  b: int64;
};

fn main(): int64 {
  var s: TTest;
  s.a := 10;
  s.b := 20;
  
  PrintStr("s.a (after assignment) = ");
  PrintInt(s.a);
  PrintStr("\n");
  
  PrintStr("s.b (after assignment) = ");
  PrintInt(s.b);
  PrintStr("\n");
  
  return 0;
}
