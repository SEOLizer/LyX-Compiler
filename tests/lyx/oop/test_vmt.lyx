// Simple VMT test
type TBase = class {
  value: int64;
  
  fn Create() {
    self.value := 10;
  }
  
  virtual fn GetValue(): int64 {
    return self.value;
  }
};

type TDerived = class extends TBase {
  extra: int64;
  
  fn Create() {
    self.value := 20;
    self.extra := 30;
  }
  
  virtual fn GetValue(): int64 {
    return self.value + self.extra;
  }
};

fn main(): int64 {
  var b: TBase := new TBase();
  var d: TDerived := new TDerived();
  
  PrintStr("Base.GetValue(): ");
  PrintInt(b.GetValue());
  PrintStr("\n");
  
  PrintStr("Derived.GetValue(): ");
  PrintInt(d.GetValue());
  PrintStr("\n");
  
  return 0;
}
