// Simple VMT test with virtual methods and override
type TBase = class {
  val: int64;
  
  fn Create() {
    self.val := 10;
  }
  
  virtual fn GetValue(): int64 {
    return self.val;
  }
};

type TDerived = class extends TBase {
  extra: int64;
  
  fn Create() {
    self.val := 20;
    self.extra := 30;
  }
  
  override fn GetValue(): int64 {
    return self.val + self.extra;
  }
};

fn main(): int64 {
  var b: TBase := new TBase();
  b.Create();
  var d: TDerived := new TDerived();
  d.Create();
  
  PrintStr("Base.GetValue(): ");
  PrintInt(b.GetValue());
  PrintStr("\n");
  
  PrintStr("Derived.GetValue(): ");
  PrintInt(d.GetValue());
  PrintStr("\n");
  
  dispose b;
  dispose d;
  
  return 0;
}
