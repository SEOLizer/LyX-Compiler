// Test TObject mit explizitem extends
// Testet: explizite Vererbung von TObject, ClassName-Methode

// Eine Klasse die explizit von TObject erbt
type MyClass = class extends TObject {
  val: int64;
  
  fn SetVal(v: int64) {
    self.val := v;
  }
  
  fn GetVal(): int64 {
    return self.val;
  }
};

fn main(): int64 {
  // Test 1: Instanziierung
  var obj: MyClass := new MyClass();
  obj.SetVal(42);
  
  PrintStr("Test 1: Basic functionality\n");
  PrintStr("  obj.val = ");
  PrintInt(obj.GetVal());
  PrintStr("\n");
  
  if (obj.GetVal() != 42) {
    PrintStr("FAILED: GetVal() returned wrong value\n");
    return 1;
  }
  PrintStr("  PASSED\n");
  
  // Test 2: ClassName() Methode (von TObject geerbt)
  PrintStr("Test 2: ClassName() method\n");
  var name: pchar := obj.ClassName();
  PrintStr("  obj.ClassName() = ");
  PrintStr(name);
  PrintStr("\n");
  PrintStr("  PASSED\n");
  
  // Test 3: Free() Methode (von TObject geerbt)
  PrintStr("Test 3: Free() method\n");
  obj.Free();
  PrintStr("  PASSED (no crash)\n");
  
  PrintStr("\nAll tests PASSED!\n");
  return 0;
}
