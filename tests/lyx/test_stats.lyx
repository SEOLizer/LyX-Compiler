// Test Statistics & Aggregation Module
// Demonstrates array aggregate functions

import std.stats;

fn main(): int64 {
  PrintStr("Testing Statistics Module...\n");
  
  // Test 1: Array Sum
  PrintStr("Test 1: ArraySum\n");
  var arr: array := [10, 20, 30, 40, 50];
  var s: int64 := ArraySum(arr);
  PrintStr("  [10,20,30,40,50] sum = ");
  PrintInt(s);
  PrintStr(" (expected 150)\n");
  
  // Test 2: Array Min
  PrintStr("Test 2: ArrayMin\n");
  var mn: int64 := ArrayMin(arr);
  PrintStr("  [10,20,30,40,50] min = ");
  PrintInt(mn);
  PrintStr(" (expected 10)\n");
  
  // Test 3: Array Max
  PrintStr("Test 3: ArrayMax\n");
  var mx: int64 := ArrayMax(arr);
  PrintStr("  [10,20,30,40,50] max = ");
  PrintInt(mx);
  PrintStr(" (expected 50)\n");
  
  // Test 4: Array Avg
  PrintStr("Test 4: ArrayAvg\n");
  var avg: int64 := ArrayAvg(arr);
  PrintStr("  [10,20,30,40,50] avg = ");
  PrintInt(avg);
  PrintStr(" (expected 30)\n");
  
  // Test 5: Array Count
  PrintStr("Test 5: ArrayCount\n");
  var c: int64 := ArrayCount(arr);
  PrintStr("  [10,20,30,40,50] count = ");
  PrintInt(c);
  PrintStr(" (expected 5)\n");
  
  // Test 6: Array Product
  PrintStr("Test 6: ArrayProduct\n");
  var p: int64 := ArrayProduct(arr);
  PrintStr("  [10,20,30,40,50] product = ");
  PrintInt(p);
  PrintStr("\n");
  
  // Test 7: Array First/Last
  PrintStr("Test 7: ArrayFirst/ArrayLast\n");
  var f: int64 := ArrayFirst(arr, -1);
  var l: int64 := ArrayLast(arr, -1);
  PrintStr("  [10,20,30,40,50] first = ");
  PrintInt(f);
  PrintStr(", last = ");
  PrintInt(l);
  PrintStr("\n");
  
  // Test 8: Array IndexOf
  PrintStr("Test 8: ArrayIndexOf\n");
  var idx: int64 := ArrayIndexOf(arr, 30);
  PrintStr("  [10,20,30,40,50] indexOf(30) = ");
  PrintInt(idx);
  PrintStr(" (expected 2)\n");
  
  // Test 9: Array Contains
  PrintStr("Test 9: ArrayContains\n");
  PrintStr("  [10,20,30,40,50] contains(25) = ");
  if (ArrayContains(arr, 25)) {
    PrintStr("true")
  } else {
    PrintStr("false")
  }
  PrintStr(" (expected false)\n");
  
  PrintStr("  [10,20,30,40,50] contains(30) = ");
  if (ArrayContains(arr, 30)) {
    PrintStr("true")
  } else {
    PrintStr("false")
  }
  PrintStr(" (expected true)\n");
  
  // Test 10: Array CountValue
  PrintStr("Test 10: ArrayCountValue\n");
  var arr2: array := [1, 2, 2, 3, 2, 4];
  var count2: int64 := ArrayCountValue(arr2, 2);
  PrintStr("  [1,2,2,3,2,4] count(2) = ");
  PrintInt(count2);
  PrintStr(" (expected 3)\n");
  
  // Test 11: Array Sort
  PrintStr("Test 11: ArraySort\n");
  var unsorted: array := [50, 10, 40, 20, 30];
  var sorted: array := ArraySort(unsorted);
  PrintStr("  [50,10,40,20,30] sorted = [");
  var i: int64 := 0;
  var n: int64 := len(sorted);
  while (i < n) {
    if (i > 0) { PrintStr(","); }
    PrintInt(sorted[i]);
    i := i + 1;
  }
  PrintStr("]\n");
  free(sorted);
  
  // Test 12: Array Reverse
  PrintStr("Test 12: ArrayReverse\n");
  var reversed: array := ArrayReverse(arr);
  PrintStr("  [10,20,30,40,50] reversed = [");
  i := 0;
  n := len(reversed);
  while (i < n) {
    if (i > 0) { PrintStr(","); }
    PrintInt(reversed[i]);
    i := i + 1;
  }
  PrintStr("]\n");
  free(reversed);
  
  // Test 13: Array Range (statistical)
  PrintStr("Test 13: ArrayRange (statistical)\n");
  var range: int64 := ArrayRange(arr);
  PrintStr("  [10,20,30,40,50] range = ");
  PrintInt(range);
  PrintStr(" (expected 40)\n");
  
  // Test 14: Array Variance
  PrintStr("Test 14: ArrayVariance\n");
  var variance: int64 := ArrayVariance(arr);
  PrintStr("  [10,20,30,40,50] variance = ");
  PrintInt(variance);
  PrintStr("\n");
  
  // Test 15: Array StdDev
  PrintStr("Test 15: ArrayStdDev\n");
  var stddev: int64 := ArrayStdDev(arr);
  PrintStr("  [10,20,30,40,50] stddev = ");
  PrintInt(stddev);
  PrintStr("\n");
  
  // Test 16: Filter Gt/Lt
  PrintStr("Test 16: ArrayFilterGt/Lt\n");
  var filtered: array := ArrayFilterGt(arr, 25);
  PrintStr("  [10,20,30,40,50] filter(>25) = [");
  i := 0;
  n := len(filtered);
  while (i < n) {
    if (i > 0) { PrintStr(","); }
    PrintInt(filtered[i]);
    i := i + 1;
  }
  PrintStr("] (expected [30,40,50])\n");
  free(filtered);
  
  // Test 17: Utility functions
  PrintStr("Test 17: Utility Functions\n");
  PrintStr("  Clamp64(150, 0, 100) = ");
  PrintInt(Clamp64(150, 0, 100));
  PrintStr(" (expected 100)\n");
  
  PrintStr("  Percentage64(25, 100) = ");
  PrintInt(Percentage64(25, 100));
  PrintStr("% (expected 25%)\n");
  
  PrintStr("  AbsDiff64(10, 30) = ");
  PrintInt(AbsDiff64(10, 30));
  PrintStr(" (expected 20)\n");
  
  PrintStr("  InRange64(15, 10, 20) = ");
  if (InRange64(15, 10, 20)) {
    PrintStr("true")
  } else {
    PrintStr("false")
  }
  PrintStr(" (expected true)\n");
  
  // Cleanup
  free(arr);
  free(arr2);
  
  PrintStr("\nAll tests completed!\n");
  return 0;
}
