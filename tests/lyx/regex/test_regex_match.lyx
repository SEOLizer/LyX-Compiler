// test_regex_match.lyx
// Teste RegexMatch (std.regex)
import std.regex;

fn main(): int64 {
  // Einfacher Match
  var matched: bool := RegexMatch(r"hello", "hello world");
  if (matched) {
    PrintStr("OK: 'hello' matched in 'hello world'\n");
  } else {
    PrintStr("FAIL: 'hello' should match 'hello world'\n");
  }

  // Kein Match
  var no_match: bool := RegexMatch(r"xyz", "hello world");
  if (no_match) {
    PrintStr("FAIL: 'xyz' should not match 'hello world'\n");
  } else {
    PrintStr("OK: 'xyz' not matched in 'hello world'\n");
  }

  // Alternation + Captures
  var pos: int64 := RegexSearch(r"(ab|xy)(cd)", "zzabcdzz");
  if (pos != 2) {
    PrintStr("FAIL: expected match at 2\n");
  } else {
    PrintStr("OK: alternation matched\n");
  }
  var c1s: int64 := RegexCaptureStart(1);
  var c1e: int64 := RegexCaptureEnd(1);
  var c2s: int64 := RegexCaptureStart(2);
  var c2e: int64 := RegexCaptureEnd(2);
  if ((c1s != 2) || (c1e != 4) || (c2s != 4) || (c2e != 6)) {
    PrintStr("FAIL: capture positions wrong\n");
  } else {
    PrintStr("OK: captures valid\n");
  }

  // Ignore-Case Flag
  var ic: bool := RegexMatchEx(r"hello", "HeLLo", 1);
  if (ic) {
    PrintStr("OK: ignore-case matched\n");
  } else {
    PrintStr("FAIL: ignore-case should match\n");
  }

  return 0;
}
