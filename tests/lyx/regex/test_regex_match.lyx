// test_regex_match.lyx
// Teste RegexMatch Builtin
fn main(): int64 {
  // Einfacher Match
  var matched: bool := RegexMatch("hello", "hello world");
  if (matched) {
    PrintStr("OK: 'hello' matched in 'hello world'\n");
  } else {
    PrintStr("FAIL: 'hello' should match 'hello world'\n");
  }

  // Kein Match
  var no_match: bool := RegexMatch("xyz", "hello world");
  if (no_match) {
    PrintStr("FAIL: 'xyz' should not match 'hello world'\n");
  } else {
    PrintStr("OK: 'xyz' not matched in 'hello world'\n");
  }

  return 0;
}
