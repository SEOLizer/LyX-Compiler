// test_regex_replace.lyx
// Teste RegexReplace (std.regex)
import std.regex;

fn main(): int64 {
  // Ersetze Pattern
  var count: int64 := RegexReplace(r"world", "hello world", "Lyx");
  PrintStr("Ersetzungen fuer 'world' -> 'Lyx': ");
  PrintInt(count);
  PrintStr("\n");

  if (count > 0) {
    PrintStr("OK: Ersetzung durchgefuehrt\n");
  } else {
    PrintStr("FAIL: Keine Ersetzung durchgefuehrt\n");
  }

  // Kein Match -> 0 Ersetzungen
  var count2: int64 := RegexReplace(r"xyz", "hello world", "foo");
  PrintStr("Ersetzungen fuer 'xyz': ");
  PrintInt(count2);
  PrintStr("\n");

  if (count2 == 0) {
    PrintStr("OK: Keine Ersetzung wie erwartet\n");
  } else {
    PrintStr("FAIL: Unerwartet Ersetzungen durchgefuehrt\n");
  }

  var outBuf: array[64]char;
  var count3: int64 := RegexReplaceInto(outBuf, r"world", "hello world", "Lyx");
  PrintStr("ReplaceInto: ");
  PrintStr(outBuf);
  PrintStr(" (count=");
  PrintInt(count3);
  PrintStr(")\n");

  return 0;
}
