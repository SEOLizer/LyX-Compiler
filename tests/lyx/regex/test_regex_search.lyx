// test_regex_search.lyx
// Teste RegexSearch Builtin
fn main(): int64 {
  // Suche Position
  var pos: int64 := RegexSearch("world", "hello world");
  PrintStr("Position von 'world' in 'hello world': ");
  PrintInt(pos);
  PrintStr("\n");

  if (pos >= 0) {
    PrintStr("OK: Pattern gefunden\n");
  } else {
    PrintStr("FAIL: Pattern nicht gefunden\n");
  }

  // Nicht gefunden -> -1
  var pos2: int64 := RegexSearch("xyz", "hello world");
  PrintStr("Position von 'xyz' in 'hello world': ");
  PrintInt(pos2);
  PrintStr("\n");

  if (pos2 == -1) {
    PrintStr("OK: Pattern korrekt nicht gefunden\n");
  } else {
    PrintStr("FAIL: Pattern sollte nicht gefunden werden\n");
  }

  return 0;
}
