fn max[T](a: T, b: T): T {
    if (a > b) {
        return a;
    }
    return b;
}

fn min[T](a: T, b: T): T {
    if (a < b) {
        return a;
    }
    return b;
}

fn main(): int64 {
    var x: int64 := max[int64](10, 20);
    PrintStr("max(10, 20) = "); PrintInt(x); PrintStr("\n");

    var y: int64 := max[int64](42, 7);
    PrintStr("max(42, 7) = "); PrintInt(y); PrintStr("\n");

    var a: int64 := min[int64](3, 9);
    PrintStr("min(3, 9) = "); PrintInt(a); PrintStr("\n");

    var b: int64 := min[int64](100, 1);
    PrintStr("min(100, 1) = "); PrintInt(b); PrintStr("\n");

    return 0;
}
