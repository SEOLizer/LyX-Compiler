// test_path.lyx - Test für Path-Funktionen

import std.fs;
import std.io;

fn main(): int64 {
  var buf1: pchar := "                                                                                ";
  var buf2: pchar := "                                                                                ";
  var buf3: pchar := "                                                                                ";
  
  Printf("Testing Path Functions\n");
  Printf("======================\n\n");
  
  // Test 1: PathNormalize
  Printf("Test 1: PathNormalize\n");
  
  PathNormalize(buf1, "/home/user/./foo/../bar//baz");
  Printf("  /home/user/./foo/../bar//baz -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  PathNormalize(buf1, "foo//bar/./baz");
  Printf("  foo//bar/./baz -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  PathNormalize(buf1, "/../etc");
  Printf("  /../etc -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  PathNormalize(buf1, ".");
  Printf("  . -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  PathNormalize(buf1, "..");
  Printf("  .. -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  PathNormalize(buf1, "/foo/bar/");
  Printf("  /foo/bar/ -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  Printf("\n");
  
  // Test 2: PathDir
  Printf("Test 2: PathDir\n");
  
  PathDir(buf1, "/home/user/doc.lyx");
  Printf("  /home/user/doc.lyx -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  PathDir(buf1, "/tmp/data.csv");
  Printf("  /tmp/data.csv -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  PathDir(buf1, "file.txt");
  Printf("  file.txt -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  PathDir(buf1, "/onlyslash/");
  Printf("  /onlyslash/ -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  Printf("\n");
  
  // Test 3: PathExt
  Printf("Test 3: PathExt\n");
  
  PathExt(buf1, "archive.tar.gz");
  Printf("  archive.tar.gz -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  PathExt(buf1, "/tmp/data.csv");
  Printf("  /tmp/data.csv -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  PathExt(buf1, "noextension");
  Printf("  noextension -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  PathExt(buf1, ".hidden");
  Printf("  .hidden -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  Printf("\n");
  
  // Test 4: PathBase
  Printf("Test 4: PathBase\n");
  
  PathBase(buf1, "/tmp/data.csv");
  Printf("  /tmp/data.csv -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  PathBase(buf1, "archive.tar.gz");
  Printf("  archive.tar.gz -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  PathBase(buf1, "/tmp/dir/");
  Printf("  /tmp/dir/ -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  Printf("\n");
  
  // Test 5: PathResolve
  Printf("Test 5: PathResolve\n");
  
  PathResolve(buf1, "/home/user/", "../other/file.txt");
  Printf("  /home/user/ + ../other/file.txt -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  PathResolve(buf1, "/home/user/dir", "sub/file.txt");
  Printf("  /home/user/dir + sub/file.txt -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  PathResolve(buf1, "/home/user", "other");
  Printf("  /home/user + other -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  // Absoluter Pfad sollte überschreiben
  PathResolve(buf1, "/home/user", "/etc/config");
  Printf("  /home/user + /etc/config -> ");
  PrintStr(buf1);
  PrintStr("\n");
  
  Printf("\n======================\n");
  Printf("Path function tests complete!\n");
  
  return 0;
}
