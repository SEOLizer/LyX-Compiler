// test_class_embedding.lyx
// Tests: class in struct, class in static array, class in class

unit test_class_embedding;

// ============================================================================
// class in class
// ============================================================================

type Node = class {
  value: int64;
  next: Node;      // class in class (self-referential)
};

// ============================================================================
// class in struct
// ============================================================================

type Container = struct {
  id: int64;
  node: Node;     // class in struct (stored as 8-byte pointer)
};

// ============================================================================
// class in static array (as struct field)
// ============================================================================

type Pool = struct {
  count: int64;
  items: [4]Node; // class in static array (4 pointers = 32 bytes)
};

fn main(): int64 {
  // Test class in class layout
  var n: Node := new Node;
  n.value := 42;

  // Test class in struct
  var c: Container := Container {};
  c.id := 1;
  c.node := n;

  // Test pool (struct with static array of class pointers)
  var p: Pool := Pool {};
  p.count := 0;
  p.items[0] := n;
  p.count := 1;

  // Verify values
  var cn: Node := c.node;
  if (cn.value != 42) {
    return 1;
  }
  var pn: Node := p.items[0];
  if (pn.value != 42) {
    return 2;
  }
  if (p.count != 1) {
    return 3;
  }

  return 0;
}
