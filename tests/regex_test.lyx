// Testprogramm für Regex-Funktionen

fn main(): int64 {
  // Test RegexMatch
  var result: int64 := 0;
  
  // Test 1: Pattern "abc" in "abcdef" -> sollte 1 (found) sein
  if (RegexMatch("abc", "abcdef")) {
    result := 1;
  } else {
    result := 0;
  }
  PrintStr("RegexMatch('abc', 'abcdef') = ");
  PrintInt(result);
  PrintStr("\n");
  
  // Test 2: Pattern "xyz" in "abcdef" -> sollte 0 (not found) sein  
  if (RegexMatch("xyz", "abcdef")) {
    result := 1;
  } else {
    result := 0;
  }
  PrintStr("RegexMatch('xyz', 'abcdef') = ");
  PrintInt(result);
  PrintStr("\n");
  
  // Test 3: RegexSearch
  result := RegexSearch("abc", "abcdef");
  PrintStr("RegexSearch('abc', 'abcdef') = ");
  PrintInt(result);
  PrintStr("\n");
  
  // Test 4: RegexSearch nicht gefunden
  result := RegexSearch("xyz", "abcdef");
  PrintStr("RegexSearch('xyz', 'abcdef') = ");
  PrintInt(result);
  PrintStr("\n");
  
  // Test 5: RegexReplace (placeholder - returns 0)
  result := RegexReplace("abc", "abcdef", "XYZ");
  PrintStr("RegexReplace('abc', 'abcdef', 'XYZ') = ");
  PrintInt(result);
  PrintStr("\n");
  
  return 0;
}
