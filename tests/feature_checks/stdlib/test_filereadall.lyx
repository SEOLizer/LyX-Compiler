// tests/feature_checks/stdlib/test_filereadall.lyx
// Tests for WP-03: FileReadAll, ArgvGet, ArgvGetStr
//
// Usage: ./test_filereadall <path-to-read> [--check=value]
// Liest die angegebene Datei und gibt Größe und Zeilenanzahl aus.
// Selbsttest: ./test_filereadall tests/feature_checks/stdlib/test_filereadall.lyx

import std.fs;
import std.env;

fn main(): int64 {
  var argc: int64 := GetArgC();
  if (argc < 2) {
    PrintStr("usage: test_filereadall <path> [--check=value]\n");
    return 1;
  }

  // === ArgvGet: Lese Dateipfad aus argv[1] ===
  var argv: pchar := GetArgV();
  var path: pchar := ArgvGet(argv, 1);
  PrintStr("reading: ");
  PrintStr(path);
  PrintStr("\n");

  // === FileReadAll: lese gesamten Inhalt ===
  var content: pchar := FileReadAll(path);
  if (content == 0 as pchar) {
    PrintStr("error: could not read file\n");
    return 1;
  }

  var len: int64 := StrLen(content);

  // === Zeilenanzahl berechnen ===
  var lines: int64 := 0;
  var i: int64 := 0;
  while (i < len) {
    if (StrCharAt(content, i) == 10) {  // '\n'
      lines := lines + 1;
    }
    i := i + 1;
  }
  // Falls letzte Zeile kein Newline hat, trotzdem mitzählen
  if (len > 0 && StrCharAt(content, len - 1) != 10) {
    lines := lines + 1;
  }

  PrintStr("size:  ");
  PrintInt(len);
  PrintStr("\n");
  PrintStr("lines: ");
  PrintInt(lines);
  PrintStr("\n");

  // === ArgvGetStr: teste --flag=value Parsing ===
  var flagVal: pchar := ArgvGetStr(argc, argv, "check");
  if (flagVal != 0 as pchar) {
    PrintStr("--check=");
    PrintStr(flagVal);
    PrintStr("\n");
    StrFree(flagVal);
  }

  return 0;
}
