// Test: enum types — basic auto-numbering and explicit values

enum Color {
  RED;      // 0
  GREEN;    // 1
  BLUE;     // 2
};

enum HttpStatus {
  OK           := 200;
  NOT_FOUND    := 404;
  SERVER_ERROR := 500;
};

enum Direction {
  NORTH;        // 0
  SOUTH;        // 1
  EAST  := 10;  // 10
  WEST;         // 11 (continues from last explicit)
};

fn main(): int64 {
  PrintStr("RED    = "); PrintInt(RED);          PrintStr("\n");
  PrintStr("GREEN  = "); PrintInt(GREEN);        PrintStr("\n");
  PrintStr("BLUE   = "); PrintInt(BLUE);         PrintStr("\n");

  PrintStr("OK           = "); PrintInt(OK);           PrintStr("\n");
  PrintStr("NOT_FOUND    = "); PrintInt(NOT_FOUND);    PrintStr("\n");
  PrintStr("SERVER_ERROR = "); PrintInt(SERVER_ERROR); PrintStr("\n");

  PrintStr("NORTH = "); PrintInt(NORTH); PrintStr("\n");
  PrintStr("SOUTH = "); PrintInt(SOUTH); PrintStr("\n");
  PrintStr("EAST  = "); PrintInt(EAST);  PrintStr("\n");
  PrintStr("WEST  = "); PrintInt(WEST);  PrintStr("\n");

  // Enum value in expression
  var status: int64 := OK;
  if (status == 200) {
    PrintStr("status is OK\n");
  }

  // Enum value in arithmetic
  var sum: int64 := RED + GREEN + BLUE;
  PrintStr("RED+GREEN+BLUE = "); PrintInt(sum); PrintStr("\n");

  return 0;
}
