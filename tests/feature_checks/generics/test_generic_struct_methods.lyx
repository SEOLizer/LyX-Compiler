// Test: methods on monomorphized generic structs
type Pair[T] = struct {
    first:  T;
    second: T;

    fn getFirst(): T { return self.first; }
    fn getSecond(): T { return self.second; }
    fn sum(): T { return self.first + self.second; }
}

fn main(): int64 {
    var p: Pair__int64;
    p.first  := 10;
    p.second := 32;
    var a: int64 := p.getFirst();
    var b: int64 := p.getSecond();
    var c: int64 := p.sum();
    PrintStr("first=");  PrintInt(a); PrintStr("\n");
    PrintStr("second="); PrintInt(b); PrintStr("\n");
    PrintStr("sum=");    PrintInt(c); PrintStr("\n");
    return 0;
}
