// tests/feature_checks/strings/test_stringbuilder.lyx
// Tests for WP-02: StringBuilder, StrTrim, StrSplit

import std.string;

fn main(): int64 {
  // === StringBuilder: Append / AppendChar / AppendInt / ToString ===
  var sb: StringBuilder := new StringBuilder();
  sb.Init(16);
  sb.Append("Hello");
  sb.Append(", ");
  sb.Append("World");
  sb.AppendChar(33);   // '!'
  sb.AppendInt(42);

  var result: pchar := sb.ToString();
  PrintStr(result);    // Hello, World!42
  PrintStr("\n");
  StrFree(result);

  // === StringBuilder: Clear ===
  sb.Clear();
  sb.Append("After clear");
  var r2: pchar := sb.ToString();
  PrintStr(r2);        // After clear
  PrintStr("\n");
  StrFree(r2);

  sb.FreeBuffer();
  dispose sb;

  // === StrTrim ===
  var t1: pchar := StrTrim("  hello  ");
  PrintStr(t1);        // hello
  PrintStr("\n");
  StrFree(t1);

  var t2: pchar := StrTrim("no spaces");
  PrintStr(t2);        // no spaces
  PrintStr("\n");
  StrFree(t2);

  var t3: pchar := StrTrim("   ");
  var t3len: int64 := StrLen(t3);
  PrintInt(t3len);     // 0
  PrintStr("\n");
  StrFree(t3);

  // === StrSplit ===
  var parts: int64 := mmap(0, 80, 3, 34, -1, 0);
  var s: pchar := "a,b,c";
  var n: int64 := StrSplit(s, ",", parts, 10);
  PrintInt(n);         // 3
  PrintStr("\n");

  var p0: pchar := peek64(parts) as pchar;
  var p1: pchar := peek64(parts + 8) as pchar;
  var p2: pchar := peek64(parts + 16) as pchar;
  PrintStr(p0);        // a
  PrintStr("\n");
  PrintStr(p1);        // b
  PrintStr("\n");
  PrintStr(p2);        // c
  PrintStr("\n");
  StrFree(p0);
  StrFree(p1);
  StrFree(p2);

  // StrSplit with maxParts limit
  var parts2: int64 := mmap(0, 80, 3, 34, -1, 0);
  var n2: int64 := StrSplit(s, ",", parts2, 2);
  PrintInt(n2);        // 2
  PrintStr("\n");
  var q0: pchar := peek64(parts2) as pchar;
  var q1: pchar := peek64(parts2 + 8) as pchar;
  PrintStr(q0);        // a
  PrintStr("\n");
  PrintStr(q1);        // b,c
  PrintStr("\n");
  StrFree(q0);
  StrFree(q1);

  return 0;
}
