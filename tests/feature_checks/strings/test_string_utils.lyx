// tests/feature_checks/strings/test_string_utils.lyx
// Tests for S1-S7 string utility builtins

fn main(): int64 {
  // === S1: StrFindChar / StrSub ===
  // Build "hello world" using StrSetChar
  var s: pchar := StrNew(16);
  StrSetChar(s, 0, 104);  // 'h'
  StrSetChar(s, 1, 101);  // 'e'
  StrSetChar(s, 2, 108);  // 'l'
  StrSetChar(s, 3, 108);  // 'l'
  StrSetChar(s, 4, 111);  // 'o'
  StrSetChar(s, 5, 32);   // ' '
  StrSetChar(s, 6, 119);  // 'w'
  StrSetChar(s, 7, 111);  // 'o'
  StrSetChar(s, 8, 114);  // 'r'
  StrSetChar(s, 9, 108);  // 'l'
  StrSetChar(s, 10, 100); // 'd'
  StrSetChar(s, 11, 0);   // null

  // StrFindChar: find space at index 5
  var idx: int64 := StrFindChar(s, 32, 0);
  PrintInt(idx);       // 5
  PrintStr("\n");

  // StrSub: extract "hello"
  var hello: pchar := StrSub(s, 0, 5);
  PrintStr(hello);     // hello
  PrintStr("\n");
  StrFree(hello);

  // StrSub: extract "world"
  var world: pchar := StrSub(s, 6, 5);
  PrintStr(world);     // world
  PrintStr("\n");
  StrFree(world);

  // === S2: StrConcat / StrAppendStr / StrCopy ===
  var a: pchar := StrNew(8);
  var a2: pchar := StrAppend(a, "Hi");

  var ab: pchar := StrConcat(a2, "!");
  PrintStr(ab);        // Hi!
  PrintStr("\n");
  StrFree(ab);

  var a3: pchar := StrAppendStr(a2, "!");
  PrintStr(a3);        // Hi!
  PrintStr("\n");
  // Note: a3 == a2 == a (in-place append), do not free here

  var ac: pchar := StrCopy(a3);
  PrintStr(ac);        // Hi!
  PrintStr("\n");
  StrFree(ac);

  // === S3: IntToStr ===
  var ns: pchar := IntToStr(42);
  PrintStr(ns);        // 42
  PrintStr("\n");
  StrFree(ns);

  // === S4: FileGetSize ===
  var sz: int64 := FileGetSize("/etc/hostname");
  var fok: bool := (sz > 0);
  if (fok) {
    PrintStr("filesize ok\n");
  }

  // === S5: HashMap ===
  var m: pchar := HashNew(16);
  var k1: pchar := StrNew(4);
  var k1b: pchar := StrAppend(k1, "A");
  HashSet(m, k1b, 100);
  var v: int64 := HashGet(m, k1b);
  PrintInt(v);         // 100
  PrintStr("\n");
  var has: bool := HashHas(m, k1b);
  if (has) {
    PrintStr("hashhas ok\n");
  }

  // === S6: GetArgC / GetArg ===
  var argc: int64 := GetArgC();
  PrintInt(argc);      // at least 1
  PrintStr("\n");
  var prog: pchar := GetArg(0);
  var proglen: int64 := StrLen(prog);
  var progok: bool := (proglen > 0);
  if (progok) {
    PrintStr("argv0 ok\n");
  }

  // === S7: StrStartsWith / StrEndsWith / StrEquals ===
  var sw1: bool := StrStartsWith(s, "hello");
  if (sw1) { PrintStr("startswith ok\n"); }

  var ew1: bool := StrEndsWith(s, "world");
  if (ew1) { PrintStr("endswith ok\n"); }

  var eq1: bool := StrEquals(a3, "Hi!");
  if (eq1) { PrintStr("equals ok\n"); }

  // Cleanup:
  // - s was allocated by StrNew(16), not reallocated, so free s directly
  // - a was freed by StrAppend(a,"Hi") (always-reallocate); free a2 (=a3) instead
  // - k1 was freed by StrAppend(k1,"A") (always-reallocate); free k1b instead
  // - m (hashmap) is not freed here (memory leak, acceptable for test)
  StrFree(s);
  StrFree(a2);
  StrFree(k1b);

  return 0;
}
