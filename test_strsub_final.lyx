// Test StrSub in bootstrap compiler
fn main(): int64 {
  var buf: int64 := mmap(0, 64, 3, 34, -1, 0);
  poke8(buf + 0, 65);
  poke8(buf + 1, 66);
  poke8(buf + 2, 67);
  poke8(buf + 3, 0);
  
  // This should work if StrSub helper is correctly generated
  var sub: int64 := StrSub(buf, 0, 3);
  
  var i: int64 := 0;
  while i < 3 {
    PrintInt(peek8(sub + i));
    PrintStr(" ");
    i := i + 1;
  }
  PrintStr("\n");
  
  munmap(buf, 64);
  return 0;
}