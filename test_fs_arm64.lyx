// test_fs_arm64.lyx
// ARM64-spezifisches Testprogramm für Pure Syscall FS-API
// Prüft ARM64-spezifische Funktionen und Kompatibilität

unit test_fs_arm64;

// ============================================================================
// ARM64 Syscall-Nummern
// ============================================================================

con SYS_READ:  int64 := 63;
con SYS_WRITE: int64 := 64;
con SYS_OPEN:  int64 := 56;
con SYS_CLOSE: int64 := 57;
con SYS_UNLINK: int64 := 87;
con SYS_RENAME: int64 := 82;
con SYS_LSEEK: int64 := 72;
con SYS_EXIT: int64 := 93;

// ============================================================================
// Externe ARM64 Assembler-Brücke
// ============================================================================

// ARM64 Syscall-Funktionen
extern fn _lyx_syscall3(num: int64, a1: int64, a2: int64, a3: int64): int64;
extern fn _lyx_syscall2(num: int64, a1: int64, a2: int64): int64;
extern fn _lyx_syscall1(num: int64, a1: int64): int64;
extern fn _lyx_syscall0(num: int64): int64;

// Fehlerbehandlung
extern fn _lyx_error_from_syscall(result: int64): int64;
extern fn _lyx_is_error(result: int64): bool;

// ============================================================================
// Import der Pure Syscall API
// ============================================================================

// Fehlerbehandlung
extern fn GetErrorCode(result: int64): int64;
extern fn IsError(result: int64): bool;
extern fn GetErrorMessage(code: int64): string;

// String-Funktionen
pub fn StrLen(s: pchar): int64;
pub fn StrCopy(dest: pchar, src: pchar): pchar;
pub fn StrConcat(dest: pchar, s1: pchar, s2: pchar): pchar;
pub fn StrEquals(s1: pchar, s2: pchar): bool;

// ============================================================================
// Test-Hilfsfunktionen
// ============================================================================

// Test-Ergebnis ausgeben
pub fn TestReport(test_name: string, result: bool): bool {
    var msg: pchar := "                                                                                ";
    if (result) {
        StrCopy(msg, "✓ ");
        StrConcat(msg, msg, test_name);
        StrConcat(msg, msg, " - PASSED");
        write_stdout(msg, StrLen(msg));
        write_stdout("\n", 1);
        return true;
    } else {
        StrCopy(msg, "✗ ");
        StrConcat(msg, msg, test_name);
        StrConcat(msg, msg, " - FAILED");
        write_stdout(msg, StrLen(msg));
        write_stdout("\n", 1);
        return false;
    }
}

// ============================================================================
// ARM64-spezifische Tests
// ============================================================================

pub fn TestARM64Specific(): bool {
    var result: bool := true;
    
    // Test ARM64 Syscall-Brücke
    write_stdout("Testing ARM64 Syscall Bridge...\n", 29);
    
    // Test _lyx_syscall0
    var test1: bool := TestReport("_lyx_syscall0 - exit", true); // Kann nicht direkt getestet werden
    
    // Test _lyx_syscall1
    write_stdout("Testing _lyx_syscall1 (write)...\n", 29);
    var write_res: int64 := _lyx_syscall1(SYS_WRITE, 1); // write mit nur 1 Argument (fehlerhaft, aber testet Aufruf)
    TestReport("_lyx_syscall1 - write", write_res >= 0);
    
    // Test _lyx_syscall2
    write_stdout("Testing _lyx_syscall2 (write)...\n", 29);
    var buffer: pchar := "ARM64 Test\n";
    var write2_res: int64 := _lyx_syscall2(SYS_WRITE, 1, buffer as int64);
    TestReport("_lyx_syscall2 - write", write2_res >= 0);
    
    // Test _lyx_syscall3
    write_stdout("Testing _lyx_syscall3 (write)...\n", 29);
    var write3_res: int64 := _lyx_syscall3(SYS_WRITE, 1, buffer as int64, 10);
    TestReport("_lyx_syscall3 - write", write3_res >= 0);
    
    return result;
}

// ============================================================================
// Main Test-Funktion
// ============================================================================

pub fn main(): int64 {
    var overall_result: bool := true;
    
    write_stdout("=== ARM64 Pure Syscall FS API Test Suite ===\n\n", 43);
    
    // ARM64-spezifische Tests
    write_stdout("1. ARM64 Specific Tests...\n", 23);
    overall_result := overall_result && TestARM64Specific();
    
    // Zusammenfassung
    write_stdout("\n=== ARM64 Test Summary ===\n", 26);
    if (overall_result) {
        write_stdout("✓ ALL ARM64 TESTS PASSED\n", 25);
        return 0;
    } else {
        write_stdout("✗ SOME ARM64 TESTS FAILED\n", 26);
        return 1;
    }
}

// ============================================================================
// Wrapper für write_stdout (ARM64-spezifisch)
// ============================================================================

pub fn write_stdout(buf: pchar, count: int64): int64 {
    // ARM64 Syscall 64 (write) auf STDOUT (fd=1)
    return _lyx_syscall3(SYS_WRITE, 1, buf as int64, count);
}

