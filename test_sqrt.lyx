// Test sqrt and EuclideanDistance
import std.io;
import std.ml;

pub fn main(): int64 {
  // Test sqrt directly
  PrintStr("sqrt(16.0) = ");
  PrintFloat(sqrt(16.0));
  PrintStr("\n");
  
  // Test EuclideanDistance
  var dist: f64 := EuclideanDistance(0.0, 0.0, 3.0, 4.0);
  PrintStr("EuclideanDistance(0,0 to 3,4) = ");
  PrintFloat(dist);
  PrintStr("\n");
  
  return 0;
}