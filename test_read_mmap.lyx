fn main(): int64 {
  // Test with prot=1 (READ only)
  var buf: int64 := mmap(0, 4096, 1, 34, -1, 0);
  
  PrintStr("buf: ");
  PrintInt(buf);
  PrintStr("\n");
  
  var n: int64 := read(0, buf, 10);
  PrintStr("read: ");
  PrintInt(n);
  PrintStr("\n");
  
  if n > 0 {
    var i: int64 := 0;
    while i < n {
      PrintInt(peek8(buf + i));
      PrintStr(" ");
      i := i + 1;
    }
    PrintStr("\n");
  }
  
  munmap(buf, 4096);
  return 0;
}