// Test: k-Nearest Neighbors (k-NN)
// Demonstrates classification without training

import std.io;
import std.ml;

// Memory functions
extern fn mmap(addr: int64, len: int64, prot: int64, flags: int64, fd: int64, offset: int64): int64;
extern fn munmap(addr: int64, len: int64): int64;

con PROT_RW: int64 := 3;
con MAP_ANON: int64 := 32;
con FD_NONE: int64 := -1;

pub fn main(): int64 {
  PrintStr("=== Test: k-Nearest Neighbors ===\n\n");
  
  // Create training data: 2D points with labels
  // Class 0: clustered around (2,2)
  // Class 1: clustered around (8,8)
  var n: int64 := 20;
  var nFeatures: int64 := 2;
  
  // Feature matrix: 20 samples x 2 features
  var features: int64 := mmap(0, n * nFeatures * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  var labels: int64 := mmap(0, n * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  
  // Fill with data
  // Class 0: points near (2,2)
  pokef64(features + 0 * 8, 1.5); pokef64(features + 1 * 8, 1.8);
  poke8(labels + 0 * 8, 0);
  pokef64(features + 2 * 8, 2.1); pokef64(features + 3 * 8, 2.3);
  poke8(labels + 2 * 8, 0);
  pokef64(features + 4 * 8, 1.8); pokef64(features + 5 * 8, 2.5);
  poke8(labels + 4 * 8, 0);
  pokef64(features + 6 * 8, 2.5); pokef64(features + 7 * 8, 1.9);
  poke8(labels + 6 * 8, 0);
  pokef64(features + 8 * 8, 2.2); pokef64(features + 9 * 8, 2.1);
  poke8(labels + 8 * 8, 0);
  pokef64(features + 10 * 8, 1.7); pokef64(features + 11 * 8, 2.2);
  poke8(labels + 10 * 8, 0);
  pokef64(features + 12 * 8, 2.3); pokef64(features + 13 * 8, 1.8);
  poke8(labels + 12 * 8, 0);
  pokef64(features + 14 * 8, 2.0); pokef64(features + 15 * 8, 2.0);
  poke8(labels + 14 * 8, 0);
  pokef64(features + 16 * 8, 1.9); pokef64(features + 17 * 8, 2.4);
  poke8(labels + 16 * 8, 0);
  pokef64(features + 18 * 8, 2.4); pokef64(features + 19 * 8, 2.2);
  poke8(labels + 18 * 8, 0);
  
  // Class 1: points near (8,8)
  pokef64(features + 20 * 8, 7.8); pokef64(features + 21 * 8, 8.2);
  poke8(labels + 20 * 8, 1);
  pokef64(features + 22 * 8, 8.1); pokef64(features + 23 * 8, 7.9);
  poke8(labels + 22 * 8, 1);
  pokef64(features + 24 * 8, 7.9); pokef64(features + 25 * 8, 8.5);
  poke8(labels + 24 * 8, 1);
  pokef64(features + 26 * 8, 8.5); pokef64(features + 27 * 8, 7.8);
  poke8(labels + 26 * 8, 1);
  pokef64(features + 28 * 8, 8.2); pokef64(features + 29 * 8, 8.1);
  poke8(labels + 28 * 8, 1);
  pokef64(features + 30 * 8, 7.7); pokef64(features + 31 * 8, 8.3);
  poke8(labels + 30 * 8, 1);
  pokef64(features + 32 * 8, 8.3); pokef64(features + 33 * 8, 7.7);
  poke8(labels + 32 * 8, 1);
  pokef64(features + 34 * 8, 8.0); pokef64(features + 35 * 8, 8.0);
  poke8(labels + 34 * 8, 1);
  pokef64(features + 36 * 8, 7.9); pokef64(features + 37 * 8, 8.4);
  poke8(labels + 36 * 8, 1);
  pokef64(features + 38 * 8, 8.4); pokef64(features + 39 * 8, 8.2);
  poke8(labels + 38 * 8, 1);
  
  PrintStr("Training samples: 20\n");
  PrintStr("Features: 2 (2D points)\n");
  PrintStr("Classes: 2 (0 and 1)\n\n");
  
  // Initialize k-NN with k=3
  KNNInit(3);
  KNNFit(features, labels, n, nFeatures);
  
  PrintStr("k = 3\n");
  
  // Test predictions
  // Test point near class 0 center
  var test1: int64 := mmap(0, 2 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  pokef64(test1 + 0 * 8, 2.5);
  pokef64(test1 + 1 * 8, 2.0);
  
  var pred1: int64 := KNNPredict(test1);
  PrintStr("Predict(2.5, 2.0): ");
  if (pred1 == 0) { PrintStr("class 0"); }
  else { PrintStr("class 1"); }
  PrintStr(" (expected: 0)\n");
  
  // Test point near class 1 center
  var test2: int64 := mmap(0, 2 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  pokef64(test2 + 0 * 8, 8.0);
  pokef64(test2 + 1 * 8, 8.0);
  
  var pred2: int64 := KNNPredict(test2);
  PrintStr("Predict(8.0, 8.0): ");
  if (pred2 == 0) { PrintStr("class 0"); }
  else { PrintStr("class 1"); }
  PrintStr(" (expected: 1)\n");
  
  // Test point in between
  var test3: int64 := mmap(0, 2 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  pokef64(test3 + 0 * 8, 5.0);
  pokef64(test3 + 1 * 8, 5.0);
  
  var pred3: int64 := KNNPredict(test3);
  PrintStr("Predict(5.0, 5.0): ");
  if (pred3 == 0) { PrintStr("class 0"); }
  else { PrintStr("class 1"); }
  PrintStr(" (boundary)\n\n");
  
  // Score on training data
  var score: f64 := KNNScore(features, labels, n);
  PrintStr("Training accuracy: ");
  PrintFloat(score * 100.0);
  PrintStr("%\n");
  
  // Test k=1 vs k=5
  PrintStr("\n--- Different k values ---\n");
  
  KNNInit(1);
  KNNFit(features, labels, n, nFeatures);
  var score1: f64 := KNNScore(features, labels, n);
  PrintStr("k=1 accuracy: ");
  PrintFloat(score1 * 100.0);
  PrintStr("%\n");
  
  KNNInit(5);
  KNNFit(features, labels, n, nFeatures);
  var score5: f64 := KNNScore(features, labels, n);
  PrintStr("k=5 accuracy: ");
  PrintFloat(score5 * 100.0);
  PrintStr("%\n");
  
  // Test cross-validation
  PrintStr("\n--- Cross-Validation ---\n");
  var cvScore: f64 := KNNCrossValidation(features, labels, n, nFeatures, 3, 5);
  PrintStr("5-fold CV accuracy (k=3): ");
  PrintFloat(cvScore * 100.0);
  PrintStr("%\n\n");
  
  // Test probabilities
  var proba: int64 := KNNPredictProba(test1, 2);
  if (proba != 0) {
    PrintStr("Probs for (2.5, 2.0): ");
    var p0: f64 := peekf64(proba + 0 * 8);
    var p1: f64 := peekf64(proba + 1 * 8);
    PrintFloat(p0 * 100.0);
    PrintStr("% class 0, ");
    PrintFloat(p1 * 100.0);
    PrintStr("% class 1\n");
    munmap(proba, 2 * 8);
  }
  
  // Clean up
  munmap(test1, 2 * 8);
  munmap(test2, 2 * 8);
  munmap(test3, 2 * 8);
  munmap(features, n * nFeatures * 8);
  munmap(labels, n * 8);
  
  PrintStr("\n=== k-NN Test Complete ===\n");
  return 0;
}