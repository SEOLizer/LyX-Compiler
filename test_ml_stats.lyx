// Test ML Statistics
import std.io;
import std.ml;

pub fn main(): int64 {
  // Test statistics
  PrintStr("Mean2(4, 6) = ");
  PrintFloat(Mean2(4.0, 6.0));
  PrintStr("\n");
  
  PrintStr("Variance2(4, 6) = ");
  PrintFloat(Variance2(4.0, 6.0));
  PrintStr("\n");
  
  PrintStr("StdDev2(4, 6) = ");
  PrintFloat(StdDev2(4.0, 6.0));
  PrintStr("\n");
  
  // Test loss metrics
  PrintStr("\nMSE2(true=[3,5], pred=[3.1,4.9]) = ");
  PrintFloat(MSE2(3.0, 5.0, 3.1, 4.9));
  PrintStr("\n");
  
  PrintStr("MAE2(true=[3,5], pred=[3.1,4.9]) = ");
  PrintFloat(MAE2(3.0, 5.0, 3.1, 4.9));
  PrintStr("\n");
  
  PrintStr("R2Score2(true=[3,5], pred=[3,5]) = ");
  PrintFloat(R2Score2(3.0, 5.0, 3.0, 5.0));
  PrintStr("\n");
  
  return 0;
}