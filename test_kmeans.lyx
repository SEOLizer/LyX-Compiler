// Test: k-Means Clustering
// Demonstrates unsupervised learning with convergence

import std.io;
import std.ml;

extern fn mmap(addr: int64, len: int64, prot: int64, flags: int64, fd: int64, offset: int64): int64;
extern fn munmap(addr: int64, len: int64): int64;

con PROT_RW: int64 := 3;
con MAP_ANON: int64 := 32;
con FD_NONE: int64 := -1;

pub fn main(): int64 {
  PrintStr("=== Test: k-Means Clustering ===\n\n");
  
  // Create 3D test data with 3 clusters
  var n: int64 := 30;
  var nFeatures: int64 := 2;  // 2D points
  var k: int64 := 3;
  
  var features: int64 := mmap(0, n * nFeatures * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  
  // Cluster 0: centered at (2, 2)
  var i: int64 := 0;
  while (i < 10) {
    pokef64(features + i * 16 + 0, 2.0 + (i as f64 * 0.1) - 0.5);
    pokef64(features + i * 16 + 8, 2.0 + (i as f64 * 0.15) - 0.5);
    i := i + 1;
  }
  
  // Cluster 1: centered at (8, 2)
  i := 10;
  while (i < 20) {
    pokef64(features + i * 16 + 0, 8.0 + ((i - 10) as f64 * 0.12) - 0.5);
    pokef64(features + i * 16 + 8, 2.0 + ((i - 10) as f64 * 0.08) - 0.3);
    i := i + 1;
  }
  
  // Cluster 2: centered at (5, 7)
  i := 20;
  while (i < 30) {
    pokef64(features + i * 16 + 0, 5.0 + ((i - 20) as f64 * 0.1) - 0.4);
    pokef64(features + i * 16 + 8, 7.0 + ((i - 20) as f64 * 0.11) - 0.5);
    i := i + 1;
  }
  
  PrintStr("Data: 30 points, 2 features\n");
  PrintStr("Clusters: 3\n\n");
  
  // Initialize and fit
  KMeansInit(k);
  KMeansFit(features, n, nFeatures, k);
  
  PrintStr("Iterations: ");
  PrintInt(KMeansGetIter());
  PrintStr("\nInertia: ");
  PrintFloat(KMeansGetInertia());
  PrintStr("\n\n");
  
  // Print centroids
  PrintStr("Centroids:\n");
  i := 0;
  while (i < k) {
    PrintStr("  Cluster ");
    PrintInt(i);
    PrintStr(": (");
    var x: f64 := KMeansGetCentroid(i, 0);
    var y: f64 := KMeansGetCentroid(i, 1);
    PrintFloat(x);
    PrintStr(", ");
    PrintFloat(y);
    PrintStr(")\n");
    PrintStr("    Size: ");
    PrintInt(KMeansGetClusterSize(i));
    PrintStr("\n");
    i := i + 1;
  }
  
  // Test predictions
  PrintStr("\n--- Predictions ---\n");
  
  var test1: int64 := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
  pokef64(test1 + 0, 2.0);
  pokef64(test1 + 8, 2.0);
  var pred1: int64 := KMeansPredictCluster(test1);
  PrintStr("Predict (2,2): Cluster ");
  PrintInt(pred1);
  PrintStr("\n");
  
  pokef64(test1 + 0, 8.0);
  pokef64(test1 + 8, 2.5);
  pred1 := KMeansPredictCluster(test1);
  PrintStr("Predict (8,2): Cluster ");
  PrintInt(pred1);
  PrintStr("\n");
  
  pokef64(test1 + 0, 5.0);
  pokef64(test1 + 8, 7.0);
  pred1 := KMeansPredictCluster(test1);
  PrintStr("Predict (5,7): Cluster ");
  PrintInt(pred1);
  PrintStr("\n");
  
  // Silhouette score
  PrintStr("\n--- Quality Metrics ---\n");
  var sil: f64 := KMeansSilhouette(features, n, nFeatures);
  PrintStr("Silhouette Score: ");
  PrintFloat(sil);
  PrintStr(" (-1 to 1, higher is better)\n");
  
  // Test different k values (elbow method)
  PrintStr("\n--- Elbow Method ---\n");
  var elbow: int64 := KMeansElbow(features, n, nFeatures, 5);
  i := 1;
  while (i <= 5) {
    var inert: f64 := peekf64(elbow + (i - 1) * 8);
    PrintStr("k=");
    PrintInt(i);
    PrintStr(": ");
    PrintFloat(inert);
    PrintStr("\n");
    i := i + 1;
  }
  munmap(elbow, 5 * 8);
  
  // Test mini-batch
  PrintStr("\n--- Mini-Batch k-Means ---\n");
  KMeansMiniBatchInit(k, 10);
  KMeansMiniBatchFit(features, n, nFeatures, k);
  PrintStr("Mini-batch iterations: ");
  PrintInt(KMeansGetIter());
  PrintStr("\nMini-batch inertia: ");
  PrintFloat(KMeansGetInertia());
  PrintStr("\n");
  
  munmap(test1, 16);
  munmap(features, n * nFeatures * 8);
  
  PrintStr("\n=== k-Means Test Complete ===\n");
  return 0;
}