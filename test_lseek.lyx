// Test lseek directly
fn main(): int64 {
  var fd: int64 := open("test_selfhost_minimal.lyx", 0, 0);
  PrintStr("open returned: ");
  PrintInt(fd);
  PrintStr("\n");
  
  if fd < 0 {
    PrintStr("open failed\n");
    return 1;
  }
  
  // lseek to end
  var size: int64 := lseek(fd, 0, 2);  // SEEK_END = 2
  PrintStr("lseek to end returned: ");
  PrintInt(size);
  PrintStr("\n");
  
  // lseek back to start
  var pos: int64 := lseek(fd, 0, 0);  // SEEK_SET = 0
  PrintStr("lseek to start returned: ");
  PrintInt(pos);
  PrintStr("\n");
  
  close(fd);
  
  return 0;
}