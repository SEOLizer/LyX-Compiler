// Lyx Credit Card Validation - Luhn Algorithm
// Validates credit card numbers, detects transposition errors
//
// The Luhn algorithm (Mod 10) is used to validate:
// - Credit card numbers (Visa, Mastercard, Amex, etc.)
// - IMEI numbers
// - National identification numbers
// - Any identifier with a check digit
//
// Algorithm:
// 1. Starting from rightmost digit, double every second digit
// 2. If result > 9, subtract 9
// 3. Sum all digits
// 4. Valid if sum mod 10 == 0
//
// Usage:
//   import std.validate.luhn;
//   var valid: bool := LuhnValidate("4532015112830366");
//   var type: int64 := CreditCardType("4532015112830366");
//   var masked: int64 := CreditCardMask("4532015112830366");

unit std.validate.luhn;

// Credit card types
pub con CARD_UNKNOWN: int64 := 0;
pub con CARD_VISA: int64 := 1;
pub con CARD_MASTERCARD: int64 := 2;
pub con CARD_AMEX: int64 := 3;
pub con CARD_DISCOVER: int64 := 4;
pub con CARD_DINERS: int64 := 5;
pub con CARD_JCB: int64 := 6;
pub con CARD_MAESTRO: int64 := 7;
pub con CARD_UNIONPAY: int64 := 8;

// String length helper
pub fn LuhnStrLen(s: int64): int64 {
  var len: int64 := 0;
  if (s == 0) {
    return 0;
  }
  while (peek8(s + len) != 0) {
    len := len + 1;
  }
  return len;
}

// Check if character is a digit
pub fn LuhnIsDigit(c: int64): int64 {
  if (c >= 48 && c <= 57) {
    return 1;
  }
  return 0;
}

// Convert digit char to int
pub fn LuhnDigitToInt(c: int64): int64 {
  if (c >= 48 && c <= 57) {
    return c - 48;
  }
  return -1;
}

// Calculate Luhn check digit
// number: digit string WITHOUT check digit
// Returns check digit (0-9), or -1 on error
pub fn LuhnCheckDigit(number: int64): int64 {
  var len: int64;
  var i: int64;
  var sum: int64;
  var d: int64;
  var doubled: int64;
  var posFromRight: int64;
  
  if (number == 0) {
    return -1;
  }
  
  len := LuhnStrLen(number);
  if (len == 0) {
    return -1;
  }
  
  // Process from right to left
  sum := 0;
  i := len - 1;
  posFromRight := 0;
  
  while (i >= 0) {
    d := LuhnDigitToInt(peek8(number + i));
    if (d < 0) {
      return -1;
    }
    
    // Every second digit from right (positions 1, 3, 5, ...)
    if ((posFromRight - (posFromRight / 2) * 2) == 1) {
      doubled := d * 2;
      if (doubled > 9) {
        doubled := doubled - 9;
      }
      sum := sum + doubled;
    } else {
      sum := sum + d;
    }
    
    posFromRight := posFromRight + 1;
    i := i - 1;
  }
  
  // Check digit = (10 - (sum mod 10)) mod 10
  var remainder: int64 := sum - (sum / 10) * 10;
  if (remainder == 0) {
    return 0;
  }
  return 10 - remainder;
}

// Validate number using Luhn algorithm
// number: digit string WITH check digit
// Returns 1 if valid, 0 if invalid
pub fn LuhnValidate(number: int64): int64 {
  var len: int64;
  var i: int64;
  var sum: int64;
  var d: int64;
  var doubled: int64;
  var posFromRight: int64;
  
  if (number == 0) {
    return 0;
  }
  
  len := LuhnStrLen(number);
  if (len < 2) {
    return 0;
  }
  
  // Verify all characters are digits
  i := 0;
  while (i < len) {
    if (LuhnIsDigit(peek8(number + i)) == 0) {
      return 0;
    }
    i := i + 1;
  }
  
  // Process from right to left
  sum := 0;
  i := len - 1;
  posFromRight := 0;
  
  while (i >= 0) {
    d := LuhnDigitToInt(peek8(number + i));
    
    // Every second digit from right (positions 1, 3, 5, ...)
    if ((posFromRight - (posFromRight / 2) * 2) == 1) {
      doubled := d * 2;
      if (doubled > 9) {
        doubled := doubled - 9;
      }
      sum := sum + doubled;
    } else {
      sum := sum + d;
    }
    
    posFromRight := posFromRight + 1;
    i := i - 1;
  }
  
  // Valid if sum is divisible by 10
  if ((sum - (sum / 10) * 10) == 0) {
    return 1;
  }
  
  return 0;
}

// Detect credit card type from number prefix
// number: credit card number string
// Returns CARD_* constant
pub fn CreditCardType(number: int64): int64 {
  var len: int64;
  var d1: int64;
  var d2: int64;
  var d3: int64;
  var d4: int64;
  var prefix2: int64;
  var prefix3: int64;
  var prefix4: int64;
  
  if (number == 0) {
    return CARD_UNKNOWN;
  }
  
  len := LuhnStrLen(number);
  if (len < 4) {
    return CARD_UNKNOWN;
  }
  
  d1 := LuhnDigitToInt(peek8(number));
  d2 := LuhnDigitToInt(peek8(number + 1));
  d3 := LuhnDigitToInt(peek8(number + 2));
  d4 := LuhnDigitToInt(peek8(number + 3));
  
  prefix2 := d1 * 10 + d2;
  prefix3 := prefix2 * 10 + d3;
  prefix4 := prefix3 * 10 + d4;
  
  // Visa: starts with 4, length 13 or 16
  if (d1 == 4) {
    if (len == 13 || len == 16 || len == 19) {
      return CARD_VISA;
    }
  }
  
  // Mastercard: 51-55 or 2221-2720
  if (prefix2 >= 51 && prefix2 <= 55) {
    if (len == 16) {
      return CARD_MASTERCARD;
    }
  }
  if (prefix4 >= 2221 && prefix4 <= 2720) {
    if (len == 16) {
      return CARD_MASTERCARD;
    }
  }
  
  // American Express: 34 or 37, length 15
  if (prefix2 == 34 || prefix2 == 37) {
    if (len == 15) {
      return CARD_AMEX;
    }
  }
  
  // Discover: 6011, 622126-622925, 644-649, 65
  if (prefix4 == 6011) {
    if (len == 16) {
      return CARD_DISCOVER;
    }
  }
  if (prefix3 >= 644 && prefix3 <= 649) {
    if (len == 16) {
      return CARD_DISCOVER;
    }
  }
  if (prefix2 == 65) {
    if (len == 16) {
      return CARD_DISCOVER;
    }
  }
  
  // Diners Club: 300-305, 36, 38, length 14
  if (prefix3 >= 300 && prefix3 <= 305) {
    if (len == 14) {
      return CARD_DINERS;
    }
  }
  if (prefix2 == 36 || prefix2 == 38) {
    if (len == 14) {
      return CARD_DINERS;
    }
  }
  
  // JCB: 2131, 1800, 3528-3589, length 15-16
  if (prefix4 == 2131 || prefix4 == 1800) {
    if (len == 15) {
      return CARD_JCB;
    }
  }
  if (prefix4 >= 3528 && prefix4 <= 3589) {
    if (len == 16) {
      return CARD_JCB;
    }
  }
  
  // Maestro: 5018, 5020, 5038, 5893, 6304, 6759, 6761, 6762, 6763
  if (prefix4 == 5018 || prefix4 == 5020 || prefix4 == 5038 || prefix4 == 5893 || prefix4 == 6304) {
    return CARD_MAESTRO;
  }
  if (prefix4 == 6759 || prefix4 == 6761 || prefix4 == 6762 || prefix4 == 6763) {
    return CARD_MAESTRO;
  }
  
  // UnionPay: 62
  if (prefix2 == 62) {
    if (len >= 16 && len <= 19) {
      return CARD_UNIONPAY;
    }
  }
  
  return CARD_UNKNOWN;
}

// Get card type name as string
// type: CARD_* constant
// Returns pointer to static string (no free needed)
pub fn CreditCardTypeName(cardType: int64): int64 {
  if (cardType == CARD_VISA) {
    return "Visa";
  }
  if (cardType == CARD_MASTERCARD) {
    return "Mastercard";
  }
  if (cardType == CARD_AMEX) {
    return "American Express";
  }
  if (cardType == CARD_DISCOVER) {
    return "Discover";
  }
  if (cardType == CARD_DINERS) {
    return "Diners Club";
  }
  if (cardType == CARD_JCB) {
    return "JCB";
  }
  if (cardType == CARD_MAESTRO) {
    return "Maestro";
  }
  if (cardType == CARD_UNIONPAY) {
    return "UnionPay";
  }
  return "Unknown";
}

// Validate credit card number (Luhn + type check + length)
// number: credit card number string
// Returns 1 if valid, 0 if invalid
pub fn CreditCardValidate(number: int64): int64 {
  var cardType: int64;
  var len: int64;
  
  if (number == 0) {
    return 0;
  }
  
  // Check Luhn algorithm
  if (LuhnValidate(number) == 0) {
    return 0;
  }
  
  // Check card type
  cardType := CreditCardType(number);
  if (cardType == CARD_UNKNOWN) {
    return 0;
  }
  
  return 1;
}

// Mask credit card number (show only last 4 digits)
// number: credit card number string
// Returns masked string (e.g., "****-****-****-0366"), caller must free
pub fn CreditCardMask(number: int64): int64 {
  var len: int64;
  var buf: int64;
  var pos: int64;
  var i: int64;
  var maskCount: int64;
  var groupSize: int64;
  
  if (number == 0) {
    return 0;
  }
  
  len := LuhnStrLen(number);
  if (len < 4) {
    return 0;
  }
  
  // Calculate masked digits
  maskCount := len - 4;
  
  // Allocate buffer (maskCount * '*' + hyphens every 4 + null)
  var bufLen: int64 := maskCount + 4 + (len / 4) + 1;
  buf := mmap(0, bufLen, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    return 0;
  }
  
  pos := 0;
  i := 0;
  
  // Masked part with hyphens every 4 digits
  while (i < maskCount) {
    if (i > 0 && (i - (i / 4) * 4) == 0) {
      poke8(buf + pos, 45);  // '-'
      pos := pos + 1;
    }
    poke8(buf + pos, 42);  // '*'
    pos := pos + 1;
    i := i + 1;
  }
  
  // Hyphen before visible part if needed
  if (maskCount > 0 && (maskCount - (maskCount / 4) * 4) == 0) {
    // No hyphen needed (aligned to 4)
  } else if (i > 0 && (maskCount - (maskCount / 4) * 4) != 0) {
    // Add hyphen if not at group boundary
  }
  
  // Visible last 4 digits
  i := len - 4;
  while (i < len) {
    if (i > maskCount && (i - maskCount - ((i - maskCount) / 4) * 4) == 0) {
      // Add hyphen at group boundary in visible part
    }
    poke8(buf + pos, peek8(number + i));
    pos := pos + 1;
    i := i + 1;
  }
  
  poke8(buf + pos, 0);
  return buf;
}

// Format credit card number with hyphens (groups of 4)
// number: credit card number string
// Returns formatted string (e.g., "4532-0151-1283-0366"), caller must free
pub fn CreditCardFormat(number: int64): int64 {
  var len: int64;
  var buf: int64;
  var pos: int64;
  var i: int64;
  var cardType: int64;
  
  if (number == 0) {
    return 0;
  }
  
  len := LuhnStrLen(number);
  if (len < 4) {
    return 0;
  }
  
  cardType := CreditCardType(number);
  
  // Allocate buffer (len + hyphens + null)
  buf := mmap(0, len + (len / 4) + 2, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    return 0;
  }
  
  pos := 0;
  i := 0;
  
  // American Express uses 4-6-5 format
  if (cardType == CARD_AMEX) {
    // First 4 digits
    while (i < 4) {
      poke8(buf + pos, peek8(number + i));
      pos := pos + 1;
      i := i + 1;
    }
    poke8(buf + pos, 32);  // space
    pos := pos + 1;
    
    // Next 6 digits
    while (i < 10) {
      poke8(buf + pos, peek8(number + i));
      pos := pos + 1;
      i := i + 1;
    }
    poke8(buf + pos, 32);  // space
    pos := pos + 1;
    
    // Last 5 digits
    while (i < len) {
      poke8(buf + pos, peek8(number + i));
      pos := pos + 1;
      i := i + 1;
    }
  }
  // Diners uses 4-6-4 format
  else if (cardType == CARD_DINERS) {
    while (i < 4) {
      poke8(buf + pos, peek8(number + i));
      pos := pos + 1;
      i := i + 1;
    }
    poke8(buf + pos, 45);  // '-'
    pos := pos + 1;
    
    while (i < 10) {
      poke8(buf + pos, peek8(number + i));
      pos := pos + 1;
      i := i + 1;
    }
    poke8(buf + pos, 45);  // '-'
    pos := pos + 1;
    
    while (i < len) {
      poke8(buf + pos, peek8(number + i));
      pos := pos + 1;
      i := i + 1;
    }
  }
  // Standard 4-4-4-4 format
  else {
    while (i < len) {
      if (i > 0 && (i - (i / 4) * 4) == 0) {
        poke8(buf + pos, 45);  // '-'
        pos := pos + 1;
      }
      poke8(buf + pos, peek8(number + i));
      pos := pos + 1;
      i := i + 1;
    }
  }
  
  poke8(buf + pos, 0);
  return buf;
}

// Generate a valid credit card number (for testing only)
// type: CARD_* constant (e.g., CARD_VISA)
// Returns valid Luhn number, caller must free
// NOTE: This generates TEST numbers only, not real cards!
pub fn CreditCardGenerateTest(cardType: int64): int64 {
  var buf: int64;
  var len: int64;
  var i: int64;
  var check: int64;
  
  // Determine length and prefix
  if (cardType == CARD_VISA) {
    len := 16;
  }
  else if (cardType == CARD_MASTERCARD) {
    len := 16;
  }
  else if (cardType == CARD_AMEX) {
    len := 15;
  }
  else if (cardType == CARD_DISCOVER) {
    len := 16;
  }
  else {
    len := 16;
  }
  
  buf := mmap(0, len + 1, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) {
    return 0;
  }
  
  // Set prefix
  if (cardType == CARD_VISA) {
    poke8(buf, 52);  // '4'
  }
  else if (cardType == CARD_MASTERCARD) {
    poke8(buf, 53);  // '5'
    poke8(buf + 1, 49);  // '1'
  }
  else if (cardType == CARD_AMEX) {
    poke8(buf, 51);  // '3'
    poke8(buf + 1, 55);  // '7'
  }
  else if (cardType == CARD_DISCOVER) {
    poke8(buf, 54);  // '6'
    poke8(buf + 1, 48);  // '0'
    poke8(buf + 2, 49);  // '1'
    poke8(buf + 3, 49);  // '1'
  }
  else {
    poke8(buf, 52);  // '4'
  }
  
  // Fill rest with zeros
  i := 0;
  while (i < len - 1) {
    if (peek8(buf + i) == 0) {
      poke8(buf + i, 48);  // '0'
    }
    i := i + 1;
  }
  
  // Calculate and set check digit
  check := LuhnCheckDigit(buf);
  if (check >= 0) {
    poke8(buf + len - 1, 48 + check);
  }
  
  poke8(buf + len, 0);
  return buf;
}

// Validate IMEI number (15 digits, uses Luhn)
// imei: 15-digit IMEI string
// Returns 1 if valid, 0 if invalid
pub fn IMEIValidate(imei: int64): int64 {
  var len: int64;
  
  if (imei == 0) {
    return 0;
  }
  
  len := LuhnStrLen(imei);
  if (len != 15) {
    return 0;
  }
  
  return LuhnValidate(imei);
}

// Validate German tax ID (Steuerliche Identifikationsnummer)
// 11 digits, all different except check digit
// Returns 1 if valid, 0 if invalid
pub fn GermanTaxIDValidate(taxId: int64): int64 {
  var len: int64;
  var i: int64;
  var j: int64;
  var d: int64;
  var seen: int64;
  
  if (taxId == 0) {
    return 0;
  }
  
  len := LuhnStrLen(taxId);
  if (len != 11) {
    return 0;
  }
  
  // Check all digits
  i := 0;
  while (i < 11) {
    if (LuhnIsDigit(peek8(taxId + i)) == 0) {
      return 0;
    }
    i := i + 1;
  }
  
  // Check that no digit appears more than twice
  i := 0;
  while (i < 10) {
    d := peek8(taxId + i);
    seen := 0;
    j := 0;
    while (j < 11) {
      if (peek8(taxId + j) == d) {
        seen := seen + 1;
      }
      j := j + 1;
    }
    if (seen > 2) {
      return 0;
    }
    i := i + 1;
  }
  
  // Check that first digit is not 0
  if (peek8(taxId) == 48) {
    return 0;
  }
  
  // Simple checksum (not full Luhn, but position-based)
  // Sum of first 10 digits, check digit = sum mod 11
  var sum: int64 := 0;
  i := 0;
  while (i < 10) {
    sum := sum + LuhnDigitToInt(peek8(taxId + i));
    i := i + 1;
  }
  
  var expectedCheck: int64 := sum - (sum / 11) * 11;
  if (expectedCheck == 10) {
    expectedCheck := 0;
  }
  
  var actualCheck: int64 := LuhnDigitToInt(peek8(taxId + 10));
  
  if (expectedCheck != actualCheck) {
    return 0;
  }
  
  return 1;
}
