  if (bodyLen < 2 || bodyLen > 10) { return VAT_ERR_INVALID_LENGTH; }
  if (VATAllDigits(vat) == 0) { return VAT_ERR_INVALID_CHAR; }
  
  // Must not start with 0
  if (peek8(vat + 2) == 48) { return VAT_ERR_INVALID_FORMAT; }
  
  return VAT_OK;
}

