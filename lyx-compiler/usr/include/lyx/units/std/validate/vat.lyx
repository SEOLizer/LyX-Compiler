// Validate CY (Cyprus) - 9 chars, last must be letter
pub fn VATValidateCY(vat: int64): int64 {
  var bodyLen: int64;
  var c: int64;
  
  bodyLen := VATStrLen(vat) - 2;
  if (bodyLen != 9) { return VAT_ERR_INVALID_LENGTH; }
  
  // Last character must be a letter
  c := VATToUpper(peek8(vat + 10));
  if (VATIsAlpha(c) == 0) { return VAT_ERR_INVALID_FORMAT; }
  
  // First 8 must be digits
  var i: int64 := 2;
  while (i < 10) {
    if (VATIsDigit(peek8(vat + i)) == 0) { return VAT_ERR_INVALID_CHAR; }
    i := i + 1;
  end;
  
  return VAT_OK;
}

