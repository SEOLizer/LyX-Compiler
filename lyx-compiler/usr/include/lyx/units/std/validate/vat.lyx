// Validate IE (Ireland) - 8 or 9 chars
pub fn VATValidateIE(vat: int64): int64 {
  var bodyLen: int64;
  var c: int64;
  
  bodyLen := VATStrLen(vat) - 2;
  
  if (bodyLen == 8) {
    // 8 digits, second can be letter, last must be letter
    c := VATToUpper(peek8(vat + 10));
    if (VATIsAlpha(c) == 0) { return VAT_ERR_INVALID_FORMAT; }
  }
  else if (bodyLen == 9) {
    // 9 chars since 2013: 7 digits + letter A-W + letter A-I
    var c8: int64 := VATToUpper(peek8(vat + 9));
    var c9: int64 := VATToUpper(peek8(vat + 10));
    if (c8 < 65 || c8 > 87) { return VAT_ERR_INVALID_FORMAT; }  // A-W
    if (c9 < 65 || c9 > 73) { return VAT_ERR_INVALID_FORMAT; }  // A-I
  }
  else {
    return VAT_ERR_INVALID_LENGTH;
  }
  
  return VAT_OK;
}

