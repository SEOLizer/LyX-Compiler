// Lyx VAT ID Validation - EU VAT Number Validation
// Validates European VAT identification numbers (USt-IdNr.)
//
// EU VAT numbers follow country-specific formats:
// - 2-letter country prefix + country-specific number
// - Various validation rules per country
//
// Usage:
//   import std.validate.vat;
//   var valid: bool := VATValidate("DE123456789");
//   var country: int64 := VATGetCountry("DE123456789");
//   var formatted: int64 := VATFormat("DE123456789");

unit std.validate.vat;

import std.country;

// VAT validation status
pub con VAT_OK: int64 := 0;
pub con VAT_ERR_INVALID_LENGTH: int64 := 1;
pub con VAT_ERR_INVALID_CHAR: int64 := 2;
pub con VAT_ERR_INVALID_FORMAT: int64 := 3;
pub con VAT_ERR_UNKNOWN_COUNTRY: int64 := 4;

// String helpers
pub fn VATStrLen(s: int64): int64 {
  var len: int64 := 0;
  if (s == 0) { return 0; }
  while (peek8(s + len) != 0) { len := len + 1; }
  return len;
}

pub fn VATIsDigit(c: int64): int64 {
  if (c >= 48 && c <= 57) { return 1; }
  return 0;
}

pub fn VATIsAlpha(c: int64): int64 {
  if ((c >= 65 && c <= 90) || (c >= 97 && c <= 122)) { return 1; }
  return 0;
}

pub fn VATIsAlphaNum(c: int64): int64 {
  if (VATIsDigit(c) == 1 || VATIsAlpha(c) == 1) { return 1; }
  return 0;
}

pub fn VATToUpper(c: int64): int64 {
  if (c >= 97 && c <= 122) { return c - 32; }
  return c;
}

pub fn VATDigitToInt(c: int64): int64 {
  if (c >= 48 && c <= 57) { return c - 48; }
  return -1;
}

// Normalize VAT string (remove spaces, convert to uppercase)
pub fn VATNormalize(vat: int64): int64 {
  var len: int64;
  var buf: int64;
  var pos: int64;
  var i: int64;
  var c: int64;
  
  if (vat == 0) { return 0; }
  len := VATStrLen(vat);
  buf := mmap(0, len + 1, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (buf == 0) { return 0; }
  
  pos := 0;
  i := 0;
  while (i < len) {
    c := peek8(vat + i);
    if (c == 32 || c == 45) { i := i + 1; continue; }
    c := VATToUpper(c);
    poke8(buf + pos, c);
    pos := pos + 1;
    i := i + 1;
  }
  poke8(buf + pos, 0);
  return buf;
}

// Count digits in VAT number body (after country prefix)
pub fn VATCountDigits(vat: int64): int64 {
  var count: int64 := 0;
  var i: int64 := 2;  // Skip country code
  var c: int64;
  while (i < 20) {
    c := peek8(vat + i);
    if (c == 0) { break; }
    if (VATIsDigit(c) == 1) { count := count + 1; }
    i := i + 1;
  }
  return count;
}

// Check if all characters after prefix are digits
pub fn VATAllDigits(vat: int64): int64 {
  var i: int64 := 2;
  var c: int64;
  while (i < 20) {
    c := peek8(vat + i);
    if (c == 0) { break; }
    if (VATIsDigit(c) == 0) { return 0; }
    i := i + 1;
  }
  return 1;
}

// Validate BE (Belgium) - 10 digits
pub fn VATValidateBE(vat: int64): int64 {
  var bodyLen: int64;
  var i: int64;
  var sum: int64;
  var d1: int64;
  var d2: int64;
  var check: int64;
  var expected: int64;
  
  bodyLen := VATStrLen(vat) - 2;
  if (bodyLen != 10) { return VAT_ERR_INVALID_LENGTH; }
  if (VATAllDigits(vat) == 0) { return VAT_ERR_INVALID_CHAR; }
  
  // Belgian check: 97 - (first 8 digits mod 97) = last 2 digits
  sum := 0;
  i := 2;
  while (i < 10) {
    sum := sum * 10 + VATDigitToInt(peek8(vat + i));
    sum := sum - (sum / 97) * 97;
    i := i + 1;
  }
  
  check := VATDigitToInt(peek8(vat + 10)) * 10 + VATDigitToInt(peek8(vat + 11));
  expected := 97 - sum;
  
  if (expected != check) { return VAT_ERR_INVALID_FORMAT; }
  return VAT_OK;
}

// Validate DE (Germany) - 9 digits
pub fn VATValidateDE(vat: int64): int64 {
  var bodyLen: int64;
  
  bodyLen := VATStrLen(vat) - 2;
  if (bodyLen != 9) { return VAT_ERR_INVALID_LENGTH; }
  if (VATAllDigits(vat) == 0) { return VAT_ERR_INVALID_CHAR; }
  return VAT_OK;
}

// Validate AT (Austria) - 9 digits, first must be U
pub fn VATValidateAT(vat: int64): int64 {
  var bodyLen: int64;
  
  bodyLen := VATStrLen(vat) - 2;
  if (bodyLen != 9) { return VAT_ERR_INVALID_LENGTH; }
  
  // First character after prefix must be 'U'
  if (VATToUpper(peek8(vat + 2)) != 85) {
    return VAT_ERR_INVALID_FORMAT;
  }
  
  // Remaining 8 must be digits
  var i: int64 := 3;
  while (i < 11) {
    if (VATIsDigit(peek8(vat + i)) == 0) { return VAT_ERR_INVALID_CHAR; }
    i := i + 1;
  }
  
  return VAT_OK;
}

// Validate FR (France) - 11 chars, first 2 can be letters
pub fn VATValidateFR(vat: int64): int64 {
  var bodyLen: int64;
  
  bodyLen := VATStrLen(vat) - 2;
  if (bodyLen != 11) { return VAT_ERR_INVALID_LENGTH; }
  
  // First 2 can be letters or digits, rest must be digits
  var i: int64 := 2;
  while (i < 13) {
    if (i < 4) {
      if (VATIsAlphaNum(peek8(vat + i)) == 0) { return VAT_ERR_INVALID_CHAR; }
    } else {
      if (VATIsDigit(peek8(vat + i)) == 0) { return VAT_ERR_INVALID_CHAR; }
    }
    i := i + 1;
  }
  
  return VAT_OK;
}

// Validate IT (Italy) - 11 digits
pub fn VATValidateIT(vat: int64): int64 {
  var bodyLen: int64;
  
  bodyLen := VATStrLen(vat) - 2;
  if (bodyLen != 11) { return VAT_ERR_INVALID_LENGTH; }
  if (VATAllDigits(vat) == 0) { return VAT_ERR_INVALID_CHAR; }
  
  // Italian check digit (Luhn-like algorithm on first 10 digits)
  var sum: int64 := 0;
  var i: int64 := 2;
  while (i < 12) {
    var d: int64 := VATDigitToInt(peek8(vat + i));
    if ((i - (i / 2) * 2) == 0) {
      d := d * 2;
      if (d > 9) { d := d - 9; }
    }
    sum := sum + d;
    i := i + 1;
  }
  
  var check: int64 := sum - (sum / 10) * 10;
  if (check != 0) { return VAT_ERR_INVALID_FORMAT; }
  
  return VAT_OK;
}

// Validate ES (Spain) - 9 chars, first/last can be letter
pub fn VATValidateES(vat: int64): int64 {
  var bodyLen: int64;
  
  bodyLen := VATStrLen(vat) - 2;
  if (bodyLen != 9) { return VAT_ERR_INVALID_LENGTH; }
  
  // First and/or last can be letters
  var i: int64 := 2;
  while (i < 11) {
    if (i == 2 || i == 10) {
      if (VATIsAlphaNum(peek8(vat + i)) == 0) { return VAT_ERR_INVALID_CHAR; }
    } else {
      if (VATIsDigit(peek8(vat + i)) == 0) { return VAT_ERR_INVALID_CHAR; }
    }
    i := i + 1;
  }
  
  return VAT_OK;
}

// Validate NL (Netherlands) - 12 chars, digits/letters/+/*
pub fn VATValidateNL(vat: int64): int64 {
  var bodyLen: int64;
  
  bodyLen := VATStrLen(vat) - 2;
  if (bodyLen != 12) { return VAT_ERR_INVALID_LENGTH; }
  
  // All characters must be alphanumeric, +, or *
  var i: int64 := 2;
  while (i < 14) {
    var c: int64 := peek8(vat + i);
    if (VATIsAlphaNum(c) == 0 && c != 43 && c != 42) {
      return VAT_ERR_INVALID_CHAR;
    }
    i := i + 1;
  }
  
  return VAT_OK;
}

// Validate PL (Poland) - 10 digits with checksum
pub fn VATValidatePL(vat: int64): int64 {
  var bodyLen: int64;
  var sum: int64 := 0;
  var weights: int64;
  var i: int64;
  var d: int64;
  
  bodyLen := VATStrLen(vat) - 2;
  if (bodyLen != 10) { return VAT_ERR_INVALID_LENGTH; }
  if (VATAllDigits(vat) == 0) { return VAT_ERR_INVALID_CHAR; }
  
  // Polish NIP checksum: 6,5,7,2,3,4,5,6,7
  i := 2;
  while (i < 11) {
    d := VATDigitToInt(peek8(vat + i));
    if (i == 2) { sum := sum + d * 6; }
    else if (i == 3) { sum := sum + d * 5; }
    else if (i == 4) { sum := sum + d * 7; }
    else if (i == 5) { sum := sum + d * 2; }
    else if (i == 6) { sum := sum + d * 3; }
    else if (i == 7) { sum := sum + d * 4; }
    else if (i == 8) { sum := sum + d * 5; }
    else if (i == 9) { sum := sum + d * 6; }
    else if (i == 10) { sum := sum + d * 7; }
    i := i + 1;
  end;
  
  var check: int64 := sum - (sum / 11) * 11;
  var lastDigit: int64 := VATDigitToInt(peek8(vat + 11));
  
  if (check == 10 && lastDigit != 0) { return VAT_ERR_INVALID_FORMAT; }
  if (check < 10 && check != lastDigit) { return VAT_ERR_INVALID_FORMAT; }
  
  return VAT_OK;
}

// Validate PT (Portugal) - 9 digits with checksum
pub fn VATValidatePT(vat: int64): int64 {
  var bodyLen: int64;
  var sum: int64 := 0;
  var i: int64;
  var d: int64;
  
  bodyLen := VATStrLen(vat) - 2;
  if (bodyLen != 9) { return VAT_ERR_INVALID_LENGTH; }
  if (VATAllDigits(vat) == 0) { return VAT_ERR_INVALID_CHAR; }
  
  // Portuguese NIPC checksum
  i := 2;
  while (i < 10) {
    d := VATDigitToInt(peek8(vat + i));
    sum := sum + d * (11 - (i - 1));
    i := i + 1;
  end;
  
  var check: int64 := VATDigitToInt(peek8(vat + 10));
  var remainder: int64 := sum - (sum / 11) * 11;
  var expected: int64 := 0;
  if (remainder >= 2) { expected := 11 - remainder; }
  
  if (expected != check) { return VAT_ERR_INVALID_FORMAT; }
  return VAT_OK;
}

// Validate SE (Sweden) - 12 digits, last 2 must be "01"
pub fn VATValidateSE(vat: int64): int64 {
  var bodyLen: int64;
  
  bodyLen := VATStrLen(vat) - 2;
  if (bodyLen != 12) { return VAT_ERR_INVALID_LENGTH; }
  if (VATAllDigits(vat) == 0) { return VAT_ERR_INVALID_CHAR; }
  
  // Last two digits must be "01"
  if (peek8(vat + 12) != 48 || peek8(vat + 13) != 49) {
    return VAT_ERR_INVALID_FORMAT;
  }
  
  return VAT_OK;
}

