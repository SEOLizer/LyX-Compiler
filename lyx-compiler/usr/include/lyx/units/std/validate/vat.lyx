// Validate VAT number
// vat: VAT number with country prefix (e.g., "DE123456789")
// Returns VAT_OK if valid, or error code
pub fn VATValidate(vat: int64): int64 {
  var normalized: int64;
  var len: int64;
  var c1: int64;
  var c2: int64;
  var result: int64;
  
  if (vat == 0) { return VAT_ERR_INVALID_LENGTH; }
  
  normalized := VATNormalize(vat);
  if (normalized == 0) { return VAT_ERR_INVALID_LENGTH; }
  
  len := VATStrLen(normalized);
  if (len < 4) {
    munmap(normalized, len + 1);
    return VAT_ERR_INVALID_LENGTH;
  }
  
  c1 := peek8(normalized);
  c2 := peek8(normalized + 1);
  
  // Country-specific validation
  if (c1 == 68 && c2 == 69) { result := VATValidateDE(normalized); }         // DE
  else if (c1 == 65 && c2 == 84) { result := VATValidateAT(normalized); }     // AT
  else if (c1 == 66 && c2 == 69) { result := VATValidateBE(normalized); }     // BE
  else if (c1 == 66 && c2 == 71) { result := VAT_OK; }                        // BG
  else if (c1 == 67 && c2 == 89) { result := VATValidateCY(normalized); }     // CY
  else if (c1 == 67 && c2 == 90) { result := VATValidateCZ(normalized); }     // CZ
  else if (c1 == 68 && c2 == 75) { result := VATValidateDK(normalized); }     // DK
  else if (c1 == 69 && c2 == 69) { result := VATValidateEE(normalized); }     // EE
  else if (c1 == 69 && c2 == 83) { result := VATValidateES(normalized); }     // ES
  else if (c1 == 70 && c2 == 73) { result := VATValidateFI(normalized); }     // FI
  else if (c1 == 70 && c2 == 82) { result := VATValidateFR(normalized); }     // FR
  else if (c1 == 71 && c2 == 66) { result := VAT_OK; }                        // GB
  else if (c1 == 71 && c2 == 82) { result := VATValidateGR(normalized); }     // GR
  else if (c1 == 72 && c2 == 82) { result := VATValidateHR(normalized); }     // HR
  else if (c1 == 72 && c2 == 85) { result := VATValidateHU(normalized); }     // HU
  else if (c1 == 73 && c2 == 69) { result := VATValidateIE(normalized); }     // IE
  else if (c1 == 73 && c2 == 84) { result := VATValidateIT(normalized); }     // IT
  else if (c1 == 76 && c2 == 84) { result := VATValidateLT(normalized); }     // LT
  else if (c1 == 76 && c2 == 85) { result := VATValidateLU(normalized); }     // LU
  else if (c1 == 76 && c2 == 86) { result := VATValidateLV(normalized); }     // LV
  else if (c1 == 77 && c2 == 84) { result := VATValidateMT(normalized); }     // MT
  else if (c1 == 78 && c2 == 76) { result := VATValidateNL(normalized); }     // NL
  else if (c1 == 80 && c2 == 76) { result := VATValidatePL(normalized); }     // PL
  else if (c1 == 80 && c2 == 84) { result := VATValidatePT(normalized); }     // PT
  else if (c1 == 82 && c2 == 79) { result := VATValidateRO(normalized); }     // RO
  else if (c1 == 83 && c2 == 69) { result := VATValidateSE(normalized); }     // SE
  else if (c1 == 83 && c2 == 73) { result := VATValidateSI(normalized); }     // SI
  else if (c1 == 83 && c2 == 75) { result := VATValidateSK(normalized); }     // SK
  else { result := VAT_ERR_UNKNOWN_COUNTRY; }
  
  munmap(normalized, len + 1);
  return result;
}

// Get VAT number name for country
// code: 2-letter country code
// Returns pointer to VAT name string (static)
pub fn VATGetCountryName(code: int64): int64 {
  var c1: int64;
  var c2: int64;
  
  if (code == 0) { return "Unknown"; }
  c1 := VATToUpper(peek8(code));
  c2 := VATToUpper(peek8(code + 1));
  
  if (c1 == 68 && c2 == 69) { return "USt-IdNr."; }
  if (c1 == 65 && c2 == 84) { return "UID-Nr"; }
  if (c1 == 66 && c2 == 69) { return "BTW-Nr."; }
  if (c1 == 70 && c2 == 82) { return "TVA"; }
  if (c1 == 73 && c2 == 84) { return "P.IVA"; }
  if (c1 == 69 && c2 == 83) { return "N.IVA"; }
  if (c1 == 78 && c2 == 76) { return "BTW-identificatienummer"; }
  if (c1 == 80 && c2 == 76) { return "NIP"; }
  if (c1 == 80 && c2 == 84) { return "NIPC"; }
  if (c1 == 83 && c2 == 69) { return "MomsNr."; }
  if (c1 == 71 && c2 == 66) { return "VAT No"; }
  if (c1 == 72 && c2 == 85) { return "Közösségi adószám"; }
  
  return "VAT";
}

// Get VAT number format description for country
pub fn VATGetFormat(code: int64): int64 {
  var c1: int64;
  var c2: int64;
  
  if (code == 0) { return "Unknown"; }
  c1 := VATToUpper(peek8(code));
  c2 := VATToUpper(peek8(code + 1));
  
  if (c1 == 68 && c2 == 69) { return "DE + 9 digits"; }
  if (c1 == 65 && c2 == 84) { return "AT + U + 8 digits"; }
  if (c1 == 66 && c2 == 69) { return "BE + 10 digits"; }
  if (c1 == 70 && c2 == 82) { return "FR + 11 alphanumeric"; }
  if (c1 == 73 && c2 == 84) { return "IT + 11 digits"; }
  if (c1 == 69 && c2 == 83) { return "ES + 9 alphanumeric"; }
  if (c1 == 78 && c2 == 76) { return "NL + 12 alphanumeric"; }
  if (c1 == 80 && c2 == 76) { return "PL + 10 digits"; }
  if (c1 == 83 && c2 == 69) { return "SE + 12 digits (ends 01)"; }
  
  return "XX + N chars";
}
