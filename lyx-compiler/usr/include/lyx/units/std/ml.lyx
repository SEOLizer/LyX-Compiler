// ============================================================================
// DataFrame-based Logistic Regression (arbitrary data points)
// ============================================================================

// Train Logistic Regression from DataFrame
pub fn LogisticRegressionFitDataFrame(df: int64, xCol: int64, yCol: int64, learningRate: f64, epochs: int64): void {
  var rowCount: int64 := 0;
  var colCount: int64 := 0;
  
  rowCount := peek8(df + 24);
  colCount := peek8(df + 16);
  
  if (rowCount < 2) {
    logr_loss := 1.0;
    logr_epochs := 0;
    return;
  }
  
  var xIdx: int64 := 0;
  var yIdx: int64 := 1;
  
  var e: int64 := 0;
  while (e < epochs) {
    var sum_dw: f64 := 0.0;
    var sum_db: f64 := 0.0;
    
    var i: int64 := 0;
    while (i < rowCount) {
      var xSeries: int64 := peek8(peek8(df) + xIdx * 16 + 8);
      var ySeries: int64 := peek8(peek8(df) + yIdx * 16 + 8);
      
      var xVal: f64 := peekf64(peek8(xSeries) + i * 8);
      var yVal: f64 := peekf64(peek8(ySeries) + i * 8);
      
      var z: f64 := logr_weight * xVal + logr_bias;
      var pred: f64 := SigmoidF64(z);
      var error: f64 := pred - yVal;
      
      sum_dw := sum_dw + (error * xVal);
      sum_db := sum_db + error;
      
      i := i + 1;
    }
    
    var n: f64 := rowCount as f64;
    var dw: f64 := sum_dw / n;
    var db: f64 := sum_db / n;
    
    logr_weight := logr_weight - (learningRate * dw);
    logr_bias := logr_bias - (learningRate * db);
    
    // Calculate loss and accuracy
    var loss_sum: f64 := 0.0;
    var correct: int64 := 0;
    
    i := 0;
    while (i < rowCount) {
      var xSeries: int64 := peek8(peek8(df) + xIdx * 16 + 8);
      var ySeries: int64 := peek8(peek8(df) + yIdx * 16 + 8);
      
      var xVal: f64 := peekf64(peek8(xSeries) + i * 8);
      var yVal: f64 := peekf64(peek8(ySeries) + i * 8);
      
      var z: f64 := logr_weight * xVal + logr_bias;
      var pred: f64 := SigmoidF64(z);
      
      var diff: f64 := pred - yVal;
      loss_sum := loss_sum + (diff * diff);
      
      var predClass: int64 := 0;
      if (pred >= 0.5) { predClass := 1; }
      if (predClass == (yVal as int64)) { correct := correct + 1; }
      
      i := i + 1;
    }
    
    logr_loss := loss_sum / n;
    logr_accuracy := correct as f64 / n;
    
    logr_epochs := logr_epochs + 1;
    e := e + 1;
  }
}

// ============================================================================
// Array-based Linear Regression (arbitrary data points)
// ============================================================================

// Train Linear Regression from f64 arrays
// xData: pointer to f64 array (x values)
// yData: pointer to f64 array (y values)  
// n: number of data points
pub fn LinearRegressionFitArrays(xData: int64, yData: int64, n: int64): void {
  if (n < 2) {
    lr_loss := 1.0;
    lr_epochs := 0;
    return;
  }
  
  // Calculate sums
  var sum_x: f64 := 0.0;
  var sum_y: f64 := 0.0;
  var sum_xy: f64 := 0.0;
  var sum_xx: f64 := 0.0;
  
  var i: int64 := 0;
  while (i < n) {
    var xVal: f64 := peekf64(xData + i * 8);
    var yVal: f64 := peekf64(yData + i * 8);
    
    sum_x := sum_x + xVal;
    sum_y := sum_y + yVal;
    sum_xy := sum_xy + (xVal * yVal);
    sum_xx := sum_xx + (xVal * xVal);
    
    i := i + 1;
  }
  
  // Closed-form solution
  var nn: f64 := n as f64;
  var denom: f64 := (nn * sum_xx) - (sum_x * sum_x);
  
  if (denom > 0.0001 || denom < -0.0001) {
    var numerator: f64 := nn * sum_xy - sum_x * sum_y;
    lr_weight := numerator / denom;
  } else {
    lr_weight := 0.1;
  }
  
  lr_bias := (sum_y - lr_weight * sum_x) / nn;
  
  // Calculate MSE loss
  var loss_sum: f64 := 0.0;
  i := 0;
  while (i < n) {
    var xVal: f64 := peekf64(xData + i * 8);
    var yVal: f64 := peekf64(yData + i * 8);
    
    var pred: f64 := lr_weight * xVal + lr_bias;
    var diff: f64 := pred - yVal;
    loss_sum := loss_sum + (diff * diff);
    
    i := i + 1;
  }
  
  lr_loss := loss_sum / nn;
  lr_epochs := 1;
}

