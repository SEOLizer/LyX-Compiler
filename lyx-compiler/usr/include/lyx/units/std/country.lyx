// Get region name by region constant
// region: REGION_* constant
// Returns pointer to region name (static, no free needed)
pub fn CountryGetRegionName(region: int64): int64 {
  if (region == REGION_EUROPE) {
    return "Europe";
  }
  if (region == REGION_ASIA) {
    return "Asia";
  }
  if (region == REGION_AFRICA) {
    return "Africa";
  }
  if (region == REGION_NORTH_AMERICA) {
    return "North America";
  }
  if (region == REGION_SOUTH_AMERICA) {
    return "South America";
  }
  if (region == REGION_OCEANIA) {
    return "Oceania";
  }
  if (region == REGION_MIDDLE_EAST) {
    return "Middle East";
  }
  if (region == REGION_CARIBBEAN) {
    return "Caribbean";
  }
  return "Unknown";
}

// Check if country code is valid ISO 3166-1 alpha-2
// code: 2-letter code
// Returns 1 if valid, 0 if not
pub fn CountryIsValid(code: int64): int64 {
  var db: int64;
  var i: int64;
  var entryCode: int64;
  
  db := CountryInitDb();
  if (db == 0) {
    return 0;
  }
  
  i := 0;
  while (i < 67 * 40) {
    entryCode := peek8(db + i);
    if (entryCode != 0) {
      if (CountryStrEqual(code, entryCode) == 1) {
        return 1;
      }
    }
    i := i + 40;
  }
  
  return 0;
}

