// Lyx Country Codes - ISO 3166-1 alpha-2
// Comprehensive country code database for business applications
//
// ISO 3166-1 defines two-letter country codes used worldwide.
// This module provides:
// - 249 country codes with names
// - Lookup by code
// - Lookup by name
// - Currency codes (ISO 4217)
// - Region/continent detection
//
// Usage:
//   import std.country;
//   var name: int64 := CountryGetName("DE");
//   var code: int64 := CountryGetCode("Germany");
//   var currency: int64 := CountryGetCurrency("DE");

unit std.country;

// Number of countries in database
pub con COUNTRY_COUNT: int64 := 249;

// Region constants
pub con REGION_EUROPE: int64 := 1;
pub con REGION_ASIA: int64 := 2;
pub con REGION_AFRICA: int64 := 3;
pub con REGION_NORTH_AMERICA: int64 := 4;
pub con REGION_SOUTH_AMERICA: int64 := 5;
pub con REGION_OCEANIA: int64 := 6;
pub con REGION_MIDDLE_EAST: int64 := 7;
pub con REGION_CARIBBEAN: int64 := 8;

// Country database entry
pub type CountryEntry = struct {
  code: int64;         // Pointer to 2-letter code string
  name: int64;         // Pointer to country name
  currency: int64;     // Pointer to 3-letter currency code
  region: int64;       // REGION_* constant
  numeric: int64;      // ISO 3166-1 numeric code
};

// Country database (allocated on first use)
pub var _countryDb: int64 := 0;

