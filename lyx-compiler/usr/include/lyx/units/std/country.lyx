  poke8(db + i, REGION_AFRICA); i := i + 8;
  poke8(db + i, 404); i := i + 8;
  
  // Oceania
  // Entry 65: Australia
  poke8(db + i, "AU"); i := i + 8;
  poke8(db + i, "Australia"); i := i + 8;
  poke8(db + i, "AUD"); i := i + 8;
  poke8(db + i, REGION_OCEANIA); i := i + 8;
  poke8(db + i, 36); i := i + 8;
  
  // Entry 66: New Zealand
  poke8(db + i, "NZ"); i := i + 8;
  poke8(db + i, "New Zealand"); i := i + 8;
  poke8(db + i, "NZD"); i := i + 8;
  poke8(db + i, REGION_OCEANIA); i := i + 8;
  poke8(db + i, 554); i := i + 8;
  
  // Store database pointer
  _countryDb := db;
  return db;
}

// String comparison helper
pub fn CountryStrEqual(s1: int64, s2: int64): int64 {
  var i: int64 := 0;
  var c1: int64;
  var c2: int64;
  
  if (s1 == 0 || s2 == 0) {
    return 0;
  }
  
  while (i < 50) {
    c1 := peek8(s1 + i);
    c2 := peek8(s2 + i);
    
    // Case-insensitive comparison
    if (c1 >= 97 && c1 <= 122) { c1 := c1 - 32; }
    if (c2 >= 97 && c2 <= 122) { c2 := c2 - 32; }
    
    if (c1 != c2) {
      return 0;
    }
    if (c1 == 0) {
      return 1;
    }
    i := i + 1;
  }
  
  return 1;
}

// Get country name by 2-letter code
// code: 2-letter ISO 3166-1 code
// Returns pointer to country name (static, no free needed), or "Unknown"
pub fn CountryGetName(code: int64): int64 {
  var db: int64;
  var i: int64;
  var entryCode: int64;
  
  db := CountryInitDb();
  if (db == 0) {
    return "Unknown";
  }
  
  i := 0;
  while (i < 67 * 40) {
    entryCode := peek8(db + i);
    if (entryCode != 0) {
      if (CountryStrEqual(code, entryCode) == 1) {
        return peek8(db + i + 8);  // Return name
      }
    }
    i := i + 40;
  }
  
  return "Unknown";
}

