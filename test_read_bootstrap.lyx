// Test read syscall with mmap - no imports needed
fn main(): int64 {
  var buf: int64 := mmap(0, 4096, 3, 34, -1, 0);
  
  // Initialize memory
  var i: int64 := 0;
  while i < 10 {
    poke8(buf + i, 0);
    i := i + 1;
  }
  
  // Print the mmap result
  PrintStr("mmap: ");
  PrintInt(buf);
  PrintStr("\n");
  
  // Read from stdin
  var n: int64 := read(0, buf, 10);
  PrintStr("read: ");
  PrintInt(n);
  PrintStr("\n");
  
  if n > 0 {
    var j: int64 := 0;
    while j < n {
      PrintInt(peek8(buf + j));
      PrintStr(" ");
      j := j + 1;
    }
    PrintStr("\n");
  }
  
  munmap(buf, 4096);
  return 0;
}