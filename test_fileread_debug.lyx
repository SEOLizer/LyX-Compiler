// Test FileReadAll directly
fn main(): int64 {
  var content: int64 := FileReadAll("test_selfhost_minimal.lyx" as pchar);
  if content == 0 {
    PrintStr("FileReadAll failed\n");
    return 1;
  }
  
  // Check first 20 bytes
  PrintStr("First 20 bytes: ");
  var i: int64 := 0;
  while i < 20 {
    var c: int64 := peek8(content + i);
    if c == 0 { PrintStr("(null)"); break; }
    PrintInt(c);
    PrintStr(" ");
    i := i + 1;
  }
  PrintStr("\n");
  
  // Check total length
  var len: int64 := StrLen(content);
  PrintStr("StrLen: ");
  PrintInt(len);
  PrintStr("\n");
  
  return 0;
}