// Even simpler test - just mmap and poke
fn main(): int64 {
  var buf: int64 := mmap(0, 32, 3, 34, -1, 0);
  poke8(buf + 0, 72);  // 'H'
  poke8(buf + 1, 101); // 'e'
  poke8(buf + 2, 108); // 'l'
  poke8(buf + 3, 108); // 'l'
  poke8(buf + 4, 111); // 'o'
  poke8(buf + 5, 0);
  
  // Print the bytes directly
  var i: int64 := 0;
  while i < 6 {
    PrintInt(peek8(buf + i));
    PrintStr(" ");
    i := i + 1;
  }
  PrintStr("\n");
  
  return 0;
}