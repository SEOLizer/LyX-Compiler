// test_fs_pure.lyx
// Einfaches Testprogramm für die Pure Syscall FS-API

// ============================================================================
// Externe Assembler-Funktionen
// ============================================================================

extern fn _lyx_syscall3(num: int64, a1: int64, a2: int64, a3: int64): int64;
extern fn _lyx_is_error(result: int64): bool;

// ============================================================================
// Syscall-Nummern
// ============================================================================

con SYS_WRITE: int64 := 1;
con SYS_OPEN: int64 := 2;
con SYS_CLOSE: int64 := 3;

// ============================================================================
// Hauptprogramm
// ============================================================================

pub fn main(): int64 {
  var result: int64 := 0;
  
  // Test 1: write syscall
  var msg1: pchar := "Test 1: write syscall";
  var msg1_addr: int64 := msg1 as int64;
  _lyx_syscall3(SYS_WRITE, 1, msg1_addr, 20);
  
  // Test 2: Datei erstellen
  var filename: pchar := "testfile.txt";
  var filename_addr: int64 := filename as int64;
  var fd: int64 := _lyx_syscall3(SYS_OPEN, filename_addr, 577, 420);
  
  if (fd >= 0) {
    var msg2: pchar := "File opened";
    var msg2_addr: int64 := msg2 as int64;
    _lyx_syscall3(SYS_WRITE, 1, msg2_addr, 12);
    
    // In Datei schreiben
    var content: pchar := "hello\n";
    var content_addr: int64 := content as int64;
    var wr: int64 := _lyx_syscall3(SYS_WRITE, fd, content_addr, 6);
    
    if (wr == 6) {
      var msg3: pchar := "Written 6 bytes";
      var msg3_addr: int64 := msg3 as int64;
      _lyx_syscall3(SYS_WRITE, 1, msg3_addr, 15);
      result := result + 1;
    }
    
    // Datei schließen
    var cr: int64 := _lyx_syscall3(SYS_CLOSE, fd, 0, 0);
    
    if (cr == 0) {
      var msg4: pchar := "File closed";
      var msg4_addr: int64 := msg4 as int64;
      _lyx_syscall3(SYS_WRITE, 1, msg4_addr, 12);
    }
  } else {
    var msg5: pchar := "Open failed";
    var msg5_addr: int64 := msg5 as int64;
    _lyx_syscall3(SYS_WRITE, 1, msg5_addr, 11);
  }
  
  // Test 3: Fehlerbehandlung
  var err_test1: bool := _lyx_is_error(5);
  var err_test2: bool := _lyx_is_error(-5);
  
  if (!err_test1 && err_test2) {
    var msg6: pchar := "Error detection OK";
    var msg6_addr: int64 := msg6 as int64;
    _lyx_syscall3(SYS_WRITE, 1, msg6_addr, 19);
    result := result + 1;
  }
  
  // Zusammenfassung
  if (result >= 2) {
    var msg7: pchar := "TESTS PASSED";
    var msg7_addr: int64 := msg7 as int64;
    _lyx_syscall3(SYS_WRITE, 1, msg7_addr, 12);
    return 0;
  } else {
    var msg8: pchar := "TESTS FAILED";
    var msg8_addr: int64 := msg8 as int64;
    _lyx_syscall3(SYS_WRITE, 1, msg8_addr, 12);
    return 1;
  }
}
