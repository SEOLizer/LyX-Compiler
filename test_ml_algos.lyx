// Test new ML algorithms
import std.io;
import std.ml;

pub fn main(): int64 {
  PrintStr("=== k-NN Test ===\n");
  KNNInit2(1, 1.0, 3.0, 0.0, 1.0);  // x=1: class 0, x=3: class 1
  var pred_knn: int64 := KNNPredict(2.5);
  PrintStr("KNNPredict(2.5) = ");
  PrintInt(pred_knn);
  PrintStr("\n");
  
  PrintStr("\n=== k-Means Test ===\n");
  KMeansInit2(0.0, 4.0);  // Initial centroids
  KMeansFit2(1.0, 3.0, 10);  // Fit with 2 points, 10 iterations
  PrintStr("KMeansCentroid0 = ");
  PrintFloat(KMeansCentroid0());
  PrintStr("\nKMeansCentroid1 = ");
  PrintFloat(KMeansCentroid1());
  PrintStr("\nKMeansPredict(1.5) = ");
  PrintInt(KMeansPredict(1.5));
  PrintStr("\n");
  
  PrintStr("\n=== Normalization Test ===\n");
  var normed: f64 := MinMaxNorm(5.0, 0.0, 10.0);
  PrintStr("MinMaxNorm(5, 0, 10) = ");
  PrintFloat(normed);
  PrintStr("\nMinMaxDenorm(0.5, 0, 10) = ");
  PrintFloat(MinMaxDenorm(0.5, 0.0, 10.0));
  PrintStr("\nZScoreNorm(5, 2, 2) = ");
  PrintFloat(ZScoreNorm(5.0, 2.0, 2.0));
  PrintStr("\n");
  
  PrintStr("\n=== Train/Test Split ===\n");
  var i: int64 := 0;
  while (i < 4) {
    PrintStr("Split(");
    PrintInt(i);
    PrintStr(") = ");
    var split: int64 := TrainTestSplit(i);
    if (split == 0) { PrintStr("train"); }
    else { PrintStr("test"); }
    PrintStr("\n");
    i := i + 1;
  }
  
  return 0;
}