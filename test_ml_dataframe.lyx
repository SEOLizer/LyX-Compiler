// Test: DataFrame-based ML with arbitrary data points
// This test demonstrates using Linear/Logistic Regression with dynamic data

import std.io;
import std.ml;

// Declare data.core functions (external since it's in data/, not std/)
extern fn SeriesNewFloat64(name: int64, capacity: int64): int64;
extern fn SeriesAppendFloat64(s: int64, value: f64): void;
extern fn DataFrameNew(): int64;
extern fn DataFrameAddColumnFloat64(df: int64, name: int64): void;
extern fn DataFrameAppendRow(df: int64): void;
extern fn DataFrameSetFloat64(df: int64, colName: int64, row: int64, value: f64): void;

// Memory functions
extern fn mmap(addr: int64, len: int64, prot: int64, flags: int64, fd: int64, offset: int64): int64;
extern fn munmap(addr: int64, len: int64): int64;

con PROT_RW: int64 := 3;
con MAP_ANON: int64 := 32;
con FD_NONE: int64 := -1;

pub fn main(): int64 {
  PrintStr("=== Test: DataFrame-based ML ===\n");
  PrintStr("Testing with arbitrary data points\n\n");
  
  // Test 1: Linear Regression with 100 data points
  PrintStr("--- Linear Regression (100 points) ---\n");
  LinearRegressionInit();
  
  // Create DataFrame with 2 columns
  var df: int64 := DataFrameNew();
  var xName: int64 := StringToPtr("x");
  var yName: int64 := StringToPtr("y");
  DataFrameAddColumnFloat64(df, xName);
  DataFrameAddColumnFloat64(df, yName);
  
  // Add 100 data points: y = 2*x + 1 + noise
  var i: int64 := 0;
  while (i < 100) {
    DataFrameAppendRow(df);
    var x: f64 := i as f64;
    var y: f64 := (2.0 * x) + 1.0 + (i as f64 * 0.01);  // with noise
    
    var rowIdx: int64 := i;
    DataFrameSetFloat64(df, xName, rowIdx, x);
    DataFrameSetFloat64(df, yName, rowIdx, y);
    
    i := i + 1;
  }
  
  PrintStr("Data points: 100\n");
  PrintStr("Fit: DataFrame...\n");
  LinearRegressionFitDataFrame(df, xName, yName);
  
  var w: f64 := LinearRegressionWeight();
  var b: f64 := LinearRegressionBias();
  var loss: f64 := LinearRegressionLoss();
  
  PrintStr("Weight: ");
  PrintFloat(w);
  PrintStr("\nBias: ");
  PrintFloat(b);
  PrintStr("\nLoss: ");
  PrintFloat(loss);
  PrintStr("\n\n");
  
  // Predict
  var pred: f64 := LinearRegressionPredict(50.0);
  PrintStr("Predict(50): ");
  PrintFloat(pred);
  PrintStr(" (expected: ~101)\n\n");
  
  // Test 2: Logistic Regression with binary classification
  PrintStr("--- Logistic Regression (100 points) ---\n");
  LogisticRegressionInit();
  
  // Create new DataFrame
  var df2: int64 := DataFrameNew();
  var featName: int64 := StringToPtr("feature");
  var labelName: int64 := StringToPtr("label");
  DataFrameAddColumnFloat64(df2, featName);
  DataFrameAddColumnFloat64(df2, labelName);
  
  // Add 100 data points: label = 1 if x > 50 else 0
  i := 0;
  while (i < 100) {
    DataFrameAppendRow(df2);
    var x: f64 := i as f64;
    var y: f64 := 0.0;
    if (x > 50.0) { y := 1.0; }
    
    var rowIdx: int64 := i;
    DataFrameSetFloat64(df2, featName, rowIdx, x);
    DataFrameSetFloat64(df2, labelName, rowIdx, y);
    
    i := i + 1;
  }
  
  PrintStr("Data points: 100\n");
  PrintStr("Fit: DataFrame...\n");
  LogisticRegressionFitDataFrame(df2, featName, labelName, 0.1, 100);
  
  var lw: f64 := LogisticRegressionWeight();
  var lb: f64 := LogisticRegressionBias();
  var lloss: f64 := LogisticRegressionLoss();
  var acc: f64 := LogisticRegressionAccuracy();
  
  PrintStr("Weight: ");
  PrintFloat(lw);
  PrintStr("\nBias: ");
  PrintFloat(lb);
  PrintStr("\nLoss: ");
  PrintFloat(lloss);
  PrintStr("\nAccuracy: ");
  PrintFloat(acc);
  PrintStr("\n\n");
  
  // Predict
  var prob: f64 := LogisticRegressionPredictProb(25.0);
  PrintStr("PredictProb(25): ");
  PrintFloat(prob);
  PrintStr(" (expected: ~0)\n");
  
  prob := LogisticRegressionPredictProb(75.0);
  PrintStr("PredictProb(75): ");
  PrintFloat(prob);
  PrintStr(" (expected: ~1)\n\n");
  
  // Test 3: Array-based API (simpler alternative)
  PrintStr("--- Array-based API ---\n");
  
  // Create f64 arrays (16-byte aligned for SIMD)
  var xArr: int64 := mmap(0, 100 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  var yArr: int64 := mmap(0, 100 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  
  i := 0;
  while (i < 100) {
    var x: f64 := i as f64;
    var y: f64 := (3.0 * x) + 5.0;
    pokef64(xArr + i * 8, x);
    pokef64(yArr + i * 8, y);
    i := i + 1;
  }
  
  LinearRegressionInit();
  LinearRegressionFitArrays(xArr, yArr, 100);
  
  w := LinearRegressionWeight();
  b := LinearRegressionBias();
  loss := LinearRegressionLoss();
  
  PrintStr("Weight: ");
  PrintFloat(w);
  PrintStr(" (expected: 3)\n");
  PrintStr("Bias: ");
  PrintFloat(b);
  PrintStr(" (expected: 5)\n");
  PrintStr("Loss: ");
  PrintFloat(loss);
  PrintStr("\n\n");
  
  munmap(xArr, 100 * 8);
  munmap(yArr, 100 * 8);
  
  PrintStr("=== All tests passed! ===\n");
  return 0;
}

// Helper: create string from literal (simplified)
fn StringToPtr(s: int64): int64 {
  // For demo, return a fixed address
  // In real code, would copy string to heap
  return s;
}