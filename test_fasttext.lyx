// test_fasttext.lyx - FastText Integration Test
// Tests the fastText wrapper API

import std.io;
import std.fasttext;

pub fn main(): int64 {
  PrintStr("=== FastText API Test ===\n\n");
  
  // Test 1: Training parameters
  PrintStr("[Test 1] Training Configuration\n");
  PrintStr("Training parameters defined:\n");
  PrintStr("  - Input file: train.txt\n");
  PrintStr("  - Output: model.bin\n");
  PrintStr("  - Learning rate: 0.1\n");
  PrintStr("  - Dimension: 100\n");
  PrintStr("  - Window: 5\n");
  PrintStr("  - Epochs: 50\n\n");
  
  // Test 2: Model loading (placeholder)
  PrintStr("[Test 2] Model Loading\n");
  var model: int64 := FastTextLoadModel("model.bin");
  if (model == 0) {
    PrintStr("Model not found (expected - no model file yet)\n");
  } else {
    PrintStr("Model loaded: ");
    PrintInt(model);
    PrintStr("\n");
  }
  PrintStr("\n");
  
  // Test 3: Prediction (placeholder - no model)
  PrintStr("[Test 3] Prediction\n");
  PrintStr("Text: \"This is amazing!\"\n");
  PrintStr("Prediction: (would call FastTextPredict)\n\n");
  
  // Test 4: Word vectors (placeholder)
  PrintStr("[Test 4] Word Vectors\n");
  PrintStr("Get vector for \"king\": ");
  var vec_ptr: int64 := FastTextGetVector(model, "king");
  PrintInt(vec_ptr);
  PrintStr(" (pointer to float array)\n\n");
  
  // Test 5: Nearest neighbors (placeholder)
  PrintStr("[Test 5] Nearest Neighbors\n");
  PrintStr("Find 5 nearest to \"cat\": (would call FastTextNearest)\n\n");
  
  // Test 6: Analogies (placeholder)
  PrintStr("[Test 6] Analogies\n");
  PrintStr("king - man + woman = (would call FastTextAnalogy)\n\n");
  
  // Test 7: Model info (placeholder)
  PrintStr("[Test 7] Model Information\n");
  var dim: int64 := FastTextGetDimension(model);
  var vocab: int64 := FastTextGetVocabSize(model);
  var labels: int64 := FastTextGetNumLabels(model);
  PrintStr("Dimension: ");
  PrintInt(dim);
  PrintStr("\nVocabulary: ");
  PrintInt(vocab);
  PrintStr("\nLabels: ");
  PrintInt(labels);
  PrintStr("\n\n");
  
  // Cleanup
  if (model != 0) {
    FastTextFree(model);
  }
  
  PrintStr("=== Done ===\n");
  
  return 0;
}