// test_fasttext.lyx - FastText Integration Test

import std.io;
import std.fasttext;

pub fn main(): int64 {
  PrintStr("=== FastText API Test ===\n\n");

  // Test 1: Configuration
  PrintStr("[Test 1] Configuration\n");
  FastTextSetDimension(50);
  FastTextSetLearningRate(0.1);
  FastTextSetWindow(3);
  PrintStr("  dimension: ");
  PrintInt(FastTextGetDimension());
  PrintStr("\n\n");

  // Test 2: Vocab init (small corpus)
  PrintStr("[Test 2] Vocab Init\n");
  FastTextInitVocab(10);
  PrintStr("  vocab_size: ");
  PrintInt(FastTextGetVocabSize());
  PrintStr("\n\n");

  // Test 3: Embedding access
  PrintStr("[Test 3] Embedding Access\n");
  var vec0: int64 := FastTextGetEmbeddingAt(0);
  var vec1: int64 := FastTextGetEmbeddingAt(1);
  PrintStr("  vec[0] ptr: ");
  PrintInt(vec0);
  PrintStr("\n  vec[1] ptr: ");
  PrintInt(vec1);
  PrintStr("\n\n");

  // Test 4: Dot product & norm
  PrintStr("[Test 4] Dot Product & Norm\n");
  var dot: f64 := FastTextDotProduct(vec0, vec1);
  var norm0: f64 := FastTextVectorNorm(vec0);
  PrintStr("  dot(v0,v1): ");
  PrintFloat(dot);
  PrintStr("\n  norm(v0):   ");
  PrintFloat(norm0);
  PrintStr("\n\n");

  // Test 5: Normalize
  PrintStr("[Test 5] Normalize\n");
  FastTextNormalize(vec0);
  var norm_after: f64 := FastTextVectorNorm(vec0);
  PrintStr("  norm(v0) after normalize: ");
  PrintFloat(norm_after);
  PrintStr("\n\n");

  // Test 6: Skipgram training step
  PrintStr("[Test 6] Skipgram Training Step\n");
  FastTextTrainSkipgramSGD(0, 1, 0.05);
  PrintStr("  done\n\n");

  // Test 7: Negative sampling
  PrintStr("[Test 7] Negative Sampling\n");
  var neg: int64 := FastTextSampleNegative(0);
  PrintStr("  negative sample for word 0: ");
  PrintInt(neg);
  PrintStr("\n\n");

  // Test 8: Nearest neighbor
  PrintStr("[Test 8] Nearest Neighbor\n");
  var results: int64 := FastTextFindNearest(vec0, 3);
  PrintStr("  top-3 result ptr: ");
  PrintInt(results);
  PrintStr("\n\n");

  // Test 9: Analogies
  PrintStr("[Test 9] Analogies\n");
  var analogy: int64 := FastTextAnalogies(2, 3, 4);
  PrintStr("  analogy(2-3+4) ptr: ");
  PrintInt(analogy);
  PrintStr("\n\n");

  // Test 10: Cleanup
  PrintStr("[Test 10] Cleanup\n");
  FastTextFree();
  PrintStr("  freed\n\n");

  PrintStr("=== Done ===\n");
  return 0;
}
