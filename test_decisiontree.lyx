// Test: Decision Tree Classifier
// Tests recursive tree building and OOP in Lyx

import std.io;
import std.ml;

extern fn mmap(addr: int64, len: int64, prot: int64, flags: int64, fd: int64, offset: int64): int64;
extern fn munmap(addr: int64, len: int64): int64;

con PROT_RW: int64 := 3;
con MAP_ANON: int64 := 32;
con FD_NONE: int64 := -1;

pub fn main(): int64 {
  PrintStr("=== Test: Decision Tree Classifier ===\n\n");
  
  // Create simple dataset
  // 3 features, 2 classes
  var n: int64 := 20;
  var nFeatures: int64 := 3;
  var nClasses: int64 := 2;
  
  var features: int64 := mmap(0, n * nFeatures * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  var labels: int64 := mmap(0, n * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  
  // Feature 0: income (< 50 = low, >= 50 = high)
  // Feature 1: age (< 30 = young, >= 30 = old)
  // Feature 2: education years
  
  // Class 0: low income
  // Class 1: high income
  
  // Training data
  var i: int64 := 0;
  
  // Low income samples (class 0)
  pokef64(features + 0, 30.0); pokef64(features + 8, 25.0); pokef64(features + 16, 12.0);
  poke8(labels + 0, 0);
  pokef64(features + 24, 35.0); pokef64(features + 32, 22.0); pokef64(features + 40, 10.0);
  poke8(labels + 8, 0);
  pokef64(features + 48, 40.0); pokef64(features + 56, 28.0); pokef64(features + 64, 14.0);
  poke8(labels + 16, 0);
  pokef64(features + 72, 25.0); pokef64(features + 80, 35.0); pokef64(features + 88, 8.0);
  poke8(labels + 24, 0);
  pokef64(features + 96, 45.0); pokef64(features + 104, 29.0); pokef64(features + 112, 16.0);
  poke8(labels + 32, 0);
  pokef64(features + 120, 38.0); pokef64(features + 128, 40.0); pokef64(features + 136, 12.0);
  poke8(labels + 40, 0);
  pokef64(features + 144, 42.0); pokef64(features + 152, 23.0); pokef64(features + 160, 10.0);
  poke8(labels + 48, 0);
  pokef64(features + 168, 28.0); pokef64(features + 176, 50.0); pokef64(features + 184, 16.0);
  poke8(labels + 56, 0);
  pokef64(features + 192, 33.0); pokef64(features + 200, 38.0); pokef64(features + 208, 14.0);
  poke8(labels + 64, 0);
  
  // High income samples (class 1)
  pokef64(features + 216, 60.0); pokef64(features + 224, 35.0); pokef64(features + 232, 16.0);
  poke8(labels + 72, 1);
  pokef64(features + 240, 75.0); pokef64(features + 248, 42.0); pokef64(features + 256, 18.0);
  poke8(labels + 80, 1);
  pokef64(features + 264, 55.0); pokef64(features + 272, 38.0); pokef64(features + 280, 14.0);
  poke8(labels + 88, 1);
  pokef64(features + 288, 80.0); pokef64(features + 296, 45.0); pokef64(features + 304, 20.0);
  poke8(labels + 96, 1);
  pokef64(features + 312, 65.0); pokef64(features + 320, 52.0); pokef64(features + 328, 16.0);
  poke8(labels + 104, 1);
  pokef64(features + 336, 70.0); pokef64(features + 344, 33.0); pokef64(features + 352, 18.0);
  poke8(labels + 112, 1);
  pokef64(features + 360, 58.0); pokef64(features + 368, 40.0); pokef64(features + 376, 12.0);
  poke8(labels + 120, 1);
  pokef64(features + 384, 85.0); pokef64(features + 392, 48.0); pokef64(features + 400, 22.0);
  poke8(labels + 128, 1);
  pokef64(features + 408, 72.0); pokef64(features + 416, 55.0); pokef64(features + 424, 16.0);
  poke8(labels + 136, 1);
  
  PrintStr("Training samples: 20\n");
  PrintStr("Features: 3 (income, age, education)\n");
  PrintStr("Classes: 2 (low/high income)\n\n");
  
  // Train with different criteria
  PrintStr("--- Decision Tree with Gini ---\n");
  DecisionTreeInit(5, DT_GINI);
  DecisionTreeFit(features, labels, n, nFeatures, nClasses);
  
  var scoreGini: f64 := DecisionTreeScore(features, labels, n);
  PrintStr("Gini training accuracy: ");
  PrintFloat(scoreGini * 100.0);
  PrintStr("%\n");
  
  PrintStr("--- Decision Tree with Entropy ---\n");
  DecisionTreeInit(5, DT_ENTROPY);
  DecisionTreeFit(features, labels, n, nFeatures, nClasses);
  
  var scoreEnt: f64 := DecisionTreeScore(features, labels, n);
  PrintStr("Entropy training accuracy: ");
  PrintFloat(scoreEnt * 100.0);
  PrintStr("%\n\n");
  
  // Test predictions
  PrintStr("--- Predictions ---\n");
  
  // Test: young, low income
  var test1: int64 := mmap(0, 3 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  pokef64(test1 + 0, 35.0);  // income
  pokef64(test1 + 8, 25.0);   // age
  pokef64(test1 + 16, 12.0); // education
  var pred1: int64 := DecisionTreePredict(test1);
  PrintStr("Predict(35k, 25y, 12yr): ");
  if (pred1 == 0) { PrintStr("LOW income"); }
  else { PrintStr("HIGH income"); }
  PrintStr("\n");
  
  // Test: older, high income
  pokef64(test1 + 0, 70.0);
  pokef64(test1 + 8, 45.0);
  pokef64(test1 + 16, 18.0);
  pred1 := DecisionTreePredict(test1);
  PrintStr("Predict(70k, 45y, 18yr): ");
  if (pred1 == 0) { PrintStr("LOW income"); }
  else { PrintStr("HIGH income"); }
  PrintStr("\n");
  
  // Test: middle
  pokef64(test1 + 0, 50.0);
  pokef64(test1 + 8, 35.0);
  pokef64(test1 + 16, 14.0);
  pred1 := DecisionTreePredict(test1);
  PrintStr("Predict(50k, 35y, 14yr): ");
  if (pred1 == 0) { PrintStr("LOW income"); }
  else { PrintStr("HIGH income"); }
  PrintStr("\n\n");
  
  // Different depths
  PrintStr("--- Different Depths ---\n");
  
  var depth: int64 := 1;
  while (depth <= 5) {
    DecisionTreeInit(depth, DT_GINI);
    DecisionTreeFit(features, labels, n, nFeatures, nClasses);
    var scoreD: f64 := DecisionTreeScore(features, labels, n);
    PrintStr("Depth ");
    PrintInt(depth);
    PrintStr(": ");
    PrintFloat(scoreD * 100.0);
    PrintStr("%\n");
    depth := depth + 1;
  }
  
  // Test probability output
  var proba: int64 := DecisionTreePredictProba(test1, nClasses);
  if (proba != 0) {
    PrintStr("\nProbs for (50k, 35y, 14yr): ");
    var p0: f64 := peekf64(proba + 0);
    var p1: f64 := peekf64(proba + 8);
    PrintFloat(p0 * 100.0);
    PrintStr("% class 0, ");
    PrintFloat(p1 * 100.0);
    PrintStr("% class 1\n");
    munmap(proba, nClasses * 8);
  }
  
  munmap(test1, 3 * 8);
  munmap(features, n * nFeatures * 8);
  munmap(labels, n * 8);
  
  PrintStr("\n=== Decision Tree Test Complete ===\n");
  return 0;
}