@energy(1)
fn low_energy_func(): int64 {
  var x: int64 := 0;
  x := x + 1;
  x := x + 2;
  return x;
}

@energy(5)
fn high_energy_func(): int64 {
  var x: int64 := 0;
  x := x + 1;
  x := x + 2;
  return x;
}

fn main(): int64 {
  var result: int64 := 0;
  
  result := low_energy_func();
  result := result + high_energy_func();
  
  PrintStr("Result: ");
  PrintInt(result);
  PrintStr("\n");
  
  return 0;
}
