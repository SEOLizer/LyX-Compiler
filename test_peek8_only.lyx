// Simple test with peek8 - doesn't use StrCharAt
fn main(): int64 {
  var buf: int64 := mmap(0, 32, 3, 34, -1, 0);
  
  // Put "ABC" in buffer
  poke8(buf + 0, 65);  // 'A'
  poke8(buf + 1, 66);  // 'B'
  poke8(buf + 2, 67);  // 'C'
  poke8(buf + 3, 0);
  
  // Use peek8 directly instead of StrCharAt
  PrintStr("peek8: ");
  var i: int64 := 0;
  while i < 3 {
    var c: int64 := peek8(buf + i);
    PrintInt(c);
    PrintStr(" ");
    i := i + 1;
  }
  PrintStr("\n");
  
  munmap(buf, 32);
  return 0;
}