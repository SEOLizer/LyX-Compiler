// Simple test with mmap - same pattern as FileReadAll
fn main(): int64 {
  // Allocate buffer like FileReadAll does
  var buf: int64 := mmap(0, 64, 3, 34, -1, 0);
  
  // Put some data in it manually
  poke8(buf + 0, 84);  // 'T'
  poke8(buf + 1, 101); // 'e'
  poke8(buf + 2, 115); // 's'
  poke8(buf + 3, 116); // 't'
  poke8(buf + 4, 0);
  
  // Read back using peek8
  PrintStr("Testing peek8: ");
  var i: int64 := 0;
  while i < 5 {
    PrintInt(peek8(buf + i));
    PrintStr(" ");
    i := i + 1;
  }
  PrintStr("\n");
  
  munmap(buf, 64);
  return 0;
}