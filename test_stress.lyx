// Test that mimics exactly what lexer.TokText() does
fn main(): int64 {
  // Simulate FileReadAll - read a small file
  var content: int64 := FileReadAll("test_selfhost_minimal.lyx" as pchar);
  if content == 0 {
    PrintStr("FileReadAll failed\n");
    return 1;
  }
  
  var len: int64 := StrLen(content);
  PrintStr("File length: ");
  PrintInt(len);
  PrintStr("\n");
  
  // Now simulate what lexer does:
  // tokStart = 0, tokLen = 2 (first token is "fn")
  var tokenText: int64 := StrSub(content, 0, 2);
  
  PrintStr("Token at 0, len 2: ");
  var i: int64 := 0;
  while i < 2 {
    var c: int64 := peek8(tokenText + i);
    PrintInt(c);
    PrintStr(" ");
    i := i + 1;
  }
  PrintStr("\n");
  
  // Another token: start=3, len=4 ("main")
  var tokenText2: int64 := StrSub(content, 3, 4);
  
  PrintStr("Token at 3, len 4: ");
  var j: int64 := 0;
  while j < 4 {
    var c: int64 := peek8(tokenText2 + j);
    PrintInt(c);
    PrintStr(" ");
    j := j + 1;
  }
  PrintStr("\n");
  
  return 0;
}