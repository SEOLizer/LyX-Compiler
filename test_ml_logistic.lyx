// test_ml_logistic.lyx - Logistic Regression Tests
// Binary classification with std.ml

import std.io;
import std.ml;

pub fn main(): int64 {
  PrintStr("=== Logistic Regression Test ===\n");
  
  // Test 1: Simple 2-point binary classification
  PrintStr("\n[Test 1] 2-Point Classification\n");
  LogisticRegressionInit();
  LogisticRegressionFit2(10.0, 100.0, 0.0, 1.0, 0.1, 100);
  
  var prob: f64 := LogisticRegressionPredictProb(50.0);
  PrintStr("P(spam|50 words) = ");
  PrintFloat(prob);
  PrintStr("\n");
  
  var klasse: int64 := LogisticRegressionPredict(50.0);
  PrintStr("Class(50 words) = ");
  PrintInt(klasse);
  PrintStr("\n");
  
  PrintStr("Weight = ");
  PrintFloat(LogisticRegressionWeight());
  PrintStr("\nBias = ");
  PrintFloat(LogisticRegressionBias());
  PrintStr("\n");
  
  // Test 2: Different learning rate
  PrintStr("\n[Test 2] Different Learning Rate\n");
  LogisticRegressionInit();
  LogisticRegressionFit2(0.0, 10.0, 0.0, 1.0, 0.01, 500);
  
  var prob2: f64 := LogisticRegressionPredictProb(5.0);
  PrintStr("P(spam|5 words) = ");
  PrintFloat(prob2);
  PrintStr("\n");
  
  // Test 3: Accuracy tracking
  PrintStr("\n[Test 3] Accuracy\n");
  var acc: f64 := LogisticRegressionAccuracy();
  PrintStr("Training Accuracy = ");
  PrintFloat(acc * 100.0);
  PrintStr("%\n");
  
  // Test 4: Loss tracking
  PrintStr("\n[Test 4] Loss\n");
  var loss: f64 := LogisticRegressionLoss();
  PrintStr("Training Loss (MSE) = ");
  PrintFloat(loss);
  PrintStr("\n");
  
  PrintStr("\n=== Done ===\n");
  
  return 0;
}