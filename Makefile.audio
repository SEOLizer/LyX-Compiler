# Makefile für MP3 Audio Player
#
# Installiert benötigte Pakete:
#   Debian/Ubuntu: sudo apt-get install libasound2-dev
#   Fedora/RedHat: sudo dnf install alsa-lib-devel

CC = gcc
CFLAGS = -Wall -Wextra -O2 -g
LDFLAGS = -lasound -lm

# Ziel
TARGET = audio_player
SOURCE = audio_player.c

$(TARGET): $(SOURCE)
	$(CC) $(CFLAGS) -o $(TARGET) $(SOURCE) $(LDFLAGS)

clean:
	rm -f $(TARGET)

run: $(TARGET)
	./$(TARGET) test.mp3

.PHONY: clean run