// Head: first N rows
pub fn DataFrameHead(df: DataFrame, n: int64): DataFrame {
  if (n > df.rowCount) { n := df.rowCount; }
  return DataFrameSlice(df, 0, n);
}

// Tail: last N rows
pub fn DataFrameTail(df: DataFrame, n: int64): DataFrame {
  var start: int64 := df.rowCount - n;
  if (start < 0) { start := 0; }
  return DataFrameSlice(df, start, df.rowCount);
}

// Shape: return (rows, cols) - prints to stdout
pub fn DataFrameShape(df: DataFrame) {
  PrintStr("(");
  PrintInt(df.rowCount);
  PrintStr(", ");
  PrintInt(df.colCount);
  PrintStr(")");
}

// Info: print DataFrame summary
pub fn DataFrameInfo(df: DataFrame) {
  var i: int64 := 0;
  var s: Series;
  
  PrintStr("DataFrame: ");
  DataFrameShape(df);
  PrintStr("\n\n");
  
  PrintStr("Columns:\n");
  while (i < df.colCount) {
    var name: int64 := peek8(df.columns + i * 16);
    s := peek8(df.columns + i * 16 + 8);
    PrintStr("  ");
    if (name != 0) { PrintStr(name); }
    PrintStr(" (");
    if (s.colType == COL_INT64) { PrintStr("int64"); }
    else if (s.colType == COL_FLOAT) { PrintStr("float64"); }
    else if (s.colType == COL_STRING) { PrintStr("string"); }
    else if (s.colType == COL_BOOL) { PrintStr("bool"); }
    PrintStr(")\n");
    i := i + 1;
  }
}

// ============================================================================
// Concat (Append DataFrames)
// ============================================================================

// Concat: append rows from right to left
// Columns must match
pub fn DataFrameConcat(left: DataFrame, right: DataFrame): DataFrame {
  var result: DataFrame := DataFrameNew();
  var i: int64;
  var j: int64;
  var srcS: Series;
  var srcName: int64;
  
  // Add all columns from left
  j := 0;
  while (j < left.colCount) {
    DataFrameAddColumn(result, peek8(left.columns + j * 16), COL_INT64);
    j := j + 1;
  }
  
  // Copy rows from left
  i := 0;
  while (i < left.rowCount) {
    DataFrameAppendRow(result);
    j := 0;
    while (j < left.colCount) {
      srcS := peek8(left.columns + j * 16 + 8);
      DataFrameSetInt(result, peek8(result.columns + j * 16), i, SeriesGetInt(srcS, i));
      j := j + 1;
    }
    i := i + 1;
  }
  
  // Append rows from right
  i := 0;
  while (i < right.rowCount) {
    DataFrameAppendRow(result);
    var newRow: int64 := result.rowCount - 1;
    j := 0;
    while (j < right.colCount) {
      srcS := peek8(right.columns + j * 16 + 8);
      DataFrameSetInt(result, peek8(result.columns + j * 16), newRow, SeriesGetInt(srcS, i));
      j := j + 1;
    }
    i := i + 1;
  }
  
  return result;
}

// ============================================================================
// Replace / Map / Clip
// ============================================================================

// Replace value in column
pub fn DataFrameReplace(df: DataFrame, colName: int64, oldVal: int64, newVal: int64) {
  var s: Series := DataFrameGetSeries(df, colName);
  var i: int64 := 0;
  
  while (i < s.length) {
    if (SeriesGetInt(s, i) == oldVal) {
      SeriesSetInt(s, i, newVal);
    }
    i := i + 1;
  }
}

// Replace value in all columns
pub fn DataFrameReplaceAll(df: DataFrame, oldVal: int64, newVal: int64) {
  var j: int64 := 0;
  while (j < df.colCount) {
    var s: Series := peek8(df.columns + j * 16 + 8);
    var i: int64 := 0;
    while (i < s.length) {
      if (SeriesGetInt(s, i) == oldVal) {
        SeriesSetInt(s, i, newVal);
      }
      i := i + 1;
    }
    j := j + 1;
  }
}

// Map: apply function to column (simplified: multiply by factor)
pub fn DataFrameMapMul(df: DataFrame, colName: int64, factor: int64) {
  var s: Series := DataFrameGetSeries(df, colName);
  var i: int64 := 0;
  
  while (i < s.length) {
    SeriesSetInt(s, i, SeriesGetInt(s, i) * factor);
    i := i + 1;
  }
}

// Map: add constant to column
pub fn DataFrameMapAdd(df: DataFrame, colName: int64, offset: int64) {
  var s: Series := DataFrameGetSeries(df, colName);
  var i: int64 := 0;
  
  while (i < s.length) {
    SeriesSetInt(s, i, SeriesGetInt(s, i) + offset);
    i := i + 1;
  }
}

// Clip: clamp values to [min, max]
pub fn DataFrameClip(df: DataFrame, colName: int64, minValue: int64, maxValue: int64) {
  var s: Series := DataFrameGetSeries(df, colName);
  var i: int64 := 0;
  var val: int64;
  
  while (i < s.length) {
    val := SeriesGetInt(s, i);
    if (val < minValue) {
      SeriesSetInt(s, i, minValue);
    } else if (val > maxValue) {
      SeriesSetInt(s, i, maxValue);
    }
    i := i + 1;
  }
}

// ============================================================================
// Duplicated / DropDuplicates
// ============================================================================

// Check if row is duplicated (based on all columns)
// Returns 1 if same row exists before this index
pub fn SeriesIsDuplicated(s: Series, idx: int64): int64 {
  var i: int64 := 0;
  var val: int64 := SeriesGetInt(s, idx);
  
  while (i < idx) {
    if (SeriesGetInt(s, i) == val) {
      return 1;
    }
    i := i + 1;
  }
  
  return 0;
}

// Drop duplicates (keep first occurrence)
pub fn DataFrameDropDuplicates(df: DataFrame, colName: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var s: Series := DataFrameGetSeries(df, colName);
  var seen: int64 := mmap(0, 1024 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  var seenCount: int64 := 0;
  var i: int64;
  var j: int64;
  var val: int64;
  var found: int64;
  
  // Add all columns
  j := 0;
  while (j < df.colCount) {
    DataFrameAddColumn(result, peek8(df.columns + j * 16), COL_INT64);
    j := j + 1;
  }
  
  // Copy unique rows
  i := 0;
  while (i < df.rowCount) {
    val := SeriesGetInt(s, i);
    found := 0;
    j := 0;
    while (j < seenCount) {
      if (peek8(seen + j * 8) == val) {
        found := 1;
        break;
      }
      j := j + 1;
    }
    
    if (found == 0) {
      // Keep this row
      DataFrameAppendRow(result);
      var newRow: int64 := result.rowCount - 1;
      j := 0;
      while (j < df.colCount) {
        var srcS: Series := peek8(df.columns + j * 16 + 8);
        DataFrameSetInt(result, peek8(result.columns + j * 16), newRow, SeriesGetInt(srcS, i));
        j := j + 1;
      }
      
      poke8(seen + seenCount * 8, val);
      seenCount := seenCount + 1;
    }
    
    i := i + 1;
  }
  
  munmap(seen, 1024 * 8);
  return result;
}

// ============================================================================
// Shift / Diff / CumSum / CumProd
// ============================================================================

// Shift: shift values by N positions (positive = down, negative = up)
// Returns new Series
pub fn SeriesShift(s: Series, n: int64): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var i: int64 := 0;
  
  result.length := s.length;
  
  while (i < s.length) {
    var srcIdx: int64 := i - n;
    if (srcIdx >= 0 && srcIdx < s.length) {
      SeriesSetInt(result, i, SeriesGetInt(s, srcIdx));
    } else {
      SeriesSetInt(result, i, 0);  // NA
    }
    i := i + 1;
  }
  
  return result;
}

// Diff: difference between consecutive elements
pub fn SeriesDiff(s: Series): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var i: int64 := 1;
  
  result.length := s.length;
  SeriesSetInt(result, 0, 0);  // First is NA
  
  while (i < s.length) {
    SeriesSetInt(result, i, SeriesGetInt(s, i) - SeriesGetInt(s, i - 1));
    i := i + 1;
  }
  
  return result;
}

// CumSum: cumulative sum
pub fn SeriesCumSum(s: Series): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var i: int64 := 0;
  var sum: int64 := 0;
  
  result.length := s.length;
  
  while (i < s.length) {
    sum := sum + SeriesGetInt(s, i);
    SeriesSetInt(result, i, sum);
    i := i + 1;
  }
  
  return result;
}

// CumProd: cumulative product
pub fn SeriesCumProd(s: Series): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var i: int64 := 0;
  var prod: int64 := 1;
  
  result.length := s.length;
  
  while (i < s.length) {
    prod := prod * SeriesGetInt(s, i);
    SeriesSetInt(result, i, prod);
    i := i + 1;
  }
  
  return result;
}

// CumMax: cumulative maximum
pub fn SeriesCumMax(s: Series): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var i: int64 := 0;
  var mx: int64;
  
  result.length := s.length;
  
  if (s.length > 0) {
    mx := SeriesGetInt(s, 0);
    SeriesSetInt(result, 0, mx);
    i := 1;
    while (i < s.length) {
      var val: int64 := SeriesGetInt(s, i);
      if (val > mx) {
        mx := val;
      }
      SeriesSetInt(result, i, mx);
      i := i + 1;
    }
  }
  
  return result;
}

// CumMin: cumulative minimum
pub fn SeriesCumMin(s: Series): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var i: int64 := 0;
  var mn: int64;
  
  result.length := s.length;
  
  if (s.length > 0) {
    mn := SeriesGetInt(s, 0);
    SeriesSetInt(result, 0, mn);
    i := 1;
    while (i < s.length) {
      var val: int64 := SeriesGetInt(s, i);
      if (val < mn) {
        mn := val;
      }
      SeriesSetInt(result, i, mn);
      i := i + 1;
    }
  }
  
  return result;
}

// ============================================================================
// Rank
// ============================================================================

// Rank: assign ranks to values (ascending)
// Returns new Series with rank of each element
pub fn SeriesRank(s: Series): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var sorted: int64 := mmap(0, s.length * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  var indices: int64 := mmap(0, s.length * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  var i: int64;
  var j: int64;
  var key: int64;
  var keyIdx: int64;
  
  result.length := s.length;
  
  // Copy values
  i := 0;
  while (i < s.length) {
    poke8(sorted + i * 8, SeriesGetInt(s, i));
    poke8(indices + i * 8, i);
    i := i + 1;
  }
  
  // Sort indices by value
  i := 1;
  while (i < s.length) {
    key := peek8(sorted + i * 8);
    keyIdx := peek8(indices + i * 8);
    j := i - 1;
    while (j >= 0) {
      var jOff8r: int64 := j * 8;
      if (peek8(sorted + jOff8r) <= key) { break; }
      var j1r: int64 := j + 1;
      var j1Off8r: int64 := j1r * 8;
      poke8(sorted + j1Off8r, peek8(sorted + jOff8r));
      poke8(indices + j1Off8r, peek8(indices + jOff8r));
      j := j - 1;
    }
    var j1s: int64 := j + 1;
    var j1Off8s: int64 := j1s * 8;
    poke8(sorted + j1Off8s, key);
    poke8(indices + j1Off8s, keyIdx);
    i := i + 1;
  }
  
  // Assign ranks
  i := 0;
  while (i < s.length) {
    var idx: int64 := peek8(indices + i * 8);
    var rankVal: int64 := i + 1;
    SeriesSetInt(result, idx, rankVal);
    i := i + 1;
  }
  
  munmap(sorted, s.length * 8);
  munmap(indices, s.length * 8);
  
  return result;
}

// ============================================================================
// Median (enhanced)
// ============================================================================

// Median for sorted array
pub fn SeriesMedian(s: Series): int64 {
  var sorted: DataFrame := DataFrameNew();
  DataFrameAddColumn(sorted, "val", COL_INT64);
  var i: int64 := 0;
  while (i < s.length) {
    DataFrameAppendRow(sorted);
    DataFrameSetInt(sorted, "val", i, SeriesGetInt(s, i));
    i := i + 1;
  }
  
  var sortedS: Series := DataFrameGetSeries(sorted, "val");
  // Sort in-place
  i := 1;
  while (i < sortedS.length) {
    var key: int64 := SeriesGetInt(sortedS, i);
    var j: int64 := i - 1;
    while (j >= 0 && SeriesGetInt(sortedS, j) > key) {
      SeriesSetInt(sortedS, j + 1, SeriesGetInt(sortedS, j));
      j := j - 1;
    }
    SeriesSetInt(sortedS, j + 1, key);
    i := i + 1;
  }
  
  var mid: int64 := s.length / 2;
  var result: int64 := SeriesGetInt(sortedS, mid);
  
  return result;
}

// ============================================================================
// DataFrame Reverse
// ============================================================================

// Reverse row order
pub fn DataFrameReverse(df: DataFrame): DataFrame {
  var result: DataFrame := DataFrameNew();
  var i: int64;
  var j: int64;
  var srcS: Series;
  
  // Add all columns
  j := 0;
  while (j < df.colCount) {
    DataFrameAddColumn(result, peek8(df.columns + j * 16), COL_INT64);
    j := j + 1;
  }
  
  // Copy rows in reverse
  i := df.rowCount - 1;
  while (i >= 0) {
    DataFrameAppendRow(result);
    var newRow: int64 := result.rowCount - 1;
    j := 0;
    while (j < df.colCount) {
      srcS := peek8(df.columns + j * 16 + 8);
      DataFrameSetInt(result, peek8(result.columns + j * 16), newRow, SeriesGetInt(srcS, i));
      j := j + 1;
    }
    i := i - 1;
  }
  
  return result;
}


// Slice DataFrame by row range [start, end)
pub fn DataFrameSlice(df: DataFrame, start: int64, endRow: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var i: int64 := start;
  var j: int64 := 0;
  
  if (endRow > df.rowCount) {
    endRow := df.rowCount;
  }
  
  // Add all columns
  while (j < df.colCount) {
    var name: int64 := peek8(df.columns + j * 16);
    var srcS: Series := peek8(df.columns + j * 16 + 8);
    DataFrameAddColumn(result, name, srcS.colType);
    j := j + 1;
  }
  
  // Copy rows
  while (i < endRow) {
    DataFrameAppendRow(result);
    j := 0;
    while (j < df.colCount) {
      var dstS: Series := peek8(result.columns + j * 16 + 8);
      var srcS2: Series := peek8(df.columns + j * 16 + 8);
      if (srcS2.colType == COL_STRING) {
        SeriesSetString(dstS, result.rowCount - 1, SeriesGetString(srcS2, i));
      } else {
        SeriesSetInt(dstS, result.rowCount - 1, SeriesGetInt(srcS2, i));
      }
      j := j + 1;
    }
    i := i + 1;
  }
  
  return result;
}

// ============================================================================
// Column Operations
// ============================================================================

// Drop column by name
pub fn DataFrameDropColumn(df: DataFrame, name: int64) {
  var colIdx: int64 := DataFrameColIndex(df, name);
  var i: int64;
  var srcSeries: Series;
  
  if (colIdx < 0) {
    return;
  }
  
  // Free series
  srcSeries := peek8(df.columns + colIdx * 16 + 8);
  if (srcSeries.data != 0) {
    munmap(srcSeries.data, srcSeries.length * 8);
  }
  
  // Shift columns left
  i := colIdx;
  while (i < df.colCount - 1) {
    var i1c: int64 := i + 1;
    var i1Off16: int64 := i1c * 16;
    var iOff16: int64 := i * 16;
    var i1Off168: int64 := i1Off16 + 8;
    var iOff168: int64 := iOff16 + 8;
    poke8(df.columns + iOff16, peek8(df.columns + i1Off16));
    poke8(df.columns + iOff168, peek8(df.columns + i1Off168));
    i := i + 1;
  }
  
  df.colCount := df.colCount - 1;
}

// Rename column
pub fn DataFrameRenameColumn(df: DataFrame, oldName: int64, newName: int64) {
  var colIdx: int64 := DataFrameColIndex(df, oldName);
  if (colIdx >= 0) {
    poke8(df.columns + colIdx * 16, newName);
  }
}

// ============================================================================
// GroupBy
// ============================================================================

// GroupBy result
pub type GroupByResult = struct {
  df: DataFrame;        // Original DataFrame
  keyCol: int64;        // Pointer to key column name
  groups: int64;        // Pointer to group values (int64 array)
  groupRows: int64;     // Pointer to row indices per group (array of arrays)
  groupCount: int64;    // Number of groups
};

// GroupBy: group rows by column value
pub fn DataFrameGroupBy(df: DataFrame, keyCol: int64): GroupByResult {
  var gb: GroupByResult;
  var s: Series := DataFrameGetSeries(df, keyCol);
  var i: int64 := 0;
  var val: int64;
  var groupIdx: int64;
  var found: int64;
  
  gb.df := df;
  gb.keyCol := keyCol;
  gb.groups := mmap(0, 1024 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  gb.groupRows := mmap(0, 1024 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  gb.groupCount := 0;
  
  // Find unique values
  while (i < df.rowCount) {
    val := SeriesGetInt(s, i);
    found := 0;
    groupIdx := 0;
    while (groupIdx < gb.groupCount) {
      if (peek8(gb.groups + groupIdx * 8) == val) {
        found := 1;
        break;
      }
      groupIdx := groupIdx + 1;
    }
    
    if (found == 0) {
      poke8(gb.groups + gb.groupCount * 8, val);
      // Create row index array for this group
      var rows: int64 := mmap(0, 1024 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
      poke8(rows, i);  // First row
      poke8(gb.groupRows + gb.groupCount * 8, rows);
      poke8(rows - 8, 1);  // Row count at offset -8
      gb.groupCount := gb.groupCount + 1;
    } else {
      // Add row to existing group
      var rows: int64 := peek8(gb.groupRows + groupIdx * 8);
      var count: int64 := peek8(rows - 8);
      poke8(rows + count * 8, i);
      poke8(rows - 8, count + 1);
    }
    
    i := i + 1;
  }
  
  return gb;
}

// GroupBy aggregation: sum
pub fn GroupBySum(gb: GroupByResult, aggCol: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var s: Series := DataFrameGetSeries(gb.df, aggCol);
  var keyS: Series := DataFrameGetSeries(gb.df, gb.keyCol);
  var i: int64 := 0;
  var j: int64;
  var rows: int64;
  var count: int64;
  var sum: int64;
  var val: int64;
  
  DataFrameAddColumn(result, gb.keyCol, keyS.colType);
  DataFrameAddColumn(result, aggCol, COL_INT64);
  
  while (i < gb.groupCount) {
    DataFrameAppendRow(result);
    
    // Set key value
    rows := peek8(gb.groupRows + i * 8);
    val := SeriesGetInt(keyS, peek8(rows));
    DataFrameSetInt(result, gb.keyCol, i, val);
    
    // Sum aggregation
    count := peek8(rows - 8);
    sum := 0;
    j := 0;
    while (j < count) {
      sum := sum + SeriesGetInt(s, peek8(rows + j * 8));
      j := j + 1;
    }
    DataFrameSetInt(result, aggCol, i, sum);
    
    i := i + 1;
  }
  
  return result;
}

// GroupBy aggregation: count
pub fn GroupByCount(gb: GroupByResult): DataFrame {
  var result: DataFrame := DataFrameNew();
  var keyS: Series := DataFrameGetSeries(gb.df, gb.keyCol);
  var i: int64 := 0;
  var rows: int64;
  var count: int64;
  var val: int64;
  
  DataFrameAddColumn(result, gb.keyCol, keyS.colType);
  DataFrameAddColumn(result, "count", COL_INT64);
  
  while (i < gb.groupCount) {
    DataFrameAppendRow(result);
    rows := peek8(gb.groupRows + i * 8);
    count := peek8(rows - 8);
    
    val := SeriesGetInt(keyS, peek8(rows));
    DataFrameSetInt(result, gb.keyCol, i, val);
    DataFrameSetInt(result, "count", i, count);
    
    i := i + 1;
  }
  
  return result;
}

// ============================================================================
// Missing Values
// ============================================================================

// Check if value is NA (0 for int, NULL for string)
pub fn IsNA(value: int64, colType: int64): bool {
  if (colType == COL_STRING) {
    return value == 0;
  }
  return value == 0;
}

// Fill NA values with default
pub fn DataFrameFillNA(df: DataFrame, colName: int64, defaultValue: int64) {
  var s: Series := DataFrameGetSeries(df, colName);
  var i: int64 := 0;
  
  if (s.data == 0) {
    return;
  }
  
  while (i < s.length) {
    if (SeriesGetInt(s, i) == 0) {
      SeriesSetInt(s, i, defaultValue);
    }
    i := i + 1;
  }
}

// Drop rows with NA in specific column
pub fn DataFrameDropNA(df: DataFrame, colName: int64): DataFrame {
  return DataFrameFilter(df, colName, OP_NE, 0);
}

// ============================================================================
// Statistics
// ============================================================================

// Sum of column
pub fn SeriesSum(s: Series): int64 {
  var sum: int64 := 0;
  var i: int64 := 0;
  while (i < s.length) {
    sum := sum + SeriesGetInt(s, i);
    i := i + 1;
  }
  return sum;
}

// Mean of column
pub fn SeriesMean(s: Series): int64 {
  if (s.length == 0) {
    return 0;
  }
  return SeriesSum(s) / s.length;
}

// Min of column
pub fn SeriesMin(s: Series): int64 {
  var i: int64 := 1;
  var mn: int64;
  
  if (s.length == 0) {
    return 0;
  }
  
  mn := SeriesGetInt(s, 0);
  while (i < s.length) {
    var val: int64 := SeriesGetInt(s, i);
    if (val < mn) {
      mn := val;
    }
    i := i + 1;
  }
  return mn;
}

// Max of column
pub fn SeriesMax(s: Series): int64 {
  var i: int64 := 1;
  var mx: int64;
  
  if (s.length == 0) {
    return 0;
  }
  
  mx := SeriesGetInt(s, 0);
  while (i < s.length) {
    var val: int64 := SeriesGetInt(s, i);
    if (val > mx) {
      mx := val;
    }
    i := i + 1;
  }
  return mx;
}

// Count non-zero values
pub fn SeriesCount(s: Series): int64 {
  var count: int64 := 0;
  var i: int64 := 0;
  while (i < s.length) {
    if (SeriesGetInt(s, i) != 0) {
      count := count + 1;
    }
    i := i + 1;
  }
  return count;
}

// Value counts (frequency of each value)
pub fn SeriesValueCounts(s: Series): DataFrame {
  var result: DataFrame := DataFrameNew();
  var values: int64 := mmap(0, 1024 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  var counts: int64 := mmap(0, 1024 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  var uniqueCount: int64 := 0;
  var i: int64 := 0;
  var j: int64;
  var val: int64;
  var found: int64;
  
  // Count occurrences
  while (i < s.length) {
    val := SeriesGetInt(s, i);
    found := 0;
    j := 0;
    while (j < uniqueCount) {
      if (peek8(values + j * 8) == val) {
        var c: int64 := peek8(counts + j * 8);
        poke8(counts + j * 8, c + 1);
        found := 1;
        break;
      }
      j := j + 1;
    }
    if (found == 0) {
      poke8(values + uniqueCount * 8, val);
      poke8(counts + uniqueCount * 8, 1);
      uniqueCount := uniqueCount + 1;
    }
    i := i + 1;
  }
  
  // Build result DataFrame
  DataFrameAddColumn(result, "value", COL_INT64);
  DataFrameAddColumn(result, "count", COL_INT64);
  
  i := 0;
  while (i < uniqueCount) {
    DataFrameAppendRow(result);
    DataFrameSetInt(result, "value", i, peek8(values + i * 8));
    DataFrameSetInt(result, "count", i, peek8(counts + i * 8));
    i := i + 1;
  }
  
  munmap(values, 1024 * 8);
  munmap(counts, 1024 * 8);
  
  return result;
}

// ============================================================================
// Print/Display
// ============================================================================

// Print DataFrame to stdout
pub fn DataFramePrint(df: DataFrame) {
  var i: int64 := 0;
  var j: int64 := 0;
  var s: Series;
  var val: int64;
  
  // Print column names
  PrintStr("| ");
  j := 0;
  while (j < df.colCount) {
    var name: int64 := peek8(df.columns + j * 16);
    if (name != 0) {
      PrintStr(name);
    } else {
      PrintStr("(unnamed)");
    }
    PrintStr(" | ");
    j := j + 1;
  }
  PrintStr("\n");
  
  // Print separator
  PrintStr("|");
  j := 0;
  while (j < df.colCount) {
    PrintStr("--------|");
    j := j + 1;
  }
  PrintStr("\n");
  
  // Print rows
  i := 0;
  while (i < df.rowCount) {
    PrintStr("| ");
    j := 0;
    while (j < df.colCount) {
      s := peek8(df.columns + j * 16 + 8);
      if (s.colType == COL_STRING) {
        var str: int64 := SeriesGetString(s, i);
        if (str != 0) {
          PrintStr(str);
        } else {
          PrintStr("NULL");
        }
      } else {
        val := SeriesGetInt(s, i);
        PrintInt(val);
      }
      PrintStr(" | ");
      j := j + 1;
    }
    PrintStr("\n");
    i := i + 1;
  }
  
  PrintStr("\n[");
  PrintInt(df.rowCount);
  PrintStr(" rows x ");
  PrintInt(df.colCount);
  PrintStr(" columns]\n");
}

// ============================================================================
// Float Support (f64 columns)
// ============================================================================

// Float data stored as int64 bit pattern (reinterpretation)
// f64 value stored as int64 bits in the series

// Set float value (stored as int64 bits)
pub fn DataFrameSetFloat(df: DataFrame, colName: int64, row: int64, value: int64) {
  var s: Series := DataFrameGetSeries(df, colName);
  if (s.data != 0) {
    SeriesSetInt(s, row, value);
  }
}

// Get float value (as int64 bits)
pub fn DataFrameGetFloat(df: DataFrame, colName: int64, row: int64): int64 {
  var s: Series := DataFrameGetSeries(df, colName);
  if (s.data == 0) {
    return 0;
  }
  return SeriesGetInt(s, row);
}

// Float series sum (using int64 representation)
// Note: This is approximate for small values
pub fn SeriesSumFloat(s: Series): int64 {
  var sum: int64 := 0;
  var i: int64 := 0;
  while (i < s.length) {
    sum := sum + SeriesGetInt(s, i);
    i := i + 1;
  }
  return sum;
}

// Float series mean
pub fn SeriesMeanFloat(s: Series): int64 {
  if (s.length == 0) {
    return 0;
  }
  return SeriesSumFloat(s) / s.length;
}

