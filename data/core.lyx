    if (peek8(bs.data + i * 8) == 1) { return 1; }
    i := i + 1;
  }
  return 0;
}

// Check if all values are true
pub fn BoolSeriesAll(bs: BoolSeries): int64 {
  var i: int64 := 0;
  while (i < bs.length) {
    if (peek8(bs.data + i * 8) == 0) { return 0; }
    i := i + 1;
  }
