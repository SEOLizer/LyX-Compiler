// Aggregate functions enum
pub con AGG_SUM: int64 := 1;
pub con AGG_MEAN: int64 := 2;
pub con AGG_MIN: int64 := 3;
pub con AGG_MAX: int64 := 4;
pub con AGG_COUNT: int64 := 5;
pub con AGG_STD: int64 := 6;

// Apply aggregation to single column
pub fn SeriesAgg(s: Series, aggType: int64): int64 {
  if (aggType == AGG_SUM) { return SeriesSum(s); }
  if (aggType == AGG_MEAN) { return SeriesMean(s); }
  if (aggType == AGG_MIN) { return SeriesMin(s); }
  if (aggType == AGG_MAX) { return SeriesMax(s); }
  if (aggType == AGG_COUNT) { return SeriesCount(s); }
  return 0;
}

// DataFrame agg: apply aggregation to all columns
pub fn DataFrameAgg(df: DataFrame, aggType: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var i: int64 := 0;
  var s: Series;
  var name: int64;
  
  while (i < df.colCount) {
    name := peek8(df.columns + i * 16);
    s := peek8(df.columns + i * 16 + 8);
    
    DataFrameAddColumn(result, name, COL_INT64);
    DataFrameAppendRow(result);
    
    var val: int64 := SeriesAgg(s, aggType);
    DataFrameSetInt(result, name, 0, val);
    
    i := i + 1;
  }
  
  return result;
}

// Aggregation result for GroupBy with multiple aggregations
pub type AggResult = struct {
  sum: int64;
  mean: int64;
  min: int64;
  max: int64;
  count: int64;
};

// Multi-aggregation on Series
pub fn SeriesAggMulti(s: Series): AggResult {
  var r: AggResult;
  r.sum := SeriesSum(s);
  r.count := SeriesCount(s);
  if (r.count > 0) {
    r.mean := r.sum / r.count;
  } else {
    r.mean := 0;
  }
  r.min := SeriesMin(s);
  r.max := SeriesMax(s);
  return r;
}

// GroupBy + Multi-Agg
pub fn GroupByAgg(gb: GroupByResult, aggCol: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var aggS: Series := DataFrameGetSeries(gb.df, aggCol);
  var keyS: Series := DataFrameGetSeries(gb.df, gb.keyCol);
  var i: int64 := 0;
  var j: int64;
  var rows: int64;
  var count: int64;
  var sum: int64;
  var mn: int64;
  var mx: int64;
  
  DataFrameAddColumn(result, gb.keyCol, COL_INT64);
  DataFrameAddColumn(result, "count", COL_INT64);
  DataFrameAddColumn(result, "sum", COL_INT64);
  DataFrameAddColumn(result, "mean", COL_INT64);
  DataFrameAddColumn(result, "min", COL_INT64);
  DataFrameAddColumn(result, "max", COL_INT64);
  
  while (i < gb.groupCount) {
    DataFrameAppendRow(result);
    rows := peek8(gb.groupRows + i * 8);
    count := peek8(rows - 8);
    
    DataFrameSetInt(result, gb.keyCol, i, SeriesGetInt(keyS, peek8(rows)));
    
    sum := 0; mn := SeriesGetInt(aggS, peek8(rows)); mx := mn;
    j := 0;
    while (j < count) {
      var val: int64 := SeriesGetInt(aggS, peek8(rows + j * 8));
      sum := sum + val;
      if (val < mn) { mn := val; }
      if (val > mx) { mx := val; }
      j := j + 1;
    }
    
    DataFrameSetInt(result, "count", i, count);
    DataFrameSetInt(result, "sum", i, sum);
    DataFrameSetInt(result, "mean", i, sum / count);
    DataFrameSetInt(result, "min", i, mn);
    DataFrameSetInt(result, "max", i, mx);
    
    i := i + 1;
  }
  
  return result;
}

// Transform: multiply all values in column by factor
pub fn SeriesTransformMul(s: Series, factor: int64): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var i: int64 := 0;
  result.length := s.length;
  while (i < s.length) {
    SeriesSetInt(result, i, SeriesGetInt(s, i) * factor);
    i := i + 1;
  }
  return result;
}

// Transform: add constant to all values
pub fn SeriesTransformAdd(s: Series, offset: int64): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var i: int64 := 0;
  result.length := s.length;
  while (i < s.length) {
    SeriesSetInt(result, i, SeriesGetInt(s, i) + offset);
    i := i + 1;
  }
  return result;
}

// Transform: normalize to 0-1 range
pub fn SeriesTransformNormalize(s: Series): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var mn: int64 := SeriesMin(s);
  var mx: int64 := SeriesMax(s);
  var range: int64 := mx - mn;
  var i: int64 := 0;
  result.length := s.length;
  if (range == 0) { range := 1; }
  while (i < s.length) {
    var val: int64 := SeriesGetInt(s, i);
    SeriesSetInt(result, i, ((val - mn) * 1000) / range);
    i := i + 1;
  }
  return result;
}

