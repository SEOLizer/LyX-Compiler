// ============================================================================
// Interpolate
// ============================================================================

// Interpolate missing values (linear)
pub fn SeriesInterpolate(s: Series): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var i: int64 := 0;
  var lastValid: int64 := 0;
  var lastValidIdx: int64 := -1;
  var nextValid: int64 := 0;
  var nextValidIdx: int64 := -1;
  
  result.length := s.length;
  
  while (i < s.length) {
    var val: int64 := SeriesGetInt(s, i);
    if (val != 0) {
      SeriesSetInt(result, i, val);
      lastValid := val;
      lastValidIdx := i;
    } else {
      // Find next valid value
      if (nextValidIdx <= i) {
        var j: int64 := i + 1;
        nextValidIdx := -1;
        while (j < s.length) {
          if (SeriesGetInt(s, j) != 0) {
            nextValid := SeriesGetInt(s, j);
            nextValidIdx := j;
            break;
          }
          j := j + 1;
        }
      }
      // Interpolate
      if (lastValidIdx >= 0 && nextValidIdx > 0) {
        var gap: int64 := nextValidIdx - lastValidIdx;
        var pos: int64 := i - lastValidIdx;
        var interpolated: int64 := lastValid + ((nextValid - lastValid) * pos) / gap;
        SeriesSetInt(result, i, interpolated);
      } else if (lastValidIdx >= 0) {
        SeriesSetInt(result, i, lastValid);  // Forward fill
      }
    }
    i := i + 1;
  }
  
  return result;
}

// ============================================================================
// Sample
// ============================================================================

// Random sample of rows (simplified: take every Nth row)
pub fn DataFrameSample(df: DataFrame, fraction: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var i: int64;
  var j: int64;
  var step: int64;
  
  if (fraction <= 0 || fraction > 100) { fraction := 10; }
  step := 100 / fraction;
  if (step < 1) { step := 1; }
  
  // Add all columns
  j := 0;
  while (j < df.colCount) {
    DataFrameAddColumn(result, peek8(df.columns + j * 16), COL_INT64);
    j := j + 1;
  }
  
  // Sample rows
  i := 0;
  while (i < df.rowCount) {
    var rowMod: int64 := i - (i / step) * step;
    if (rowMod == 0) {
      DataFrameAppendRow(result);
      var newRow: int64 := result.rowCount - 1;
      j := 0;
      while (j < df.colCount) {
        var srcS: Series := peek8(df.columns + j * 16 + 8);
        DataFrameSetInt(result, peek8(result.columns + j * 16), newRow, SeriesGetInt(srcS, i));
        j := j + 1;
      }
    }
    i := i + 1;
  }
  
  return result;
}

// ============================================================================
// Cut / QCut (Binning)
// ============================================================================

// Cut: assign values to bins
pub fn SeriesCut(s: Series, bins: int64): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var mn: int64 := SeriesMin(s);
  var mx: int64 := SeriesMax(s);
  var range: int64 := mx - mn;
  if (range == 0) { range := 1; }
  var binSize: int64 := range / bins;
  if (binSize == 0) { binSize := 1; }
  
  result.length := s.length;
  var i: int64 := 0;
  while (i < s.length) {
    var val: int64 := SeriesGetInt(s, i);
    var bin: int64 := (val - mn) / binSize;
    if (bin >= bins) { bin := bins - 1; }
    SeriesSetInt(result, i, bin);
    i := i + 1;
  }
  
  return result;
}

// QCut: assign values to quantile-based bins
pub fn SeriesQCut(s: Series, quantiles: int64): Series {
  // Simple implementation: sort and divide
  var sorted: DataFrame := DataFrameNew();
  DataFrameAddColumn(sorted, "val", COL_INT64);
  var i: int64 := 0;
  while (i < s.length) {
    DataFrameAppendRow(sorted);
    DataFrameSetInt(sorted, "val", i, SeriesGetInt(s, i));
    i := i + 1;
  }
  
  // Sort
  var sortedS: Series := DataFrameGetSeries(sorted, "val");
  i := 1;
  while (i < sortedS.length) {
    var key: int64 := SeriesGetInt(sortedS, i);
    var j: int64 := i - 1;
    while (j >= 0 && SeriesGetInt(sortedS, j) > key) {
      SeriesSetInt(sortedS, j + 1, SeriesGetInt(sortedS, j));
      j := j - 1;
    }
    SeriesSetInt(sortedS, j + 1, key);
    i := i + 1;
  }
  
  // Assign quantiles
  var result: Series := SeriesNewInt64(s.name, s.length);
  result.length := s.length;
  var bucketSize: int64 := s.length / quantiles;
  if (bucketSize == 0) { bucketSize := 1; }
  i := 0;
  while (i < s.length) {
    var bin: int64 := i / bucketSize;
    if (bin >= quantiles) { bin := quantiles - 1; }
    SeriesSetInt(result, i, bin);
    i := i + 1;
  }
  
  return result;
}

// ============================================================================
// MultiIndex (simplified)
// ============================================================================

// Multi-index: combine two columns as index
pub fn DataFrameSetMultiIndex(df: DataFrame, col1: int64, col2: int64) {
  var s1: Series := DataFrameGetSeries(df, col1);
  var s2: Series := DataFrameGetSeries(df, col2);
  var i: int64 := 0;
  
  df.index := mmap(0, df.rowCount * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (df.index == 0) { return; }
  
  // Create composite labels (concatenate values)
  while (i < df.rowCount) {
    var label: int64 := mmap(0, 64, PROT_RW, MAP_ANON, FD_NONE, 0);
    var pos: int64 := 0;
    var v1: int64 := SeriesGetInt(s1, i);
    var v2: int64 := SeriesGetInt(s2, i);
    
    // Convert v1 to string
    var tmp: int64 := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
    var tmpPos: int64 := 0;
    if (v1 == 0) { poke8(tmp, 48); tmpPos := 1; }
    else { var n: int64 := v1; while (n > 0) { poke8(tmp + tmpPos, 48 + (n - (n / 10) * 10)); tmpPos := tmpPos + 1; n := n / 10; } }
    while (tmpPos > 0) { tmpPos := tmpPos - 1; poke8(label + pos, peek8(tmp + tmpPos)); pos := pos + 1; }
    munmap(tmp, 16);
    
    // Add separator
    poke8(label + pos, 95); pos := pos + 1;  // '_'
    
    // Convert v2 to string
    tmp := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
    tmpPos := 0;
    if (v2 == 0) { poke8(tmp, 48); tmpPos := 1; }
    else { var n: int64 := v2; while (n > 0) { poke8(tmp + tmpPos, 48 + (n - (n / 10) * 10)); tmpPos := tmpPos + 1; n := n / 10; } }
    while (tmpPos > 0) { tmpPos := tmpPos - 1; poke8(label + pos, peek8(tmp + tmpPos)); pos := pos + 1; }
    munmap(tmp, 16);
    
    poke8(label + pos, 0);
    poke8(df.index + i * 8, label);
    i := i + 1;
  }
  
  df.indexName := col1;
  df.hasIndex := 1;
}

// Float sum (using f64 arithmetic)
pub fn SeriesSumF64(s: Series): f64 {
  var sum: f64 := 0.0;
  var i: int64 := 0;
  while (i < s.length) {
    sum := sum + peekf64(s.data + i * 8);
    i := i + 1;
  }
  return sum;
}

// Float mean
pub fn SeriesMeanF64(s: Series): f64 {
  if (s.length == 0) { return 0.0; }
  return SeriesSumF64(s) / (s.length as f64);
}

// Float min
pub fn SeriesMinF64(s: Series): f64 {
  var i: int64 := 1;
  var mn: f64;
  if (s.length == 0) { return 0.0; }
  mn := peekf64(s.data);
  while (i < s.length) {
    var val: f64 := peekf64(s.data + i * 8);
    if (val < mn) { mn := val; }
    i := i + 1;
  }
  return mn;
}

// Float max
pub fn SeriesMaxF64(s: Series): f64 {
  var i: int64 := 1;
  var mx: f64;
  if (s.length == 0) { return 0.0; }
  mx := peekf64(s.data);
  while (i < s.length) {
    var val: f64 := peekf64(s.data + i * 8);
    if (val > mx) { mx := val; }
    i := i + 1;
  }
  return mx;
}

// Float variance
pub fn SeriesVarianceF64(s: Series): f64 {
  var n: f64 := s.length as f64;
  if (n == 0.0) { return 0.0; }
  var mean: f64 := SeriesMeanF64(s);
  var sumSq: f64 := 0.0;
  var i: int64 := 0;
  while (i < s.length) {
    var diff: f64 := peekf64(s.data + i * 8) - mean;
    sumSq := sumSq + (diff * diff);
    i := i + 1;
  }
  return sumSq / n;
}

// Float std deviation
pub fn SeriesStdDevF64(s: Series): f64 {
  var variance: f64 := SeriesVarianceF64(s);
  // Newton's method sqrt
  var x: f64 := variance;
  if (x <= 0.0) { return 0.0; }
  var y: f64 := (x + 1.0) / 2.0;
  while (y < x) {
    x := y;
    y := (x + variance / x) / 2.0;
  }
  return x;
}

// Float cumulative sum
pub fn SeriesCumSumF64(s: Series): Series {
  var result: Series := SeriesNewFloat64(s.name, s.length);
  var i: int64 := 0;
  var sum: f64 := 0.0;
  result.length := s.length;
  while (i < s.length) {
    sum := sum + peekf64(s.data + i * 8);
    pokef64(result.data + i * 8, sum);
    i := i + 1;
  }
  return result;
}

// Float filter by threshold
pub fn SeriesFilterGtF64(s: Series, threshold: f64): Series {
  var result: Series := SeriesNewFloat64(s.name, s.length);
  var i: int64 := 0;
  while (i < s.length) {
    var val: f64 := peekf64(s.data + i * 8);
    if (val > threshold) {
      pokef64(result.data + result.length * 8, val);
      result.length := result.length + 1;
    }
    i := i + 1;
  }
  return result;
}

// Float filter less than
pub fn SeriesFilterLtF64(s: Series, threshold: f64): Series {
  var result: Series := SeriesNewFloat64(s.name, s.length);
  var i: int64 := 0;
  while (i < s.length) {
    var val: f64 := peekf64(s.data + i * 8);
    if (val < threshold) {
      pokef64(result.data + result.length * 8, val);
      result.length := result.length + 1;
    }
    i := i + 1;
  }
  return result;
}

// Add float column to DataFrame
pub fn DataFrameAddColumnFloat64(df: DataFrame, name: int64) {
  if (df.colCount >= df.colCapacity) { return; }
  var s: Series := SeriesNewFloat64(name, df.rowCapacity);
  s.length := df.rowCount;
  poke8(df.columns + df.colCount * 16, name);
  poke8(df.columns + df.colCount * 16 + 8, s);
  df.colCount := df.colCount + 1;
}

// Set float value
pub fn DataFrameSetFloat64(df: DataFrame, colName: int64, row: int64, value: f64) {
  var s: Series := DataFrameGetSeries(df, colName);
  if (s.data != 0 && row >= 0 && row < s.length) {
    pokef64(s.data + row * 8, value);
  }
}

// Get float value
pub fn DataFrameGetFloat64(df: DataFrame, colName: int64, row: int64): f64 {
  var s: Series := DataFrameGetSeries(df, colName);
  if (s.data == 0 || row < 0 || row >= s.length) {
    return 0.0;
  }
  return peekf64(s.data + row * 8);
}

// ============================================================================
// Rolling Window
// ============================================================================

// Rolling mean (int64)
pub fn SeriesRollingMean(s: Series, window: int64): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var i: int64 := 0;
  result.length := s.length;
  
  while (i < s.length) {
    if (i < window - 1) {
      SeriesSetInt(result, i, 0);  // Not enough data
    } else {
      var sum: int64 := 0;
      var j: int64 := i - window + 1;
      while (j <= i) {
        sum := sum + SeriesGetInt(s, j);
        j := j + 1;
      }
      SeriesSetInt(result, i, sum / window);
    }
    i := i + 1;
  }
  return result;
}

// Rolling sum
pub fn SeriesRollingSum(s: Series, window: int64): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var i: int64 := 0;
  result.length := s.length;
  
  while (i < s.length) {
    if (i < window - 1) {
      SeriesSetInt(result, i, 0);
    } else {
      var sum: int64 := 0;
      var j: int64 := i - window + 1;
      while (j <= i) {
        sum := sum + SeriesGetInt(s, j);
        j := j + 1;
      }
      SeriesSetInt(result, i, sum);
    }
    i := i + 1;
  }
  return result;
}

// Rolling min
pub fn SeriesRollingMin(s: Series, window: int64): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var i: int64 := 0;
  result.length := s.length;
  
  while (i < s.length) {
    if (i < window - 1) {
      SeriesSetInt(result, i, 0);
    } else {
      var mn: int64 := SeriesGetInt(s, i - window + 1);
      var j: int64 := i - window + 2;
      while (j <= i) {
        var val: int64 := SeriesGetInt(s, j);
        if (val < mn) { mn := val; }
        j := j + 1;
      }
      SeriesSetInt(result, i, mn);
    }
    i := i + 1;
  }
  return result;
}

// Rolling max
pub fn SeriesRollingMax(s: Series, window: int64): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var i: int64 := 0;
  result.length := s.length;
  
  while (i < s.length) {
    if (i < window - 1) {
      SeriesSetInt(result, i, 0);
    } else {
      var mx: int64 := SeriesGetInt(s, i - window + 1);
      var j: int64 := i - window + 2;
      while (j <= i) {
        var val: int64 := SeriesGetInt(s, j);
        if (val > mx) { mx := val; }
        j := j + 1;
      }
      SeriesSetInt(result, i, mx);
    }
    i := i + 1;
  }
  return result;
}

