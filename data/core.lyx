// Boolean indexing: filter DataFrame by boolean series
pub fn DataFrameFilterByMask(df: DataFrame, mask: BoolSeries): DataFrame {
  var result: DataFrame := DataFrameNew();
  var i: int64;
  var j: int64;
  var srcS: Series;
  
  // Add all columns
  j := 0;
  while (j < df.colCount) {
    DataFrameAddColumn(result, peek8(df.columns + j * 16), COL_INT64);
    j := j + 1;
  }
  
  // Copy rows where mask is 1
  i := 0;
  while (i < df.rowCount) {
    if (peek8(mask.data + i * 8) == 1) {
      DataFrameAppendRow(result);
      var newRow: int64 := result.rowCount - 1;
      j := 0;
      while (j < df.colCount) {
        srcS := peek8(df.columns + j * 16 + 8);
        DataFrameSetInt(result, peek8(result.columns + j * 16), newRow, SeriesGetInt(srcS, i));
        j := j + 1;
      }
    }
    i := i + 1;
  }
  
  return result;
}

// Count true values in boolean series
pub fn BoolSeriesCount(bs: BoolSeries): int64 {
  var count: int64 := 0;
  var i: int64 := 0;
  while (i < bs.length) {
    if (peek8(bs.data + i * 8) == 1) {
      count := count + 1;
    }
    i := i + 1;
  }
  return count;
}

// Check if any value is true
pub fn BoolSeriesAny(bs: BoolSeries): int64 {
  var i: int64 := 0;
