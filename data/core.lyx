}

// Get string label at index
pub fn SeriesGetLabelString(s: Series, idx: int64): int64 {
  if (s.labels == 0 || idx < 0 || idx >= s.length) {
    return 0;
  }
  return peek8(s.labels + idx * 8);
}

// Set index labels for DataFrame
// labels: array of pchar pointers
// name: index name
pub fn DataFrameSetIndex(df: DataFrame, labels: int64, name: int64) {
  df.index := labels;
  df.indexName := name;
  df.hasIndex := 1;
}

// Set index from column values (set_index)
// colName: column whose values become the index
// The column is NOT removed from the DataFrame
pub fn DataFrameSetIndexFromColumn(df: DataFrame, colName: int64) {
  var s: Series := DataFrameGetSeries(df, colName);
  var i: int64 := 0;
  
  if (s.data == 0) {
    return;
  }
  
  // Allocate index labels array
  df.index := mmap(0, df.rowCount * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (df.index == 0) {
    return;
  }
  
  // Copy column values as index labels
  if (s.colType == COL_STRING) {
    // Copy string pointers
    while (i < df.rowCount) {
      poke8(df.index + i * 8, SeriesGetString(s, i));
      i := i + 1;
    }
  } else {
    // Convert int values to string labels
    while (i < df.rowCount) {
      var val: int64 := SeriesGetInt(s, i);
      var label: int64 := mmap(0, 32, PROT_RW, MAP_ANON, FD_NONE, 0);
      var pos: int64 := 0;
      var num: int64 := val;
      var isNeg: int64 := 0;
      
      if (num < 0) {
        isNeg := 1;
        num := -num;
      }
      
      if (num == 0) {
        poke8(label, 48);
        pos := 1;
      } else {
        var tmp: int64 := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
        var tmpPos: int64 := 0;
        while (num > 0) {
          poke8(tmp + tmpPos, 48 + (num - (num / 10) * 10));
          tmpPos := tmpPos + 1;
          num := num / 10;
        }
        while (tmpPos > 0) {
          tmpPos := tmpPos - 1;
          poke8(label + pos, peek8(tmp + tmpPos));
          pos := pos + 1;
        }
        munmap(tmp, 16);
      }
      
      poke8(label + pos, 0);
      poke8(df.index + i * 8, label);
      i := i + 1;
    }
  }
  
  df.indexName := colName;
  df.hasIndex := 1;
}

// Reset index to numeric (0, 1, 2, ...)
pub fn DataFrameResetIndex(df: DataFrame) {
  var i: int64 := 0;
  
  // Free old index labels
  if (df.index != 0) {
    munmap(df.index, df.rowCount * 8);
    df.index := 0;
  }
  
  df.indexName := 0;
  df.hasIndex := 0;
}

// Get index label at row
pub fn DataFrameGetIndexLabel(df: DataFrame, row: int64): int64 {
  if (df.hasIndex == 0 || df.index == 0 || row < 0 || row >= df.rowCount) {
    return 0;
  }
  return peek8(df.index + row * 8);
}

// Set index label at row
pub fn DataFrameSetIndexLabel(df: DataFrame, row: int64, label: int64) {
  if (df.hasIndex == 1 && df.index != 0 && row >= 0 && row < df.rowCount) {
    poke8(df.index + row * 8, label);
  }
}

// Get index name
pub fn DataFrameGetIndexName(df: DataFrame): int64 {
  return df.indexName;
}

// Has index?
pub fn DataFrameHasIndex(df: DataFrame): int64 {
  return df.hasIndex;
}

// Find row by index label
pub fn DataFrameIndexLookup(df: DataFrame, label: int64): int64 {
  if (df.hasIndex == 0 || df.index == 0) {
    return -1;
  }
  
  var i: int64 := 0;
  while (i < df.rowCount) {
    var idx: int64 := peek8(df.index + i * 8);
    // Compare strings
    var match: int64 := 1;
    var j: int64 := 0;
    while (j < 256) {
      var c1: int64 := peek8(idx + j);
      var c2: int64 := peek8(label + j);
      if (c1 != c2) {
        match := 0;
        break;
      }
      if (c1 == 0) { break; }
      j := j + 1;
    }
    if (match == 1) {
      return i;
    }
    i := i + 1;
  }
  
  return -1;
}

// Get value by index label
pub fn DataFrameGetIntByLabel(df: DataFrame, colName: int64, label: int64): int64 {
  var row: int64 := DataFrameIndexLookup(df, label);
  if (row < 0) {
    return 0;
  }
  return DataFrameGetInt(df, colName, row);
}

// Set value by index label
pub fn DataFrameSetIntByLabel(df: DataFrame, colName: int64, label: int64, value: int64) {
  var row: int64 := DataFrameIndexLookup(df, label);
  if (row >= 0) {
    DataFrameSetInt(df, colName, row, value);
  }
}

pub fn DataFrameSortBy(df: DataFrame, colName: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var i: int64 := 0;
  var j: int64 := 0;
  var indices: int64;
  var key: int64;
  var keyIdx: int64;
  var s: Series;
  var srcS: Series;

  while (i < df.colCount) {
    var cname: int64 := peek8(df.columns + i * 16);
    var csrc: Series := peek8(df.columns + i * 16 + 8);
    DataFrameAddColumn(result, cname, csrc.colType);
    i := i + 1;
  }

  s := DataFrameGetSeries(df, colName);
  if (s.data == 0) { return result; }

  i := 0;
  while (i < df.rowCount) {
    DataFrameAppendRow(result);
    i := i + 1;
  }

  // Create index array [0, 1, 2, ...]
  var idxSz: int64 := df.rowCount * 8;
  indices := mmap(0, idxSz, PROT_RW, MAP_ANON, FD_NONE, 0);
  i := 0;
  while (i < df.rowCount) {
    poke8(indices + i * 8, i);
    i := i + 1;
  }
  
  // Insertion sort on indices
  i := 1;
  while (i < df.rowCount) {
    key := SeriesGetInt(s, peek8(indices + i * 8));
    keyIdx := peek8(indices + i * 8);
    j := i - 1;
    while (j >= 0) {
      var jOff8: int64 := j * 8;
      if (SeriesGetInt(s, peek8(indices + jOff8)) <= key) { break; }
      var j1a: int64 := j + 1;
      var j1Off8a: int64 := j1a * 8;
      poke8(indices + j1Off8a, peek8(indices + jOff8));
      j := j - 1;
    }
    var j1b: int64 := j + 1;
    var j1Off8b: int64 := j1b * 8;
    poke8(indices + j1Off8b, keyIdx);
    i := i + 1;
  }

  // Copy rows in sorted order
  i := 0;
  while (i < df.rowCount) {
    DataFrameAppendRow(result);
    var srcIdx: int64 := peek8(indices + i * 8);
    j := 0;
    while (j < df.colCount) {
      srcS := peek8(df.columns + j * 16 + 8);
      DataFrameSetInt(result, peek8(result.columns + j * 16), i, SeriesGetInt(srcS, srcIdx));
      j := j + 1;
    }
    i := i + 1;
  }
  
  munmap(indices, df.rowCount * 8);
  return result;
}

// Sort descending
pub fn DataFrameSortByDesc(df: DataFrame, colName: int64): DataFrame {
  var sorted: DataFrame := DataFrameSortBy(df, colName);
  return DataFrameReverse(sorted);
}

