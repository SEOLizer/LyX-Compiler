// Lyx Data Library - Core Module
// Pandas-like data analysis structures for Lyx
//
// This module provides:
// - Series: 1D typed array with optional labels
// - DataFrame: 2D table with named columns
// - Index: Row/column label management
// - Core operations: Select, Filter, Slice, AddColumn, DropColumn, GroupBy
//
// Design:
// - Data is stored as int64 arrays (numbers) or pchar arrays (strings)
// - Column names are pchar pointers
// - Row indices are int64 or pchar
// - Missing values: 0 for numbers, NULL for strings
//
// Usage:
//   import data.core;
//   var df: DataFrame := DataFrameNew();
//   DataFrameAddColumn(df, "name", COL_STRING);
//   DataFrameAddColumn(df, "age", COL_INT64);
//   DataFrameAppendRow(df);
//   DataFrameSetInt(df, "age", 0, 25);
//   var filtered: DataFrame := DataFrameFilter(df, "age", OP_GT, 20);

@description("Pandas-like data analysis core structures (Series, DataFrame)")
@author("Andreas Röne")
@copyright("2024-2025 Andreas Röne")
unit data.core;

// ============================================================================
// Type Constants
// ============================================================================

pub con COL_INT64: int64 := 1;
pub con COL_FLOAT: int64 := 2;
pub con COL_STRING: int64 := 3;
pub con COL_BOOL: int64 := 4;

// Comparison operators
pub con OP_EQ: int64 := 1;   // ==
pub con OP_NE: int64 := 2;   // !=
pub con OP_LT: int64 := 3;   // <
pub con OP_LE: int64 := 4;   // <=
pub con OP_GT: int64 := 5;   // >
pub con OP_GE: int64 := 6;   // >=

// Join types
pub con JOIN_INNER: int64 := 1;
pub con JOIN_LEFT: int64 := 2;
pub con JOIN_RIGHT: int64 := 3;
pub con JOIN_OUTER: int64 := 4;

// ============================================================================
// Series - 1D typed array with optional labels
// ============================================================================

// Series structure (fat pointer to heap data)
pub type Series = struct {
  data: int64;          // Pointer to data array (int64*)
  labels: int64;        // Pointer to label array (pchar*), 0 if none
  length: int64;        // Number of elements
  colType: int64;       // COL_INT64, COL_FLOAT, COL_STRING, COL_BOOL
  name: int64;          // Pointer to column name (pchar)
};

// Create new int64 series
pub fn SeriesNewInt64(name: int64, capacity: int64): Series {
  var s: Series;
  s.data := mmap(0, capacity * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  s.labels := 0;
  s.length := 0;
  s.colType := COL_INT64;
  s.name := name;
  return s;
}

// Create new string series
pub fn SeriesNewString(name: int64, capacity: int64): Series {
  var s: Series;
  s.data := mmap(0, capacity * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  s.labels := 0;
  s.length := 0;
  s.colType := COL_STRING;
  s.name := name;
  return s;
}

// Create new float64 series
pub fn SeriesNewFloat64(name: int64, capacity: int64): Series {
  var s: Series;
  s.data := mmap(0, capacity * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  s.labels := 0;
  s.length := 0;
  s.colType := COL_FLOAT;
  s.name := name;
  return s;
}

// Get int value at index
pub fn SeriesGetInt(s: Series, idx: int64): int64 {
  if (idx < 0 || idx >= s.length) {
    return 0;
  }
  return peek8(s.data + idx * 8);
}

// Set int value at index
pub fn SeriesSetInt(s: Series, idx: int64, value: int64) {
  if (idx >= 0 && idx < s.length) {
    poke8(s.data + idx * 8, value);
  }
}

// Get string value at index
pub fn SeriesGetString(s: Series, idx: int64): int64 {
  if (idx < 0 || idx >= s.length) {
    return 0;
  }
  return peek8(s.data + idx * 8);
}

// Set string value at index
pub fn SeriesSetString(s: Series, idx: int64, value: int64) {
  if (idx >= 0 && idx < s.length) {
    poke8(s.data + idx * 8, value);
  }
}

// Get label at index
pub fn SeriesGetLabel(s: Series, idx: int64): int64 {
  if (s.labels == 0 || idx < 0 || idx >= s.length) {
    return 0;
  }
  return peek8(s.labels + idx * 8);
}

// Set label at index
pub fn SeriesSetLabel(s: Series, idx: int64, label: int64) {
  if (s.labels != 0 && idx >= 0 && idx < s.length) {
    poke8(s.labels + idx * 8, label);
  }
}

// Append value to series (resize if needed)
pub fn SeriesAppendInt(s: Series, value: int64) {
  SeriesSetInt(s, s.length, value);
  s.length := s.length + 1;
}

// Append string to series
pub fn SeriesAppendString(s: Series, value: int64) {
  SeriesSetString(s, s.length, value);
  s.length := s.length + 1;
}

// ============================================================================
// DataFrame - 2D table with named columns
// ============================================================================

// Column descriptor
pub type Column = struct {
  name: int64;          // Column name (pchar)
  series: Series;       // Series data
};

// DataFrame structure
pub type DataFrame = struct {
  columns: int64;       // Pointer to Column array (each 16 bytes)
  colCount: int64;      // Number of columns
  rowCount: int64;      // Number of rows
  colCapacity: int64;   // Column capacity
  rowCapacity: int64;   // Row capacity
  index: int64;         // Pointer to index labels (pchar*), 0 if none
  indexName: int64;     // Pointer to index name (pchar)
  hasIndex: int64;      // 1 if index is set
};

// Create new empty DataFrame
pub fn DataFrameNew(): DataFrame {
  var df: DataFrame;
  df.columns := mmap(0, 16 * 16, PROT_RW, MAP_ANON, FD_NONE, 0);
  df.colCount := 0;
  df.rowCount := 0;
  df.colCapacity := 16;
  df.rowCapacity := 1024;
  df.index := 0;
  df.indexName := 0;
  df.hasIndex := 0;
  return df;
}

// Get column index by name (-1 if not found)
pub fn DataFrameColIndex(df: DataFrame, name: int64): int64 {
  var i: int64 := 0;
  var colName: int64;
  
  while (i < df.colCount) {
    colName := peek8(df.columns + i * 16);  // Column name at offset 0
    if (colName != 0 && name != 0) {
      // Compare strings
      var j: int64 := 0;
      var match: int64 := 1;
      while (j < 256) {
        var c1: int64 := peek8(colName + j);
        var c2: int64 := peek8(name + j);
        if (c1 != c2) { match := 0; break; }
        if (c1 == 0) { break; }
        j := j + 1;
      }
      if (match == 1) {
        return i;
      }
    }
    i := i + 1;
  }
  
  return -1;
}

// Get Series for column name
pub fn DataFrameGetSeries(df: DataFrame, name: int64): Series {
  var s: Series;
  var colIdx: int64;
  
  s.data := 0;
  s.labels := 0;
  s.length := 0;
  s.colType := 0;
  s.name := 0;
  
  colIdx := DataFrameColIndex(df, name);
  if (colIdx < 0) {
    return s;
  }
  
  // Series pointer at column[colIdx].series
  return peek8(df.columns + colIdx * 16 + 8);
}

// Add column to DataFrame
pub fn DataFrameAddColumn(df: DataFrame, name: int64, colType: int64) {
  var s: Series;
  
  if (df.colCount >= df.colCapacity) {
    return;  // Capacity exceeded
  }
  
  // Create series
  if (colType == COL_STRING) {
    s := SeriesNewString(name, df.rowCapacity);
  } else {
    s := SeriesNewInt64(name, df.colCapacity);
  }
  
  // Set existing rows to 0/NULL
  s.length := df.rowCount;
  
  // Store column
  poke8(df.columns + df.colCount * 16, name);     // Column name
  poke8(df.columns + df.colCount * 16 + 8, s);     // Series
  
  df.colCount := df.colCount + 1;
}

// Add row to DataFrame
pub fn DataFrameAppendRow(df: DataFrame) {
  var i: int64 := 0;
  var s: Series;
  
  while (i < df.colCount) {
    s := peek8(df.columns + i * 16 + 8);
    if (s.colType == COL_STRING) {
      SeriesAppendString(s, 0);  // NULL
    } else {
      SeriesAppendInt(s, 0);     // 0
    }
    i := i + 1;
  }
  
  df.rowCount := df.rowCount + 1;
}

// Get int value from DataFrame
pub fn DataFrameGetInt(df: DataFrame, colName: int64, row: int64): int64 {
  var s: Series := DataFrameGetSeries(df, colName);
  if (s.data == 0) {
    return 0;
  }
  return SeriesGetInt(s, row);
}

// Set int value in DataFrame
pub fn DataFrameSetInt(df: DataFrame, colName: int64, row: int64, value: int64) {
  var s: Series := DataFrameGetSeries(df, colName);
  if (s.data != 0) {
    SeriesSetInt(s, row, value);
  }
}

// Get string value from DataFrame
pub fn DataFrameGetString(df: DataFrame, colName: int64, row: int64): int64 {
  var s: Series := DataFrameGetSeries(df, colName);
  if (s.data == 0) {
    return 0;
  }
  return SeriesGetString(s, row);
}

// Set string value in DataFrame
pub fn DataFrameSetString(df: DataFrame, colName: int64, row: int64, value: int64) {
  var s: Series := DataFrameGetSeries(df, colName);
  if (s.data != 0) {
    SeriesSetString(s, row, value);
  }
}

// Get column type
pub fn DataFrameGetColumnType(df: DataFrame, colName: int64): int64 {
  var s: Series := DataFrameGetSeries(df, colName);
  return s.colType;
}

// ============================================================================
// Selection and Filtering
// ============================================================================

// Compare int value
pub fn CompareInt(value: int64, op: int64, target: int64): int64 {
  if (op == OP_EQ) { if (value == target) { return 1; } else { return 0; } }
  if (op == OP_NE) { if (value != target) { return 1; } else { return 0; } }
  if (op == OP_LT) { if (value < target) { return 1; } else { return 0; } }
  if (op == OP_LE) { if (value <= target) { return 1; } else { return 0; } }
  if (op == OP_GT) { if (value > target) { return 1; } else { return 0; } }
  if (op == OP_GE) { if (value >= target) { return 1; } else { return 0; } }
  return 0;
}

// Filter DataFrame by column value
// Returns new DataFrame with rows where colName op value
pub fn DataFrameFilter(df: DataFrame, colName: int64, op: int64, value: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var i: int64 := 0;
  var j: int64 := 0;
  var colIdx: int64;
  var srcSeries: Series;
  var val: int64;
  
  // Add all columns to result
  while (j < df.colCount) {
    var name: int64 := peek8(df.columns + j * 16);
    var srcS: Series := peek8(df.columns + j * 16 + 8);
    DataFrameAddColumn(result, name, srcS.colType);
    j := j + 1;
  }
  
  // Find filter column
  colIdx := DataFrameColIndex(df, colName);
  if (colIdx < 0) {
    return result;
  }

  srcSeries := peek8(df.columns + colIdx * 16 + 8);
  i := 0;
  while (i < df.rowCount) {
    val := SeriesGetInt(srcSeries, i);
    if (CompareInt(val, op, value) == 1) {
      DataFrameAppendRow(result);
      j := 0;
      while (j < df.colCount) {
        var dstS: Series := peek8(result.columns + j * 16 + 8);
        var srcS2: Series := peek8(df.columns + j * 16 + 8);
        if (srcS2.colType == COL_STRING) {
          SeriesSetString(dstS, result.rowCount - 1, SeriesGetString(srcS2, i));
        } else {
          SeriesSetInt(dstS, result.rowCount - 1, SeriesGetInt(srcS2, i));
        }
        j := j + 1;
      }
    }
    i := i + 1;
  }

  return result;
}

// ============================================================================
// String Operations
// ============================================================================

// String length helper
fn DataStrLen(s: int64): int64 {
  var len: int64 := 0;
  if (s == 0) { return 0; }
  while (peek8(s + len) != 0) { len := len + 1; }
  return len;
}

// String to uppercase (returns new string)
pub fn StrToUpper(s: int64): int64 {
  var len: int64 := DataStrLen(s);
  var sz0: int64 := len + 1;
  var buf: int64 := mmap(0, sz0, PROT_RW, MAP_ANON, FD_NONE, 0);
  var i: int64 := 0;
  while (i < len) {
    var c: int64 := peek8(s + i);
    if (c >= 97 && c <= 122) { c := c - 32; }
    poke8(buf + i, c);
    i := i + 1;
  }
  poke8(buf + len, 0);
  return buf;
}

// String to lowercase (returns new string)
pub fn StrToLower(s: int64): int64 {
  var len: int64 := DataStrLen(s);
  var sz1: int64 := len + 1;
  var buf: int64 := mmap(0, sz1, PROT_RW, MAP_ANON, FD_NONE, 0);
  var i: int64 := 0;
  while (i < len) {
    var c: int64 := peek8(s + i);
    if (c >= 65 && c <= 90) { c := c + 32; }
    poke8(buf + i, c);
    i := i + 1;
  }
  poke8(buf + len, 0);
  return buf;
}

// String trim left (remove leading spaces)
pub fn StrTrimLeft(s: int64): int64 {
  var start: int64 := 0;
  while (peek8(s + start) == 32) { start := start + 1; }
  var fullLen: int64 := DataStrLen(s);
  var len: int64 := fullLen - start;
  var sz2: int64 := len + 1;
  var buf: int64 := mmap(0, sz2, PROT_RW, MAP_ANON, FD_NONE, 0);
  var i: int64 := 0;
  while (i < len) {
    var srcOff: int64 := start + i;
    poke8(buf + i, peek8(s + srcOff));
    i := i + 1;
  }
  poke8(buf + len, 0);
  return buf;
}

// String trim right (remove trailing spaces)
pub fn StrTrimRight(s: int64): int64 {
  var len: int64 := DataStrLen(s);
  while (len > 0) {
    var len1: int64 := len - 1;
    if (peek8(s + len1) != 32) { break; }
    len := len1;
  }
  var sz3: int64 := len + 1;
  var buf: int64 := mmap(0, sz3, PROT_RW, MAP_ANON, FD_NONE, 0);
  var i: int64 := 0;
  while (i < len) {
    poke8(buf + i, peek8(s + i));
    i := i + 1;
  }
  poke8(buf + len, 0);
  return buf;
}

// String trim both
pub fn StrTrim(s: int64): int64 {
  var tmp: int64 := StrTrimLeft(s);
  var result: int64 := StrTrimRight(tmp);
  var tmpLen: int64 := DataStrLen(tmp);
  var tmpSz: int64 := tmpLen + 1;
  munmap(tmp, tmpSz);
  return result;
}

// Split string by delimiter
// Returns array of pchar pointers (first element is count at offset -8)
pub fn StrSplit(s: int64, delim: int64): int64 {
  var maxParts: int64 := 256;
  var partsBase: int64 := maxParts * 8;
  var partsSz: int64 := partsBase + 8;
  var parts: int64 := mmap(0, partsSz, PROT_RW, MAP_ANON, FD_NONE, 0);
  var count: int64 := 0;
  var start: int64 := 0;
  var i: int64 := 0;
  var len: int64 := DataStrLen(s);
  
  while (i <= len) {
    if (peek8(s + i) == delim || peek8(s + i) == 0) {
      var partLen: int64 := i - start;
      var partSz: int64 := partLen + 1;
      var part: int64 := mmap(0, partSz, PROT_RW, MAP_ANON, FD_NONE, 0);
      var j: int64 := 0;
      while (j < partLen) {
        var srcJ: int64 := start + j;
        poke8(part + j, peek8(s + srcJ));
        j := j + 1;
      }
      poke8(part + partLen, 0);
      poke8(parts + count * 8, part);
      count := count + 1;
      start := i + 1;
    }
    i := i + 1;
  }
  
  // Store count at the end
  // Return parts pointer (count can be accessed as needed)
  return parts;
}

// Join array of strings with delimiter
pub fn StrJoin(parts: int64, count: int64, delim: int64): int64 {
  var totalLen: int64 := 0;
  var i: int64 := 0;
  var lengths: int64 := mmap(0, count * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  
  // Calculate total length
  while (i < count) {
    var part: int64 := peek8(parts + i * 8);
    var partLen: int64 := DataStrLen(part);
    poke8(lengths + i * 8, partLen);
    totalLen := totalLen + partLen;
    if (i < count - 1) { totalLen := totalLen + 1; }  // delimiter
    i := i + 1;
  }
  
  var joinSz: int64 := totalLen + 1;
  var buf: int64 := mmap(0, joinSz, PROT_RW, MAP_ANON, FD_NONE, 0);
  var pos: int64 := 0;
  i := 0;
  while (i < count) {
    var part: int64 := peek8(parts + i * 8);
    var partLen: int64 := peek8(lengths + i * 8);
    var j: int64 := 0;
    while (j < partLen) {
      poke8(buf + pos, peek8(part + j));
      pos := pos + 1;
      j := j + 1;
    }
    if (i < count - 1) {
      poke8(buf + pos, delim);
      pos := pos + 1;
    }
    i := i + 1;
  }
  
  poke8(buf + pos, 0);
  munmap(lengths, count * 8);
  return buf;
}

// String contains
pub fn StrContains(s: int64, needle: int64): int64 {
  var sLen: int64 := DataStrLen(s);
  var nLen: int64 := DataStrLen(needle);
  var i: int64 := 0;
  while (i <= sLen - nLen) {
    var j: int64 := 0;
    var match: int64 := 1;
    while (j < nLen) {
      if (peek8(s + i + j) != peek8(needle + j)) {
        match := 0;
        break;
      }
      j := j + 1;
    }
    if (match == 1) { return 1; }
    i := i + 1;
  }
  return 0;
}

// String starts with
fn DataStrStartsWith(s: int64, prefix: int64): int64 {
  var pLen: int64 := DataStrLen(prefix);
  var i: int64 := 0;
  while (i < pLen) {
    if (peek8(s + i) != peek8(prefix + i)) { return 0; }
    i := i + 1;
  }
  return 1;
}

// String ends with
fn DataStrEndsWith(s: int64, suffix: int64): int64 {
  var sLen: int64 := DataStrLen(s);
  var sufLen: int64 := DataStrLen(suffix);
  if (sLen < sufLen) { return 0; }
  var i: int64 := 0;
  while (i < sufLen) {
    var base: int64 := sLen - sufLen;
    var pos: int64 := base + i;
    if (peek8(s + pos) != peek8(suffix + i)) { return 0; }
    i := i + 1;
  }
  return 1;
}

// String replace (first occurrence)
pub fn StrReplace(s: int64, old: int64, newStr: int64): int64 {
  var sLen: int64 := DataStrLen(s);
  var oLen: int64 := DataStrLen(old);
  var nLen: int64 := DataStrLen(newStr);
  var i: int64 := 0;
  
  while (i <= sLen - oLen) {
    var j: int64 := 0;
    var match: int64 := 1;
    while (j < oLen) {
      var ij: int64 := i + j;
      if (peek8(s + ij) != peek8(old + j)) { match := 0; break; }
      j := j + 1;
    }
    if (match == 1) {
      var newLen1: int64 := sLen - oLen;
      var newLen: int64 := newLen1 + nLen;
      var newLenSz: int64 := newLen + 1;
      var buf: int64 := mmap(0, newLenSz, PROT_RW, MAP_ANON, FD_NONE, 0);
      var pos: int64 := 0;
      j := 0;
      while (j < i) { poke8(buf + pos, peek8(s + j)); pos := pos + 1; j := j + 1; }
      j := 0;
      while (j < nLen) { poke8(buf + pos, peek8(newStr + j)); pos := pos + 1; j := j + 1; }
      var iOLen: int64 := i + oLen;
      j := iOLen;
      while (j < sLen) { poke8(buf + pos, peek8(s + j)); pos := pos + 1; j := j + 1; }
      poke8(buf + pos, 0);
      return buf;
    }
    i := i + 1;
  }
  // No match found, return copy
  var copySz: int64 := sLen + 1;
  var buf: int64 := mmap(0, copySz, PROT_RW, MAP_ANON, FD_NONE, 0);
  i := 0;
  while (i < sLen) { poke8(buf + i, peek8(s + i)); i := i + 1; }
  poke8(buf + sLen, 0);
  return buf;
}

// ============================================================================
// CorrMatrix
// ============================================================================

// Pairwise correlation matrix for multiple columns
pub fn DataFrameCorrMatrix(df: DataFrame): DataFrame {
  var result: DataFrame := DataFrameNew();
  var i: int64;
  var j: int64;
  var s1: Series;
  var s2: Series;
  
  // Add index column (column names)
  DataFrameAddColumn(result, "column", COL_STRING);
  
  // Add one column per DataFrame column
  i := 0;
  while (i < df.colCount) {
    DataFrameAddColumn(result, peek8(df.columns + i * 16), COL_INT64);
    i := i + 1;
  }
  
  // Compute correlations
  i := 0;
  while (i < df.colCount) {
    DataFrameAppendRow(result);
    DataFrameSetString(result, "column", i, peek8(df.columns + i * 16));
    s1 := peek8(df.columns + i * 16 + 8);
    
    j := 0;
    while (j < df.colCount) {
      s2 := peek8(df.columns + j * 16 + 8);
      var corr: int64 := SeriesCorr(s1, s2);
      var j1corr: int64 := j + 1;
      var j1Off16corr: int64 := j1corr * 16;
      DataFrameSetInt(result, peek8(result.columns + j1Off16corr), i, corr);
      j := j + 1;
    }
    
    i := i + 1;
  }
  
  return result;
}

// ============================================================================
// GetDummies (One-Hot Encoding)
// ============================================================================

// Convert column values to binary columns
pub fn DataFrameGetDummies(df: DataFrame, colName: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var s: Series := DataFrameGetSeries(df, colName);
  var uniqueVals: int64 := mmap(0, 1024 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  var uniqueCount: int64 := 0;
  var i: int64;
  var j: int64;
  var val: int64;
  var found: int64;
  
  // Find unique values
  i := 0;
  while (i < s.length) {
    val := SeriesGetInt(s, i);
    found := 0;
    j := 0;
    while (j < uniqueCount) {
      if (peek8(uniqueVals + j * 8) == val) { found := 1; break; }
      j := j + 1;
    }
    if (found == 0) {
      poke8(uniqueVals + uniqueCount * 8, val);
      uniqueCount := uniqueCount + 1;
    }
    i := i + 1;
  }
  
  // Create dummy columns
  j := 0;
  while (j < uniqueCount) {
    // Create column name: colName + "_" + value
    var colNameStr: int64 := mmap(0, 64, PROT_RW, MAP_ANON, FD_NONE, 0);
    var pos: int64 := 0;
    var nameLen: int64 := DataStrLen(colName);
    i := 0;
    while (i < nameLen) { poke8(colNameStr + pos, peek8(colName + i)); pos := pos + 1; i := i + 1; }
    poke8(colNameStr + pos, 95); pos := pos + 1;  // '_'
    // Convert value to string
    var num: int64 := peek8(uniqueVals + j * 8);
    var tmp: int64 := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
    var tmpPos: int64 := 0;
    if (num == 0) { poke8(tmp, 48); tmpPos := 1; }
    else {
      while (num > 0) { poke8(tmp + tmpPos, 48 + (num - (num / 10) * 10)); tmpPos := tmpPos + 1; num := num / 10; }
    }
    while (tmpPos > 0) { tmpPos := tmpPos - 1; poke8(colNameStr + pos, peek8(tmp + tmpPos)); pos := pos + 1; }
    poke8(colNameStr + pos, 0);
    munmap(tmp, 16);
    
    DataFrameAddColumn(result, colNameStr, COL_INT64);
    j := j + 1;
  }
  
  // Fill dummy values
  i := 0;
  while (i < df.rowCount) {
    DataFrameAppendRow(result);
    val := SeriesGetInt(s, i);
    j := 0;
    while (j < uniqueCount) {
      var dummyVal: int64 := 0;
      if (peek8(uniqueVals + j * 8) == val) { dummyVal := 1; }
      DataFrameSetInt(result, peek8(result.columns + j * 16), i, dummyVal);
      j := j + 1;
    }
    i := i + 1;
  }
  
  munmap(uniqueVals, 1024 * 8);
  return result;
}

// ============================================================================
// Right/Outer Join
// ============================================================================

// Right join: all rows from right, matching rows from left
pub fn DataFrameJoinRight(left: DataFrame, leftKey: int64, right: DataFrame, rightKey: int64): DataFrame {
  // Swap and use left join
  return DataFrameJoinLeft(right, rightKey, left, leftKey);
}

// Outer join: all rows from both DataFrames
pub fn DataFrameJoinOuter(left: DataFrame, leftKey: int64, right: DataFrame, rightKey: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var leftS: Series := DataFrameGetSeries(left, leftKey);
  var rightS: Series := DataFrameGetSeries(right, rightKey);
  var i: int64;
  var j: int64;
  var found: int64;
  
  // Add all columns from left
  i := 0;
  while (i < left.colCount) {
    DataFrameAddColumn(result, peek8(left.columns + i * 16), COL_INT64);
    i := i + 1;
  }
  // Add columns from right (skip key)
  i := 0;
  while (i < right.colCount) {
    var name: int64 := peek8(right.columns + i * 16);
    if (name != rightKey) { DataFrameAddColumn(result, name, COL_INT64); }
    i := i + 1;
  }
  
  // All rows from left
  i := 0;
  while (i < left.rowCount) {
    DataFrameAppendRow(result);
    var newRow: int64 := result.rowCount - 1;
    j := 0;
    while (j < left.colCount) {
      var s: Series := peek8(left.columns + j * 16 + 8);
      DataFrameSetInt(result, peek8(result.columns + j * 16), newRow, SeriesGetInt(s, i));
      j := j + 1;
    }
    // Try to find match in right
    var leftVal: int64 := SeriesGetInt(leftS, i);
    found := 0;
    j := 0;
    while (j < right.rowCount) {
      if (SeriesGetInt(rightS, j) == leftVal) {
        var col: int64 := 0;
        while (col < right.colCount) {
          var rName: int64 := peek8(right.columns + col * 16);
          if (rName != rightKey) {
            var s2: Series := peek8(right.columns + col * 16 + 8);
            DataFrameSetInt(result, rName, newRow, SeriesGetInt(s2, j));
          }
          col := col + 1;
        }
        found := 1;
        break;
      }
      j := j + 1;
    }
    i := i + 1;
  }
  
  // Add unmatched rows from right
  i := 0;
  while (i < right.rowCount) {
    var rightVal: int64 := SeriesGetInt(rightS, i);
    found := 0;
    j := 0;
    while (j < left.rowCount) {
      if (SeriesGetInt(leftS, j) == rightVal) { found := 1; break; }
      j := j + 1;
    }
    if (found == 0) {
      DataFrameAppendRow(result);
      var newRow: int64 := result.rowCount - 1;
      // Copy right columns
      j := 0;
      while (j < right.colCount) {
        var rName: int64 := peek8(right.columns + j * 16);
        var s: Series := peek8(right.columns + j * 16 + 8);
        DataFrameSetInt(result, rName, newRow, SeriesGetInt(s, i));
        j := j + 1;
      }
    }
    i := i + 1;
  }
  
  return result;
}

// ============================================================================
// Normalize
// ============================================================================

// Min-Max normalization (0-1000 scale)
pub fn SeriesNormalizeMinMax(s: Series): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var mn: int64 := SeriesMin(s);
  var mx: int64 := SeriesMax(s);
  var range: int64 := mx - mn;
  if (range == 0) { range := 1; }
  result.length := s.length;
  var i: int64 := 0;
  while (i < s.length) {
    var val: int64 := SeriesGetInt(s, i);
    SeriesSetInt(result, i, ((val - mn) * 1000) / range);
    i := i + 1;
  }
  return result;
}

// Z-Score normalization (mean=0, std=1 approximation)
pub fn SeriesNormalizeZScore(s: Series): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var mean: int64 := SeriesMean(s);
  var variance: int64 := 0;
  var i: int64 := 0;
  result.length := s.length;
  
  // Calculate variance
  while (i < s.length) {
    var diff: int64 := SeriesGetInt(s, i) - mean;
    variance := variance + (diff * diff);
    i := i + 1;
  }
  if (s.length > 0) { variance := variance / s.length; }
  
  // Integer sqrt
  var std: int64 := variance;
  if (std > 0) {
    var std1: int64 := std + 1;
    var tmp: int64 := std1 / 2;
    while (tmp < std) {
      std := tmp;
      var vds: int64 := variance / std;
      var svds: int64 := std + vds;
      tmp := svds / 2;
    }
  }
  if (std == 0) { std := 1; }

  // Normalize
  i := 0;
  while (i < s.length) {
    var val: int64 := SeriesGetInt(s, i);
    SeriesSetInt(result, i, ((val - mean) * 100) / std);
    i := i + 1;
  }
  return result;
}

// ============================================================================
// DatetimeIndex
// ============================================================================

// Unix timestamp to components
pub type DateTime = struct {
  year: int64;
  month: int64;
  day: int64;
  hour: int64;
  minute: int64;
  second: int64;
};

// Convert Unix timestamp to DateTime
pub fn UnixToDateTime(unix: int64): DateTime {
  var dt: DateTime;
  var days: int64 := unix / 86400;
  var secs: int64 := unix - days * 86400;
  
  dt.hour := secs / 3600;
  dt.minute := (secs - dt.hour * 3600) / 60;
  dt.second := secs - dt.hour * 3600 - dt.minute * 60;
  
  // Simplified year/month/day
  dt.year := 1970 + (days / 365);
  var daysInYear: int64 := days - (dt.year - 1970) * 365;
  daysInYear := daysInYear - ((dt.year - 1968) / 4);
  
  if (daysInYear < 31) { dt.month := 1; dt.day := daysInYear + 1; }
  else if (daysInYear < 59) { dt.month := 2; dt.day := daysInYear - 30; }
  else if (daysInYear < 90) { dt.month := 3; dt.day := daysInYear - 58; }
  else if (daysInYear < 120) { dt.month := 4; dt.day := daysInYear - 89; }
  else if (daysInYear < 151) { dt.month := 5; dt.day := daysInYear - 119; }
  else if (daysInYear < 181) { dt.month := 6; dt.day := daysInYear - 150; }
  else if (daysInYear < 212) { dt.month := 7; dt.day := daysInYear - 180; }
  else if (daysInYear < 243) { dt.month := 8; dt.day := daysInYear - 211; }
  else if (daysInYear < 273) { dt.month := 9; dt.day := daysInYear - 242; }
  else if (daysInYear < 304) { dt.month := 10; dt.day := daysInYear - 272; }
  else if (daysInYear < 334) { dt.month := 11; dt.day := daysInYear - 303; }
  else { dt.month := 12; dt.day := daysInYear - 333; }
  
  return dt;
}

// Get year from timestamp
pub fn UnixGetYear(ts: int64): int64 {
  return UnixToDateTime(ts).year;
}

// Get month from timestamp
pub fn UnixGetMonth(ts: int64): int64 {
  return UnixToDateTime(ts).month;
}

// Get day from timestamp
pub fn UnixGetDay(ts: int64): int64 {
  return UnixToDateTime(ts).day;
}

// Get hour from timestamp
pub fn UnixGetHour(ts: int64): int64 {
  return UnixToDateTime(ts).hour;
}

// ============================================================================
// Resample (simplified)
// ============================================================================

// Resample by counting occurrences in time windows
// windowSec: window size in seconds
pub fn SeriesResampleCount(s: Series, windowSec: int64): Series {
  // Simple binning
  if (s.length == 0) { return SeriesNewInt64(s.name, 0); }
  var mn: int64 := SeriesMin(s);
  var mx: int64 := SeriesMax(s);
  var bins: int64 := ((mx - mn) / windowSec) + 1;
  var result: Series := SeriesNewInt64(s.name, bins);
  var i: int64 := 0;
  result.length := bins;
  while (i < bins) { SeriesSetInt(result, i, 0); i := i + 1; }
  i := 0;
  while (i < s.length) {
    var val: int64 := SeriesGetInt(s, i);
    var bin: int64 := (val - mn) / windowSec;
    if (bin >= 0 && bin < bins) {
      SeriesSetInt(result, bin, SeriesGetInt(result, bin) + 1);
    }
    i := i + 1;
  }
  return result;
}

// ============================================================================
// Explode
