  // Copy matching rows
  while (i < df.rowCount) {
    val := SeriesGetInt(srcSeries, i);
    if (CompareInt(val, op, value) == 1) {
      // Copy all columns for this row
      DataFrameAppendRow(result);
      j := 0;
      while (j < df.colCount) {
        var dstS: Series := peek8(result.columns + j * 16 + 8);
        var srcS2: Series := peek8(df.columns + j * 16 + 8);
        if (srcS2.colType == COL_STRING) {
          SeriesSetString(dstS, result.rowCount - 1, SeriesGetString(srcS2, i));
        } else {
          SeriesSetInt(dstS, result.rowCount - 1, SeriesGetInt(srcS2, i));
        }
        j := j + 1;
      }
    }
    i := i + 1;
  }
  
  return result;
}

// Slice DataFrame by row range [start, end)
pub fn DataFrameSlice(df: DataFrame, start: int64, endRow: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var i: int64 := start;
  var j: int64 := 0;
  
  if (endRow > df.rowCount) {
    endRow := df.rowCount;
  }
  
  // Add all columns
  while (j < df.colCount) {
    var name: int64 := peek8(df.columns + j * 16);
    var srcS: Series := peek8(df.columns + j * 16 + 8);
    DataFrameAddColumn(result, name, srcS.colType);
    j := j + 1;
  }
  
  // Copy rows
  while (i < endRow) {
    DataFrameAppendRow(result);
    j := 0;
    while (j < df.colCount) {
      var dstS: Series := peek8(result.columns + j * 16 + 8);
      var srcS2: Series := peek8(df.columns + j * 16 + 8);
      if (srcS2.colType == COL_STRING) {
        SeriesSetString(dstS, result.rowCount - 1, SeriesGetString(srcS2, i));
      } else {
        SeriesSetInt(dstS, result.rowCount - 1, SeriesGetInt(srcS2, i));
      }
      j := j + 1;
    }
    i := i + 1;
  }
  
  return result;
}

// ============================================================================
// Column Operations
// ============================================================================

// Drop column by name
pub fn DataFrameDropColumn(df: DataFrame, name: int64) {
  var colIdx: int64 := DataFrameColIndex(df, name);
  var i: int64;
  var srcSeries: Series;
  
  if (colIdx < 0) {
    return;
  }
  
  // Free series
  srcSeries := peek8(df.columns + colIdx * 16 + 8);
  if (srcSeries.data != 0) {
    munmap(srcSeries.data, srcSeries.length * 8);
  }
  
  // Shift columns left
  i := colIdx;
  while (i < df.colCount - 1) {
    poke8(df.columns + i * 16, peek8(df.columns + (i + 1) * 16));
    poke8(df.columns + i * 16 + 8, peek8(df.columns + (i + 1) * 16 + 8));
    i := i + 1;
  }
  
  df.colCount := df.colCount - 1;
}

// Rename column
pub fn DataFrameRenameColumn(df: DataFrame, oldName: int64, newName: int64) {
  var colIdx: int64 := DataFrameColIndex(df, oldName);
  if (colIdx >= 0) {
    poke8(df.columns + colIdx * 16, newName);
  }
}

// ============================================================================
// GroupBy
// ============================================================================

// GroupBy result
pub type GroupByResult = struct {
  df: DataFrame;        // Original DataFrame
  keyCol: int64;        // Pointer to key column name
  groups: int64;        // Pointer to group values (int64 array)
  groupRows: int64;     // Pointer to row indices per group (array of arrays)
  groupCount: int64;    // Number of groups
};

// GroupBy: group rows by column value
pub fn DataFrameGroupBy(df: DataFrame, keyCol: int64): GroupByResult {
  var gb: GroupByResult;
  var s: Series := DataFrameGetSeries(df, keyCol);
  var i: int64 := 0;
  var val: int64;
  var groupIdx: int64;
  var found: int64;
  
  gb.df := df;
  gb.keyCol := keyCol;
  gb.groups := mmap(0, 1024 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  gb.groupRows := mmap(0, 1024 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  gb.groupCount := 0;
  
  // Find unique values
  while (i < df.rowCount) {
    val := SeriesGetInt(s, i);
    found := 0;
    groupIdx := 0;
    while (groupIdx < gb.groupCount) {
      if (peek8(gb.groups + groupIdx * 8) == val) {
        found := 1;
        break;
      }
      groupIdx := groupIdx + 1;
    }
    
    if (found == 0) {
      poke8(gb.groups + gb.groupCount * 8, val);
      // Create row index array for this group
      var rows: int64 := mmap(0, 1024 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
      poke8(rows, i);  // First row
      poke8(gb.groupRows + gb.groupCount * 8, rows);
      poke8(rows - 8, 1);  // Row count at offset -8
      gb.groupCount := gb.groupCount + 1;
    } else {
      // Add row to existing group
      var rows: int64 := peek8(gb.groupRows + groupIdx * 8);
      var count: int64 := peek8(rows - 8);
      poke8(rows + count * 8, i);
      poke8(rows - 8, count + 1);
    }
    
    i := i + 1;
  }
  
  return gb;
}

// GroupBy aggregation: sum
pub fn GroupBySum(gb: GroupByResult, aggCol: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var s: Series := DataFrameGetSeries(gb.df, aggCol);
  var keyS: Series := DataFrameGetSeries(gb.df, gb.keyCol);
  var i: int64 := 0;
  var j: int64;
  var rows: int64;
  var count: int64;
  var sum: int64;
  var val: int64;
  
  DataFrameAddColumn(result, gb.keyCol, keyS.colType);
  DataFrameAddColumn(result, aggCol, COL_INT64);
  
  while (i < gb.groupCount) {
    DataFrameAppendRow(result);
    
    // Set key value
    rows := peek8(gb.groupRows + i * 8);
    val := SeriesGetInt(keyS, peek8(rows));
    DataFrameSetInt(result, gb.keyCol, i, val);
    
    // Sum aggregation
    count := peek8(rows - 8);
    sum := 0;
    j := 0;
    while (j < count) {
      sum := sum + SeriesGetInt(s, peek8(rows + j * 8));
      j := j + 1;
    }
    DataFrameSetInt(result, aggCol, i, sum);
    
    i := i + 1;
  }
  
  return result;
}

// GroupBy aggregation: count
pub fn GroupByCount(gb: GroupByResult): DataFrame {
  var result: DataFrame := DataFrameNew();
  var keyS: Series := DataFrameGetSeries(gb.df, gb.keyCol);
  var i: int64 := 0;
  var rows: int64;
  var count: int64;
  var val: int64;
  
  DataFrameAddColumn(result, gb.keyCol, keyS.colType);
  DataFrameAddColumn(result, "count", COL_INT64);
  
  while (i < gb.groupCount) {
    DataFrameAppendRow(result);
    rows := peek8(gb.groupRows + i * 8);
    count := peek8(rows - 8);
    
    val := SeriesGetInt(keyS, peek8(rows));
    DataFrameSetInt(result, gb.keyCol, i, val);
    DataFrameSetInt(result, "count", i, count);
    
    i := i + 1;
  }
  
  return result;
}

// ============================================================================
// Missing Values
// ============================================================================

// Check if value is NA (0 for int, NULL for string)
pub fn IsNA(value: int64, colType: int64): bool {
  if (colType == COL_STRING) {
    return value == 0;
  }
  return value == 0;
}

// Fill NA values with default
pub fn DataFrameFillNA(df: DataFrame, colName: int64, defaultValue: int64) {
  var s: Series := DataFrameGetSeries(df, colName);
  var i: int64 := 0;
  
  if (s.data == 0) {
    return;
  }
  
  while (i < s.length) {
    if (SeriesGetInt(s, i) == 0) {
      SeriesSetInt(s, i, defaultValue);
    }
    i := i + 1;
  }
}

// Drop rows with NA in specific column
pub fn DataFrameDropNA(df: DataFrame, colName: int64): DataFrame {
  return DataFrameFilter(df, colName, OP_NE, 0);
}

// ============================================================================
// Statistics
// ============================================================================

// Sum of column
pub fn SeriesSum(s: Series): int64 {
  var sum: int64 := 0;
  var i: int64 := 0;
  while (i < s.length) {
    sum := sum + SeriesGetInt(s, i);
    i := i + 1;
  }
  return sum;
}

// Mean of column
pub fn SeriesMean(s: Series): int64 {
  if (s.length == 0) {
    return 0;
  }
  return SeriesSum(s) / s.length;
}

// Min of column
pub fn SeriesMin(s: Series): int64 {
  var i: int64 := 1;
  var mn: int64;
  
  if (s.length == 0) {
    return 0;
  }
  
  mn := SeriesGetInt(s, 0);
  while (i < s.length) {
    var val: int64 := SeriesGetInt(s, i);
    if (val < mn) {
      mn := val;
    }
    i := i + 1;
  }
  return mn;
}

// Max of column
pub fn SeriesMax(s: Series): int64 {
  var i: int64 := 1;
  var mx: int64;
  
  if (s.length == 0) {
    return 0;
  }
  
  mx := SeriesGetInt(s, 0);
  while (i < s.length) {
    var val: int64 := SeriesGetInt(s, i);
    if (val > mx) {
      mx := val;
    }
    i := i + 1;
  }
  return mx;
}

// Count non-zero values
pub fn SeriesCount(s: Series): int64 {
  var count: int64 := 0;
  var i: int64 := 0;
  while (i < s.length) {
    if (SeriesGetInt(s, i) != 0) {
      count := count + 1;
    }
    i := i + 1;
  }
  return count;
}

// Value counts (frequency of each value)
pub fn SeriesValueCounts(s: Series): DataFrame {
  var result: DataFrame := DataFrameNew();
  var values: int64 := mmap(0, 1024 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  var counts: int64 := mmap(0, 1024 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  var uniqueCount: int64 := 0;
  var i: int64 := 0;
  var j: int64;
  var val: int64;
  var found: int64;
  
  // Count occurrences
  while (i < s.length) {
    val := SeriesGetInt(s, i);
    found := 0;
    j := 0;
    while (j < uniqueCount) {
      if (peek8(values + j * 8) == val) {
        var c: int64 := peek8(counts + j * 8);
        poke8(counts + j * 8, c + 1);
        found := 1;
        break;
      }
      j := j + 1;
    }
    if (found == 0) {
      poke8(values + uniqueCount * 8, val);
      poke8(counts + uniqueCount * 8, 1);
      uniqueCount := uniqueCount + 1;
    }
    i := i + 1;
  }
  
  // Build result DataFrame
  DataFrameAddColumn(result, "value", COL_INT64);
  DataFrameAddColumn(result, "count", COL_INT64);
  
  i := 0;
  while (i < uniqueCount) {
    DataFrameAppendRow(result);
    DataFrameSetInt(result, "value", i, peek8(values + i * 8));
    DataFrameSetInt(result, "count", i, peek8(counts + i * 8));
    i := i + 1;
  }
  
  munmap(values, 1024 * 8);
  munmap(counts, 1024 * 8);
  
  return result;
}

// ============================================================================
// Print/Display
// ============================================================================

// Print DataFrame to stdout
pub fn DataFramePrint(df: DataFrame) {
  var i: int64 := 0;
  var j: int64 := 0;
  var s: Series;
  var val: int64;
  
  // Print column names
  PrintStr("| ");
  j := 0;
  while (j < df.colCount) {
    var name: int64 := peek8(df.columns + j * 16);
    if (name != 0) {
      PrintStr(name);
    } else {
      PrintStr("(unnamed)");
    }
    PrintStr(" | ");
    j := j + 1;
  }
  PrintStr("\n");
  
  // Print separator
  PrintStr("|");
  j := 0;
  while (j < df.colCount) {
    PrintStr("--------|");
    j := j + 1;
  }
  PrintStr("\n");
  
  // Print rows
  i := 0;
  while (i < df.rowCount) {
    PrintStr("| ");
    j := 0;
    while (j < df.colCount) {
      s := peek8(df.columns + j * 16 + 8);
      if (s.colType == COL_STRING) {
        var str: int64 := SeriesGetString(s, i);
        if (str != 0) {
          PrintStr(str);
        } else {
          PrintStr("NULL");
        }
      } else {
        val := SeriesGetInt(s, i);
        PrintInt(val);
      }
      PrintStr(" | ");
      j := j + 1;
    }
    PrintStr("\n");
    i := i + 1;
  }
  
  PrintStr("\n[");
  PrintInt(df.rowCount);
  PrintStr(" rows x ");
  PrintInt(df.colCount);
  PrintStr(" columns]\n");
}

// ============================================================================
// Float Support (f64 columns)
// ============================================================================

// Float data stored as int64 bit pattern (reinterpretation)
// f64 value stored as int64 bits in the series

// Set float value (stored as int64 bits)
pub fn DataFrameSetFloat(df: DataFrame, colName: int64, row: int64, value: int64) {
  var s: Series := DataFrameGetSeries(df, colName);
  if (s.data != 0) {
    SeriesSetInt(s, row, value);
  }
}

// Get float value (as int64 bits)
pub fn DataFrameGetFloat(df: DataFrame, colName: int64, row: int64): int64 {
  var s: Series := DataFrameGetSeries(df, colName);
  if (s.data == 0) {
    return 0;
  }
  return SeriesGetInt(s, row);
}

// Float series sum (using int64 representation)
// Note: This is approximate for small values
pub fn SeriesSumFloat(s: Series): int64 {
  var sum: int64 := 0;
  var i: int64 := 0;
  while (i < s.length) {
    sum := sum + SeriesGetInt(s, i);
    i := i + 1;
  }
  return sum;
}

// Float series mean
pub fn SeriesMeanFloat(s: Series): int64 {
  if (s.length == 0) {
    return 0;
  }
  return SeriesSumFloat(s) / s.length;
}

// ============================================================================
// Join/Merge
// ============================================================================

// Inner join two DataFrames on key columns
// Returns rows where key values match in both DataFrames
pub fn DataFrameJoinInner(left: DataFrame, leftKey: int64, right: DataFrame, rightKey: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var leftS: Series := DataFrameGetSeries(left, leftKey);
  var rightS: Series := DataFrameGetSeries(right, rightKey);
  var i: int64;
  var j: int64;
  var leftVal: int64;
  var rightVal: int64;
  var col: int64;
  var s: Series;
  var prefix: int64;
  
  // Add all columns from left with "left_" prefix
  i := 0;
  while (i < left.colCount) {
    var name: int64 := peek8(left.columns + i * 16);
    DataFrameAddColumn(result, name, COL_INT64);
    i := i + 1;
  }
  
  // Add all columns from right with "right_" prefix (skip key column)
  i := 0;
  while (i < right.colCount) {
    var name: int64 := peek8(right.columns + i * 16);
    if (name != rightKey) {
      DataFrameAddColumn(result, name, COL_INT64);
    }
    i := i + 1;
  }
  
  // Find matching rows
  i := 0;
  while (i < left.rowCount) {
    leftVal := SeriesGetInt(leftS, i);
    
    j := 0;
    while (j < right.rowCount) {
      rightVal := SeriesGetInt(rightS, j);
      
      if (leftVal == rightVal) {
        // Match found - add row
        DataFrameAppendRow(result);
        var newRow: int64 := result.rowCount - 1;
        
        // Copy left columns
        col := 0;
        while (col < left.colCount) {
          s := peek8(left.columns + col * 16 + 8);
          DataFrameSetInt(result, peek8(left.columns + col * 16), newRow, SeriesGetInt(s, i));
          col := col + 1;
        }
        
        // Copy right columns (skip key)
        col := 0;
        while (col < right.colCount) {
          var name: int64 := peek8(right.columns + col * 16);
          if (name != rightKey) {
            s := peek8(right.columns + col * 16 + 8);
            DataFrameSetInt(result, name, newRow, SeriesGetInt(s, j));
          }
          col := col + 1;
        }
      }
      
      j := j + 1;
    }
    
    i := i + 1;
  }
  
  return result;
}

// Left join: all rows from left, matching rows from right
pub fn DataFrameJoinLeft(left: DataFrame, leftKey: int64, right: DataFrame, rightKey: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var leftS: Series := DataFrameGetSeries(left, leftKey);
  var rightS: Series := DataFrameGetSeries(right, rightKey);
  var i: int64;
  var j: int64;
  var leftVal: int64;
  var rightVal: int64;
  var col: int64;
  var s: Series;
  var found: int64;
  
  // Add all columns from left
  i := 0;
  while (i < left.colCount) {
    DataFrameAddColumn(result, peek8(left.columns + i * 16), COL_INT64);
    i := i + 1;
  }
  
  // Add all columns from right (skip key)
  i := 0;
  while (i < right.colCount) {
    var name: int64 := peek8(right.columns + i * 16);
    if (name != rightKey) {
      DataFrameAddColumn(result, name, COL_INT64);
    }
    i := i + 1;
  }
  
  // All rows from left
  i := 0;
  while (i < left.rowCount) {
    DataFrameAppendRow(result);
    var newRow: int64 := result.rowCount - 1;
    
    // Copy left columns
    col := 0;
    while (col < left.colCount) {
      s := peek8(left.columns + col * 16 + 8);
      DataFrameSetInt(result, peek8(left.columns + col * 16), newRow, SeriesGetInt(s, i));
      col := col + 1;
    }
    
    // Try to find matching row in right
    leftVal := SeriesGetInt(leftS, i);
    found := 0;
    j := 0;
    while (j < right.rowCount) {
      rightVal := SeriesGetInt(rightS, j);
      if (leftVal == rightVal) {
        // Copy right columns
        col := 0;
        while (col < right.colCount) {
          var name: int64 := peek8(right.columns + col * 16);
          if (name != rightKey) {
            s := peek8(right.columns + col * 16 + 8);
            DataFrameSetInt(result, name, newRow, SeriesGetInt(s, j));
          }
          col := col + 1;
        end;
        found := 1;
        break;
      }
      j := j + 1;
    }
    
    i := i + 1;
  }
  
  return result;
}

// ============================================================================
// Pivot / Melt
// ============================================================================

// Pivot: convert long format to wide format
// df: DataFrame in long format
// indexCol: column to use as row index
// pivotCol: column whose values become new column names
// valueCol: column whose values fill the pivot table
// Returns pivoted DataFrame
pub fn DataFramePivot(df: DataFrame, indexCol: int64, pivotCol: int64, valueCol: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var indexS: Series := DataFrameGetSeries(df, indexCol);
  var pivotS: Series := DataFrameGetSeries(df, pivotCol);
  var valueS: Series := DataFrameGetSeries(df, valueCol);
  
  var uniqueIndices: int64 := mmap(0, 1024 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  var uniquePivots: int64 := mmap(0, 1024 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  var indexCount: int64 := 0;
  var pivotCount: int64 := 0;
  var i: int64;
  var j: int64;
  var found: int64;
  
  // Find unique index values
  i := 0;
  while (i < df.rowCount) {
    var val: int64 := SeriesGetInt(indexS, i);
    found := 0;
    j := 0;
    while (j < indexCount) {
      if (peek8(uniqueIndices + j * 8) == val) {
        found := 1;
        break;
      }
      j := j + 1;
    end;
    if (found == 0) {
      poke8(uniqueIndices + indexCount * 8, val);
      indexCount := indexCount + 1;
    }
    i := i + 1;
  }
  
  // Find unique pivot values
  i := 0;
  while (i < df.rowCount) {
    var val: int64 := SeriesGetInt(pivotS, i);
    found := 0;
    j := 0;
    while (j < pivotCount) {
      if (peek8(uniquePivots + j * 8) == val) {
        found := 1;
        break;
      }
      j := j + 1;
    end;
    if (found == 0) {
      poke8(uniquePivots + pivotCount * 8, val);
      pivotCount := pivotCount + 1;
    }
    i := i + 1;
  }
  
  // Add index column
  DataFrameAddColumn(result, indexCol, COL_INT64);
  
  // Add pivot columns
  j := 0;
  while (j < pivotCount) {
    // Create column name from pivot value
    var colName: int64 := mmap(0, 32, PROT_RW, MAP_ANON, FD_NONE, 0);
    var pivotVal: int64 := peek8(uniquePivots + j * 8);
    var pos: int64 := 0;
    var num: int64 := pivotVal;
    if (num < 0) { num := -num; }
    // Convert to string
    var tmp: int64 := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
    var tmpPos: int64 := 0;
    if (num == 0) {
      poke8(tmp, 48);
      tmpPos := 1;
    } else {
      while (num > 0) {
        poke8(tmp + tmpPos, 48 + (num - (num / 10) * 10));
        tmpPos := tmpPos + 1;
        num := num / 10;
      }
    }
    // Reverse
    while (tmpPos > 0) {
      tmpPos := tmpPos - 1;
      poke8(colName + pos, peek8(tmp + tmpPos));
      pos := pos + 1;
    }
    poke8(colName + pos, 0);
    munmap(tmp, 16);
    
    DataFrameAddColumn(result, colName, COL_INT64);
    j := j + 1;
  }
  
  // Fill pivoted data
  i := 0;
  while (i < indexCount) {
    DataFrameAppendRow(result);
    DataFrameSetInt(result, indexCol, i, peek8(uniqueIndices + i * 8));
    i := i + 1;
  }
  
  // Fill values
  var row: int64 := 0;
  while (row < df.rowCount) {
    var idxVal: int64 := SeriesGetInt(indexS, row);
    var pivVal: int64 := SeriesGetInt(pivotS, row);
    var valVal: int64 := SeriesGetInt(valueS, row);
    
    // Find row index
    i := 0;
    while (i < indexCount) {
      if (peek8(uniqueIndices + i * 8) == idxVal) {
        break;
      }
      i := i + 1;
    }
    
    // Find column index
    j := 0;
    while (j < pivotCount) {
      if (peek8(uniquePivots + j * 8) == pivVal) {
        break;
      }
      j := j + 1;
    end;
    
    // Set value (column 1 + j)
    DataFrameSetInt(result, peek8(result.columns + (1 + j) * 16), i, valVal);
    
    row := row + 1;
  }
  
  munmap(uniqueIndices, 1024 * 8);
  munmap(uniquePivots, 1024 * 8);
  
  return result;
}

// Melt: convert wide format to long format (unpivot)
// df: DataFrame in wide format
// idCols: column(s) to keep as identifiers
// valueCols: columns to melt into rows
// Returns melted DataFrame with columns: idCols + "variable" + "value"
pub fn DataFrameMelt(df: DataFrame, idCol: int64, valueColStart: int64, valueColEnd: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var i: int64;
  var j: int64;
  var col: int64;
  var idS: Series := DataFrameGetSeries(df, idCol);
  var s: Series;
  
  // Add id column
  DataFrameAddColumn(result, idCol, COL_INT64);
  DataFrameAddColumn(result, "variable", COL_INT64);
  DataFrameAddColumn(result, "value", COL_INT64);
  
  // For each row and each value column, create a row in result
  i := 0;
  while (i < df.rowCount) {
    col := valueColStart;
    while (col <= valueColEnd) {
      DataFrameAppendRow(result);
      var newRow: int64 := result.rowCount - 1;
      
      // Copy id value
      DataFrameSetInt(result, idCol, newRow, SeriesGetInt(idS, i));
      
      // Set variable name (column index as int)
      DataFrameSetInt(result, "variable", newRow, col);
      
      // Copy value
      s := peek8(df.columns + col * 16 + 8);
      DataFrameSetInt(result, "value", newRow, SeriesGetInt(s, i));
      
      col := col + 1;
    end;
    i := i + 1;
  }
  
  return result;
}

// ============================================================================
// Correlation / Covariance
// ============================================================================

// Pearson correlation between two series
// Returns correlation coefficient * 1000 (for integer precision)
pub fn SeriesCorr(s1: Series, s2: Series): int64 {
  var n: int64 := s1.length;
  var i: int64 := 0;
  var sumX: int64 := 0;
  var sumY: int64 := 0;
  var sumXY: int64 := 0;
  var sumX2: int64 := 0;
  var sumY2: int64 := 0;
  var x: int64;
  var y: int64;
  var num: int64;
  var denX: int64;
  var denY: int64;
  var den: int64;
  
  if (n == 0 || s2.length != n) {
    return 0;
  }
  
  // Calculate sums
  while (i < n) {
    x := SeriesGetInt(s1, i);
    y := SeriesGetInt(s2, i);
    sumX := sumX + x;
    sumY := sumY + y;
    sumXY := sumXY + (x * y);
    sumX2 := sumX2 + (x * x);
    sumY2 := sumY2 + (y * y);
    i := i + 1;
  }
  
  // Pearson correlation: r = (n*Σxy - Σx*Σy) / sqrt((n*Σx² - (Σx)²) * (n*Σy² - (Σy)²))
  num := n * sumXY - sumX * sumY;
  denX := n * sumX2 - sumX * sumX;
  denY := n * sumY2 - sumY * sumY;
  
  if (denX <= 0 || denY <= 0) {
    return 0;
  }
  
  // Integer square root approximation
  var sqrtX: int64 := denX;
  var sqrtY: int64 := denY;
  var tmp: int64;
  
  // Newton's method for sqrt(denX)
  tmp := (sqrtX + 1) / 2;
  while (tmp < sqrtX) {
    sqrtX := tmp;
    tmp := (sqrtX + denX / sqrtX) / 2;
  }
  
  // Newton's method for sqrt(denY)
  tmp := (sqrtY + 1) / 2;
  while (tmp < sqrtY) {
    sqrtY := tmp;
    tmp := (sqrtY + denY / sqrtY) / 2;
  }
  
  den := sqrtX * sqrtY;
  if (den == 0) {
    return 0;
  }
  
  // Return correlation * 1000
  return (num * 1000) / den;
}

// Covariance between two series
pub fn SeriesCov(s1: Series, s2: Series): int64 {
  var n: int64 := s1.length;
  var i: int64 := 0;
  var meanX: int64 := SeriesMean(s1);
  var meanY: int64 := SeriesMean(s2);
  var sum: int64 := 0;
  
  if (n == 0 || s2.length != n) {
    return 0;
  }
  
  while (i < n) {
    sum := sum + (SeriesGetInt(s1, i) - meanX) * (SeriesGetInt(s2, i) - meanY);
    i := i + 1;
  }
  
  return sum / n;
}

// Describe: summary statistics for a series
// Returns DataFrame with: count, mean, std, min, max
pub fn SeriesDescribe(s: Series): DataFrame {
  var result: DataFrame := DataFrameNew();
  var n: int64 := s.length;
  var mean: int64 := SeriesMean(s);
  var variance: int64;
  var i: int64;
  var diff: int64;
  var sumSq: int64;
  
  DataFrameAddColumn(result, "stat", COL_STRING);
  DataFrameAddColumn(result, "value", COL_INT64);
  
  // Count
  DataFrameAppendRow(result);
  DataFrameSetString(result, "stat", 0, "count");
  DataFrameSetInt(result, "value", 0, n);
  
  // Mean
  DataFrameAppendRow(result);
  DataFrameSetString(result, "stat", 1, "mean");
  DataFrameSetInt(result, "value", 1, mean);
  
  // Variance
  sumSq := 0;
  i := 0;
  while (i < n) {
    diff := SeriesGetInt(s, i) - mean;
    sumSq := sumSq + (diff * diff);
    i := i + 1;
  end;
  if (n > 0) {
    variance := sumSq / n;
  }
  
  // Std (approximate sqrt)
  var std: int64 := variance;
  if (std > 0) {
    var tmp: int64 := (std + 1) / 2;
    while (tmp < std) {
      std := tmp;
      tmp := (std + variance / std) / 2;
    }
  }
  
  DataFrameAppendRow(result);
  DataFrameSetString(result, "stat", 2, "std");
  DataFrameSetInt(result, "value", 2, std);
  
  // Min
  DataFrameAppendRow(result);
  DataFrameSetString(result, "stat", 3, "min");
  DataFrameSetInt(result, "value", 3, SeriesMin(s));
  
  // Max
  DataFrameAppendRow(result);
  DataFrameSetString(result, "stat", 4, "max");
  DataFrameSetInt(result, "value", 4, SeriesMax(s));
  
  return result;
}

// ============================================================================
// Multi-Column GroupBy
// ============================================================================

// Multi-column GroupBy result
pub type MultiGroupByResult = struct {
  df: DataFrame;
  keyCols: int64;       // Pointer to array of column name pointers
  keyColCount: int64;
  groups: int64;        // Pointer to group key values (2D array)
  groupRows: int64;
  groupCount: int64;
};

// GroupBy on multiple columns
pub fn DataFrameGroupByMulti(df: DataFrame, keyCols: int64, keyColCount: int64): MultiGroupByResult {
  var gb: MultiGroupByResult;
  var i: int64 := 0;
  var j: int64;
  var k: int64;
  var keyValues: int64 := mmap(0, 8, PROT_RW, MAP_ANON, FD_NONE, 0);  // Temp array for current row keys
  var found: int64;
  var match: int64;
  
  gb.df := df;
  gb.keyCols := keyCols;
  gb.keyColCount := keyColCount;
  gb.groups := mmap(0, 1024 * keyColCount * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  gb.groupRows := mmap(0, 1024 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  gb.groupCount := 0;
  
  // For each row, check if key combination exists
  while (i < df.rowCount) {
    // Get key values for this row
    j := 0;
    while (j < keyColCount) {
      var colName: int64 := peek8(keyCols + j * 8);
      var s: Series := DataFrameGetSeries(df, colName);
      // Store in temporary location
      j := j + 1;
    end;
    
    // Check if this key combination exists
    found := 0;
    j := 0;
    while (j < gb.groupCount) {
      match := 1;
      k := 0;
      while (k < keyColCount) {
        var colName: int64 := peek8(keyCols + k * 8);
        var s: Series := DataFrameGetSeries(df, colName);
        var val: int64 := SeriesGetInt(s, i);
        var groupVal: int64 := peek8(gb.groups + (j * keyColCount + k) * 8);
        if (val != groupVal) {
          match := 0;
          break;
        }
        k := k + 1;
      end;
      if (match == 1) {
        found := 1;
        break;
      }
      j := j + 1;
    end;
    
    if (found == 0) {
      // New group
      k := 0;
      while (k < keyColCount) {
        var colName: int64 := peek8(keyCols + k * 8);
        var s: Series := DataFrameGetSeries(df, colName);
        poke8(gb.groups + (gb.groupCount * keyColCount + k) * 8, SeriesGetInt(s, i));
        k := k + 1;
      end;
      
      var rows: int64 := mmap(0, 1024 * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
      poke8(rows, i);
      poke8(rows - 8, 1);
      poke8(gb.groupRows + gb.groupCount * 8, rows);
      gb.groupCount := gb.groupCount + 1;
    } else {
      var rows: int64 := peek8(gb.groupRows + j * 8);
      var count: int64 := peek8(rows - 8);
      poke8(rows + count * 8, i);
      poke8(rows - 8, count + 1);
    end;
    
    i := i + 1;
  }
  
  return gb;
}

// Multi-column GroupBy aggregation: count
pub fn GroupByMultiCount(gb: MultiGroupByResult): DataFrame {
  var result: DataFrame := DataFrameNew();
  var i: int64 := 0;
  var j: int64;
  var rows: int64;
  var count: int64;
  
  // Add key columns
  j := 0;
  while (j < gb.keyColCount) {
    DataFrameAddColumn(result, peek8(gb.keyCols + j * 8), COL_INT64);
    j := j + 1;
  end;
  DataFrameAddColumn(result, "count", COL_INT64);
  
  while (i < gb.groupCount) {
    DataFrameAppendRow(result);
    var newRow: int64 := result.rowCount - 1;
    
    // Set key values
    j := 0;
    while (j < gb.keyColCount) {
      var val: int64 := peek8(gb.groups + (i * gb.keyColCount + j) * 8);
      DataFrameSetInt(result, peek8(gb.keyCols + j * 8), newRow, val);
      j := j + 1;
    end;
    
    rows := peek8(gb.groupRows + i * 8);
    count := peek8(rows - 8);
    DataFrameSetInt(result, "count", newRow, count);
    
    i := i + 1;
  end;
  
  return result;
}
