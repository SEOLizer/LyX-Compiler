};

// Create boolean series from comparison
pub fn SeriesGreaterThan(s: Series, value: int64): BoolSeries {
  var bs: BoolSeries;
  bs.data := mmap(0, s.length * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  bs.length := s.length;
  bs.name := s.name;
  var i: int64 := 0;
  while (i < s.length) {
    if (SeriesGetInt(s, i) > value) {
      poke8(bs.data + i * 8, 1);
    } else {
      poke8(bs.data + i * 8, 0);
    }
    i := i + 1;
  }
  return bs;
}

