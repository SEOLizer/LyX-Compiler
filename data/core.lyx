// Explode: expand a column (simplified: duplicate row for each value)
pub fn DataFrameExplode(df: DataFrame, colName: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var s: Series := DataFrameGetSeries(df, colName);
  var i: int64;
  var j: int64;
  
  // Add all columns
  j := 0;
  while (j < df.colCount) {
    DataFrameAddColumn(result, peek8(df.columns + j * 16), COL_INT64);
    j := j + 1;
  }
  
  // Copy rows (each row once - full explode would need array columns)
  i := 0;
  while (i < df.rowCount) {
    DataFrameAppendRow(result);
    j := 0;
    while (j < df.colCount) {
      var srcS: Series := peek8(df.columns + j * 16 + 8);
      DataFrameSetInt(result, peek8(result.columns + j * 16), i, SeriesGetInt(srcS, i));
      j := j + 1;
    }
    i := i + 1;
  }
  
  return result;
}

