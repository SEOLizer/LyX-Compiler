// Apply (simplified - operations on columns)
// ============================================================================

// Apply: transform column by adding constant
pub fn DataFrameApplyAdd(df: DataFrame, colName: int64, offset: int64): Series {
  var s: Series := DataFrameGetSeries(df, colName);
  return SeriesTransformAdd(s, offset);
}

// Apply: transform column by multiplying
pub fn DataFrameApplyMul(df: DataFrame, colName: int64, factor: int64): Series {
  var s: Series := DataFrameGetSeries(df, colName);
  return SeriesTransformMul(s, factor);
}

// Apply: transform column by normalizing
pub fn DataFrameApplyNormalize(df: DataFrame, colName: int64): Series {
  var s: Series := DataFrameGetSeries(df, colName);
  return SeriesTransformNormalize(s);
}

// Apply: compute absolute values
pub fn SeriesApplyAbs(s: Series): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var i: int64 := 0;
  result.length := s.length;
  while (i < s.length) {
    var val: int64 := SeriesGetInt(s, i);
    if (val < 0) { val := -val; }
    SeriesSetInt(result, i, val);
    i := i + 1;
  }
  return result;
}

// Apply: square all values
pub fn SeriesApplySquare(s: Series): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var i: int64 := 0;
  result.length := s.length;
  while (i < s.length) {
    var val: int64 := SeriesGetInt(s, i);
    SeriesSetInt(result, i, val * val);
    i := i + 1;
  }
  return result;
}

// Apply: compute sqrt (integer approximation)
pub fn SeriesApplySqrt(s: Series): Series {
  var result: Series := SeriesNewInt64(s.name, s.length);
  var i: int64 := 0;
  result.length := s.length;
  while (i < s.length) {
    var val: int64 := SeriesGetInt(s, i);
    if (val < 0) { val := 0; }
    // Integer sqrt
    var x: int64 := val;
    if (x > 0) {
      var x1: int64 := x + 1;
      var y: int64 := x1 / 2;
      while (y < x) {
        x := y;
        var vdx: int64 := val / x;
        var xvdx: int64 := x + vdx;
        y := xvdx / 2;
      }
    }
    SeriesSetInt(result, i, x);
    i := i + 1;
  }
  return result;
}

