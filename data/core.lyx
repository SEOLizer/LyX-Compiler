// Lyx Data Library - Core Module
// Pandas-like data analysis structures for Lyx
//
// This module provides:
// - Series: 1D typed array with optional labels
// - DataFrame: 2D table with named columns
// - Index: Row/column label management
// - Core operations: Select, Filter, Slice, AddColumn, DropColumn, GroupBy
//
// Design:
// - Data is stored as int64 arrays (numbers) or pchar arrays (strings)
// - Column names are pchar pointers
// - Row indices are int64 or pchar
// - Missing values: 0 for numbers, NULL for strings
//
// Usage:
//   import data.core;
//   var df: DataFrame := DataFrameNew();
//   DataFrameAddColumn(df, "name", COL_STRING);
//   DataFrameAddColumn(df, "age", COL_INT64);
//   DataFrameAppendRow(df);
//   DataFrameSetInt(df, "age", 0, 25);
//   var filtered: DataFrame := DataFrameFilter(df, "age", OP_GT, 20);

unit data.core;

// ============================================================================
// Type Constants
// ============================================================================

pub con COL_INT64: int64 := 1;
pub con COL_FLOAT: int64 := 2;
pub con COL_STRING: int64 := 3;
pub con COL_BOOL: int64 := 4;

// Comparison operators
pub con OP_EQ: int64 := 1;   // ==
pub con OP_NE: int64 := 2;   // !=
pub con OP_LT: int64 := 3;   // <
pub con OP_LE: int64 := 4;   // <=
pub con OP_GT: int64 := 5;   // >
pub con OP_GE: int64 := 6;   // >=

// Join types
pub con JOIN_INNER: int64 := 1;
pub con JOIN_LEFT: int64 := 2;
pub con JOIN_RIGHT: int64 := 3;
pub con JOIN_OUTER: int64 := 4;

// ============================================================================
// Series - 1D typed array with optional labels
// ============================================================================

// Series structure (fat pointer to heap data)
pub type Series = struct {
  data: int64;          // Pointer to data array (int64*)
  labels: int64;        // Pointer to label array (pchar*), 0 if none
  length: int64;        // Number of elements
  colType: int64;       // COL_INT64, COL_FLOAT, COL_STRING, COL_BOOL
  name: int64;          // Pointer to column name (pchar)
};

// Create new int64 series
pub fn SeriesNewInt64(name: int64, capacity: int64): Series {
  var s: Series;
  s.data := mmap(0, capacity * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  s.labels := 0;
  s.length := 0;
  s.colType := COL_INT64;
  s.name := name;
  return s;
}

// Create new string series
pub fn SeriesNewString(name: int64, capacity: int64): Series {
  var s: Series;
  s.data := mmap(0, capacity * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  s.labels := 0;
  s.length := 0;
  s.colType := COL_STRING;
  s.name := name;
  return s;
}

// Get int value at index
pub fn SeriesGetInt(s: Series, idx: int64): int64 {
  if (idx < 0 || idx >= s.length) {
    return 0;
  }
  return peek8(s.data + idx * 8);
}

// Set int value at index
pub fn SeriesSetInt(s: Series, idx: int64, value: int64) {
  if (idx >= 0 && idx < s.length) {
    poke8(s.data + idx * 8, value);
  }
}

// Get string value at index
pub fn SeriesGetString(s: Series, idx: int64): int64 {
  if (idx < 0 || idx >= s.length) {
    return 0;
  }
  return peek8(s.data + idx * 8);
}

// Set string value at index
pub fn SeriesSetString(s: Series, idx: int64, value: int64) {
  if (idx >= 0 && idx < s.length) {
    poke8(s.data + idx * 8, value);
  }
}

// Get label at index
pub fn SeriesGetLabel(s: Series, idx: int64): int64 {
  if (s.labels == 0 || idx < 0 || idx >= s.length) {
    return 0;
  }
  return peek8(s.labels + idx * 8);
}

// Set label at index
pub fn SeriesSetLabel(s: Series, idx: int64, label: int64) {
  if (s.labels != 0 && idx >= 0 && idx < s.length) {
    poke8(s.labels + idx * 8, label);
  }
}

// Append value to series (resize if needed)
pub fn SeriesAppendInt(s: Series, value: int64) {
  SeriesSetInt(s, s.length, value);
  s.length := s.length + 1;
}

// Append string to series
pub fn SeriesAppendString(s: Series, value: int64) {
  SeriesSetString(s, s.length, value);
  s.length := s.length + 1;
}

// ============================================================================
// DataFrame - 2D table with named columns
// ============================================================================

// Column descriptor
pub type Column = struct {
  name: int64;          // Column name (pchar)
  series: Series;       // Series data
};

// DataFrame structure
pub type DataFrame = struct {
  columns: int64;       // Pointer to Column array (each 16 bytes)
  colCount: int64;      // Number of columns
  rowCount: int64;      // Number of rows
  colCapacity: int64;   // Column capacity
  rowCapacity: int64;   // Row capacity
  index: int64;         // Pointer to index labels (pchar*), 0 if none
  indexName: int64;     // Pointer to index name (pchar)
  hasIndex: int64;      // 1 if index is set
};

// Create new empty DataFrame
pub fn DataFrameNew(): DataFrame {
  var df: DataFrame;
  df.columns := mmap(0, 16 * 16, PROT_RW, MAP_ANON, FD_NONE, 0);
  df.colCount := 0;
  df.rowCount := 0;
  df.colCapacity := 16;
  df.rowCapacity := 1024;
  df.index := 0;
  df.indexName := 0;
  df.hasIndex := 0;
  return df;
}

// Get column index by name (-1 if not found)
pub fn DataFrameColIndex(df: DataFrame, name: int64): int64 {
  var i: int64 := 0;
  var colName: int64;
  
  while (i < df.colCount) {
    colName := peek8(df.columns + i * 16);  // Column name at offset 0
    if (colName != 0 && name != 0) {
      // Compare strings
      var j: int64 := 0;
      var match: int64 := 1;
      while (j < 256) {
        var c1: int64 := peek8(colName + j);
        var c2: int64 := peek8(name + j);
        if (c1 != c2) { match := 0; break; }
        if (c1 == 0) { break; }
        j := j + 1;
      }
      if (match == 1) {
        return i;
      }
    }
    i := i + 1;
  }
  
  return -1;
}

// Get Series for column name
pub fn DataFrameGetSeries(df: DataFrame, name: int64): Series {
  var s: Series;
  var colIdx: int64;
  
  s.data := 0;
  s.labels := 0;
  s.length := 0;
  s.colType := 0;
  s.name := 0;
  
  colIdx := DataFrameColIndex(df, name);
  if (colIdx < 0) {
    return s;
  }
  
  // Series pointer at column[colIdx].series
  return peek8(df.columns + colIdx * 16 + 8);
}

// Add column to DataFrame
pub fn DataFrameAddColumn(df: DataFrame, name: int64, colType: int64) {
  var s: Series;
  
  if (df.colCount >= df.colCapacity) {
    return;  // Capacity exceeded
  }
  
  // Create series
  if (colType == COL_STRING) {
    s := SeriesNewString(name, df.rowCapacity);
  } else {
    s := SeriesNewInt64(name, df.colCapacity);
  }
  
  // Set existing rows to 0/NULL
  s.length := df.rowCount;
  
  // Store column
  poke8(df.columns + df.colCount * 16, name);     // Column name
  poke8(df.columns + df.colCount * 16 + 8, s);     // Series
  
  df.colCount := df.colCount + 1;
}

// Add row to DataFrame
pub fn DataFrameAppendRow(df: DataFrame) {
  var i: int64 := 0;
  var s: Series;
  
  while (i < df.colCount) {
    s := peek8(df.columns + i * 16 + 8);
    if (s.colType == COL_STRING) {
      SeriesAppendString(s, 0);  // NULL
    } else {
      SeriesAppendInt(s, 0);     // 0
    }
    i := i + 1;
  }
  
  df.rowCount := df.rowCount + 1;
}

// Get int value from DataFrame
pub fn DataFrameGetInt(df: DataFrame, colName: int64, row: int64): int64 {
  var s: Series := DataFrameGetSeries(df, colName);
  if (s.data == 0) {
    return 0;
  }
  return SeriesGetInt(s, row);
}

// Set int value in DataFrame
pub fn DataFrameSetInt(df: DataFrame, colName: int64, row: int64, value: int64) {
  var s: Series := DataFrameGetSeries(df, colName);
  if (s.data != 0) {
    SeriesSetInt(s, row, value);
  }
}

// Get string value from DataFrame
pub fn DataFrameGetString(df: DataFrame, colName: int64, row: int64): int64 {
  var s: Series := DataFrameGetSeries(df, colName);
  if (s.data == 0) {
    return 0;
  }
  return SeriesGetString(s, row);
}

// Set string value in DataFrame
pub fn DataFrameSetString(df: DataFrame, colName: int64, row: int64, value: int64) {
  var s: Series := DataFrameGetSeries(df, colName);
  if (s.data != 0) {
    SeriesSetString(s, row, value);
  }
}

// Get column type
pub fn DataFrameGetColumnType(df: DataFrame, colName: int64): int64 {
  var s: Series := DataFrameGetSeries(df, colName);
  return s.colType;
}

// ============================================================================
// Selection and Filtering
// ============================================================================

// Compare int value
pub fn CompareInt(value: int64, op: int64, target: int64): int64 {
  if (op == OP_EQ) { return value == target; }
  if (op == OP_NE) { return value != target; }
  if (op == OP_LT) { return value < target; }
  if (op == OP_LE) { return value <= target; }
  if (op == OP_GT) { return value > target; }
  if (op == OP_GE) { return value >= target; }
  return 0;
}

// Filter DataFrame by column value
// Returns new DataFrame with rows where colName op value
pub fn DataFrameFilter(df: DataFrame, colName: int64, op: int64, value: int64): DataFrame {
  var result: DataFrame := DataFrameNew();
  var i: int64 := 0;
  var j: int64 := 0;
  var colIdx: int64;
  var srcSeries: Series;
  var val: int64;
  
  // Add all columns to result
  while (j < df.colCount) {
    var name: int64 := peek8(df.columns + j * 16);
    var srcS: Series := peek8(df.columns + j * 16 + 8);
    DataFrameAddColumn(result, name, srcS.colType);
    j := j + 1;
  }
  
  // Find filter column
  colIdx := DataFrameColIndex(df, colName);
  if (colIdx < 0) {
  return result;
}

// ============================================================================
// String Index Labels
// ============================================================================

// Set string labels for Series
pub fn SeriesSetLabels(s: Series, labels: int64) {
  // labels is a pchar* array (array of pchar pointers)
  s.labels := labels;
}

// Get string label at index
pub fn SeriesGetLabelString(s: Series, idx: int64): int64 {
  if (s.labels == 0 || idx < 0 || idx >= s.length) {
    return 0;
  }
  return peek8(s.labels + idx * 8);
}

// Set index labels for DataFrame
// labels: array of pchar pointers
// name: index name
pub fn DataFrameSetIndex(df: DataFrame, labels: int64, name: int64) {
  df.index := labels;
  df.indexName := name;
  df.hasIndex := 1;
}

// Set index from column values (set_index)
// colName: column whose values become the index
// The column is NOT removed from the DataFrame
pub fn DataFrameSetIndexFromColumn(df: DataFrame, colName: int64) {
  var s: Series := DataFrameGetSeries(df, colName);
  var i: int64 := 0;
  
  if (s.data == 0) {
    return;
  }
  
  // Allocate index labels array
  df.index := mmap(0, df.rowCount * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  if (df.index == 0) {
    return;
  }
  
  // Copy column values as index labels
  if (s.colType == COL_STRING) {
    // Copy string pointers
    while (i < df.rowCount) {
      poke8(df.index + i * 8, SeriesGetString(s, i));
      i := i + 1;
    end;
  } else {
    // Convert int values to string labels
    while (i < df.rowCount) {
      var val: int64 := SeriesGetInt(s, i);
      var label: int64 := mmap(0, 32, PROT_RW, MAP_ANON, FD_NONE, 0);
      var pos: int64 := 0;
      var num: int64 := val;
      var isNeg: int64 := 0;
      
      if (num < 0) {
        isNeg := 1;
        num := -num;
      }
      
      if (num == 0) {
        poke8(label, 48);
        pos := 1;
      } else {
        var tmp: int64 := mmap(0, 16, PROT_RW, MAP_ANON, FD_NONE, 0);
        var tmpPos: int64 := 0;
        while (num > 0) {
          poke8(tmp + tmpPos, 48 + (num - (num / 10) * 10));
          tmpPos := tmpPos + 1;
          num := num / 10;
        end;
        while (tmpPos > 0) {
          tmpPos := tmpPos - 1;
          poke8(label + pos, peek8(tmp + tmpPos));
          pos := pos + 1;
        end;
        munmap(tmp, 16);
      end;
      
      poke8(label + pos, 0);
      poke8(df.index + i * 8, label);
      i := i + 1;
    end;
  }
  
  df.indexName := colName;
  df.hasIndex := 1;
}

// Reset index to numeric (0, 1, 2, ...)
pub fn DataFrameResetIndex(df: DataFrame) {
  var i: int64 := 0;
  
  // Free old index labels
  if (df.index != 0) {
    munmap(df.index, df.rowCount * 8);
    df.index := 0;
  end;
  
  df.indexName := 0;
  df.hasIndex := 0;
}

// Get index label at row
pub fn DataFrameGetIndexLabel(df: DataFrame, row: int64): int64 {
  if (df.hasIndex == 0 || df.index == 0 || row < 0 || row >= df.rowCount) {
    return 0;
  }
  return peek8(df.index + row * 8);
}

// Set index label at row
pub fn DataFrameSetIndexLabel(df: DataFrame, row: int64, label: int64) {
  if (df.hasIndex == 1 && df.index != 0 && row >= 0 && row < df.rowCount) {
    poke8(df.index + row * 8, label);
  }
}

// Get index name
pub fn DataFrameGetIndexName(df: DataFrame): int64 {
  return df.indexName;
}

// Has index?
pub fn DataFrameHasIndex(df: DataFrame): int64 {
  return df.hasIndex;
}

// Find row by index label
pub fn DataFrameIndexLookup(df: DataFrame, label: int64): int64 {
  if (df.hasIndex == 0 || df.index == 0) {
    return -1;
  }
  
  var i: int64 := 0;
  while (i < df.rowCount) {
    var idx: int64 := peek8(df.index + i * 8);
    // Compare strings
    var match: int64 := 1;
    var j: int64 := 0;
    while (j < 256) {
      var c1: int64 := peek8(idx + j);
      var c2: int64 := peek8(label + j);
      if (c1 != c2) {
        match := 0;
        break;
      end;
      if (c1 == 0) { break; }
      j := j + 1;
    end;
    if (match == 1) {
      return i;
    end;
    i := i + 1;
  end;
  
  return -1;
}

// Get value by index label
pub fn DataFrameGetIntByLabel(df: DataFrame, colName: int64, label: int64): int64 {
  var row: int64 := DataFrameIndexLookup(df, label);
  if (row < 0) {
    return 0;
  end;
  return DataFrameGetInt(df, colName, row);
}

// Set value by index label
pub fn DataFrameSetIntByLabel(df: DataFrame, colName: int64, label: int64, value: int64) {
  var row: int64 := DataFrameIndexLookup(df, label);
  if (row >= 0) {
    DataFrameSetInt(df, colName, row, value);
  end;
}
  
  // Create index array [0, 1, 2, ...]
  indices := mmap(0, df.rowCount * 8, PROT_RW, MAP_ANON, FD_NONE, 0);
  i := 0;
  while (i < df.rowCount) {
    poke8(indices + i * 8, i);
    i := i + 1;
  }
  
  // Insertion sort on indices
  i := 1;
  while (i < df.rowCount) {
    key := SeriesGetInt(s, peek8(indices + i * 8));
    keyIdx := peek8(indices + i * 8);
    j := i - 1;
    while (j >= 0 && SeriesGetInt(s, peek8(indices + j * 8)) > key) {
      poke8(indices + (j + 1) * 8, peek8(indices + j * 8));
      j := j - 1;
    end;
    poke8(indices + (j + 1) * 8, keyIdx);
    i := i + 1;
  end;
  
  // Copy rows in sorted order
  i := 0;
  while (i < df.rowCount) {
    DataFrameAppendRow(result);
    var srcIdx: int64 := peek8(indices + i * 8);
    j := 0;
    while (j < df.colCount) {
      srcS := peek8(df.columns + j * 16 + 8);
      DataFrameSetInt(result, peek8(result.columns + j * 16), i, SeriesGetInt(srcS, srcIdx));
      j := j + 1;
    end;
