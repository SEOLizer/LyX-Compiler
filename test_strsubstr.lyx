// Test StrSubstr directly (not StrSub which is a builtin in S0)
fn main(): int64 {
  // Create source string
  var src: int64 := mmap(0, 64, 3, 34, -1, 0);
  
  // Put "Hello World" in it
  poke8(src + 0, 72);  // H
  poke8(src + 1, 101); // e
  poke8(src + 2, 108); // l
  poke8(src + 3, 108); // l
  poke8(src + 4, 111); // o
  poke8(src + 5, 32);  // space
  poke8(src + 6, 87);  // W
  poke8(src + 7, 111); // o
  poke8(src + 8, 114); // r
  poke8(src + 9, 108); // l
  poke8(src + 10, 100); // d
  poke8(src + 11, 0);
  
  // Test StrSubstr - different name so it won't be the builtin
  var sub: int64 := StrSubstr(src, 6, 5);  // "World"
  
  PrintStr("StrSubstr result: ");
  var i: int64 := 0;
  while i < 5 {
    var c: int64 := peek8(sub + i);
    PrintInt(c);
    PrintStr(" ");
    i := i + 1;
  }
  PrintStr("\n");
  
  munmap(src, 64);
  return 0;
}